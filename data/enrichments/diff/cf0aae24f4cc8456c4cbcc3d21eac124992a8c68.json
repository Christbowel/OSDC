s a dev override due to","+\t\t\t// its presence in the ProviderDevOverrides map.","+\t\t\tProviderDevOverrides: map[addrs.Provider]getproviders.PackageLocalDir{","+\t\t\t\tmockProviderAddress: \".\",","+\t\t\t},","+\t\t}","+","+\t\t// Make Terraform believe that we already have version 1.2.3 installed.","+\t\tinstallFakeProviderPackages(t, &m, map[string][]string{","+\t\t\t\"test\": {\"1.2.3\"},","+\t\t})","+\t\t// Create a dependency lock file describing the hashicorp/test provider at version 1.2.3, to simulate a previous init with that version.","+\t\tlocks := depsfile.NewLocks()","+\t\tlocks.SetProvider(","+\t\t\taddrs.NewDefaultProvider(\"test\"),","+\t\t\tgetproviders.MustParseVersion(\"1.2.3\"),","+\t\t\tgetproviders.MustParseVersionConstraints(\"> 1.0.0\"),","+\t\t\t[]getproviders.Hash{","+\t\t\t\tgetproviders.HashScheme1.New(\"wlbEC2mChQZ2hhgUhl6SeVLPP7fMqOFUZAQhQ9GIIno=\"),","+\t\t\t},","+\t\t)","+\t\tif err := depsfile.SaveLocksToFile(locks, \".terraform.lock.hcl\"); err != nil {","+\t\t\tt.Fatalf(\"failed to write provider locks file: %s\", err)","+\t\t}","+","+\t\tc := &InitCommand{","+\t\t\tMeta: m,","+\t\t}","+","+\t\targs := []string{","+\t\t\t\"-upgrade=true\",","+\t\t\t\"-enable-pluggable-state-storage-experiment\",","+\t\t}","+\t\tcode := c.Run(args)","+\t\tif code != 0 {","+\t\t\tt.Fatalf(\"expected code 0, but got code %d. \\nOutput:\\n%s\", code, done(t).All())","+\t\t}","+","+\t\t// Assert that no providers were upgraded.","+\t\t//","+\t\t// Unlike other test scenarios, \"test\" v9.9.9 will not be installed in the cache.","+\t\t// This is because the installation process skips installing providers that are","+\t\t// dev_overrides. That logic is used in both upgrade and non-upgrade operations.","+\t\tcacheDir := m.providerLocalCacheDir()","+\t\tgotPackages := cacheDir.AllAvailablePackages()","+\t\twantPackages := map[addrs.Provider][]providercache.CachedProvider{","+\t\t\tmockProviderAddress: {","+\t\t\t\t// No v9.9.9 entry","+\t\t\t\t{","+\t\t