tcome so later entries with the same RepoID skip that load.","+\t\t_, jobID, ok := status.ParseGiteaActionsTargetURL(ctx)","+\t\trepoByID[status.RepoID] = status.Repo","+\t\tif ok {","+\t\t\tstatusByJobID[jobID] = status","+\t\t}","+\t}","+\tif len(statusByJobID) == 0 {","+\t\treturn nil","+\t}","+\tjobs := make(map[int64]*actions_model.ActionRunJob, len(statusByJobID))","+\tif err := db.GetEngine(ctx).In(\"id\", slices.Collect(maps.Keys(statusByJobID))).Cols(\"id\", \"status\").Find(&jobs); err != nil {","+\t\tlog.Error(\"db.Find: failed to find action run jobs: %v\", err)","+\t\treturn nil","+\t}","+\tinfo := make(CommitActionsStatusMap, len(jobs))","+\tfor jobID, status := range statusByJobID {","+\t\tif job, ok := jobs[jobID]; ok {","+\t\t\tinfo[status.ID] = job.Status","+\t\t}","+\t}","+\treturn info","+}"],"additions":70,"deletions":0,"truncated":false},{"path":"modules/templates/util_actions.go","lines":["@@ -0,0 +1,23 @@","+// Copyright 2026 The Gitea Authors. All rights reserved.","+// SPDX-License-Identifier: MIT","+","+package templates","+","+import (","+\t\"context\"","+","+\tgit_model \"code.gitea.io/gitea/models/git\"","+\tactions_module \"code.gitea.io/gitea/modules/actions\"","+)","+","+type ActionsUtils struct {","+\tctx context.Context","+}","+","+func NewActionsUtils(ctx context.Context) *ActionsUtils {","+\treturn &ActionsUtils{ctx: ctx}","+}","+","+func (a *ActionsUtils) CommitStatusesToActionsStatuses(statuses []*git_model.CommitStatus) actions_module.CommitActionsStatusMap {","+\treturn actions_module.GetCommitActionsStatusMap(a.ctx, statuses)","+}"],"additions":23,"deletions":0,"truncated":false},{"path":"routers/api/actions/artifactsv4.go","lines":["@@ -104,7 +104,6 @@ import ("," "," \tactions_model \"code.gitea.io/gitea/models/actions\""," \t\"code.gitea.io/gitea/models/db\"","-\t\"code.gitea.io/gitea/modules/actions\""," \t\"code.gitea.io/gitea/modules/httplib\""," \t\"code.gitea.io/gitea/modules/log\""," \t\"code.gitea.io/gitea/modules/