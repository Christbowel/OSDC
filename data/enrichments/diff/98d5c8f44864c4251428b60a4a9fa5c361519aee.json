mbed query\", \"err\", err)","-\t\treturn nil, status.Error(codes.Internal, \"embed query\")","+\tif err := s.checkVectorSearchRateLimit(ctx, req.Key.Namespace); err != nil {","+\t\treturn nil, err"," \t}","-\tif len(out.Embeddings) != 1 || len(out.Embeddings[0].Dense) == 0 {","-\t\ts.log.Error(\"vector search: embedder returned no vectors\")","-\t\treturn nil, status.Error(codes.Internal, \"embed query: empty result\")","+","+\tdense, err := s.embedVectorSearchQuery(ctx, req.Key.Namespace, req.Query)","+\tif err != nil {","+\t\treturn nil, err"," \t}"," "," \tresults, err := s.vectorBackend.Search(ctx,"," \t\treq.Key.Namespace, s.embedder.Model, req.Key.Resource,","-\t\tout.Embeddings[0].Dense, limit, translateVectorSearchFilters(req.Filters)...)","+\t\tdense, limit, translateVectorSearchFilters(req.Filters)...)"," \tif err != nil {"," \t\ts.log.Error(\"vector search: backend\", \"err\", err)"," \t\treturn nil, status.Error(codes.Internal, \"vector search backend\")","@@ -685,6 +691,109 @@ func validateVectorSearchRequest(req *resourcepb.VectorSearchRequest) *resourcep"," \treturn nil"," }"," ","+// checkVectorSearchRateLimit returns a gRPC status error when the","+// request must be rejected (over quota or limiter unreachable), nil","+// when it should proceed.","+func (s *searchServer) checkVectorSearchRateLimit(ctx context.Context, namespace string) error {","+\tif s.rateLimiter == nil {","+\t\treturn nil","+\t}","+\tallowed, count, err := s.rateLimiter.Allow(ctx, namespace, s.rateLimitWindow, s.rateLimitPerTenant)","+\tif err != nil {","+\t\ts.log.Error(\"vector search: rate-limit check failed, fail-closed\", \"err\", err, \"namespace\", namespace)","+\t\tif s.vectorMetrics != nil {","+\t\t\ts.vectorMetrics.RateLimiterErrorsTotal.Inc()","+\t\t}","+\t\treturn status.Error(codes.Unavailable, \"rate limiter unavailable\")","+\t}","+\tif !allowed {","+\t\tif s.vectorMetrics != nil {","+\t\t\ts.vectorMetrics.RateLimitedRequestsTotal.Inc()","+\t\t}","+\t\treturn status.Errorf(codes.ResourceExhausted, \"tenant rate limit exceeded: %d requests in window\", count)","+\t}","+\treturn nil","+}","+","+// embedVectorSearchQuery returns the query embedding, fetching it from","+// the cache on hit or calling the embedder on miss (and best-effort","+// writing back into the cache, enforcing the per-tenant cap).","+func (s *searchServer) embedVectorSearchQuery(ctx context.Context, namespace, query string) ([]float32, error) {","+\tqueryHash := sha256Hex(query)","+\tif dense, ok := s.lookupCachedQueryEmbedding(ctx, namespace, queryHash); ok {","+\t\treturn dense, nil","+\t}","+","+\t// Embed the query as a retrieval *query* (different task hint than","+\t// the retrieval *document* hint used at index time — providers tune","+\t// projections per side of the retrieval pair).","+\tout, err := s.embedder.EmbedText(ctx, embedder.EmbedTextInput{","+\t\tTexts:     []string{query},","+\t\tNormalize: s.embedder.ShouldNormalize(),","+\t\tTask:      embedder.TaskRetrievalQuery,","+\t})","+\tif err != nil {","+\t\ts.log.Error(\"vector search: embed query\", \"err\", err)","+\t\treturn nil, status.Error(codes.Internal, \"embed query\")","+\t}","+\tif len(out.Embeddings) != 1 || len(out.Embeddings[0].Dense) == 0 {","+\t\ts.log.Error(\"vector search: embedder returned no vectors\")","+\t\treturn nil, status.Error(codes.Internal, \"embed query: empty result\")","+\t}","+\tdense := out.Embeddings[0].Dense","+\tif s.vectorMetrics != nil {","+\t\ts.vectorMetrics.QueryCacheMissesTotal.WithLabelValues(s.embedder.Model).Inc()","+\t}","+\ts.storeCachedQueryEmbedding(ctx, namespace, queryHash, dense)","+\treturn dense, nil","+}","+","+// lookupCachedQueryEmbedding returns (embedding, true) on hit; (nil,","+// false) on miss or any error (cache failures must not fail the search).","+func (s *searchServer) lookupCachedQueryEmbedding(ctx context.Context, namespace, queryHash string) ([]float32, bool) {","+\tif s.queryCache == nil {","+\t\treturn nil, false","+\t}","+\temb, hit, err := s.queryCache.Get(ctx, namespace, s.embedder.Model, queryHash)","+\tif err != nil {","+\t\ts.log.Warn(\"vector search: cache lookup failed, falling through\", \"err\", err)","+\t\treturn nil, false","+\t}","+\tif !hit {","+\t\treturn nil, false","+\t}","+\tif s.vectorMetrics != nil {","+\t\ts.vectorMetrics.QueryCacheHitsTotal.WithLabelValues(s.embedder.Model).Inc()","+\t}","+\treturn emb, true","+}","+","+// vectorQueryCacheEvictTargetFraction is how full the cache is left","+// after an eviction round runs.","+const vectorQueryCacheEvictTargetFraction = 0.8","+","+// storeCachedQueryEmbedding writes the freshly-embedded vector into the","+// cache (best-effort). When the tenant is at or above the cap, eviction","+// trims down to vectorQueryCacheEvictTargetFraction of the cap in one","+// pass so we don't run a DELETE on every cache miss at steady state.","+func (s *searchServer) storeCachedQueryEmbedding(ctx context.Context, namespace, queryHash string, dense []float32) {","+\tif s.queryCache == nil || s.queryCacheMaxPerTenant <= 0 {","+\t\treturn","+\t}","+\tif n, err := s.queryCache.Count(ctx, namespace); err == nil && int(n) >= s.queryCacheMaxPerTenant {","+\t\ttarget := int(float64(s.queryCacheMaxPerTenant) * vectorQueryCacheEvictTargetFraction)","+\t\tevictN := int(n) - target","+\t\tif deleted, err := s.queryCache.EvictOldest(ctx, namespace, evictN); err != nil {","+\t\t\ts.log.Warn(\"vector search: cache evict failed\", \"err\", err)","+\t\t} else if deleted > 0 && s.vectorMetrics != nil {","+\t\t\ts.vectorMetrics.QueryCacheEvictionsTotal.Add(float64(deleted))","+\t\t}","+\t}","+\tif err := s.queryCache.Put(ctx, namespace, s.embedder.Model, queryHash, dense); err != nil {","+\t\ts.log.Warn(\"vector search: cache put failed\", \"err\", err)","+\t}","+}","+"," // vectorAuthzKey de-dupes (UID, Folder) so sub-resources of the same"," // parent (e.g. dashboard panels) share a single batch-check entry."," type vectorAuthzKey struct{ uid, folder string }","@@ -1028,6 +1137,8 @@ func (s *searchServer) init(ctx context.Context) error {"," \ts.bgTaskWg.Add(1)"," \tgo s.runPeriodicScanForIndexesToRebuild(subctx)"," ","+\ts.startRateBucketSweeper(subctx)","+"," \tend := time.Now().Unix()"," \ts.log.Info(\"search index initialized\", \"duration_secs\", end-start, \"total_docs\", s.search.TotalDocs())"," \treturn nil","@@ -1080,6 +1191,42 @@ func (s *searchServer) runPeriodicScanForIndexesToRebuild(ctx context.Context) {"," \t}"," }"," ","+func sha256Hex(s string) string {","+\th := sha256.Sum256([]byte(s))","+\treturn hex.EncodeToString(h[:])","+}","+","+// Old buckets never affect Allow() — sweeping is purely housekeeping.","+func (s *searchServer) startRateBucketSweeper(ctx context.Context) {","+\tif s.rateLimiter == nil || s.rateLimitWindow <= 0 {","+\t\treturn","+\t}","+\ts.bgTaskWg.Go(func() {","+\t\tinterval := s.rateLimitWindow / 2","+\t\tif interval < time.Minute {","+\t\t\tinterval = time.Minute","+\t\t}","+\t\tt := time.NewTicker(interval)","+\t\tdefer t.Stop()","+\t\tfor {","+\t\t\tselect {","+\t\t\tcase <-ctx.Done():","+\t\t\t\treturn","+\t\t\tcase <-t.C:","+\t\t\t\tcutoff := time.Now().Add(-2 * s.rateLimitWindow)","+\t\t\t\tdeleted, err := s.rateLimiter.SweepOlderThan(ctx, cutoff)","+\t\t\t\tif err != nil {","+\t\t\t\t\ts.log.Warn(\"rate-bucket sweep failed\", \"err\", err)","+\t\t\t\t\tcontinue","+\t\t\t\t}","+\t\t\t\tif deleted > 0 {","+\t\t\t\t\ts.log.Debug(\"rate-bucket sweep\", \"deleted\", deleted, \"cutoff\", cutoff)","+\t\t\t\t}","+\t\t\t}","+\t\t}","+\t})","+}","+"," // jitterForKey returns a deterministic jitter duration for the given key,"," // bounded to [0, maxAge/2). This spreads index rebuilds across scan intervals"," // to avoid thundering herd CPU spikes when many indexes become stale at once."],"additions":162,"deletions":15,"truncated":false},{"path":"pkg/storage/unified/resource/search_vector_cache_test.go","lines":["@@ -0,0 +1,233 @@","+package resource","+","+import (","+\t\"context\"","+\t\"errors\"","+\t\"sync\"","+\t\"testing\"","+\t\"time\"","+","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+\t\"google.golang.org/grpc/codes\"","+\t\"google.golang.org/grpc/status\"","+","+\t\"github.com/grafana/grafana/pkg/storage/unified/resourcepb\"","+\t\"github.com/grafana/grafana/pkg/storage/unified/search/embed/embedder\"","+\t\"github.com/grafana/grafana/pkg/storage/unified/search/vector\"","+)","+","+type fakeQueryCache struct {","+\tmu       sync.Mutex","+\tentries  map[string][]float32","+\tgetCalls int","+\tputCalls int","+\tevicted  int64","+\tputErr   error","+\tgetErr   error","+}","+","+func newFakeQueryCache() *fakeQueryCache {","+\treturn &fakeQueryCache{entries: map[string][]float32{}}","+}","+","+func cacheKey(ns, model, hash string) string { return ns + \"|\" + model + \"|\" + hash }","+","+func (f *fakeQueryCache) Get(_ context.Context, ns, model, hash string) ([]float32, bool, error) {","+\tf.mu.Lock()","+\tdefer f.mu.Unlock()","+\tf.getCalls++","+\tif f.getErr != nil {","+\t\treturn nil, false, f.getErr","+\t}","+\tif v, ok := f.entries[cacheKey(ns, model, hash)]; ok {","+\t\treturn v, true, nil","+\t}","+\treturn nil, false, nil","+}","+","+func (f *fakeQueryCache) Put(_ context.Context, ns, model, hash string, emb []float32) error {","+\tf.mu.Lock()","+\tdefer f.mu.Unlock()","+\tf.putCalls++","+\tif f.putErr != nil {","+\t\treturn f.putErr","+\t}","+\tf.entries[cacheKey(ns, model, hash)] = emb","+\treturn nil","+}","+","+func (f *fakeQueryCache) Count(_ context.Context, ns string) (int64, error) {","+\tf.mu.Lock()","+\tdefer f.mu.Unlock()","+\tvar n int64","+\tfor k := range f.entries {","+\t\t// Prefix match is safe because tests use unique namespaces.","+\t\tif len(k) >= len(ns) && k[:len(ns)] == ns {","+\t\t\tn++","+\t\t}","+\t}","+\treturn n, nil","+}","+","+func (f *fakeQueryCache) EvictOldest(_ context.Context, ns string, n int) (int64, error) {","+\tf.mu.Lock()","+\tdefer f.mu.Unlock()","+\tdeleted := int64(0)","+\tfor k := range f.entries {","+\t\tif deleted >= int64(n) {","+\t\t\tbreak","+\t\t}","+\t\tif len(k) >= len(ns) && k[:len(ns)] == ns {","+\t\t\tdelete(f.entries, k)","+\t\t\tdeleted++","+\t\t}","+\t}","+\tf.evicted += deleted","+\treturn deleted, nil","+}","+","+type fakeRateLimiter struct {","+\tmu      sync.Mutex","+\tcalls   int","+\tcount   int64","+\tallow   bool","+\terr     error","+\tsweeps  int","+\tswept   int64","+\tsweepEr error","+}","+","+func (f *fakeRateLimiter) Allow(_ context.Context, _ string, _ time.Duration, _ int) (bool, int64, error) {","+\tf.mu.Lock()","+\tdefer f.mu.Unlock()","+\tf.calls++","+\tif f.err != nil {","+\t\treturn false, 0, f.err","+\t}","+\treturn f.allow, f.count, nil","+}","+","+func (f *fakeRateLimiter) SweepOlderThan(_ context.Context, _ time.Time) (int64, error) {","+\tf.mu.Lock()","+\tdefer f.mu.Unlock()","+\tf.sweeps++","+\treturn f.swept, f.sweepEr","+}","+","+func newTestSearchServerWithCache(emb *embedder.Embedder, backend vector.VectorBackend, cache vector.QueryEmbeddingCache, rl vector.RateLimiter) *searchServer {","+\ts := newTestSearchServer(emb, backend)","+\ts.queryCache = cache","+\ts.queryCacheMaxPerTenant = 1000","+\ts.rateLimiter = rl","+\ts.rateLimitPerTenant = 60","+\ts.rateLimitWindow = time.Minute","+\treturn s","+}","+","+func TestVectorSearch_CacheMissThenHitSkipsEmbedder(t *testing.T) {","+\tfake := &fakeTextEmbedder{dim: 4}","+\temb := newTestEmbedder(fake)","+\tbackend := &fakeVectorBackend{results: []vector.VectorSearchResult{{UID: \"u\", Title: \"t\"}}}","+\tcache := newFakeQueryCache()","+\ts := newTestSearchServerWithCache(emb, backend, cache, nil)","+","+\treq := &resourcepb.VectorSearchRequest{Key: validKey(), Query: \"same query\", Limit: 5}","+","+\t_, err := s.VectorSearch(authedCtx(), req)","+\trequire.NoError(t, err)","+\tassert.Equal(t, 1, cache.getCalls)","+\tassert.Equal(t, 1, cache.putCalls)","+\tassert.Equal(t, \"same query\", fake.gotIn.Texts[0])","+","+\t// Reset the captured input so the next call leaves a clear trace.","+\tfake.gotIn = embedder.EmbedTextInput{}","+","+\t_, err = s.VectorSearch(authedCtx(), req)","+\trequire.NoError(t, err)","+\tassert.Equal(t, 2, cache.getCalls)","+\tassert.Equal(t, 1, cache.putCalls, \"second call must not write to cache again\")","+\tassert.Empty(t, fake.gotIn.Texts, \"embedder must be skipped on cache hit\")","+}","+","+func TestVectorSearch_CacheGetErrorFallsThroughToEmbed(t *testing.T) {","+\tfake := &fakeTextEmbedder{dim: 4}","+\temb := newTestEmbedder(fake)","+\tbackend := &fakeVectorBackend{results: []vector.VectorSearchResult{{UID: \"u\", Title: \"t\"}}}","+\tcache := newFakeQueryCache()","+\tcache.getErr = errors.New(\"transient db error\")","+\ts := newTestSearchServerWithCache(emb, backend, cache, nil)","+","+\tresp, err := s.VectorSearch(authedCtx(), &resourcepb.VectorSearchRequest{","+\t\tKey: validKey(), Query: \"q\",","+\t})","+\trequire.NoError(t, err)","+\trequire.NotNil(t, resp)","+\tassert.NotEmpty(t, fake.gotIn.Texts, \"embedder must run after cache lookup error\")","+}","+","+func TestVectorSearch_CachePutErrorIsNonFatal(t *testing.T) {","+\tfake := &fakeTextEmbedder{dim: 4}","+\temb := newTestEmbedder(fake)","+\tbackend := &fakeVectorBackend{results: []vector.VectorSearchResult{{UID: \"u\", Title: \"t\"}}}","+\tcache := newFakeQueryCache()","+\tcache.putErr = errors.New(\"transient write error\")","+\ts := newTestSearchServerWithCache(emb, backend, cache, nil)","+","+\tresp, err := s.VectorSearch(authedCtx(), &resourcepb.VectorSearchRequest{","+\t\tKey: validKey(), Query: \"q\",","+\t})","+\trequire.NoError(t, err)","+\trequire.NotNil(t, resp)","+\trequire.Len(t, resp.Results, 1)","+}","+","+func TestVectorSearch_RateLimitedReturnsResourceExhausted(t *testing.T) {","+\tbackend := &fakeVectorBackend{}","+\temb := newTestEmbedder(&fakeTextEmbedder{dim: 4})","+\trl := &fakeRateLimiter{allow: false, count: 61}","+\ts := newTestSearchServerWithCache(em