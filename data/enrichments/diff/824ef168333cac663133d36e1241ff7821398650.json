}","+","+type checkAndSetDefaulter interface {","+\tCheckAndSetDefaults(scoped bool) error","+}","+","+type testCheckAndSetDefaultsCase[T checkAndSetDefaulter] struct {","+\tname string","+\tin   func() T","+","+\t// scoped indicates that CheckAndSetDefaults should be called with","+\t// scoped set to true.","+\tscoped bool","+","+\t// want specifies the desired state of the checkAndSetDefaulter after","+\t// check and set defaults has been run. If want is nil, the output is","+\t// compared to its initial state.","+\twant    checkAndSetDefaulter","+\twantErr string","+}","+","+func testCheckAndSetDefaults[T checkAndSetDefaulter](t *testing.T, tests []testCheckAndSetDefaultsCase[T]) {","+\tt.Helper()","+","+\tfor _, tt := range tests {","+\t\tt.Run(tt.name, func(t *testing.T) {","+\t\t\tgot := tt.in()","+\t\t\terr := got.CheckAndSetDefaults(tt.scoped)","+\t\t\tif tt.wantErr != \"\" {","+\t\t\t\trequire.ErrorContains(t, err, tt.wantErr)","+\t\t\t\treturn","+\t\t\t}","+","+\t\t\twant := tt.want","+\t\t\tif want == nil {","+\t\t\t\twant = tt.in()","+\t\t\t}","+\t\t\trequire.NoError(t, err)","+\t\t\trequire.Equal(t, want, got)","+\t\t})","+\t}","+}"],"additions":99,"deletions":0,"truncated":false},{"path":"lib/tbot/services/beams/testdata/TestVNetService_YAML/full.golden","lines":["@@ -0,0 +1,7 @@","+name: beams-vnet","+credential_ttl: 1m0s","+renewal_interval: 30s","+delegation_session_id: 8a50ba48-2fad-4c2c-a8ce-f48bc18db9ee","+upstream_nameservers:","+  - 1.1.1.1:53","+  - '[2606:4700:4700::1111]:53'"],"additions":7,"deletions":0,"truncated":false},{"path":"lib/tbot/services/beams/testdata/TestVNetService_YAML/minimal.golden","lines":["@@ -0,0 +1 @@","+delegation_session_id: 8a50ba48-2fad-4c2c-a8ce-f48bc18db9ee"],"additions":1,"deletions":0,"truncated":false},{"path":"lib/tbot/services/beams/vnet_config.go","lines":["@@ -0,0 +1,130 @@","+// Teleport","+// Copyright (C) 2026 Gravitational, Inc.","+//","+// This program is free software: you can redistribute it and/or modify","+// it under the terms of the GNU Affero General Public License as published by","+// the Free Software Foundation, either version 3 of the License, or","+// (at your option) any later version.","+//","+// This program is distributed in the hope that it will be useful,","+// but WITHOUT ANY WARRANTY; without even the implied warranty of","+// MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the","+// GNU Affero General Public License for more details.","+//","+// You should have received a copy of the GNU Affero General Public License","+// along with this program.  If not, see <http://www.gnu.org/licenses/>.","+","+package beams","+","+import (","+\t\"context\"","+\t\"net/netip\"","+","+\t\"github.com/gravitational/trace\"","+","+\t\"github.com/gravitational/teleport/lib/tbot/bot\"","+\t\"github.com/gravitational/teleport/lib/vnet\"","+)","+","+// VNetServiceType identifies the Beams VNet service.","+const VNetServiceType = \"beams/vnet\"","+","+// VNetServiceConfig holds the configuration for the Beams VNet service.","+type VNetServiceConfig struct {","+\t// Name of the service for logs and the /readyz endpoint.","+\tName string `yaml:\"name,omitempty\"`","+","+\t// CredentialLifetime contains configuration for how long credentials will","+\t// last and the frequency at which they'll be renewed.","+\tCredentialLifetime bot.CredentialLifetime `yaml:\",inline\"`","+","+\t// DelegationSessionID identifies the delegation session the generated","+\t// credentials will be associated with, enabling the bot to act on a (human)","+\t// user's behalf.","+\tDelegationSessionID string `yaml:\"delegation_session_id,omitempty\"`","+","+\t// UpstreamNameservers allows you to override the upstream nameservers that","+\t// will be used when an FQDN does not belong to a VNet-accessible app.","+\t//","+\t// By default, the `/etc/resolv.conf` file will be read to determine these.","+\tUpstreamNameservers StaticUpstreamNameservers `yaml:\"upstream_nameservers,omitempty\"`","+}","+","+// Type satisfies the config.ServiceConfig interface.","+func (VNetServiceConfig) Type() string { return VNetServiceType }","+","+// CheckAndSetDefaults satisfies the config.ServiceConfig interface.","+func (c *VNetServiceConfig) CheckAndSetDefaults(scoped bool) error {","+\tif scoped {","+\t\treturn trace.BadParameter(\"service type %q is not supported in scoped mode\", VNetServiceType)","+\t}","+\tif c.DelegationSessionID == \"\" {","+\t\treturn trace.BadParameter(\"delegation_session_id: is required\")","+\t}","+\tfor idx, ns := range c.UpstreamNameservers {","+\t\tif _, err := netip.ParseAddrPort(ns); err != nil {","+\t\t\treturn trace.BadParameter(\"upstream_nameservers[%d]: must be a valid `ip:port` pair\", idx)","+\t\t}","+\t}","+\treturn nil","+}","+","+// GetCredentialLifetime satisfies the config.ServiceConfig interface.","+func (c *VNetServiceConfig) GetCredentialLifetime() bot.CredentialLifetime {","+\treturn c.CredentialLifetime","+}","+","+// GetName satisfies the config.ServiceConfig interface.","+func (c *VNetServiceConfig) GetName() string {","+\treturn c.Name","+}","+","+// SetName satisfies the config.ServiceConfig interface.","+func (c *VNetServiceConfig) SetName(name string) {","+\tc.Name = name","+}","+","+// VNetServiceOpt can be used to customize the VNetService.","+type VNetServiceOpt func(*VNetService)","+","+// WithInsecure disables server certificate verification when dialing the ALPN","+// proxy.","+func WithInsecure() VNetServiceOpt {","+\treturn func(svc *VNetService) {","+\t\tsvc.insecure = true","+\t}","+}","+","+// WithDefaultCredentialLifetime sets the default credential lifetime.","+func WithDefaultCredentialLifetime(lifetime bot.CredentialLifetime) VNetServiceOpt {","+\treturn func(svc *VNetService) {","+\t\tsvc.defaultCredentialLifetime = lifetime","+\t}","+}","+","+// WithTUNDevice overrides the service's TUN device in tests.","+func WithTUNDevice(tun vnet.TUNDevice) VNetServiceOpt {","+\treturn func(svc *VNetService) {","+\t\tsvc.createTUN = func() (vnet.TUNDevice, error) {","+\t\t\treturn tun, nil","+\t\t}","+\t}","+}","+","+// WithConfigureHost overrides the function that will be called to configure","+// the host network, in tests.","+func WithConfigureHost(fn vnet.EmbeddedConfigureHostFunc) VNetServiceOpt {","+\treturn func(svc *VNetService) {","+\t\tsvc.configureHost = func(ctx context.Context, _ vnet.TUNDevice, cfg *vnet.EmbeddedVNetHostConfig) error {","+\t\t\treturn fn(ctx, cfg)","+\t\t}","+\t}","+}","+","+// StaticUpstreamNameservers is a fixed list of upstream nameserver addresses.","+type StaticUpstreamNameservers []string","+","+// UpstreamNameservers satisfies the dns.UpstreamNameserversSource interface.","+func (s StaticUpstreamNameservers) UpstreamNameservers(context.Context) ([]string, error) {","+\treturn s, nil","+}"],"additions":130,"deletions":0,"truncated":false},{"path":"lib/tbot/services/beams/vnet_config_test.go","lines":["@@ -0,0 +1,110 @@","+// Teleport","+// Copyright (C) 2026 Gravitational, Inc.","+//","+// This program is free software: you can redistribute it and/or modify","+// it under the terms of the GNU Affero General Public License as published by","+// the Free Software Foundation, either version 3 of the License, or","+// (at your option) any later version.","+//","+// This program is distributed in the hope that it will be useful,","+// but WITHOUT ANY WARRANTY; without even the implied warranty of","+// MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the","+// GNU Affero General Public License for more details.","+//","+// You should have received a copy of the GNU Affero General Public License","+// along with this program.  If not, see <http://www.gnu.org/licenses/>.","+","+package beams","+","+import (","+\t\"testing\"","+\t\"time\"","+","+\t\"github.com/gravitational/teleport/lib/tbot/bot\"","+)","+","+func TestVNetService_YAML(t *testing.T) {","+\tt.Parallel()","+","+\ttests := []testYAMLCase[VNetServiceConfig]{","+