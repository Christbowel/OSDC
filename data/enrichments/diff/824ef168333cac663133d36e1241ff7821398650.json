"upstream_nameservers[0]: must be a valid `ip:port` pair\",","+\t\t},","+\t\t{","+\t\t\tname:   \"scoped\",","+\t\t\tscoped: true,","+\t\t\tin: func() *VNetServiceConfig {","+\t\t\t\treturn &VNetServiceConfig{","+\t\t\t\t\tDelegationSessionID: \"8a50ba48-2fad-4c2c-a8ce-f48bc18db9ee\",","+\t\t\t\t}","+\t\t\t},","+\t\t\twantErr: \"is not supported in scoped mode\",","+\t\t},","+\t}","+","+\ttestCheckAndSetDefaults(t, tests)","+}"],"additions":110,"deletions":0,"truncated":false},{"path":"lib/tbot/services/beams/vnet_service.go","lines":["@@ -0,0 +1,449 @@","+// Teleport","+// Copyright (C) 2026 Gravitational, Inc.","+//","+// This program is free software: you can redistribute it and/or modify","+// it under the terms of the GNU Affero General Public License as published by","+// the Free Software Foundation, either version 3 of the License, or","+// (at your option) any later version.","+//","+// This program is distributed in the hope that it will be useful,","+// but WITHOUT ANY WARRANTY; without even the implied warranty of","+// MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the","+// GNU Affero General Public License for more details.","+//","+// You should have received a copy of the GNU Affero General Public License","+// along with this program.  If not, see <http://www.gnu.org/licenses/>.","+","+package beams","+","+import (","+\t\"cmp\"","+\t\"context\"","+\t\"crypto\"","+\t\"crypto/tls\"","+\t\"fmt\"","+\t\"log/slog\"","+\t\"net\"","+\t\"os\"","+\t\"strings\"","+\t\"sync\"","+\t\"time\"","+","+\t\"github.com/gravitational/trace\"","+","+\t\"github.com/gravitational/teleport/api/client\"","+\t\"github.com/gravitational/teleport/api/client/proto\"","+\t\"github.com/gravitational/teleport/api/types\"","+\ttypesvnet \"github.com/gravitational/teleport/api/types/vnet\"","+\tvnetv1 \"github.com/gravitational/teleport/gen/proto/go/teleport/lib/vnet/v1\"","+\t\"github.com/gravitational/teleport/lib/tbot/bot\"","+\t\"github.com/gravitational/teleport/lib/tbot/bot/connection\"","+\ttbotclient \"github.com/gravitational/teleport/lib/tbot/client\"","+\t\"github.com/gravitational/teleport/lib/tbot/identity\"","+\t\"github.com/gravitational/teleport/lib/tbot/readyz\"","+\t\"github.com/gravitational/teleport/lib/tbot/services/clientcredentials\"","+\t\"github.com/gravitational/teleport/lib/utils\"","+\t\"github.com/gravitational/teleport/lib/vnet\"","+\t\"github.com/gravitational/teleport/lib/vnet/dns\"","+)","+","+// VNetServiceBuilder returns a builder for the Beams VNet service.","+func VNetServiceBuilder(cfg *VNetServiceConfig, opts ...VNetServiceOpt) bot.ServiceBuilder {","+\tbuildFn := func(deps bot.ServiceDependencies) (bot.Service, error) {","+\t\tif err := cfg.CheckAndSetDefaults(deps.Scoped); err != nil {","+\t\t\treturn nil, trace.Wrap(err)","+\t\t}","+","+\t\t// Prevent accidental misuse.","+\t\tif os.Getenv(\"TELEPORT_BEAMS_RUNTIME\") != \"yes\" {","+\t\t\treturn nil, trace.Errorf(\"service type %q is not intended for use outside of Teleport Beams, see: https://beams.run for more information\", VNetServiceType)","+\t\t}","+","+\t\tsvc := &VNetService{","+\t\t\tcfg:                       cfg,","+\t\t\tcreateTUN:                 platformCreateTUN,","+\t\t\tconfigureHost:             platformConfigureHost,","+\t\t\tdefaultCredentialLifetime: bot.DefaultCredentialLifetime,","+\t\t\tstatusReporter:            deps.GetStatusReporter(),","+\t\t\tidentityGenerator:         deps.IdentityGenerator,","+\t\t\tclientBuilder:             deps.ClientBuilder,","+\t\t\tproxyPinger:               deps.ProxyPinger,","+\t\t\tlogger:                    deps.Logger,","+\t\t\tidentity: &clientcredentials.UnstableConfig{","+\t\t\t\tDelegationSessionID: cfg.DelegationSessionID,","+\t\t\t},","+\t\t}","+\t\tfor _, opt := range opts {","+\t\t\topt(svc)","+\t\t}","+","+\t\tidentityBuilder := clientcredentials.ServiceBuilder(","+\t\t\tsvc.identity,","+\t\t\tcmp.Or(cfg.CredentialLifetime, svc.defaultCredentialLifetime),","+\t\t)","+\t\tidentitySvc, err := identityBuilder.Build(","+\t\t\tdeps.WithStatusReporter(readyz.NoopReporter()),","+\t\t)","+\t\tif err != nil {","+\t\t\treturn nil, trace.Wrap(err)","+\t\t}","+\t\treturn bot.NewServicePair(svc, identitySvc), nil","+\t}","+","+\treturn bot.NewServiceBuilder(VNetServiceType, cfg.Name, buildFn)","+}","+","+// VNetService runs an embedded implementation of VNet to transparently route","+// egress traffic from the Beams Runtime through the Teleport proxy. It creates","+// a TUN interface and updates the host's routing table. The Beams orchestrator","+// is responsible for updating the /etc/resolv.conf to use the VNet nameserver.","+type VNetService struct {","+\tcfg                       *VNetServiceConfig","+\tcreateTUN                 func() (vnet.TUNDevice, error)","+\tconfigureHost             func(context.Context, vnet.TUNDevice, *vnet.EmbeddedVNetHostConfig) error","+\tdefaultCredentialLifetime bot.CredentialLifetime","+\tstatusReporter            readyz.Reporter","+\tidentityGenerator         *identity.Generator","+\tclientBuilder             *tbotclient.Builder","+\tproxyPinger               connection.ProxyPinger","+\tlogger                    *slog.Logger","+\t// TODO(boxofrad): Wrapping the clientcredentials service is a little awkward","+\t// consider if we should move its automatic renewal behavior into the identity","+\t// package.","+\tidentity *clientcredentials.UnstableConfig","+\tinsecure bool","+}","+","+// String satisfies the bot.Service interface.","+func (svc *VNetService) String() string { return svc.cfg.Name }","+","+// Run the VNet service until the given context is canceled.","+func (s *VNetService) Run(ctx context.Context) error {","+\tdevice, err := s.createTUN()","+\tif err != nil {","+\t\treturn trace.Wrap(err)","+\t}","+\tdefer device.Close()","+","+\tvar upstreamNameservers dns.UpstreamNameserverSource","+\tif len(s.cfg.UpstreamNameservers) == 0 {","+\t\tupstreamNameservers, err = platformUpstreamNameserverSource(s.logger)","+\t\tif err != nil {","+\t\t\treturn trace.Wrap(err)","+\t\t}","+\t} else {","+\t\tupstreamNameservers = s.cfg.UpstreamNameservers","+\t}","+","+\tselect {","+\tcase <-s.identity.Ready():","+\tcase <-ctx.Done():","+\t\treturn ctx.Err()","+\t}","+\tfacade, err := s.identity.Facade()","+\tif err != nil {","+\t\treturn trace.Wrap(err)","+\t}","+\tclient, err := s.clientBuilder.Build(ctx, facade)","+\tif err != nil {","+\t\treturn trace.Wrap(err)","+\t}","+\tdefer client.Close()","+","+\tapplicationService, err := newVNetApplicationService(","+\t\tclient,","+\t\ts.identityGenerator,","+\t\tfacade.Get().PrivateKey.Signer,","+\t\tcmp.Or(s.cfg.CredentialLifetime, s.defaultCredentialLifetime),","+\t\ts.cfg.DelegationSessionID,","+\t\ts.insecure,","+\t\ts.logger,","+\t)","+\tif err != nil {","+\t\treturn trace.Wrap(err)","+\t}","+","+\tvar configureHostOnce sync.Once","+\tnet, err := vnet.NewEmbeddedVNet(vnet.EmbeddedVNetConfig{","+\t\tDevice:             device,","+\t\tApplicationService: applicationService,","+\t\tConfigureHost: func(ctx context.Context, cfg *vnet.EmbeddedVNetHostConfig) error {","+\t\t\t// ConfigureHost is called with `cfg == nil` when VNet is shutting","+\t\t\t// down to tear down any host configuration, however we do not need","+\t\t\t// to do anything as removing the TUN device (by calling Close) will","+\t\t\t// drop its associated routes.","+\t\t\tif cfg == nil {","+\t\t\t\treturn nil","+\t\t\t}","+","+\t\t\t// In the Beams environment, we assume DNS zones and CIDR ranges are","+\t\t\t// stable, so we do not need to make our setup function idempotent.","+\t\t\tvar err error","+\t\t\tconfigureHostOnce.Do(func() {","+\t\t\t\terr = s.configureHost(ctx, device, cfg)","+\t\t\t\tif err == nil {","+\t\t\t\t\ts.statusReporter.Report(readyz.Healthy)","+\t\t\t\t} else {","+\t\t\t\t\ts.statusReporter.ReportReason(readyz.Unhealthy, err.Error())","+\t\t\t\t}","+\t\t\t})","+\t\t\treturn err","+\t\t},","+\t\tUpstreamNameserverSource: upstreamNameservers,","+\t})","+\tif err != nil {","+\t\treturn trace.Wrap(err, \"creating embedded VNet\")","+\t}","+\treturn trace.Wrap(net.Run(ctx))","+}","+","+func newVNetApplicationService(","+\tclient *client.Client,","+\tidentityGenerator *identity.Generator,","+\tprivateKey crypto.Signer,","+\tcredentialLifetime bot.CredentialLifetime,","+\tdelegationSessionID string,","+\tinsecure bool,","+\tlogger *slog.Logger,","+) (*vnetApplicationService, error) {","+\tcache, err := utils.NewFnCache(utils.FnCacheConfig{TTL: 1 * time.Minute})","+\tif err != nil {","+\t\treturn nil, trace.Wrap(err)","+\t}","+\treturn &vnetApplicationService{","+\t\tclient:              client,","+\t\tidentityGenerator:   identityGenerator,","+\t\tprivateKey:          privateKey,","+\t\tcredentialLifetime:  credentialLifetime,","+\t\tdelegationSessionID: delegationSessionID,","+\t\tinsecure:            insecure,","+\t\tcache:               cache,","+\t\tlogger:              logger,","+\t}, nil","+}","+","+type vnetApplicationService struct {","+\tvnet.EmbeddedApplicationService","+","+\tclient              *client.Client","+\tcache               *utils.FnCache","+\tidentityGenerator   *identity.Generator","+\tprivateKey          crypto.Signer","+\tcredentialLifetime  bot.CredentialLifetime","+\tdelegationSessionID string","+\tinsecure            bool","+\tlogger              *slog.Logger","+}","+","+func (v *vnetApplicationService) GetTargetOSConfiguration(ctx context.Context) (*vnetv1.TargetOSConfiguration, error) {","+\tcfg, err := v.getOSConfiguration(ctx)","+\tif err != nil {","+\t\treturn nil, trace.Wrap(err)","+\t}","+\treturn cfg.config, nil","+}","+","+func (v *vnetApplicationService) getOSConfiguration(ctx context.Context) (*vnetOSConfiguration, error) {","+\tuncached := func(ctx context.Context) (*vnetOSConfiguration, error) {","+\t\tpong, err := v.client.Ping(ctx)","+\t\tif err != nil {","+\t\t\treturn nil, trace.Wrap(err, \"pinging auth server\")","+\t\t}","+","+\t\tdnsZones := []string{hostname(pong.GetProxyPublicAddr())}","+","+\t\tvnetConfig, err := v.client.GetVnetConfig(ctx)","+\t\tswitch {","+\t\tcase trace.IsNotFound(err) || trace.IsNotImplemented(err):","+\t\t\t// Use the defaults, nothing to do here.","+\t\tcase err != nil:","+\t\t\treturn nil, trace.Wrap(err)","+\t\t}","+","+\t\tfor _, zone := range vnetConfig.GetSpec().GetCustomDnsZones() {","+\t\t\tdnsZones = append(dnsZones, zone.GetSuffix())","+\t\t}","+","+\t\treturn &vnetOSConfiguration{","+\t\t\tpong: pong,","+\t\t\tconfig: &vnetv1.TargetOSConfiguration{","+\t\t\t\tDnsZones: dnsZones,","+","+\t\t\t\t// Note: we do not currently honor custom CIDR ranges, because cloud","+\t\t\t\t// makes assumptions about the IPv4 address of the nameserver.","+\t\t\t\tIpv4CidrRanges: []string{typesvnet.DefaultIPv4CIDRRange},","+\t\t\t},","+\t\t}, nil","+\t}","+\treturn utils.FnCacheGet(ctx, v.cache, \"\", uncached)","+}","+","+type vnetOSConfiguration struct {","+\tpong   proto.PingResponse","+\tconfig *vnetv1.TargetOSConfiguration"],"additions":283,"deletions":0,"truncated":false}],"additions":693,"deletions":11,"truncated":true,"file_count":11},"error":null,"fetched_at":"2026-05-20T17:48:12.005495+00:00"}