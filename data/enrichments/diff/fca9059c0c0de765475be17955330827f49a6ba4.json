\": false","         }","       }","+    },","+    \"23.1.0\": {","+      \"version\": \"23.1.0-beta.1\",","+      \"requires\": {","+        \"expo\": \">=55.0.0 <56.0.0\"","+      },","+      \"packages\": {","+        \"expo\": {","+          \"version\": \"~56.0.0\",","+          \"alwaysAddToPackageJson\": false","+        },","+        \"expo-splash-screen\": {","+          \"version\": \"~56.0.10\",","+          \"alwaysAddToPackageJson\": false","+        },","+        \"expo-status-bar\": {","+          \"version\": \"~56.0.4\",","+          \"alwaysAddToPackageJson\": false","+        },","+        \"expo-system-ui\": {","+          \"version\": \"~56.0.5\",","+          \"alwaysAddToPackageJson\": false","+        },","+        \"@expo/cli\": {","+          \"version\": \"~56.1.14\",","+          \"alwaysAddToPackageJson\": false","+        },","+        \"babel-preset-expo\": {","+          \"version\": \"~56.0.14\",","+          \"alwaysAddToPackageJson\": false","+        },","+        \"react\": {","+          \"version\": \"^19.2.0\",","+          \"alwaysAddToPackageJson\": false","+        },","+        \"react-dom\": {","+          \"version\": \"^19.2.0\",","+          \"alwaysAddToPackageJson\": false","+        },","+        \"@types/react\": {","+          \"version\": \"^19.2.0\",","+          \"alwaysAddToPackageJson\": false","+        },","+        \"react-native\": {","+          \"version\": \"0.85.3\",","+          \"alwaysAddToPackageJson\": false","+        },","+        \"react-native-web\": {","+          \"version\": \"~0.21.0\",","+          \"alwaysAddToPackageJson\": false","+        },","+        \"@expo/metro\": {","+          \"version\": \"~56.0.0\",","+          \"alwaysAddToPackageJson\": false","+        },","+        \"@expo/metro-config\": {","+          \"version\": \"~56.0.13\",","+          \"alwaysAddToPackageJson\": false","+        },","+        \"@expo/metro-runtime\": {","+          \"version\": \"~56.0.14\",","