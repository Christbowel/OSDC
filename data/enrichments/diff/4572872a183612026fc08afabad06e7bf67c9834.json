ss in edit mode so that we can interrupt the app","@@ -85,7 +86,7 @@ def start_kernel(self) -> None:","                     self.configs,","                     self.app_metadata,","                     self.config_manager.get_config(hide_secrets=False),","-                    self._virtual_files_supported,","+                    self._virtual_file_storage,","                     self.redirect_console_to_browser,","                     self.queue_manager.win32_interrupt_queue,","                     self.profile_path,","@@ -137,7 +138,7 @@ def launch_kernel_with_cleanup(","                     self.configs,","                     self.app_metadata,","                     self.config_manager.get_config(hide_secrets=False),","-                    self._virtual_files_supported,","+                    self._virtual_file_storage,","                     self.redirect_console_to_browser,","                     # win32 interrupt queue","                     None,"],"additions":5,"deletions":4,"truncated":false},{"path":"marimo/_session/session.py","lines":["@@ -66,6 +66,7 @@","     from collections.abc import Iterator, Mapping"," ","     from marimo._ast.cell_manager import CellManager","+    from marimo._runtime.virtual_file import VirtualFileStorageType","     from marimo._server.models.models import InstantiateNotebookRequest","     from marimo._session.app_host import AppHostContext"," ","@@ -116,7 +117,7 @@ def create(","         app_metadata: AppMetadata,","         app_file_manager: AppFileManager,","         config_manager: MarimoConfigManager,","-        virtual_files_supported: bool,","+        virtual_file_storage: VirtualFileStorageType | None,","         redirect_console_to_browser: bool,","         auto_instantiate: bool,","         ttl_seconds: int | None,","@@ -183,7 +184,6 @@ def create(","                 configs=configs,","                 app_metadata=app_metadata,","                 config_manager=config_manager,","-                virtual_files_supported=virtual_files_supported,","                 redirect_console_to_browser=redirect_console_to_browser,","             )","         else:","@@ -198,7 +198,7 @@ def create(","                 configs=configs,","                 app_metadata=app_metadata,","                 config_manager=config_manager,","-                virtual_files_supported=virtual_files_supported,","+                virtual_file_storage=virtual_file_storage,","                 redirect_console_to_browser=redirect_console_to_browser,","             )"," "],"additions":3,"deletions":3,"truncated":false},{"path":"marimo/_smoke_tests/process_isolation/README.md","lines":["@@ -46,3 +46,20 @@ Open both apps in browser. Each should show a green \"PASS\" callout."," - **With `--sandbox`**: Both apps additionally show a green \"Sandbox: PASS\" callout —","   each app's unique dependency (`humanize` for app1, `pyfiglet` for app2) was installed","   in its own sandbox venv, and the other app's dependency is not present.","+","+---","+","+## Virtual File Smoke Test","+","+Tests that virtual files (images, Arrow data for tables, etc.) created in","+an isolated child process are accessible to the parent server process.","+","+```bash","+marimo run marimo/_smoke_tests/process_isolation/virtual_files.py \\","+           marimo/_smoke_tests/process_isolation/app1.py","+```","+","+Multi-file `marimo run` auto-enables process isolation. You should see a","+blue square image, a green HTML heading, and a three-row table. If any of","+those are broken, the cross-process virtual file storage handoff is not","+working."],"additions":17,"deletions":0,"truncated":false},{"path":"marimo/_smoke_tests/process_isolation/virtual_files.py","lines":["@@ -0,0 +1,98 @@","+import marimo","+","+__generated_with = \"0.23.1\"","+app = marimo.App()","+","+with app.setup:","+    import marimo as mo","+","+","+@app.cell","+def _():","+    mo.md(\"\"\"","+    # Virtual Files + Process Isolation Smoke Test","+","+    This notebook creates virtual files (HTML, image, Arrow) to verify they","+    are served correctly when the app runs in an isolated subprocess","+    (`isolate_apps=true`).","+","+    **Bug:** When `isolate_apps` is enabled, the kernel runs in a child","+    process that stores virtual files in process-local `InMemoryStorage`.","+    The server process cannot access them, causing `FileNotFoundError`","+    when the browser requests `/@file/...`.","+","+    **How to test:**","+","+    ```","+    marimo run marimo/_smoke_tests/process_isolation/virtual_files.py \\\\","+               marimo/_smoke_tests/process_isolation/app1.py","+    ```","+","+    Multi-file `marimo run` auto-enables process isolation. If all three","+    sections below render correctly (not broken images / empty iframes),","+    virtual file serving across process boundaries is working.","+    \"\"\")","+    return","+","+","+@app.cell","+def _():","+    import struct","+    import zlib","+","+    def _make_tiny_png(r: int, g: int, b: int) -> bytes:","+        \"\"\"Create a minimal valid 1x1 PNG with the given RGB colour.\"\"\"","+","+        def _chunk(chunk_type: bytes, data: bytes) -> bytes:","+            c = chunk_type + data","+            return (","+                struct.pack(\">I\", len(data))","+                + c","+                + struct.pack(\">I\", zlib.crc32(c) & 0xFFFFFFFF)","+            )","+","+        header = b\"\\x89PNG\\r\\n\\x1a\\n\"","+        ihdr = _chunk(b\"IHDR\", struct.pack(\">IIBBBBB\", 1, 1, 8, 2, 0, 0, 0))","+        raw_row = b\"\\x00\" + bytes([r, g, b])","+        idat = _chunk(b\"IDAT\", zlib.compress(raw_row))","+        iend = _chunk(b\"IEND\", b\"\")","+        return header + ihdr + idat + iend","+","+    png_bytes = _make_tiny_png(0, 128, 255)","+","+    mo.vstack([","+        mo.md(","+            \"## 1. Image virtual file\\n\\n\"","+            \"If you see a small blue square below, the image virtual \"","+            \"file was served successfully.\"","+        ),","+        mo.image(src=png_bytes, width=64, height=64),","+    ])","+    return","+","+","+@app.cell","+def _():","+    # Use mo.ui.table with a small dataset — tables produce .arrow virtual","+    # files under the hood.","+    table = mo.ui.table(","+        [","+            {\"name\": \"Alice\", \"score\": 95},","+            {\"name\": \"Bob\", \"score\": 87},","+            {\"name\": \"Charlie\", \"score\": 72},","+        ],","+    )","+","+    mo.vstack([","+        mo.md(","+            \"## 2. Table (Arrow virtual file)\\n\\n\"","+            \"If the table renders with three rows below, the Arrow \"","+            \"virtual file was served successfully.\"","+        ),","+        table,","+    ])","+    return","+","+","+if __name__ == \"__main__\":","+    app.run()"],"additions":98,"deletions":0,"truncated":false},{"path":"tests/_runtime/test_runtime.py","lines":["@@ -1384,7 +1384,7 @@ async def test_notebook_dir_for_unnamed_notebook(","                 stream=k.stream,","                 stdout=k.stdout,","                 stderr=k.stderr,","-                virtual_files_supported=True,","+                virtual_file_storage=\"shared_memory\",","                 mode=SessionMode.EDIT,","             )"," ","@@ -1550,7 +1550,7 @@ async def test_sys_path_updated_with_exec_req(","                 stream=k.stream,","                 stdout=k.stdout,","                 stderr=k.stderr,","-                virtual_files_supported=True,","+                virtual_file_storage=\"shared_memory\",","                 mode=SessionMode.EDIT,","             )"," "],"additions":2,"deletions":2,"truncated":false},{"path":"tests/_server/test_sessions.py","lines":["@@ -140,7 +140,7 @@ def test_kernel_manager_run_mode() -> None:","         configs={},","         app_metadata=app_metadata,","         config_manager=get_default_config_manager(current_path=None),","-        virtual_files_supported=True,","+        virtual_file_storage=\"in_memory\",","         redirect_co