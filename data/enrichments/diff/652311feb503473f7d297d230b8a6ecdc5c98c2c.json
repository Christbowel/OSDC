th.min(maxConnectionLimit, currentValue) / maxConnectionLimit) * 100)","+  }","+","+  return Math.floor(maxConnectionLimit * (Math.min(100, currentValue) / 100))","+}",""],"additions":27,"deletions":0,"truncated":false}],"additions":215,"deletions":20,"truncated":false,"file_count":4},"error":null,"fetched_at":"2026-07-14T09:31:57.140888+00:00"}