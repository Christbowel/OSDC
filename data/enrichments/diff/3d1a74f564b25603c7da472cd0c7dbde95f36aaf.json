pe beamsCommands struct {","+\tls        *beamsLSCommand","+\tadd       *beamsAddCommand","+\trm        *beamsRMCommand","+\tssh       *beamsSSHCommand","+\texec      *beamsExecCommand","+\tpublish   *beamsPublishCommand","+\tunpublish *beamsUnpublishCommand","+\tscp       *beamsSCPCommand","+}","+","+func newBeamsCommands(app *kingpin.Application) beamsCommands {","+\tbeams := app.Command(\"beams\", \"View, manage and run beams. Beams are ephemeral, sandbox VMs built for agentic workloads.\").Alias(\"beam\")","+\treturn beamsCommands{","+\t\tls:        newBeamsLSCommand(beams),","+\t\tadd:       newBeamsAddCommand(beams),","+\t\trm:        newBeamsRMCommand(beams),","+\t\tssh:       newBeamsSSHCommand(beams),","+\t\texec:      newBeamsExecCommand(beams),","+\t\tpublish:   newBeamsPublishCommand(beams),","+\t\tunpublish: newBeamsUnpublishCommand(beams),","+\t\tscp:       newBeamsSCPCommand(beams),","+\t}","+}","+","+func formatBeam(beam *beamsv1.Beam, proxyAddr string) formattedBeam {","+\treturn formattedBeam{","+\t\tID:      beam.GetStatus().GetAlias(),","+\t\tUUID:    beam.GetMetadata().GetName(),","+\t\tOwner:   beam.GetStatus().GetUser(),","+\t\tExpires: beam.GetSpec().GetExpires().AsTime(),","+\t\tURL:     beamPublishURL(beam, proxyAddr),","+\t}","+}","+","+func beamPublishURL(beam *beamsv1.Beam, proxyAddr string) string {","+\tpublish := beam.GetSpec().GetPublish()","+\tif publish == nil {","+\t\treturn \"\"","+\t}","+","+\t// We discard the port because in Teleport Cloud proxies are always listening","+\t// on :443. For TCP apps, the address can only be dialed via VNet anyway (and","+\t// the port doesn't need to match the proxy port).","+\tproxyHost, _, err := net.SplitHostPort(proxyAddr)","+\tif err != nil {","+\t\tproxyHost = proxyAddr","+\t}","+","+\thostname := utils.DefaultAppPublicAddr(beam.GetStatus().GetAppName(), proxyHost)","+\tswitch publish.GetProtocol() {","+\tcase beamsv1.Protocol_PROTOCOL_HTTP:","+\t\treturn fmt.Sprintf(\"https://%s\", hostname)","+\tcase beamsv1.Protocol_PROTOCOL_TCP:","+\t\treturn fmt.Sprintf(\"tcp://%s:%d\", hostname, publish.GetPort())","+\tdefault:","+\t\treturn hostname","+\t}","+}","+","+// formattedBeam contains only the useful parts of the beam resource for scripting","+// or automating with an AI Agent.","+type formattedBeam struct {","+\t// ID is the human-friendly name of the beam (taken from `status.alias`).","+\t//","+\t// As there is a limited number of possible word pairs, eventual reuse is","+\t// likely but it will uniquely point to this beam for as long as the beam","+\t// is alive.","+\tID string `json:\"id\"`","+","+\t// UUID is the stable/globally-unique identifier for the beam (taken from","+\t// `metadata.name`).","+\tUUID string `json:\"uuid\"`","+","+\t// Owner of this beam (taken from `status.user`).","+\tOwner string `json:\"owner\"`","+","+\t// Expires is the time at which this beam will expire and be automatically","+\t// deleted (taken from `spec.expires`).","+\tExpires time.Time `json:\"expires\"`","+","+\t// URL is the address at which the beam's published application can be","+\t// reached.","+\t//","+\t// For HTTP applications, it will be in the form: `https://<host>`.","+\t//","+\t// For TCP applications, it will be in the form: `tcp://<host>:<port>` but","+\t// this address can only be dialed via VNet, otherwise you'll need to start","+\t// a local proxy.","+\tURL string `json:\"url,omitempty\"`","+}","+","+// getBeam reads a beam by UUID or human-friendly name depending on the format","+// of the given string.","+func getBeam(ctx context.Context, client authclient.ClientI, ref string) (*beamsv1.Beam, error) {","+\treq := &beamsv1.GetBeamRequest{}","+\tif _, err := uuid.Parse(ref); err == nil {","+\t\treq.Id = &beamsv1.GetBeamRequest_Name{Name: ref}","+\t} else {","+\t\treq.Id = &beamsv1.GetBeamRequest_Alias{Alias: ref}","+\t}","+","+\trsp, err := client.","+\t\tBeamServiceClient().","+\t\tGetBeam(ctx, req)","+\tif err != nil {","+\t\treturn nil, trace.Wrap(err)","+\t}","+\treturn rsp.GetBeam(), nil","+}"],"additions":147,"deletions":0,"truncated":false},{"path":"tool/tsh/common/beams_add.go","lines":["@@ -0,0 +1,117 @@","+/*","+ * Teleport","+ * Copyright (C) 2026  Gravitational, Inc.","+ *","+ * This program is free software: you can redistribute it and/or modify","+ * it under the terms of the GNU Affero General Public License as published by","+ * the Free Software Foundation, either version 3 of the License, or","+ * (at your option) any later version.","+ *","+ * This program is distributed in the hope that it will be useful,","+ * but WITHOUT ANY WARRANTY; without even the implied warranty of","+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the","+ * GNU Affero General Public License for more details.","+ *","+ * You should have received a copy of the GNU Affero General Public License","+ * along with this program.  If not, see <http://www.gnu.org/licenses/>.","+ */","+","+package common","+","+import (","+\t\"fmt\"","+\t\"strings\"","+","+\t\"github.com/alecthomas/kingpin/v2\"","+\t\"github.com/gravitational/trace\"","+","+\t\"github.com/gravitational/teleport\"","+\tbeamsv1 \"github.com/gravitational/teleport/api/gen/proto/go/teleport/beams/v1\"","+\t\"github.com/gravitational/teleport/lib/client\"","+\t\"github.com/gravitational/teleport/lib/defaults\"","+\t\"github.com/gravitational/teleport/tool/common\"","+)","+","+type beamsAddCommand struct {","+\t*kingpin.CmdClause","+\tconsole bool","+\tformat  string","+}","+","+func newBeamsAddCommand(parent *kingpin.CmdClause) *beamsAddCommand {","+\tcmd := &beamsAddCommand{","+\t\tCmdClause: parent.Command(\"add\", \"Start a new beam, and optionally connect to it via SSH.\"),","+\t}","+\tcmd.Flag(\"console\", \"Connect to the beam via SSH after creation.\").Default(\"true\").BoolVar(&cmd.console)","+\tcmd.Flag(\"format\", defaults.FormatFlagDescription(defaults.DefaultFormats...)).","+\t\tShort('f').","+\t\tDefault(teleport.Text).","+\t\tEnumVar(&cmd.format, defaults.DefaultFormats...)","+\treturn cmd","+}","+","+func (c *beamsAddCommand) run(cf *CLIConf) error {","+\tctx := cf.Context","+","+\ttc, err := makeClient(cf)","+\tif err != nil {","+\t\treturn trace.Wrap(err)","+\t}","+","+\tvar beam *beamsv1.Beam","+\terr = client.RetryWithRelogin(ctx, tc, func() error {","+\t\tclusterClient, err := tc.ConnectToCluster(ctx)","+\t\tif err != nil {","+\t\t\treturn trace.Wrap(err)","+\t\t}","+\t\tdefer clusterClient.Close()","+","+\t\trootClient, err := clusterClient.ConnectToRootCluster(ctx)","+\t\tif err != nil {","+\t\t\treturn trace.Wrap(err)","+\t\t}","+\t\tdefer rootClient.Close()","+","+\t\t// Create the beam.","+\t\trsp, err := rootClient.","+\t\t\tBeamServiceClient().","+\t\t\tCreateBeam(ctx, &beamsv1.CreateBeamRequest{","+\t\t\t\tEgress: beamsv1.EgressMode_EGRESS_MODE_UNRESTRICTED,","+\t\t\t})","+\t\tif err != nil {","+\t\t\treturn trace.Wrap(err)","+\t\t}","+","+\t\tbeam = rsp.GetBeam()","+\t\treturn nil","+\t})","+\tif err != nil {","+\t\treturn trace.Wrap(err)","+\t}","+","+\t// formatBeams uses the proxy address to derive the Publish URL but we given","+\t// the beam won't be published yet, there's no need to actually fetch it.","+\tconst proxyAddr = \"\"","+","+\tswitch strings.ToLower(c.format) {","+\tcase teleport.JSON:","+\t\treturn trace.Wrap(common.PrintJSONIndent(cf.Stdout(), formatBeam(beam, proxyAddr)))","+\tcase teleport.YAML:","+\t\treturn trace.Wrap(common.PrintYAML(cf.Stdout(), formatBeam(beam, proxyAddr)))","+\tdefault:","+\t\tif _, err := fmt.Fprintf(","+\t\t\tcf.Stdout(),","+\t\t\t\"Beam %q created.\\n\",","+\t\t\tbeam.GetStatus().GetAlias(),","+\t\t); err != nil {","+\t\t\treturn trace.Wrap(err)","+\t\t}","+","+\t\t// Connect to the beam via SSH.","+\t\tif c.console {","+\t\t\treturn trace.Wrap(sshBeam(cf, tc, beam, nil))","+\t\t}","+\t}","+","+\treturn nil","+}"],"additions":117,"deletions":0,"truncated":false},{"path":"tool/tsh/common/beams_exec.go","lines":["@@ -0,0 +1,75 @@","+/*","+ * Teleport","+ * Copyright (C) 2026  Gravitational, Inc.","+ *","+ * This program is free software: you can redistribute it and/or modify","+ * it under the terms of the GNU Affero General Public License as published by","+ * the Free Software Foundation, either version 3 of the License, or","+ * (at your option) any later version.","+ *","+ * This program is distributed in the hope that it will be useful,","+ * but WITHOUT ANY WARRANTY; without even the implied warranty of","+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the","+ * GNU Affero General Public License for more details.","+ *","+ * You should have received a copy of the GNU Affero General Public License","+ * along with this program.  If not, see <http://www.gnu.org/licenses/>.","+ */","+","+package common","+","+import (","+\t\"github.com/alecthomas/kingpin/v2\"","+\t\"github.com/gravitational/trace\"","+","+\tbeamsv1 \"github.com/gravitational/teleport/api/gen/proto/go/teleport/beams/v1\"","+\t\"github.com/gravitational/teleport/lib/client\"","+)","+","+type beamsExecCommand struct {","+\t*kingpin.CmdClause","+\tname    string","+\tcommand []string","+}","+","+func newBeamsExecCommand(parent *kingpin.CmdClause) *beamsExecCommand {","+\tcmd := &beamsExecCommand{","+\t\tCmdClause: parent.Command(\"exec\", \"Run a command in a beam, via SSH.\"),","+\t}","+\tcmd.Arg(\"name\", \"ID (or UUID) of the beam to target.\").Required().StringVar(&cmd.name)","+\tcmd.Arg(\"command\", \"Command to execute in the instance.\").Required().StringsVar(&cmd.command)","+\treturn cmd","+}","+","+func (c *beamsExecCommand) run(cf *CLIConf) error {","+\tctx := cf.Context","+","+\ttc, err := makeClient(cf)","+\tif err != nil {","+\t\treturn trace.Wrap(err)","+\t}","+\ttc.AllowHeadless = true","+","+\tvar beam *beamsv1.Beam","+\terr = client.RetryWithRelogin(ctx, tc, func() error {","+\t\tclusterClient, err := tc.ConnectToCluster(ctx)","+\t\tif err != nil {","+\t\t\treturn trace.Wrap(err)","+\t\t}","+\t\tdefer clusterClient.Close()","+","+\t\trootClient, err := clusterClient.ConnectToRootCluster(ctx)","+\t\tif err != nil {","+\t\t\treturn trace.Wrap(err)","+\t\t}","+\t\tdefer rootClient.Close()","+","+\t\tbeam, err = getBeam(ctx, rootClient, c.name)","+\t\treturn trace.Wrap(err)","+\t})","+\tif err != nil {","+\t\treturn trace.Wrap(err)","+\t}","+","+\treturn trace.Wrap(sshBeam(cf, tc, beam, c.command))","+}"],"additions":75,"deletions":0,"truncated":false},{"path":"tool/tsh/common/beams_ls.go","lines":["@@ -0,0 +1,182 @@","+/*","+ * Teleport","+ * Copyright (C) 2026  Gravitational, Inc.","+ *","+ * This program is free software: you can redistribute it and/or modify","+ * it under the terms of the GNU Affero General Public License as published by","+ * the Free Software Foundation, either version 3 of the License, or","+ * (at your option) any later version.","+ *","+ * This program is distributed in the hope that it will be useful,","+ * but WITHOUT ANY WARRANTY; without even the implied warranty of","+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the","+ * GNU Affero General Public License for more details.","+ *","+ * You should have received a copy of the GNU Affero General Public License","+ * along with this program.  If not, see <http://www.gnu.org/licenses/>.","+ */","+","+package common","+","+import (","+\t\"context\"","+\t\"io\"","+\t\"strings\"","+\t\"time\"","+","+\t\"github.com/alecthomas/kingpin/v2\"","+\t\"github.com/dustin/go-humanize\"","+\t\"github.com/gravitational/trace\"","+","+\t\"github.com/gravitational/teleport\"","+\tbeamsv1 \"github.com/gravitational/teleport/api/gen/proto/go/teleport/beams/v1\"","+\t\"github.com/gravitational/teleport/api/utils/clientutils\"","+\t\"github.com/gravitational/teleport/lib/asciitable\"","+\t\"github.com/gravitational/teleport/lib/client\"","+\t\"github.com/gravitational/teleport/lib/defaults\"","+\t\"github.com/gravitational/teleport/lib/itertools/stream\"","+\t\"github.com/gravitational/teleport/tool/common\"","+)","+","+type beamsLSCommand struct {","+\t*kingpin.CmdClause","+\tall    bool","+\tformat string","+","+\t// These helper functions can be overridden.","+\tfetchFn        func(context.Context, *client.TeleportClient, bool) ([]*beamsv1.Beam, error)","+\tproxyAddrFn    func(*CLIConf) (string, error)","+\thumanizeTimeFn func(time.Time) string","+}","+","+func newBeamsLSCommand(parent *kingpin.CmdClause) *beamsLSCommand {","+\tcmd := &beamsLSCommand{","+\t\tCmdClause: parent.Command(\"ls\", \"List beam instances.\").Alias(\"list\"),","+\t}","+\tcmd.fetchFn = cmd.fetch","+\tcmd.proxyAddrFn = cmd.proxyAddr","+\tcmd.humanizeTimeFn = humanize.Time","+","+\tcmd.Flag(\"all\", \"List all beams. By default, filters to show only beams belonging to the current user.\").BoolVar(&cmd.all)","+\tcmd.Flag(\"format\", defaults.FormatFlagDescription(defaults.DefaultFormats...)).","+\t\tShort('f').","+\t\tDefault(teleport.Text).","+\t\tEnumVar(&cmd.format, defaults.DefaultFormats...)","+\treturn cmd","+}","+","+func (c *beamsLSCommand) run(cf *CLIConf) error {","+\tctx := cf.Context","+","+\ttc, err := makeClient(cf)","+\tif err != nil {","+\t\treturn trace.Wrap(err)","+\t}","+","+\tbeams, err := c.fetchFn(ctx, tc, c.all)","+\tif err != nil {","+\t\treturn trace.Wrap(err)","+\t}","+","+\tproxyAddr, err := c.proxyAddrFn(cf)","+\tif err != nil {","+\t\treturn trace.Wrap(err)","+\t}","+","+\treturn trace.Wrap(c.print(cf, beams, proxyAddr))","+}","+","+func (c *beamsLSCommand) fetch(ctx context.Context, tc *client.TeleportClient, all bool) ([]*beamsv1.Beam, error) {","+\tvar beams []*beamsv1.Beam","+\terr := client.RetryWithRelogin(ctx, tc, func() error {","+\t\tclusterClient, err := tc.ConnectToCluster(ctx)","+\t\tif err != nil {","+\t\t\treturn trace.Wrap(err)","+\t\t}","+\t\tdefer clusterClient.Close()","+","+\t\trootClient, err := clusterClient.ConnectToRootCluster(ctx)","+\t\tif err != nil {","+\t\t\treturn trace.Wrap(err)","+\t\t}","+\t\tdefer rootClient.Close()",