lumn when the user passed the `--all` flag,","+\t// otherwise there's no point as we're just showing them their own beams.","+\tif c.all {","+\t\theadings = append(headings, \"Owner\")","+\t}","+","+\ttable := asciitable.MakeTable(headings)","+\tfor _, beam := range beams {","+\t\trow := []string{","+\t\t\tbeam.ID,","+\t\t\tbeam.URL,","+\t\t\tc.humanizeTimeFn(beam.Expires),","+\t\t}","+\t\tif c.all {","+\t\t\trow = append(row, beam.Owner)","+\t\t}","+\t\ttable.AddRow(row)","+\t}","+\treturn trace.Wrap(table.WriteTo(w))","+}"],"additions":182,"deletions":0,"truncated":false},{"path":"tool/tsh/common/beams_ls_test.go","lines":["@@ -0,0 +1,154 @@","+/*","+ * Teleport","+ * Copyright (C) 2026  Gravitational, Inc.","+ *","+ * This program is free software: you can redistribute it and/or modify","+ * it under the terms of the GNU Affero General Public License as published by","+ * the Free Software Foundation, either version 3 of the License, or","+ * (at your option) any later version.","+ *","+ * This program is distributed in the hope that it will be useful,","+ * but WITHOUT ANY WARRANTY; without even the implied warranty of","+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the","+ * GNU Affero General Public License for more details.","+ *","+ * You should have received a copy of the GNU Affero General Public License","+ * along with this program.  If not, see <http://www.gnu.org/licenses/>.","+ */","+","+package common","+","+import (","+\t\"bytes\"","+\t\"context\"","+\t\"testing\"","+\t\"time\"","+","+\t\"github.com/dustin/go-humanize\"","+\t\"github.com/stretchr/testify/require\"","+\t\"google.golang.org/protobuf/types/known/timestamppb\"","+","+\t\"github.com/gravitational/teleport\"","+\tbeamsv1 \"github.com/gravitational/teleport/api/gen/proto/go/teleport/beams/v1\"","+\theaderv1 \"github.com/gravitational/teleport/api/gen/proto/go/teleport/header/v1\"","+\t\"github.com/gravitational/teleport/lib/client\"","+\t\"github.com/gravitational/teleport/