l billed credits","+ * for a `/v1/messages` request as `copilot_usage.total_nano_aiu` on the","+ * Anthropic SSE stream. The Claude SDK subprocess strips this field from","+ * its `result` message, so the proxy — which sees the raw CAPI response —","+ * is the only place the real billed amount survives. `sessionId` is","+ * decoded from the proxy Bearer token (`<nonce>.<sessionId>`) so consumers","+ * can attribute credits to the originating session/turn.","+ */","+export interface IClaudeProxyCreditsReport {","+\treadonly sessionId: string;","+\t/** Billed credits for the request, in nano-AIU (1 credit = 1e9 nano-AIU). */","+\treadonly totalNanoAiu: number;","+}","+"," export interface IClaudeProxyService {"," \treadonly _serviceBrand: undefined;"," ","+\t/**","+\t * Fires once per completed CAPI `/v1/messages` request that reported","+\t * `copilot_usage.total_nano_aiu`. Consumers accumulate per turn to","+\t * surface real per-turn Copilot credits (the SDK-computed","+\t * `total_cost_usd` is an Anthropic-list-price estimate, not the","+\t * amount CAPI actually bills).","+\t */","+\treadonly onDidReportCredits: Event<IClaudeProxyCreditsReport>;","+"," \t/**"," \t * Start the proxy (if not already running) and return a refcounted"," \t * handle. The supplied `githubToken` becomes the active token for","@@ -123,6 +148,26 @@ function generateNonce(): string {"," \treturn out;"," }"," ","+/**","+ * CAPI augments the Anthropic `/v1/messages` response with the request's","+ * billed credits under `copilot_usage.total_nano_aiu`. The published","+ * Anthropic SDK types don't declare it, so narrow through this shape","+ * (mirrors `messagesApi.ts` in the Copilot extension).","+ */","+interface ICopilotUsageEnvelope {","+\treadonly copilot_usage?: { readonly total_nano_aiu?: number };","+}","+","+/**","+ * Read `copilot_usage.total_nano_aiu` off an Anthropic stream event or","+ * message, returning `undefined` unless it is a finite, non-negative","+ * number.","+ */","+fu