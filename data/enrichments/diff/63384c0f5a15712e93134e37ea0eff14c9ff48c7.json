{"id":"63384c0f5a15712e93134e37ea0eff14c9ff48c7","axis":"silent","repo":"microsoft/vscode","sha":"63384c0f5a15712e93134e37ea0eff14c9ff48c7","parsed":{"files":[{"path":"src/vs/platform/agentHost/node/claude/claudeAgent.ts","lines":["@@ -241,6 +241,13 @@ export class ClaudeAgent extends Disposable implements IAgent {"," \t) {"," \t\tsuper();"," \t\tthis._metadataStore = _instantiationService.createInstance(ClaudeSessionMetadataStore, this.id);","+\t\t// CAPI reports each request's billed credits via the proxy (the SDK","+\t\t// strips `copilot_usage` from its `result`). Route every report to","+\t\t// the originating session by the session id the proxy decoded from","+\t\t// the Bearer token, so the session can surface real per-turn credits.","+\t\tthis._register(this._claudeProxyService.onDidReportCredits(e => {","+\t\t\tthis._findAnySession(e.sessionId)?.recordTurnCredits(e.totalNanoAiu);","+\t\t}));"," \t}"," "," \t// #region Descriptor + auth"],"additions":7,"deletions":0,"truncated":false},{"path":"src/vs/platform/agentHost/node/claude/claudeAgentSession.ts","lines":["@@ -191,6 +191,54 @@ export class ClaudeAgentSession extends Disposable {"," \tprivate readonly _onDidSessionProgress = this._register(new Emitter<AgentSignal>());"," \treadonly onDidSessionProgress: Event<AgentSignal> = this._onDidSessionProgress.event;"," ","+\t/**","+\t * Real Copilot credits (in nano-AIU) billed by CAPI for the current","+\t * turn, summed across every `/v1/messages` request the SDK made","+\t * (including subagents). Fed by {@link recordTurnCredits} from the","+\t * proxy's `onDidReportCredits`, reset at the start of each {@link send},","+\t * and attached to the turn's `ChatUsage` signal by","+\t * {@link _enrichSignalWithCredits}. Unlike the SDK's `total_cost_usd`","+\t * (an Anthropic-list-price estimate), this is what CAPI actually bills.","+\t */","+\tprivate _currentTurnNanoAiu = 0;","+","+\t/**","+\t * Accumulate proxy-reported billed credits for the in-flight turn.","+\