ization': `Bearer ${handle.nonce}.sess-9`,","+\t\t\t\t\t\t'Content-Type': 'application/json',","+\t\t\t\t\t},","+\t\t\t\t\tbody: JSON.stringify({ model: 'claude-opus-4-6', messages: [], max_tokens: 8 }),","+\t\t\t\t});","+\t\t\t\tassert.deepStrictEqual(reports, []);","+\t\t\t} finally {","+\t\t\t\tsub.dispose();","+\t\t\t\thandle.dispose();","+\t\t\t\tservice.dispose();","+\t\t\t}","+\t\t});","+\t});","+","+\t// #endregion","+"," \t// #region Body validation"," "," \tsuite('Body validation', () => {"],"additions":87,"deletions":0,"truncated":false},{"path":"src/vs/workbench/contrib/chat/browser/agentSessions/agentHost/agentHostSessionHandler.ts","lines":["@@ -2869,14 +2869,31 @@ export class AgentHostSessionHandler extends Disposable implements IChatSessionC"," \t */"," \tprivate _createTurnModelLookup(sessionResource: URI, fallbackRawModelId: string | undefined): TurnModelLookup {"," \t\tconst resolveRaw = (rawModelId: string | undefined): string | undefined => rawModelId ?? fallbackRawModelId;","-\t\treturn {","-\t\t\ttoLanguageModelId: (rawModelId) => this._toLanguageModelId(sessionResource, resolveRaw(rawModelId)),","-\t\t\ttoResponseDetails: (rawModelId, usage) => {","-\t\t\t\tconst modelId = this._toLanguageModelId(sessionResource, resolveRaw(rawModelId));","+\t\t// Resolve the registered language model for a turn, trying the","+\t\t// turn's own reported model id first and then the session's","+\t\t// fallback model id. The turn-reported id can differ from the","+\t\t// registered id (e.g. the Claude SDK reports the raw provider","+\t\t// slug `claude-sonnet-4-6` while models are registered under the","+\t\t// CAPI id `claude-sonnet-4.6`); without this fallback the lookup","+\t\t// fails and the entire response-detail footer — including","+\t\t// per-turn credits — is dropped.","+\t\tconst lookupModel = (rawModelId: string | undefined) => {","+\t\t\tfor (const candidate of [rawModelId, fallbackRawModelId]) {","+\t\t\t\tconst modelId = this._toLanguageModelId(