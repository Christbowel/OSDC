sql/pgwire/pgcode\"","+\t\"github.com/cockroachdb/cockroach/pkg/sql/pgwire/pgerror\"","+\t\"github.com/cockroachdb/cockroach/pkg/sql/pgwire/pgnotice\"","+\t\"github.com/cockroachdb/cockroach/pkg/sql/privilege\"","+\t\"github.com/cockroachdb/cockroach/pkg/sql/sem/catconstants\"","+\t\"github.com/cockroachdb/cockroach/pkg/sql/sem/eval\"","+\t\"github.com/cockroachdb/cockroach/pkg/sql/sem/tree\"","+\t\"github.com/cockroachdb/cockroach/pkg/sql/sessiondata\"","+\t\"github.com/cockroachdb/cockroach/pkg/sql/sessioninit\"","+\t\"github.com/cockroachdb/cockroach/pkg/sql/sqltelemetry\"","+\t\"github.com/cockroachdb/cockroach/pkg/sql/types\"","+\t\"github.com/cockroachdb/cockroach/pkg/util/log/eventpb\"","+\t\"github.com/cockroachdb/redact\"","+)","+","+// maxDropProvisionedRolesLimit is the maximum number of roles that can","+// be dropped in a single DROP PROVISIONED ROLES statement. Each role","+// requires dependency checks across all descriptors plus multiple","+// system table mutations, so we cap the batch size to keep","+// transactions bounded.","+const maxDropProvisionedRolesLimit = 1024","+","+// DropProvisionedRolesNode drops provisioned users matching filter","+// criteria (SOURCE, LAST LOGIN BEFORE) with a required LIMIT. Users","+// that own objects or have dependencies are skipped with a NOTICE","+// rather than failing the entire operation.","+type DropProvisionedRolesNode struct {","+\tzeroInputPlanNode","+\tsource          tree.TypedExpr // nil if no SOURCE filter","+\tlastLoginBefore tree.TypedExpr // nil if no LAST LOGIN BEFORE filter","+\tlimitCount      int64","+}","+","+// DropProvisionedRoles creates a plan node for DROP PROVISIONED ROLES.","+// Requires CREATEROLE privilege.","+func (p *planner) DropProvisionedRoles(","+\tctx context.Context, n *tree.DropProvisionedRoles,","+) (planNode, error) {","+\tif err := p.CheckGlobalPrivilegeOrRoleOption(ctx, privilege.CREATEROLE); err != nil {","+\t\treturn nil, err","+\t}","+\t// LIMIT is required to prevent accidentally dropping an unbounded","+\t// number of roles in a single transaction.","+\tif n.Limit == nil || n.Limit.Count == nil {","+\t\treturn nil, pgerror.Newf(pgcode.InvalidParameterValue,","+\t\t\t\"LIMIT is required for DROP PROVISIONED ROLES\")","+\t}","+\t// Validate that the LIMIT expression is a constant integer to","+\t// prevent subqueries or other expressions from being smuggled","+\t// into the internal query.","+\tnumVal, ok := n.Limit.Count.(*tree.NumVal)","+\tif !ok {","+\t\treturn nil, pgerror.Newf(pgcode.InvalidParameterValue,","+\t\t\t\"LIMIT must be a constant integer expression\")","+\t}","+\tlimitInt, err := numVal.AsInt64()","+\tif err != nil {","+\t\treturn nil, pgerror.Wrapf(err, pgcode.InvalidParameterValue,","+\t\t\t\"LIMIT must be an integer\")","+\t}","+\tif limitInt <= 0 || limitInt > maxDropProvisionedRolesLimit {","+\t\treturn nil, pgerror.Newf(pgcode.InvalidParameterValue,","+\t\t\t\"LIMIT must be between 1 and %d\", maxDropProvisionedRolesLimit)","+\t}","+","+\t// Type-check SOURCE and LAST LOGIN BEFORE expressions so that","+\t// expressions like now() - '7d'::interval are properly evaluated","+\t// at execution time rather than being pretty-printed as text.","+\tnode := &DropProvisionedRolesNode{limitCount: limitInt}","+\tvar dummyHelper tree.IndexedVarHelper","+","+\tif n.Options != nil && n.Options.Source != nil {","+\t\texpr := paramparse.UnresolvedNameToStrVal(n.Options.Source)","+\t\ttyped, err := p.analyzeExpr(","+\t\t\tctx, expr, dummyHelper, types.String, true, /* requireType */","+\t\t\t\"DROP PROVISIONED ROLES SOURCE\",","+\t\t)","+\t\tif err != nil {","+\t\t\treturn nil, err","+\t\t}","+\t\tnode.source = typed","+\t}","+","+\tif n.Options != nil && n.Options.LastLoginBefore != nil {","+\t\texpr := paramparse.UnresolvedNameToStrVal(n.Options.LastLoginBefore)","+\t\ttyped, err := p.analyzeExpr(","+\t\t\tctx, expr, dummyHelper, types.TimestampTZ, true, /* requireType */","+\t\t\t\"DROP PROVISIONED ROLES LAST LOGIN BEFORE\",","+\t\t)","+\t\tif err != nil {","+\t\t\treturn nil, err","+\t\t}","+\t\tnode.lastLoginBefore = typed","+\t}","+","+\treturn node, nil","+}","+","+func (n *DropProvisionedRolesNode) startExec(params runParams) error {","+\tsqltelemetry.IncIAMDropCounter(sqltelemetry.Role)","+\tconst opName redact.RedactableString = \"drop-provisioned-roles\"","+","+\thasAdmin, err := params.p.HasAdminRole(params.ctx)","+\tif err != nil {","+\t\treturn err","+\t}","+","+\t// Evaluate filter expressions and build the query.","+\tsourceVal, lastLoginVal, err := n.evalFilterExprs(params)","+\tif err != nil {","+\t\treturn err","+\t}","+\tquery, queryArgs := buildProvisionedRolesQuery(sourceVal, lastLoginVal, n.limitCount)","+","+\trows, err := params.p.InternalSQLTxn().QueryBufferedEx(","+\t\tparams.ctx,","+\t\t\"drop-provisioned-roles-find\",","+\t\tparams.p.txn,","+\t\tsessiondata.InternalExecutorOverride{User: params.p.User()},","+\t\tquery,","+\t\tqueryArgs...,","+\t)","+\tif err != nil {","+\t\treturn err","+\t}","+","+\t// Collect all descriptors once for dependency checking.","+\tallDescs, err := params.p.Descriptors().GetAllDescriptors(","+\t\tparams.ctx, params.p.txn,","+\t)","+\tif err != nil {","+\t\treturn err","+\t}","+","+\tvar numDropped, numSkipped int","+\tvar droppedNames []string","+\tvar numRoleSettingsRowsDeleted int","+","+\tfor _, row := range rows {","+\t\tnormalizedUsername := username.MakeSQLUsernameFromPreNormalizedString(","+\t\t\tstring(tree.MustBeDString(row[0])),","+\t\t)","+","+\t\t// Skip reserved roles (public, node, pg_*, crdb_internal_*),","+\t\t// root, and admin.","+\t\tif normalizedUsername.IsReserved() ||","+\t\t\tnormalizedUsername.IsRootUser() ||","+\t\t\tnormalizedUsername.IsAdminRole() {","+\t\t\tcontinue","+\t\t}","+","+\t\t// Non-admin users cannot drop admins.","+\t\tif !hasAdmin {","+\t\t\ttargetIsAdmin, err := params.p.UserHasAdminRole(","+\t\t\t\tparams.ctx, normalizedUsername,","+\t\t\t)","+\t\t\tif err != nil {","+\t\t\t\treturn err","+\t\t\t}","+\t\t\tif targetIsAdmin {","+\t\t\t\tparams.p.BufferClientNotice(","+\t\t\t\t\tparams.ctx,","+\t\t\t\t\tpgnotice.Newf(\"skipping %q: must be superuser to drop superusers\", normalizedUsername),","+\t\t\t\t)","+\t\t\t\tnumSkipped++","+\t\t\t\tcontinue","+\t\t\t}","+\t\t}","+","+\t\t// Check for dependencies (owned objects, grants, default","+\t\t// privileges, scheduled jobs, system privileges).","+\t\tif hasDeps, err := n.userHasDependencies(","+\t\t\tparams, normalizedUsername, allDescs,","+\t\t); err != nil {","+\t\t\treturn err","+\t\t} else if hasDeps {","+\t\t\tparams.p.BufferClientNotice(","+\t\t\t\tparams.ctx,","+\t\t\t\tpgnotice.Newf(\"skipping %q: role has dependent objects\", normalizedUsername),","+\t\t\t)","+\t\t\tnumSkipped++","+\t\t\tcontinue","+\t\t}","+","+\t\t// Delete the role from all system tables.","+\t\tdeleted, err := n.deleteRole(params, normalizedUsername, opName)","+\t\tif err != nil {","+\t\t\treturn err","+\t\t}","+\t\tnumRoleSettingsRowsDeleted += deleted","+\t\tnumDropped++","+\t\tdroppedNames = append(droppedNames, normalizedUsername.Normalized())","+\t}","+","+\t// Bump table versions if anything was dropped.","+\tif numDropped > 0 {","+\t\tif sessioninit.CacheEnabled.Get(&params.p.ExecCfg().Settings.SV) {","+\t\t\tif err := params.p.bumpUsersTableVersion(params.ctx); err != nil {","+\t\t\t\treturn err","+\t\t\t}","+\t\t\tif err := params.p.bumpRoleOptionsTableVersion(params.ctx); err != nil {","+\t\t\t\treturn err","+\t\t\t}","+\t\t\tif numRoleSettingsRowsDeleted > 0 {","+\t\t\t\tif err := params.p.bumpDatabaseRoleSettingsTableVersion(params.ctx); err != nil {","+\t\t\t\t\treturn err","+\t\t\t\t}","+\t\t\t}","+\t\t}","+\t\tif err := params.p.BumpRoleMembershipTableVersion(params.ctx); err != nil {","+\t\t\treturn err","+\t\t}","+","+\t\t// Log per-user DropRole events.","+\t\tfor _, name := range droppedNames {","+\t\t\tif err := params.p.logEvent(params.ctx,","+\t\t\t\t0, /* no target */","+\t\t\t\t&eventpb.DropRole{RoleName: name}); err != nil {","+\t\t\t\treturn err","+\t\t\t}","+\t\t}","+\t}","+","+\treturn nil","+}","+","+// evalFilterExprs evaluates the typed SOURCE and LAST LOGIN BEFORE","+// expressions using the session's EvalContext, returning concrete","+// Go values suitable for parameterized query arguments.","+func (n *DropProvisionedRolesNode) evalFilterExprs(","+\tparams runParams,","+) (sourceVal *string, lastLoginVal *tree.DTimestampTZ, err error) {","+\tif n.source != nil {","+\t\td, err := eval.Expr(params.ctx, params.EvalContext(), n.source)","+\t\tif err != nil {","+\t\t\treturn nil, nil, err","+\t\t}","+\t\ts := string(tree.MustBeDString(d))","+\t\tsourceVal = &s","+\t}","+\tif n.lastLoginBefore != nil {","+\t\td, err := eval.Expr(params.ctx, params.EvalContext(), n.lastLoginBefore)","+\t\tif err != nil {","+\t\t\treturn nil, nil, err","+\t\t}","+\t\tv := tree.MustBeDTimestampTZ(d)","+\t\tlastLoginVal = &v","+\t}","+\treturn sourceVal, lastLoginVal, nil","+}","+","+// buildProvisionedRolesQuery constructs the parameterized SQL query","+// to find provisioned users matching the given filter values.","+func buildProvisionedRolesQuery(","+\tsourceVal *string, lastLoginVal *tree.DTimestampTZ, limitCount int64,","+) (string, []any) {","+\tvar whereExprs []string","+\tvar args []any","+\targIdx := 1","+","+\t// Always filter for users that have a PROVISIONSRC role option","+\t// (i.e. are provisioned).","+\tprovisionFilter := \"EXISTS (SELECT 1 FROM system.role_options AS src\" +","+\t\t\" WHERE src.username = u.username AND src.option = 'PROVISIONSRC'\"","+","+\tif sourceVal != nil {","+\t\tprovisionFilter += fmt.Sprintf(\" AND src.value = $%d\", argIdx)","+\t\targs = append(args, *sourceVal)","+\t\targIdx++","+\t}","+\tprovisionFilter += \")\"","+\twhereExprs = append(whereExprs, provisionFilter)","+","+\tif lastLoginVal != nil {","+\t\twhereExprs = append(whereExprs, fmt.Sprintf(","+\t\t\t\"(u.estimated_last_login_time IS NULL OR u.estimated_last_login_time < $%d)\", argIdx,","+\t\t))","+\t\targs = append(args, lastLoginVal.Time)","+\t\targIdx++","+\t}","+","+\twhereClause := \" WHERE \" + strings.Join(whereExprs, \" AND \")","+","+\tlimitClause := fmt.Sprintf(\" LIMIT $%d\", argIdx)","+\targs = append(args, limitCount)","+","+\tquery := fmt.Sprintf(","+\t\t`SELECT u.username FROM system.users AS u%s%s`,","+\t\twhereClause, limitClause,","+\t)","+","+\treturn query, args","+}","+","+// userHasDependencies checks whether the given user owns any objects,","+// has grants, default privileges, row-level security policies,","+// scheduled jobs, or system privileges that would prevent dropping.","+func (n *DropProvisionedRolesNode) userHasDependencies(","+\tparams runParams, normalizedUsername username.SQLUsername, allDescs nstree.Catalog,","+) (bool, error) {","+\t// Check ownership, grants, default privileges, and RLS policies","+\t// across all descriptors.","+\tfor _, desc := range allDescs.OrderedDescriptors() {","+\t\tif !descriptorIsVisible(desc, true /* allowAdding */, false /* includeDropped */) {","+\t\t\tcontinue","+\t\t}","+\t\tif desc.GetPrivileges().Owner() == normalizedUsername {","+\t\t\treturn true, nil","+\t\t}","+\t\tfor _, u := range desc.GetPrivileges().Users {","+\t\t\tif u.User() == normalizedUsername {","+\t\t\t\treturn true, nil","+\t\t\t}","+\t\t}","+","+\t\t// Check default privileges on databases and schemas.","+\t\tvar defaultPrivs catalog.DefaultPrivilegeDescriptor","+\t\tif dbDesc, ok := desc.(catalog.DatabaseDescriptor); ok {","+\t\t\tdefaultPrivs = dbDesc.GetDefaultPrivilegeDescriptor()","+\t\t} else if schemaDesc, ok := desc.(catalog.SchemaDescriptor); ok {","+\t\t\tdefaultPrivs = schemaDesc.GetDefaultPrivilegeDescriptor()","+\t\t}","+\t\tif defaultPrivs != nil {","+\t\t\thasDep := false","+\t\t\tif err := defaultPrivs.ForEachDefaultPrivilegeForRole(","+\t\t\t\tfunc(dpForRole catpb.DefaultPrivilegesForRole) error {","+\t\t\t\t\tif dpForRole.IsExplicitRole() &&","+\t\t\t\t\t\tdpForRole.GetExplicitRole().UserProto.Decode() == normalizedUsername {","+\t\t\t\t\t\thasDep = true","+\t\t\t\t\t}","+\t\t\t\t\tfor _, privs := range dpForRole.DefaultPrivilegesPerObject {","+\t\t\t\t\t\tfor _, u := range privs.Users {","+\t\t\t\t\t\t\tif u.User() == normalizedUsername {","+\t\t\t\t\t\t\t\thasDep = true","+\t\t\t\t\t\t\t}","+\t\t\t\t\t\t}","+\t\t\t\t\t}","+\t\t\t\t\treturn nil","+\t\t\t\t},","+\t\t\t); err != nil {","+\t\t\t\treturn false, err","+\t\t\t}","+\t\t\tif hasDep {","+\t\t\t\treturn true, nil","+\t\t\t}","+\t\t}","+","+\t\t// Check row-level security policies on tables.","+\t\tif tblDesc, ok := desc.(catalog.TableDescriptor); ok {","+\t\t\tfor _, p := range tblDesc.GetPolicies() {","+\t\t\t\tfor _, rn := range p.RoleNames {","+\t\t\t\t\tif username.MakeSQLUsernameFromPreNormalizedString(rn) == normalizedUsername {","+\t\t\t\t\t\treturn true, nil","+\t\t\t\t\t}","+\t\t\t\t}","+\t\t\t}","+\t\t}","+\t}","+","+\t// Check scheduled jobs. Use NodeUserSessionDataOverride because","+\t// CREATEROLE users cannot read system.scheduled_jobs directly.","+\t// This is safe since the query is hardcoded with only a","+\t// parameterized username — no user-controlled SQL expressions.","+\trow, err := params.p.InternalSQLTxn().QueryRowEx(","+\t\tparams.ctx,","+\t\t\"check-user-schedules\",","+\t\tparams.p.txn,","+\t\tsessiondata.NodeUserSessionDataOverride,","+\t\t\"SELECT count(*) FROM system.scheduled_jobs WHERE owner=$1\",","+\t\tnormalizedUsername,","+\t)","+\tif err != nil {","+\t\treturn false, err","+\t}","+\tif row != nil && int64(tree.MustBeDInt(row[0])) > 0 {","+\t\treturn true, nil","+\t}","+","+\t// Check system privileges. Same as above — use node privileges","+\t// for the hardcoded parameterized query.","+\trow, err = params.p.InternalSQLTxn().QueryRowEx(","+\t\tparams.ctx,","+\t\t\"check-user-system-privileges\",","+\t\tparams.p.txn,","+\t\tsessiondata.NodeUserSessionDataOverride,","+\t\t\"SELECT count(*) FROM system.privileges WHERE username=$1\",","+\t\tnormalizedUsername.Normalized(),","+\t)","+\tif err != nil {","+\t\treturn false, err","+\t}","+\tif row != nil && int64(tree.MustBeDInt(row[0])) > 0 {","+\t\treturn true, nil","+\t}","+","+\treturn false, nil","+}","+","+// deleteRole removes a single role from all system tables and revokes","+// its web sessions.","+func (n *DropProvisionedRolesNode) deleteRole(","+\tparams runParams, normalizedUsername username.SQLUsername, opName redact.RedactableString,","+) (int, error) {","+\t// DELETE from system.users.","+\tif _, err := params.p.InternalSQLTxn().ExecEx(","+\t\tparams.ctx, opName, params.p.txn,","+\t\tsessiondata.NodeUserSessionDataOverride,","+\t\t`DELETE FROM system.users WHERE username=$1`,","+\t\tnormalizedUsername,","+\t); err != nil {","+\t\treturn 0, err","+\t}","+","+\t// DELETE from system.role_members.","+\tif _, err := params.p.InternalSQLTxn().ExecEx(","+\t\tparams.ctx, \"drop-role-membership\", params.p.txn,","+\t\tsessiondata.NodeUserSessionDataOverride,","+\t\t`DELETE FROM system.role_members WHERE \"role\" = $1 OR \"member\" = $1`,","+\t\tnormalizedUsername,","+\t); err != nil {","+\t\treturn 0, err","+\t}","+","+\t// DELETE from system.role_options.","+\tif _, err := params.p.InternalSQLTxn().ExecEx(","+\t\tparams.ctx, opName, params.p.txn,","+\t\tsessiondata.NodeUserSessionDataOverride,","+\t\tfmt.Sprintf(","+\t\t\t`DELETE FROM system.public.%s WHERE username=$1`,","+\t\t\tcatconstants.RoleOptionsTableName,","+\t\t),","+\t\tnormalizedUsername,","+\t); err != nil {","+\t\treturn 0, err","+\t}","+","+\t// DELETE from system.database_role_settings.","+\trowsDeleted, err := params.p.InternalSQLTxn().ExecEx(","+\t\tparams.ctx, opName, params.p.txn,","+\t\tsessiondata.NodeUserSessionDataOverride,","+\t\tfmt.Sprintf(","+\t\t\t`DELETE FROM system.public.%s WHERE role_name = $1`,","+\t\t\tcatconstants.DatabaseRoleSettingsTableName,","+\t\t),","+\t\tnormalizedUsername,","+\t)","+\tif err != nil {","+\t\treturn 0, err","+\t}","+","+\t// Revoke web ses