errors\"","+\t\"fmt\"","+","+\t\"github.com/grafana/grafana/apps/secret/pkg/decrypt\"","+\t\"github.com/grafana/grafana/pkg/apimachinery/utils\"","+)","+","+// DecryptedSecureJSONLoader returns the decrypted secure values for a resource","+// once preceding access checks have passed. Construction validates inputs;","+// the returned function performs the actual decryption on demand.","+type DecryptedSecureJSONLoader func(context.Context) (map[string]string, error)","+","+// EmptyDecryptedSecureJSONLoader is a loader that returns no secure values.","+// Use it when a resource is known to have nothing to decrypt.","+func EmptyDecryptedSecureJSONLoader(context.Context) (map[string]string, error) {","+\treturn map[string]string{}, nil","+}","+","+type ctxKey struct{}","+","+type secureContextShim struct {","+\tloader DecryptedSecureJSONLoader","+}","+","+// WithSecureContextShim must wrap a context before any request that may stash","+// already-decrypted values via WithDecryptedValues. Without the shim,","+// WithDecryptedValues is a no-op and GetDecryptedSecureJSONLoader falls through","+// to the decrypter.","+func WithSecureContextShim(ctx context.Context) context.Context {","+\treturn context.WithValue(ctx, ctxKey{}, &secureContextShim{})","+}","+","+// WithDecryptedValues stashes already-decrypted secure values on the context","+// shim so a later GetDecryptedSecureJSONLoader call returns them directly","+// without re-decrypting. No-op if WithSecureContextShim was not called.","+func WithDecryptedValues(ctx context.Context, loader DecryptedSecureJSONLoader) {","+\tif shim, ok := ctx.Value(ctxKey{}).(*secureContextShim); ok {","+\t\tshim.loader = loader","+\t}","+}","+","+// GetDecryptedSecureJSONLoader returns a loader for the decrypted secure values","+// of obj. If WithDecryptedValues populated the same context, those values are","+// reused; otherwise the loader calls decrypter on demand.","+func GetDecryptedSecureJSONLoader(ctx context.Context, obj utils.GrafanaMetaAccessor, decrypter decrypt.DecryptService) (DecryptedSecureJSONLoader, error) {","+\tif shim, ok := ctx.Value(ctxKey{}).(*secureContextShim); ok && shim.loader != nil {","+\t\treturn shim.loader, nil","+\t}","+","+\tsecure, err := obj.GetSecureValues()","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\tif len(secure) == 0 {","+\t\treturn EmptyDecryptedSecureJSONLoader, nil","+\t}","+\tif decrypter == nil {","+\t\treturn nil, errors.New(\"no decrypter configured\")","+\t}","+","+\t// Validate and collect names up front so config errors surface here rather","+\t// than on the first decrypt call.","+\tnames := make([]string, 0, len(secure))","+\tfor k, ref := range secure {","+\t\tif ref.Name == \"\" {","+\t\t\treturn nil, fmt.Errorf(\"missing secure value name for key: %s\", k)","+\t\t}","+\t\tnames = append(names, ref.Name)","+\t}","+","+\tgroup := obj.GetGroupVersionKind().Group","+\tnamespace := obj.GetNamespace()","+\treturn func(ctx context.Context) (map[string]string, error) {","+\t\tlookup, err := decrypter.Decrypt(ctx, group, namespace, names...)","+\t\tif err != nil {","+\t\t\treturn nil, fmt.Errorf(\"error decrypting secure values: %w\", err)","+\t\t}","+","+\t\tdecrypted := make(map[string]string, len(secure))","+\t\tfor k, ref := range secure {","+\t\t\tres, ok := lookup[ref.Name]","+\t\t\tif !ok {","+\t\t\t\treturn nil, fmt.Errorf(\"unable to find secure value: %s for key: %s\", ref.Name, k)","+\t\t\t}","+\t\t\tif err := res.Error(); err != nil {","+\t\t\t\treturn nil, fmt.Errorf(\"error decrypting secure value: %s / %w\", k, err)","+\t\t\t}","+\t\t\tif val := res.Value(); val != nil {","+\t\t\t\tdecrypted[k] = val.DangerouslyExposeAndConsumeValue()","+\t\t\t}","+\t\t}","+\t\treturn decrypted, nil","+\t}, nil","+}"],"additions":98,"deletions":0,"truncated":false},{"path":"pkg/services/pluginsintegration/pluginsettings/decrypted_test.go","lines":["@@ -0,0 +1,313 @@","+package pluginsettings","+","+import (","+\t\"context\"","+\t\"errors\"","+\t\"testing\"","+","+\t\"github.com/stretchr/testify/require\"","+\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"","+\t\"k8s.io/apimachinery/pkg/runtime/schema\"","+","+\tsecretv1beta1 \"github.com/grafana/grafana/apps/secret/pkg/apis/secret/v1beta1\"","+\t\"github.com/grafana/grafana/apps/secret/pkg/decrypt\"","+\tcommon \"github.com/grafana/grafana/pkg/apimachinery/apis/common/v0alpha1\"","+\t\"github.com/grafana/grafana/pkg/apimachinery/utils\"","+)","+","+const testAPIVersion = \"something.grafana.app/v7beta6\"","+","+func TestEmptyDecryptedSecureJSONLoader(t *testing.T) {","+\tout, err := EmptyDecryptedSecureJSONLoader(context.Background())","+\trequire.NoError(t, err)","+\trequire.Empty(t, out)","+\trequire.NotNil(t, out)","+}","+","+func TestSecureContextShim(t *testing.T) {","+\tt.Run(\"WithDecryptedValues without shim is a no-op\", func(t *testing.T) {","+\t\tctx := context.Background()","+\t\t// Should not panic; later GetDecryptedSecureJSONLoader must fall through","+\t\t// to the decrypter.","+\t\tWithDecryptedValues(ctx, func(context.Context) (map[string]string, error) {","+\t\t\tt.Fatal(\"loader should not be invoked\")","+\t\t\treturn nil, nil","+\t\t})","+","+\t\tobj := newTestObject(t, \"ns\", testAPIVersion, \"DataSource\", nil)","+\t\tloader, err := GetDecryptedSecureJSONLoader(ctx, obj, nil)","+\t\trequire.NoError(t, err)","+\t\t// No secure values configured, so we get the empty loader.","+\t\tout, err := loader(ctx)","+\t\trequire.NoError(t, err)","+\t\trequire.Empty(t, out)","+\t})","+","+\tt.Run(\"WithSecureContextShim + WithDecryptedValues short-circuits decrypter\", func(t *testing.T) {","+\t\tctx := WithSecureContextShim(context.Background())","+","+\t\tstashed := map[string]string{\"token\": \"abc\"}","+\t\tWithDecryptedValues(ctx, func(context.Context) (map[string]string, error) {","+\t\t\treturn stashed, nil","+\t\t})","+","+\t\t// Even with a decrypter and secure values present, the stashed loader wins.","+\t\tdec := &stubDecrypter{}","+\t\tobj := newTestObject(t, \"ns\", testAPIVersion, \"DataSource\", common.InlineSecureValues{","+\t\t\t\"token\": {Name: \"secret-token\"},","+\t\t})","+\t\tloader, err := GetDecryptedSecureJSONLoader(ctx, obj, dec)","+\t\trequire.NoError(t, err)","+\t\tout, err := loader(ctx)","+\t\trequire.NoError(t, err)","+\t\trequire.Equal(t, stashed, out)","+\t\trequire.Zero(t, dec.calls, \"decrypter must not be called when values were already stashed\")","+\t})","+","+\tt.Run(\"WithSecureContextShim without WithDecryptedValues falls through\", func(t *testing.T) {"],"additions":67,"deletions":0,"truncated":false}],"additions":318,"deletions":102,"truncated":true,"file_count":14},"error":null,"fetched_at":"2026-05-20T17:50:43.096175+00:00"}