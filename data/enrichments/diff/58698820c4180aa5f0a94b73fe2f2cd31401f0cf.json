SSL library. You","+# must comply with the Server Side Public License in all respects for","+# all of the code used other than as permitted herein. If you modify file(s)","+# with this exception, you may extend this exception to your version of the","+# file(s), but you are not obligated to do so. If you do not wish to do so,","+# delete this exception statement from your version. If you delete this","+# exception statement from all source files in the program, then also delete","+# it in the license file.","+#","+","+global:","+    cpp_namespace: \"mongo\"","+","+imports:","+    - \"mongo/db/basic_types.idl\"","+","+server_parameters:","+    clientMetadataUpdateLogRatePerSec:","+        description: >-","+            Maximum number of clientUpdate log entries (log id 51817) logged at INFO severity per","+            second across all connections. Entries that exceed this rate are demoted to DEBUG(2)","+            severity. A value of 0 disables the limit (all entries are logged at INFO).","+","+            Evaluation order: clientMetadataUpdateLogPerConnectionThrottlingSecs is evaluated first.","+            If the per-connection interval has not elapsed, the entry is dropped. Otherwise, this","+            cross connection rate limit is evaluated second and determines the log severity.","+        set_at: [startup]","+        cpp_varname: gClientMetadataUpdateLogRatePerSec","+        cpp_vartype: int32_t","+        default: 50","+        validator: {gte: 0, lte: 1000}","+        redact: false","+","+    clientMetadataUpdateDocumentMaxByteLength:","+        description: >-","+            Maximum size in bytes of a clientUpdate metadata document. Documents exceeding this size","+            are rejected by validation.","+        set_at: [startup]","+        cpp_varname: gClientMetadataUpdateDocumentMaxByteLength","+        cpp_vartype: int32_t","+        default: 1024","+        validator: {gte: 1}","+        redact: false","+","+    clientMetadataUpdateLogPerConnectionThrottlingSecs:","+        description: >-","+            Minimum number of seconds between clientUpdate log entries (log id 51817) for the same","+            connection. If a connection sends a clientUpdate before this interval has elapsed, the","+            entry is dropped. A value of 0 disables the limit (every update is logged).","+","+            Evaluation order: this per-connection interval is evaluated first. If the entry passes,","+            clientMetadataUpdateLogRatePerSec is evaluated second and determines the log severity.","+        set_at: [startup, runtime]","+        cpp_varname: gClientMetadataUpdateLogPerConnectionThrottlingSecs","+        cpp_vartype: Atomic<int32_t>","+        default: 1800","+        validator: {gte: 0}","+        redact: false"],"additions":76,"deletions":0,"truncated":false},{"path":"src/mongo/rpc/metadata/client_metadata_test.cpp","lines":["@@ -36,10 +36,17 @@"," #include \"mongo/bson/bsonobjbuilder.h\""," #include \"mongo/db/client.h\""," #include \"mongo/db/service_context.h\"","+#include \"mongo/logv2/log_manager.h\""," #include \"mongo/platform/process_id.h\"","+#include \"mongo/rpc/metadata/client_metadata_server_parameters_gen.h\"","+#include \"mongo/transport/transport_layer_mock.h\"","+#include \"mongo/unittest/log_capture.h\""," #include \"mongo/unittest/unittest.h\""," #include \"mongo/util/assert_util.h\"","+#include \"mongo/util/clock_source_mock.h\"","+#include \"mongo/util/scopeguard.h\""," #include \"mongo/util/testing_proctor.h\"","+#include \"mongo/util/tick_source_mock.h\""," "," #include <memory>"," #include <string>","@@ -64,6 +71,7 @@ constexpr auto kArchitecture = \"architecture\"sv;"," constexpr auto kMongos = \"mongos\"sv;"," constexpr auto kClient = \"client\"sv;"," constexpr auto kHost = \"host\"sv;","+constexpr auto kCid = \"cid\"sv;"," "," constexpr auto kUnknown = \"unkown\"sv;"," ","@@ -439,4 +447,197 @@ TEST(ClientMetadataTest, InternalClientLimit) {","     ASSERT_DOES_NOT_THROW(Client