{"id":"719268e847e7cdd0b0c7932049ceaf04251eccdb","axis":"silent","repo":"valkey-io/valkey","sha":"719268e847e7cdd0b0c7932049ceaf04251eccdb","parsed":{"files":[{"path":"src/redismodule.h","lines":["@@ -336,7 +336,14 @@"," #define RedisModuleCommandHistoryEntry ValkeyModuleCommandHistoryEntry"," "," /* RedisModule APIs */","-#define RedisModule_OnLoad ValkeyModule_OnLoad","+/*","+ * Keep RedisModule_OnLoad unmapped.","+ *","+ * Renaming this entry-point via macro substitution can break modules that use","+ * a linker version script to export RedisModule_OnLoad explicitly.","+ * valkey-server already supports loading both ValkeyModule_OnLoad and","+ * RedisModule_OnLoad symbols.","+ */"," #define RedisModule_Init ValkeyModule_Init"," #define RedisModule_Assert ValkeyModule_Assert"," #define RedisModule_Alloc ValkeyModule_Alloc"],"additions":8,"deletions":1,"truncated":false},{"path":"tests/modules/Makefile","lines":["@@ -69,6 +69,7 @@ TEST_MODULES = \\","     rdbloadsave.so \\","     crash.so \\","     cluster.so \\","+    hellovalkey.so \\","     helloscripting.so \\","     unsupported_features.so \\","     deferred_reply.so","@@ -86,6 +87,18 @@ all: $(TEST_MODULES)"," %.so: %.xo"," \t$(LD) -o $@ $^ $(SHOBJ_LDFLAGS) $(LDFLAGS) $(LIBS)"," ","+# hellovalkey is the only test module that exercises the legacy redismodule.h","+# include path (regression test for #547). The generic %.xo rule above only","+# tracks valkeymodule.h, so declare the redismodule.h dependency explicitly.","+hellovalkey.xo: ../../src/redismodule.h","+","+hellovalkey.so: hellovalkey.xo hellovalkey.version","+ifeq ($(uname_S),Linux)","+\t$(LD) -o $@ hellovalkey.xo $(SHOBJ_LDFLAGS) $(LDFLAGS) $(LIBS) -Wl,--version-script=hellovalkey.version","+else","+\t$(LD) -o $@ hellovalkey.xo $(SHOBJ_LDFLAGS) $(LDFLAGS) $(LIBS)","+endif","+"," .PHONY: clean"," "," clean:"],"additions":13,"deletions":0,"truncated":false},{"path":"tests/modules/hellovalkey.c","lines":["@@ -0,0 +1,11 @@","+#include \"redismodule.h\"","+","+int RedisModule_OnLoad(RedisModuleCtx *ctx, RedisModuleString **argv, int argc) {","+    REDISMODULE_NOT_USED(argv);","+    REDISMODULE_NOT_USED(argc);","+","+    if (RedisModule_Init(ctx, \"hello\", 1, REDISMODULE_APIVER_1) == REDISMODULE_ERR)","+        return REDISMODULE_ERR;","+","+    return REDISMODULE_OK;","+}"],"additions":11,"deletions":0,"truncated":false},{"path":"tests/modules/hellovalkey.version","lines":["@@ -0,0 +1,4 @@","+module {","+global: RedisModule_OnLoad;","+local: *;","+};"],"additions":4,"deletions":0,"truncated":false},{"path":"tests/unit/moduleapi/redismodule_onload.tcl","lines":["@@ -0,0 +1,14 @@","+set testmodule [file normalize tests/modules/hellovalkey.so]","+","+start_server {tags {\"modules external:skip\"}} {","+    test {module with RedisModule_OnLoad symbol exported via version script can be loaded} {","+        if {$::tcl_platform(os) eq \"Linux\"} {","+            set nm_out [exec nm -D $testmodule]","+            assert_match {*RedisModule_OnLoad*} $nm_out","+        }","+","+        assert_equal {OK} [r module load $testmodule]","+        verify_log_message 0 \"*Legacy Redis Module*hellovalkey.so found*\" 0","+        assert_equal {OK} [r module unload hello]","+    }","+}",""],"additions":14,"deletions":0,"truncated":false}],"additions":50,"deletions":1,"truncated":false,"file_count":5},"error":null,"fetched_at":"2026-06-11T12:27:19.500895+00:00"}