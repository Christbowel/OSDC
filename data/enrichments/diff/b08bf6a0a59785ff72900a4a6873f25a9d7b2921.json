"+\t\t{","+\t\t\tname:    \"python seal package\",","+\t\t\teco:     ecosystem.Pip,","+\t\t\tpkgName: \"seal-django\",","+\t\t\tpkgVer:  \"4.2.8+sp1\",","+\t\t\twant:    true,","+\t\t},","+\t\t{","+\t\t\tname:    \"python non-seal package\",","+\t\t\teco:     ecosystem.Pip,","+\t\t\tpkgName: \"django\",","+\t\t\tpkgVer:  \"4.2.8+sp1\",","+\t\t\twant:    false,","+\t\t},","+\t\t// Go - name prefix sealsecurity.io/","+\t\t{","+\t\t\tname:    \"go seal package\",","+\t\t\teco:     ecosystem.Go,","+\t\t\tpkgName: \"sealsecurity.io/github.com/Masterminds/goutils\",","+\t\t\tpkgVer:  \"v1.1.1-sp1\",","+\t\t\twant:    true,","+\t\t},","+\t\t{","+\t\t\tname:    \"go non-seal package\",","+\t\t\teco:     ecosystem.Go,","+\t\t\tpkgName: \"github.com/Masterminds/goutils\",","+\t\t\tpkgVer:  \"v1.1.1-sp1\",","+\t\t\twant:    false,","+\t\t},","+\t\t// Ruby - name prefix seal-","+\t\t{","+\t\t\tname:    \"ruby seal package\",","+\t\t\teco:     ecosystem.RubyGems,","+\t\t\tpkgName: \"seal-rack\",","+\t\t\tpkgVer:  \"2.0.7.0.1.sp1\",","+\t\t\twant:    true,","+\t\t},","+\t\t{","+\t\t\tname:    \"ruby non-seal package\",","+\t\t\teco:     ecosystem.RubyGems,","+\t\t\tpkgName: \"rack\",","+\t\t\tpkgVer:  \"2.0.7\",","+\t\t\twant:    false,","+\t\t},","+\t\t// Unsupported ecosystem","+\t\t{","+\t\t\tname:    \"erlang package is not supported\",","+\t\t\teco:     ecosystem.Erlang,","+\t\t\tpkgName: \"seal-cowboy\",","+\t\t\tpkgVer:  \"2.9.0\",","+\t\t\twant:    false,","+\t\t},","+\t\t// Edge cases","+\t\t{","+\t\t\tname:    \"empty version\",","+\t\t\teco:     ecosystem.Pip,","+\t\t\tpkgName: \"seal-requests\",","+\t\t\tpkgVer:  \"\",","+\t\t\twant:    true,","+\t\t},","+\t\t{","+\t\t\tname:    \"empty package name\",","+\t\t\teco:     ecosystem.Pip,","+\t\t\tpkgName: \"\",","+\t\t\tpkgVer:  \"1.0.0\",","+\t\t\twant:    false,","+\t\t},","+\t}","+","+\tfor _, tt := range tests {","+\t\tt.Run(tt.name, func(t *testing.T) {","+\t\t\ts := sealSecurity{}","+\t\t\tgot := s.Match(tt.eco, tt.pkgName, tt.pkgVer)","+\t\t\trequire.Equal(t, tt.want, got)","+\t\t})","+\t}","+}"],"additions":147,"deletions":0,"truncated":false},{"path":"pkg/detector/library/testdata/fixtures/data-source.yaml","lines":["@@ -35,3 +35,28 @@","         ID: \"julia\"","         Name: \"Julia Ecosystem Security Advisories\"","         URL: \"https://github.com/JuliaLang/SecurityAdvisories.jl\"","+    - key: \"seal pip::Seal Security Database\"","+      value:","+        ID: \"seal\"","+        Name: \"Seal Security Database\"","+        URL: \"http://vulnfeed.sealsecurity.io/v1/osv/renamed/vulnerabilities.zip\"","+    - key: \"seal rubygems::Seal Security Database\"","+      value:","+        ID: \"seal\"","+        Name: \"Seal Security Database\"","+        URL: \"http://vulnfeed.sealsecurity.io/v1/osv/renamed/vulnerabilities.zip\"","+    - key: \"seal npm::Seal Security Database\"","+      value:","+        ID: \"seal\"","+        Name: \"Seal Security Database\"","+        URL: \"http://vulnfeed.sealsecurity.io/v1/osv/renamed/vulnerabilities.zip\"","+    - key: \"seal go::Seal Security Database\"","+      value:","+        ID: \"seal\"","+        Name: \"Seal Security Database\"","+        URL: \"http://vulnfeed.sealsecurity.io/v1/osv/renamed/vulnerabilities.zip\"","+    - key: \"seal maven::Seal Security Database\"","+      value:","+        ID: \"seal\"","+        Name: \"Seal Security Database\"","+        URL: \"http://vulnfeed.sealsecurity.io/v1/osv/renamed/vulnerabilities.zip\""],"additions":25,"deletions":0,"truncated":false},{"path":"pkg/detector/library/testdata/fixtures/seal.yaml","lines":["@@ -0,0 +1,54 @@","+- bucket: \"seal pip::Seal Security Database\"","+  pairs:","+    - bucket: \"seal-requests\"","+      pairs:","+        - key: \"CVE-2023-32681\"","+          value:","+            PatchedVersions:","+              - \"2.14.2+sp999\"","+            VulnerableVersions:","+              - \">= 2.14.2+sp1, < 2.14.2+sp999\"","+","+- bucket: \"seal npm::Seal Security Database\"","+  pairs:","+    - bucket: \"@seal-security/ajv\"","+      pairs:","+        - key: \"CVE-2025-69873\"","+          value:","+            PatchedVersions:","+              - \"5.5.2-sp999\"","+            VulnerableVersions:","+              - \">=5.5.2-sp1 <5.5.2-sp999\"","+","+- bucket: \"seal go::Seal Security Database\"","+  pairs:","+    - bucket: \"sealsecurity.io/golang.org/x/crypto\"","+      pairs:","+        - key: \"CVE-2025-22869\"","+          value:","+            PatchedVersions:","+              - \"0.26.0-sp2\"","+            VulnerableVersions:","+              - \">= 0.26.0-sp1, < 0.26.0-sp2\"","+","+- bucket: \"seal rubygems::Seal Security Database\"","+  pairs:","+    - bucket: \"seal-rack\"","+      pairs:","+        - key: \"CVE-2025-61780\"","+          value:","+            PatchedVersions:","+              - \"2.0.7.0.1.sp999\"","+            VulnerableVersions:","+              - \">= 2.0.7.0.1.sp1, < 2.0.7.0.1.sp999\"","+","+- bucket: \"seal maven::Seal Security Database\"","+  pairs:","+    - bucket: \"seal.sp1.org.apache.logging.log4j:log4j-core\"","+      pairs:","+        - key: \"CVE-2025-68161\"","+          value:","+            PatchedVersions:","+              - \"2.13.3+sp999\"","+            VulnerableVersions:","+              - \">= 2.13.3, < 2.13.3+sp999\""],"additions":54,"deletions":0,"truncated":false},{"path":"pkg/detector/library/vendor.go","lines":["@@ -0,0 +1,73 @@","+package library","+","+import (","+\t\"fmt\"","+\t\"slices\"","+","+\t\"github.com/aquasecurity/trivy-db/pkg/ecosystem\"","+\t\"github.com/aquasecurity/trivy/pkg/detector/library/compare\"","+)","+","+// Vendor represents a third-party security vendor that provides patched packages","+// with their own vulnerability advisories. These vendors (e.g., Seal Security)","+// offer patched versions of open source packages and maintain separate advisory","+// databases that should be used instead of the standard ecosystem advisories.","+//","+// When a package is identified as coming from a vendor, Trivy queries the","+// vendor-specific advisory bucket (e.g., \"seal pip::\") rather than the","+// standard ecosystem bucket (e.g., \"pip::\").","+type Vendor interface {","+\t// Name returns the vendor identifier used in the advisory bucket prefix.","+\t// For example, \"seal\" results in advisory queries to \"seal pip::\", \"seal npm::\", etc.","+\tName() string","+","+\t// Match determines whether a package is provided by this vendor.","+\t// It receives the ecosystem type, a normalized package name","+\t// (see vulnerability.NormalizePkgName), and version to make the determination.","+\tMatch(eco ecosystem.Type, pkgName, pkgVer string) bool","+","+\t// BucketPrefix returns the advisory bucket prefix for the given ecosystem.","+\t// For example, \"seal pip::\" for Seal Security pip packages.","+\tBucketPrefix(eco ecosystem.Type) string","+","+\t// Comparer returns a version comparer for the given ecosystem.","+\t// The defaultComparer is provided so the vendor can return it unchanged","+\t// when no custom comparison logic is needed.","+\tComparer(eco ecosystem.Type, defaultComparer compare.Comparer) compare.Comparer","+}","+","+// vendors is the list of registered vendors. The first matching vendor wins.","+// See also: pkg/detector/ospkg/seal/ for the OS package equivalent.","+var vendors []Vendor","+","+// RegisterVendor registers a new vendor for library vulnerability detection.","+// It should be called from an init() function in the vendor's package.","+func RegisterVendor(v Vendor) {","+\tvendors = append(vendors, v)","+}","+","+// DeregisterVendor removes a registered vendor by name.","+// Use it to opt out of a vendor that was registered via","+// pkg/detector/library/all (e.g., DeregisterVendor(\"seal\")).","+func DeregisterVendor(name string) {","+\tvendors = slices.DeleteFunc(vendors, func(v Vendor) bool {","+\t\treturn v.Name() == name","+\t})","+}","+","+// lookupVendor finds the matching vendor for the given package.","+// If a vendor matches, it is returned with ok=true.","+// If no vendor matches, ok is false.","+func lookupVendor(eco ecosystem.Type, pkgName, pkgVer string) (Vendor, bool) {","+\tfor _, v := range vendors {","+\t\tif v.Match(eco, pkgName, pkgVer) {","+\t\t\treturn v, true","+\t\t}","+\t}","+\treturn nil, false","+}","+","+// defaultBucketPrefix returns the standard ecosystem bucket prefix (e.g. \"pip::\").","+func defaultBucketPrefix(eco ecosystem.Type) string {","+\treturn fmt.Sprintf(\"%s::\", eco)","+}"],"additions":73,"deletions":0,"truncated":false},{"path":"pkg/detector/library/vendor_test.go","lines":["@@ -0,0 +1,100 @@","+package library_test","+","+import (","+\t\"testing\"","+","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+","+\t\"github.com/aquasecurity/trivy-db/pkg/ecosystem\"","+\t\"github.com/aquasecurity/trivy/pkg/detector/library\"","+\t\"github.com/aquasecurity/trivy/pkg/detector/library/compare\"","+\t\"github.com/aquasecurity/trivy/pkg/detector/library/compare/pep440\"","+","+\t_ \"github.com/aquasecurity/trivy/pkg/detector/library/seal\" // register Seal Security vendor","+)","+","+func Test_lookupVendor(t *testing.T) {","+\tdefaultComparer := compare.GenericComparer{}","+","+\ttests := []struct {","+\t\tname                string","+\t\teco                 ecosystem.Type","+\t\tpkgName             string","+\t\twantMatch           bool","+\t\twantPrefix          string","+\t\twantDefaultComparer bool","+\t}{","+\t\t{","+\t\t\tname:                \"seal pip package returns vendor prefix and pep440 comparer\",","+\t\t\teco:                 ecosystem.Pip,","+\t\t\tpkgName:             \"seal-requests\","],"additions":31,"deletions":0,"truncated":false}],"additions":673,"deletions":20,"truncated":true,"file_count":15},"error":null,"fetched_at":"2026-05-20T17:51:27.788584+00:00"}