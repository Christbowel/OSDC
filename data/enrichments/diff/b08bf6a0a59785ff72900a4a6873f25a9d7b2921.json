specifiers like \">= 4.2.8+sp1, < 4.2.8+sp999\" are valid and","+// \"4.2.8+sp1\" does not match \"== 4.2.8\".","+func AllowLocalSpecifier() Option {","+\treturn func(c *Comparer) {","+\t\tc.allowLocalSpecifier = true","+\t}","+}","+"," // Comparer represents a comparer for PEP 440","-type Comparer struct{}","+type Comparer struct {","+\tallowLocalSpecifier bool","+}","+","+// NewComparer returns a new Comparer with the given options.","+func NewComparer(opts ...Option) Comparer {","+\tc := Comparer{}","+\tfor _, o := range opts {","+\t\to(&c)","+\t}","+\treturn c","+}"," "," // IsVulnerable checks if the package version is vulnerable to the advisory."," func (n Comparer) IsVulnerable(ver string, advisory dbTypes.Advisory) bool {","@@ -23,7 +55,12 @@ func (n Comparer) matchVersion(currentVersion, constraint string) (bool, error)"," \t\treturn false, xerrors.Errorf(\"python version error (%s): %s\", currentVersion, err)"," \t}"," ","-\tc, err := version.NewSpecifiers(constraint, version.WithPreRelease(true))","+\topts := []version.SpecifierOption{version.WithPreRelease(true)}","+\tif n.allowLocalSpecifier {","+\t\topts = append(opts, version.AllowLocalSpecifier(true))","+\t}","+","+\tc, err := version.NewSpecifiers(constraint, opts...)"," \tif err != nil {"," \t\treturn false, xerrors.Errorf(\"python constraint error (%s): %s\", constraint, err)"," \t}"],"additions":39,"deletions":2,"truncated":false},{"path":"pkg/detector/library/compare/pep440/compare_test.go","lines":["@@ -15,9 +15,10 @@ func TestPep440Comparer_IsVulnerable(t *testing.T) {"," \t\tadvisory       dbTypes.Advisory"," \t}"," \ttests := []struct {","-\t\tname string","-\t\targs args","-\t\twant bool","+\t\tname           string","+\t\tallowLocalSpec bool","+\t\targs           args","+\t\twant           bool"," \t}{"," \t\t{"," \t\t\tname: \"happy path\",","@@ -105,10 +106,53 @@ func TestPep440Comparer_IsVulnerable(t *testing.T) {"," \t\t\t},"," \t\t\twant: false,"," \t\t},","+\t\t{","+\t\t\t// Without AllowLocalSpecifier, the local segment is stripped from the candidate version,","+\t\t\t// so \"4.2.8+sp1\" matches \"== 4.2.8\" and is incorrectly treated as vulnerable.","+\t\t\tname:           \"without AllowLocalSpecifier: local segment ignored, version matches base constraint\",","+\t\t\tallowLocalSpec: false,","+\t\t\targs: args{","+\t\t\t\tcurrentVersion: \"4.2.8+sp1\",","+\t\t\t\tadvisory: dbTypes.Advisory{","+\t\t\t\t\tVulnerableVersions: []string{\"== 4.2.8\"},","+\t\t\t\t\tPatchedVersions:    []string{\"== 4.2.9\"},","+\t\t\t\t},","+\t\t\t},","+\t\t\twant: true,","+\t\t},","+\t\t{","+\t\t\t// With AllowLocalSpecifier, the local segment is compared strictly,","+\t\t\t// so \"4.2.8+sp999\" does not fall in \">= sp1, < sp999\" and is correctly not vulnerable.","+\t\t\tname:           \"with AllowLocalSpecifier: patched version not vulnerable\",","+\t\t\tallowLocalSpec: true,","+\t\t\targs: args{","+\t\t\t\tcurrentVersion: \"4.2.8+sp999\",","+\t\t\t\tadvisory: dbTypes.Advisory{","+\t\t\t\t\tVulnerableVersions: []string{\">= 4.2.8+sp1, < 4.2.8+sp999\"},","+\t\t\t\t\tPatchedVersions:    []string{\"4.2.8+sp999\"},","+\t\t\t\t},","+\t\t\t},","+\t\t\twant: false,","+\t\t},","+\t\t{","+\t\t\tname:           \"with AllowLocalSpecifier: vulnerable version matched by local range\",","+\t\t\tallowLocalSpec: true,","+\t\t\targs: args{","+\t\t\t\tcurrentVersion: \"4.2.8+sp1\",","+\t\t\t\tadvisory: dbTypes.Advisory{","+\t\t\t\t\tVulnerableVersions: []string{\">= 4.2.8+sp1, < 4.2.8+sp999\"},","+\t\t\t\t\tPatchedVersions:    []string{\"4.2.8+sp999\"},","+\t\t\t\t},","+\t\t\t},","+\t\t\twant: true,","+\t\t},"," \t}"," \tfor _, tt := range tests {"," \t\tt.Run(tt.name, func(t *testing.T) {","-\t\t\tc := pep440.Comparer{}","+\t\t\tvar c pep440.Comparer","+\t\t\tif tt.allowLocalSpec {","+\t\t\t\tc = pep440.NewComparer(pep440.AllowLocalSpecifier())","+\t\t\t}"," \t\t\tgot := c.IsVulnerable(tt.args.currentVersion, tt.args.advisory)"," \t\t\tassert.Equal(t, tt.want, got)"," \t\t})"],"additions":48,"deletions":4,"truncated":false},{"path":"pkg/detector/library/driver.go","lines":["@@ -1,7 +1,6 @@"," package library"," "," import (","-\t\"fmt\""," \t\"strings\""," "," \t\"github.com/samber/lo\"","@@ -114,16 +113,24 @@ func (d *Driver) Type() string {"," // It allows us to add a new data source with the ecosystem prefix (e.g. pip::new-data-source)"," // and detect vulnerabilities without specifying a specific bucket name."," func (d *Driver) DetectVulnerabilities(pkgID, pkgName, pkgVer string) ([]types.DetectedVulnerability, error) {","-\t// e.g. \"pip::\", \"npm::\"","-\tprefix := fmt.Sprintf(\"%s::\", d.ecosystem)","-\tadvisories, err := d.dbc.GetAdvisories(prefix, vulnerability.NormalizePkgName(d.ecosystem, pkgName))","+\tnormalizedName := vulnerability.NormalizePkgName(d.ecosystem, pkgName)","+","+\t// Resolve advisory prefix and comparer based on package info.","+\t// For vendor packages (e.g. Seal Security), uses a vendor-specific prefix and comparer.","+\tprefix := defaultBucketPrefix(d.ecosystem)","+\tcomparer := d.comparer","+\tif v, ok := lookupVendor(d.ecosystem, normalizedName, pkgVer); ok {","+\t\tprefix = v.BucketPrefix(d.ecosystem)","+\t\tcomparer = v.Comparer(d.ecosystem, d.comparer)","+\t}","+\tadvisories, err := d.dbc.GetAdvisories(prefix, normalizedName)"," \tif err != nil {"," \t\treturn nil, xerrors.Errorf(\"failed to get %s advisories: %w\", d.ecosystem, err)"," \t}"," "," \tvar vulns []types.DetectedVulnerability"," \tfor _, adv := range advisories {","-\t\tif !d.comparer.IsVulnerable(pkgVer, adv) {","+\t\tif !comparer.IsVulnerable(pkgVer, adv) {"," \t\t\tcontinue"," \t\t}"," "],"additions":12,"deletions":5,"truncated":false},{"path":"pkg/detector/library/driver_test.go","lines":["@@ -13,6 +13,8 @@ import ("," \t\"github.com/aquasecurity/trivy/pkg/detector/library\""," \tftypes \"github.com/aquasecurity/trivy/pkg/fanal/types\""," \t\"github.com/aquasecurity/trivy/pkg/types\"","+","+\t_ \"github.com/aquasecurity/trivy/pkg/