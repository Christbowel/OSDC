"   )","   .boxed();"," "],"additions":4,"deletions":0,"truncated":false},{"path":"packages/rspack/src/builtin-plugin/lazy-compilation/lazyCompilation.ts","lines":["@@ -10,7 +10,15 @@ export const BuiltinLazyCompilationPlugin = create(","     entries: boolean,","     imports: boolean,","     client: string,","+    reservedExternals: string[],","     test?: RegExp | ((module: Module) => boolean),","-  ) => ({ imports, entries, test, client, currentActiveModules }),","+  ) => ({","+    imports,","+    entries,","+    test,","+    client,","+    currentActiveModules,","+    reservedExternals,","+  }),","   'thisCompilation',"," );"],"additions":9,"deletions":1,"truncated":false},{"path":"packages/rspack/src/builtin-plugin/lazy-compilation/middleware.ts","lines":["@@ -2,6 +2,7 @@ import type { IncomingMessage, ServerResponse } from 'node:http';"," import { createRequire } from 'node:module';"," import { type Compiler, MultiCompiler } from '../..';"," import type { LazyCompilationOptions } from '../../config';","+import type { ExternalItem, Externals } from '../../config';"," import type { DevServerMiddlewareHandler } from '../../config/devServer';"," import { BuiltinLazyCompilationPlugin } from './lazyCompilation';"," ","@@ -128,11 +129,42 @@ function applyPlugin(","     options.entries ?? true,","     options.imports ?? true,","     `${options.client || getDefaultClient(compiler)}?${encodeURIComponent(getFullServerUrl(options))}`,","+    collectReservedExternals(compiler.options.externals),","     options.test,","   );","   plugin.apply(compiler);"," }"," ","+// Statically-declared external requests to reserve in the closure-library wrapper","+// (externals live on the JS options, not Rust's `CompilerOptions`).","+function collectReservedExternals(externals: Externals | undefined): string[] {","+  const requests = new Set<string>();","+  const visit = (item: ExternalItem) => {","+    if (typeof item === 'string') {","+      requests.add(item);","+      return;","+    }","+    if (!item || typeof item !== 'object' || item instanceof RegExp) {","+      return;","+    }","+    for (const [request, value] of Object.entries(item)) {","+      // `false` opts out of externalization; every other key mirrors `ExternalsPlugin`.","+      if (value === false) {","+        continue;","+      }","+      requests.add(request);","+    }","+  };","+  if (Array.isArray(externals)) {","+    for (const item of externals) {","+      visit(item);","+    }","+  } else if (externals !== undefined) {","+    visit(externals);","+  }","+  return [...requests];","+}","+"," function readModuleIdsFromBody(","   req: IncomingMessage & { body?: unknown },"," ): Promise<string[]> {"],"additions":32,"deletions":0,"truncated":false},{"path":"tests/rspack-test/hotCases/lazy-compilation/issue-19134/index.js","lines":["@@ -0,0 +1,14 @@","+const path = require(\"path\");","+","+it(\"first activation of a lazy 'page' must not throw under UMD + closure externals (issue #9023)\", async () => {","+\tlet resolved;","+\tconst promise = import(\"./page\").then(r => (resolved = r));","+\texpect(resolved).toBe(undefined);","+\tawait new Promise(resolve => setTimeout(resolve, 1000));","+\tawait NEXT_HMR();","+\tconst result = await promise;","+\texpect(result).toHaveProperty(\"isFile\");","+\texpect(result).toHaveProperty(\"joinedPath\");","+\texpect(typeof result.isFile).toBe(\"function\");","+\texpect(result.joinedPath).toBe(path.join(\"a\", \"b\"));","+});"],"additions":14,"deletions":0,"truncated":false},{"path":"tests/rspack-test/hotCases/lazy-compilation/issue-19134/page.js","lines":["@@ -0,0 +1,7 @@","+// Simulates a \"page\" module in a micro-frontend that pulls in multiple","+// externally provided libraries (in the real issue, React and Ant Design).","+import { existsSync } from \"fs\";","+import { join } from \"path\";","+","+export const isFile = existsSync;","+export const joinedPath = join(\"a\", \"b\");"],"additions":7,"deletions":0,"truncated":false},{"path":"tests/rspack-test/hotCases/lazy-compilation/issue-19134/rspack.config.js","lines":["@@ -0,0 +1,24 @@","+'use strict';","+","+// Mirrors https://github.com/web-infra-dev/rspack/issues/9023 (webpack #19134):","+// a UMD micro-frontend bundle with multiple closure-bound externals where","+// `lazyCompilation` defers the entry's dependents. Before the fix, the first","+// activation throws because the initial UMD wrapper didn't reserve the closure","+// identifiers for externals that weren't yet referenced by the inactive proxy.","+/** @type {import(\"@rspack/core\").Configuration} */","+module.exports = {","+  output: {","+    library: {","+      name: 'demo',","+      type: 'umd',","+    },","+  },","+  externals: {","+    fs: 'fs',","+    path: 'path',","+  },","+  externalsType: 'umd',","+  lazyCompilation: {","+    entries: false,","+  },","+};"],"additions":24,"deletions":0,"truncated":false},{"path":"tests/rspack-test/hotCases/lazy-compilation/issue-19134/test.config.js","lines":["@@ -0,0 +1,3 @@","+module.exports = {","+\tcheckSteps: false","+};"],"additions":3,"deletions":0,"truncated":false},{"path":"tests/rspack-test/hotCases/lazy-compilation/issue-19134/test.filter.js","lines":["@@ -0,0 +1,6 @@","+// The externals (`fs`, `path`) are Node builtins resolved by the UMD wrapper's","+// CommonJS branch via `require`. Restrict to the node target so they resolve","+// deterministically; the reproduced bug is target-independent.","+module.exports = function (config) {","+\treturn config.target === \"async-node\";","+};"],"additions":6,"deletions":0,"truncated":false},{"path":"tests/rspack-test/hotCases/lazy-compilation/umd-library-externals/index.js","lines":["@@ -0,0 +1,9 @@","+it(\"first activation of a lazy import with a UMD external must not throw\", async () => {","+\tlet resolved;","+\tconst promise = import(\"./module\").then(r => (resolved = r));","+\texpect(resolved).toBe(undefined);","+\tawait new Promise(resolve => setTimeout(resolve, 1000));","+\tawait NEXT_HMR();","+\tconst result = await promise;","+\texpect(result).toHaveProperty(\"default\", \"answer=42\");","+});"],"additions":9,"deletions":0,"truncated":false},{"path":"tests/rspack-test/hotCases/lazy-compilation/umd-library-externals/module.js","lines":["@@ -0,0 +1,3 @@","+import * as util from \"util\";","+","+export default util.format(\"answer=%s\", 42);"],"additions":3,"deletions":0,"truncated":false},{"path":"tests/rspack-test/hotCases/lazy-compilation/umd-library-externals/rspack.config.js","lines":["@@ -0,0 +1,22 @@","+'use strict';","+","+// A UMD library bundle with a closure-bound external (`util`) where","+// `lazyCompilation` defers the entry's dependents. Before the fix, the first","+// activation throws because the initial UMD wrapper didn't reserve the closure","+// identifier for the `util` external that the inactive proxy never referenced.","+/** @type {import(\"@rspack/core\").Configuration} */","+module.exports = {","+  output: {","+    library: {","+      name: 'TestLib',","+      type: 'umd',","+    },","+  },","+  externals: {","+    util: 'util',","+  },","+  externalsType: 'umd',","+  lazyCompilation: {","+    entries: false,","+  },","+};"],"additions":22,"deletions":0,"truncated":false},{"path":"tests/rspack-test/hotCases/lazy-compilation/umd-library-externals/test.config.js","lines":["@@ -0,0 +1,3 @@","+module.exports = {","+\tcheckSteps: false","+};"],"additions":3,"deletions":0,"truncated":false},{"path":"tests/rspack-test/hotCases/lazy-compilation/umd-library-externals/test.filter.js","lines":["@@ -0,0 +1,6 @@","+// The external (`util`) is a Node builtin resolved by the UMD wrapper's","+// CommonJS branch via `require`. Restrict to the node target so it resolves","+// deterministically; the reproduced bug is target-independent.","+module.exports = function (config) {","+\treturn config.target === \"async-node\";","+};",""],"additions":6,"deletions":0,"truncated":false}],"additions":206,"deletions":6,"truncated":false,"file_count":19},"error":null,"fetched_at":"2026-06-03T12:51:09.083065+00:00"}