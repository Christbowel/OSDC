{"id":"4bf23b51b8efaf337b06e0e1b7f90b1fb9f45daa","axis":"silent","repo":"golang/go","sha":"4bf23b51b8efaf337b06e0e1b7f90b1fb9f45daa","parsed":{"files":[{"path":"doc/godebug.md","lines":["@@ -170,6 +170,14 @@ to `1`. This opt-out is expected to be kept indefinitely in case goroutine"," labels acquire sensitive information that shouldn't be made available in"," tracebacks."," ","+Go 1.27 added a new `x509sslcertoverrideplatform` setting that controls whether","+crypto/x509 will load roots from disk on Windows and Darwin when `SSL_CERT_FILE`","+or `SSL_CERT_DIR` are set. The default value `x509sslcertoverrideplatform=1` will","+cause roots to be loaded from disk when these environment variables are set.","+Setting `x509sslcertoverrideplatform=0` disables this behavior in favor of using","+the platform certificate store instead of honoring the environment variables. We","+plan to remove this setting in Go 1.31.","+"," ### Go 1.26"," "," Go 1.26 added a new `httpcookiemaxnum` setting that controls the maximum number"],"additions":8,"deletions":0,"truncated":false},{"path":"doc/next/6-stdlib/99-minor/crypto/x509/77865.md","lines":["@@ -0,0 +1,5 @@","+[SystemCertPool] now respects SSL_CERT_FILE and SSL_CERT_DIR on Windows and","+Darwin. When these environment variables are set, roots are loaded from disk and","+instead of using the platform certificate verification APIs, the native Go","+verifier is used. This behavior can be disabled with","+`GODEBUG=x509sslcertoverrideplatform=0`.","\\ No newline at end of file"],"additions":5,"deletions":0,"truncated":false},{"path":"src/crypto/x509/cert_pool.go","lines":["@@ -105,10 +105,14 @@ func (s *CertPool) Clone() *CertPool {"," "," // SystemCertPool returns a copy of the system cert pool."," //","-// On Unix systems other than macOS the environment variables SSL_CERT_FILE and","-// SSL_CERT_DIR can be used to override the system default locations for the SSL","-// certificate file and SSL certificate files directory, respectively. The","-// latter can be a colon-separated list.","+// The environment variables SSL_CERT_FILE and SSL_CERT_DIR can be used to","+// override the system default locations for the SSL certificate file and SSL","+// certificate files directory, respectively. The latter can be a","+// colon-separated list, or a semicolon-separated list on Windows. On platforms","+// which have system APIs for certificate verification (macOS and Windows),","+// setting SSL_CERT_FILE or SSL_CERT_DIR will prevent those APIs from being","+// used, unless the x509sslcertoverrideplatform=0 GODEBUG setting is used. (This","+// changed in Go 1.27.)"," //"," // Any mutations to the returned pool are not written to disk and do not affect"," // any other pool returned by SystemCertPool."],"additions":8,"deletions":4,"truncated":false},{"path":"src/crypto/x509/root.go","lines":["@@ -6,6 +6,11 @@ package x509"," "," import ("," \t\"internal/godebug\"","+\t\"io/fs\"","+\t\"os\"","+\t\"path/filepath\"","+\t\"runtime\"","+\t\"strings\""," \t\"sync\""," \t_ \"unsafe\" // for linkname"," )","@@ -115,3 +120,111 @@ func SetFallbackRoots(roots *CertPool) {"," "," \tsystemRoots, systemRootsErr = roots, nil"," }","+","+const (","+\t// certFileEnv is the environment variable which identifies where to locate","+\t// the SSL certificate file. If set this overrides the system default.","+\tcertFileEnv = \"SSL_CERT_FILE\"","+","+\t// certDirEnv is the environment variable which identifies which directory","+\t// to check for SSL certificate files. If set this overrides the system default.","+\t// See https://docs.openssl.org/4.0/man1/openssl-rehash/#environment.","+\tcertDirEnv = \"SSL_CERT_DIR\"","+)","+","+var x509sslcertoverrideplatform = godebug.New(\"x509sslcertoverrideplatform\")","+","+func loadSystemRoots() (*CertPool, error) {","+\tcertFilePath, certDirPath := os.Getenv(certFileEnv), os.Getenv(certDirEnv)","+","+\tif runtime.GOOS == \"windows\" || runtime.GOOS == \"darwin\" || runtime.GOOS == \"ios\" {","+\t\tif certFilePath == \"\" && certDirPath == \"\" {","+\t\t\treturn &CertPool{systemPool: true}, nil","+\t\t}","+\t\tif x509sslcertoverrideplatform.Value() == \"0\" {","+\t\t\tx509sslcertoverrideplatform.IncNonDefault()","+\t\t\treturn &CertPool{systemPool: true}, nil","+\t\t}","+\t}","+","+\treturn loadOnDiskRoots(certFilePath, certDirPath)","+}","+","+func loadOnDiskRoots(certFilePath, certDirPath string) (*CertPool, error) {","+\troots := NewCertPool()","+","+\tfiles := certFiles","+\tif certFilePath != \"\" {","+\t\tfiles = []string{certFilePath}","+\t}","+","+\tvar firstErr error","+\tfor _, file := range files {","+\t\tdata, err := os.ReadFile(file)","+\t\tif err == nil {","+\t\t\troots.AppendCertsFromPEM(data)","+\t\t\tbreak","+\t\t}","+\t\tif firstErr == nil && !os.IsNotExist(err) {","+\t\t\tfirstErr = err","+\t\t}","+\t}","+","+\tdirs := certDirectories","+\tif certDirPath != \"\" {","+\t\t// OpenSSL and BoringSSL both use \":\" as the SSL_CERT_DIR separator on","+\t\t// Unix-like systems, and \";\" on Windows.","+\t\t// See:","+\t\t//  * https://golang.org/issue/35325","+\t\t//  * https://docs.openssl.org/4.0/man1/openssl-rehash/#environment","+\t\tdirs = filepath.SplitList(certDirPath)","+\t}","+","+\tfor _, directory := range dirs {","+\t\tfis, err := readUniqueDirectoryEntries(directory)","+\t\tif err != nil {","+\t\t\tif firstErr == nil && !os.IsNotExist(err) {","+\t\t\t\tfirstErr = err","+\t\t\t}","+\t\t\tcontinue","+\t\t}","+\t\tfor _, fi := range fis {","+\t\t\tdata, err := os.ReadFile(filepath.Join(directory, fi.Name()))","+\t\t\tif err == nil {","+\t\t\t\troots.AppendCertsFromPEM(data)","+\t\t\t}","+\t\t}","+\t}","+","+\tif roots.len() > 0 || firstErr == nil {","+\t\treturn roots, nil","+\t}","+","+\treturn nil, firstErr","+}","+","+// readUniqueDirectoryEntries is like os.ReadDir but omits","+// symlinks that point within the directory.","+func readUniqueDirectoryEntries(dir string) ([]fs.DirEntry, error) {","+\tfiles, err := os.ReadDir(dir)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\tuniq := files[:0]","+\tfor _, f := range files {","+\t\tif !isSameDirSymlink(f, dir) {","+\t\t\tuniq = append(uniq, f)","+\t\t}","+\t}","+\treturn uniq, nil","+}","+","+// isSameDirSymlink reports whether f in dir is a symlink with a","+// target not containing a slash.","+func isSameDirSymlink(f fs.DirEntry, dir string) bool {","+\tif f.Type()&fs.ModeSymlink == 0 {","+\t\treturn false","+\t}","+\ttarget, err := os.Readlink(filepath.Join(dir, f.Name()))","+\treturn err == nil && !strings.ContainsRune(target, filepath.Separator)","+}"],"additions":113,"deletions":0,"truncated":false},{"path":"src/crypto/x509/root_darwin.go","lines":["@@ -10,6 +10,9 @@ import ("," \t\"fmt\""," )"," ","+// macOS has no default SSL_CERT_{FILE,DIR} paths.","+var certFiles, certDirectories []string","+"," func (c *Certificate) systemVerify(opts *VerifyOptions) (chains [][]*Certificate, err error) {"," \tcerts := macos.CFArrayCreateMutable()"," \tdefer macos.ReleaseCFArray(certs)","@@ -125,7 +128,3 @@ func exportCertificate(cert macos.CFRef) (*Certificate, error) {"," \t}"," \treturn ParseCertificate(data)"," }","-","-func loadSystemRoots() (*CertPool, error) {","-\treturn &CertPool{systemPool: true}, nil","-}"],"additions":3,"deletions":4,"truncated":false},{"path":"src/crypto/x509/root_plan9.go","lines":["@@ -6,34 +6,13 @@"," "," package x509"," ","-import (","-\t\"os\"","-)","-"," // Possible certificate files; stop after finding one."," var certFiles = []string{"," \t\"/sys/lib/tls/ca.pem\","," }"," ","+var certDirectories = []string{}","+"," func (c *Certificate) systemVerify(opts *VerifyOptions) (chains [][]*Certificate, err error) {"," \treturn nil, nil"," }","-","-func loadSystemRoots() (*CertPool, error) {","-\troots := NewCertPool()","-\tvar bestErr error","-\tfor _, file := range certFiles {","-\t\tdata, err := os.ReadFile(file)","-\t\tif err == nil {","-\t\t\troots.AppendCertsFromPEM(data)","-\t\t\treturn roots, nil","-\t