s.layoutSplitView();","+\t\t}));","+","+\t\tthis._register(widget.onDidChangeHeight(() => {","+\t\t\tif (!this.splitView) {","+\t\t\t\treturn;","+\t\t\t}","+\t\t\tconst visible = widget.visible;","+\t\t\tconst isCurrentlyVisible = this.splitView.isViewVisible(paneIndex);","+\t\t\tif (visible !== isCurrentlyVisible) {","+\t\t\t\tthis.splitView.setViewVisible(paneIndex, visible);","+\t\t\t}","+\t\t\tthis.layoutSplitView();","+\t\t}));","+\t}","+"," \tprivate getTreeSelection(): IChangesFileItem[] {"," \t\tconst selection = this.tree?.getSelection() ?? [];"," \t\treturn selection.filter(item => !!item && isChangesFileItem(item));"],"additions":83,"deletions":31,"truncated":false},{"path":"src/vs/sessions/contrib/changes/browser/media/sessionFilesWidget.css","lines":["@@ -0,0 +1,161 @@","+/*---------------------------------------------------------------------------------------------","+ *  Copyright (c) Microsoft Corporation. All rights reserved.","+ *  Licensed under the MIT License. See License.txt in the project root for license information.","+ *--------------------------------------------------------------------------------------------*/","+","+/* Session Files Widget - between the files list and the CI checks widget */","+.session-files-widget {","+\tdisplay: flex;","+\tflex-direction: column;","+\tflex-shrink: 0;","+\tbox-sizing: border-box;","+\tfont-size: var(--vscode-agents-fontSize-label1, 12px);","+}","+","+/* Header */","+.session-files-widget-header {","+\tposition: relative;","+\tdisplay: flex;","+\talign-items: center;","+\tpadding: 4px;","+\tmargin-top: 6px;","+\tborder-radius: var(--vscode-cornerRadius-medium);","+\tmin-height: 20px;","+\tfont-weight: var(--vscode-agents-fontWeight-semiBold, 600);","+\tcursor: pointer;","+\tuser-select: none;","+}","+","+.session-files-widget-header:hover {","+\tpadding-right: 32px;","+}","+","+.session-files-widget-header:focus-visible {","+\tpadding-right: 32px;","+}","+","+.session-files-widget-header.collapsed {","+\tpadding-right: 32px;","+}","+","+/* Hover/keyboard focus promote the title to the strong foreground instead of","+\tpainting a row background — matches the sessions list section labels. */","+.session-files-widget-header:hover .session-files-widget-title,","+.session-files-widget-header:focus-visible .session-files-widget-title {","+\tcolor: var(--vscode-strongForeground);","+}","+","+.session-files-widget-header:focus-visible {","+\toutline: 1px solid var(--vscode-focusBorder);","+\toutline-offset: -1px;","+}","+","+/* Suppress the outline for mouse-driven focus — keyboard navigation only */","+.session-files-widget-header:focus:not(:focus-visible) {","+\toutline: none !important;","+}","+","+/* Chevron — right-aligned, visible on hover, keyboard focus, or when collapsed */","+.session-files-widget-header .group-chevron {","+\tposition: absolute;","+\tright: 4px;","+\ttop: 50%;","+\ttransform: translateY(-50%);","+\twidth: 22px;","+\theight: 22px;","+\tborder-radius: var(--vscode-cornerRadius-small);","+\tdisplay: flex;","+\talign-items: center;","+\tjustify-content: center;","+\tfont-size: var(--vscode-codiconFontSize-compact, 12px);","+\tvisibility: hidden;","+\topacity: 0;","+}","+","+.session-files-widget-header:hover .group-chevron,","+.session-files-widget-header:focus-visible .group-chevron,","+.session-files-widget-header.collapsed .group-chevron {","+\tvisibility: visible;","+\topacity: 0.7;","+}","+","+.session-files-widget-header .group-chevron:hover {","+\tbackground-color: var(--vscode-toolbar-hoverBackground);","+}","+","+/* Title - single line, overflow ellipsis */","+.session-files-widget-title {","+\tflex: 1;","+\tdisplay: flex;","+\talign-items: center;","+\tgap: 6px;","+\toverflow: hidden;","+\tcolor: var(--vscode-foreground);","+}","+","+.session-files-widget-title-label {","+\toverflow: hidden;","+\ttext-overflow: ellipsis;","+\twhite-space: nowrap;","+}","+","+/* File count badge in the header */","+.session-files-widget-count {","+\tflex-shrink: 0;","+\tmargin-left: auto;","+\tpadding-right: 8px;","+\tfont-size: var(--vscode-agents-fontSize-body2);","+\topacity: 0.7;","+}","+","+.session-files-widget-header:hover .session-files-widget-count,","+.session-files-widget-header:focus-visible .session-files-widget-count,","+.session-files-widget-header.collapsed .session-files-widget-count {","+\tvisibility: hidden;","+}","+","+/* Body - file list */","+.session-files-widget-body {","+\tflex: 1;","+\tmin-height: 0;","+\toverflow: hidden;","+}","+","+.session-files-widget-list {","+\theight: 100%;","+\tbackground-color: transparent;","+}","+","+.session-files-widget-list > .monaco-list,","+.session-files-widget-list > .monaco-list > .monaco-scrollable-element {","+\tbackground-color: transparent;","+}","+","+/* Individual file row */","+.session-files-widget .session-files-widget-list .monaco-list-row {","+\tborder-radius: var(--vscode-cornerRadius-small);","+}","+","+.session-files-widget-file {","+\tdisplay: flex;","+\talign-items: center;","+\tgap: 6px;","+\tpadding: 0 0 0 6px;","+\theight: 100%;","+\twidth: 100%;","+\tbox-sizing: border-box;","+\tmin-width: 0;","+}","+","+.session-files-widget-file .monaco-icon-label {","+\tdisplay: flex;","+\tflex: 1;","+\tmin-width: 0;","+\twidth: 100%;","+}","+","+.session-files-widget-file .monaco-icon-label .label-name {","+\toverflow: hidden;","+\ttext-overflow: ellipsis;","+\twhite-space: nowrap;","+}"],"additions":161,"deletions":0,"truncated":false},{"path":"src/vs/sessions/contrib/changes/browser/sessionFilesViewModel.ts","lines":["@@ -0,0 +1,35 @@","+/*---------------------------------------------------------------------------------------------","+ *  Copyright (c) Microsoft Corporation. All rights reserved.","+ *  Licensed under the MIT License. See License.txt in the project root for license information.","+ *--------------------------------------------------------------------------------------------*/","+","+import { Disposable } from '../../../../base/common/lifecycle.js';","+import { derived, IObservable } from '../../../../base/common/observable.js';","+import { ISessionsService } from '../../../services/sessions/browser/sessionsService.js';","+import { ISessionFile } from '../../../services/sessions/common/session.js';","+","+/** Shared stable empty result so \"no session / no files\" doesn't churn observers. */","+const EMPTY_SESSION_FILES: readonly ISessionFile[] = Object.freeze([]);","+","+/**","+ * View model backing the \"Session Files\" section in the changes view. Exposes","+ * the files created/edited/deleted outside the workspace by the active session.","+ */","+export class SessionFilesViewModel extends Disposable {","+\treadonly sessionFilesObs: IObservable<readonly ISessionFile[]>;","+","+\tconstructor(","+\t\t@ISessionsService sessionsService: ISessionsService,","+\t) {","+\t\tsuper();","+","+\t\t// The underlying `externalChanges` observable carries its own structural","+\t\t// equality, so when it is unchanged it returns the same array reference","+\t\t// and this derived does not propagate. The shared empty constant keeps","+\t\t// the \"no session\" case equally stable.","+\t\tthis.sessionFilesObs = derived(this, reader => {","+\t\t\tconst activeSession = sessionsService.activeSession.read(reader);","+\t\t\treturn activeSession?.externalChanges?.read(reader) ?? EMPTY_SESSION_FILES;","+\t\t});","+\t}","+}"],"additions":35,"deletions":0,"truncated":false},{"path":"src/vs/sessions/contrib/changes/browser/sessionFilesWidget.ts","lines":["@@ -0,0 +1,363 @@","+/*---------------------------------------------------------------------------------------------","+ *  Copyright (c) Microsoft Corporation. All rights reserved.","+ *  Licensed under the MIT License. See License.txt in the project root for license information.","+ *--------------------------------------------------------------------------------------------*/","+","+import './media/sessionFilesWidget.css';","+import * as dom from '../../../../base/browser/dom.js';","+import { getDefaultHoverDelegate } from '../../../../base/browser/ui/hover/hoverDelegateFactory.js';","+import { IListRenderer, IListVirtualDelegate } from '../../../../base/browser/ui/list/list.js';","+import { Gesture, EventType as TouchEventType } from '../../../../base/browser/touch.js';","+import { Codicon } from '../../../../base/common/codicons.js';","+import { Emitter } from '../../../../base/common/event.js';","+import { Disposable, DisposableStore, IDisposable } from '../../../../base/common/lifecycle.js';","+import { autorun, IObservable } from '../../../../base/common/observable.js';","+import { basename, dirname } from '../../../../base/common/resources.js';","+import { ThemeIcon } from '../../../../base/common/themables.js';","+import { URI } from '../../../../base/common/uri.js';","+import { localize } from '../../../../nls.js';","+import { FileKind } from '../../../../platform/files/common/files.js';","+import { IHoverService } from '../../../../platform/hover/browser/hover.js';","+import { IInstantiationService } from '../../../../platform/instantiation/common/instantiation.js';","+import { ILabelService } from '../../../../platform/label/common/label.js';","+import { WorkbenchList } from '../../../../platform/list/browser/listService.js';","+import { DEFAULT_LABELS_CONTAINER, IResourceLabel, ResourceLabels } from '../../../../workbench/browser/labels.js';","+import { ACTIVE_GROUP, IEditorService } from '../../../../workbench/services/editor/common/editorService.js';","+import { ISessionFile, SessionFileOperation } from '../../../services/sessions/common/session.js';","+","+const $ = dom.$;","+","+/** Minimal input contract for {@link SessionFilesWidget.setInput}. */","+export interface ISessionFilesInput {","+\treadonly sessionFilesObs: IObservable<readonly ISessionFile[]>;","+}","+","+class SessionFileListDelegate implements IListVirtualDelegate<ISessionFile> {","+\tstatic readonly ITEM_HEIGHT = 22;","+","+\tgetHeight(_element: ISessionFile): number {","+\t\treturn SessionFileListDelegate.ITEM_HEIGHT;","+\t}","+","+\tgetTemplateId(_element: ISessionFile): string {","+\t\treturn SessionFileListRenderer.TEMPLATE_ID;","+\t}","+}","+","+interface ISessionFileTemplateData {","+\treadonly label: IResourceLabel;","+\treadonly templateDisposables: DisposableStore;","+}","+","+class SessionFileListRenderer implements IListRenderer<ISessionFile, ISessionFileTemplateData> {","+\tstatic readonly TEMPLATE_ID = 'sessionFile';","+\treadonly templateId = SessionFileListRenderer.TEMPLATE_ID;","+","+\tconstructor(","+\t\tprivate readonly _labels: ResourceLabels,","+\t\tprivate readonly _labelService: ILabelService,","+\t) { }","+","+\trenderTemplate(container: HTMLElement): ISessionFileTemplateData {","+\t\tconst templateDisposables = new DisposableStore();","+\t\tconst row = dom.append(container, $('.session-files-widget-file'));","+\t\tconst label = templateDisposables.add(this._labels.create(row, { supportIcons: true }));","+\t\treturn { label, templateDisposables };","+\t}","+","+\trenderElement(element: ISessionFile, _index: number, templateData: ISessionFileTemplateData): void {","+\t\tconst parent = dirname(element.uri);","+\t\ttemplateData.label.setResource({","+\t\t\tresource: element.uri,","+\t\t\tname: basename(element.uri),","+\t\t\tdescription: this._labelService.getUriLabel(parent, { noPrefix: true }),","+\t\t}, {","+\t\t\tfileKind: FileKind.FILE,","+\t\t\tstrikethrough: element.operation === SessionFileOperation.Deleted,","+\t\t\ttitle: getSessionFileTitle(element, this._labelService),","+\t\t});","+\t}","+","+\tdisposeTemplate(templateData: ISessionFileTemplateData): void {","+\t\ttemplateData.templateDisposables.dispose();","+\t}","+}","+","+/**","+ * A widget that lists the files created, edited or deleted **outside** the","+ * session workspace during the session. Rendered between the changes tree and","+ * the CI checks widget in the changes view as a resizable SplitView pane.","+ *","+ * The collapse/resize behaviour mirrors {@link CIStatusWidget}.","+ */","+export class SessionFilesWidget extends Disposable {","+","+\tstatic readonly HEADER_HEIGHT = 32; // 5px section margin + 6px header margin + 28px header","+\tstatic readonly MIN_BODY_HEIGHT = 3 * SessionFileListDelegate.ITEM_HEIGHT + 2;","+\tstatic readonly PREFERRED_BODY_HEIGHT = 4 * SessionFileListDelegate.ITEM_HEIGHT;","+\tstatic readonly MAX_BODY_HEIGHT = 240;","+","+\tprivate readonly _domNode: HTMLElement;","+\tprivate readonly _headerNode: HTMLElement;","+\tprivate readonly _titleNode: HTMLElement;","+\tprivate readonly _titleLabelNode: HTMLElement;","+\tprivate readonly _countNode: HTMLElement;","+\tprivate readonly _chevronNode: HTMLElement;","+\tprivate readonly _bodyNode: HTMLElement;","+\tprivate readonly _list: WorkbenchList<ISessionFile>;","+\tprivate readonly _labels: ResourceLabels;","+","+\tprivate readonly _onDidChangeHeight = this._register(new Emitter<void>());","+\treadonly onDidChangeHeight = this._onDidChangeHeight.event;","+","+\tprivate readonly _onDidToggleCollapsed = this._register(new Emitter<boolean>());","+\treadonly onDidToggleCollapsed = this._onDidToggleCollapsed.event;","+","+\tprivate _fileCount = 0;","+\tprivate _collapsed = false;","+","+\tget element(): HTMLElement {","+\t\treturn this._domNode;","+\t}","+","+\t/** The full content height the widget would like (header + all files). */","+\tget desiredHeight(): number {","+\t\tif (this._fileCount === 0) {","+\t\t\treturn 0;","+\t\t}","+\t\tif (this._collapsed) {","+\t\t\treturn SessionFilesWidget.HEADER_HEIGHT;","+\t\t}","+\t\treturn SessionFilesWidget.HEADER_HEIGHT + this._fileCount * SessionFileListDelegate.ITEM_HEIGHT;","+\t}","+","+\t/** Whether the widget is currently visible (has files to show). */","+\tget visible(): boolean {","+\t\treturn this._fileCount > 0;","+\t}","+","+\t/** Whether the body is collapsed (header-only). */","+\tget collapsed(): boolean {","+\t\treturn this._collapsed;","+\t}","+","+\tconstructor(","+\t\tcontainer: HTMLElement,","+\t\t@IInstantiationService private readonly _instantiationService: IInstantiationService,","+\t\t@ILabelService private readonly _labelService: ILabelService,","+\t\t@IEditorService private readonly _editorService: IEditorService,","+\t\t@IHoverService private readonly _hoverService: IHoverService,","+\t) {","+\t\tsuper();","+\t\tthis._labels = this._register(this._instantiationService.createInstance(ResourceLabels, DEFAULT_LABELS_CONTAINER));","+","+\t\tthis._domNode = dom.append(container, $('.session-files-widget'));","+\t\tthis._domNode.style.display = 'none';","+","+\t\t// Header (always visible, click to collapse/expand)","+\t\tthis._headerNode = dom.append(this._domNode, $('.session-files-widget-header'));","+\t\tthis._titleNode = dom.append(this._headerNode, $('.session-files-widget-title'));","+\t\tthis._titleLabelNode = dom.append(this._titleNode, $('.session-files-widget-title-label'));","+\t\tthis._titleLabelNode.textContent = localize('sessionFiles.label', \"Session Files\");","+\t\tthis._countNode = dom.append(this._titleNode, $('.session-files-widget-count'));","+\t\tthis._chevronNode = dom.append(this._headerNode, $('.group-chevron'));","+\t\tthis._chevronNode.classList.add(...ThemeIcon.asClassNameArray(Codicon.chevronDown));","+","+\t\tthis._headerNode.setAttribute('role', 'button');","+\t\tthis._headerNode.setAttribute('aria-label', localize('sessionFiles.toggle', \"Toggle Session Files\"));","+\t\tthis._headerNode.setAttribute('aria-expanded', 'true');","+\t\tthis._headerNode.tabIndex = 0;","+","+\t\tthis._register(this._hoverService.setupManagedHover(","+\t\t\tgetDefaultHoverDelegate('element'),","+\t\t\tthis._headerNode,","+\t\t\tlocalize('sessionFiles.hover', \"Files created or edited outside the workspace during this session. These files are not part of the workspace and won't be committed.\"),","+\t\t));","+","+\t\t// Register the gesture target so the toggle works on touch platforms","+