`GRPC_RUST_REGENERATE_PROTO=1` in your environment.  This requires that you have","+the `protoc-gen-rust-grpc` binary installed in your path.  This can be","+downloaded from [our releases].","+","+Alternatively, you can also set the `grpc-protobuf-build/build-plugin` feature","+flag when building via `cargo` using the `--features` flag.  In this case you","+will need a compatible C++ compiler and CMake as described in the","+`protoc-gen-rust-grpc` crate.","+","+[our releases]: https://github.com/grpc/grpc-rust/releases","+","+## Helloworld","+","+### Client","+","+```bash","+$ cargo run --bin grpc-helloworld-client","+```","+","+### Server","+","+```bash","+$ cargo run --bin grpc-helloworld-server","+```","+","+## RouteGuide","+","+### Client","+","+```bash","+$ cargo run --bin grpc-routeguide-client","+```","+","+### Server","+","+```bash","+$ cargo run --bin grpc-routeguide-server","+```","+"," ## Helloworld"," "," ### Client"],"additions":44,"deletions":1,"truncated":false},{"path":"examples/build.rs","lines":["@@ -1,6 +1,7 @@"," use std::{env, path::PathBuf};"," "," fn main() {","+    println!(\"cargo:rerun-if-changed=build.rs\");","     tonic_prost_build::configure()","         .compile_protos(&[\"proto/routeguide/route_guide.proto\"], &[\"proto\"])","         .unwrap();","@@ -40,6 +41,30 @@ fn main() {","         .codec_path(\"crate::common::SmallBufferCodec\")","         .compile_protos(&[\"proto/helloworld/helloworld.proto\"], &[\"proto\"])","         .unwrap();","+","+    println!(\"cargo:rerun-if-env-changed=GRPC_RUST_REGENERATE_PROTO\");","+    let grpc_helloworld = env::var_os(\"CARGO_FEATURE_GRPC_HELLOWORLD\").is_some();","+    let grpc_routeguide = env::var_os(\"CARGO_FEATURE_GRPC_ROUTEGUIDE\").is_some();","+","+    if (grpc_helloworld || grpc_routeguide) && env::var_os(\"GRPC_RUST_REGENERATE_PROTO\").is_some() {","+        let manifest_dir = PathBuf::from(env::var(\"CARGO_MANIFEST_DIR\").unwrap());","+","+        grpc_protobuf_build::CodeGen::new()","+            .output_dir(manifest_dir.join(\"src/grpc-helloworld/generated\"))","+            .input(\"helloworld.proto\")","+            .include(manifest_dir.join(\"proto/helloworld\"))"],"additions":13,"deletions":0,"truncated":false}],"additions":289,"deletions":272,"truncated":true,"file_count":7},"error":null,"fetched_at":"2026-05-28T11:21:13.649510+00:00"}