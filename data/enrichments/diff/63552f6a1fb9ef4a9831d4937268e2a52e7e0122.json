{"id":"63552f6a1fb9ef4a9831d4937268e2a52e7e0122","axis":"silent","repo":"gravitational/teleport","sha":"63552f6a1fb9ef4a9831d4937268e2a52e7e0122","parsed":{"files":[{"path":"lib/auth/access_request_test.go","lines":["@@ -196,6 +196,7 @@ func TestAccessRequest(t *testing.T) {"," \tt.Run(\"role refresh with bogus request ID\", func(t *testing.T) { testRoleRefreshWithBogusRequestID(t, testPack) })"," \tt.Run(\"bot user approver\", func(t *testing.T) { testBotAccessRequestReview(t, testPack) })"," \tt.Run(\"deny\", func(t *testing.T) { testAccessRequestDenyRules(t, testPack) })","+\tt.Run(\"cert extension resource IDs\", func(t *testing.T) { testCertExtensionResourceIDs(t, testPack) })"," }"," "," // waitForAccessRequests is a helper for writing access request tests that need to wait for access request CRUD. the supplied condition is","@@ -1403,7 +1404,29 @@ func checkCerts(t *testing.T,"," \tsshCertAllowedResources, err := types.ResourceAccessIDsFromString(sshCert.Permissions.Extensions[teleport.CertExtensionAllowedResourceAccessIDs])"," \trequire.NoError(t, err)"," \tassert.ElementsMatch(t, resourceAccessIDs, sshCertAllowedResources)","+\tassert.ElementsMatch(t, resourceAccessIDs, sshIdentity.AllowedResourceAccessIDs)"," \tassert.ElementsMatch(t, resourceAccessIDs, tlsIdentity.AllowedResourceAccessIDs)","+","+\t// Verify the legacy AllowedResourceIDs extension contains the expected values.","+\t// Plain (unconstrained) resource IDs should appear in the old extension so that older","+\t// agents/proxies that don't understand AllowedResourceAccessIDs can still enforce","+\t// resource-level restrictions. The sentinel should only appear when all requested","+\t// resources carry constraints that old agents can't enforce.","+\tsshCertLegacyResources, err := types.ResourceIDsFromString(sshCert.Permissions.Extensions[teleport.CertExtensionAllowedResources])","+\trequire.NoError(t, err)","+\tplainIDs, constrainedOnly := types.UnwrapResourceAccessIDs(resourceAccessIDs)","+\tif len(plainIDs) > 0 {","+\t\t// Plain resources should be in the old extension.","+\t\tassert.ElementsMatch(t, plainIDs, sshCertLegacyResources, \"SSH cert legacy extension should contain plain resource IDs\")","+\t\t// Sentinel should not be present.","+\t\tfor _, rid := range sshCertLegacyResources {","+\t\t\tassert.False(t, types.IsSentinelResourceID(rid), \"SSH cert legacy extension should not contain sentinel when plain resources are present\")","+\t\t}","+\t} else if len(constrainedOnly) > 0 {","+\t\t// Constraint-only requests should have the sentinel in the old extension.","+\t\trequire.Len(t, sshCertLegacyResources, 1, \"SSH cert legacy extension should contain only sentinel\")","+\t\tassert.True(t, types.IsSentinelResourceID(sshCertLegacyResources[0]), \"SSH cert legacy extension should be sentinel\")","+\t}"," }"," "," func TestCreateSuggestions(t *testing.T) {","@@ -1791,3 +1814,147 @@ func createAccessRequestWithStartTime(t *testing.T) accessRequestWithStartTime {"," \t\tcreatedRequest:                createdReq,"," \t}"," }","+","+// testCertExtensionResourceIDs verifies that both the legacy AllowedResourceIDs","+// and the new AllowedResourceAccessIDs cert extensions are correctly populated","+// for access requests with constrained resources only, unconstrained resources","+// only, and a mix of both.","+//","+// Plain (unconstrained) resources should appear in both extensions.","+// Constrained resources appear only in the new extension. When all resources","+// are constrained, the legacy extension receives a sentinel value to prevent","+// older agents from interpreting an empty extension as \"unrestricted access\".","+// When a mix of plain and constrained resources is requested, only the plain","+// resource IDs appear in the legacy extension (no sentinel).","+func testCertExtensionResourceIDs(t *testing.T, testPack *accessRequestTestPack) {","+\tt.Parallel()","+","+\tctx := t.Context()","+","+\tusername := \"requester\"","+","+\tconstrainedResourceIDs := []types.ResourceAccessID{{","+\t\tId: types.ResourceID{","+\t\t\tClusterName: testPack.clusterName,","+\t\t\tKind:        types.KindNode,","+\t\t\tName:        \"staging\",","+\t\t},","+\t\tConstraints: &types.ResourceConstraints{","+\t\t\tDetails: &types.ResourceConstraints_Ssh{","+\t\t\t\tSsh: &types.SSHResourceConstraints{Logins: []string{\"root\"}},","+\t\t\t},","+\t\t},","+\t}}","+","+\tplainResourceIDs := []types.ResourceAccessID{{","+\t\tId: types.ResourceID{","+\t\t\tClusterName: testPack.clusterName,","+\t\t\tKind:        types.KindNode,","+\t\t\tName:        \"prod\",","+\t\t},","+\t}}","+","+\tmixedResourceIDs := append(plainResourceIDs, constrainedResourceIDs...)","+","+\tconstrainedRequest, err := services.NewAccessRequestWithResources(username, []string{\"admins\"}, constrainedResourceIDs)","+\trequire.NoError(t, err)","+\tplainRequest, err := services.NewAccessRequestWithResources(username, []string{\"admins\"}, plainResourceIDs)","+\trequire.NoError(t, err)","+\tmixedRequest, err := services.NewAccessRequestWithResources(username, []string{\"admins\"}, mixedResourceIDs)","+\trequire.NoError(t, err)","+","+\tfor _, req := range []types.AccessRequest{constrainedRequest, plainRequest, mixedRequest} {","+\t\treq.SetState(types.RequestState_APPROVED)","+\t\treq.SetAccessExpiry(time.Now().Add(time.Hour).UTC())","+\t\trequire.NoError(t, testPack.tlsServer.Auth().UpsertAccessRequest(ctx, req))","+\t}","+","+\trequester := authtest.TestUser(username)","+\trequesterClient, err := testPack.tlsServer.NewClient(requester)","+\trequire.NoError(t, err)","+\tt.Cleanup(func() { require.NoError(t, requesterClient.Close()) })","+","+\tgenerateCerts := func(t *testing.T, requestName string) *proto.Certs {","+\t\tt.Helper()","+\t\tcerts, err := requesterClient.GenerateUserCerts(ctx, proto.UserCertsRequest{","+\t\t\tSSHPublicKey:   testPack.sshPubKey,","+\t\t\tTLSPublicKey:   testPack.tlsPubKey,","+\t\t\tUsername:       username,","+\t\t\tExpires:        time.Now().Add(time.Hour).UTC(),","+\t\t\tAccessRequests: []string{requestName},","+\t\t})","+\t\trequire.NoError(t, err)","+\t\treturn certs","+\t}","+","+\ttype certResources struct {","+\t\tAllowedResourceIDs       []types.ResourceID","+\t\tAllowedResourceAccessIDs []types.ResourceAccessID","+\t}","+","+\tparseCertResources := func(t *testing.T, certs *proto.Certs) (ssh, tls certResources) {","+\t\tt.Helper()","+","+\t\tsshCert, err := sshutils.ParseCertificate(certs.SSH)","+\t\trequire.NoError(t, err)","+\t\tssh.AllowedResourceIDs, err = types.ResourceIDsFromString(sshCert.Permissions.Extensions[teleport.CertExtensionAllowedResources])","+\t\trequire.NoError(t, err)","+\t\tssh.AllowedResourceAccessIDs, err = types.ResourceAccessIDsFromString(sshCert.Permissions.Extensions[teleport.CertExtensionAllowedResourceAccessIDs])","+\t\trequire.NoError(t, err)","+","+\t\ttlsCert, err := tlsca.ParseCertificatePEM(certs.TLS)","+\t\trequire.NoError(t, err)","+\t\tfor _, attr := range tlsCert.Subject.Names {","+\t\t\tswitch {","+\t\t\tcase attr.Type.Equal(tlsca.AllowedResourcesASN1ExtensionOID):","+\t\t\t\ttls.AllowedResourceIDs, err = types.ResourceIDsFromString(attr.Value.(string))","+\t\t\t\trequire.NoError(t, err)","+\t\t\tcase attr.Type.Equal(tlsca.AllowedResourceAccessIDsASN1ExtensionOID):","+\t\t\t\ttls.AllowedResourceAccessIDs, err = types.ResourceAccessIDsFromString(attr.Value.(string))","+\t\t\t\trequire.NoError(t, err)","+\t\t\t}","+\t\t}","+","+\t\treturn ssh, tls","+\t}","+","+\tt.Run(\"constrained\", func(t *testing.T) {","+\t\tsshCert, tlsCert := parseCertResources(t, generateCerts(t, constrainedRequest.GetName()))","+","+\t\t// All resources are constrained, so the legacy extension gets the","+\t\t// sentinel and the new extension carries the full access IDs.","+\t\twant := certResources{","+\t\t\tAllowedResourceIDs:       []types.ResourceID{types.CreateSentinelResourceID()},","+\t\t\tAllowedResourceAccessIDs: constrainedResourceIDs,","+\t\t}","+\t\trequire.Equal(t, want, sshCert)","+\t\trequire.Equal(t, want, tlsCert)","+\t})","+","+\tt.Run(\"without constraints\", func(t *testing.T) {","+\t\tsshCert, tlsCert := parseCertResources(t, generateCerts(t, plainRequest.GetName()))","+","+\t\t// No constraints, so the legacy extension carries the actual","+\t\t// resource IDs and no sentinel is needed.","+\t\twant := certResources{","+\t\t\tAllowedResourceIDs:       []types.ResourceID{plainResourceIDs[0].Id},","+\t\t\tAllowedResourceAccessIDs: plainResourceIDs,","+\t\t}","+\t\trequire.Equal(t, want, sshCert)","+\t\trequire.Equal(t, want, tlsCert)","+\t})","+","+\tt.Run(\"mixed constrained and unconstrained\", func(t *testing.T) {","+\t\tsshCert, tlsCert := parseCertResources(t, generateCerts(t, mixedRequest.GetName()))","+","+\t\t// The legacy extension should contain only the plain resource IDs","+\t\t// (no sentinel) because older agents can still enforce those.","+\t\t// The new extension carries all resources including constrained ones.","+\t\twant := certResources{","+\t\t\tAllowedResourceIDs:       []types.ResourceID{plainResourceIDs[0].Id},","+\t\t\tAllowedResourceAccessIDs: mixedResourceIDs,","+\t\t}","+\t\trequire.Equal(t, want, sshCert)","+\t\trequire.Equal(t, want, tlsCert)","+\t})","+}"],"additions":167,"deletions":0,"truncated":false},{"path":"lib/auth/auth.go","lines":["@@ -3803,6 +3803,7 @@ func generateCert(ctx context.Context, a *Server, req cert.Request, caType types"," \tvar ("," \t\tscopePin                 *scopesv1.Pin"," \t\troleNames                []string","+\t\tallowedResourceIDs       []types.ResourceID"," \t\tallowedResourceAccessIDs []types.ResourceAccessID"," \t)"," ","@@ -3813,6 +3814,15 @@ func generateCert(ctx context.Context, a *Server, req cert.Request, caType types"," \tif unscoped := certParams.UnscopedCertParams(); unscoped != nil {"," \t\troleNames = unscoped.RoleNames()"," \t\tallowedResourceAccessIDs = unscoped.GetAllowedResourceAccessIDs()","+\t\t// Separate out any plain ResourceIDs (those