\"Add Comment\"),","+\t\t\t\tinvocationMessage: localize('toolInvoke.addComment', \"Adding comment\"),","+\t\t\t\tpastTenseMessage: localize('toolComplete.addComment', \"Added comment\"),","+\t\t\t};","+\t\tcase listCommentsToolName: {","+\t\t\tlet pastTenseMessage: StringOrMarkdown;","+\t\t\tconst count = result ? parseListedCommentCount(result.text) : undefined;","+\t\t\tif (count === undefined) {","+\t\t\t\tpastTenseMessage = localize('toolComplete.listComments', \"Checked comments\");","+\t\t\t} else if (count === 1) {","+\t\t\t\tpastTenseMessage = localize('toolComplete.listComments.one', \"Checked 1 comment\");","+\t\t\t} else {","+\t\t\t\tpastTenseMessage = localize('toolComplete.listComments.many', \"Checked {0} comments\", count);","+\t\t\t}","+\t\t\treturn {","+\t\t\t\tdisplayName: localize('toolName.listComments', \"List Comments\"),","+\t\t\t\tinvocationMessage: localize('toolInvoke.listComments', \"Checking comments\"),","+\t\t\t\tpastTenseMessage,","+\t\t\t};","+\t\t}","+\t\tcase deleteCommentsToolName:","+\t\t\treturn {","+\t\t\t\tdisplayName: localize('toolName.deleteComments', \"Delete Comments\"),","+\t\t\t\tinvocationMessage: localize('toolInvoke.deleteComments', \"Deleting comments\"),","+\t\t\t\tpastTenseMessage: localize('toolComplete.deleteComments', \"Deleted comments\"),","+\t\t\t};","+\t\tcase resolveCommentsToolName:","+\t\t\treturn {","+\t\t\t\tdisplayName: localize('toolName.resolveComments', \"Resolve Comments\"),","+\t\t\t\tinvocationMessage: localize('toolInvoke.resolveComments', \"Resolving comments\"),","+\t\t\t\tpastTenseMessage: localize('toolComplete.resolveComments', \"Resolved comments\"),","+\t\t\t};","+\t\tcase viewUnreviewedCommentsToolName:","+\t\t\treturn {","+\t\t\t\tdisplayName: localize('toolName.viewUnreviewedComments', \"View Comments\"),","+\t\t\t\tinvocationMessage: localize('toolInvoke.viewUnreviewedComments', \"Viewing comments\"),","+\t\t\t\tpastTenseMessage: localize('toolComplete.viewUnreviewedComments', \"Viewed comments\"),","+\t\t\t};","+\t\tdefault:","+\t\t\treturn undefined;","+\t}","+}","+"," /**","  * The feedback (\"comments\") server-tool group, contributed to the","  * {@link AgentServerToolHost} at startup (see `node/agentService.ts`). Wraps","@@ -514,6 +590,9 @@ export const feedbackServerToolGroup: IServerToolGroup = {"," \trequiresConfirmation(toolName): boolean {"," \t\treturn feedbackToolRequiresConfirmation(toolName);"," \t},","+\tgetDisplay(toolName, args, result): IServerToolDisplay | undefined {","+\t\treturn getFeedbackToolDisplay(toolName, args, result);","+\t},"," \texecute(stateManager, chatUri, toolName, rawArgs): string {"," \t\t// A session can contain multiple chats, each addressed by its own"," \t\t// `ahp-chat` URI but sharing the same context/workspace. Comments belong"],"additions":80,"deletions":1,"truncated":false},{"path":"src/vs/platform/agentHost/node/shared/agentServerToolHost.ts","lines":["@@ -5,9 +5,38 @@"," "," import type { IAgentServerToolHost } from '../../common/agentServerTools.js';"," import { ActionType } from '../../common/state/protocol/common/actions.js';","-import type { ToolDefinition, URI } from '../../common/state/sessionState.js';","+import type { StringOrMarkdown, ToolDefinition, URI } from '../../common/state/sessionState.js';"," import type { AgentHostStateManager } from '../agentHostStateManager.js';"," ","+/**","+ * Result of a server tool, passed to {@link IServerToolGroup.getDisplay} so the","+ * owning group can tailor its past-tense message to what the tool returned","+ * (for example a count parsed from the textual result). Absent while the tool","+ * is still running.","+ */","+export interface IServerToolDisplayResult {","+\t/** The textual tool result (the string the group's `execute` returned). */","+\treadonly text?: string;","+\t/** Whether the tool completed successfully. */","+\treadonly success: boolean;","+}","+","+/**","+ * Display strings for a server tool, authored by the group that owns the tool","+ * so every provider renders it identically (instead of each provider's display","+ * layer re-deriving the strings from the tool name). Each field is optional: a","+ * provider uses the returned value where present and falls back to its own","+ * generic display otherwise.","+ */","+export interface IServerToolDisplay {","+\t/** Human-readable tool name (e.g. \"List Comments\"). */","+\treadonly displayName?: string;","+\t/** Present-tense message shown while the tool runs (e.g. \"Checking comments\"). */","+\treadonly invocationMessage?: StringOrMarkdown;","+\t/** Past-tense message shown once the tool completes (e.g. \"Checked 3 comments\"). */","+\treadonly pastTenseMessage?: StringOrMarkdown;","+}","+"," /**","  * A group of related server tools owned and executed by the agent host. Each","  * group bundles the {@link ToolDefinition}s it advertises with an executor","@@ -43,6 +72,20 @@ export interface IServerToolGroup {"," \t * are invalid."," \t */"," \texecute(stateManager: AgentHostStateManager, sessionUri: URI, toolName: string, rawArgs: unknown): string;","+","+\t/**","+\t * Display strings for {@link toolName} (one of this group's","+\t * {@link definitions}), authored here so every provider renders this tool","+\t * identically rather than re-deriving the strings from the tool name. The","+\t * caller passes the parsed tool arguments and, once the tool has completed,","+\t * its {@link IServerToolDisplayResult result}. Returns `undefined` (or","+\t * individually-absent fields) to let the provider fall back to its generic","+\t * display. Optional: a group without bespoke display omits this.","+\t *","+\t * `toolName` is the bare tool name (the provider strips any transport","+\t * prefix such as Claude's `mcp__<server>__` before calling).","+\t */","+\tgetDisplay?(toolName: string, args: unknown, result?: IServerToolDisplayResult): IServerToolDisplay | undefined;"," }"," "," /**"],"additions":44,"deletions":1,"truncated":false},{"path":"src/vs/platform/agentHost/node/shared/serverToolGroups.ts","lines":["@@ -0,0 +1,58 @@","+/*---------------------------------------------------------------------------------------------","+ *  Copyright (c) Microsoft Corporation. All rights reserved.","+ *  Licensed under the MIT License. See License.txt in the project root for license information.","+ *--------------------------------------------------------------------------------------------*/","+","+import { feedbackServerToolGroup } from './agentFeedbackServerTools.js';","+import type { IServerToolDisplay, IServerToolDisplayResult, IServerToolGroup } from './agentServerToolHost.js';","+","+/**","+ * The server-tool groups contributed to every agent host session, in priority","+ * order. This is the single source of truth wired into the","+ * {@link AgentServerToolHost} at startup (see `agentService.ts`) and consulted","+ * by each provider's display layer via {@link getServerToolDisplay}.","+ *","+ * Adding a group here makes its tools available to all providers (Copilot,","+ * Claude, Codex, …) and — if the group implements","+ * {@link IServerToolGroup.getDisplay} — gives them nice display everywhere for","+ * free.","+ */","+export const serverToolGroups: readonly IServerToolGroup[] = [feedbackServerToolGroup];","+","+/**","+ * Whether {@link toolName} (a tool name as seen on a tool call) refers to the","+ * server tool {@link bareName}. Accepts both the bare name and a transport","+ * prefix such as Claude's `mcp__<server>__<name>` (matched as a `__`-delimited","+ * suffix), mirroring the convention in `agentFeedbackAnnotations.ts`.","+ */","+function matchesServerToolName(toolName: string, bareName: string): boolean {","+\treturn toolName === bareName || toolName.endsWith(`__${bareName}`);","+}","+","+/**","+ * Resolves the {@link IServerToolDisplay} for a server tool call, authored by","+ * the group that owns the tool. Returns `undefined` when no contributed group","+ * owns {@link toolName} or the owning group has no bespoke display, so each","+ * provider's display layer can fall back to its generic behavior.","+ *","+ * Pure over {@link serverToolGroups} (it does not need the constructed","+ * {@link AgentServerToolHost}) so the providers' history-replay paths — which","+ * build display from pure functions without a host instance — can call it too.","+ *","+ * @param toolName The tool name as seen on the call (bare or transport-prefixed).","+ * @param args The parsed tool arguments.","+ * @param result The tool result, once it has completed; absent while running.","+ */","+export function getServerToolDisplay(toolName: string, args: unknown, result?: IServerToolDisplayResult): IServerToolDisplay | undefined {","+\tfor (const group of serverToolGroups) {","+\t\tif (!group.getDisplay) {","+\t\t\tcontinue;","+\t\t}","+\t\tfor (const def of group.definitions) {","+\t\t\tif (matchesServerToolName(toolName, def.name)) {","+\t\t\t\treturn group.getDisplay(def.name, args, result);","+\t\t\t}","+\t\t}","+\t}","+\treturn undefined;","+}"],"additions":58,"deletions":0,"truncated":false},{"path":"src/vs/platform/agentHost/test/node/copilotToolDisplay.test.ts","lines":["@@ -66,6 +66,11 @@ suite('copilotToolDisplay — friendly tool names', () => {"," \t\t\t['tool_search_tool_regex', 'Search Tools'],"," \t\t\t['parallel_validation', 'Validate Changes'],"," \t\t\t['codeql_checker', 'CodeQL Security Scan'],","+\t\t\t['addComment', 'Add Comment'],","+\t\t\t['listComments', 'List Comments'],","+\t\t\t['deleteComments', 'Delete Comments'],","+\t\t\t['resolveComments', 'Resolve Comments'],","+\t\t\t['viewUnreviewedComments', 'View Comments'],"," \t\t];"," "," \t\tfor (const [toolName, displayName] of cases) {","@@ -443,6 +448,34 @@ suite('copilotToolDisplay — write_/read_ shell tools', () => {"," \t\t});"," \t});"," ","+\tsuite('feedback comment tools (delegated to the shared server-tool group)', () => {","+","+\t\tfunction text(msg: ReturnType<typeof getInvocationMessage> | ReturnType<typeof getPastTenseMessage>): string {","+\t\t\treturn typeof msg === 'string' ? msg : msg.markdown;","+\t\t}","+","+\t\t// Exhaustive per-tool/count coverage lives in serverToolGroups.test.ts.","+\t\t// These smoke checks only assert that the Copilot display functions","+\t\t// delegate to the shared group instead of falling through to the","+\t\t// generic `Using/Used \"<tool>\"` fallback.","+\t\ttest('Copilot display delegates to the shared group', () => {","+\t\t\tconst listResult = JSON.stringify({ comments: [{ id: 'a' }, { id: 'b' }] });","+\t\t\tassert.deepStrictEqual({","+\t\t\t\tdisplayName: getToolDisplayName('listComments'),","+\t\t\t\tinvoke: text(getInvocationMessage('listComments', 'List Comments', undefined)),","+\t\t\t\tpast: text(getPastTenseMessage('listComments', 'List Comments', undefined, true, listResult)),","+\t\t\t}, {","+\t\t\t\tdisplayName: 'List Comments',","+\t\t\t\tinvoke: 'Checking comments',","+\t\t\t\tpast: 'Checked 2 comments',","+\t\t\t});","+\t\t});","+","+\t\ttest('failed feedback tool still uses the generic failure message', () => {","+\t\t\tassert.strictEqual(text(getPastTenseMessage('listComments', 'List Comments', undefined, false)), '\"List Comments\" failed');","+\t\t});","+\t});","+"," \tsuite('getToolInputString', () => {"," "," \t\ttest('write_bash extracts command field', () => {"],"additions":33,"deletions":0,"truncated":false},{"path":"src/vs/platform/agentHost/test/node/serverToolGroups.test.ts","lines":["@@ -0,0 +1,84 @@","+/*---------------------------------------------------------------------------------------------","+ *  Copyright (c) Microsoft Corporation. All rights reserved.","+ *  Licensed under the MIT License. See License.txt in the project root for license information.","+ *--------------------------------------------------------------------------------------------*/","+","+import assert from 'assert';","+import { ensureNoDisposablesAreLeakedInTestSuite } from '../../../../base/test/common/utils.js';","+import type { StringOrMarkdown } from '../../common/state/sessionState.js';","+import { getServerToolDisplay } from '../../node/shared/serverToolGroups.js';","+","+function text(value: StringOrMarkdown | undefined): string | undefined {","+\tif (value === undefined) {","+\t\treturn undefined;","+\t}","+\treturn typeof value === 'string' ? value : value.markdown;","+}","+","+suite('serverToolGroups display', () => {","+","+\tensureNoDisposablesAreLeakedInTestSuite();","+","+\ttest('feedback tools resolve to dedicated display strings', () => {","+\t\tconst display = (toolName: string) => {","+\t\t\tconst d = getServerToolDisplay(toolName, undefined);","+\t\t\treturn { displayName: d?.displayName, invocation: text(d?.invocationMessage) };","+\t\t};","+\t\tassert.deepStrictEqual({","+\t\t\tadd: display('addComment'),","+\t\t\tlist: display('listComments'),","+\t\t\tdel: display('deleteComments'),","+\t\t\tresolve: display('resolveComments'),","+\t\t\tview: display('viewUnreviewedComments'),","+\t\t}, {","+\t\t\tadd: { displayName: 'Add Comment', invocation: 'Adding comment' },","+\t\t\tlist: { displayName: 'List Comments', invocation: 'Checking comments' },","+\t\t\tdel: { displayName: 'Delete Comments', invocation: 'Deleting comments' },","+\t\t\tresolve: { displayName: 'Resolve Comments', invocation: 'Resolving comments' },","+\t\t\tview: { displayName: 'View Comments', invocation: 'Viewing comments' },","+\t\t});","+\t});","+","+\ttest('listComments past tense reflects the comment count parsed from the result', () => {","+\t\tconst past = (resultText?: string) =>","+\t\t\ttext(getServerToolDisplay('listComments', undefined, { text: resultText, success: true })?.pastTenseMessage);","+\t\tconst withComments = (n: number) => JSON.stringify({ comments: Array.from({ length: n }, (_, i) => ({ id: `${i}` })) });","+\t\tassert.deepStrictEqual({","+\t\t\tzero: past(withComments(0)),","+\t\t\tone: past(withComments(1)),","+\t\t\tmany: past(withComments(3)),","+\t\t\tnoResult: past(),","+\t\t\tmalformed: past('not json'),","+\t\t\tnoComments: past(JSON.stringify({ other: 1 })),","+\t\t}, {","+\t\t\tzero: 'Checked 0 comments',","+\t\t\tone: 'Checked 1 comment',","+\t\t\tmany: 'Checked 3 comments',","+\t\t\tnoResult: 'Checked comments',","+\t\t\tmalformed: 'Checked comments',","+\t\t\tnoComments: 'Checked comments',","+\t\t});","+\t});","+","+\ttest('non-listComments past tense ignores the result text', () => {","+\t\tassert.strictEqual(","+\t\t\ttext(getServerToolDisplay('resolveComments', undefined, { text: 'anything', success: true })?.pastTenseMessage),","+\t\t\t'Resolved comments',","+\t\t);","+\t});","+","+\ttest('transport-prefixed names (Claude mcp__host__) match the bare tool', () => {","+\t\tassert.deepStrictEqual({","+\t\t\tdisplay: getServerToolDisplay('mcp__host__listComments', undefined)?.displayName,","+\t\t\tpast: text(getServerToolDisplay('mcp__host__listComments', undefined, { text: JSON.stringify({ comments: [{ id: 'a' }, { id: 'b' }] }), success: true })?.pastTenseMessage),","+\t\t}, {","+\t\t\tdisplay: 'List Comments',","+\t\t\tpast: 'Checked 2 comments',","+\t\t});","+\t});","+","+\ttest('unknown tools return undefined so callers fall back to their generic display', () => {","+\t\tassert.strictEqual(getServerToolDisplay('bash', { command: 'ls' }), undefined);","+\t\tassert.strictEqual(getServerToolDisplay('someClientTool', undefined), undefined);","+\t});","+});",""],"additions":84,"deletions":0,"truncated":false}],"additions":349,"deletions":12,"truncated":false,"file_count":13},"error":null,"fetched_at":"2026-06-28T10:13:00.720996+00:00"}