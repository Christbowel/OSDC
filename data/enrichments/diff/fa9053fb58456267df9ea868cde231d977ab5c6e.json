","+\t\tif err == nil {","+\t\t\tt.Fatal(\"SafeOpenFile should reject symlink\")","+\t\t}","+\t})","+}","+","+func TestSafeRemoveAll(t *testing.T) {","+\tt.Run(\"remove real directory\", func(t *testing.T) {","+\t\ttempDir := t.TempDir()","+\t\ttarget := filepath.Join(tempDir, \"removeme\")","+\t\tif err := os.MkdirAll(filepath.Join(target, \"sub\"), 0755); err != nil {","+\t\t\tt.Fatalf(\"Failed to create dirs: %v\", err)","+\t\t}","+\t\tif err := os.WriteFile(filepath.Join(target, \"sub\", \"f.txt\"), []byte(\"x\"), 0644); err != nil {","+\t\t\tt.Fatalf(\"Failed to create file: %v\", err)","+\t\t}","+","+\t\tif err := SafeRemoveAll(target); err != nil {","+\t\t\tt.Fatalf(\"SafeRemoveAll should remove real dir: %v\", err)","+\t\t}","+","+\t\tif _, err := os.Stat(target); !os.IsNotExist(err) {","+\t\t\tt.Error(\"Directory should have been removed\")","+\t\t}","+\t})","+","+\tt.Run(\"reject symlink\", func(t *testing.T) {","+\t\ttempDir := t.TempDir()","+\t\trealDir := filepath.Join(tempDir, \"real_dir\")","+\t\tif err := os.Mkdir(realDir, 0755); err != nil {","+\t\t\tt.Fatalf(\"Failed to create dir: %v\", err)","+\t\t}","+\t\tif err := os.WriteFile(filepath.Join(realDir, \"precious.txt\"), []byte(\"keep\"), 0644); err != nil {","+\t\t\tt.Fatalf(\"Failed to create file: %v\", err)","+\t\t}","+","+\t\tsymDir := filepath.Join(tempDir, \"sym_dir\")","+\t\tif err := os.Symlink(realDir, symDir); err != nil {","+\t\t\tt.Fatalf(\"Failed to create symlink: %v\", err)","+\t\t}","+","+\t\tif err := SafeRemoveAll(symDir); err == nil {","+\t\t\tt.Fatal(\"SafeRemoveAll should reject symlink\")","+\t\t}","+","+\t\tif _, err := os.Stat(filepath.Join(realDir, \"precious.txt\")); err != nil {","+\t\t\tt.Fatal(\"Real directory contents should not have been deleted\")","+\t\t}","+\t})","+","+\tt.Run(\"non-existent path is no-op\", func(t *testing.T) {","+\t\tif err := SafeRemoveAll(\"/path/that/does/not/exist\"); err != nil {","+\t\t\tt.Errorf(\"SafeRemoveAll should silently succeed fo