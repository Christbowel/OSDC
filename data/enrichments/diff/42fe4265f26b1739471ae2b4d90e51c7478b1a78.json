(req.PriorAttrs, cty.DynamicPseudoType)","+\tif err != nil {","+\t\treturn ErrorEvalFromDiags(append(diags, &proto.Diagnostic{","+\t\t\tSeverity: proto.Severity_ERROR,","+\t\t\tSummary:  \"Failed to serialize prior attributes\",","+\t\t\tDetail:   fmt.Sprintf(\"Failed to serialize prior attributes: %v.\", err),","+\t\t}))","+\t}","+","+\tevalID := c.callbackRegistry.NextID()","+\trequest := &proto.PolicyEvaluateResourceRequest{","+\t\tEvaluationId: evalID,","+\t\tResource:     req.Target,","+\t\tAttrs:        attrsBytes,","+\t\tMetadata:     req.Meta,","+\t\tPriorAttrs:   priorAttrsBytes,","+\t}","+","+\t// Register the callback functions with the callback service, so that they are available","+\t// for use during evaluation.","+\tc.callbackRegistry.Register(evalID, req.Callbacks)","+","+\t// We can unregister the callback functions after the evaluation is complete.","+\tdefer c.callbackRegistry.Unregister(evalID)","+","+\tresponse, err := c.client.EvaluateResource(ctx, request)","+\tif err != nil {","+\t\treturn ErrorEvalFromDiags(append(diags, &proto.Diagnostic{","+\t\t\tSeverity: proto.Severity_ERROR,","+\t\t\tSummary:  \"Failed to evaluate Terraform Policy\",","+\t\t\tDetail:   fmt.Sprintf(\"Failed to evaluate Terraform Policy: %v.\", err),","+\t\t}))","+\t}","+","+\treturn EvaluationFromProtoResponse(response.Result, response.PolicyDetails)","+}","+","+func (c *client) EvaluateProvider(ctx context.Context, req EvaluationRequest[*proto.PolicyEvaluateProviderRequest_ProviderMetadata]) EvaluationResponse {","+\tlog.Printf(\"[DEBUG] Evaluating policy for provider %s\", req.Target)","+\tvar diags []*proto.Diagnostic","+\treq = normalizeRequest(req)","+","+\tattrsBytes, err := msgpack.Marshal(req.Attrs, cty.DynamicPseudoType)","+\tif err != nil {","+\t\treturn ErrorEvalFromDiags(append(diags, &proto.Diagnostic{","+\t\t\tSeverity: proto.Severity_ERROR,","+\t\t\tSummary:  \"Failed to serialize attributes\",","+\t\t\tDetail:   fmt.Sprintf(\"Failed to serialize attribute