e config: %w\", err)","+\t}","+","+\tfunctions, ok := s.Registry.Get(request.EvaluationRequestId)","+\tif !ok {","+\t\treturn nil, fmt.Errorf(\"no callback registered for ID %d (request type: %s)\", request.EvaluationRequestId, request.Type)","+\t}","+\tdatasource, err := functions.GetDataSource(request.Type, config)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+","+\tresult, err := msgpack.Marshal(datasource, cty.DynamicPseudoType)","+\tif err != nil {","+\t\treturn nil, fmt.Errorf(\"failed to serialize datasource: %w\", err)","+\t}","+","+\treturn &proto.GetDataSourceResponse{","+\t\tResult: result,","+\t}, nil","+}","+","+func (s *Server) Stop() {","+\tif s.Grpc != nil {","+\t\ts.Grpc.GracefulStop()","+\t}","+}"],"additions":85,"deletions":0,"truncated":false},{"path":"internal/policy/callback/testing.go","lines":["@@ -0,0 +1,61 @@","+// Copyright IBM Corp. 2014, 2026","+// SPDX-License-Identifier: BUSL-1.1","+","+package callback","+","+import \"sync\"","+","+var _ Registry = (*MockRegistry)(nil)","+","+// MockRegistry implements Registry for testing purposes.","+type MockRegistry struct {","+\tmu sync.Mutex","+","+\tNextIDCalled bool","+\tNextIDValue  uint32","+","+\tRegisterCalled   bool","+\tFunctionsStore   map[uint32]Functions","+\tUnregisterCalled bool","+\tGetCalled        bool","+}","+","+func (m *MockRegistry) Register(id uint32, fns Functions) {","+\tm.mu.Lock()","+\tdefer m.mu.Unlock()","+\tm.RegisterCalled = true","+\tif m.FunctionsStore == nil {","+\t\tm.FunctionsStore = make(map[uint32]Functions)","+\t}","+\tm.FunctionsStore[id] = fns","+}","+","+func (m *MockRegistry) Unregister(id uint32) {","+\tm.mu.Lock()","+\tdefer m.mu.Unlock()","+\tm.UnregisterCalled = true","+\tif m.FunctionsStore != nil {","+\t\tdelete(m.FunctionsStore, id)","+\t}","+}","+","+func (m *MockRegistry) Get(id uint32) (Functions, bool) {","+\tm.mu.Lock()","+\tdefer m.mu.Unlock()","+","+\tm.GetCalled = true","+\tif m.FunctionsStore == nil {","+\t\treturn Functions{}, fal