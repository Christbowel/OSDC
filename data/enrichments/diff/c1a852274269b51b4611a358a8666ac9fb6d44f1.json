{"id":"c1a852274269b51b4611a358a8666ac9fb6d44f1","axis":"silent","repo":"gravitational/teleport","sha":"c1a852274269b51b4611a358a8666ac9fb6d44f1","parsed":{"files":[{"path":"api/types/session.go","lines":["@@ -82,6 +82,13 @@ type WebSession interface {"," \tGetBearerTokenExpiryTime() time.Time"," \t// GetExpiryTime - absolute time when web session expires"," \tGetExpiryTime() time.Time","+\t// GetEarliestExpiry returns the time after which the session should be","+\t// considered dead by the system. For standard sessions this is the","+\t// earliest of BearerTokenExpires and Expires (treating zero as infinity);","+\t// for ACCESS_GRAPH_API sessions, which authenticate via client TLS","+\t// certificate and carry no bearer token, it is Expires. See","+\t// [WebSessionV2.GetEarliestExpiry] for the full rationale.","+\tGetEarliestExpiry() time.Time"," \t// GetLoginTime returns the time this user recently logged in."," \tGetLoginTime() time.Time"," \t// SetLoginTime sets when this user logged in.","@@ -387,6 +394,47 @@ func (ws *WebSessionV2) GetExpiryTime() time.Time {"," \treturn ws.Spec.Expires"," }"," ","+// GetEarliestExpiry returns the time after which the session should be considered","+// dead by the system. The choice depends on which credential authenticates","+// requests for that session's [WebSessionUsage]:","+//","+//   - WEB_SESSION_USAGE_UNSPECIFIED: requests are authenticated with the","+//     bearer token (cookie + Authorization header). Returns the earliest of","+//     BearerTokenExpires and Expires so the session dies as soon as either","+//     the bearer token or the session itself expires. In practice the auth","+//     server caps the bearer-token TTL at the session TTL, so the","+//     bearer-token expiry is the typical winner; the session-expiry cap","+//     guards against externally-constructed sessions that violate that","+//     invariant.","+//","+//   - WEB_SESSION_USAGE_ACCESS_GRAPH_API: requests are authenticated with a","+//     client TLS certificate. There is no bearer token (BearerToken is empty","+//     and BearerTokenExpires is zero), so the session lives until the","+//     certificate / session itself expires. Returns Expires.","+//","+// Callers that compute a backend item TTL or fall back to a session-local","+// expiry decision when a backend lookup is inconclusive should prefer this","+// method over reading the bearer/session expiries directly, so the","+// usage-specific choice stays in one place.","+func (ws *WebSessionV2) GetEarliestExpiry() time.Time {","+\tif ws.Spec.Usage == WebSessionUsage_WEB_SESSION_USAGE_ACCESS_GRAPH_API {","+\t\treturn ws.Spec.Expires","+\t}","+\t// Return the earlier of the two expiries, treating a zero time as \"no","+\t// expiry\" rather than the epoch.","+\tbearer, sess := ws.Spec.BearerTokenExpires, ws.Spec.Expires","+\tswitch {","+\tcase bearer.IsZero():","+\t\treturn sess","+\tcase sess.IsZero():","+\t\treturn bearer","+\tcase bearer.Before(sess):","+\t\treturn bearer","+\tdefault:","+\t\treturn sess","+\t}","+}","+"," // GetLoginTime returns the time this user recently logged in."," func (ws *WebSessionV2) GetLoginTime() time.Time {"," \treturn ws.Spec.LoginTime"],"additions":48,"deletions":0,"truncated":false},{"path":"api/types/session_test.go","lines":["@@ -0,0 +1,92 @@","+// Copyright 2026 Gravitational, Inc.","+//","+// Licensed under the Apache License, Version 2.0 (the \"License\");","+// you may not use this file except in compliance with the License.","+// You may obtain a copy of the License at","+//","+//     http://www.apache.org/licenses/LICENSE-2.0","+//","+// Unless required by applicable law or agreed to in writing, software","+// distributed under the License is distributed on an \"AS IS\" BASIS,","+// WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.","+// See the License for the specific language governing permissions and","+// limitations under the License.","+","+package types_test","+","+import (","+\