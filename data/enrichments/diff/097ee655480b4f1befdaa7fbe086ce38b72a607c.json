," import {phpantomHover} from \"./editor/phpantomHover\";","+import {goToDefinition} from \"./editor/goToDefinition\";"," import {phpantomLsp, PHP_URI} from \"./phpantom/lspClient\";"," "," ko.bindingHandlers.codeMirror = {","@@ -87,6 +88,7 @@ ko.bindingHandlers.codeMirror = {"," \t\t\tlineErrors,"," \t\t\thover,"," \t\t\tphpantomHover,","+\t\t\tgoToDefinition,"," \t\t\tphpantomLsp.plugin(PHP_URI, 'php'),"," \t\t\tEditorView.baseTheme({"," \t\t\t\t'.cm-tooltip.cm-tooltip-hover': {"],"additions":2,"deletions":0,"truncated":false},{"path":"website/src/js/editor/goToDefinition.ts","lines":["@@ -0,0 +1,194 @@","+import {Decoration, DecorationSet, EditorView, ViewPlugin} from '@codemirror/view';","+import {EditorState, Extension, StateEffect, StateField} from '@codemirror/state';","+import {phpantomLsp, PHP_URI} from '../phpantom/lspClient';","+","+// Cmd/Ctrl-click go-to-definition for symbols declared in the playground file","+// itself (classes, methods, properties, functions). Holding the modifier and","+// hovering shows an underline + pointer over navigable symbols; clicking jumps","+// to the declaration and briefly flashes its line. Symbols from phpstorm-stubs,","+// PHP builtins or the shipped PHPStan stubs are deliberately not navigable —","+// PHPantom resolves their definition to a different (or no) URI, and we only","+// act when it points back into the edited document.","+","+interface LspPosition { line: number; character: number }","+interface LspLocation { uri: string; range: {start: LspPosition; end: LspPosition} }","+interface DefinitionParams { textDocument: {uri: string}; position: LspPosition }","+","+// CodeMirror abstracts the platform modifier for *keymaps* (`Mod-` = Cmd on","+// macOS, Ctrl elsewhere) but not for mouse events, so we mirror its own check.","+const isMac = typeof navigator !== 'undefined' && /Mac|iP(hone|ad|od)/.test(navigator.platform);","+function modHeld(event: MouseEvent): boolean {","+\treturn isMac ? event.metaKey : event.ctrlKey;","+}","+","+function toLspPosition(state: EditorState, offset: number): LspPosition {","+\tconst line = state.doc.lineAt(offset);","+\treturn {line: line.number - 1, character: offset - line.from};","+}","+","+function fromLspPosition(state: EditorState, pos: LspPosition): number {","+\tif (pos.line >= state.doc.lines) {","+\t\treturn state.doc.length;","+\t}","+\tconst line = state.doc.line(pos.line + 1);","+\treturn Math.min(line.from + pos.character, line.to);","+}","+","+// Ask PHPantom for the definition at `offset`; return the in-document target","+// offset, or null if there's none or it lives outside the edited file.","+async function resolveInFileDefinition(state: EditorState, offset: number): Promise<number | null> {","+\t// Flush pending edits to the worker so the definition is resolved against","+\t// the current document (mirrors what serverCompletion does).","+\tphpantomLsp.sync();","+\tlet result: LspLocation[] | LspLocation | null;","+\ttry {","+\t\tresult = await phpantomLsp.request<DefinitionParams, LspLocation[] | LspLocation | null>(","+\t\t\t'textDocument/definition',","+\t\t\t{textDocument: {uri: PHP_URI}, position: toLspPosition(state, offset)},","+\t\t);","+\t} catch {","+\t\treturn null;","+\t}","+\tconst location = Array.isArray(result) ? result[0] : result;","+\tif (!location || location.uri !== PHP_URI) {","+\t\treturn null;","+\t}","+\treturn fromLspPosition(state, location.range.start);","+}","+","+const linkMark = Decoration.mark({class: 'cm-goto-def-link'});","+const flashLine = Decoration.line({class: 'cm-goto-def-flash'});","+","+const setLink = StateEffect.define<{from: number; to: number} | null>();","+const setFlash = StateEffect.define<number | null>();","+","+const linkField = StateField.define<DecorationSet>({","+\tcreate: () => Decoration.none,","+\tupdate(deco, tr) {","+\t\tdeco = deco.map(tr.changes);","+\t\tfor (const effect of tr.effects) {","+\t\t\tif (effect.is(setLink)) {","+\t\t\t\tdeco = effect.value","+\t\t\t\t\t? Decoration.set([linkMark.range(effect.value.from, effect.value.to)])","+\t\t\t\t\t: Decoration.none;","+\t\t\t}","+\t\t}","+\t\treturn deco;","+\t},","+\tprovide: f => EditorView.decorations.from(f),","+});","+","+const flashField = StateField.define<DecorationSet>({","+\tcreate: () => Decoration.none,","+\tupdate(deco, tr) {","+\t\tdeco = deco.map(tr.changes);","+\t\tfor (const effect of tr.effects) {","+\t\t\tif (effect.is(setFlash)) {","+\t\t\t\tdeco = effect.value == null","+\t\t\t\t\t? Decoration.none","+\t\t\t\t\t: Decoration.set([flashLine.range(tr.state.doc.lineAt(effect.value).from)]);","+\t\t\t}","+\t\t}","+\t\treturn deco;","+\t},","+\tprovide: f => EditorView.decorations.from(f),","+});","+","+const goToDefinitionPlugin = ViewPlugin.fromClass(class {","+\tprivate link: {from: number; to: number} | null = null;","+\tprivate requestSeq = 0;","+\tprivate flashTimer = -1;","+","+\tconstructor(private readonly view: EditorView) {","+\t\tthis.onKeyUp = this.onKeyUp.bind(this);","+\t\twindow.addEventListener('keyup', this.onKeyUp);","+\t}","+","+\tdestroy(): void {","+\t\twindow.removeEventListener('keyup', this.onKeyUp);","+\t\tif (this.flashTimer >= 0) {","+\t\t\tclearTimeout(this.flashTimer);","+\t\t}","+\t}","+","+\tprivate onKeyUp(): void {","+\t\tthis.clearLink();","+\t}","+","+\tclearLink(): void {","+\t\tif (this.link !== null) {","+\t\t\tthis.link = null;","+\t\t\tthis.view.dispatch({effects: setLink.of(null)});","+\t\t}","+\t}","+","+\tonMouseMove(event: MouseEvent): void {","+\t\tif (!modHeld(event)) {","+\t\t\tthis.clearLink();","+\t\t\treturn;","+\t\t}","+\t\tconst offset = this.view.posAtCoords({x: event.clientX, y: event.clientY});","+\t\tconst word = offset == null ? null : this.view.state.wordAt(offset);","+\t\tif (offset == null || word == null) {","+\t\t\tthis.clearLink();","+\t\t\treturn;","+\t\t}","+\t\tif (this.link !== null && this.link.from === word.from && this.link.to === word.to) {","+\t\t\treturn; // already showing this token","+\t\t}","+\t\tconst seq = ++this.requestSeq;","+\t\tvoid resolveInFileDefinition(this.view.state, offset).then(target => {","+\t\t\tif (seq !== this.requestSeq) {","+\t\t\t\treturn; // a newer hover superseded this request","+\t\t\t}","+\t\t\tif (target == null) {","+\t\t\t\tthis.clearLink();","+\t\t\t\treturn;","+\t\t\t}","+\t\t\tthis.link = {from: word.from, to: word.to};","+\t\t\tthis.view.dispatch({effects: setLink.of(this.link)});","+\t\t});","+\t}","+","+\tonMouseDown(event: MouseEvent): boolean {","+\t\tif (!modHeld(event)) {","+\t\t\treturn false;","+\t\t}","+\t\tconst offset = this.view.posAtCoords({x: event.clientX, y: event.clientY});","+\t\tif (offset == null || this.view.state.wordAt(offset) == null) {","+\t\t\treturn false;","+\t\t}","+\t\t// Take over the modifier-click (CodeMirror would otherwise add a cursor).","+\t\tevent.preventDefault();","+\t\tvoid resolveInFileDefinition(this.view.state, offset).then(target => {","+\t\t\tif (target != null) {","+\t\t\t\tthis.jumpTo(target);","+\t\t\t}","+\t\t});","+\t\treturn true;","+\t}","+","+\tprivate jumpTo(offset: number): void {","+\t\tthis.clearLink();","+\t\tthis.view.dispatch({","+\t\t\tselection: {anchor: offset},","+\t\t\teffects: [EditorView.scrollIntoView(offset, {y: 'center'}), setFlash.of(offset)],","+\t\t});","+\t\tthis.view.focus();","+\t\tif (this.flashTimer >= 0) {","+\t\t\tclearTimeout(this.flashTimer);","+\t\t}","+\t\tthis.flashTimer = window.setTimeout(() => {","+\t\t\tthis.view.dispatch({effects: setFlash.of(null)});","+\t\t\tthis.flashTimer = -1;","+\t\t}, 1200);","+\t}","+}, {","+\teventHandlers: {","+\t\tmousemove(event) { this.onMouseMove(event); },","+\t\tmousedown(event) { return this.onMouseDown(event); },","+\t\tmouseleave() { this.clearLink(); },","+\t},","+});","+","+export const goToDefinition: Extension = [linkField, flashField, goToDefinitionPlugin];",""],"additions":194,"deletions":0,"truncated":false}],"additions":242,"deletions":2,"truncated":false,"file_count":6},"error":null,"fetched_at":"2026-05-23T09:23:52.992322+00:00"}