{"id":"097ee655480b4f1befdaa7fbe086ce38b72a607c","axis":"silent","repo":"phpstan/phpstan","sha":"097ee655480b4f1befdaa7fbe086ce38b72a607c","parsed":{"files":[{"path":"website/functional-tests/autocomplete.spec.ts","lines":["@@ -124,7 +124,7 @@ test('selects the parameter placeholder after completing a method with args', as"," "," \t// The first placeholder ($name) is selected — not the empty $0 — and the"," \t// LSP escape is unescaped (no leading backslash).","-\tawait expect.poll(() => page.evaluate(() => window.getSelection()!.toString())).toBe('$name');","+\tawait expect.poll(() => page.evaluate(() => window.getSelection()!.toString()), {timeout: COMPLETION_TIMEOUT}).toBe('$name');"," });"," "," test('adds a use statement when completing a class inside a namespace', async ({page}) => {","@@ -145,3 +145,26 @@ test('adds a use statement when completing a class inside a namespace', async ({"," \tconst doc = page.locator('.cm-content').first();"," \tawait expect(doc).toContainText('use DateTimeImmutable;');"," });","+","+test('Cmd/Ctrl-click jumps to an in-file declaration', async ({page}) => {","+\tawait setCode(page, [","+\t\t'<?php',","+\t\t'class Greeter {',","+\t\t'    public function greet(): string { return \"hi\"; }',","+\t\t'}',","+\t\t'$g = new Greeter();',","+\t\t'$g->greet();',","+\t].join('\\n'));","+\t// Let the worker index the document before resolving the definition.","+\tawait page.waitForTimeout(500);","+","+\t// Modifier-click the greet() call (second 'greet' token; the first is the","+\t// declaration). ControlOrMeta maps to Cmd on macOS, Ctrl elsewhere — the","+\t// same split the extension uses.","+\tawait page.locator('.cm-content').getByText('greet', {exact: true}).nth(1)","+\t\t.click({modifiers: ['ControlOrMeta']});","+","+\t// The declaration line flashes (and the cursor jumps there).","+\tawait expect(page.locator('.cm-goto-def-flash'))","+\t\t.toContainText('function greet', {timeout: COMPLETION_TIMEOUT});","+});"],"additions":24,"delet