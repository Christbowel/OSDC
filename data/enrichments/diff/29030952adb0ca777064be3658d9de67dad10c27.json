ntains;","+","+public class ModelWithContainsConstraints {","+","+\t@Contains(\"foo\")","+\tpublic Collection<String> collection;","+","+\t@Contains(\"foo\")","+\tpublic List<String> list;","+","+\t@Contains(\"foo\")","+\tpublic Set<String> set;","+","+\t@Contains(\"foo\")","+\tpublic String string;","+}"],"additions":26,"deletions":0,"truncated":false},{"path":"documentation/src/main/asciidoc/reference/_ch02.adoc","lines":["@@ -665,6 +665,10 @@ message, groups and payload. This is a requirement of the Jakarta Validation spe"," In addition to the constraints defined by the Jakarta Validation API, Hibernate Validator provides several useful custom constraints which are listed below."," With one exception also these constraints apply to the field/property level, only `@ScriptAssert` is a class-level constraint."," ","+`@Contains(value=, minRequired=, ignoreCase=)`:: Validates that the annotated character sequence contains the specified substrings. By default, all substrings must be present. Use `minRequired` to specify a minimum number of substrings that must match (e.g., `minRequired=1` for an OR-style check). When `ignoreCase` is set to `true`, the comparison is case-insensitive.","+\tSupported data types::: `CharSequence`","+\tHibernate metadata impact::: None","+"," `@CreditCardNumber(ignoreNonDigitCharacters=)`:: Checks that the annotated character sequence passes the Luhn checksum test. Note, this validation aims to check for user mistakes, not credit card validity! See also http://www.dirigodev.com/blog/ecommerce/anatomy-of-a-credit-card-number/[Anatomy of a credit card number]. `ignoreNonDigitCharacters` allows to ignore non digit characters. The default is `false`."," \tSupported data types::: `CharSequence`"," \tHibernate metadata impact::: None"],"additions":4,"deletions":0,"truncated":false},{"path":"engine/src/main/java/org/hibernate/validator/cfg/defs/ContainsDef.java","lines":["@@ -0,0 +1,38 @@","+/*","+ * SPDX-License-Identifier: Apache-2.0","+ * Copyright Red Hat Inc. and Hibernate Authors","+ */","+","+package org.hibernate.validator.cfg.defs;","+","+import org.hibernate.validator.Incubating;","+import org.hibernate.validator.cfg.ConstraintDef;","+import org.hibernate.validator.constraints.Contains;","+","+/**","+ * A {@link Contains} constraint definition.","+ * @author Sean Okafor","+ * @since 9.2","+ */","+@Incubating","+public class ContainsDef extends ConstraintDef<ContainsDef, Contains> {","+","+\tpublic ContainsDef() {","+\t\tsuper( Contains.class );","+\t}","+","+\tpublic ContainsDef value(String... value) {","+\t\taddParameter( \"value\", value );","+\t\treturn this;","+\t}","+","+\tpublic ContainsDef minRequired(int minRequired) {","+\t\taddParameter( \"minRequired\", minRequired );","+\t\treturn this;","+\t}","+","+\tpublic ContainsDef ignoreCase(boolean ignoreCase) {","+\t\taddParameter( \"ignoreCase\", ignoreCase );","+\t\treturn this;","+\t}","+}"],"additions":38,"deletions":0,"truncated":false},{"path":"engine/src/main/java/org/hibernate/validator/cfg/defs/DateTimeFormatDef.java","lines":["@@ -7,6 +7,7 @@"," "," import java.util.Locale;"," ","+import org.hibernate.validator.Incubating;"," import org.hibernate.validator.cfg.ConstraintDef;"," import org.hibernate.validator.constraints.DateTimeFormat;"," ","@@ -15,6 +16,7 @@","  * @author Sean Okafor","  * @since 9.2","  */","+@Incubating"," public class DateTimeFormatDef extends ConstraintDef<DateTimeFormatDef, DateTimeFormat> {"," "," \tpublic DateTimeFormatDef() {"],"additions":2,"deletions":0,"truncated":false},{"path":"engine/src/main/java/org/hibernate/validator/constraints/Contains.java","lines":["@@ -0,0 +1,85 @@","+/*","+ * SPDX-License-Identifier: Apache-2.0","+ * Copyright Red Hat Inc. and Hibernate Authors","+ */","+package org.hibernate.validator.constraints;","+","+import static java.lang.annotation.ElementType.ANNOTATION_TYPE;","+import static java.lang.annotation.ElementType.CONSTRUCTOR;","+import static java.lang.annotation.ElementType.FIELD;","+import static java.lang.annotation.ElementType.METHOD;","+import static java.lang.annotation.ElementType.PARAMETER;","+import static java.lang.annotation.ElementType.TYPE_USE;","+import static java.lang.annotation.RetentionPolicy.RUNTIME;","+","+import java.lang.annotation.Documented;","+import java.lang.annotation.Repeatable;","+import java.lang.annotation.Retention;","+import java.lang.annotation.Target;","+","+import jakarta.validation.Constraint;","+import jakarta.validation.Payload;","+","+import org.hibernate.validator.Incubating;","+import org.hibernate.validator.constraints.Contains.List;","+","+/**","+ * Validates that the annotated character sequence contains all (or a minimum number of) the specified substrings.","+ * <p>","+ * By default, all specified values must be present (AND semantics). Use {@code minRequired} to require only","+ * a minimum number of matches (e.g., {@code minRequired=1} for OR semantics).","+ * <p>","+ * When {@code ignoreCase} is set to {@code true}, the comparison is case-insensitive.","+ * {@code null} values are considered valid.","+ *","+ * @author Sean Okafor","+ * @since 9.2","+ */","+@Documented","+@Constraint(validatedBy = { })","+@Target({ METHOD, FIELD, ANNOTATION_TYPE, CONSTRUCTOR, PARAMETER, TYPE_USE })","+@Retention(RUNTIME)","+@Repeatable(List.class)","+@Incubating","+public @interface Contains {","+\t/**","+\t * Sentinel value indicating that all provided substrings must be present.","+\t */","+\tint MATCH_ALL = -1;","+","+\t/**","+\t * @return the substrings that must be present in the annotated character sequence.","+\t */","+\tString[] value();","+","+\t/**","+\t * @return the minimum number of substrings that must be present for validation to pass.","+\t * Defaults to {@link #MATCH_ALL}, meaning all substrings must be present (AND semantics).","+\t * Set to {@code 1} for OR semantics, or any other positive value for a custom threshold.","+\t */","+\tint minRequired() default MATCH_ALL;","+","+\t/**","+\t * @return whether to perform case-insensitive matching.","+\t * When {@code false} (default), matching is case-sensitive.","+\t * When {@code true}, both the input and the substrings are compared","+\t * using {@link java.util.Locale#ROOT} lowercasing.","+\t */","+\tboolean ignoreCase() default false;","+","+\tString message() default \"{org.hibernate.validator.constraints.Contains.message}\";","+","+\tClass<?>[] groups() default { };","+","+\tClass<? extends Payload>[] payload() default { };","+","+\t/**","+\t * Defines several {@code @Contains} annotations on the same element.","+\t */","+\t@Target({ METHOD, FIELD, ANNOTATION_TYPE, CONSTRUCTOR, PARAMETER, TYPE_USE })","+\t@Retention(RUNTIME)","+\t@Documented","+\tpublic @interface List {","+\t\tContains[] value();","+\t}","+}"],"additions":85,"deletions":0,"truncated":false},{"path":"engine/src/main/java/org/hibernate/validator/internal/constraintvalidators/hv/ContainsValidator.java","lines":["@@ -0,0 +1,77 @@","+/*","+ * SPDX-License-Identifier: Apache-2.0","+ * Copyright Red Hat Inc. and Hibernate Authors","+ */","+package org.hibernate.validator.internal.constraintvalidators.hv;","+","+import java.lang.invoke.MethodHandles;","+import java.util.Locale;","+","+import jakarta.validation.ConstraintValidator;","+import jakarta.validation.ConstraintValidatorContext;","+","+import org.hibernate.validator.constraints.Contains;","+import org.hibernate.validator.internal.util.logging.Log;","+import org.hibernate.validator.internal.util.logging.LoggerFactory;","+","+/**","+ * Checks that the character sequence contains the specified substrings.","+ *","+ * @author Sean Okafor","+ * @since 9.2","+ */","+public class ContainsValidator implements ConstraintValidator<Contains, CharSequence> {","+","+\tprivate static final Log LOG = LoggerFactory.make( MethodHandles.lookup() );","+","+\tprivate String[] values;","+\tprivate int minRequired;","+\tprivate boolean ignoreCase;","+","+\t@Override","+\tpublic void initialize(Contains parameters) {","+\t\tthis.ignoreCase = parameters.ignoreCase();","+","+\t\tString[] rawValues = parameters.value();","+\t\tif ( ignoreCase ) {","+\t\t\tthis.values = new String[rawValues.length];","+\t\t\tfor ( int i = 0; i < rawValues.length; i++ ) {","+\t\t\t\tthis.values[i] = rawValues[i].toLowerCase( Locale.ROOT );","+\t\t\t}","+\t\t}","+\t\telse {","+\t\t\tthis.values = rawValues;","+\t\t}","+","+\t\tint min = parameters.minRequired();","+\t\tthis.minRequired = ( min == Contains.MATCH_ALL ) ? values.length : min;","+\t\tvalidateParameters();","+\t}","+","+\t@Override","+\tpublic boolean isValid(CharSequence value, ConstraintValidatorContext constraintValidatorContext) {","+\t\tif ( value == null ) {","+\t\t\treturn true;","+\t\t}","+\t\tString str = ignoreCase ? value.toString().toLowerCase( Locale.ROOT ) : value.toString();","+\t\tint matchCount = 0;","+\t\tfor ( String v : values ) {","+\t\t\tif ( str.contains( v ) ) {","+\t\t\t\tmatchCount++;","+\t\t\t\tif ( matchCount >= minRequired ) {","+\t\t\t\t\treturn true;","+\t\t\t\t}","+\t\t\t}","+\t\t}","+\t\treturn matchCount >= minRequired;","+\t}","+","+\tprivate void validateParameters() {","+\t\tif ( minRequired < 0 ) {","+\t\t\tthrow LOG.getMinCannotBeNegativeException();","+\t\t}","+\t\tif ( minRequired > values.length ) {","+\t\t\tthrow LOG.getMinRequiredCannotExceedNumberOfValuesException( minRequired, values.length );","+\t\t}","+\t}","+}"],"additions":77,"deletions":0,"truncated":false},{"path":"engine/src/main/java/org/hibernate/validator/internal/metadata/core/BuiltinConstraint.java","lines":["@@ -52,6 +52,7 @@ enum BuiltinConstraint {"," "," \t// Hibernate Validator specific constraints"," \tORG_HIBERNATE_VALIDATOR_CONSTRAINTS_CODE_POINT_LENGTH( \"org.hibernate.validator.constraints.CodePointLength\" ),","+\tORG_HIBERNATE_VALIDATOR_CONSTRAINTS_CONTAINS( \"org.hibernate.validator.constraints.Contains\" ),"," \tORG_HIBERNATE_VALIDATOR_CONSTRAINTS_CURRENCY( \"org.hibernate.validator.constraints.