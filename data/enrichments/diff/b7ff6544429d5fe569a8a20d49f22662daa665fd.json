rovideVectorBackfiller constructs the embedding backfiller. Returns","-// (nil, nil) when the feature is disabled or any required dep is missing.","-// Callers must tolerate a nil result and treat it as \"feature off\".","-func ProvideVectorBackfiller(","-\tcfg *setting.Cfg,","-\tstorage resource.StorageBackend,","-\tvb vector.VectorBackend,","-\temb *embedder.Embedder,","-) (*VectorBackfiller, error) {","-\tif cfg == nil || !cfg.VectorBackfillerEnabled {","-\t\treturn nil, nil","-\t}","-\tif cfg.EmbeddingProvider == \"\" {","-\t\treturn nil, nil","-\t}","-\tif storage == nil || vb == nil || emb == nil {","-\t\treturn nil, nil","-\t}","-\treturn NewVectorBackfiller(Options{","-\t\tStorage:       storage,","-\t\tVectorBackend: vb,","-\t\tEmbedder:      emb,","-\t\tBatchEmbedder: embedder.NewBatchEmbedder(*emb),","-\t\tBuilders:      []embed.Builder{dashboard.New()},","-\t\tLog:           log.New(\"backfill\"),","-\t})","-}"],"additions":0,"deletions":39,"truncated":false},{"path":"pkg/storage/unified/search/embed/embedder/batch_embedder.go","lines":["@@ -86,3 +86,7 @@ func (b *BatchEmbedder) Embed("," \t}"," \treturn vectors, nil"," }","+","+func (b *BatchEmbedder) Model() string {","+\treturn b.embedder.Model","+}"],"additions":4,"deletions":0,"truncated":false},{"path":"pkg/storage/unified/search/embed/reconciler/fakes_test.go","lines":["@@ -0,0 +1,414 @@","+package reconciler","+","+import (","+\t\"context\"","+\t\"errors\"","+\t\"iter\"","+\t\"sync\"","+\t\"time\"","+","+\t\"github.com/grafana/grafana/pkg/storage/unified/resource\"","+\t\"github.com/grafana/grafana/pkg/storage/unified/resourcepb\"","+\t\"github.com/grafana/grafana/pkg/storage/unified/search/embed/embedder\"","+\t\"github.com/grafana/grafana/pkg/storage/unified/search/vector\"","+)","+","+// fakeStorage stubs the bits of resource.StorageBackend the reconciler uses.","+// ListModifiedSince returns the configured changes (filtered by sinceRv)","+// and a latestRv equal to the highest RV in the slice. Empty namespace","+// on the request runs cross-namespace, mirroring the real backends.","+type fakeStorage struct {","+\tmu       sync.Mutex","+\tchanges  []*resource.ModifiedResource","+\tlistErr  error","+\twatchErr error","+\twatchCh  chan *resource.WrittenEvent","+\titemErr  error // returned from the iterator partway through","+\titemErrI int   // index after which to inject itemErr","+}","+","+// emit synchronously delivers a watch event on the channel set up by","+// startWatch. Tests use it to drive the watch path.","+func (f *fakeStorage) emit(ev *resource.WrittenEvent) {","+\tf.mu.Lock()","+\tch := f.watchCh","+\tf.mu.Unlock()","+\tif ch == nil {","+\t\treturn","+\t}","+\tch <- ev","+}","+","+func (f *fakeStorage) WriteEvent(context.Context, resource.WriteEvent) (int64, error) {","+\tpanic(\"not implemented\")","+}","+func (f *fakeStorage) ReadResource(context.Context, *resourcepb.ReadRequest) *resource.BackendReadResponse {","+\tpanic(\"not implemented\")","+}","+func (f *fakeStorage) ListIterator(context.Context, *resourcepb.ListRequest, func(resource.ListIterator) error) (int64, error) {","+\tpanic(\"not implemented\")","+}","+func (f *fakeStorage) ListHistory(context.Context, *resourcepb.ListRequest, func(resource.ListIterator) error) (int64, error) {","+\tpanic(\"not implemented\")","+}","+","+// WatchWriteEvents returns a channel the test can push events onto via","+// emit(). Closing happens when the parent ctx ends (handled by the test","+// harness). Tests that need watch errors set watchErr.","+func (f *fakeStorage) WatchWriteEvents(ctx context.Context) (<-chan *resource.WrittenEvent, error) {","+\tf.mu.Lock()","+\tdefer f.mu.Unlock()","+\tif f.watchErr != nil {","+\t\treturn nil, f.watchErr","+\t}","+\tif f.watchCh == nil {","+\t\tf.watchCh = make(chan *resource.WrittenEvent, 16)","+\t}","+\treturn f.watchCh, nil","+}","+","+// GetResourceStats returns one ResourceStats per distinct","+// (namespace, group, resource) seen in `changes`. Used elsewhere in","+// the codebase; the reconciler doesn't call it directly post-refactor.","+func (f *fakeStorage) GetResourceStats(_ context.Context, nsr resource.NamespacedResource, _ int) ([]resource.ResourceStats, error) {","+\tf.mu.Lock()","+\tdefer f.mu.Unlock()","+\tseen := map[string]resource.ResourceStats{}","+\tfor _, c := range f.changes {","+\t\tif c.Key.Group != nsr.Group || c.Key.Resource != nsr.Resource {","+\t\t\tcontinue","+\t\t}","+\t\tk := c.Key.Namespace","+\t\ts, ok := seen[k]","+\t\tif !ok {","+\t\t\ts = resource.ResourceStats{","+\t\t\t\tNamespacedResource: resource.NamespacedResource{","+\t\t\t\t\tNamespace: c.Key.Namespace,","+\t\t\t\t\tGroup:     c.Key.Group,","+\t\t\t\t\tResource:  c.Key.Resource,","+\t\t\t\t},","+\t\t\t}","+\t\t}","+\t\ts.Count++","+\t\tif c.ResourceVersion > s.ResourceVersion {","+\t\t\ts.ResourceVersion = c.ResourceVersion","+\t\t}","+\t\tseen[k] = s","+\t}","+\tout := make([]resource.ResourceStats, 0, len(seen))","+\tfor _, s := range seen {","+\t\tout = append(out, s)","+\t}","+\treturn out, nil","+}","+func (f *fakeStorage) GetResourceLastImportTimes(context.Context) iter.Seq2[resource.ResourceLastImportTime, error] {","+\tpanic(\"not implemented\")","+}","+","+func (f *fakeStorage) ListModifiedSince(_ context.Context, key resource.NamespacedResource, sinceRv int64, _ *time.Time) (int64, iter.Seq2[*resource.ModifiedResource, error]) {","+\tf.mu.Lock()","+\tdefer f.mu.Unlock()","+\tif f.listErr != nil {","+\t\terr := f.listErr","+\t\treturn 0, func(yield func(*resource.ModifiedResource, error) bool) {","+\t\t\tyield(nil, err)","+\t\t}","+\t}","+\t// Snapshot the slice + per-iteration error config so the iterator","+\t// closes over a stable view. The reconciler runs the iter outside the","+\t// lock, and the test may mutate state afterwards. Empty namespace","+\t// runs cross-namespace, mirroring the real backends.","+\tmatches := make([]*resource.ModifiedResource, 0, len(f.changes))","+\tvar latestRv int64","+\tfor _, c := range f.changes {","+\t\tif c.Key.Group != key.Group || c.Key.Resource != key.Resource {","+\t\t\tcontinue","+\t\t}","+\t\tif key.Namespace != \"\" && c.Key.Namespace != key.Namespace {","+\t\t\tcontinue","+\t\t}","+\t\tif c.ResourceVersion <= sinceRv {","+\t\t\tcontinue","+\t\t}","+\t\tmatches = append(matches, c)","+\t\tif c.ResourceVersion > latestRv {","+\t\t\tlatestRv = c.ResourceVersion","+\t\t}","+\t}","+\titemErr := f.itemErr","+\titemErrI := f.itemErrI","+\treturn latestRv, func(yield func(*resource.ModifiedResource, error) bool) {","+\t\tfor i, c := range matches {","+\t\t\tif itemErr != nil && i == itemErrI {","+\t\t\t\tif !yield(nil, itemErr) {","+\t\t\t\t\treturn","+\t\t\t\t}","+\t\t\t\tcontinue","+\t\t\t}","+\t\t\tif !yield(c, nil) {","+\t\t\t\treturn","+\t\t\t}","+\t\t}","+\t}","+}","+","+// fakeVector records calls and lets tests inspect upserts/deletes/checkpoint advancement.","+type fakeVector struct {","+\tmu sync.Mutex","+","+\tlatestRV    int64","+\tupserts     [][]vector.Vector","+\tdeletes     []deleteCall","+\tdelsubs     []deleteSubsCall","+\tstoredSubs  map[string]map[string]string // ns|model|res|uid -> sub -> content","+\tupsertErr   error","+\tupsertErrFn func(vs []vector.Vector) error // dynamic error decision","+\tdeleteErr   error","+","+\tlockUnavailable bool","+\tlockAttempts    int","+\tlockReleases    int","+","+\tsetLatestRVCalls int","+\tsetLatestRVErr   error","+\tgetLatestRVErr   error","+}","+","+type deleteCall struct{ Namespace, Model, Resource, UID string }","+type deleteSubsCall struct {","+\tNamespace, Model, Resource, UID string","+\tSubresources                    []string","+}","+","+func newFakeVector() *fakeVector {","+\treturn &fakeVector{storedSubs: map[string]map[string]string{}}","+}","+","+func subsKey(ns, model, res, uid string) string { return ns + \"|\" + model + \"|\" + res + \"|\" + uid }","+","+func (f *fakeVector) Search(context.Context, string, string, string, []float32, int, ...vector.SearchFilter) ([]vector.VectorSearchResult, error) {","+\treturn nil, nil","+}","+func (f *fakeVector) Upsert(_ context.Context, vs []vector.Vector) error {","+\tf.mu.Lock()","+\tdefer f.mu.Unlock()","+\treturn f.upsertLocked(vs)","+}","+","+func (f *fakeVector) UpsertReplaceSubresources(_ context.Context, vs []vector.Vector) error {","+\tf.mu.Lock()","+\tdefer f.mu.Unlock()","+\t// Atomic stale-removal + upsert: stage the delete-stale step, then","+\t// the upsert. Failure on either rolls back via the lock-protected","+\t// snapshot.","+\ttype uidKey struct{ ns, model, res, uid string }","+\tgroups := map[uidKey]map[string]struct{}{}","+\tfor _, v := range vs {","+\t\tk := uidKey{v.Namespace, v.Model, v.Resource, v.UID}","+\t\tif groups[k] == nil {","+\t\t\tgroups[k] = map[string]struct{}{}","+\t\t}","+\t\tgroups[k][v.Subresource] = struct{}{}","+\t}","+\tfor k, keep := range groups {","+\t\tkey := subsKey(k.ns, k.model, k.res, k.uid)","+\t\tstored := f.storedSubs[key]","+\t\tvar stale []string","+\t\tfor sub := range stored {","+\t\t\tif _, ok := keep[sub]; !ok {","+\t\t\t\tstale = append(stale, sub)","+\t\t\t}","+\t\t}","+\t\tif len(stale) > 0 {","+\t\t\tf.delsubs = append(f.delsubs, deleteSubsCall{k.ns, k.model, k.res, k.uid, stale})","+\t\t\tfor _, s := range stale {","+\t\t\t\tdelete(stored, s)","+\t\t\t}","+\t\t}","+\t}","+\treturn f.upsertLocked(vs)","+}","+","+func (f *fakeVector) upsertLocked(vs []vector.Vector) error {","+\tif f.upsertErrFn != nil {","+\t\tif err := f.upsertErrFn(vs); err != nil {","+\t\t\treturn err","+\t\t}","+\t}","+\tif f.upsertErr != nil {","+\t\treturn f.upsertErr","+\t}","+\tf.upserts = append(f.upserts, vs)","+\tfor _, v := range vs {","+\t\tk := subsKey(v.Namespace, v.Model, v.Resource, v.UID)","+\t\tif f.storedSubs[k] == nil {","+\t\t\tf.storedSubs[k] = map[string]string{}","+\t\t}","+\t\tf.storedSubs[k][v.Subresource] = v.Content","+\t}","+\treturn nil","+}","+func (f *fakeVector) Delete(_ context.Context, ns, model, res, uid string) error 