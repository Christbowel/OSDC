{"id":"c90564f584a4b81f7f0ace4314dbaa85d2a7605d","axis":"silent","repo":"mongodb/mongo","sha":"c90564f584a4b81f7f0ace4314dbaa85d2a7605d","parsed":{"files":[{"path":"buildscripts/idl/generate_ifr_registry.py","lines":["@@ -2,7 +2,7 @@"," \"\"\"Generate src/mongo/db/ifr_flag_registry.yml from the feature flags in IDL files."," "," The IFR flag registry lists every feature flag declared with","-incremental_rollout_phase 'rollout' or 'released' across all IDL files under src/.","+incremental_rollout_phase 'rollout' or 'release' across all IDL files under src/."," It is fully derived from the IDL."," "," The registry's purpose is to give GitHub's CODEOWNERS mechanism a concrete","@@ -26,7 +26,7 @@","     #","     # This file is regenerated by buildscripts/idl/generate_ifr_registry.py.","     # It lists every feature flag declared with incremental_rollout_phase","-    # 'rollout' or 'released' across the IDL sources under src/. Just commit","+    # 'rollout' or 'release' across the IDL sources under src/. Just commit","     # whatever your script invocation produces — there is no manual step.","     #","     # Why this file exists","@@ -52,7 +52,7 @@","     # as on-by-default while still allowing it to be toggled at runtime, so","     # operators can disable it without a server restart if something goes wrong.","     #   - 'rollout':  actively being rolled out; on by default, kill-switchable.","-    #   - 'released': rollout complete; retained here as a historical record.","+    #   - 'release': rollout complete; retained here as a historical record."," \"\"\")"," "," ","@@ -65,7 +65,7 @@ def _iter_idl_files(source_root):"," "," "," def _extract_phase_flags(idl_path):","-    \"\"\"Return (rollout_flags, released_flags) declared in one IDL file.","+    \"\"\"Return (rollout_flags, release_flags) declared in one IDL file."," ","     IDL files are YAML, so we can read them directly with yaml.safe_load — no need","     to bring in the full IDL parser just to look at feature_flags entries.","@@ -76,38 +76,38 @@ def _extract_phase_flags(idl_path):","         return set(), set()","     feature_flags = doc.get(\"feature_flags\") or {}","     rollout = set()","-    released = set()","+    release = set()","     for flag_name, flag_body in feature_flags.items():","         if not isinstance(flag_body, dict):","             continue","         phase = flag_body.get(\"incremental_rollout_phase\")","         if phase == \"rollout\":","             rollout.add(flag_name)","-        elif phase == \"released\":","-            released.add(flag_name)","-    return rollout, released","+        elif phase == \"release\":","+            release.add(flag_name)","+    return rollout, release"," "," "," def collect_flags(source_root):","-    \"\"\"Walk source_root and return (rollout_flags, released_flags) across all IDLs.\"\"\"","+    \"\"\"Walk source_root and return (rollout_flags, release_flags) across all IDLs.\"\"\"","     rollout = set()","-    released = set()","+    release = set()","     for idl_path in _iter_idl_files(source_root):","         r, rel = _extract_phase_flags(idl_path)","         rollout |= r","-        released |= rel","-    overlap = rollout & released","+        release |= rel","+    overlap = rollout & release","     if overlap:","         # TODO SERVER-126893 This shouldn't be possible, and we should delete","         # this code and the corresponding test case.","         raise ValueError(","-            f\"Feature flag(s) declared in both 'rollout' and 'released' phases \"","+            f\"Feature flag(s) declared in both 'rollout' and 'release' phases \"","             f\"across IDL files: {sorted(overlap)}. A flag can only be in one phase.\"","         )","-    return rollout, released","+    return rollout, release"," "," ","-def render_registry(rollout_flags, released_flags):","+def render_registry(rollout_flags, release_flags):","     \"\"\"Render the registry file contents. Deterministic given the inputs.\"\"\""," ","     def section(name, flags):","@@ -124,7 +124,7 @@ def section(name, flags):","         + \"\\n\"","         + section(\"rollout\", rollout_flags)","         + \"\\n\"","-        + section(\"released\", released_flags)","+        + section(\"release\", release_flags)","     )"," "," ","@@ -145,13 +145,13 @@ def main(argv=None):","     args = parser.parse_args(argv)"," ","     try:","-        rollout, released = collect_flags(args.source_root)","+        rollout, release = collect_flags(args.source_root)","     except ValueError as exc:","         sys.stderr.write(f\"{exc}\\n\")","         return 2"," ","     with open(args.output, \"w\", encoding=\"utf-8\") as f:","-        f.write(render_registry(rollout, released))","+        f.write(render_registry(rollout, release))","     return 0"," "," "],"additions":18,"deletions":18,"truncated":false},{"path":"buildscripts/idl/idl/ast.py","lines":["@@ -430,8 +430,8 @@ class FeatureFlagRolloutPhase(enum.Enum):","     IN_DEVELOPMENT = enum.auto()","     # Incremental rollout flag for feature that is ready to roll out; defaults to disabled.","     ROLLOUT = enum.auto()","-    # Incremental rollout flag for feature that is completely rolled out; defaults to enabled.","-    RELEASED = enum.auto()","+    # Incremental rollout flag for feature that is enabled by default.","+    RELEASE = enum.auto()"," ","     @classmethod","     def bind(cls, string_value):","@@ -442,7 +442,7 @@ def bind(cls, string_value):","             \"not_for_incremental_rollout\": cls.NOT_FOR_INCREMENTAL_ROLLOUT,","             \"in_development\": cls.IN_DEVELOPMENT,","             \"rollout\": cls.ROLLOUT,","-            \"released\": cls.RELEASED,","+            \"release\": cls.RELEASE,","         }","         return bindings.get(string_value, None)"," ","@@ -451,7 +451,7 @@ def __str__(self):","             FeatureFlagRolloutPhase.NOT_FOR_INCREMENTAL_ROLLOUT: \"not_for_incremental_rollout\",","             FeatureFlagRolloutPhase.IN_DEVELOPMENT: \"in