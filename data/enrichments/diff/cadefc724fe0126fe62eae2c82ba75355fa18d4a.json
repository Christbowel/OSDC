 for that type only."," #    and the following records that are expected to fail:"," #      rsa-bad: invalid sha1 fingerprint and good sha256 fingerprint"," #      rsa-sha{1,256}-bad: invalid fingerprints for that type only.","-#    The SSHFP records for the other key types (ed25519_openssh.prv)","-#      follow the same pattern.","-","-dnsfps='\\","-rsa IN SSHFP 1 1 99C79CC09F5F81069CC017CDF9552CFC94B3B929","-rsa IN SSHFP 1 2 E30D6B9EB7A4DE495324E4D5870B8220577993EA6AF417E8E4A4F1C5BF01A9B6","-rsa-sha1 IN SSHFP 1 1 99C79CC09F5F81069CC017CDF9552CFC94B3B929","-rsa-sha256 IN SSHFP 1 2 E30D6B9EB7A4DE495324E4D5870B8220577993EA6AF417E8E4A4F1C5BF01A9B6","-rsa-bad IN SSHFP 1 1 99C79CC09F5F81069CC017CDF9552CFC94B3B928","-rsa-bad IN SSHFP 1 2 E30D6B9EB7A4DE495324E4D5870B8220577993EA6AF417E8E4A4F1C5BF01A9B6","-rsa-sha1-bad IN SSHFP 1 1 99D79CC09F5F81069CC017CDF9552CFC94B3B929","-rsa-sha256-bad IN SSHFP 1 2 E30D6B9EB7A4DE495324E4D5870B8220577993EA6AF417E8E4A4F1C5BF01A9B5","-ed25519 IN SSHFP 4 1 8A8647A7567E202CE317E62606C799C53D4C121F","-ed25519 IN SSHFP 4 2 54A506FB849AAFB9F229CF78A94436C281EFCB4AE67C8A430E8C06AFCB5EE18F","-ed25519-sha1 IN SSHFP 4 1 8A8647A7567E202CE317E62606C799C53D4C121F","-ed25519-sha256 IN SSHFP 4 2 54A506FB849AAFB9F229CF78A94436C281EFCB4AE67C8A430E8C06AFCB5EE18F","-ed25519-bad IN SSHFP 4 1 8A8647A7567E202CE317E62606C799C53D4C121E","-ed25519-bad IN SSHFP 4 2 54A506FB849AAFB9F229CF78A94436C281EFCB4AE67C8A430E8C06AFCB5EE18F","-ed25519-sha1-bad IN SSHFP 4 1 8A8647A7567E202CE317E62606C799C53D4C121E","-ed25519-sha256-bad IN SSHFP 4 2 54A506FB849AAFB9F229CF78A94436C281EFCB4AE67C8A430E8C06AFCB5EE18E'","+#    The SSHFP records for the other key types follow the same pattern.","+#    The BIND-format zone file $OBJ/sshfp-connect.zone is created","+#      containing these records."," "," tid=\"sshfp connect\""," ","@@ -39,32 +22,55 @@ if [ -z \"${TEST_SSH_SSHFP_DOMAIN}\" ]; then"," \tskip \"TEST_SSH_SSHFP_DOMAIN not set.\""," fi"," ","+# Generate expected SSHFP zone file.  This can also be handy to import if","+# you're setting this up from scratch.","+for kt in `$SSH -Q key-plain | grep -v sk- | \\","+    egrep '^(ssh-rsa|ecdsa-sha2|ssh-ed25519)'`; do","+\tcase \"$kt\" in","+\tssh-rsa)\t\tdnsname=rsa ;;","+\tecdsa-sha2-nistp256)\tdnsname=ecdsa256 ;;","+\tecdsa-sha2-nistp384)\tdnsname=ecdsa384 ;;","+\tecdsa-sha2-nistp521)\tdnsname=ecdsa521 ;;","+\tssh-ed25519)\t\tdnsname=ed25519 ;;","+\t*)\t\t\tfatal \"unknown keytype $kt\" ;;","+\tesac","+\tfile=\"${dnsname}_openssh\"","+\t# Make good fingerprints","+\t$SSHKEYGEN -r ${dnsname} -f ${SRC}/${file}.pub","+\t$SSHKEYGEN -r ${dnsname}-sha1 -f ${SRC}/${file}.pub | awk '$5==\"1\"'","+\t$SSHKEYGEN -r ${dnsname}-sha256 -f ${SRC}/${file}.pub | awk '$5==\"2\"'","+\t# Make bad fingerprints.","+\t# For the name with both types we only want the sha1 to be bad.","+\t$SSHKEYGEN -r ${dnsname}-bad -f ${SRC}/${file}.pub | awk '$5==\"1\"' | tr f e","+\t$SSHKEYGEN -r ${dnsname}-bad -f ${SRC}/${file}.pub | awk '$5==\"2\"'","+\t$SSHKEYGEN -r ${dnsname}-sha1-bad -f ${SRC}/${file}.pub | awk '$5==\"1\"' | tr f e","+\t$SSHKEYGEN -r ${dnsname}-sha256-bad -f ${SRC}/${file}.pub | awk '$5==\"2\"' | tr f e","+done | sort -n -k4,5 > $OBJ/sshfp-connect.zone","+"," # Check that the required DNS entries exist."," # This also primes any DNS caches and resolvers.","-#","-# It uses here documents instead of the more obvious \"foo | while read\"","-# since the latter runs the loop inside a subshell and any variables set in it","-# vanish when the subshell does."," while read line; do"," \tname=`echo \"$line\" | awk '{print $1}'`","-\texpected=`echo \"$line\" | awk '{print $4\" \"$5\" \"$6}'`","+\texpected=`echo \"$line\" | awk '{print $4\" \"$5\" \"$6}' | tr a-z A-Z`"," \t# Ensure at least one result matches exactly"," \tmatched=no","+","+\t# This uses a here document instead of \"foo | while read\" since the","+\t# the latter runs the loop inside a subshell and any variables set","+\t# vanish when the subshell does."," \twhile read result; do"," \t\tif [ \"$result\" = \"$expected\" ]; then"," \t\t\tmatched=yes"," \t\tfi"," \tdone <<EOD"," `host -t sshfp \"${name}.${TEST_SSH_SSHFP_DOMAIN}\" | \\","-    awk '{print $5\" \"$6\" \"$7$8}'`","+    awk '{print $5\" \"$6\" \"$7$8}' | tr a-z A-Z`"," EOD"," \tif [ \"$matched\" = \"no\" ]; then","-\t\tfatal \"$name.${TEST_SSH_SSHFP_DOMAIN} does not match required\"","+\t\tfatal \"$name.${TEST_SSH_SSHFP_DOMAIN} SSHFP record does not match required\""," \tfi"," \ttrace \"verified sshfp record '$name' -> '$expected'\"","-done <<EOD","-$dnsfps","-EOD","+done <${OBJ}/sshfp-connect.zone"," verbose \"all required sshfp entries exist\""," "," # Zero out known hosts and key aliases to force use of SSHFP records.","@@ -100,10 +106,42 @@ if $SSH -Q key-plain | grep ssh-rsa >/dev/null; then"," "," \t\ttrace \"sshfp connect $n bad fingerprint\""," \t\thost=\"${n}-bad.${TEST_SSH_SSHFP_DOMAIN}\"","-\t\tif ${SSH} $opts ${host} true 2>/dev/null; then","+\t\tif ${SSH} $opts $algs ${host} true 2>/dev/null; then","+\t\t\tfail \"sshfp-connect succeeded with bad SSHFP record\"","+\t\tfi","+\tdone","+fi","+","+if $SSH -Q key-plain | grep ecdsa-sha2-nistp >/dev/null; then","+    for b in 256 384 521; do","+\tverbose \"connect sshfp ecdsa${b}\"","+","+\t# Set ecdsa host key to match fingerprints above.","+\tmv $OBJ/sshd_proxy $OBJ/sshd_proxy.orig","+\t$SUDO cp $SRC/ecdsa${b}_openssh.prv $OBJ/host.ecdsa-sha2-nistp${b}","+\t$SUDO chmod 600 $OBJ/host.ecdsa-sha2-nistp${b}","+\tsed -e \"s|$OBJ/ecdsa-sha2-nistp${b}|$OBJ/host.ecdsa-sha2-nistp${b}|\" \\","+\t    $OBJ/sshd_proxy.orig > $OBJ/sshd_proxy","+","+\tfor n in ecdsa${b} ecdsa${b}-sha1 ecdsa${b}-sha256; do","+\t\ttrace \"sshfp connect $n good fingerprint\"","+\t\talgs=\"$opts -oHostKeyAlgorithms=ecdsa-sha2-nistp${b}\"","+\t\thost=\"${n}.${TEST_SSH_SSHFP_DOMAIN}\"","+\t\tSSH_CONNECTION=`${SSH} $opts $algs $host 'echo $SSH_CONNECTION'`","+\t\tif [ $? -ne 0 ]; then","+\t\t\tfail \"ssh sshfp connect $n failed\"","+\t\tfi","+\t\tif [ \"$SSH_CONNECTION\" != \"UNKNOWN 65535 UNKNOWN 65535\" ]; then","+\t\t\tfail \"bad SSH_CONNECTION: $SSH_CONNECTION\"","+\t\tfi","+","+\t\ttrace \"sshfp connect $n bad fingerprint\"","+\t\thost=\"${n}-bad.${TEST_SSH_SSHFP_DOMAIN}\"","+\t\tif ${SSH} $opts $algs ${host} true 2>/dev/null; then"," \t\t\tfail \"sshfp-connect succeeded with bad SSHFP record\""," \t\tfi"," \tdone","+    done"," fi"," "," if $SSH -Q key-plain | grep ssh-ed25519 >/dev/null; then","@@ -130,7 +168,7 @@ if $SSH -Q key-plain | grep ssh-ed25519 >/dev/null; then"," "," \t\ttrace \"sshfp connect $n bad fingerprint\""," \t\thost=\"${n}-bad.${TEST_SSH_SSHFP_DOMAIN}\"","-\t\tif ${SSH} $opts ${host} true 2>/dev/null; then","+\t\tif ${SSH} $opts $algs ${host} true 2>/dev/null; then"," \t\t\tfail \"sshfp-connect succeeded with bad SSHFP record\""," \t\tfi"," \tdone",""],"additions":72,"deletions":34,"truncated":false}],"additions":105,"deletions":34,"truncated":false,"file_count":7},"error":null,"fetched_at":"2026-07-13T10:43:49.527909+00:00"}