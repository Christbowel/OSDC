{"id":"3ec27264267f3aeae8c3485cb9012441c2a88d12","axis":"silent","repo":"WordPress/wordpress-develop","sha":"3ec27264267f3aeae8c3485cb9012441c2a88d12","parsed":{"files":[{"path":"src/js/_enqueues/admin/common.js","lines":["@@ -2356,3 +2356,242 @@ $( function( $ ) {"," \t// Expose public methods."," \treturn pub;"," })();","+","+/**","+ * Validate the delete-and-reassign users form and surface an accessible","+ * error summary instead of disabling the submit button.","+ *","+ * Disabled buttons can't be discovered by assistive technology, so rather","+ * than blocking submission we let the form submit, intercept it when content","+ * decisions are still missing, and present a focusable error summary that","+ * lists how many decisions remain and links straight to each one.","+ *","+ * Shared by both the single-site (wp-admin/users.php) and multisite/network","+ * (confirm_delete_users() in wp-admin/includes/ms.php) deletion forms. The two","+ * differ in markup: single site has one content decision per user, multisite","+ * has one decision per site a user belongs to (several radio groups per","+ * fieldset), and their reassign dropdowns use different \"no selection\" values.","+ * The logic below works per radio group so it covers both.","+ *","+ * @since 7.1.0","+ */","+(function(){","+\tconst { _n, sprintf } = wp.i18n;","+\tconst usersForm = document.querySelector( '.delete-and-reassign-users-form' );","+","+\t// Check if the form exists and contains any radio buttons.","+\tif ( ! usersForm || ! usersForm.querySelector( 'input[type=\"radio\"]' ) ) {","+\t\treturn;","+\t}","+","+\tconst summaryId = 'delete-users-error-summary';","+","+\t/**","+\t * Whether a reassign dropdown has no user selected.","+\t *","+\t * The \"Select a user\" placeholder value differs between the forms: the","+\t * single-site dropdown uses an empty string, the multisite one uses the","+\t * wp_dropdown_users() default of '-1'.","+\t *","+\t * @param {HTMLSelectElement} select The reassign dropdown.","+\t * @return {boolean} True when no real user is selected.","+\t */","+\tfunction hasNoSelectedUser( select ) {","+\t\treturn '' === select.value || '-1' === select.value;","+\t}","+","+\t/**","+\t * Builds a human-readable label for a radio group's decision.","+\t *","+\t * Combines the fieldset legend (the user) with the site context that","+\t * precedes the group on multisite, so each summary entry is identifiable.","+\t *","+\t * @param {HTMLElement} group The radio group (<ul>) element.","+\t * @return {string} The composed label.","+\t */","+\tfunction getDecisionLabel( group ) {","+\t\tconst fieldset = group.closest( 'fieldset' );","+\t\tconst legend   = fieldset ? fieldset.querySelector( 'legend' ) : null;","+\t\tconst parts    = [];","+","+\t\tif ( legend ) {","+\t\t\tparts.push( legend.textContent.trim() );","+\t\t}","+","+\t\t// On multisite each radio group is preceded by a \"Site: …\" paragraph.","+\t\tconst previous = group.previousElementSibling;","+\t\tif ( previous && previous !== legend && previous.textContent.trim() ) {","+\t\t\tparts.push( previous.textContent.trim() );","+\t\t}","+","+\t\treturn parts.join( ' – ' );","+\t}","+","+\t// Keep the radio selection in sync with the reassign dropdown.","+\tusersForm.querySelectorAll( 'select' ).forEach( function( selectElement ) {","+\t\tselectElement.addEventListener( 'change', function( e ) {","+\t\t\tconst item  = e.target.closest( 'li' );","+\t\t\tconst radio = item ? item.querySelector( 'input[type=\"radio\"]' ) : null;","+\t\t\tif ( radio ) {","+\t\t\t\tradio.checked = ! hasNoSelectedUser( e.target );","+\t\t\t}","+\t\t});","+\t});","+","+\t/**","+\t * Returns the radio groups whose content decision is still incomplete.","+\t *","+\t * A decision unit is a single radio group (<ul>), which maps to one user on","+\t * single site and one site-per-user on multisite.","+\t *","+\t * @return {Array} Objects describing each incomplete decision.","+\t */","+\tfunction getIncompleteDecisions() {","+\t\tconst incomplete = [];","+","+\t\tusersForm.querySelectorAll( 'fieldset ul' ).forEach( function( group ) {","+\t\t\tconst radios = group.querySelectorAll( 'input[type=\"radio\"]' );","+\t\t\tif ( ! radios.length ) {","+\t\t\t\treturn;","+\t\t\t}","+","+\t\t\tconst checked = group.querySelector( 'input[type=\"radio\"]:checked' );","+","+\t\t\t// No option chosen yet.","+\t\t\tif ( ! checked ) {","+\t\t\t\tincomplete.push( { target: radios[ 0 ], label: getDecisionLabel( group ) } );","+\t\t\t\treturn;","+\t\t\t}","+","+\t\t\t// \"Attribute to another user\" chosen, but no user selected.","+\t\t\tif ( 'reassign' === checked.value ) {","+\t\t\t\tconst select = group.querySelector( 'select' );","+\t\t\t\tif ( select && hasNoSelectedUser( select ) ) {","+\t\t\t\t\tincomplete.push( { target: select, label: getDecisionLabel( group ) } );","+\t\t\t\t}","+\t\t\t}","+\t\t});","+","+\t\treturn incomplete;","+\t}","+","+\t/**","+\t * Builds or refreshes the error summary markup.","+\t *","+\t * @param {Array} incomplete Incomplete decisions from getIncompleteDecisions().","+\t * @return {string} The summary title, for announcing to assistive technology.","+\t */","+\tfunction renderErrorSummary( incomplete ) {","+\t\tlet summary = document.getElementById( summaryId );","+","+\t\tif ( ! summary ) {","+\t\t\tsummary = document.createElement( 'div' );","+\t\t\tsummary.id = summaryId;","+\t\t\tsummary.className = 'notice notice-error';","+\t\t\tsummary.setAttribute( 'tabindex', '-1' );","+","+\t\t\t// The wrapper contains the form on single site and wraps it on","+\t\t\t// multisite; insert the summary right after the page heading.","+\t\t\tconst wrap    = usersForm.querySelector( '.wrap' ) || usersForm.closest( '.wrap' ) || usersForm;","+\t\t\tconst heading = wrap.querySelector( 'h1' );","+\t\t\twrap.insertBefore( summary, heading ? heading.nextSibling : wrap.firstChild );","+\t\t}","+","+\t\tconst count = incomplete.length;","+\t\tconst title = sprintf(","+\t\t\t/* translators: %s: Number of content decisions still required. */","+\t\t\t_n(","+\t\t\t\t'%s content decision is still required before you can delete.',","+\t\t\t\t'%s content decisions are still required before you can delete.',","+\t\t\t\tcount","+\t\t\t),","+\t\t\tcount","+\t\t);","+","+\t\t// Clear any previous markup and invalid states before rebuilding,","+\t\t// so decisions resolved since the last render are no longer flagged.","+\t\tsummary.textContent = '';","+\t\tusersForm.querySelectorAll( '[aria-invalid]' ).forEach( function( el ) {","+\t\t\tel.removeAttribute( 'aria-invalid' );","+\t\t});","+","+\t\tconst titleEl = document.createElement( 'p' );","+\t\tconst strong  = document.createElement( 'strong' );","+\t\tstrong.textContent = title;","+\t\ttitleEl.appendChild( strong );","+\t\tsummary.appendChild( titleEl );","+","+\t\tconst list = document.createElement( 'ul' );","+\t\tincomplete.forEach( function( item ) {","+\t\t\tconst li   = document.createElement( 'li' );","+\t\t\tconst link = document.createElement( 'a' );","+\t\t\tlink.href        = '#' + item.target.id;","+\t\t\tlink.textContent = item.label;","+\t\t\tlink.addEventListener( 'click', function( e ) {","+\t\t\t\te.preventDefault();","+\t\t\t\titem.target.focus();","+\t\t\t});","+\t\t\tli.appendChild( link );","+\t\t\tlist.appendChild( li );","+","+\t\t\titem.target.setAttribute( 'aria-invalid', 'true' );","+\t\t});","+\t\tsummary.appendChild( list );","+","+\t\treturn title;","+\t}","+","+\t/**","+\t * Removes the error summary and clears invalid states.","+\t */","+\tfunction clearErrorState() {","+\t\tconst summary = document.getElementById( summaryId );","+\t\tif ( summary ) {","+\t\t\tsummary.remove();","+\t\t}","+\t\tusersForm.querySelectorAll( '[aria-invalid]' ).forEach( function( el ) {","+\t\t\tel.removeAttribute( 'aria-invalid' );","+\t\t});","+\t}","+","+\t/**","+\t * Refreshes the error summary to match the current form state.","+\t *","+\t * @param {boolean} moveFocus Whether to move focus to the summary and","+\t *                            announce it (used on a failed submit).","+\t * @return {number} The number of incomplete decisions.","+\t */","+\tfunction updateSummary( moveFocus ) {","+\t\tconst incomplete = getIncompleteDecisions();","+","+\t\tif ( ! incomplete.length ) {","+\t\t\tclearErrorState();","+\t\t\treturn 0;","+\t\t}","+","+\t\tconst title = renderErrorSummary( incomplete );","+","+\t\tif ( moveFocus ) {","+\t\t\tdocument.getElementById( summaryId ).focus();","+\t\t\tif ( window.wp && window.wp.a11y ) {","+\t\t\t\twindow.wp.a11y.speak( title, 'assertive' );","+\t\t\t}","+\t\t}","+","+\t\treturn incomplete.length;","+\t}","+","+\tusersForm.addEventListener( 'submit', function( e ) {","+\t\tif ( updateSummary( true ) > 0 ) {","+\t\t\te.preventDefault();","+\t\t}","+\t});","+","+\t// Keep an existing summary current as decisions are resolved, without","+\t// stealing focus on every interaction.","+\tusersForm.addEventListener( 'change', function() {","+\t\tif ( document.getElementById( summaryId ) ) {","+\t\t\tupdateSummary( false );","+\t\t}","+\t});","+})();"],"additions":239,"deletions":0,"truncated":false},{"path":"src/wp-admin/css/common.css","lines":["@@ -2605,6 +2605,23 @@ body.iframe {"," \tdisplay: block;"," }"," ","+.delete-and-reassign-users-form legend {","+\tmargin: 1em 0;","+\tline-height: 1.5;","+\tfloat: inline-start;","+}","+","+.delete-and-reassign-users-form fieldset > fieldset,","+.delete-and-reassign-users-form fieldset > ul {","+\tclear: both;","+}","+","+.delete-and-reassign-users-form fieldset:has(select[aria-invalid=\"true\"]):not(fieldset:has(fieldset)) {","+\tborder-left: 4px solid #cc1818;","+\tbackground: #fcf0f0;","+\tpadding-left: 12px;","+}","+"," .importers {"," \tfont-size: 16px;"," \twidth: auto;"],"additions":17,"deletions":0,"truncated":false},{"path":"src/wp-admin/includes/deprecated.php","lines":["@@ -1589,3 +1589,14 @@ function image_attachment_fields_to_save( $post, $attachment ) {"," 