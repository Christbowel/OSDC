.bin\"","+    f.write_text(\"hello\")","+    run.upload_file(str(f), root=str(tmp_path))","+","+    service_api.send_api_request.assert_not_called()","+","+"," @pytest.mark.parametrize(","     \"field,value,expected\",","     ["],"additions":45,"deletions":0,"truncated":false},{"path":"wandb/apis/public/runs.py","lines":["@@ -59,6 +59,7 @@"," from wandb.apis.public.const import RETRY_TIMEDELTA"," from wandb.apis.public.service_api import ServiceApi"," from wandb.proto import wandb_api_pb2 as apb","+from wandb.proto import wandb_internal_pb2 as pb"," from wandb.sdk import wandb_setup"," from wandb.sdk.lib import ipython, json_util"," from wandb.sdk.lib.paths import LogicalPath","@@ -1146,6 +1147,28 @@ def upload_file(self, path: str, root: str = \".\") -> public.File:","         upload_path = util.make_file_path_upload_safe(name)","         with open(os.path.join(root, name), \"rb\") as f:","             api.push({LogicalPath(upload_path): f})","+","+        # Uploading the bytes to the (presigned) destination URL doesn't notify"],"additions":3,"deletions":0,"truncated":false}],"additions":315,"deletions":357,"truncated":true,"file_count":12},"error":null,"fetched_at":"2026-07-02T10:21:30.510377+00:00"}