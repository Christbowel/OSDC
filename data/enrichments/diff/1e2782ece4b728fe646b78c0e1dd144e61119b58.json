dRef, patches };","+  }","+","   /**","    * Count commits HEAD is ahead/behind its upstream tracking ref.","    * Returns `hasUpstream: false` when the branch has no upstream configured"],"additions":159,"deletions":0,"truncated":false},{"path":"locales/en-US/chat.json","lines":["@@ -857,13 +857,21 @@","   \"workingPanel.resources.updatedAt\": \"Updated {{time}}\",","   \"workingPanel.resources.viewMode.list\": \"List view\",","   \"workingPanel.resources.viewMode.tree\": \"Tree view\",","+  \"workingPanel.review.baseRef.default\": \"default\",","+  \"workingPanel.review.baseRef.loading\": \"Loading branches…\",","+  \"workingPanel.review.baseRef.reset\": \"Reset to default branch\",","+  \"workingPanel.review.baseRef.unresolved\": \"Pick a base branch\",","   \"workingPanel.review.binary\": \"Binary file — diff not shown\",","   \"workingPanel.review.collapseAll\": \"Collapse all\",","   \"workingPanel.review.copied\": \"Path copied\",","   \"workingPanel.review.copyPath\": \"Copy file path\",","   \"workingPanel.review.empty\": \"No working tree changes\",","+  \"workingPanel.review.empty.branch\": \"No changes vs {{baseRef}}\",","+  \"workingPanel.review.empty.noBaseRef\": \"Couldn't determine the remote default branch. Run `git remote set-head origin --auto` in your terminal.\",","   \"workingPanel.review.error\": \"Couldn't load this file's diff\",","   \"workingPanel.review.expandAll\": \"Expand all\",","+  \"workingPanel.review.mode.branch\": \"Branch\",","+  \"workingPanel.review.mode.unstaged\": \"Unstaged\",","   \"workingPanel.review.more\": \"More options\",","   \"workingPanel.review.refresh\": \"Refresh\",","   \"workingPanel.review.textDiff.disable\": \"Disable inline text diff\","],"additions":8,"deletions":0,"truncated":false},{"path":"locales/zh-CN/chat.json","lines":["@@ -857,13 +857,21 @@","   \"workingPanel.resources.updatedAt\": \"更新于 {{time}}\",","   \"workingPanel.resources.viewMode.list\": \"列表视图\",","   \"workingPanel.resources.viewMode.tr