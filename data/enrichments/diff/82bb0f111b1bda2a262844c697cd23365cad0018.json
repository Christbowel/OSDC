query I nosort desc0","+SELECT finalize(quantile_disc(d, -0.25) EXPORT_STATE) FROM dummy;","+----","+","+# grouped","+query II nosort grouped0","+SELECT g, quantile_cont(d, 0.5) FROM dummy GROUP BY g ORDER BY g;","+----","+","+query II nosort grouped0","+SELECT g, finalize(quantile_cont(d, 0.5) EXPORT_STATE) FROM dummy GROUP BY g ORDER BY g;","+----","+","+# empty group","+query I nosort empty0","+SELECT quantile_disc(d, 0.5) FROM dummy WHERE FALSE;","+----","+","+query I nosort empty0","+SELECT finalize(quantile_disc(d, 0.5) EXPORT_STATE) FROM dummy WHERE FALSE;","+----","+","+# VARCHAR input","+query I nosort varchar0","+SELECT quantile_disc(d::VARCHAR, 0.5) FROM dummy;","+----","+","+query I nosort varchar0","+SELECT finalize(quantile_disc(d::VARCHAR, 0.5) EXPORT_STATE) FROM dummy;","+----","+","+# DECIMAL input","+query I nosort decimal0","+SELECT quantile_cont((d / 10)::DECIMAL(8, 3), 0.5) FROM dummy;","+----","+","+query I nosort decimal0","+SELECT finalize(quantile_cont((d / 10)::DECIMAL(8, 3), 0.5) EXPORT_STATE) FROM dummy;","+----","+","+# combining two states computes the quantile over the union of the values","+query I nosort combine0","+SELECT quantile_disc(d, 0.5) FROM dummy;","+----","+","+query I nosort combine0","+SELECT finalize(combine(","+\t(SELECT quantile_disc(d, 0.5) EXPORT_STATE FROM dummy WHERE d < 50),","+\t(SELECT quantile_disc(d, 0.5) EXPORT_STATE FROM dummy WHERE d >= 50)))","+----","+","+# combining a state with an empty state keeps the values","+query I nosort combine1","+SELECT quantile_disc(d, 0.5) FROM dummy WHERE d < 50;","+----","+","+query I nosort combine1","+SELECT finalize(combine(","+\t(SELECT quantile_disc(d, 0.5) EXPORT_STATE FROM dummy WHERE d < 50),","+\t(SELECT quantile_disc(d, 0.5) EXPORT_STATE FROM dummy WHERE FALSE)))","+----","+","+# combining two states with different quantiles is an error","+statement error","+SELECT finalize(combine(","+\t(SELECT quantile_disc(d, 0.5) EXPORT_STATE FROM dummy WHERE d < 50),","+\t(SELECT quantile_disc(d, 0.25) EXPORT_STATE FROM dummy WHERE d >= 50)))","+----","+different parameters","+","+# nested types fall back to sort-key states - exercise the sort-key list export/import","+","+# quantile_disc over a STRUCT (scalar)","+query I nosort struct0","+SELECT quantile_disc({'a': d, 'b': d::VARCHAR}, 0.5) FROM dummy;","+----","+","+query I nosort struct0","+SELECT finalize(quantile_disc({'a': d, 'b': d::VARCHAR}, 0.5) EXPORT_STATE) FROM dummy;","+----","+","+# quantile_disc over a STRUCT (list of quantiles)","+query I nosort structlist0","+SELECT quantile_disc({'a': d, 'b': d::VARCHAR}, [0.25, 0.5, 0.75]) FROM dummy;","+----","+","+query I nosort structlist0","+SELECT finalize(quantile_disc({'a': d, 'b': d::VARCHAR}, [0.25, 0.5, 0.75]) EXPORT_STATE) FROM dummy;","+----","+","+# median over a nested LIST","+query I nosort medianstruct0","+SELECT median([d, d + 1]) FROM dummy;","+----","+","+query I nosort medianstruct0","+SELECT finalize(median([d, d + 1]) EXPORT_STATE) FROM dummy;","+----","+","+# grouped fallback","+query II nosort structgrouped0","+SELECT g, quantile_disc({'a': d}, 0.5) FROM dummy GROUP BY g ORDER BY g;","+----","+","+query II nosort structgrouped0","+SELECT g, finalize(quantile_disc({'a': d}, 0.5) EXPORT_STATE) FROM dummy GROUP BY g ORDER BY g;","+----","+","+# combining two fallback states computes the quantile over the union of the values","+query I nosort structcombine0","+SELECT quantile_disc({'a': d}, 0.5) FROM dummy;","+----","+","+query I nosort structcombine0","+SELECT finalize(combine(","+\t(SELECT quantile_disc({'a': d}, 0.5) EXPORT_STATE FROM dummy WHERE d < 50),","+\t(SELECT quantile_disc({'a': d}, 0.5) EXPORT_STATE FROM dummy WHERE d >= 50)))","+----","+","+# a fallback list larger than a standard vector exercises the chunked sort-key transform","+statement ok","+create table big as select range r, {'a': range} s from range(5000);","+","+query I nosort big0","+SELECT quantile_disc(s, [0.1, 0.5, 0.9]) FROM big;","+----","+","+query I nosort big0"],"additions":184,"deletions":0,"truncated":false}],"additions":378,"deletions":44,"truncated":true,"file_count":10},"error":null,"fetched_at":"2026-06-16T12:32:49.364052+00:00"}