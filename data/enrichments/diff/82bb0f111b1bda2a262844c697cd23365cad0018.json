le parameter (e.g. 0.5 or [0.25, 0.75]) from the bind data, so that it can be recorded","+//! in the AGGREGATE_STATE type - param_type is the declared type of the (erased) parameter argument","+inline Value QuantileParameterValue(const QuantileBindData &bind_data, const LogicalType &param_type) {","+\tvector<Value> quantiles;","+\tfor (auto &q : bind_data.quantiles) {","+\t\t// the bind data holds the normalized (absolute) quantiles - restore the sign of descending quantiles","+\t\tquantiles.push_back(bind_data.desc ? QuantileNeg(q.val) : q.val);","+\t}","+\tif (param_type.id() != LogicalTypeId::LIST && param_type.id() != LogicalTypeId::ARRAY) {","+\t\tD_ASSERT(quantiles.size() == 1);","+\t\treturn quantiles[0];","+\t}","+\tif (quantiles.empty()) {","+\t\treturn Value::LIST(LogicalType::DOUBLE, std::move(quantiles));","+\t}","+\tauto child_type = quantiles[0].type();","+\treturn Value::LIST(child_type, std::move(quantiles));","+}","+","+template <class STATE, class STATE_FIELD = StateListType<StateInputType<0>>>","+AggregateStateLayout QuantileStateLayout(AggregateLayoutInput &input) {","+\tauto &function = input.function;","+\tAggregateStateLayout layout;","+\tif (function.GetReturnType().IsAggregateState()) {","+\t\t// the function has been modified for state export (see ExportAggregateFunction::SetStateExport) -","+\t\t// its return type IS the state type already","+\t\tlayout.type = function.GetReturnType();","+\t} else {","+\t\tlayout.type = LogicalType::LIST(function.GetArguments()[0]);","+\t}","+\tlayout.total_state_size = AlignValue<idx_t>(sizeof(STATE));","+\tlayout.field = BuildStateField<STATE_FIELD>();","+\tAggregateStateField::PopulateListFunctions(layout.type, layout.field);","+\tif (function.GetOriginalArguments().size() == 2) {","+\t\t// the quantile parameter must be a constant at bind time (its argument is erased by BindQuantile) -","+\t\t// record its value so that re-binding the exported state can supply it","+\t\t// median and mad have no parame