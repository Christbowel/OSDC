deletions":4,"truncated":false},{"path":"test/configs/verify_aggregate_state_export.json","lines":["@@ -17,7 +17,7 @@","       ]","     },","     {","-      \"reason\": \"FIXME: aggregate functions with custom destructors cannot be exported (approx_top_k, arg_min/arg_max(N), bitstring_agg, histograms, mad, median, mode, quantiles, etc.)\",","+      \"reason\": \"FIXME: aggregate states that own memory cannot be exported and have no state type callback (approx_top_k, arg_min/arg_max(N), min/max(N), bitstring_agg, bit_and/or/xor over BIT, histograms, mode, reservoir_quantile, approx_quantile, etc.)\",","       \"paths\": [","         \"test/fuzzer/duckfuzz/bitstring_agg_minmax.test\",","         \"test/fuzzer/duckfuzz/bitstring_agg_uhugeint.test\",","@@ -26,9 +26,7 @@","         \"test/fuzzer/pedro/first_value_window_crash.test\",","         \"test/fuzzer/pedro/non_boolean_aggregate_filter.test\",","         \"test/fuzzer/sqlsmith/bitstring_agg_overflow.test\",","-        \"test/fuzzer/sqlsmith/mad_overflow.test\",","         \"test/issues/general/test_5072.test\",","-        \"test/optimizer/ordered_aggregate.test\",","         \"test/sql/aggregate/aggregates/approx_top_k.test\",","         \"test/sql/aggregate/aggregates/arg_min_max_n.test\",","         \"test/sql/aggregate/aggregates/arg_min_max_n_tpch.test\",","@@ -47,15 +45,8 @@","         \"test/sql/aggregate/aggregates/test_entropy.test\",","         \"test/sql/aggregate/aggregates/test_histogram.test\",","         \"test/sql/aggregate/aggregates/test_histogram_3529.test\",","-        \"test/sql/aggregate/aggregates/test_mad.test\",","-        \"test/sql/aggregate/aggregates/test_median.test\",","         \"test/sql/aggregate/aggregates/test_mode.test\",","         \"test/sql/aggregate/aggregates/test_ordered_aggregates.test\",","-        \"test/sql/aggregate/aggregates/test_quantile_cont.test\",","-        \"test/sql/aggregate/aggregates/test_quantile_cont_list.test\",","-        \"test/sql/aggregate/aggregate