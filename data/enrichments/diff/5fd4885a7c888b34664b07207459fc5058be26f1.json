er/sandbox/Dockerfile.base","lines":["@@ -53,7 +53,7 @@ RUN apt-get update && apt-get install -y --no-install-recommends \\"," "," # Create supervisor and sandbox users/groups"," RUN groupadd -r supervisor && useradd -r -g supervisor -s /usr/sbin/nologin supervisor && \\","-    groupadd -r sandbox && useradd -r -g sandbox -s /usr/sbin/nologin sandbox","+    groupadd -r sandbox && useradd -r -g sandbox -d /sandbox -s /bin/bash sandbox"," "," # Stage 3: Python dependencies builder"," FROM base AS builder","@@ -142,6 +142,14 @@ RUN mkdir -p /var/navigator /sandbox /var/log && \\","     chown supervisor:supervisor /var/log/navigator.log && \\","     chmod 0664 /var/log/navigator.log && \\","     chown sandbox:sandbox /sandbox && \\","+    # Minimal shell init files so interactive and non-interactive shells","+    # get a sane PATH and prompt.  Without these, bash sources nothing","+    # under /sandbox and tools like VS Code Remote-SSH may mis-detect","+    # the platform.","+    printf 'export PATH=\"/app/.venv/bin:$PATH\"\\nexport PS1=\"\\\\u@\\\\h:\\\\w\\\\$ \"\\n' \\","+        > /sandbox/.bashrc && \\","+    printf '[ -f ~/.bashrc ] && . ~/.bashrc\\n' > /sandbox/.profile && \\","+    chown sandbox:sandbox /sandbox/.bashrc /sandbox/.profile && \\","     # Install agent skills into the sandbox user's home directory","     # so Claude and other agents can discover them at runtime.","     # Sources: ai-pim-utils (.deb) and custom navigator skills."],"additions":9,"deletions":1,"truncated":false},{"path":"dev-sandbox-policy.rego","lines":["@@ -120,12 +120,10 @@ binary_allowed(policy, exec) if {"," "," # Binary matching: glob pattern against path, any ancestor, or any cmdline path."," binary_allowed(policy, exec) if {","-\tsome b","-\tb := policy.binaries[_]","+\tsome b in policy.binaries"," \tcontains(b.path, \"*\")"," \tall_paths := array.concat(array.concat([exec.path], exec.ancestors), exec.cmdline_paths)","-\tsome p","-\tp := all_paths[_]","+\tsome p in all_paths"," \tglob.match(b.path, [\"/\"], p)"," }"," "],"additions":2,"deletions":4,"truncated":false},{"path":"dev-sandbox-policy.yaml","lines":["@@ -132,6 +132,20 @@ network_policies:","       - { path: /usr/local/bin/claude }","       - { path: /usr/bin/gh }"," ","+  vscode:","+    name: vscode","+    endpoints:","+      - { host: update.code.visualstudio.com, port: 443 }","+      - { host: \"*.vo.msecnd.net\", port: 443 }","+      - { host: vscode.download.prss.microsoft.com, port: 443 }","+      - { host: marketplace.visualstudio.com, port: 443 }","+      - { host: \"*.gallerycdn.vsassets.io\", port: 443 }","+    binaries:","+      - { path: /usr/bin/curl }","+      - { path: /usr/bin/wget }","+      - { path: \"/sandbox/.vscode-server/**\" }","+      - { path: \"/sandbox/.vscode-remote-containers/**\" }","+"," inference:","   allowed_routes:","     - local"],"additions":14,"deletions":0,"truncated":false},{"path":"examples/vscode-remote-sandbox.md","lines":["@@ -0,0 +1,64 @@","+# Open VSCode in a Sandbox","+","+Connect VSCode to a running sandbox using the","+[Remote - SSH](https://marketplace.visualstudio.com/items?itemName=ms-vscode-remote.remote-ssh)","+extension so you get a full IDE experience inside the sandbox environment.","+","+## Prerequisites","+","+- A running navigator cluster (`navigator cluster admin deploy`)","+- [VSCode](https://code.visualstudio.com/) with the","+  [Remote - SSH](https://marketplace.visualstudio.com/items?itemName=ms-vscode-remote.remote-ssh)","+  extension installed","+- The `navigator` CLI on your `PATH`","+","+## Quick start","+","+### 1. Create a sandbox","+","+```bash","+navigator sandbox create --keep --name my-sandbox","+```","+","+`--keep` prevents the sandbox from being cleaned up when the shell exits so","+VSCode can reconnect to it later.","+","+### 2. Generate an SSH config entry","+","+```bash","+navigator sandbox ssh-config my-sandbox >> ~/.ssh/config","+```","+","+This will append a block like:","+","+```text","+Host nav-my-sandbox","+    User sandbox","+    StrictHostKeyChecking no","+    UserKnownHostsFile /dev/null","+    GlobalKnownHostsFile /dev/null","+    LogLevel ERROR","+    ProxyCommand navigator ssh-proxy --cluster <cluster-name> --name my-sandbox","+```","+","+### 3. Open VSCode","+","+Open VSCode and run **Remote-SSH: Connect to Host...** from the command","+palette (`Cmd+Shift+P` / `Ctrl+Shift+P`). Select `nav-my-sandbox` from the","+list. VSCode will open a remote window connected to the sandbox.","+","+Alternatively, from the terminal:","+","+```bash","+code --remote ssh-remote+nav-my-sandbox /sandbox","+```","+","+### 4. Clean up","+","+When you are done, delete the sandbox:","+","+```bash","+navigator sandbox delete my-sandbox","+```","+","+This also removes any active port forwards.",""],"additions":64,"deletions":0,"truncated":false}],"additions":336,"deletions":142,"truncated":false,"file_count":8},"error":null,"fetched_at":"2026-05-20T17:38:07.824380+00:00"}