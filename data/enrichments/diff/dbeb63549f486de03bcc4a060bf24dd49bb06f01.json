{"id":"dbeb63549f486de03bcc4a060bf24dd49bb06f01","axis":"silent","repo":"mongodb/mongo","sha":"dbeb63549f486de03bcc4a060bf24dd49bb06f01","parsed":{"files":[{"path":"bazel/config/BUILD.bazel","lines":["@@ -1411,6 +1411,33 @@ selects.config_setting_group(","     ],"," )"," ","+# --------------------------------------","+# connection handoff options","+# --------------------------------------","+","+# s2n-tls, on which we depend, supports Linux and Darwin, but we are targeting Linux only.","+# Additionally, restrict the compatible targets to Amazon Linux 2023, since there are linkage issues","+# related to the version of OpenSSL used by s2n-tls versus deployed to production machines on some","+# other build variants. See, for example, BF-44238.","+# We also include Ubuntu targets for compatibility with typical developer workstations.","+selects.config_setting_group(","+    name = \"build_connection_handoff_distros\",","+    match_any = [","+        \"//bazel/platforms:amazon_linux_2023\",","+        \"//bazel/platforms:amazon_linux_2023_3\",","+        \"//bazel/platforms:ubuntu22\",","+        \"//bazel/platforms:ubuntu24\",","+    ],","+)","+","+selects.config_setting_group(","+    name = \"build_connection_handoff_enabled\",","+    match_all = [","+        \":build_connection_handoff_distros\",","+        \":linux_aarch64_or_x86_64\",","+    ],","+)","+"," # --------------------------------------"," # linkstatic options"," # --------------------------------------"],"additions":27,"deletions":0,"truncated":false},{"path":"jstests/noPassthrough/network/proxy_unix_socket_maximum_header_size.js","lines":["@@ -160,7 +160,7 @@ function runTestSuite(conn, prefix) {"," }"," "," {","-    const prefix = `${MongoRunner.dataPath}${jsTestName()}_mongod`;","+    const prefix = `${MongoRunner.dataPath}_mongod`;","     mkdir(prefix);","     const mongod = MongoRunner.runMongod({","         proxyUnixSocketPrefix: prefix,","@@ -171,7 +171,7 @@ function runTestSuite(conn, prefix) {","