","+\t}","+\tthrow BinderException(\"Unrecognized prefetch_strategy '%s' (supported: 'auto', 'whole_group')\", value);","+}","+","+static idx_t ParquetColumnChunkFileOffset(const duckdb_parquet::ColumnChunk &chunk) {","+\tidx_t offset = NumericCast<idx_t>(chunk.meta_data.data_page_offset);","+\tif (chunk.meta_data.__isset.dictionary_page_offset) {","+\t\toffset = MinValue<idx_t>(offset, NumericCast<idx_t>(chunk.meta_data.dictionary_page_offset));","+\t}","+\tif (chunk.meta_data.__isset.index_page_offset) {","+\t\toffset = MinValue<idx_t>(offset, NumericCast<idx_t>(chunk.meta_data.index_page_offset));","+\t}","+\treturn offset;","+}","+","+void ParquetLoggerPrefetchMetrics::GeneratePrefetchGroup(ThriftFileTransport &trans,","+                                                         vector<ParquetPrefetchColumn> &requested_columns,","+                                                         const vector<duckdb_parquet::ColumnChunk> &all_chunks) {","+\tif (requested_columns.empty()) {","+\t\treturn;","+\t}","+","+\t// Let's use ReadHead to bucket registrations so we are use we are getting whatever the ThriftFileTransport does","+\tvector<reference<ReadHead>> bucket_order;","+\treference_map_t<ReadHead, vector<ParquetPrefetchColumn>> buckets;","+\tset<idx_t> registered_offsets;","+\tfor (auto &requested_column : requested_columns) {","+\t\tregistered_offsets.insert(requested_column.offset);","+\t\tauto rh_ptr = trans.GetReadHead(requested_column.offset);","+\t\tif (!rh_ptr) {","+\t\t\tcontinue;","+\t\t}","+\t\tauto &rh = *rh_ptr;","+\t\tauto inserted = buckets.emplace(rh, vector<ParquetPrefetchColumn> {});","+\t\tif (inserted.second) {","+\t\t\tbucket_order.emplace_back(rh);","+\t\t}","+\t\tinserted.first->second.push_back(requested_column);","+\t}","+","+\tfor (auto &chunk : all_chunks) {","+\t\t// We gotta figure out if we had any hitchhiker","+\t\tidx_t chunk_start = ParquetColumnChunkFileOffset(chunk);","+\t\tif (registered_offsets.count(chunk_start) > 0) {","+\t\t\tcontinue;","+\t\t}","+\t\tidx_t chunk_end = chunk_start + NumericCast<idx_t>(chunk.meta_data.total_compressed_size);","+\t\t// Figure out what physical I/O this file offset lives in","+\t\tauto rh_ptr = trans.GetReadHead(chunk_start);","+\t\tif (!rh_ptr || chunk_end > rh_ptr->GetEnd()) {","+\t\t\tcontinue;","+\t\t}","+\t\tauto &rh = *rh_ptr;","+\t\t// Hitchhiker only counts if the ReadHead was created for one of our registrations.","+\t\tauto bucket_it = buckets.find(rh);","+\t\tif (bucket_it == buckets.end()) {","+\t\t\tcontinue;","+\t\t}","+\t\tauto &path = chunk.meta_data.path_in_schema;","+\t\tstring name = path.empty() ? string() : StringUtil::Join(path, \".\");","+\t\t// we tag hitchhikers with *column_name*","+\t\tbucket_it->second.emplace_back(\"*\" + std::move(name) + \"*\", chunk_start);","+\t}","+","+\t// Issue one log group per ReadHead, on the order they were registered","+\tfor (auto &rh_ref : bucket_order) {","+\t\tauto &bucket = buckets[rh_ref];","+\t\tstd::sort(bucket.begin(), bucket.end());","+\t\tvector<string> names;","+\t\tnames.reserve(bucket.size());","+\t\tfor (auto &col : bucket) {","+\t\t\tnames.push_back(std::move(col.name));","+\t\t}","+\t\tprefetch_groups.push_back(std::move(names));","+\t}","+\trequested_columns.clear();","+}","+","+static void LogRowGroupPrefetch(ClientContext &context, const string &file_path, idx_t row_group_id,","+                                ParquetReaderScanState &state) {","+\tconst bool fully_filtered = !state.prefetch_metrics.had_match;","+\tauto &filters_used = state.prefetch_metrics.logger.filters_used;","+\tvector<string> minimal_filters;","+\tminimal_filters.reserve(filters_used.size());","+\tfor (idx_t i = 0; i < state.scan_filters.size(); i++) {","+\t\tif (i < filters_used.size() && filters_used[i]) {","+\t\t\tauto &scan_filter = state.scan_filters[i];","+\t\t\tMultiFileLocalIndex local_idx(scan_filter.filter_idx);","+\t\t\tminimal_filters.push_back(state.GetColumnReader(local_idx).Schema().name);","+\t\t}","+\t}","+\tDUCKDB_LOG(context, ParquetPrefetchLogType, file_path, row_group_id, fully_filtered,","+\t           ParquetPrefetchStrategyToString(state.prefetch_metrics.logger.strategy),","+\t           state.prefetch_metrics.logger.prefetch_groups, minimal_filters);","+}","+"," using duckdb_parquet::ColumnChunk;"," using duckdb_parquet::ConvertedType;"," using duckdb_parquet::FieldRepetitionType;","@@ -1327,6 +1446,9 @@ void ParquetReader::InitializeScan(ClientContext &context, ParquetReaderScanStat"," \t\t\tstate.scan_filters.emplace_back(context, entry.GetIndex(), entry.Filter());"," \t\t}"," \t}","+\tif (state.filter_eliminated_all_rows.size() != state.scan_filters.size()) {","+\t\tstate.filter_eliminated_all_rows.assign(state.scan_filters.size(), false);","+\t}"," "," \tstate.thrift_file_proto = CreateThriftFileProtocol(context, *state.file_handle, state.prefetch_mode);"," ","@@ -1427,12 +1549,105 @@ void ParquetReader::GetPartitionStats(const duckdb_parquet::FileMetaData &metada"," \t}"," }"," ","+void ParquetReader::WholeGroupPrefetch(ParquetReaderScanState &state, ThriftFileTransport &trans,","+                                       const duckdb_parquet::RowGroup &group, uint64_t total_row_group_span,","+                                       bool log_prefetch) {","+\tif (!state.current_group_prefetched) {","+\t\tauto total_compressed_size = GetGroupCompressedSize(state);","+\t\tif (total_compressed_size > 0) {","+\t\t\ttrans.Prefetch(GetGroupOffset(state), total_row_group_span);","+\t\t}","+\t\tstate.current_group_prefetched = true;","+\t}","+\tif (log_prefetch) {","+\t\tstate.prefetch_metrics.logger.strategy = ParquetPrefetchStrategy::WHOLE_GROUP;","+\t\tvector<ParquetPrefetchColumn> pending_registrations;","+\t\tfor (auto &column_chunk : group.columns) {","+\t\t\tauto &path = column_chunk.meta_data.path_in_schema;","+\t\t\tstring name = path.empty() ? string() : StringUtil::Join(path, \".\");","+\t\t\tpending_registrations.push_back({name, ParquetColumnChunkFileOffset(column_chunk)});","+\t\t}","+\t\tstate.prefetch_metrics.logger.GeneratePrefetchGroup(trans, pending_registrations, group.columns);","+\t}","+}","+","+void ParquetReader::ColumnWisePrefetch(ParquetReaderScanState &state, ThriftFileTransport &trans,","+                                       const duckdb_parquet::RowGroup &group, bool filters_look_unselective,","+                                       bool log_prefetch) {","+\tbool has_non_optional_filter = false;","+\tif (filters) {","+\t\tfor (auto &entry : *filters) {","+\t\t\tif (!ExpressionFilter::IsRootOptionalFilter(entry.Filter())) {","+\t\t\t\thas_non_optional_filter = true;","+\t\t\t}","+\t\t}","+\t}","+\tconst bool lazy_fetch = has_non_optional_filter && !filters_look_unselective;","+","+\tvector<bool> already_registered(column_ids.size(), false);","+\tvector<ParquetPrefetchColumn> pending_registrations;","+","+\tif (lazy_fetch && !state.scan_filters.empty()) {","+\t\tauto &adaptive_filter = state.adaptive_filter_cache.GetAdaptiveFilter();","+\t\tconst auto &permutation = adaptive_filter.GetPermutation();","+\t\tfor (idx_t i = 0; i < state.scan_filters.size(); i++) {","+\t\t\t// We must do the filter grouping based on the set that excludes all rows","+\t\t\tif (i > 0 && state.filter_eliminated_all_rows[permutation[i - 1]]) {","+\t\t\t\ttrans.FinalizeRegistration();","+\t\t\t\tif (log_prefetch) {","+\t\t\t\t\tstate.prefetch_metrics.logger.GeneratePrefetchGroup(trans, pending_registrations, group.columns);","+\t\t\t\t}","+\t\t\t}","+\t\t\tauto &scan_filter = state.scan_filters[permutation[i]];","+\t\t\tMultiFileLocalIndex local_idx(scan_filter.filter_idx);","+\t\t\tauto &child = state.GetColumnReader(local_idx);","+\t\t\tchild.RegisterPrefetch(trans, true);","+\t\t\tif (log_prefetch) {","+\t\t\t\tpending_registrations.emplace_back(child.Schema().name, child.FileOffset());","+\t\t\t}","+\t\t\talready_registered[local_idx.GetIndex()] = true;","+\t\t}","+\t\t// Done with the filter columns, tim