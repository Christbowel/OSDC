ter the conflicting insert\")","+\tassert.Equal(t, int64(100), jobs[0].StoppingRV, \"original stopping_rv preserved\")","+}","+"," func TestIntegrationVectorReconcilerLock(t *testing.T) {"," \tbackend, _, ctx := setupIntegrationTest(t)"," ","@@ -481,3 +498,45 @@ func makeEmbedding(a, b float32) []float32 {"," \te[1] = b"," \treturn e"," }","+","+func TestEnsureResourcePartition_RejectsUnsafeResource(t *testing.T) {","+\tb := &pgvectorBackend{}","+\tfor _, res := range []string{\"\", \"Dashboards\", \"dash-boards\", \"a.b\", \"drop;table\", \"with space\"} {","+\t\trequire.Error(t, b.EnsureResourcePartition(context.Background(), res),","+\t\t\t\"resource %q must be rejected\", res)","+\t}","+}","+","+func TestIntegrationVectorEnsureResourcePartition(t *testing.T) {","+\tbackend, engine, ctx := setupIntegrationTest(t)","+\tpg := backend.(*pgvectorBackend)","+","+\tconst res = \"testpartition\"","+\tleaf := subtreeName(res)","+\tidx := leaf + \"_metadata_idx\"","+\tdrop := func() { _, _ = engine.DB().ExecContext(ctx, fmt.Sprintf(`DROP TABLE IF EXISTS %s`, leaf)) }","+\tdrop()","+\tt.Cleanup(drop)","+","+\t// Absent before creation.","+\tready, err := pg.resourcePartitionReady(ctx, leaf, idx)","+\trequire.NoError(t, err)","+\trequire.False(t, ready)","+","+\t// Create it: partition + metadata index both present.","+\trequire.NoError(t, backend.EnsureResourcePartition(ctx, res))","+\tready, err = pg.resourcePartitionReady(ctx, leaf, idx)","+\trequire.NoError(t, err)","+\tassert.True(t, ready, \"leaf attached as partition and metadata index present\")","+","+\t// Heals a missing index: drop it, retry must recreate it.","+\t_, err = engine.DB().ExecContext(ctx, fmt.Sprintf(`DROP INDEX IF EXISTS %s`, idx))","+\trequire.NoError(t, err)","+\trequire.NoError(t, backend.EnsureResourcePartition(ctx, res))","+\tready, err = pg.resourcePartitionReady(ctx, leaf, idx)","+\trequire.NoError(t, err)","+\tassert.True(t, ready, \"missing index recreated on retry\")","+","+\t// Idempotent: a second call (fast path) is a no-op, no error.","+\trequire.NoError(t, backend.EnsureResourcePartition(ctx, res))","+}"],"additions":59,"deletions":0,"truncated":false},{"path":"pkg/storage/unified/search/vector/pgvector.go","lines":["@@ -416,6 +416,95 @@ func (b *pgvectorBackend) ListIncompleteBackfillJobs(ctx context.Context, model"," \treturn out, nil"," }"," ","+// EnsureResourcePartition creates the embeddings_<resource> partition leaf and","+// its metadata index. The per-resource advisory lock serializes the attach","+// (ACCESS EXCLUSIVE on the parent) so concurrent replicas don't race it.","+func (b *pgvectorBackend) EnsureResourcePartition(ctx context.Context, resource string) error {","+\t// resource is interpolated unquoted into the DDL below; reject anything","+\t// sanitizeIdentifier would alter to keep it injection-safe.","+\tif resource == \"\" || sanitizeIdentifier(resource) != resource {","+\t\treturn fmt.Errorf(\"ensure partition: unsafe resource %q\", resource)","+\t}","+\tleaf := subtreeName(resource) // embeddings_<resource>","+\tidx := leaf + \"_metadata_idx\"","+","+\t// Fast path: skip the lock + DDL only when BOTH leaf and index exist.","+\t// Checking the index too lets a retry finish a prior attempt that created","+\t// the leaf but failed before the index.","+\tready, err := b.resourcePartitionReady(ctx, leaf, idx)","+\tif err != nil {","+\t\treturn fmt.Errorf(\"check partition %s: %w\", leaf, err)","+\t}","+\tif ready {","+\t\treturn nil","+\t}","+","+\tconn, err := b.db.SqlDB().Conn(ctx)","+\tif err != nil {","+\t\treturn fmt.Errorf(\"ensure partition conn: %w\", err)","+\t}","+\tdefer func() { _ = conn.Close() }()","+","+\tlockName := \"vectorpartition_\" + resource","+\tif _, err := conn.ExecContext(ctx,","+\t\t\"SELECT pg_advisory_lock(hashtext($1)::bigint)\", lockName); err != nil {","+\t\treturn fmt.Errorf(\"ensure partition lock: %w\", err)","+\t}","+\tdefer func() {","+\t\t_, _ = conn.ExecContext(context.Background(),","+\t\t\t\"SELECT pg_advisory_unlock(hashtext($1)::bigint)\", lockName)","+\t}()","+","+\tif _, err := conn.ExecContext(ctx, fmt.Sprintf(","+\t\t`CREATE TABLE IF NOT EXISTS %s PARTITION OF %s FOR VALUES IN ('%s')`,","+\t\tleaf, unifiedParent, resource,","+\t)); err != nil {","+\t\treturn fmt.Errorf(\"create partition %s: %w\", leaf, err)","+\t}","+\tif _, err := conn.ExecContext(ctx, fmt.Sprintf(","+\t\t`CREATE INDEX IF NOT EXISTS %s ON %s USING GIN (metadata)`,","+\t\tidx, leaf,","+\t)); err != nil {","+\t\treturn fmt.Errorf(\"create metadata index on %s: %w\", leaf, err)","+\t}","+\treturn nil","+}","+","+// resourcePartitionReady reports whether leaf is attached as a partition of","+// the parent (pg_inherits, not to_regclass, so a same-named unrelated table","+// can't match) AND its metadata index exists.","+func (b *pgvectorBackend) resourcePartitionReady(ctx context.Context, leaf, idx string) (bool, error) {","+\tvar ready bool","+\terr := b.db.QueryRowContext(ctx, `","+\t\tSELECT","+\t\t\tEXISTS (","+\t\t\t\tSELECT 1 FROM pg_inherits i","+\t\t\t\tJOIN pg_class c ON c.oid = i.inhrelid","+\t\t\t\tJOIN pg_class p ON p.oid = i.inhparent","+\t\t\t\tWHERE p.relname = $1 AND c.relname = $2","+\t\t\t)","+\t\t\tAND EXISTS (","+\t\t\t\tSELECT 1 FROM pg_class WHERE relname = $3 AND relkind = 'i'","+\t\t\t)`, unifiedParent, leaf, idx).Scan(&ready)","+\tif err != nil {","+\t\treturn false, err","+\t}","+\treturn ready, nil","+}","+","+func (b *pgvectorBackend) CreateBackfillJob(ctx context.Context, model, resource string, stoppingRV int64) error {","+\treq := &sqlVectorBackfillJobsCreateRequest{","+\t\tSQLTemplate: sqltemplate.New(b.dialect),","+\t\tModel:       model,","+\t\tResource:    resource,","+\t\tStoppingRV:  stoppingRV,","+\t}","+\tif _, err := dbutil.Exec(ctx, b.db, sqlVectorBackfillJobsCreate, req); err != nil {","+\t\treturn fmt.Errorf(\"create backfill job (%s,%s): %w\", model, resource, err)","+\t}","+\treturn nil","+}","+"," func (b *pgvectorBackend) UpdateBackfillJobCheckpoint(ctx context.Context, id int64, lastSeenKey string, lastErr string) error {"," \treq := &sqlVectorBackfillJobsUpdateRequest{"," \t\tSQLTemplate: sqltemplate.New(b.dialect),"],"additions":89,"deletions":0,"truncated":false},{"path":"pkg/storage/unified/search/vector/queries.go","lines":["@@ -36,6 +36,7 @@ var ("," \tsqlVectorCollectionExists            = mustTemplate(\"vector_collection_exists.sql\")"," \tsqlVectorCollectionSearch            = mustTemplate(\"vector_collection_search.sql\")"," \tsqlVectorBackfillJobsList            = mustTemplate(\"vector_backfill_jobs_list.sql\")","+\tsqlVectorBackfillJobsCreate          = mustTemplate(\"vector_backfill_jobs_create.sql\")"," \tsqlVectorBackfillJobsUpdate          = mustTemplate(\"vector_backfill_jobs_update.sql\")"," \tsqlVectorBackfillJobsSetError        = mustTemplate(\"vector_backfill_jobs_set_error.sql\")"," \tsqlVectorBackfillJobsComplete        = mustTemplate(\"vector_backfill_jobs_complete.sql\")","@@ -158,6 +159,26 @@ func (r *sqlVectorBackfillJobsListRequest) Results() (*sqlVectorBackfillJobsList"," \treturn &cp, nil"," }"," ","+type sqlVectorBackfillJobsCreateRequest struct {","+\tsqltemplate.SQLTemplate","+\tModel      string","+\tResource   string","+\tStoppingRV int64","+}","+","+func (r *sqlVectorBackfillJobsCreateRequest) Validate() error {","+\tif r.Model == \"\" {","+\t\treturn fmt.Errorf(\"missing model\")","+\t}","+\tif r.Resource == \"\" {","+\t\treturn fmt.Errorf(\"missing resource\")","+\t}","+\tif r.StoppingRV <= 0 {","+\t\treturn fmt.Errorf(\"stopping_rv must be positive\")","+\t}","+\treturn nil","+}","+"," type sqlVectorBackfillJobsUpdateRequest struct {"," \tsqltemplate.SQLTemplate"," \tID          int64"],"additions":21,"deletions":0,"truncated":false},{"path":"pkg/storage/unified/search/vector/queries_test.go","lines":["@@ -103,6 +103,17 @@ func TestVectorQueries(t *testing.T) {"," \t\t\t\t\t},"," \t\t\t\t},"," \t\t\t},","+\t\t\tsqlVectorBackfillJobsCreate: {","+\t\t\t\t{"