turated) PURE;","+","   /**","    * Used by ConnectionHandler to manage listeners.","    */","@@ -172,6 +177,12 @@ class ConnectionHandler {","      */","     virtual void onFilterChainDraining(","         const std::list<const Network::FilterChain*>& draining_filter_chains) PURE;","+","+    // New method for handling idle connection closing","+    virtual void onCloseIdleHttpConnections(bool /*is_saturated*/) {","+      // Default implementation does nothing.","+      // Specific listener types (TCP, QUIC) will override this.","+    }","   };"," ","   using ActiveListenerPtr = std::unique_ptr<ActiveListener>;"],"additions":11,"deletions":0,"truncated":false},{"path":"envoy/server/overload/overload_manager.h","lines":["@@ -42,16 +42,20 @@ class OverloadActionNameValues {","   // Overload action to reset streams using excessive memory.","   const std::string ResetStreams = \"envoy.overload_actions.reset_high_memory_stream\";"," ","+  // Overload action to terminate idle downstream HTTP connections.","+  const std::string CloseIdleHttpConnections = \"envoy.overload_actions.close_idle_http_connections\";","+","   // This should be kept current with the Overload actions available.","   // This is the last member of this class to duplicating the strings with","   // proper lifetime guarantees.","-  const std::array<absl::string_view, 7> WellKnownActions = {StopAcceptingRequests,","+  const std::array<absl::string_view, 8> WellKnownActions = {StopAcceptingRequests,","                                                              DisableHttpKeepAlive,","                                                              StopAcceptingConnections,","                                                              RejectIncomingConnections,","                                                              ShrinkHeap,","                                                              ReduceTimeouts,","-                                                             ResetStreams};","+           