e an instance of this class.","+","+        .. versionadded:: 3.2","+        \"\"\"","+        if not value:","+            return cls(None)","+","+        result = []","+","+        for item in parse_list_header(value):","+            item, options = parse_options_header(item)","+","+            if \"q\" in options:","+                # pop q, remaining options are reconstructed","+                q_str = options.pop(\"q\").strip()","+","+                if _q_value_re.fullmatch(q_str) is None:","+                    # ignore an invalid q","+                    continue","+","+                q = float(q_str)","+","+                if q < 0 or q > 1:","+                    # ignore an invalid q","+                    continue","+            else:","+                q = 1","+","+            if options:","+                # reconstruct the media type with any options","+                item = dump_options_header(item, options)","+","+            result.append((item, q))","+","+        return cls(result)","+","     def to_header(self) -> str:","-        \"\"\"Convert the header set into an HTTP header string.\"\"\"","+        \"\"\"Convert to an ``Accept`` header value.\"\"\"","         result = []","         for value, quality in self:","             if quality != 1:"],"additions":47,"deletions":1,"truncated":false},{"path":"src/werkzeug/datastructures/auth.py","lines":["@@ -88,8 +88,8 @@ def __eq__(self, other: object) -> bool:"," ","     @classmethod","     def from_header(cls, value: str | None) -> te.Self | None:","-        \"\"\"Parse an ``Authorization`` header value and return an instance, or ``None``","-        if the value is empty.","+        \"\"\"Parse an ``Authorization`` header value and create an instance of","+        this class, or ``None`` if the value is empty."," ","         :param value: The header value to parse."," ","@@ -118,7 +118,7 @@ def from_header(cls, value: str | None) -> te.Self | None:","         return cls(scheme, None, rest)"," "," 