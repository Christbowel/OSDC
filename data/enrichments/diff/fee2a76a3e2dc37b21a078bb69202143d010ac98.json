{"id":"fee2a76a3e2dc37b21a078bb69202143d010ac98","axis":"silent","repo":"hashicorp/vault","sha":"fee2a76a3e2dc37b21a078bb69202143d010ac98","parsed":{"files":[{"path":"api/sudo_paths.go","lines":["@@ -22,6 +22,7 @@ var sudoPaths = map[string]*regexp.Regexp{"," \t\"/sys/audit/{path}\":                             regexp.MustCompile(`^/sys/audit/.+$`),"," \t\"/sys/auth/{path}\":                              regexp.MustCompile(`^/sys/auth/.+$`),"," \t\"/sys/auth/{path}/tune\":                         regexp.MustCompile(`^/sys/auth/.+/tune$`),","+\t\"/sys/mounts/auth/{path}/tune\":                  regexp.MustCompile(`^/sys/mounts/auth/.+/tune$`),"," \t\"/sys/config/auditing/request-headers\":          regexp.MustCompile(`^/sys/config/auditing/request-headers$`),"," \t\"/sys/config/auditing/request-headers/{header}\": regexp.MustCompile(`^/sys/config/auditing/request-headers/.+$`),"," \t\"/sys/config/cors\":                              regexp.MustCompile(`^/sys/config/cors$`),"],"additions":1,"deletions":0,"truncated":false},{"path":"changelog/_13738.txt","lines":["@@ -0,0 +1,3 @@","+```release-note:change","+core: Require sudo capability for `sys/mounts/auth/<path>/tune`, matching `sys/auth/<path>/tune`.","+```"],"additions":3,"deletions":0,"truncated":false},{"path":"sdk/logical/logical.go","lines":["@@ -122,7 +122,10 @@ type Factory func(context.Context, *BackendConfig) (Backend, error)"," "," // Paths is the structure of special paths that is used for SpecialPaths."," type Paths struct {","-\t// Root are the API paths that require a root token to access","+\t// Root are the API paths that require a root token to access.","+\t// These can't be regular expressions; each entry is either an exact match,","+\t// a prefix match (append '*' as a suffix), or a wildcard segment match","+\t// (use '+' in a segment, e.g. 'foo/+/bar')."," \tRoot []string"," "," \t// Unauthenticated are the API paths that can be accessed without any auth."],"additions":4,"deletions":1,"truncated":false},{"path":"vault/external_tests/mountsauthtune/mounts_auth_tune_sudo_test.go","lines":["@@ -0,0 +1,105 @@","+// Copyright IBM Corp. 2016, 2026","+// SPDX-License-Identifier: BUSL-1.1","+","+package mountsauthtune","+","+import (","+\t\"fmt\"","+\t\"testing\"","+","+\t\"github.com/hashicorp/vault/api\"","+\tcredUserpass \"github.com/hashicorp/vault/builtin/credential/userpass\"","+\tvaulthttp \"github.com/hashicorp/vault/http\"","+\t\"github.com/hashicorp/vault/sdk/logical\"","+\t\"github.com/hashicorp/vault/vault\"","+\t\"github.com/stretchr/testify/require\"","+)","+","+// TestMountsAuthTuneRequiresSudo ensures sys/mounts/auth/<path>/tune requires","+// sudo-equivalent privilege while sys/mounts/auth/<path> remains readable","+// without sudo when ACL allows it.","+func TestMountsAuthTuneRequiresSudo(t *testing.T) {","+\tt.Parallel()","+","+\tcluster := vault.NewTestCluster(t, &vault.CoreConfig{","+\t\tCredentialBackends: map[string]logical.Factory{","+\t\t\t\"userpass\": credUserpass.Factory,","+\t\t},","+\t}, &vault.TestClusterOptions{","+\t\tHandlerFunc: vaulthttp.Handler,","+\t\tNumCores:    1,","+\t})","+","+\tclient := cluster.Cores[0].Client","+\trootToken := cluster.RootToken","+","+\trequire.NoError(t, client.Sys().EnableAuthWithOptions(\"userpass\", &api.EnableAuthOptions{","+\t\tType: \"userpass\",","+\t}))","+","+\tnoSudoPolicy := `","+path \"sys/mounts/auth/userpass/tune\" {","+\tcapabilities = [\"read\", \"update\"]","+}","+path \"sys/mounts/auth/userpass*\" {","+\tcapabilities = [\"read\"]","+}","+`","+\trequire.NoError(t, client.Sys().PutPolicy(\"mounts-auth-tune-no-sudo\", noSudoPolicy))","+","+\tnoSudoTokenResp, err := client.Auth().Token().Create(&api.TokenCreateRequest{","+\t\tPolicies: []string{\"mounts-auth-tune-no-sudo\"},","+\t})","+\trequire.NoError(t, err)","+\trequire.NotNil(t, noSudoTokenResp)","+\trequire.NotNil(t, noSudoTokenResp.Auth)","+\trequire.NotEmpty(t, noSudoTokenResp.Auth.ClientToken)","+","+\tclient.SetToken(noSudoTokenResp.Auth.ClientToken)","+","+\t// Non-tune path should remain readable without sudo.","+\tnonTuneResp, err := client.Logical().Read(\"sys/mounts/auth/userpass\")","+\trequire.NoError(t, err)","+\trequire.NotNil(t, nonTuneResp)","+","+\t// Tune endpoints should fail without sudo.","+\t_, err = client.Logical().Write(\"sys/mounts/auth/userpass/tune\", map[string]interface{}{","+\t\t\"max_lease_ttl\": \"2h\",","+\t})","+\trequire.Error(t, err)","+\trequire.Contains(t, err.Error(), logical.ErrPermissionDenied.Error())","+","+\t_, err = client.Logical().Read(\"sys/mounts/auth/userpass/tune\")","+\trequire.Error(t, err)","+\trequire.Contains(t, err.Error(), logical.ErrPermissionDenied.Error())","+","+\tclient.SetToken(rootToken)","+","+\tsudoPolicy := `","+path \"sys/mounts/auth/userpass/tune\" {","+\tcapabilities = [\"sudo\", \"read\", \"update\"]","+}","+`","+\trequire.NoError(t, client.Sys().PutPolicy(\"mounts-auth-tune-with-sudo\", sudoPolicy))","+","+\twithSudoTokenResp, err := client.Auth().Token().Create(&api.TokenCreateRequest{","+\t\tPolicies: []string{\"mounts-auth-tune-with-sudo\"},","+\t})","+\trequire.NoError(t, err)","+\trequire.NotNil(t, withSudoTokenResp)","+\trequire.NotNil(t, withSudoTokenResp.Auth)","+\trequire.NotEmpty(t, withSudoTokenResp.Auth.ClientToken)","+","+\tclient.SetToken(withSudoTokenResp.Auth.ClientToken)","+","+\t_, err = client.Logical().Write(\"sys/mounts/auth/userpass/tune\", map[string]interface{}{","+\t\t\"max_lease_ttl\": \"3h\",","+\t})","+\trequire.NoError(t, err)","+","+\ttuneResp, err := client.Logical().Read(\"sys/mounts/auth/userpass/tune\")","+\trequire.NoError(t, err)","+\trequire.NotNil(t, tuneResp)","+\trequire.Contains(t, tuneResp.Data, \"max_lease_ttl\")","+\trequire.Equal(t, \"10800\", fmt.Sprint(tuneResp.Data[\"max_lease_ttl\"]))","+}"],"additions":105,"deletions":0,"truncated":false},{"path":"vault/logical_system.go","lines":["@@ -169,6 +169,7 @@ func NewSystemBackend(core *Core, logger log.Logger, config *logical.Ba