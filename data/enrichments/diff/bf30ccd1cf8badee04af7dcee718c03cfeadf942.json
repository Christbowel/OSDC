Duration(settings.SystemAgentInstallerTokenShortTTL.Get())","+\tif err != nil {","+\t\tlogrus.Warnf(\"could not parse %s setting: %s\", settings.SystemAgentInstallerTokenShortTTL.Name, err)","+\t\treturn 0","+\t}","+","+\tlongTTL, err := time.ParseDuration(settings.SystemAgentInstallerTokenLongTTL.Get())","+\tif err != nil {","+\t\tlogrus.Warnf(\"could not parse %s setting: %s\", settings.SystemAgentInstallerTokenLongTTL.Name, err)","+\t\treturn 0","+\t}","+","+\tfinalTTL := secret.CreationTimestamp.Time.Add(longTTL).Sub(now)","+","+\tlastAccessString := secret.Annotations[capr.BootstrapTokenLastAccessTimeAnnotation]","+\tif lastAccessString != \"\" {","+\t\tlastAccessTime, err := time.Parse(time.RFC3339, lastAccessString)","+\t\tif err != nil {","+\t\t\tlogrus.Warnf(\"could not parse last access time for %s/%s: %s\", secret.Namespace, secret.Name, err)","+\t\t\treturn 0","+\t\t}","+","+\t\taccessTTL := lastAccessTime.Add(shortTTL).Sub(now)","+","+\t\tif accessTTL < finalTTL {","+\t\t\tfinalTTL = accessTTL","+\t\t}","+\t}","+","+\treturn finalTTL","+}"],"additions":95,"deletions":0,"truncated":false},{"path":"pkg/controllers/capr/bootstraptoken/controller_test.go","lines":["@@ -0,0 +1,134 @@","+package bootstraptoken","+","+import (","+\t\"testing\"","+\t\"time\"","+","+\t\"github.com/rancher/rancher/pkg/capr\"","+\t\"github.com/rancher/rancher/pkg/settings\"","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+\tcorev1 \"k8s.io/api/core/v1\"","+\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"","+)","+","+func parseTime(t *testing.T, timeString string) time.Time {","+\tret, err := time.Parse(time.RFC3339, timeString)","+","+\trequire.NoError(t, err)","+","+\treturn ret","+}","+","+func Test_tokenTTL(t *testing.T) {","+\ttests := []struct {","+\t\tname     string","+\t\tsecret   *corev1.Secret","+\t\tshortTTL string","+\t\tlongTTL  string","+\t\tnow      time.Time","+\t\texpect   time.Duration","+\t}{","+\t\t{","+\t\t\tname: \"