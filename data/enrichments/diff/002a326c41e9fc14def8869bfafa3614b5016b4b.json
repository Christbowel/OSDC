{"id":"002a326c41e9fc14def8869bfafa3614b5016b4b","axis":"silent","repo":"anchore/syft","sha":"002a326c41e9fc14def8869bfafa3614b5016b4b","parsed":{"files":[{"path":"internal/os/feature_detection.go","lines":["@@ -2,6 +2,8 @@ package os"," "," import ("," \t\"context\"","+\t\"encoding/json\"","+\t\"errors\""," \t\"fmt\""," \t\"regexp\""," ","@@ -10,6 +12,7 @@ import ("," \t\"github.com/anchore/syft/internal/sbomsync\""," \t\"github.com/anchore/syft/syft/file\""," \t\"github.com/anchore/syft/syft/linux\"","+\t\"github.com/anchore/syft/syft/pkg\""," \t\"github.com/anchore/syft/syft/sbom\""," )"," ","@@ -19,8 +22,11 @@ func DetectFeatures(_ context.Context, resolver file.Resolver, builder sbomsync."," \t\t\treturn"," \t\t}"," ","-\t\terr := findRhelFeatures(resolver, s.Artifacts.LinuxDistribution)","-\t\tif err != nil {","+\t\tif err := findRhelFeatures(resolver, s.Artifacts.LinuxDistribution); err != nil {","+\t\t\tlog.WithFields(\"error\", err, \"release\", s.Artifacts.LinuxDistribution).Trace(\"error searching for extended support\")","+\t\t}","+","+\t\tif err := findUbuntuFeatures(resolver, s.Artifacts.LinuxDistribution, s.Artifacts.Packages); err != nil {"," \t\t\tlog.WithFields(\"error\", err, \"release\", s.Artifacts.LinuxDistribution).Trace(\"error searching for extended support\")"," \t\t}"," \t})","@@ -28,6 +34,9 @@ func DetectFeatures(_ context.Context, resolver file.Resolver, builder sbomsync."," \treturn nil"," }"," ","+// rhelEUSPatterns match a RHEL content manifest referencing an extended-update-support (EUS) repo.","+var rhelEUSPatterns = []*regexp.Regexp{regexp.MustCompile(`baseos-eus`), regexp.MustCompile(`baseos-eus|appstream-eus`)}","+"," func findRhelFeatures(resolver file.Resolver, release *linux.Release) error {"," \tif release == nil || release.ID != \"rhel\" {"," \t\treturn nil","@@ -37,9 +46,9 @@ func findRhelFeatures(resolver file.Resolver, release *linux.Release) error {"," \t\treturn fmt.Errorf(\"unable to find content manifests: %w\", err)"," \t}"," \tfor _, contentManifestFile := range contentManifestFiles {","-\t\tfound, err := hasRhelExtendedSupportInContentManifest(resolver, contentManifestFile)","+\t\tfound, err := fileMatchesAny(resolver, contentManifestFile, rhelEUSPatterns...)"," \t\tif err != nil {","-\t\t\treturn fmt.Errorf(\"unable to read content manifest from %s: %w\", contentManifestFile.String(), err)","+\t\t\treturn fmt.Errorf(\"unable to read content manifest from %s: %w\", contentManifestFile.RealPath, err)"," \t\t}"," \t\tif found {"," \t\t\trelease.ExtendedSupport = true","@@ -49,13 +58,152 @@ func findRhelFeatures(resolver file.Resolver, release *linux.Release) error {"," \treturn nil"," }"," ","-func hasRhelExtendedSupportInContentManifest(resolver file.Resolver, contentManifestFile file.Location) (bool, error) {","-\tcontents, err := resolver.FileContentsByLocation(contentManifestFile)","+// Ubuntu Pro (formerly Ubuntu Advantage) is Canonical's subscription that unlocks Expanded Security","+// Maintenance (ESM): security fixes past a package's standard support window. we detect the two base ESM","+// streams, esm-infra (the `main` repo) and esm-apps (`universe`), and collapse them into one ExtendedSupport","+// signal; the infra-vs-apps split is disambiguated by the downstream consumer, not by this boolean.","+//","+// the other Pro streams on the same host (esm.ubuntu.com/fips, /fips-updates, /realtime) are deliberately","+// excluded: they are separate compliance products with their own downstream channels, and a host can run","+// them with base ESM disabled, so folding them in would be unsound.","+//","+// detection is deliberately forgiving: apt/status evidence disappears when ESM is disabled, but an installed","+// +esmN package is durable proof ESM content is on disk. so ExtendedSupport means \"ESM was or is in effect","+// for this host or its content\", not \"currently entitled\" (mere eligibility, without evidence, is not enough).","+","+// esmAptSourcePattern matches an uncommented apt source (classic or DEB822) or auth entry pointing at the","+// plain ESM streams esm.ubuntu.com/infra or /apps. it deliberately scopes to /(infra|apps) so the other","+// Pro streams served from the same host (/fips, /fips-updates, /realtime) are never folded into the base","+// esm channel. the [^#\\n]* before the host ensures a leading `#` (comment) can never satisfy the match.","+var esmAptSourcePattern = regexp.MustCompile(`(?m)^[^#\\n]*esm\\.ubuntu\\.com/(infra|apps)`)","+","+// esmVersionPattern matches a dpkg version carrying a numbered ESM pocket suffix, e.g. `...+esm1` or","+// `...~esm2`. the trailing \\d scopes this to the ESM pocket and excludes other Pro pockets (e.g. +fips).","+var esmVersionPattern = regexp.MustCompile(`[~+]esm\\d`)","+","+func findUbuntuFeatures(resolver file.Resolver, release *linux.Release, packages *pkg.Collection) error {","+\tif release == nil || release.ID != \"ubuntu\" {","+\t\treturn nil","+\t}","+","+\t// an uncommented esm.ubuntu.com apt source or an active pro esm service both prove Pro/ESM was enabled.","+\t// these are the durable, file-based signals present on attached hosts. a read error in one signal must","+\t// not suppress the others, so errors are collected and detection continues to the next signal.","+\tvar errs error","+\tfor _, check := range []func() (bool, error){","+\t\tfunc() (bool, error) { return hasUbuntuESMAptEvidence(resolver) },","+\t\tfunc() (bool, error) { return hasActiveUbuntuESMService(resolver) },","+\t} {","+\t\tfound, err := check()","+\t\tif err != nil {","+\t\t\terrs = errors.Join(errs, err)","+\t\t\tcontinue","+\t\t}","+\t\tif found {","+\t\t\trelease.ExtendedSupport = true","+\t\t\treturn errs","+\t\t}","+\t}","+","+\t// fallback for images (typically not pro-attached): an installed package whose version carries an","+\t// +esm/~esm suffix was pulled from an ESM pocket, so ESM was in effect when it was installed.","+\tif hasInstalledESMPackage(packages) {","+\t\trelease.ExtendedSupport = true","+\t}","+\treturn errs","+}","+","+// hasUbuntuESMAptEvidence reports whether any apt source (classic .list or DEB822 .sources) or auth entry","+// references esm.ubuntu.com via an uncommented line.","+func hasUbuntuESMAptEvidence(resolver file.Resolver) (bool, error) {","+\t// apt source files live in a directory (classic .list or DEB822 .sources), the credentials file is a fixed path.","+\tsourceLocations, err := resolver.FilesByGlob(\"/etc/apt/sources.list.d/*\")","+\tif err != nil {","+\t\treturn false, fmt.Errorf(\"unable to find apt esm sources: %w\", err)","+\t}","+\tauthLocations, err := resolver.FilesByPath(\"/etc/apt/auth.conf.d/90ubuntu-advantage\")","+\tif err != nil {","+\t\treturn false, fmt.Errorf(\"unable to find apt esm auth: %w\", err)","+\t}","+","+\t// ponytail: a DEB822 source with `Enabled: no` would still match; the pro client removes/comments the","+\t// file on disable rather than toggling that key, so this is an accepted false-positive ceiling. the","+\t// auth.conf.d entry is deleted by the pro client on disable, so it is a durable positive-only signal.","+\tfor _, location := range append(sourceLocations, authLocations...) {","+\t\tmatch, err := fileMatchesAny(resolver, location, esmAptSourcePattern)","+\t\tif err != nil {","+\t\t\treturn false, err","+\t\t}","+\t\tif match {","+\t\t\treturn true, nil","+\t\t}","+\t}","+\treturn false, nil","+}","+","+// hasActiveUbuntuESMService reports whether the ubuntu-advantage/pro status cache shows an enabled esm service.","+func hasActiveUbuntuESMService(resolver file.Resolver) (bool, error) {","+\tlocations, err := resolver.FilesByPath(\"/var/lib/ubuntu-advantage/status.json\")","+\tif err != nil {","+\t\treturn false, fmt.Errorf(\"unable to find ubuntu-advantage status: %w\", err)","+\t}","+\tfor _, location := range locations {","+\t\tenabled, err := hasEnabledESMServiceInStatus(resolver, location)","+\t\tif err != nil {","+\t\t\treturn false, err","+\t\t}","+\t\tif enabled {","+\t\t\treturn true, nil","+\t\t}","+\t}","+\treturn false, nil","+}","+","+func hasEnabledESMServiceInStatus(resolver file.Resolver, location file.Location) (bool, error) {","+\tcontents, err := resolver.FileContentsByLocation(location)"," \tif err != nil {","-\t\treturn false, fmt.Errorf(\"unable to read content manifest from %s: %w\", contentManifestFile.String(), err)","+\t\treturn false, fmt.Errorf(\"unable to read ubuntu-advantage status from %s: %w\", location.RealPath, err)"," \t}","-\tdefer internal.CloseAndLogError(contents, \"content-manifest\")","+\tdefer internal.CloseAndLogError(contents, location.RealPath)"," ","-\tpatterns := []*regexp.Regexp{regexp.MustCompile(`baseos-eus`), regexp.MustCompile(`baseos-eus|appstream-eus`)}","+\tvar status struct {","+\t\tServices []struct {","+\t\t\tName   string `json:\"name\"`","+\t\t\tStatus string `json:\"status\"`","+\t\t} `json:\"services\"`","+\t}","+\tif err := json.NewDecoder(contents).Decode(&status); err != nil {","+\t\treturn false, fmt.Errorf(\"unable to parse ubuntu-advantage status from %s: %w\", location.RealPath, err)","+\t}","+","+\t// pro status values are enabled/disabled/n-a/warning/—; only \"enabled\" proves the stream is active.","+\t// warning/expired states are intentionally excluded here and left to the apt-source and installed-package signals.","+\tfor _, svc := range status.Services {","+\t\tif (svc.Name == \"esm-infra\" || svc.Name == \"esm-apps\") && svc.Status == \"enabled\" {","+\t\t\treturn true, nil","+\t\t}","+\t}","+\treturn false, nil","+}","+","+// hasInstalledESMPackage reports whether any installed dpkg package version carries an ESM pocket suffix.","+func hasInstalledESMPackage(packages *pkg.Collection) bool {","+\tif packages == nil {","+\t\treturn false","+\t}","+\tfor p := range packages.Enumerate(pkg.DebPkg) {","+\t\tif esmVersionPattern.MatchString(p.Version) {","+\t\t\treturn true","+\t\t}","+\t}","+\treturn false","+}","+","+func fileMatchesAny(resolver file.Resolver, location file.Location, patterns ...*regexp.Regexp) (bool, error) {","+\tcontents, err := resolver.FileContentsByLocation(location)","+\tif err != nil {","+\t\treturn false, fmt.Errorf(\"unable to read %s: %w\", location.RealPath, err)","+\t}","+\tdefer internal.CloseAndLogError(contents, location.RealPath)"," \treturn internal.MatchAnyFromReader(contents, patterns...)"," }"],"additions":157,"deletions":9,"truncated":false},{"path":"internal/os/feature_detection_test.go","lines":["@@ -2,6 +2,11 @@ package os_test"," "," import ("," \t\"context\"","+\t\"io\"","+\tstdos \"os\"","+\t\"path\"","+\t\"path/filepath\"","+\t\"slices\""," \t\"testing\""," "," \t\"github.com/stretchr/testify/require\"","@@ -11,7 +16,9 @@ import ("," \t\"github.com/anchore/syft/internal/sbomsync\""," \t\"github.com/anchore/syft/internal/task\""," \t\"github.com/anchore/syft/syft\"","+\t\"github.com/anchore/syft/syft/file\""," \t\"github.com/anchore/syft/syft/linux\"","+\t\"github.com/anchore/syft/syft/pkg\""," \t\"github.com/anchore/syft/syft/sbom\""," \t\"github.com/anchore/syft/syft/source\""," )","@@ -99,3 +106,210 @@ func Test_EnvironmentTask(t *testing.T) {"," \t\t})"," \t}"," }","+","+func Test_findUbuntuFeatures(t *testing.T) {","+\ttests := []struct {","+\t\tname      string","+\t\tdir       string","+\t\treleaseID string","+\t\tpackages  []pkg.Package","+\t\texpected  bool","+\t}{","+\t\t{","+\t\t\tname:      \"esm apt source present\",","+\t\t\tdir:       \"testdata/ubuntu_esm_apt\",","+\t\t\treleaseID: \"ubuntu\",","+\t\t\texpected:  true,","+\t\t},","+\t\t{","+\t\t\tname:      \"esm apt source in DEB822 .sources format\",","+\t\t\tdir:       \"testdata/ubuntu_esm_deb822\",","+\t\t\treleaseID: \"ubuntu\",","+\t\t\texpected:  true,","+\t\t},","+\t\t{","+\t\t\tname:      \"esm evidence in apt auth.conf.d\",","+\t\t\tdir:       \"testdata/ubuntu_esm_authconf\",","+\t\t\treleaseID: \"ubuntu\",","+\t\t\texpected:  true,","+\t\t},","+\t\t{","+\t\t\tname:      \"active esm service in ubuntu-advantage status\",","+\t\t\tdir:       \"testdata/ubuntu_esm_status\",","+\t\t\treleaseID: \"ubuntu\",","+\t\t\texpected:  true,","+\t\t},","+\t\t{","+\t\t\tname:      \"only esm-infra enabled (esm-apps disabled)\",","+\t\t\tdir:       \"testdata/ubuntu_esm_infra_only\",","+\t\t\treleaseID: \"ubuntu\",","+\t\t\texpected:  true,","+\t\t},","+\t\t{","+\t\t\tname:      \"malformed status.json does not panic or match\",","+\t\t\tdir:       \"testdata/ubuntu_esm_malformed\",","+\t\t\treleaseID: \"ubuntu\",","+\t\t\texpected:  false,","+\t\t},","+\t\t{","+\t\t\tname:      \"installed +esm package version\",","+\t\t\tdir:       \"testdata/ubuntu_plain\",","+\t\t\treleaseID: \"ubuntu\",","+\t\t\tpackages: []pkg.Package{","+\t\t\t\t{Name: \"openssl\", Version: \"1.1.1f-1ubuntu2.19+esm1\", Type: pkg.DebPkg},","+\t\t\t},","+\t\t\texpected: true,","+\t\t},","+\t\t{","+\t\t\tname:      \"installed ~esm package version\",","+\t\t\tdir:       \"testdata/ubuntu_plain\",","+\t\t\treleaseID: \"ubuntu\",","+\t\t\tpackages: []pkg.Package{","+\t\t\t\t{Name: \"libcap2\", Version: \"1:2.32-1ubuntu0.1~esm1\", Type: pkg.DebPkg},","+\t\t\t},","+\t\t\texpected: true,","+\t\t},","+\t\t{","+\t\t\tname:      \"plain ubuntu with no esm evidence\",","+\t\t\tdir:       \"testdata/ubuntu_plain\",","+\t\t\treleaseID: \"ubuntu\",","+\t\t\tpackages: []pkg.Package{","+\t\t\t\t{Name: \"openssl\", Version: \"1.1.1f-1ubuntu2.19\", Type: pkg.DebPkg},","+\t\t\t},","+\t\t\texpected: false,","+\t\t},","+\t\t{","+\t\t\tname:      \"commented esm source and disabled esm service\",","+\t\t\tdir:       \"testdata/ubuntu_esm_disabled\",","+\t\t\treleaseID: \"ubuntu\",","+\t\t\texpected:  false,","+\t\t},","+\t\t{","+\t\t\tname:      \"esm disabled but +esm package remains installed\",","+\t\t\tdir:       \"testdata/ubuntu_esm_disabled\",","+\t\t\treleaseID: \"ubuntu\",","+\t\t\tpackages: []pkg.Package{","+\t\t\t\t{Name: \"openssl\", Version: \"1.1.1f-1ubuntu2.19+esm1\", Type: pkg.DebPkg},","+\t\t\t},","+\t\t\texpected: true, // durable proof: ESM content is on disk even though the channel is now off","+\t\t},","+\t\t{","+\t\t\tname:      \"fips-only pro host is not plain esm\",","+\t\t\tdir:       \"testdata/ubuntu_fips_only\",","+\t\t\treleaseID: \"ubuntu\",","+\t\t\texpected:  false, // esm.ubuntu.com/fips must not be folded into the base esm channel","+\t\t},","+\t\t{","+\t\t\tname:      \"non-ubuntu is unaffected by esm evidence\",","+\t\t\tdir:       \"testdata/ubuntu_esm_apt\",","+\t\t\treleaseID: \"debian\",","+\t\t\texpected:  false,","+\t\t},","+\t\t{","+\t\t\tname:      \"non-ubuntu is unaffected by esm package version\",","+\t\t\tdir:       \"testdata/ubuntu_plain\",","+\t\t\treleaseID: \"debian\",","+\t\t\tpackages: []pkg.Package{","+\t\t\t\t{Name: \"openssl\", Version: \"1.1.1f-1ubuntu2.19+esm1\", Type: pkg.DebPkg},","+\t\t\t},","+\t\t\texpected: false,","+\t\t},","+\t}","+","+\tfor _, test := range tests {","+\t\tt.Run(test.name, func(t *testing.T) {","+\t\t\tresolver := fixtureResolverForDir(t, test.dir)","+","+\t\t\ts := sbom.SBOM{}","+\t\t\ts.Artifacts.LinuxDistribution = &linux.Release{ID: test.releaseID}","+\t\t\ts.Artifacts.Packages = pkg.NewCollection(test.packages...)","+","+\t\t\terr := os.DetectFeatures(context.Background(), resolver, sbomsync.NewBuilder(&s))","+\t\t\trequire.NoError(t, err)","+","+\t\t\trequire.Equal(t, test.expected, s.Artifacts.LinuxDistribution.ExtendedSupport)","+\t\t})","+\t}","+}","+","+// a read error in the apt-source signal must not suppress the ubuntu-advantage status signal; the three","+// signals are meant to be independent fallbacks.","+func Test_findUbuntuFeatures_signalErrorDoesNotSuppressOthers(t *testing.T) {","+\tresolver := errOnGlobResolver{","+\t\tfixtureResolver: fixtureResolverForDir(t, \"testdata/ubuntu_esm_status\").(fixtureResolver),","+\t\terrOnGlob:       \"/etc/apt/sources.list.d/*\",","+\t}","+","+\ts := sbom.SBOM{}","+\ts.Artifacts.LinuxDistribution = &linux.Release{ID: \"ubuntu\"}","+\ts.Artifacts.Packages = pkg.NewCollection()","+","+\trequire.NoError(t, os.DetectFeatures(context.Background(), resolver, sbomsync.NewBuilder(&s)))","+","+\t// the apt glob errors, but the status.json signal (esm-infra enabled) should still be consulted","+\trequire.True(t, s.Artifacts.LinuxDistribution.ExtendedSupport)","+}","+","+// errOnGlobResolver injects a failure for a specific glob to simulate an unreadable apt directory.","+type errOnGlobResolver struct {","+\tfixtureResolver","+\terrOnGlob string","+}","+","+func (r errOnGlobResolver) FilesByGlob(patterns ...string) ([]file.Location, error) {","+\tif slices.Contains(patterns, r.errOnGlob) {","+\t\treturn nil, stdos.ErrPermission","+\t}","+\treturn r.fixtureResolver.FilesByGlob(patterns...)","+}","+","+// fixtureResolver maps in-image logical paths to on-disk fixture files so DetectFeatures can be driven","+// without building a container image.","+type fixtureResolver struct {","+\tfile.Resolver // unused methods; nil is fine since only the three below are called","+\tfiles         map[string]string","+}","+","+func (r fixtureResolver) FilesByGlob(patterns ...string) ([]file.Location, error) {","+\tvar out []file.Location","+\tfor logical := range r.files {","+\t\tfor _, p := range patterns {","+\t\t\tif ok, _ := path.Match(p, logical); ok {","+\t\t\t\tout = append(out, file.NewLocation(logical))","+\t\t\t\tbreak","+\t\t\t}","+\t\t}","+\t}","+\treturn out, nil","+}","+","+func (r fixtureResolver) FilesByPath(paths ...string) ([]file.Location, error) {","+\tvar out []file.Location","+\tfor _, p := range paths {","+\t\tif _, ok := r.files[p]; ok {","+\t\t\tout = append(out, file.NewLocation(p))","+\t\t}","+\t}","+\treturn out, nil","+}","+","+func (r fixtureResolver) FileContentsByLocation(l file.Location) (io.ReadCloser, error) {","+\treturn stdos.Open(r.files[l.RealPath])","+}","+","+func fixtureResolverForDir(t *testing.T, dir string) file.Resolver {","+\tt.Helper()","+\tfiles := map[string]string{}","+\trequire