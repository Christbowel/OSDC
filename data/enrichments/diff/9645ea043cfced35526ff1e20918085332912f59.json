{"id":"9645ea043cfced35526ff1e20918085332912f59","axis":"silent","repo":"WordPress/wordpress-develop","sha":"9645ea043cfced35526ff1e20918085332912f59","parsed":{"files":[{"path":"src/wp-includes/rest-api/endpoints/class-wp-rest-abilities-v1-run-controller.php","lines":["@@ -223,6 +223,112 @@ private function get_input_from_request( $request ) {"," \t\treturn $json_params['input'] ?? null;"," \t}"," ","+\t/**","+\t * Sanitizes the run input by coercing it to the ability's input schema.","+\t *","+\t * Registered as the `input` argument `sanitize_callback` so that both","+\t * `check_ability_permissions()` and `execute_ability()` receive natively typed input","+\t * regardless of transport.","+\t *","+\t * @since 7.1.0","+\t *","+\t * @see WP_REST_Abilities_V1_Run_Controller::coerce_input_to_schema()","+\t *","+\t * @param mixed           $input   Raw input extracted from the request.","+\t * @param WP_REST_Request $request The request object.","+\t * @return mixed Coerced input, or the raw input when it cannot be safely coerced.","+\t */","+\tpublic function sanitize_input_for_ability( $input, $request ) {","+\t\t$ability = wp_get_ability( $request['name'] );","+\t\tif ( ! $ability instanceof WP_Ability ) {","+\t\t\treturn $input;","+\t\t}","+","+\t\treturn $this->coerce_input_to_schema( $input, $ability );","+\t}","+","+\t/**","+\t * Coerces raw request input to the types declared in the ability input schema.","+\t *","+\t * GET and DELETE deliver every scalar as a string (\"10\", \"true\") and a list as a single","+\t * comma-separated string, so without coercion an ability receives raw strings where its","+\t * schema declares integers, booleans, or arrays.","+\t *","+\t * Coercion never changes what validation accepts. Input is coerced only when","+\t * {@see WP_Ability::validate_input()} already accepts it, and any error surfaced while","+\t * sanitizing falls back to the raw input, so `validate_input()` stays the single authority","+\t * on what is rejected.","+\t *","+\t * @since 7.1.0","+\t *","+\t * @param mixed      $input   Raw input extracted from the request.","+\t * @param WP_Ability $ability The ability being executed.","+\t * @return mixed Coerced input, or the raw input when it cannot be safely coerced.","+\t */","+\tprivate function coerce_input_to_schema( $input, WP_Ability $ability ) {","+\t\tif ( null === $input ) {","+\t\t\treturn $input;","+\t\t}","+","+\t\t$schema = $ability->get_input_schema();","+\t\tif ( empty( $schema ) ) {","+\t\t\treturn $input;","+\t\t}","+","+\t\t/*","+\t\t * Only coerce input that already validates. Sanitizing invalid input can silently","+\t\t * change which values are accepted -- `additionalProperties: false` strips unknown","+\t\t * keys, and a non-numeric string casts to 0 -- so leaving invalid input untouched","+\t\t * lets validate_input() reject it exactly as it does without coercion.","+\t\t *","+\t\t * validate_input() is asked rather than rest_validate_value_from_schema() so that the","+\t\t * `wp_ability_validate_input` filter decides what counts as valid here as well. A filter","+\t\t * that overrides a schema failure accepts the input, so the input is coerced; a filter","+\t\t * that rejects otherwise valid input leaves it untouched for validate_input() to report.","+\t\t */","+\t\tif ( is_wp_error( $ability->validate_input( $input ) ) ) {","+\t\t\treturn $input;","+\t\t}","+","+\t\t$sanitized = rest_sanitize_value_from_schema( $input, $schema, 'input' );","+","+\t\t/*","+\t\t * Sanitizing can still surface an error the lenient validation above did not, such as","+\t\t * items that are unique as strings but collide once cast to integers (`uniqueItems`).","+\t\t * The error may be returned at the top level or nested inside the returned array, so","+\t\t * scan recursively and fall back to the raw input on any error.","+\t\t */","+\t\tif ( $this->input_contains_error( $sanitized ) ) {","+\t\t\treturn $input;","+\t\t}","+","+\t\treturn $sanitized;","+\t}","+","+\t/**","+\t * Determines whether a sanitized value is, or contains, a WP_Error.","+\t *","+\t * @since 7.1.0","+\t *","+\t * @param mixed $value The value to inspect.","+\t * @return bool True if the value is, or contains, a WP_Error.","+\t */","+\tprivate function input_contains_error( $value ): bool {","+\t\tif ( is_wp_error( $value ) ) {","+\t\t\treturn true;","+\t\t}","+","+\t\tif ( is_array( $value ) ) {","+\t\t\tforeach ( $value as $item ) {","+\t\t\t\tif ( $this->input_contains_error( $item ) ) {","+\t\t\t\t\treturn true;","+\t\t\t\t}","+\t\t\t}","+\t\t}","+","+\t\treturn false;","+\t}","+"," \t/**"," \t * Retrieves the arguments for ability execution endpoint."," \t *","@@ -233,9 +339,10 @@ private function get_input_from_request( $request ) {"," \tpublic function get_run_args(): array {"," \t\treturn array("," \t\t\t'input' => array(","-\t\t\t\t'description' => __( 'Input parameters for the ability execution.' ),","-\t\t\t\t'type'        => array( 'integer', 'number', 'boolean', 'string', 'array', 'object', 'null' ),","-\t\t\t\t'default'     => null,","+\t\t\t\t'description'       => __( 'Input parameters for the ability execution.' ),","+\t\t\t\t'type'              => array( 'integer', 'number', 'boolean', 'string', 'array', 'object', 'null' ),","+\t\t\t\t'default'           => null,","+\t\t\t\t'sanitize_callback' => array( $this, 'sanitize_input_for_ability' ),"," \t\t\t),"," \t\t);"," \t}"],"additions":110,"deletions":3,"truncated":false},{"path":"tests/phpunit/tests/rest-api/wpRestAbilitiesV1RunController.php","lines":["@@ -1386,4 +1386,509 @@ public function test_options_method_handling(): void {"," \t\t// OPTIONS requests return 200 with allowed methods"," \t\t$this->assertEquals( 200, $response->get_status() );"," \t}","+","+\t/**","+\t * Registers an ability that reflects the received input value back to the caller.","+\t *","+\t * The execute callback returns the received input under `value`, so a test can assert","+\t * the exact value and PHP type the ability received, whether it is a scalar, an array, or an","+\t * object of fields.","+\t *","+\t * @param string $name         Ability name.","+\t * @param array  $input_schema Input schema for the ability.","+\t * @param array  $annotations  Optional. Ability annotations. Defaults to a read-only ability","+\t *                             (GET). Pass an empty array for a POST ability.","+\t */","+\tprivate function register_reflecting_ability( string $name, array $input_schema, array $annotations = array( 'readonly' => true ) ): void {","+\t\t$this->register_test_ability(","+\t\t\t$name,","+\t\t\tarray(","+\t\t\t\t'label'               => 'Reflecting Ability',","+\t\t\t\t'description'         => 'Reflects the received input value.',","+\t\t\t\t'category'            => 'general',","+\t\t\t\t'input_schema'        => $input_schema,","+\t\t\t\t'execute_callback'    => static function ( $input ) {","+\t\t\t\t\treturn array( 'value' => $input );","+\t\t\t\t},","+\t\t\t\t'permission_callback' => '__return_true',","+\t\t\t\t'meta'                => array(","+\t\t\t\t\t'annotations'  => $annotations,","+\t\t\t\t\t'show_in_rest' => true,","+\t\t\t\t),","+\t\t\t)","+\t\t);","+\t}","+","+\t/**","+\t * Dispatches a run request for an ability, nesting the value under the `input` parameter.","+\t *","+\t * GET and DELETE send the input as query parameters, POST sends it as a JSON body. Pass","+\t * `null` to send no input at all.","+\t *","+\t * @param string $method HTTP method.","+\t * @param string $name   Ability name.","+\t * @param mixed  $input  Optional. Input value, or null to send no input. Default null.","+\t * @return WP_REST_Response The dispatched response.","+\t */","+\tprivate function dispatch_run( string $method, string $name, $input = null ) {","+\t\t$request = new WP_REST_Request( $method, \"/wp-abilities/v1/abilities/{$name}/run\" );","+","+\t\tif ( null !== $input ) {","+\t\t\tif ( in_array( $method, array( 'GET', 'DELETE' ), true ) ) {","+\t\t\t\t$request->set_query_params( array( 'input' => $input ) );","+\t\t\t} else {","+\t\t\t\t$request->set_header( 'Content-Type', 'application/json' );","+\t\t\t\t$request->set_body( wp_json_encode( array( 'input' => $input ) ) );","+\t\t\t}","+\t\t}","+","+\t\treturn $this->server->dispatch( $request );","+\t}","+","+\t/**","+\t * Data provider for input coerced to the ability input schema over a GET request.","+\t *","+\t * Covers fields nested inside an object as well as a top-level scalar or array input.","+\t *","+\t * @return array<string, array{0: array, 1: mixed, 2: mixed}> Schema, raw input, and the","+\t *                                                            expected coerced value.","+\t */","+\tpublic function data_input_is_coerced(): array {","+\t\t$object_schema = array(","+\t\t\t'type'       => 'object',","+\t\t\t'properties' => array(","+\t\t\t\t'count' => array( 'type' => 'integer' ),","+\t\t\t\t'flag'  => array( 'type' => 'boolean' ),","+\t\t\t\t'tags'  => array(","+\t\t\t\t\t'type'  => 'array',","+\t\t\t\t\t'items' => array( 'type' => 'string' ),","+\t\t\t\t),","+\t\t\t),","+\t\t);","+","+\t\t$tags_object_schema = array(","+\t\t\t'type'       => 'object',","+\t\t\t'properties' => array(","+\t\t\t\t'tags' => array(","+\t\t\t\t\t'type'  => 'array',","+\t\t\t\t\t'items' => array( 'type' => 'string' ),","+\t\t\t\t),","+\t\t\t),","+\t\t);","+","+\t\t// Two-mode schema mirroring real read abilities: select by id, or return a collection.","+\t\t$one_of_schema = array(","+\t\t\t'type'  => 'object',","+\t\t\t'oneOf' => array(","+\t\t\t\tarray(","+\t\t\t\t\t'title'                => 'by_id',","+\t\t\t\t\t'type'                 => 'object',","+\t\t\t\t\t'properties'           => array(","+\t\t\t\t\t\t'id' => array( 'type' => 'integer' ),","+\t\t\t\t\t),","+\t\t\t\t\t'required'             => array( 'id' ),","+\t\t\t\t\t'additionalProperties' => false,","+\t\t\t\t),","+\t\t\t\tarray(","+\t\t\t\t\t'title'                => 'collection',","+\t\t\t\t\t'type'                 => 'object',","+\t\t\t\t\t'properties'           => array(","+\t\t\t\t\t\t'per_page' => array( 'type' => 'integer' ),","+\t\t\t\t\t\t'fields'   => array(","+\t\t\t\t\t\t\t'type'  => 'array',","+\t\t\t\t\t\t\t'items' => array( 'type' => 'string' ),","+\t\t\t\t\t\t),","+\t\t\t\t\t),","+\t\t\t\t\t'required'             => array( 'per_page' ),","+\t\t\t\t\t'additionalProperties' => false,","+\t\t\t\t),","+\t\t\t),","+\t\t);","+","+\t\t// Object nested two levels deep, to confirm coercion walks `properties` recursively.","+\t\t$deep_schema = array(","+\t\t\t'type'       => 'object',","+\t\t\t'properties' => array(","+\t\t\t\t'a' => array(","+\t\t\t\t\t'type'       => 'object',","+\t\t\t\t\t'properties' => array(","+\t\t\t\t\t\t'b' => array(","+\t\t\t\t\t\t\t'type'       => 'object',","+\t\t\t\t\t\t\t'properties' => array(","+\t\t\t\t\t\t\t\t'id'    => array( 'type' => 'integer' ),","+\t\t\t\t\t\t\t\t'is_ok' => array( 'type' => 'boolean' ),","+\t\t\t\t\t\t\t\t'parts' => array(","+\t\t\t\t\t\t\t\t\t'type'  => 'array',","+\t\t\t\t\t\t\t\t\t'items' => array( 'type' => 'string' ),","+\t\t\t\t\t\t\t\t),","+\t\t\t\t\t\t\t),","+\t\t\t\t\t\t),","+\t\t\t\t\t),","+\t\t\t\t),","+\t\t\t),","+\t\t);","+","+\t\treturn array(","+\t\t\t// Fields nested inside an object.","+\t\t\t'object integer field'           => array(","+\t\t\t\t$object_schema,","+\t\t\t\tarray( 'count' => '10' ),","+\t\t\t\tarray( 'count' => 10 ),","+\t\t\t),","+\t\t\t'object boolean true'            => array(","+\t\t\t\t$object_schema,","+\t\t\t\tarray( 'flag' => 'true' ),","+\t\t\t\tarray( 'flag' => true ),","+\t\t\t),","+\t\t\t'object boolean false'           => array(","+\t\t\t\t$object_schema,","+\t\t\t\tarray( 'flag' => 'false' ),","+\t\t\t\tarray( 'flag' => false ),","+\t\t\t),","+\t\t\t'object comma-separated array'   => array(","+\t\t\t\t$object_schema,","+\t\t\t\tarray( 'tags' => 'a,b' ),","+\t\t\t\tarray( 'tags' => array( 'a', 'b' ) ),","+\t\t\t),","+\t\t\t'object all fields at once'      => array(","+\t\t\t\t$object_schema,","+\t\t\t\tarray(","+\t\t\t\t\t'count' => '10',","+\t\t\t\t\t'flag'  => 'true',","+\t\t\t\t\t'tags'  => 'a,b',","+\t\t\t\t),","+\t\t\t\tarray(","+\t\t\t\t\t'count' => 10,","+\t\t\t\t\t'flag'  => true,","+\t\t\t\t\t'tags'  => array( 'a', 'b' ),","+\t\t\t\t),","+\t\t\t),","+\t\t\t'object bracket array preserved' => array(","+\t\t\t\t$tags_object_schema,","+\t\t\t\tarray( 'tags' => array( 'a', 'b' ) ),","+\t\t\t\tarray( 'tags' => array( 'a', 'b' ) ),","+\t\t\t),","+\t\t\t'oneOf id mode'                  => array(","+\t\t\t\t$one_of_schema,","+\t\t\t\tarray( 'id' => '5' ),","+\t\t\t\tarray( 'id' => 5 ),","+\t\t\t),","+\t\t\t'oneOf collection mode'          => array(","+\t\t\t\t$one_of_schema,","+\t\t\t\tarray(","+\t\t\t\t\t'per_page' => '2',","+\t\t\t\t\t'fields'   => 'id,name',","+\t\t\t\t),","+\t\t\t\tarray(","+\t\t\t\t\t'per_page' => 2,","+\t\t\t\t\t'fields'   => array( 'id', 'name' ),","+\t\t\t\t),","+\t\t\t),","+\t\t\t'deeply nested object'           => array(","+\t\t\t\t$deep_schema,","+\t\t\t\tarray(","+\t\t\t\t\t'a' => array(","+\t\t\t\t\t\t'b' => array(","+\t\t\t\t\t\t\t'id'    => '22',","+\t\t\t\t\t\t\t'is_ok' => 'true',","+\t\t\t\t\t\t\t'parts' => 'x,y',","+\t\t\t\t\t\t),","+\t\t\t\t\t),","+\t\t\t\t),","+\t\t\t\tarray(","+\t\t\t\t\t'a' => array(","+\t\t\t\t\t\t'b' => array(","+\t\t\t\t\t\t\t'id'    => 22,","+\t\t\t\t\t\t\t'is_ok' => true,","+\t\t\t\t\t\t\t'parts' => array( 'x', 'y' ),","+\t\t\t\t\t\t),","+\t\t\t\t\t),","+\t\t\t\t),","+\t\t\t),","+","+\t\t\t// Top-level (non-object) input.","+\t\t\t'top-level integer'              => array( array( 'type' => 'integer' ), '10', 10 ),","+\t\t\t'top-level number'               => array( array( 'type' => 'number' ), '3.5', 3.5 ),","+\t\t\t'top-level boolean true'         => array( array( 'type' => 'boolean' ), 'true', true ),","+\t\t\t'top-level boolean false'        => array( array( 'type' => 'boolean' ), 'false', false ),","+\t\t\t'top-level string unchanged'     => array( array( 'type' => 'string' ), 'hello', 'hello' ),","+\t\t\t// A numeric string against a `string` schema must stay a string, not become an integer.","+\t\t\t'numeric string stays string'    => array( array( 'type' => 'string' ), '10', '10' ),","+\t\t\t'top-level array of integers'    => array(","+\t\t\t\tarray(","+\t\t\t\t\t'type'  => 'array',","+\t\t\t\t\t'items' => array( 'type' => 'integer' ),","+\t\t\t\t),","+\t\t\t\t'1,2,3',","+\t\t\t\tarray( 1, 2, 3 ),","+\t\t\t),","+\t\t);","+\t}","+","+\t/**","+\t * Tests that GET input is coerced to the types declared in the ability input schema.","+\t *","+\t * PHP delivers every scalar in a GET query string as a string (\"10\", \"true\") and a","+\t * comma-separated list as a single string, so the whole input must arrive natively typed,","+\t * whether it is a field nested in an object or a top-level scalar or array.","+\t *","+\t * @ticket 65594","+\t *","+\t * @dataProvider data_input_is_coerced","+\t *","+\t * @param array $schema   Ability input schema.","+\t * @param mixed $input    Raw input as delivered over a GET query string.","+\t * @param mixed $expected Expected input value after coercion.","+\t */","+\tpublic function test_get_input_is_coerced( array $schema, $input, $expected ): void {","+\t\t$this->register_reflecting_ability( 'test/coerced-input', $schema );","+","+\t\t$response = $this->dispatch_run( 'GET', 'test/coerced-input', $input );","+\t\t$this->assertSame( 200, $response->get_status() );","+\t\t$this->assertSame( $expected, $response->get_data()['value'] );","+\t}","+","+\t/**","+\t * Data provider for input that coercion must not rescue.","+\t *","+\t * @return array<string, array{0: array, 1: array}> Schema and the invalid raw input.","+\t */","+\tpublic function data_invalid_input_returns_400(): array {","+\t\t$schema = array(","+\t\t\t'type'                 => 'object',","+\t\t\t'properties'           => array(","+\t\t\t\t'count' => array( 'type' => 'integer' ),","+\t\t\t),","+\t\t\t'additionalProperties' => false,","+\t\t);","+","+\t\treturn array(","+\t\t\t// An unknown property must still be rejected, not silently stripped.","+\t\t\t'unknown property under additionalProperties:false' => array(","+\t\t\t\t$schema,","+\t\t\t\tarray(","+\t\t\t\t\t'count'   => '10',","+\t\t\t\t\t'unknown' => 'x',","+\t\t\t\t),","+\t\t\t),","+\t\t\t// A non-numeric string must still be rejected, not coerced to 0.","+\t\t\t'non-numeric string for an integer' => array(","+\t\t\t\t$schema,","+\t\t\t\tarray( 'count' => 'not-a-number' ),","+\t\t\t),","+\t\t);","+\t}","+","+\t/**","+\t * Tests that coercion never rescues otherwise-invalid input.","+\t *","+\t * Sanitizing invalid input could silently change what is accepted, so coercion runs only on","+\t * input that already validates. Invalid input therefore still returns the authoritative","+\t * `ability_invalid_input` (400) from validation.","+\t *","+\t * @ticket 65594","+\t *","+\t * @dataProvider data_invalid_input_returns_400","+\t *","+\t * @param array $schema Ability input schema.","+\t * @param array $input  Invalid raw input that must not be coerced.","+\t */","+\tpublic function test_invalid_input_returns_400( array $schema, array $input ): void {","+\t\t$this->register_reflecting_ability( 'test/strict-typed-input', $schema );","+","+\t\t$response = $this->dispatch_run( 'GET', 'test/strict-typed-input', $input );","+","+\t\t$this->assertSame( 400, $response->get_status() );","+\t\t$this->assertSame( 'ability_invalid_input', $response->get_data()['code'] );","+\t}","+","+\t/**","+\t * Tests that `validate_input()` decides what gets coerced, filters included.","+\t *","+\t * Coercion gates on `validate_input()`, not the raw schema, so a `wp_ability_validate_input`","+\t * filter that accepts input the schema rejects makes that input coerced too.","+\t *","+\t * @ticket 65594","+\t */","+\tpublic function test_validate_input_filter_override_still_coerces(): void {","+\t\t$this->register_reflecting_ability(","+\t\t\t'test/filtered-typed-input',","+\t\t\tarray(","+\t\t\t\t'type'       => 'object',","+\t\t\t\t'properties' => array(","+\t\t\t\t\t'count' => array(","+\t\t\t\t\t\t'type'    => 'integer',","+\t\t\t\t\t\t'minimum' => 100,","+\t\t\t\t\t),","+\t\t\t\t),","+\t\t\t)","+\t\t);","+","+\t\t// Below `minimum`, so the schema rejects it.","+\t\t$input = array( 'count' => '10' );","+","+\t\t$response = $this->dispatch_run( 'GET', 'test/filtered-typed-input', $input );","+\t\t$this->assertSame( 400, $response->get_status(), 'Schema validation should reject the input on its own.' );","+\t\t$this->assertSame( 'ability_invalid_input', $response->get_data()['code'] );","+","+\t\t// A filter that accepts the input makes it valid, so it must also be coerced.","+\t\tadd_filter( 'wp_ability_validate_input', '__return_true' );","+","+\t\t$response = $this->dispatch_run( 'GET', 'test/filtered-typed-input', $input );","+\t\t$this->assertSame( 200, $response->get_status() );","+\t\t$this->assertSame( array( 'count' => 10 ), $response->get_data()['value'], 'Input a validation filter accepts should be coerced.' );","+\t}","+","+\t/**","+\t * Tests that already-typed POST input is unchanged by coercion.","+\t *","+\t * JSON delivers native types, so coercion is a near no-op for POST. Applying it uniformly","+\t * keeps GET and POST consistent without altering already-typed values.","+\t *","+\t * @ticket 65594","+\t */","+\tpublic function test_post_typed_input_is_unchanged(): void {","+\t\t// An empty annotations array registers a POST (non-read-only) ability.","+\t\t$this->register_reflecting_ability(","+\t\t\t'test/typed-input-post',","+\t\t\tarray(","+\t\t\t\t'type'       => 'object',","+\t\t\t\t'properties' => array(","+\t\t\t\t\t'count' => array( 'type' => 'integer' ),","+\t\t\t\t\t'flag'  => array( 'type' => 'boolean' ),","+\t\t\t\t\t'tags'  => array(","+\t\t\t\t\t\t'type'  => 'array',","+\t\t\t\t\t\t'items' => array( 'type' => 'string' ),","+\t\t\t\t\t),","+\t\t\t\t),","+\t\t\t),","+\t\t\tarray()","+\t\t);","+","+\t\t$response = $this->dispatch_run(","+\t\t\t'POST',","+\t\t\t'test/typed-input-post',","+\t\t\tarray(","+\t\t\t\t'count' => 10,","+\t\t\t\t'flag'  => true,","+\t\t\t\t'tags'  => array( 'a', 'b' ),","+\t\t\t)","+\t\t);","+\t\t$this->assertSame( 200, $response->get_status() );","+\t\t$this->assertSame(","+\t\t\tarray(","+\t\t\t\t'count' => 10,","+\t\t\t\t'flag'  => true,","+\t\t\t\t'tags'  => array( 'a', 'b' ),","+\t\t\t),","+\t\t\t$response->get_data()['value']","+\t\t);","+\t}","+","+\t/**","+\t * Tests that an ability without an input schema is unaffected by coercion.","+\t *","+\t * @ticket 65594","+\t */","+\tpublic function test_input_without_schema_passes_through(): void {","+\t\t$this->register_test_ability(","+\t\t\t'test/no-input-schema',","+\t\t\tarray(","+\t\t\t\t'label'               => 'No Input Schema',","+\t\t\t\t'description'         => 'Executes without an input schema.',","+\t\t\t\t'category'            => 'general',","+\t\t\t\t'execute_callback'    => static function () {","+\t\t\t\t\treturn array( 'ran' => true );","+\t\t\t\t},","+\t\t\t\t'permission_callback' => '__return_true',","+\t\t\t\t'meta'                => array(","+\t\t\t\t\t'annotations'  => array( 'readonly' => true ),","+\t\t\t\t\t'show_in_rest' => true,","+\t\t\t\t),","+\t\t\t)","+\t\t);","+","+\t\t$response = $this->dispatch_run( 'GET', 'test/no-input-schema' );","+","+\t\t$this->assertSame( 200, $response->get_status() );","+\t\t$this->assertTrue( $response->get_data()['ran'] );","+\t}","+","+\t/**","+\t * Tests that the permission callback receives natively typed input.","+\t *","+\t * Coercion runs before `check_ability_permissions()`, so an ability that inspects its input","+\t * during the permission check sees the coerced integer, not the raw \"10\" string the GET query","+\t * string delivered. The gate runs first, so the first recorded type is the one it acted on.","+\t *","+\t * @ticket 65594","+\t */","+\tpublic function test_permission_callback_receives_typed_input(): void {","+\t\t$seen        = new stdClass();","+\t\t$seen->types = array();","+","+\t\t$this->register_test_ability(","+\t\t\t'test/permission-typed-input',","+\t\t\tarray(","+\t\t\t\t'label'               => 'Permission Typed Input',","+\t\t\t\t'description'         => 'Records the type the permission callback receives.',","+\t\t\t\t'category'            => 'general',","+\t\t\t\t'input_schema'        => array(","+\t\t\t\t\t'type'       => 'object',","+\t\t\t\t\t'properties' => array(","+\t\t\t\t\t\t'count' => array( 'type' => 'integer' ),","+\t\t\t\t\t),","+\t\t\t\t),","+\t\t\t\t'permission_callback' => static function ( $input ) use ( $seen ) {","+\t\t\t\t\t$seen->types[] = gettype( $input['count'] );","+\t\t\t\t\treturn true;","+\t\t\t\t},","+\t\t\t\t'execute_callback'    => static function ( $input ) {","+\t\t\t\t\treturn $input;","+\t\t\t\t},","+\t\t\t\t'meta'                => array(","+\t\t\t\t\t'annotations'  => array( 'readonly' => true ),","+\t\t\t\t\t'show_in_rest' => true,","+\t\t\t\t),","+\t\t\t)","+\t\t);","+","+\t\t$response = $this->dispatch_run( 'GET', 'test/permission-typed-input', array( 'count' => '10' ) );","+","+\t\t$this->assertSame( 200, $response->get_status() );","+\t\t$this->assertNotEmpty( $seen->types, 'The permission callback should have run.' );","+\t\t$this->assertSame( 'integer', $seen->types[0], 'The REST permission gate should receive coerced (typed) input, not a raw string.' );","+\t\t$this->assertSame( array( 'count' => 10 ), $response->get_data(), 'The execute callback should receive coerced input too.' );","+\t}","+","+\t/**","+\t * Tests that a value which only fails validation once coerced falls back to the raw input.","+\t *","+\t * `[\"1\", \"01\"]` is unique as strings but collides once cast to integers, so it cannot be","+\t * coerced without producing a `uniqueItems` error. The raw input is kept instead, so","+\t * validation still accepts it and no `WP_Error` reaches the ability.","+\t *","+\t * @ticket 65594","+\t */","+\tpublic function test_nested_sanitize_error_falls_back_to_raw_input(): void {","+\t\t$this->register_reflecting_ability(","+\t\t\t'test/unique-items-input',","+\t\t\tarray(","+\t\t\t\t'type'       => 'object',","+\t\t\t\t'properties' => array(","+\t\t\t\t\t'include' => array(","+\t\t\t\t\t\t'type'        => 'array',","+\t\t\t\t\t\t'items'       => array( 'type' => 'integer' ),","+\t\t\t\t\t\t'uniqueItems' => true,","+\t\t\t\t\t),","+\t\t\t\t),","+\t\t\t)","+\t\t);","+","+\t\t$response = $this->dispatch_run( 'GET', 'test/unique-items-input', array( 'include' => array( '1', '01' ) ) );","+","+\t\t// Accepted (unique as strings) and the ability received the raw values, not a WP_Error.","+\t\t$this->assertSame( 200, $response->get_status() );","+\t\t$this->assertSame( array( 'include' => array( '1', '01' ) ), $response->get_data()['value'] );","+\t}"," }",""],"additions":505,"deletions":0,"truncated":false}],"additions":615,"deletions":3,"truncated":false,"file_count":2},"error":null,"fetched_at":"2026-07-10T10:53:40.574953+00:00"}