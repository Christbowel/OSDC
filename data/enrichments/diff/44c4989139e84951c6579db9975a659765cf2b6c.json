{"id":"44c4989139e84951c6579db9975a659765cf2b6c","axis":"silent","repo":"withastro/astro","sha":"44c4989139e84951c6579db9975a659765cf2b6c","parsed":{"files":[{"path":".changeset/lovely-nights-stay.md","lines":["@@ -0,0 +1,38 @@","+---","+'astro': minor","+---","+","+Adds support for the more specific CSP directives `script-src-elem`, `script-src-attr`, `style-src-elem`, and `style-src-attr` through a new `kind` option.","+","+Previously, [`CSP`](https://docs.astro.build/en/reference/configuration-reference/#securitycsp) was only scoped to generic `script-src`/`style-src` directives. Now each source or hash can be scoped to a narrower directive — for example, to allow inline `style` attributes (such as those from `define:vars` or Shiki) without loosening the policy for your `<style>` and `<link>` elements.","+","+#### Scoping sources and hashes in your config","+","+Each entry in `resources` and `hashes` can be an object with a `kind` property. Depending on whether you use `scriptDirective` or `styleDirective`, `\"element\"` targets `script-src-elem` or `style-src-elem`, `\"attribute\"` targets `script-src-attr` or `style-src-attr`, and `\"default\"` (the same as a bare string or hash) targets `script-src` or `style-src`.","+","+```js","+// astro.config.mjs","+import { defineConfig } from 'astro/config';","+","+export default defineConfig({","+  security: {","+    csp: {","+      scriptDirective: {","+        resources: [{ resource: 'https://cdn.example.com', kind: 'element' }],","+      },","+      styleDirective: {","+        resources: [{ resource: \"'unsafe-inline'\", kind: 'attribute' }],","+      },","+    },","+  },","+});","+```","+","+#### Scoping at runtime","+","+The same `kind` option is available on the runtime CSP API, where the existing methods now also accept an object:","+","+```js","+ctx.csp.insertScriptResource({ resource: 'https://cdn.example.com', kind: 'element' });","+ctx.csp.insertStyleResource({ resource: \"'unsafe-inline'\", kind: 'attribute' });","+```"],"additions":38,"deletions":0,"truncated":false},{"path":"packages/astro/src/core/app/types.ts","lines":["@@ -14,7 +14,7 @@ import type {"," \tSSRResult,"," } from '../../types/public/internal.js';"," import type { SinglePageBuiltModule } from '../build/types.js';","-import type { CspDirective } from '../csp/config.js';","+import type { CspDirective, CspHashEntry, CspResourceEntry } from '../csp/config.js';"," import type {"," \tAstroLoggerDestination,"," \tAstroLoggerLevel,","@@ -170,15 +170,49 @@ export type SSRManifestI18n = {"," \tdomains: Record<string, string> | undefined;"," };"," ","+/**","+ * The CSP section of the manifest. It mirrors the `security.csp` config: `directives` plus a","+ * `scriptDirective`/`styleDirective`, each holding `resources`/`hashes` entries that carry their","+ * `kind` (`default`/`element`/`attribute`). The `kind` is only interpreted at render time. Astro's","+ * generated hashes are appended to the relevant `hashes` array as `default`-kind entries.","+ */"," export type SSRManifestCSP = {"," \tcspDestination: 'adapter' | 'meta' | 'header' | undefined;"," \talgorithm: CspAlgorithm;","+\tdirectives: CspDirective[];","+\t/**","+\t * @deprecated Use {@linkcode scriptDirective} instead. Holds the `default`-kind `script-src`","+\t * hashes (the same values `scriptDirective.hashes` carries with `kind: \"default\"`).","+\t */"," \tscriptHashes: string[];","+\t/**","+\t * @deprecated Use {@linkcode scriptDirective} instead. Holds the `default`-kind `script-src`","+\t * resources.","+\t */"," \tscriptResources: string[];","+\t/**","+\t * @deprecated Use {@linkcode scriptDirective}'s `strictDynamic` instead.","+\t */"," \tisStrictDynamic: boolean;","+\t/**","+\t * @deprecated Use {@linkcode styleDirective} instead. Holds the `default`-kind `style-src`","+\t * hashes.","+\t */"," \tstyleHashes: string[];","+\t/**","+\t * @deprecated Use {@linkcode styleDirective} instead. Holds the `default`-kind `style-src`","+\t * resources.","+\t */"," \tstyleResources: string[];","-\tdirectives: CspDirective[];","+\tscriptDirective: {","+\t\tresources: CspResourceEntry[];","+\t\thashes: CspHashEntry[];","+\t\tstrictDynamic: boolean;","+\t};","+\tstyleDirective: {","+\t\tresources: CspResourceEntry[];","+\t\thashes: CspHashEntry[];","+\t};"," };"," "," export interface SSRManifestSession extends BaseSessionConfig {"],"additions":36,"deletions":2,"truncated":false},{"path":"packages/astro/src/core/build/index.ts","lines":["@@ -29,7 +29,7 @@ import { collectPagesData } from './page-data.js';"," import { viteBuild } from './static-build.js';"," import type { StaticBuildOptions } from './types.js';"," import { getTimeStat } from './util.js';","-import { warnIfCspWithShiki } from '../messages/runtime.js';","+import { warnIfCspResourceFallbackShadowing, warnIfCspWithShiki } from '../messages/runtime.js';"," "," interface BuildOptions {"," \t/**","@@ -57,6 +57,7 @@ export default async function build("," \ttelemetry.record(eventCliSession('build', userConfig));"," "," \twarnIfCspWithShiki(astroConfig, logger);","+\twarnIfCspResourceFallbackShadowing(astroConfig, logger);"," "," \tconst settings = await createSettings("," \t\tastroConfig,"],"additions":2,"deletions":1,"truncated":false},{"path":"packages/astro/src/core/build/plugins/plugin-manifest.ts","lines":["@@ -27,6 +27,7 @@ import {"," \ttrackScriptHashes,"," \ttrackStyleHashes,"," } from '../../csp/common.js';","+import { partitionByKind } from '../../csp/runtime.js';"," import { encodeKey } from '../../encryption.js';"," import { fileExtension, joinPaths, prependForwardSlash } from '../../path.js';"," import { DEFAULT_COMPONENTS } from '../../routing/default.js';","@@ -308,26 +309,45 @@ async function buildManifest("," \tlet csp: SSRManifestCSP | undefined = undefined;"," "," \tif (shouldTrackCspHashes(settings.config.security.csp)) {","-\t\tconst algorithm = getAlgorithm(settings.config.security.csp);","+\t\tconst cspConfig = settings.config.security.cs