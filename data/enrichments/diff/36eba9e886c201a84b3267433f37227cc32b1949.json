 ctx.Err()","+\t\tcase update, ok := <-loopbackUpdateCh:","+\t\t\tif !ok {","+\t\t\t\treturn nil","+\t\t\t}","+\t\t\tif update.TargetApplierID == c.localApplierID {","+\t\t\t\tselect {","+\t\t\t\tcase <-ctx.Done():","+\t\t\t\t\treturn ctx.Err()","+\t\t\t\tcase c.receiveCh <- update:","+\t\t\t\t}","+\t\t\t} else {","+\t\t\t\tselect {","+\t\t\t\tcase <-ctx.Done():","+\t\t\t\t\treturn ctx.Err()","+\t\t\t\tcase c.outCh <- DepResolverEvent{","+\t\t\t\t\tTargetApplierID: update.TargetApplierID,","+\t\t\t\t\tEvent: txnpb.LDRDepResolverEvent{","+\t\t\t\t\t\tEvent: &txnpb.LDRDepResolverEvent_ForwardUpdate{","+\t\t\t\t\t\t\tForwardUpdate: &txnpb.DepResolverForwardUpdate{","+\t\t\t\t\t\t\t\tTxnID:        update.TxnID,","+\t\t\t\t\t\t\t\tResolvedTime: update.ResolvedTime,","+\t\t\t\t\t\t\t},","+\t\t\t\t\t\t},","+\t\t\t\t\t},","+\t\t\t\t}:","+\t\t\t\t}","+\t\t\t}","+\t\t}","+\t}"," }"],"additions":168,"deletions":80,"truncated":false},{"path":"pkg/crosscluster/logical/txnapply/test_tracker_client.go","lines":["@@ -0,0 +1,169 @@","+// Copyright 2026 The Cockroach Authors.","+//","+// Use of this software is governed by the CockroachDB Software License","+// included in the /LICENSE file.","+","+package txnapply","+","+import (","+\t\"context\"","+","+\t\"github.com/cockroachdb/cockroach/pkg/crosscluster/logical/ldrdecoder\"","+\t\"github.com/cockroachdb/cockroach/pkg/crosscluster/logical/txnpb\"","+\t\"github.com/cockroachdb/cockroach/pkg/util/ctxgroup\"","+\t\"github.com/cockroachdb/cockroach/pkg/util/hlc\"","+\t\"github.com/cockroachdb/errors\"","+)","+","+// testTrackerClient wraps per-applier DistDepResolverClients and","+// TrackerServers, simulating the DistSQL dep resolver processor's event","+// routing in-process. Each applier's outCh events are routed to the correct","+// TrackerServer; resulting updates are delivered through loopback channels","+// to RunBackchannelForwarder goroutines, which handle local delivery and","+// remote forwarding -- mirroring the production data path exactly.","+type testTrackerClient struct {","+\tclients   map[ldrdecoder.ApplierID]*DistDepResolverClient","+\tservers   map[ldrdecoder.ApplierID]*TrackerServer","+\tloopbacks map[ldrdecoder.ApplierID]chan DependencyUpdate","+}","+","+// NewTestDependencyTrackerClient creates a DependencyResolverClient backed by","+// per-applier DistDepResolverClients wired to TrackerServers via in-process","+// routing goroutines. The caller must cancel ctx to stop the background","+// goroutines and then call the returned cleanup function to wait for them to","+// exit and check for errors.","+func NewTestDependencyTrackerClient(","+\tctx context.Context, appliers []ldrdecoder.ApplierID,","+) (DependencyResolverClient, func() error) {","+\tclients := make(map[ldrdecoder.ApplierID]*DistDepResolverClient, len(appliers))","+\tservers := make(map[ldrdecoder.ApplierID]*TrackerServer, len(appliers))","+\tloopbacks := make(map[ldrdecoder.ApplierID]chan DependencyUpdate, len(appliers))","+","+\tfor _, id := range appliers {","+\t\tclients[id] = NewDistDepResolverClient(id)","+\t\tservers[id] = NewTrackerServer()","+\t\tloopbacks[id] = make(chan DependencyUpdate, 1000)","+\t}","+","+\tt := &testTrackerClient{clients: clients, servers: servers, loopbacks: loopbacks}","+","+\tgrp := ctxgroup.WithContext(ctx)","+\tfor _, id := range appliers {","+\t\tgrp.GoCtx(func(ctx context.Context) error {","+\t\t\treturn clients[id].RunBackchannelForwarder(ctx, loopbacks[id])","+\t\t})","+\t\tgrp.GoCtx(func(ctx context.Context) error {","+\t\t\treturn t.runRouter(ctx, clients[id])","+\t\t})","+\t}","+","+\treturn t, grp.Wait","+}","+","+// runRouter drains events from a single client's OutCh and dispatches them to","+// the correct TrackerServer, delivering resulting updates to the co-located","+// applier's loopback channel.","+func (t *testTrackerClient) runRouter(ctx context.Context, client *DistDepResolverClient) error {","+\tfor {","+\t\tselect {","+\t\tcase <-ctx.Done():","+\t\t\treturn ctx.Err()","+\t\tcase ev, ok := <-client.OutCh():","+\t\t\tif !ok {","+\t\t\t\treturn nil","+\t\t\t}","+\t\t\tif err := t.processEvent(ctx, ev); err != nil {","+\t\t\t\treturn err","+\t\t\t}","+\t\t}","+\t}","+}","+","+// processEvent handles a single DepResolverEvent by dispatching it to the","+// correct TrackerServer and delivering resulting updates to the co-located","+// applier's loopback channel. The RunBackchannelForwarder goroutine then","+// handles local delivery or remote forwarding.","+func (t *testTrackerClient) processEvent(ctx context.Context, ev DepResolverEvent) error {","+\tsendToLoopback := func(","+\t\tcolocatedApplierID ldrdecoder.ApplierID, update DependencyUpdate,","+\t) error {","+\t\tselect {","+\t\tcase <-ctx.Done():","+\t\t\treturn ctx.Err()","+\t\tcase t.loopbacks[colocatedApplierID] <- update:","+\t\t\treturn nil","+\t\t}","+\t}","+\tswitch e := ev.Event.Event.(type) {","+\tcase *txnpb.LDRDepResolverEvent_Wait:","+\t\tserver := t.servers[ev.TargetApplierID]","+\t\tfor _, txn := range e.Wait.WaitTxns {","+\t\t\tresolved, resolvedTime := server.MaybeAddWaiter(txn, e.Wait.WaitingID)","+\t\t\tif resolved {","+\t\t\t\tif err := sendToLoopback(ev.TargetApplierID, DependencyUpdate{","+\t\t\t\t\tTxnID:           txn,","+\t\t\t\t\tResolvedTime:    resolvedTime,","+\t\t\t\t\tTargetApplierID: e.Wait.WaitingID,","+\t\t\t\t}); err != nil {","+\t\t\t\t\treturn err","+\t\t\t\t}","+\t\t\t}","+\t\t}","+\tcase *txnpb.LDRDepResolverEvent_WaitHorizon:","+\t\tserver := t.servers[ev.TargetApplierID]","+\t\tresolved, resolvedTime := server.WaitHorizon(","+\t\t\te.WaitHorizon.WaitingID, e.WaitHorizon.TxnHorizon,","+\t\t)","+\t\tif resolved {","+\t\t\tif err := sendToLoopback(ev.TargetApplierID, DependencyUpdate{","+\t\t\t\tTxnID:           ldrdecoder.TxnID{ApplierID: e.WaitHorizon.DependID},","+\t\t\t\tResolvedTime:    resolvedTime,","+\t\t\t\tTargetApplierID: e.WaitHorizon.WaitingID,","+\t\t\t}); err != nil {","+\t\t\t\treturn err","+\t\t\t}","+\t\t}","+\tcase *txnpb.LDRDepResolverEvent_Ready:","+\t\tserver := t.servers[ev.TargetApplierID]","+\t\tupdates := server.Ready(e.Ready.ReadyTxn, e.Ready.ResolvedTime)","+\t\tfor _, update := range updates {","+\t\t\tif err := sendToLoopback(ev.TargetApplierID, update); err != nil {","+\t\t\t\treturn err","+\t\t\t}","+\t\t}","+\tcase *txnpb.LDRDepResolverEvent_ForwardUpdate:","+\t\tif err := sendToLoopback(ev.TargetApplierID, DependencyUpdate{","+\t\t\tTxnID:           e.ForwardUpdate.TxnID,","+\t\t\tResolvedTime:    e.ForwardUpdate.ResolvedTime,","+\t\t\tTargetApplierID: ev.TargetApplierID,","+\t\t}); err != nil {","+\t\t\treturn err","+\t\t}","+\tdefault:","+\t\treturn errors.AssertionFailedf(\"unknown dep resolver event type: %T\",","+\t\t\tev.Event.Event)","+\t}","+\treturn nil","+}","+","+// Wait implements DependencyResolverClient.","+func (t *testTrackerClient) Wait(waiter ldrdecoder.ApplierID, txns []ldrdecoder.TxnID) {","+\tt.clients[waiter].Wait(waiter, txns)","+}","+","+// WaitHorizon implements DependencyResolverClient.","+func (t *testTrackerClient) WaitHorizon(","+\tapplierID, dependID ldrdecoder.ApplierID, txnHorizon hlc.Timestamp,","+) {","+\tt.clients[applierID].WaitHorizon(applierID, dependID, txnHorizon)","+}","+","+// Ready implements DependencyResolverClient.","+func (t *testTrackerClient) Ready(txn ldrdecoder.TxnID, resolvedTime hlc.Timestamp) {","+\tt.clients[txn.ApplierID].Ready(txn, resolvedTime)","+}","+","+// Receive implements DependencyResolverClient.","+func (t *testTrackerClient) Receive(applier ldrdecoder.ApplierID) <-chan DependencyUpdate {","+\treturn t.clients[applier].Receive(applier)","+}"],"additions":169,"deletions":0,"truncated":false},{"path":"pkg/crosscluster/logical/txnapply/txn_applier.go","lines":["@@ -94,7 +94,7 @@ type Checkpoint struct{ Timestamp hlc.Timestamp }"," // timestamp order."," type Applier struct {"," \tid          ldrdecoder.ApplierID","-\tdepResolver DependencyResolver","+\tdepResolver DependencyResolverClient"," "," 