{"id":"ce500befb5f01f811766d78cdede45ebbad783ef","axis":"silent","repo":"expo/expo","sha":"ce500befb5f01f811766d78cdede45ebbad783ef","parsed":{"files":[{"path":"apps/router-e2e/modules/devtools-e2e/expo-module.config.json","lines":["@@ -0,0 +1,8 @@","+{","+  \"platforms\": [\"devtools\"],","+  \"devtools\": {","+    \"webpageRoot\": \"public\",","+    \"serverEntryPoint\": \"server.mjs\",","+    \"bannerTitle\": \"Banner E2E\"","+  }","+}"],"additions":8,"deletions":0,"truncated":false},{"path":"apps/router-e2e/modules/devtools-e2e/package.json","lines":["@@ -0,0 +1,6 @@","+{","+  \"name\": \"devtools-e2e\",","+  \"version\": \"0.0.0\",","+  \"description\": \"Expo DevTools plugin for E2E tests.\",","+  \"private\": true","+}"],"additions":6,"deletions":0,"truncated":false},{"path":"apps/router-e2e/modules/devtools-e2e/public/index.html","lines":["@@ -0,0 +1,121 @@","+<!doctype html>","+<html lang=\"en\">","+  <head>","+    <meta charset=\"utf-8\" />","+    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />","+    <title>DevTools Plugin</title>","+  </head>","+  <body>","+    <main>","+      <h1>Hello from Expo DevTools</h1>","+      <p>","+        This static page is served from the plugin.","+      </p>","+      <button id=\"call-server\">Call plugin server</button>","+      <pre id=\"server-result\" hidden></pre>","+      <button id=\"open-socket\">Open WebSocket</button>","+      <pre id=\"socket-log\" hidden></pre>","+    </main>","+    <script>","+      const pluginPathname = location.pathname.replace(/\\/$/, '');","+      const button = document.getElementById('call-server');","+      const result = document.getElementById('server-result');","+      button.addEventListener('click', async () => {","+        result.hidden = false;","+        result.textContent = 'Loading…';","+        try {","+          const response = await fetch(`${pluginPathname}/api/hello`);","+          result.textContent = JSON.stringify(await response.json(), null, 2);","+        } catch (error) {","+          result.textContent = String(error);","+        }","+      });","+","+      const socketButton = document.getElementById('open-socket');","+      const socketLog = document.getElementById('socket-log');","+      let socket;","+      socketButton.addEventListener('click', () => {","+        if (socket) {","+          socket.close();","+          return;","+        }","+        socketLog.hidden = false;","+        socketLog.textContent = '';","+        const append = (line) => {","+          socketLog.textContent += `${line}\\n`;","+        };","+        socket = new WebSocket(`${pluginPathname}/ws`);","+        socket.addEventListener('open', () => {","+          append('open');","+          socketButton.textContent = 'Close WebSocket';","+          socket.send('Hello from the webpage!');","+        });","+        socket.addEventListener('message', (event) => append(`message: ${event.data}`));","+        socket.addEventListener('close', () => {","+          append('close');","+          socketButton.textContent = 'Open WebSocket';","+          socket = undefined;","+        });","+        socket.addEventListener('error', () => append('error'));","+      });","+    </script>","+    <style>","+      :root {","+        font-family:","+          system-ui,","+          sans-serif;","+      }","+","+      body {","+        min-height: 100vh;","+        margin: 0;","+        display: grid;","+        place-items: center;","+        background: #f6f7f9;","+        color: #111318;","+      }","+","+      main {","+        width: min(480px, calc(100vw - 48px));","+        padding: 32px;","+        border: 1px solid #d9dde5;","+        border-radius: 8px;","+        background: #fff;","+        box-shadow: 0 12px 30px rgba(18, 22, 30, 0.08);","+      }","+","+      h1 {","+        margin: 0 0 12px;","+        font-size: 28px;","+        line-height: 1.15;","+      }","+","+      p {","+        margin: 0;","+        color: #515866;","+        font-size: 16px;","+        line-height: 1.5;","+      }","+","+      button {","+        margin-top: 16px;","+        padding: 8px 16px;","+        border: 1px solid #d9dde5;","+        border-radius: 6px;","+        background: #f6f7f9;","+        font: inherit;","+        cursor: pointer;","+      }","+","+      pre {","+        margin: 12px 0 0;","+        padding: 12px;","+        border-radius: 6px;","+        background: #f0f1f4;","+        font-size: 13px;","+        white-space: pre-wrap;","+        word-break: break-word;","+      }","+    </style>","+  </body>","+</html>"],"additions":121,"deletions":0,"truncated":false},{"path":"apps/router-e2e/modules/devtools-e2e/server.mjs","lines":["@@ -0,0 +1,27 @@","+export default async function handler(request) {","+  const url = new URL(request.url);","+","+  if (url.pathname === '/api/hello') {","+    return new Response(","+      JSON.stringify({","+        message: `Hello from the plugin server! You sent a ${request.method} request.`,","+        time: new Date().toISOString(),","+      }),","+      { status: 200, headers: { 'Content-Type': 'application/json' } }","+    );","+  }","+","+  // Fallback to static plugin page","+  return null;","+};","+","+export const webSocketHandlers = {","+  '/ws': (socket) => {","+    socket.send(","+      JSON.stringify({ type: 'welcome', message: 'Connected to the Hello World plugin server.' })","+    );","+    socket.on('message', (data) => {","+      socket.send(JSON.stringify({ type: 'echo', message: data.toString() }));","+    });","+  },","+};"],"additions":27,"deletions":0,"truncated":false},{"path":"packages/@expo/cli/e2e/playwright/dev/devtools-e2e.test.ts","lines":["@@ -0,0 +1,87 @@","+import { expect, test } from '@playwright/test';","+import { stripVTControlCharacters } from 'node:util';","+","+import { getRouterE2ERoot } from '../../__tests__/utils';","+import { createExpoStart } from '../../utils/expo';","+import { processCollectOutput } from '../.