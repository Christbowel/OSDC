')).toContain('application/json');","+    await expect(response.json()).resolves.toMatchObject({","+      message: 'Hello from the plugin server! You sent a GET request.',","+    });","+  });","+","+  test('connects and responds over the plugin webpage WebSocket button', async ({ page }) => {","+    await page.goto(new URL(pluginPath, expoStart.url).href);","+","+    await page.getByRole('button', { name: 'Open WebSocket' }).click();","+","+    await expect(page.locator('#socket-log')).toContainText(","+      'message: {\"type\":\"welcome\",\"message\":\"Connected to the Hello World plugin server.\"}'","+    );","+    await expect(page.locator('#socket-log')).toContainText(","+      'message: {\"type\":\"echo\",\"message\":\"Hello from the webpage!\"}'","+    );","+  });","+});"],"additions":87,"deletions":0,"truncated":false},{"path":"packages/@expo/cli/src/events/types.ts","lines":["@@ -1,5 +1,6 @@"," import type { rootEvent } from './index';"," import type { collectEventLoggers } from '../events/builder';","+import type { event as devToolsPluginManagerEvent } from '../start/server/DevToolsPluginManager';"," import type { event as metroBundlerDevServerEvent } from '../start/server/metro/MetroBundlerDevServer';"," import type { event as metroTerminalReporterEvent } from '../start/server/metro/MetroTerminalReporter';"," import type { event as instantiateMetroEvent } from '../start/server/metro/instantiateMetro';","@@ -13,6 +14,7 @@ import type { event as nodeEnvEvent } from '../utils/nodeEnv';"," export type Events = collectEventLoggers<","   [","     typeof rootEvent,","+    typeof devToolsPluginManagerEvent,","     typeof metroBundlerDevServerEvent,","     typeof metroTerminalReporterEvent,","     typeof instantiateMetroEvent,"],"additions":2,"deletions":0,"truncated":false},{"path":"packages/@expo/cli/src/start/interface/__tests__/interactiveActions-test.ts","lines":["@@ -0,0 +1,65 @@","+import { DevToolsPlugin } from '../../server/DevToolsPlugin';","+import { ge