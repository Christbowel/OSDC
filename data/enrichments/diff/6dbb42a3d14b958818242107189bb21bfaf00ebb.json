{"id":"6dbb42a3d14b958818242107189bb21bfaf00ebb","axis":"silent","repo":"elastic/elasticsearch","sha":"6dbb42a3d14b958818242107189bb21bfaf00ebb","parsed":{"files":[{"path":"docs/changelog/146600.yaml","lines":["@@ -0,0 +1,5 @@","+area: ES|QL","+issues: []","+pr: 146600","+summary: Add CRUD REST API for data sources and datasets","+type: enhancement"],"additions":5,"deletions":0,"truncated":false},{"path":"rest-api-spec/src/main/resources/rest-api-spec/api/esql.delete_data_source.json","lines":["@@ -0,0 +1,34 @@","+{","+  \"esql.delete_data_source\": {","+    \"documentation\": {","+      \"url\": \"https://www.elastic.co/docs/api/doc/elasticsearch/operation/operation-esql-data-source-delete\",","+      \"description\": \"Delete one or more ES|QL data sources. Fails with 409 if any dataset references them.\"","+    },","+    \"stability\": \"experimental\",","+    \"visibility\": \"public\",","+    \"headers\": {","+      \"accept\": [","+        \"application/json\"","+      ],","+      \"content_type\": [","+        \"application/json\"","+      ]","+    },","+    \"url\": {","+      \"paths\": [","+        {","+          \"path\": \"/_query/data_source/{name}\",","+          \"methods\": [","+            \"DELETE\"","+          ],","+          \"parts\": {","+            \"name\": {","+              \"type\": \"list\",","+              \"description\": \"A comma-separated list of data sources to delete\"","+            }","+          }","+        }","+      ]","+    }","+  }","+}"],"additions":34,"deletions":0,"truncated":false},{"path":"rest-api-spec/src/main/resources/rest-api-spec/api/esql.delete_dataset.json","lines":["@@ -0,0 +1,34 @@","+{","+  \"esql.delete_dataset\": {","+    \"documentation\": {","+      \"url\": \"https://www.elastic.co/docs/api/doc/elasticsearch/operation/operation-esql-dataset-delete\",","+      \"description\": \"Delete one or more ES|QL datasets.\"","+    },","+    \"stability\": \"experimental\",","+    \"visibility\": \"public\",","+    \"headers\": {","+      \"accept\": [","+        \"application/json\"","+      ],","+      \"content_type\": [","+        \"application/json\"","+      ]","+    },","+    \"url\": {","+      \"paths\": [","+        {","+          \"path\": \"/_query/dataset/{name}\",","+          \"methods\": [","+            \"DELETE\"","+          ],","+          \"parts\": {","+            \"name\": {","+              \"type\": \"list\",","+              \"description\": \"A comma-separated list of datasets to delete\"","+            }","+          }","+        }","+      ]","+    }","+  }","+}"],"additions":34,"deletions":0,"truncated":false},{"path":"rest-api-spec/src/main/resources/rest-api-spec/api/esql.get_data_source.json","lines":["@@ -0,0 +1,40 @@","+{","+  \"esql.get_data_source\": {","+    \"documentation\": {","+      \"url\": \"https://www.elastic.co/docs/api/doc/elasticsearch/operation/operation-esql-data-source-get\",","+      \"description\": \"Get one or more ES|QL data sources. Secret setting values are returned masked.\"","+    },","+    \"stability\": \"experimental\",","+    \"visibility\": \"public\",","+    \"headers\": {","+      \"accept\": [","+        \"application/json\"","+      ],","+      \"content_type\": [","+        \"application/json\"","+      ]","+    },","+    \"url\": {","+      \"paths\": [","+        {","+          \"path\": \"/_query/data_source/{name}\",","+          \"methods\": [","+            \"GET\"","+          ],","+          \"parts\": {","+            \"name\": {","+              \"type\": \"list\",","+              \"description\": \"A comma-separated list of data source names or wildcard patterns\"","+            }","+          }","+        },","+        {","+          \"path\": \"/_query/data_source\",","+          \"methods\": [","+            \"GET\"","+          ]","+        }","+      ]","+    }","+  }","+}"],"additions":40,"deletions":0,"truncated":false},{"path":"rest-api-spec/src/main/resources/rest-api-spec/api/es