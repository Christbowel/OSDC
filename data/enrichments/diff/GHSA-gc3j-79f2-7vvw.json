{"id":"GHSA-gc3j-79f2-7vvw","axis":"advisories","repo":"fission/fission","sha":"e2b92663499f4dc3a1e2d38178f39c3c65e0134a","parsed":{"files":[{"path":"pkg/buildermgr/common.go","lines":["@@ -47,6 +47,15 @@ import ("," func buildPackage(ctx context.Context, logger logr.Logger, fissionClient versioned.Interface, envBuilderNamespace string,"," \tstorageSvcUrl string, pkg *fv1.Package) (uploadResp *fetcher.ArchiveUploadResponse, buildLogs string, err error) {"," ","+\t// Defence in depth against cross-namespace Environment references; the","+\t// admission webhook is the user-visible reject, this guard catches","+\t// objects that bypassed it (GHSA-vjhc-cf4p-72q4).","+\tif pkg.Spec.Environment.Namespace != \"\" && pkg.Spec.Environment.Namespace != pkg.Namespace {","+\t\te := fmt.Sprintf(\"cross-namespace environment reference is not allowed: pkg.namespace=%s env.namespace=%s\",","+\t\t\tpkg.Namespace, pkg.Spec.Environment.Namespace)","+\t\treturn nil, e, ferror.MakeError(ferror.ErrorInvalidArgument, e)","+\t}","+"," \tenv, err := fissionClient.CoreV1().Environments(pkg.Spec.Environment.Namespace).Get(ctx, pkg.Spec.Environment.Name, metav1.GetOptions{})"," \tif err != nil {"," \t\te := \"error getting environment CRD info\""],"additions":9,"deletions":0,"truncated":false},{"path":"pkg/buildermgr/pkgwatcher.go","lines":["@@ -107,6 +107,20 @@ func (pkgw *packageWatcher) build(ctx context.Context, srcpkg *fv1.Package) {"," \t\treturn"," \t}"," ","+\t// Defence in depth — the admission webhook should already have rejected","+\t// a cross-namespace environment reference at submit time, but reconcile","+\t// loops can still see stale objects on upgraded clusters or on clusters","+\t// running the webhook with failurePolicy=Ignore (GHSA-vjhc-cf4p-72q4).","+\tif pkg.Spec.Environment.Namespace != \"\" && pkg.Spec.Environment.Namespace != pkg.Namespace {","+\t\tmsg := fmt.Sprintf(\"cross-namespace environment reference is not allowed: pkg.namespace=%s env.namespace=%s\",","+\t\t\tpkg.Namespace, pkg.Spec.Environment.Namespace)","+\t\tlogger.Info(\"rejecting cross-namespace environment reference\", \"env_namespace\", pkg.Spec.Environment.Namespace)","+\t\tif _, er := updatePackage(ctx, logger, pkgw.fissionClient, pkg, fv1.BuildStatusFailed, msg, nil); er != nil {","+\t\t\tlogger.Error(er, \"error updating package\")","+\t\t}","+\t\treturn","+\t}","+"," \tenv, err := pkgw.fissionClient.CoreV1().Environments(pkg.Spec.Environment.Namespace).Get(ctx, pkg.Spec.Environment.Name, metav1.GetOptions{})"," \tif k8serrors.IsNotFound(err) {"," \t\te := \"environment does not exist\""],"additions":14,"deletions":0,"truncated":false},{"path":"pkg/kubewatcher/kubewatcher.go","lines":["@@ -102,6 +102,24 @@ func createKubernetesWatch(ctx context.Context, kubeClient kubernetes.Interface,"," \tvar err error"," \tvar watchTimeoutSec int64 = 120"," ","+\t// Refuse cross-namespace targets — the webhook should already reject","+\t// these at admission, but reconcile loops can see stale objects on","+\t// upgraded clusters or on webhook-failurePolicy=Ignore deployments","+\t// (GHSA-gc3j-79f2-7vvw).","+\tif w.Spec.Namespace != \"\" && w.Spec.Namespace != w.Namespace {","+\t\treturn nil, fmt.Errorf(\"cross-namespace watch is not allowed: trigger.namespace=%s spec.namespace=%s\",","+\t\t\tw.Namespace, w.Spec.Namespace)","+\t}","+","+\t// An empty Spec.Namespace previously meant \"watch all namespaces\" via","+\t// client-go's empty-namespace semantics — a separate cross-tenant leak.","+\t// Coerce it to the trigger's own namespace so an unset field can never","+\t// resolve to cluster-wide visibility.","+\ttarget := w.Spec.Namespace","+\tif target == \"\" {","+\t\ttarget = w.Namespace","+\t}","+"," \t// TODO populate labelselector and fieldselector"," \tlistOptions := metav1.ListOptions{"," \t\tResourceVersion: resourceVersion,","@@ -111,13 +129,13 @@ func createKubernetesWatch(ctx context.Context, kubeClient kubernetes.Interface,"," \t// TODO handle the full list of types"," \tswitch strings.ToUpper(w.Spec.Type) {"," \tcase \"POD\":","-\t\twi, err = kubeClient.CoreV1().Pods(w.Spec.Namespace).Watch(ctx, listOptions)","+\t\twi, err = kubeClient.CoreV1().Pods(target).Watch(ctx, listOptions)"," \tcase \"SERVICE\":","-\t\twi, err = kubeClient.CoreV1().Services(w.Spec.Namespace).Watch(ctx, listOptions)","+\t\twi, err = kubeClient.CoreV1().Services(target).Watch(ctx, listOptions)"," \tcase \"REPLICATIONCONTROLLER\":","-\t\twi, err = kubeClient.CoreV1().ReplicationControllers(w.Spec.Namespace).Watch(ctx, listOptions)","+\t\twi, err = kubeClient.CoreV1().ReplicationControllers(target).Watch(ctx, listOptions)"," \tcase \"JOB\":","-\t\twi, err = kubeClient.BatchV1().Jobs(w.Spec.Namespace).Watch(ctx, listOptions)","+\t\twi, err = kubeClient.BatchV1().Jobs(target).Watch(ctx, listOptions)"," \tdefault:"," \t\terr = errors.NewBadRequest(fmt.Sprintf(\"Error: unknown obj type '%v'\", w.Spec.Type))"," \t}"],"additions":22,"deletions":4,"truncated":false},{"path":"pkg/kubewatcher/kubewatcher_test.go","lines":["@@ -0,0 +1,107 @@","+/*","+Copyright 2026 The Fission Authors.","+","+Licensed under the Apache License, Version 2.0 (the \"License\");","+you may not use this file except in compliance with the License.","+You may obtain a copy of the License at","+","+    http://www.apache.org/licenses/LICENSE-2.0","+","+Unless required by applicable law or agreed to in writing, software","+distributed under the License is distributed on an \"AS IS\" BASIS,","+WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.","+See the License for the specific language governing permissions and","+limitations under the License.","+*/","+","+package kubewatcher","+","+import (","+\t\"context\"","+\t\"strings\"","+\t\"testing\"","+","+\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"","+\t\"k8s.io/apimachinery/pkg/watch\"","+\t\"k8s.io/client-go/kubernetes/fake\"","+\tclienttesting \"k8s.io/client-go/testing\"","+","+\tfv1 \"github.com/fission/fission/pkg/apis/core/v1\"","+)","+","+// captureWatchedNamespace records the namespace passed to the Watch verb on","+// the fake client. createKubernetesWatch hits client-go's Pods(ns).Watch path;","+// the fake client exposes the request via WatchAction.Namespace.","+func captureWatchedNamespace(t *testing.T, w *fv1.KubernetesWatchTrigger) (string, error) {","+\tt.Helper()","+\tkc := fake.NewSimpleClientset()","+\tvar ns string","+\tkc.PrependWatchReactor(\"pods\", func(action clienttesting.Action) (bool, watch.Interface, error) {","+\t\tns = action.GetNamespace()","+\t\treturn true, watch.NewFake(), nil","+\t})","+\t_, err := createKubernetesWatch(context.Background(), kc, w, \"\")","+\treturn ns, err","+}","+","+func TestCreateKubernetesWatch_RejectsCrossNamespace(t *testing.T) {","+\tw := &fv1.KubernetesWatchTrigger{","+\t\tObjectMeta: metav1.ObjectMeta{Name: \"kwt-1\", Namespace: \"ns-attacker\"},","+\t\tSpec: fv1.KubernetesWatchTriggerSpec{","+\t\t\tNamespace: \"ns-victim\",","+\t\t\tType:      \"POD\",","+\t\t},","+\t}","+\tkc := fake.NewSimpleClientset()","+\tcalled := false","+\tkc.PrependWatchReactor(\"pods\", func(action clienttesting.Action) (bool, watch.Interface, error) {","+\t\tcalled = true","+\t\treturn true, watch.NewFake(), nil","+\t})","+\t_, err := createKubernetesWatch(context.Background(), kc, w, \"\")","+\tif err == nil {","+\t\tt.Fatalf(\"expected error, got nil\")","+\t}","+\tif !strings.Contains(err.Error(), \"cross-namespace watch is not allowed\") {","+\t\tt.Fatalf(\"expected cross-namespace error, got: %v\", err)","+\t}","+\tif called {","+\t\tt.Fatalf(\"Watch reactor must not have been invoked when cross-namespace is rejected\")","+\t}","+}","+","+func TestCreateKubernetesWatch_EmptySpecNamespaceCoercedToTriggerNamespace(t *testing.T) {","+\tw := &fv1.KubernetesWatchTrigger{","+\t\tObjectMeta: metav1.ObjectMeta{Name: \"kwt-1\", Namespace: \"ns-attacker\"},","+\t\tSpec: fv1.KubernetesWatchTriggerSpec{","+\t\t\tNamespace: \"\",","+\t\t\tType:      \"POD\",","+\t\t},","+\t}","+\tns, err := captureWatchedNamespace(t, w)","+\tif err != nil {","+\t\tt.Fatalf(\"expected acceptance, got: %v\", err)","+\t}","+\t// Pre-fix behaviour would have used \"\" → all namespaces. Post-fix must","+\t// resolve to the trigger's own namespace.","+\tif ns != \"ns-attacker\" {","+\t\tt.Fatalf(\"expected coerced namespace %q, got %q\", \"ns-attacker\", ns)","+\t}","+}","+","+func TestCreateKubernetesWatch_SameNamespaceAccepted(t *testing.T) {","+\tw := &fv1.KubernetesWatchTrigger{","+\t\tObjectMeta: metav1.ObjectMeta{Name: \"kwt-1\", Namespace: \"default\"},","+\t\tSpec: fv1.KubernetesWatchTriggerSpec{","+\t\t\tNamespace: \"default\",","+\t\t\tType:      \"POD\",","+\t\t},","+\t}","+\tns, err := captureWatchedNamespace(t, w)","+\tif err != nil {","+\t\tt.Fatalf(\"expected acceptance, got: %v\", err)","+\t}","+\tif ns != \"default\" {","+\t\tt.Fatalf(\"expected namespace %q, got %q\", \"default\", ns)","+\t}","+}"],"additions":107,"deletions":0,"truncated":false},{"path":"pkg/webhook/kuberneteswatchtrigger.go","lines":["@@ -17,10 +17,13 @@ limitations under the License."," package webhook"," "," import (","+\t\"fmt\"","+"," \tctrl \"sigs.k8s.io/controller-runtime\""," \t\"sigs.k8s.io/controller-runtime/pkg/webhook\""," "," \tv1 \"github.com/fission/fission/pkg/apis/core/v1\"","+\tferror \"github.com/fission/fission/pkg/error\""," \t\"github.com/fission/fission/pkg/utils/loggerfactory\""," )"," ","@@ -42,7 +45,7 @@ func (r *KubernetesWatchTrigger) SetupWebhookWithManager(mgr ctrl.Manager) error"," var _ webhook.CustomDefaulter = &KubernetesWatchTrigger{}"," "," // user: change verbs to \"verbs=create;update;delete\" if you want to enable deletion validation.","-//+kubebuilder:webhook:path=/validate-fission-io-v1-kuberneteswatchtrigger,mutating=false,failurePolicy=fail,sideEffects=None,groups=fission.io,resources=kuberneteswatchtriggers,verbs=create,versions=v1,name=vkuberneteswatchtrigger.fission.io,admissionReviewVersions=v1","+//+kubebuilder:webhook:path=/validate-fission-io-v1-kuberneteswatchtrigger,mutating=false,failurePolicy=fail,sideEffects=None,groups=fission.io,resources=kuberneteswatchtriggers,verbs=create;update,versions=v1,name=vkuberneteswatchtrigger.fission.io,admissionReviewVersions=v1"," "," var _ webhook.CustomValidator = &KubernetesWatchTrigger{}"," ","@@ -50,5 +53,15 @@ func (r *KubernetesWatchTrigger) Validate(new *v1.KubernetesWatchTrigger) error"," \tif err := new.Validate(); err != nil {"," \t\treturn v1.AggregateValidationErrors(\"Watch\", err)"," \t}","+","+\t// Refuse cross-namespace Watch targets — the kubewatcher controller has","+\t// cluster-wide watch privileges and would otherwise stream every event","+\t// from the referenced namespace to the trigger's function, defeating","+\t// namespace-as-tenant boundaries (GHSA-gc3j-79f2-7vvw).","+\tif new.Spec.Namespace != \"\" && new.Spec.Namespace != new.Namespace {","+\t\treturn ferror.MakeError(ferror.ErrorInvalidArgument,","+\t\t\tfmt.Sprintf(\"KubernetesWatchTrigger.spec.namespace must equal the trigger namespace (got spec.namespace=%q, metadata.namespace=%q)\",","+\t\t\t\tnew.Spec.Namespace, new.Namespace))","+\t}"," \treturn nil"," }"],"additions":14,"deletions":1,"truncated":false},{"path":"pkg/webhook/kuberneteswatchtrigger_test.go","lines":["@@ -0,0 +1,79 @@","+/*","+Copyright 2026.","+","+Licensed under the Apache License, Version 2.0 (the \"License\");","+you may not use this file except in compliance with the License.","+You may obtain a copy of the License at","+","+    http://www.apache.org/licenses/LICENSE-2.0","+*/","+","+package webhook","+","+import (","+\t\"strings\"","+\t\"testing\"","+","+\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"","+","+\tv1 \"github.com/fission/fission/pkg/apis/core/v1\"","+)","+","+func makeValidKWT(triggerNs, specNs string) *v1.KubernetesWatchTrigger {","+\treturn &v1.KubernetesWatchTrigger{","+\t\tObjectMeta: metav1.ObjectMeta{","+\t\t\tName:      \"kwt-1\",","+\t\t\tNamespace: triggerNs,","+\t\t},","+\t\tSpec: v1.KubernetesWatchTriggerSpec{","+\t\t\tNamespace: specNs,","+\t\t\tType:      \"POD\",","+\t\t\tFunctionReference: v1.FunctionReference{","+\t\t\t\tType: v1.FunctionReferenceTypeFunctionName,","+\t\t\t\tName: \"fn-1\",","+\t\t\t},","+\t\t},","+\t}","+}","+","+func TestKubernetesWatchTriggerWebhook_Validate_CrossNamespace(t *testing.T) {","+\tcases := []struct {","+\t\tname         string","+\t\ttriggerNs    string","+\t\tspecNs       string","+\t\twantRejected bool","+\t\twantCrossErr bool // expect the new cross-namespace error specifically","+\t}{","+\t\t// Empty Spec.Namespace is already rejected by upstream KubernetesWatchTriggerSpec.Validate","+\t\t// (ValidateKubeName requires a non-empty RFC 1123 label). Asserted here so we notice","+\t\t// if upstream validation ever loosens — the controller-side coercion in","+\t\t// createKubernetesWatch is the safety net for any object that slips through.","+\t\t{name: \"empty spec.namespace rejected by upstream Validate\", triggerNs: \"default\", specNs: \"\", wantRejected: true, wantCrossErr: false},","+\t\t{name: \"same namespace is accepted\", triggerNs: \"default\", specNs: \"default\", wantRejected: false},","+\t\t{name: \"cross-namespace target is rejected by new check\", triggerNs: \"ns-attacker\", specNs: \"ns-victim\", wantRejected: true, wantCrossErr: true},","+\t}","+","+\tr := &KubernetesWatchTrigger{}","+\tfor _, tc := range cases {","+\t\tt.Run(tc.name, func(t *testing.T) {","+\t\t\terr := r.Validate(makeValidKWT(tc.triggerNs, tc.specNs))","+\t\t\tif !tc.wantRejected {","+\t\t\t\tif err != nil {","+\t\t\t\t\tt.Fatalf(\"expected acceptance, got: %v\", err)","+\t\t\t\t}","+\t\t\t\treturn","+\t\t\t}","+\t\t\tif err == nil {","+\t\t\t\tt.Fatalf(\"expected rejection, got nil\")","+\t\t\t}","+\t\t\tif tc.wantCrossErr {","+\t\t\t\tif !strings.Contains(err.Error(), \"spec.namespace must equal the trigger namespace\") {","+\t\t\t\t\tt.Fatalf(\"expected cross-namespace error, got: %v\", err)","+\t\t\t\t}","+\t\t\t\tif !strings.Contains(err.Error(), tc.triggerNs) || !strings.Contains(err.Error(), tc.specNs) {","+\t\t\t\t\tt.Fatalf(\"error should mention both namespaces (%q and %q), got: %v\", tc.triggerNs, tc.specNs, err)","+\t\t\t\t}","+\t\t\t}","+\t\t})","+\t}","+}"],"additions":79,"deletions":0,"truncated":false},{"path":"pkg/webhook/package.go","lines":["@@ -82,5 +82,17 @@ func (r *Package) Validate(new *v1.Package) error {"," \t\treturn ferror.MakeError(ferror.ErrorInvalidArgument,"," \t\t\tfmt.Sprintf(\"Package literal larger than %s\", humanize.Bytes(uint64(v1.ArchiveLiteralSizeLimit))))"," \t}","+","+\t// Refuse Package objects whose spec.environment.namespace targets a","+\t// different namespace than the Package itself. The buildermgr runs with","+\t// a cluster-wide ServiceAccount and would otherwise dispatch a build","+\t// into the referenced Environment's namespace builder, leaking that","+\t// namespace's builder-SA token and Secret/ConfigMap contents back via","+\t// Package.status.buildlog (GHSA-vjhc-cf4p-72q4).","+\tif new.Spec.Environment.Namespace != \"\" && new.Spec.Environment.Namespace != new.Namespace {","+\t\treturn ferror.MakeError(ferror.ErrorInvalidArgument,","+\t\t\tfmt.Sprintf(\"Package.spec.environment.namespace must equal Package namespace (got env.namespace=%q, pkg.namespace=%q)\",","+\t\t\t\tnew.Spec.Environment.Namespace, new.Namespace))","+\t}"," \treturn nil"," }"],"additions":12,"deletions":0,"truncated":false},{"path":"pkg/webhook/package_test.go","lines":["@@ -0,0 +1,74 @@","+/*","+Copyright 2026.","+","+Licensed under the Apache License, Version 2.0 (the \"License\");","+you may not use this file except in compliance with the License.","+You may obtain a copy of the License at","+","+    http://www.apache.org/licenses/LICENSE-2.0","+*/","+","+package webhook","+","+import (","+\t\"strings\"","+\t\"testing\"","+","+\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"","+","+\tv1 \"github.com/fission/fission/pkg/apis/core/v1\"","+)","+","+// makeValidPackage returns a Package object that satisfies v1.Package.Validate()","+// so the cross-namespace branch is the only thing under test.","+func makeValidPackage(pkgNs, envNs string) *v1.Package {","+\treturn &v1.Package{","+\t\tObjectMeta: metav1.ObjectMeta{","+\t\t\tName:      \"pkg-1\",","+\t\t\tNamespace: pkgNs,","+\t\t},","+\t\tSpec: v1.PackageSpec{","+\t\t\tEnvironment: v1.EnvironmentReference{","+\t\t\t\tName:      \"env-1\",","+\t\t\t\tNamespace: envNs,","+\t\t\t},","+\t\t},","+\t\tStatus: v1.PackageStatus{","+\t\t\tBuildStatus: v1.BuildStatusPending,","+\t\t},","+\t}","+}","+","+func TestPackageWebhook_Validate_CrossNamespaceEnvironment(t *testing.T) {","+\tcases := []struct {","+\t\tname         string","+\t\tpkgNs        string","+\t\tenvNs        string","+\t\twantRejected bool","+\t}{","+\t\t{name: \"empty env.namespace is accepted\", pkgNs: \"default\", envNs: \"\", wantRejected: false},","+\t\t{name: \"same namespace is accepted\", pkgNs: \"default\", envNs: \"default\", wantRejected: false},","+\t\t{name: \"cross namespace is rejected\", pkgNs: \"ns-attacker\", envNs: \"ns-victim\", wantRejected: true},","+\t\t{name: \"cross namespace rejected even when pkg in kube-system\", pkgNs: \"kube-system\", envNs: \"default\", wantRejected: true},","+\t}","+","+\tr := &Package{}","+\tfor _, tc := range cases {","+\t\tt.Run(tc.name, func(t *testing.T) {","+\t\t\terr := r.Validate(makeValidPackage(tc.pkgNs, tc.envNs))","+\t\t\tif tc.wantRejected {","+\t\t\t\tif err == nil {","+\t\t\t\t\tt.Fatalf(\"expected rejection, got nil\")","+\t\t\t\t}","+\t\t\t\tif !strings.Contains(err.Error(), \"spec.environment.namespace\") {","+\t\t\t\t\tt.Fatalf(\"error should reference spec.environment.namespace, got: %v\", err)","+\t\t\t\t}","+\t\t\t\tif !strings.Contains(err.Error(), tc.envNs) || !strings.Contains(err.Error(), tc.pkgNs) {","+\t\t\t\t\tt.Fatalf(\"error should mention both namespaces (%q and %q), got: %v\", tc.pkgNs, tc.envNs, err)","+\t\t\t\t}","+\t\t\t} else if err != nil {","+\t\t\t\tt.Fatalf(\"expected acceptance, got: %v\", err)","+\t\t\t}","+\t\t})","+\t}","+}",""],"additions":74,"deletions":0,"truncated":false}],"additions":331,"deletions":5,"truncated":false,"file_count":8},"error":null,"fetched_at":"2026-07-01T11:08:44.808973+00:00"}