,"+","+class Empty {","+  // empty record return type — used in Elm-style architecture.","+  () makeEmpty() => ();","+","+  // single-named-field record with trailing comma.","+  ({int id}) makeNamed() => (id: 42,);","+","+  // dot-shorthand inferred from context.","+  Color get primary => .blue;","+  Container build() => .new(child: .primary);","+","+  // null-aware element in a map literal.","+  Map<String, int> defaults(int? maybe) => {","+        \"always\": 1,","+        ?\"sometimes\": maybe,","+      };","+","+  // null-assertion `!` inside a cascade chain.","+  void wire(Foo? foo) {","+    foo!","+      ..a = 1","+      ..b!.c = 2;","+  }","+","+  // operator and dotted symbol literals.","+  static const Symbol opEq = #==;","+  static const Symbol nested = #a.b.c;","+","+  // 'get'/'set' usable as identifiers in expression context.","+  void useContextual() {","+    final get = 1;","+    final set = 2;","+    print(get + set);","+  }","+}"],"additions":47,"deletions":0,"truncated":false},{"path":"tests/parsing/dart/switch_object_pattern.dart","lines":["@@ -0,0 +1,40 @@","+// Regression test for Dart 3 object patterns in switch expressions.","+// The previously-pinned tree-sitter-dart grammar rejected empty-paren","+// object patterns ('_MyClass()' arms), causing parse failures on real","+// Flutter code. Upstream tree-sitter-dart PR #93 fixed this by changing","+// `commaSep1TrailingComma` to `commaSepTrailingComma` on `object_pattern`.","+","+sealed class Library {","+  const Library();","+}","+","+class _MaterialLibrary extends Library {}","+class _CupertinoLibrary extends Library {}","+class _OtherLibrary extends Library {}","+","+bool canImport(Library lib) {","+  return switch (lib) {","+    _MaterialLibrary() => true,","+    _CupertinoLibrary() => true,","+    _OtherLibrary() => false,","+  };","+}","+","+class Box<T> {","+  final T value;","+  Box(this.value);","+}","+","+String describe(Object o) {","+  return switch (o) {","+    Box<int>(value: final v) when v > 0 => 'positive box',","+    Box(value: final v) => 'box of $v',","+    null => 'null',","+    _ => 'other',","+  };","+}","+","+void main() {","+  print(canImport(_MaterialLibrary()));","+  print(describe(Box<int>(42)));","+}"],"additions":40,"deletions":0,"truncated":false},{"path":"tests/patterns/dart/function_call.dart","lines":["@@ -0,0 +1,21 @@","+","+String foo()","+{","+  // ERROR:","+  xxx();","+}","+","+String foo(String a, String b)","+{","+  // ERROR:","+  xxx();","+}","+","+class C","+{","+  String foo(String a, String b)","+  {","+    // ERROR:","+    xxx();","+  }","+}"],"additions":21,"deletions":0,"truncated":false},{"path":"tests/patterns/dart/function_call.sgrep","lines":["@@ -0,0 +1 @@","+$FOO(...)"],"additions":1,"deletions":0,"truncated":false},{"path":"tests/patterns/dart/function_def.dart","lines":["@@ -0,0 +1,20 @@","+// ERROR:","+String foo()","+{","+  xxx();","+}","+","+// ERROR:","+String foo(String a, String b)","+{","+  xxx();","+}","+","+class C","+{","+  // ERROR:","+  String foo(String a, String b)","+  {","+    xxx();","+  }","+}"],"additions":20,"deletions":0,"truncated":false},{"path":"tests/patterns/dart/function_def.sgrep","lines":["@@ -0,0 +1 @@","+$T $FOO(...) { ... }"],"additions":1,"deletions":0,"truncated":false},{"path":"tests/patterns/dart/function_def_void.dart","lines":["@@ -0,0 +1,20 @@","+// Top-level function with the matching name and shape.","+// ERROR:","+void test() {","+  foo();","+}","+","+void run() {","+  bar();","+}","+","+class A {","+  // ERROR:","+  void test() {","+    foo();","+  }","+","+  void other() {","+    bar();","+  }","+}"],"additions":20,"deletions":0,"truncated":false},{"path":"tests/patterns/dart/function_def_void.sgrep","lines":["@@ -0,0 +1 @@","+void test() { ... }"],"additions":1,"deletions":0,"truncated":false},{"path":"tests/patterns/dart/uninit_local_var.dart","lines":["@@ -0,0 +1,22 @@","+// Local declarations without an initializer must survive into the AST so","+// patt