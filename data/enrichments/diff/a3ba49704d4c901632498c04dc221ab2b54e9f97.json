s the settings flow to providers of that organization.","+\t// This parameter is only effective in the Ory Network.","+\t//","+\t// required: false","+\t// in: query","+\tOrganization string `json:\"organization\"`"," }"," "," // swagger:route GET /self-service/settings/api frontend createNativeSettingsFlow","@@ -268,6 +277,13 @@ type createBrowserSettingsFlow struct {"," \t// in: header"," \t// name: Cookie"," \tCookies string `json:\"Cookie\"`","+","+\t// An optional organization ID that scopes the settings flow to providers of that organization.","+\t// This parameter is only effective in the Ory Network.","+\t//","+\t// required: false","+\t// in: query","+\tOrganization string `json:\"organization\"`"," }"," "," // swagger:route GET /self-service/settings/browser frontend createBrowserSettingsFlow"],"additions":17,"deletions":1,"truncated":false},{"path":"selfservice/flow/settings/organizations.go","lines":["@@ -0,0 +1,113 @@","+// Copyright © 2026 Ory Corp","+// SPDX-License-Identifier: Apache-2.0","+","+package settings","+","+import (","+\t\"net/http\"","+\t\"slices\"","+\t\"strings\"","+","+\t\"github.com/gofrs/uuid\"","+","+\t\"github.com/ory/kratos/driver/config\"","+\t\"github.com/ory/kratos/identity\"","+\t\"github.com/ory/kratos/selfservice/flow\"","+\t\"github.com/ory/kratos/x\"","+)","+","+var organizationFilter = []StrategyFilter{func(s Strategy) bool {","+\ta, b := s.(flow.OrganizationImplementor)","+\treturn b && a.SupportsOrganizations()","+}}","+","+// PrepareOrganizations resolves the org id from the identity (winner) or the","+// `?organization=` query param, sets it on the flow, and returns a filter","+// that keeps only org-implementing strategies. Returns an empty filter when","+// no org id applies — the flow then proceeds as a normal (non-org) settings","+// flow.","+//","+// The identity is the authoritative source: an identity already bound to an","+// org cannot be silently re-bound, and the session cache must not be relied","+// on because it can lag behind a just-persisted org binding (PostSettingsHook","+// rebuilds the flow with the freshly linked identity).","+//","+// The query param is free-form caller input, so it is only honored when one","+// of the identity's email addresses is under the organization's configured","+// domains. Without that gate, any authenticated identity could render an","+// org-scoped flow for every org in the project and enumerate its SSO","+// providers. The org hooks block self-service registration and profile","+// updates under a claimed domain, so a matching address implies the domain","+// owner provisioned the account.","+//","+// When the resolved org id does not match any configured organization, the","+// flow falls back to the unscoped path. An identity may carry an","+// organization_id for an organization that has since been deleted; scoping","+// to a dangling org would render no nodes and trap chained flows such as","+// recovery -> settings.","+func PrepareOrganizations(r *http.Request, f *Flow, i *identity.Identity, configuredOrgs []config.Organization) []StrategyFilter {","+\tif f.OrganizationID.Valid {","+\t\treturn organizationFilter","+\t}","+","+\tif i != nil && i.OrganizationID.Valid {","+\t\tif _, ok := findConfiguredOrganization(i.OrganizationID.UUID, configuredOrgs); !ok {","+\t\t\treturn []StrategyFilter{}","+\t\t}","+\t\tf.OrganizationID = i.OrganizationID","+\t\treturn organizationFilter","+\t}","+","+\torgID := flow.ParseOrganizationFromURLQuery(r.Context(), r.URL.Query())","+\tif !orgID.Valid {","+\t\treturn []StrategyFilter{}","+\t}","+","+\torg, ok := findConfiguredOrganization(orgID.UUID, configuredOrgs)","+\tif !ok {","+\t\treturn []StrategyFilter{}","+\t}","+","+\tif !identityEmailMatchesOrganizationDomains(i, org) {","+\t\treturn []StrategyFilter{}","+\t}","+","+\tf.OrganizationID = orgID","+\treturn organizationFilter","+}","+","+func findConfiguredOrganization(id uuid.UUID, configured []config.Organization) (config.Organization, bool) {","+\tidx := slices.IndexFunc(configured, func(o config.Organization) bool {","+\t\treturn o.ID == id","+\t})","+\tif idx < 0 {","+\t\treturn config.Organization{}, false","+\t}","+\treturn configured[idx], true","+}","+","+// identityEmailMatchesOrganizationDomains reports whether one of the","+// identity's email addresses is under one of the organization's domains. The","+// normalization mirrors the org email-domain matching in the cloud module's","+// organization hook.","+func identityEmailMatchesOrganizationDomains(i *identity.Identity, org config.Organization) bool {","+\tif i == nil {","+\t\treturn false","+\t}","+\t// TODO(jonas): This should actually use the `organization.via` field of the identity schema.","+\tfor _, addr := range i.VerifiableAddresses {","+\t\tif addr.Via != identity.AddressTypeEmail {","+\t\t\tcontinue","+\t\t}","+\t\t_, domain, ok := strings.Cut(x.NormalizeEmailIdentifier(addr.Value), \"@\")","+\t\tif !ok || domain == \"\" {","+\t\t\tcontinue","+\t\t}","+\t\tif slices.ContainsFunc(org.Domains, func(orgDomain string) bool {","+\t\t\treturn strings.EqualFold(domain, x.NormalizeOtherIdentifier(orgDomain))","+\t\t}) {","+\t\t\treturn true","+\t\t}","+\t}","+\treturn false","+}"],"additions":113,"deletions":0,"truncated":false},{"path":"selfservice/flow/settings/organizations_test.go","lines":["@@ -0,0 +1,157 @@","+// Copyright © 2026 Ory Corp","+// SPDX-License-Identifier: Apache-2.0","+","+package settings_test","+","+import (","+\t\"context\"","+\t\"net/http/httptest\"","+\t\"testing\"","+","+\t\"github.com/gofrs/uuid\"","+\t\"github.com/stretchr/testify/assert\"","+","+\t\"github.com/ory/kratos/driver/config\"","+\t\"github.com/ory/kratos/identity\"","+\t\"github.com/ory/kratos/selfservice/flow/settings\"","+)","+","+func TestPrepareOrganizations(t *testing.T) {"],"additions":19,"deletions":0,"truncated":false}],"additions":358,"deletions":47,"truncated":true,"file_count":27},"error":null,"fetched_at":"2026-06-12T11:44:57.982081+00:00"}