com/gravitational/teleport/lib/modules/modulestest\"","+)","+","+func TestWatchEvents_enterpriseOnlyKinds(t *testing.T) {","+\tt.Parallel()","+","+\tossTestServer := newTestTLSServer(t)","+\tentTestServer := newTestTLSServer(t, withModules(modulestest.EnterpriseModules()))","+","+\tossClient, err := ossTestServer.NewClient(authtest.TestAdmin())","+\trequire.NoError(t, err)","+\tentClient, err := entTestServer.NewClient(authtest.TestAdmin())","+\trequire.NoError(t, err)","+","+\t// kindOther is a watch kind we expect to always work.","+\tconst kindOther = types.KindCertAuthority","+","+\tconst wantErr = \"only available in Teleport Enterprise\"","+","+\tconfirmKinds := func(t *testing.T, watcher types.Watcher, wantKinds ...string) {","+\t\tt.Helper()","+","+\t\tselect {","+\t\tcase <-t.Context().Done():","+\t\t\tt.Fatal(\"t.Context() done before first event\")","+\t\tcase <-watcher.Done():","+\t\t\tt.Fatalf(\"watcher done before first event, err=%v\", watcher.Error())","+\t\tcase e := <-watcher.Events():","+\t\t\trequire.Equal(t, types.OpInit, e.Type, \"Unexpected event type\")","+","+\t\t\ts, ok := e.Resource.(types.WatchStatus)","+\t\t\trequire.True(t, ok, \"e.Resource has unexpected type: %T\", e.Resource)","+","+\t\t\twatchKinds := s.GetKinds()","+\t\t\tgotKinds := make([]string, len(watchKinds))","+\t\t\tfor i, k := range watchKinds {","+\t\t\t\tgotKinds[i] = k.Kind","+\t\t\t}","+\t\t\tif diff := cmp.Diff(wantKinds, gotKinds); diff != \"\" {","+\t\t\t\tt.Errorf(\"WatchStatus.GetKinds() mismatch (-want +got)\\n%s\", diff)","+\t\t\t}","+\t\t}","+\t}","+","+\ttests := []struct {","+\t\tkind string","+\t}{","+\t\t{kind: types.KindCertAuthorityOverride},","+\t}","+\tfor _, test := range tests {","+\t\tt.Run(test.kind, func(t *testing.T) {","+\t\t\tt.Parallel()","+","+\t\t\tt.Run(\"OSS fails\", func(t *testing.T) {","+\t\t\t\twatcher, err := ossClient.NewWatcher(t.Context(), types.Watch{","+\t\t\t\t\tName: \"oss\",","+\t\t\t\t\tKinds: []types.WatchKind{","+\t\t\t\t\t\