iderEnabled() bool {","+\t// Fast path: check the last known active provider first. In the common","+\t// production steady state a single provider stays enabled indefinitely, so","+\t// one IsDisabledProvider call is enough to confirm and return early — no","+\t// snapshot allocation, no calls to any other provider.","+\t//","+\t// alreadyChecked records which provider the fast path called IsDisabledProvider","+\t// on so the full scan below can skip it and avoid a redundant call.","+\tvar alreadyChecked string","+\tif hint, _ := lastKnownEnabled.Load().(string); hint != \"\" {","+\t\tmu.RLock()","+\t\tp := providers[hint]","+\t\tmu.RUnlock()","+\t\tif p != nil {","+\t\t\tdisabled, err := p.IsDisabledProvider()","+\t\t\tif err == nil {","+\t\t\t\tif !disabled {","+\t\t\t\t\treturn true // Hint still valid.","+\t\t\t\t}","+\t\t\t\t// Got a clean \"disabled\" answer — safe to skip in the full scan.","+\t\t\t\talreadyChecked = hint","+\t\t\t}","+\t\t\t// On error: alreadyChecked stays \"\" so the full scan retries this provider.","+\t\t}","+\t\t// Don't clear the hint here; the full scan overwrites it authoritatively.","+\t}","+","+\t// Full scan: snapshot the non-local provider list while holding the lock,","+\t// then call IsDisabledProvider outside the lock — those implementations make","+\t// live Kubernetes API calls that must not block the lock.","+\tmu.RLock()","+\ttype entry struct {","+\t\tname     string","+\t\tprovider common.AuthProvider","+\t}","+\tsnapshot := make([]entry, 0, len(providers))","+\tfor name, p := range providers {","+\t\tif name != local.Name && name != alreadyChecked {","+\t\t\tsnapshot = append(snapshot, entry{name, p})","+\t\t}","+\t}","+\tmu.RUnlock()","+","+\tfor _, e := range snapshot {","+\t\tdisabled, err := e.provider.IsDisabledProvider()","+\t\tif err != nil {","+\t\t\tlogrus.Warnf(\"checking if provider %s is disabled: %v\", e.name, err)","+\t\t\tcontinue","+\t\t}","+\t\tif !disabled {","+\t\t\tlastKnownEnabled.Store(e.name)","+\t\t\treturn true","+\t\t}","+\t}","+\tlastKnownEnabled.Store(\"\")","+\treturn false","+}","+","+// IsLocalHidden reports whether the local auth provider should be hidden from public-facing endpoints.","+// It returns true when the HideLocalAuthProvider feature flag is enabled and at least one external","+// auth provider is currently active.","+func IsLocalHidden() bool {","+\treturn features.HideLocalAuthProvider.Enabled() && IsExternalProviderEnabled()"," }"," "," // ProviderUsesUserSecrets reports whether the named provider stores per-user secrets for token refresh."],"additions":77,"deletions":1,"truncated":false},{"path":"pkg/auth/providers/providers_test.go","lines":["@@ -1,6 +1,7 @@"," package providers"," "," import (","+\t\"fmt\""," \t\"testing\""," "," \t\"github.com/rancher/rancher/pkg/auth/providers/common\"","@@ -8,7 +9,10 @@ import ("," \t\"github.com/rancher/rancher/pkg/auth/providers/github\""," \t\"github.com/rancher/rancher/pkg/auth/providers/githubapp\""," \t\"github.com/rancher/rancher/pkg/auth/providers/local\"","+\t\"github.com/rancher/rancher/pkg/auth/providers/mocks\"","+\t\"github.com/rancher/rancher/pkg/features\""," \t\"github.com/stretchr/testify/assert\"","+\t\"go.uber.org/mock/gomock\""," )"," "," func TestIsSAMLProvider(t *testing.T) {","@@ -55,3 +59,164 @@ func TestProviderCanRefreshPrincipals(t *testing.T) {"," \tassert.True(t, ProviderCanRefreshPrincipals(github.Name))"," \tassert.False(t, ProviderCanRefreshPrincipals(genericoidc.Name))"," }","+","+func TestIsExternalProviderEnabled(t *testing.T) {","+\tctrl := gomock.NewController(t)","+","+\tactive := mocks.NewMockAuthProvider(ctrl)","+\tactive.EXPECT().IsDisabledProvider().Return(false, nil).AnyTimes()","+","+\tinactive := mocks.NewMockAuthProvider(ctrl)","+\tinactive.EXPECT().IsDisabledProvider().Return(true, nil).AnyTimes()","+","+\tbroken := mocks.NewMockAuthProvider(ctrl)","+\tbroken.EXPECT().IsDisabledProvider().Return(false, fmt.Errorf(\"db timeout\")).AnyTimes()","+","+\