ck()","+\tdefer b.mu.Unlock()","+\tb.ipVIPServiceMap = m","+\tif ns, ok := b.sys.Netstack.GetOK(); ok {","+\t\tns.UpdateIPServiceMappings(m)","+\t}","+}","+","+// GetFilter returns the current packet filter.","+func (f forTest) GetFilter() *filter.Filter {","+\tb := f.b","+\t// Take b.mu so the read serializes with [LocalBackend.setControlClientStatusLocked],","+\t// which installs the netmap and the filter at separate sub-steps. Without","+\t// this, a test thread that observes the new netmap (via [LocalBackend.NetMapWithPeers])","+\t// can race ahead of the filter store and read the previous filter.","+\tb.mu.Lock()","+\tdefer b.mu.Unlock()","+\treturn b.currentNode().filterAtomic.Load()","+}","+","+// SetControlClientGetter sets the func that creates a control plane","+// client. It can be called at most once, before Start.","+func (f forTest) SetControlClientGetter(newControlClient func(controlclient.Options) (controlclient.Client, error)) {","+\tb := f.b","+\tb.mu.Lock()","+\tdefer b.mu.Unlock()","+\tif b.ccGen != nil {","+\t\tpanic(\"invalid use of forTest.SetControlClientGetter after Start\")","+\t}","+\tb.ccGen = newControlClient","+}","+","+// Peers returns all the current peers, sorted by Node.ID, for integration","+// tests in another repo.","+func (f forTest) Peers() []tailcfg.NodeView {","+\treturn f.b.currentNode().PeersForTest()","+}","+","+// AwaitNodeKey returns a channel that is closed once a peer with the given","+// node key first appears in the current netmap. If the peer is already","+// present, the returned channel is already closed. See","+// [nodeBackend.AwaitNodeKeyForTest].","+func (f forTest) AwaitNodeKey(k key.NodePublic) <-chan struct{} {","+\treturn f.b.currentNode().AwaitNodeKeyForTest(k)","+}","+","+// CurrentUser returns the current user and the associated WindowsUserID.","+// It will be removed along with the rest of the \"current user\" functionality","+// as we progress on the multi-user improvements (tailscale/corp#18342).","+f