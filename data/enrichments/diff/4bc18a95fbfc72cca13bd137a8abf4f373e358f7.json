inTransaction( (t) -> {","+\t\t\t\tassertThat( interceptor.getCounter() ).isEqualTo( 0 );","+\t\t\t\tem.insert( new TestEntity( 1, \"Stuff\" ) );","+\t\t\t} );","+\t\t\tassertThat( interceptor.getCounter() ).isEqualTo( 1 );","+\t\t}","+\t\tfinally {","+\t\t\tfactoryScope.dropData();","+\t\t}","+\t}","+"," \t@Entity","+\t@Table(name = \"test_entity\")"," \tpublic static class TestEntity {"," \t\t@Id","-\t\tprivate Long id;","+\t\tprivate Integer id;"," \t\tprivate String name;","+","+\t\tpublic TestEntity() {","+\t\t}","+","+\t\tpublic TestEntity(Integer id, String name) {","+\t\t\tthis.id = id;","+\t\t\tthis.name = name;","+\t\t}"," \t}"," "," \t@Entity","+\t@Table(name = \"test_entity2\")"," \tpublic static class TestEntity2 {"," \t\t@Id","-\t\tprivate Long id;","+\t\tprivate Integer id;"," \t\tprivate String name;"," \t\t@TenantId"," \t\tprivate String segment;"," \t}","+","+\tpublic static class InterceptorImpl implements Interceptor {","+\t\tprivate int counter;","+","+\t\tpublic int getCounter() {","+\t\t\treturn counter;","+\t\t}","+","+\t\t@Override","+\t\tpublic boolean onPersist(Object entity, Object id, Object[] state, String[] propertyNames, Type[] types) {","+\t\t\tcounter++;","+\t\t\treturn false;","+\t\t}","+","+\t\t@Override","+\t\tpublic void onInsert(Object entity, Object id, Object[] state, String[] propertyNames, Type[] propertyTypes) {","+\t\t\tcounter++;","+\t\t}","+\t}"," }"],"additions":112,"deletions":2,"truncated":false},{"path":"hibernate-testing/src/main/java/org/hibernate/testing/jdbc/CollectingStatementObserver.java","lines":["@@ -18,7 +18,7 @@","  * @author Steve Ebersole","  */"," public class CollectingStatementObserver implements StatementObserver {","-\tprivate List<Statement> statements = new ArrayList<>();","+\tprivate final List<Statement> statements = new ArrayList<>();"," "," \t@Override"," \tpublic void performingSql(String sql, int batchPosition) {"],"additions":1,"deletions":1,"truncated":false},{"path":"whats-new.adoc","lines":["@@ -45,7 +45,7 @@ Hibernate Data Repositories now implements Jakarta Data 1.1, including support f"," "," "," [[graph-flushing]]","-=== Graph-based Flushing","+== Graph-based Flushing"," "," 8.0 introduces graph-based flush coordination that plans insert, update, delete, and collection work using the mapped relational constraints of the domain model.  Instead of relying primarily on operation ordering heuristics, the graph queue builds a dependency model for each flush and executes work in an order that better reflects foreign keys, uniqueness constraints, optional tables, secondary tables, and other mapping relationships."," ","@@ -138,3 +138,42 @@ var book = session.getReference(Book.class, isbn, NATURAL);"," == Discriminator-Based Multi-Tenancy and Row-Level Security"," "," On databases with built-in support for row-level security, Hibernate now uses row-level security to enforce the visibility rules implied by discriminator-based multi-tenancy.","+","+","+","+[[session-open]]","+== Session and StatelessSession Options","+","+One use of <<jpa4>> features is the ability to open and configure a `Session` or `StatelessSession` with Hibernate-specific options directly from the Jakarta Persistence API.","+","+`EntityManager.CreationOption` and `EntityAgent.CreationOption` define options which are applicable during creation of the `Session` or `StatelessSession` and which are in effect for its lifecycle.  Hibernate supports the following creation options -","+","+* `org.hibernate.SessionCreationOption.TenantId`","+* `org.hibernate.SessionCreationOption.EffectiveChangeset`","+* `org.hibernate.SessionCreationOption.EffectiveAt`","+* `org.hibernate.StatementObserver` (see <<StatementObserver>>)","+* `org.hibernate.Interceptor`","+","+NOTE: `Session` may also be created with a `org.hibernate.SessionCreationOption.SubselectFetchMode`.","+","+`EntityManager.Option` and `EntityAgent.Option` define configuration values which are mutable throughout the `Session` or `StatelessSession` lifecycle, though they may also be used as creation options -","+","+* `org.hibernate.CacheMode`","+* `jakarta.persistence.CacheStoreMode`","+* `jakarta.persistence.CacheRetrieveMode`","+* `org.hibernate.FlushMode`","+* `jakarta.persistence.FlushModeType`","+* `org.hibernate.BatchSize`","+* `org.hibernate.ReadOnlyMode`","+","+E.g.","+","+[source,java]","+----","+var entityManager = entityManagerFactory.createEntityManager(","+\t\tnew TenantId(\"acme\"),","+\t\tnew EffectiveAt(now().minus(1,YEARS)),","+\t\tReadOnlyMode.READ_ONLY","+);","+","+----",""],"additions":40,"deletions":1,"truncated":false}],"additions":224,"deletions":21,"truncated":false,"file_count":14},"error":null,"fetched_at":"2026-06-09T10:50:51.907683+00:00"}