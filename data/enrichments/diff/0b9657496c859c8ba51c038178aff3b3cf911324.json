9,68 @@ func (is *indexSplitAndScatter) getSplitPointsWithStats("," \treturn splitPoints, nil"," }"," ","+// estimatedTableSize returns the estimated total data size of the table in","+// bytes, based on cached table statistics. It sums AvgSize across","+// single-column stats from the most recent collection and multiplies by","+// RowCount. Returns 0 if stats are unavailable or insufficient, since a","+// table without stats is most likely newly created and small.","+func (is *indexSplitAndScatter) estimatedTableSize(","+\tctx context.Context, table catalog.TableDescriptor,","+) int64 {","+\ttableStats, err := is.statsCache.GetFreshTableStats(","+\t\tctx, table, nil, /* typeResolver */","+\t)","+\tif err != nil || len(tableStats) == 0 {","+\t\treturn 0","+\t}","+\trowCount := tableStats[0].RowCount","+\tif rowCount == 0 {","+\t\treturn 0","+\t}","+\t// Sum AvgSize across single-column stats from the latest collection to","+\t// estimate total row width.","+\tlatestCreatedAt := tableStats[0].CreatedAt","+\tvar totalAvgRowSize uint64","+\tfor _, s := range tableStats {","+\t\tif s.CreatedAt != latestCreatedAt {","+\t\t\tbreak","+\t\t}","+\t\tif len(s.ColumnIDs) == 1 {","+\t\t\ttotalAvgRowSize += s.AvgSize","+\t\t}","+\t}","+\tif totalAvgRowSize == 0 {","+\t\treturn 0","+\t}","+\treturn int64(rowCount * totalAvgRowSize)","+}","+","+// rangeMaxBytesForTable returns the effective RangeMaxBytes for the given","+// table from its zone config. Falls back to the default (512 MB) if the","+// zone config is unavailable.","+func (is *indexSplitAndScatter) rangeMaxBytesForTable(table catalog.TableDescriptor) int64 {","+\tif !SkipBackfillSplitsForSmallTables.Get(is.sv) {","+\t\treturn 0","+\t}","+\tif is.systemConfig != nil {","+\t\tif sysCfg := is.systemConfig.GetSystemConfig(); sysCfg != nil {","+\t\t\tif zc, err := sysCfg.GetZoneConfigForObject(","+\t\t\t\tis.codec, config.ObjectID(table.GetID()),","+\t\t\t); err == nil && zc != nil && zc.RangeMaxBytes != nil {","+\t\t\t\treturn *zc.RangeMaxBytes","+\t\t\t}","+\t\t}","+\t}","+\treturn *zonepb.DefaultZoneConfig().RangeMaxBytes","+}","+","+// ShouldSkipSplitForSmallTable implements the scexec.IndexSpanSplitter interface.","+func (is *indexSplitAndScatter) ShouldSkipSplitForSmallTable(","+\tctx context.Context, table catalog.TableDescriptor,","+) bool {","+\treturn is.estimatedTableSize(ctx, table) < is.rangeMaxBytesForTable(table)","+}","+"," // MaybeSplitIndexSpans implements the scexec.IndexSpanSplitter interface."," func (is *indexSplitAndScatter) MaybeSplitIndexSpans("," \tctx context.Context,","@@ -201,6 +278,15 @@ func (is *indexSplitAndScatter) MaybeSplitIndexSpans("," \tindexToBackfill catalog.Index,"," \tcopyIndexSource catalog.Index,"," ) error {","+\t// Skip splitting if table stats indicate the table fits within a single","+\t// range. Splits exist to distribute write load during index backfills,","+\t// which is unnecessary when there is little or no data. This avoids range","+\t// count bloat on clusters running many schema changes on small tables.","+\tif is.ShouldSkipSplitForSmallTable(ctx, table) {","+\t\tlog.Dev.Infof(ctx, \"skipping index split for tableId=%d index=%d\",","+\t\t\ttable.GetID(), indexToBackfill.GetID())","+\t\treturn nil","+\t}"," \t// If we are asked to copy a source indexes splits, then there is"," \t// no need split along partitioning."," \tif copyIndexSource == nil {","@@ -384,6 +470,11 @@ func (is *indexSplitAndScatter) MaybeSplitIndexSpansForPartitioning("," \tif !is.shouldSplitAndScatter(idx) {"," \t\treturn nil"," \t}","+\tif is.ShouldSkipSplitForSmallTable(ctx, tableDesc) {","+\t\tlog.Dev.Infof(ctx, \"skipping hash shard pre-split for tableId=%d index=%d\",","+\t\t\ttableDesc.GetID(), idx.GetID())","+\t\treturn nil","+\t}"," \tconst backfillSplitExpiration = time.Hour"," \texpirationTime := is.db.Clock().Now().Add(backfillSplitExpiration.Nanoseconds(), 0) // Iterate through all partitioning lists to get all possible list"," "],"additions":91,"deletions":0,"truncated":false},{"path":"pkg/sql/index_split_scatter_test.go","lines":["@@ -7,10 +7,13 @@ package sql_test"," "," import ("," \t\"context\"","+\t\"fmt\""," \t\"sync/atomic\""," \t\"testing\""," "," \t\"github.com/cockroachdb/cockroach/pkg/base\"","+\t\"github.com/cockroachdb/cockroach/pkg/config\"","+\t\"github.com/cockroachdb/cockroach/pkg/keys\""," \t\"github.com/cockroachdb/cockroach/pkg/sql\""," \t\"github.com/cockroachdb/cockroach/pkg/testutils\""," \t\"github.com/cockroachdb/cockroach/pkg/testutils/serverutils\"","@@ -18,9 +21,109 @@ import ("," \t\"github.com/cockroachdb/cockroach/pkg/testutils/sqlutils\""," \t\"github.com/cockroachdb/cockroach/pkg/util/leaktest\""," \t\"github.com/cockroachdb/cockroach/pkg/util/log\"","+\t\"github.com/cockroachdb/errors\""," \t\"github.com/stretchr/testify/require\""," )"," ","+// TestIndexSplitAndScatterSkipsSmallTable verifies that MaybeSplitIndexSpans","+// skips splitting when table statistics indicate the table is smaller than","+// the table's RangeMaxBytes, and proceeds normally when the table is large","+// enough.","+func TestIndexSplitAndScatterSkipsSmallTable(t *testing.T) {","+\tdefer leaktest.AfterTest(t)()","+\tdefer log.Scope(t).Close(t)","+","+\tskip.UnderDuress(t, \"test takes too long under duress\")","+","+\tctx := context.Background()","+\tvar splitCount atomic.Int64","+\ts, sqlDB, _ := serverutils.StartServer(t, base.TestServerArgs{","+\t\tKnobs: base.TestingKnobs{","+\t\t\tSQLExecutor: &sql.ExecutorTestingKnobs{","+\t\t\t\tBeforeIndexSplitAndScatter: func(splitPoints [][]byte) {","+\t\t\t\t\tsplitCount.Swap(int64(len(splitPoints)))","+\t\t\t\t},","+\t\t\t},","+\t\t},","+\t})","+\tdefer s.Stopper().Stop(ctx)","+\trunner := sqlutils.MakeSQLRunner(sqlDB)","+","+\t// Set range_max_bytes to the minimum so we can exceed it with a","+\t// reasonable amount of data.","+\tconst rangeMaxBytes = 64 << 20 // 64 MB (minimum allowed)","+\trunner.Exec(t, fmt.Sprintf(","+\t\t\"ALTER RANGE default CONFIGURE ZONE USING range_max_bytes = %d, range_min_bytes = 1\",","+\t\trangeMaxBytes,","+\t))","+","+\t// Wait for the zone config change to propagate through the gossip-based","+\t// system config cache. rangeMaxBytesForTable reads from this cache, and","+\t// without this wait the test is flaky (~10% of the time the cache still","+\t// has the old default of 512 MB).","+\ttestutils.SucceedsSoon(t, func() error {","+\t\tcfg := s.SystemConfigProvider().GetSystemConfig()","+\t\tif cfg == nil {","+\t\t\treturn errors.New(\"system config not yet available\")","+\t\t}","+\t\tzc, err := cfg.GetZoneConfigForObject(","+\t\t\ts.Codec(), config.ObjectID(keys.RootNamespaceID),","+\t\t)","+\t\tif err != nil {","+\t\t\treturn errors.Wrap(err, \"looking up zone config\")","+\t\t}","+\t\tif zc == nil || zc.RangeMaxBytes == nil || *zc.RangeMaxBytes != rangeMaxBytes {","+\t\t\treturn errors.New(\"zone config not yet propagated\")","+\t\t}","+\t\treturn nil","+\t})","+","+\t// Disable automatic statistics so we control when stats are refreshed.","+\trunner.Exec(t, \"SET CLUSTER SETTING sql.stats.automatic_collection.enabled = false\")","+","+\t// Creating an index with skip_splits_for_small_tables disabled should create splits.","+\trunner.Exec(t, \"CREATE TABLE t_splits (k INT PRIMARY KEY, v INT, payload STRING)\")","+\trunner.Exec(t, \"SET CLUSTER SETTING schemachanger.backfiller.skip_splits_for_small_tables.enabled = false\")","+\tsplitCount.Store(0)","+\trunner.Exec(t, \"CREATE INDEX idx_disable_skip ON t_splits (v)\")","+\trequire.Greater(t, splitCount.Load(), int64(0),","+\t\t\"expected splits when cluster setting is disabled\")","+\trunner.Exec(t, \"SET CLUSTER SETTING schemachanger.backfiller.skip_splits_for_small_tables.enabled = true\")","+","+\t// Creating an index on table without stats should skip splits.","+\tsplitCount.Store(0)","+\trunner.Exec(t, \"CREATE INDEX idx_no_stats ON t_splits (v)\")","+\trequire.Equal(t, int64(0), splitCount.Load(),","+\t\t\"expected no splits on a table with no stats\")","+","+\t// Collect stats so the cache knows RowCount=0. Creating an index","+\t// on the empty table should skip splits.","+\trunner.Exec(t, \"CREATE STATISTICS s FROM t_splits\")","+\trunner.Exec(t, \"CREATE INDEX idx_empty ON t_splits (v)\")","+\trequire.Equal(t, int64(0), splitCount.Load(),","+\t\t\"expected no splits on an empty table with stats\")","+","+\t// Insert data and refresh stats. The estimated table size (~1 MB)","+\t// is well below the 64 MB RangeMaxBytes, so splits are still skipped.","+\trunner.Exec(t, \"INSERT INTO t_splits SELECT i, i, repeat('x', 1000) FROM generate_series(1, 1000) AS g(i)\")","+\trunner.Exec(t, \"CREATE STATISTICS s FROM t_splits\")","+","+\trunner.Exec(t, \"CREATE INDEX idx_small ON t_splits (v, k)\")","+\trequire.Equal(t, int64(0), splitCount.Load(),","+\t\t\"expected no splits on a small table below RangeMaxBytes\")","+","+\t// Insert enough data to well exceed 64 MB. Use 10k rows with 10 KB","+\t// payloads (10k × 10 KB ≈ 100 MB) to keep the insert fast while","+\t// having enough rows for the stats-based split point generator.","+\trunner.Exec(t, \"INSERT INTO t_splits SELECT i, i, repeat('x', 10000) FROM generate_series(1001, 11000) AS g(i)\")","+\trunner.Exec(t, \"CREATE STATISTICS s FROM t_splits\")","+","+\tsplitCount.Store(0)","+\trunner.Exec(t, \"CREATE INDEX idx_large ON t_splits (v, k)\")","+\trequire.Greater(t, splitCount.Load(), int64(0),","+\t\t\"expected splits on a large table above RangeMaxBytes\")","+}","+"," // TestIndexSplitAndScatterWithStats tests the creation of indexes on tables with statistics,"," // where the splits will be generated using statistics on the table."," func TestIndexSplitAndScatterWithStats(t *testing.T) {","@@ -50,6 +153,9 @@ func TestIndexSplitAndScatterWithStats(t *testing.T) {"," \t\t})"," \t\tdefer cluster.Stopper().Stop(ctx)"," \t\trunner := sqlutils.MakeSQLRunner(cluster.ServerConn(0))","+\t\t// Disable the small-table size check so this test exercises the","+\t\t// stats-based split point generation.","+\t\trunner.Exec(t, \"SET CLUSTER SETTING schemachanger.backfiller.skip_splits_for_small_tables.enabled = false\")"," \t\t// Disable automatic statistics."," \t\trunner.Exec(t, \"SET CLUSTER SETTING sql.stats.automatic_collection.enabled = false\")"," \t\t// Create and populate the tables."],"additions":106,"deletions":0,"truncated":false},{"path":"pkg/sql/logictest/testdata/logic_test/hash_sharded_index","lines":["@@ -1125,34 +1125,26 @@ CREATE TABLE t_hash_pre_split (","   b INT"," );"," ","-skipif config 3node-tenant-default-configs","+skipif config 3node-tenant-default-configs local-mixed-25.4 local-mixed-26.1 local-mixed-26.2"," query TITTT retry,rowsort"," SELECT table_name, table_id, index_name, start_key, end_key","   FROM [SHOW RANGES FROM DATABASE test WITH INDEXES]","  WHERE table_name = 't_hash_pre_split'"," ----","-t_hash_pre_split  134  t_hash_pre_split_pkey  /Table/129/3/7  /Max","+t_hash_pre_split  134  t_hash_pre_split_pkey  /Table/80  /Max"," "," statement ok"," CREATE INDEX t_hash_pre_split_idx_b ON t_hash_pre_split (b) USING HASH WITH (bucket_count=8);"," ","-skipif config 3node-tenant-default-configs","+skipif config 3node-tenant-default-configs local-mixed-25.4 local-mixed-26.1 local-mixed-26.2"," query TITTT colnames,retry,rowsort"," SELECT table_name, table_id, index_name, start_key, end_key","   FROM [SHOW RANGES FROM DATABASE test WITH INDEXES]","  WHERE table_name = 't_hash_pre_split'"," ----","-table_name        table_id  index_name              start_key       end_key","-t_hash_pre_split  134       t_hash_pre_split_pkey   /Table/129/3/7  /Table/134/2","-t_hash_pre_split  134       t_hash_pre_split_idx_b  /Table/134/2    /Table/134/2/0","-t_hash_pre_split  134       t_hash_pre_split_idx_b  /Table/134/2/0  /Table/134/2/1","-t_hash_pre_split  134       t_hash_pre_split_idx_b  /Table/134/2/1  /Table/134/2/2","-t_hash_pre_split  134       t_hash_pre_split_idx_b  /Table/134/2/2  /Table/134