m\"","+)]","+pub(crate) struct IncompatibleArchiveFormat {","+    pub path: PathBuf,","+    pub actual: String,","+    pub expected: String,","+}","+"," #[derive(Diagnostic)]"," #[diag(\"linking static libraries is not supported for BPF\")]"," pub(crate) struct BpfStaticlibNotSupported;"],"additions":12,"deletions":0,"truncated":false},{"path":"tests/run-make/archive-corrupt-error/corrupt.a","lines":["@@ -0,0 +1,3 @@","+!<arch>","+corrupt.o/      0           0     0     100644  10000     `","+small_data"],"additions":3,"deletions":0,"truncated":false},{"path":"tests/run-make/archive-corrupt-error/lib.rs","lines":["@@ -0,0 +1,3 @@","+extern \"C\" {","+    fn foo() -> i32;","+}"],"additions":3,"deletions":0,"truncated":false},{"path":"tests/run-make/archive-corrupt-error/rmake.rs","lines":["@@ -0,0 +1,21 @@","+// Regression test for https://github.com/rust-lang/rust/issues/148217","+// A corrupt archive with member offset exceeding file boundary should produce","+// an error, not an ICE.","+","+//@ ignore-cross-compile","+","+use run_make_support::{path, rfs, rustc, static_lib_name};","+","+fn main() {","+    rfs::create_dir(\"archive\");","+    rfs::copy(\"corrupt.a\", path(\"archive\").join(static_lib_name(\"corrupt\")));","+    rustc()","+        .input(\"lib.rs\")","+        .crate_type(\"rlib\")","+        .library_search_path(\"archive\")","+        .arg(\"-lstatic=corrupt\")","+        .run_fail()","+        .assert_stderr_not_contains(\"panicked\")","+        .assert_stderr_not_contains(\"unexpectedly panicked\")","+        .assert_stderr_contains(\"invalid archive member\");","+}"],"additions":21,"deletions":0,"truncated":false},{"path":"tests/run-make/archive-format-error/lib.rs","lines":["@@ -0,0 +1,3 @@","+extern \"C\" {","+    fn foo() -> i32;","+}"],"additions":3,"deletions":0,"truncated":false},{"path":"tests/run-make/archive-format-error/native.c","lines":["@@ -0,0 +1 @@","+int foo() { return 42; }"],"additions":1,"deletions":0,"truncated":false},{"path":"tests/run-make/archive-format-error/rmake.rs","lines":["@@ -0,0 +1,22 @@","+// Regression test for https://github.com/rust-lang/rust/issues/148217","+// BSD format archive on a Linux target should emit a format mismatch warning.","+","+//@ ignore-cross-compile","+//@ only-linux","+","+use run_make_support::{cc, llvm_ar, path, rfs, rustc, static_lib_name};","+","+fn main() {","+    rfs::create_dir(\"archive\");","+","+    cc().arg(\"-c\").input(\"native.c\").output(\"archive/native.o\").run();","+    let bsd_archive = path(\"archive\").join(static_lib_name(\"native_bsd\"));","+    llvm_ar().arg(\"rcus\").arg(\"--format=bsd\").output_input(&bsd_archive, \"archive/native.o\").run();","+    rustc()","+        .input(\"lib.rs\")","+        .crate_type(\"rlib\")","+        .library_search_path(\"archive\")","+        .arg(\"-lstatic=native_bsd\")","+        .run()","+        .assert_stderr_contains(\"was built as BSD format, but the target expects GNU\");","+}",""],"additions":22,"deletions":0,"truncated":false}],"additions":141,"deletions":4,"truncated":false,"file_count":8},"error":null,"fetched_at":"2026-05-20T17:44:43.378390+00:00"}