 update API, switches to","+// the new root partition, and asks gokrazy to reboot.","+//","+// The local gokrazy API is reached over gokrazyUpdateSocket. The","+// gokrazyUpdateBaseURL host is only a net/http URL sentinel; it is not resolved","+// with DNS.","+func init() {","+\tGokrazyUpdateFromURL.Set(gokrazyUpdateFromURL)","+}","+","+func gokrazyUpdateFromURL(ctx context.Context, args GokrazyUpdateArgs) error {","+\tlogf := args.Logf","+\tif logf == nil {","+\t\tlogf = logger.Discard","+\t}","+\tif !args.AllowUnsigned {","+\t\treturn fmt.Errorf(\"signed GAF verification is not implemented yet; see https://github.com/tailscale/tailscale/issues/20002\")","+\t}","+","+\ttmp, err := os.CreateTemp(\"\", \"tailscale-gokrazy-*.gaf\")","+\tif err != nil {","+\t\treturn err","+\t}","+\ttmpName := tmp.Name()","+\tdefer os.Remove(tmpName)","+","+\treq, err := http.NewRequestWithContext(ctx, \"GET\", args.URL, nil)","+\tif err != nil {","+\t\ttmp.Close()","+\t\treturn err","+\t}","+\tres, err := http.DefaultClient.Do(req)","+\tif err != nil {","+\t\ttmp.Close()","+\t\treturn err","+\t}","+\tdefer res.Body.Close()","+\tif res.StatusCode != http.StatusOK {","+\t\ttmp.Close()","+\t\treturn fmt.Errorf(\"download GAF: %s\", res.Status)","+\t}","+\tif _, err := io.Copy(tmp, res.Body); err != nil {","+\t\ttmp.Close()","+\t\treturn err","+\t}","+\tif err := tmp.Close(); err != nil {","+\t\treturn err","+\t}","+","+\tzr, err := zip.OpenReader(tmpName)","+\tif err != nil {","+\t\treturn err","+\t}","+\tdefer zr.Close()","+","+\tgokClient := gokrazyHTTPClient()","+\tfor _, part := range []struct {","+\t\tname string","+\t\tpath string","+\t}{","+\t\t{\"root.img\", \"/update/root\"},","+\t\t{\"boot.img\", \"/update/boot\"},","+\t\t{\"mbr.img\", \"/update/mbr\"},","+\t} {","+\t\tif err := putGokrazyGAFMember(ctx, gokClient, zr.File, part.name, part.path); err != nil {","+\t\t\treturn err","+\t\t}","+\t\tlogf(\"wrote %s\", part.name)","+\t}","+\tif err := postGokrazy(ctx, gokClient, \"/update/switch\"); err != nil {","+\t\treturn err","+\t}","+\tlogf(\"switched boot target\")","+\tif err := postGokrazy(ctx, gokClient, \"/reboot?async=true&kexec_merge_cmdline=true\"); err != nil {","+\t\treturn err","+\t}","+\tlogf(\"reboot requested\")","+\treturn nil","+}","+","+func gokrazyHTTPClient() *http.Client {","+\ttr := http.DefaultTransport.(*http.Transport).Clone()","+\ttr.DialContext = func(ctx context.Context, network, addr string) (net.Conn, error) {","+\t\tvar d net.Dialer","+\t\treturn d.DialContext(ctx, \"unix\", gokrazyUpdateSocket)","+\t}","+\treturn &http.Client{","+\t\tTransport: tr,","+\t\tCheckRedirect: func(req *http.Request, via []*http.Request) error {","+\t\t\treturn http.ErrUseLastResponse","+\t\t},","+\t}","+}","+","+func putGokrazyGAFMember(ctx context.Context, hc *http.Client, files []*zip.File, name, path string) error {","+\tvar zf *zip.File","+\tfor _, f := range files {","+\t\tif f.Name == name {","+\t\t\tzf = f","+\t\t\tbreak","+\t\t}","+\t}","+\tif zf == nil {","+\t\treturn fmt.Errorf(\"GAF is missing %s\", name)","+\t}","+\trc, err := zf.Open()","+\tif err != nil {","+\t\treturn err","+\t}","+\tdefer rc.Close()","+","+\th := crc32.NewIEEE()","+\tbody := io.TeeReader(rc, h)","+\treq, err := http.NewRequestWithContext(ctx, \"PUT\", gokrazyUpdateBaseURL+path, body)","+\tif err != nil {","+\t\treturn err","+\t}","+\treq.ContentLength = int64(zf.UncompressedSize64)","+\treq.Header.Set(\"X-Gokrazy-Update-Hash\", \"crc32\")","+\tres, err := hc.Do(req)","+\tif err != nil {","+\t\treturn err","+\t}","+\tdefer res.Body.Close()","+\tresBody, _ := io.ReadAll(io.LimitReader(res.Body, 1<<20))","+\tif res.StatusCode != http.StatusOK {","+\t\treturn fmt.Errorf(\"PUT %s: %s: %s\", path, res.Status, strings.TrimSpace(string(resBody)))","+\t}","+\tif got, want := strings.TrimSpace(string(resBody)), fmt.Sprintf(\"%08x\", h.Sum32()); got != want {","+\t\treturn fmt.Errorf(\"PUT %s: gokrazy checksum = %q; want %q\", path, got, want)","+\t}","+\treturn nil","+}","+","+func postGokrazy(ctx context.Context, hc *http.Client, path string) error {","+\treq, err := http.NewRequestWithContext(ctx, \"POST\", gokrazyUpdateBaseURL+path, nil)","+\tif err != nil {","+\t\treturn err","+\t}","+\tres, err := hc.Do(req)","+\tif err != nil {","+\t\treturn err","+\t}","+\tdefer res.Body.Close()","+\tif res.StatusCode != http.StatusOK {","+\t\tbody, _ := io.ReadAll(io.LimitReader(res.Body, 1<<20))","+\t\treturn fmt.Errorf(\"POST %s: %s: %s\", path, res.Status, strings.TrimSpace(string(body)))","+\t}","+\treturn nil","+}"],"additions":177,"deletions":0,"truncated":false},{"path":"cmd/tailscale/cli/update.go","lines":["@@ -10,6 +10,7 @@ import ("," \t\"errors\""," \t\"flag\""," \t\"fmt\"","+\t\"io\""," \t\"runtime\""," "," \t\"github.com/peterbourgon/ff/v3/ffcli\"","@@ -67,8 +68,19 @@ var updateArgs struct {"," \tversion string // explicit version; empty means auto"," }"," ","+const gokrazyUpdateFromURLMagicArg = \"--gokrazy-update-from-url\"","+"," func runUpdate(ctx context.Context, args []string) error {"," \tif len(args) > 0 {","+\t\tif runtime.GOOS == \"linux\" && distro.Get() == distro.Gokrazy {","+\t\t\tgokArgs, err := gokrazyUpdateArgsFromMagicArg(args)","+\t\t\tif err != nil {","+\t\t\t\treturn err","+\t\t\t}","+\t\t\tif gokArgs != nil {","+\t\t\t\treturn clientupdate.GokrazyUpdateFromURL.Get()(ctx, *gokArgs)","+\t\t\t}","+\t\t}"," \t\treturn flag.ErrHelp"," \t}"," \tif updateArgs.version != \"\" && updateArgs.track != \"\" {","@@ -102,3 +114,39 @@ func confirmUpdate(ver string) bool {"," \tmsg := fmt.Sprintf(\"This will update Tailscale from %v to %v. Continue?\", version.Short(), ver)"," \treturn prompt.YesNo(msg, true)"," }","+","+// gokrazyUpdateArgsFromMagicArg parses the Gokrazy update-from-URL command-line","+// flow. It returns nil if args do not select that flow. A non-nil result means","+// the caller may safely invoke clientupdate.GokrazyUpdateFromURL.","+func gokrazyUpdateArgsFromMagicArg(args []string) (*clien