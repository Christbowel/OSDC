:= map[string]string{","+\t\t\t\"user\": \"alice\",","+\t\t\t\"role\": \"admin\",","+\t\t}","+\t\tdesc, err := BuildTokenDescription(\"my-prefix\", meta)","+\t\trequire.NoError(t, err)","+","+\t\t// Maps are unordered, so checking exact JSON string match can be flaky.","+\t\t// Instead, we verify the prefix and that both keys/values are present in the JSON.","+\t\trequire.True(t, strings.HasPrefix(desc, \"my-prefix: {\"))","+\t\trequire.Contains(t, desc, `\"user\":\"alice\"`)","+\t\trequire.Contains(t, desc, `\"role\":\"admin\"`)","+\t\trequire.True(t, strings.HasSuffix(desc, \"}\"))","+\t})","+\tt.Run(\"empty prefix with meta\", func(t *testing.T) {","+\t\tmeta := map[string]string{\"env\": \"prod\"}","+\t\tdesc, err := BuildTokenDescription(\"\", meta)","+\t\trequire.NoError(t, err)","+","+\t\t// It should format as \": {\"env\":\"prod\"}\" based on the fmt.Sprintf(\"%s: %s\") logic","+\t\trequire.True(t, strings.HasPrefix(desc, \": {\"))","+\t\trequire.Contains(t, desc, `\"env\":\"prod\"`)","+\t})","+","+\tt.Run(\"meta with special characters\", func(t *testing.T) {","+\t\tmeta := map[string]string{","+\t\t\t\"complex\": \"value \\\"with quotes\\\" \\n and newlines\",","+\t\t\t\"unicode\": \"💥 symbols\",","+\t\t}","+\t\tdesc, err := BuildTokenDescription(\"prefix\", meta)","+\t\trequire.NoError(t, err)","+","+\t\t// Ensure the JSON marshal correctly escaped the quotes and newlines","+\t\trequire.Contains(t, desc, `\"value \\\"with quotes\\\" \\n and newlines\"`)","+\t\trequire.Contains(t, desc, `\"💥 symbols\"`)","+\t})","+}","+","+func TestFormatTokenName(t *testing.T) {","+\tt.Parallel()","+","+\tt.Run(\"nil auth method\", func(t *testing.T) {","+\t\tname, err := FormatTokenName(nil, nil)","+\t\trequire.NoError(t, err)","+\t\trequire.Empty(t, name)","+\t})","+","+\tt.Run(\"empty token name format\", func(t *testing.T) {","+\t\tauthMethod := &structs.ACLAuthMethod{","+\t\t\tName: \"test-method\",","+\t\t\tType: \"testing\",","+\t\t}","+\t\tname, err := FormatTokenName(authMethod, nil)","+\t\trequire.NoError(t, err)","+\t\trequire.Empty(t, name)","+\t})","+","+\tt.Run(\"valid format with standard fields\", func(t *testing.T) {","+\t\tauthMethod := &structs.ACLAuthMethod{","+\t\t\tName:            \"k8s-dev\",","+\t\t\tType:            \"kubernetes\",","+\t\t\tTokenNameFormat: \"${auth_method_type}-${auth_method_name}\",","+\t\t}","+","+\t\tname, err := FormatTokenName(authMethod, nil)","+\t\trequire.NoError(t, err)","+","+\t\t// Expect the interpolated prefix followed by a random uint64 suffix","+\t\trequire.True(t, strings.HasPrefix(name, \"kubernetes-k8s-dev-\"))","+\t\trequire.NotEqual(t, \"kubernetes-k8s-dev-\", name) // Ensure suffix exists","+\t})","+","+\tt.Run(\"valid format with claims\", func(t *testing.T) {","+\t\tauthMethod := &structs.ACLAuthMethod{","+\t\t\tName:            \"jwt-prod\",","+\t\t\tType:            \"jwt\",","+\t\t\tTokenNameFormat: \"${auth_method_name}-${value.app}-${value.env}\",","+\t\t}","+\t\tclaims := map[string]string{","+\t\t\t\"app\": \"frontend\",","+\t\t\t\"env\": \"production\",","+\t\t}","+","+\t\tname, err := FormatTokenName(authMethod, claims)","+\t\trequire.NoError(t, err)","+","+\t\trequire.True(t, strings.HasPrefix(name, \"jwt-prod-frontend-production-\"))","+\t})","+\tt.Run(\"static token name format (no interpolation)\", func(t *testing.T) {","+\t\tauthMethod := &structs.ACLAuthMethod{","+\t\t\tName:            \"static-method\",","+\t\t\tType:            \"testing\",","+\t\t\tTokenNameFormat: \"my-hardcoded-prefix\",","+\t\t}","+","+\t\tname, err := FormatTokenName(authMethod, nil)","+\t\trequire.NoError(t, err)","+","+\t\t// Expect the literal string followed by a random uint64 suffix","+\t\trequire.True(t, strings.HasPrefix(name, \"my-hardcoded-prefix-\"))","+\t\trequire.NotEqual(t, \"my-hardcoded-prefix-\", name)","+\t})","+","+\tt.Run(\"missing claim variable in format\", func(t *testing.T) {","+\t\tauthMethod := &structs.ACLAuthMethod{","+\t\t\tName: \"jwt-test\",","+\t\t\tType: \"jwt\",","+\t\t\t// Format expects value.namespace, but we won't provide it","+\t\t\tTokenNameFormat: \"${auth_method_name}-${value.namespace}\",","+\t\t}","+","+\t\t// Passing nil claims means \"value.namespace\" won't exist in the valueMap","+\t\tname, err := FormatTokenName(authMethod, nil)","+\t\trequire.Error(t, err)","+\t\trequire.Contains(t, err.Error(), \"unknown variable accessed: value.namespace\")","+\t\trequire.Empty(t, name)","+\t})","+","+\tt.Run(\"unknown root variable in format\", func(t *testing.T) {","+\t\tauthMethod := &structs.ACLAuthMethod{","+\t\t\tName: \"test\",","+\t\t\tType: \"testing\",","+\t\t\t// Format accesses a variable that FormatTokenName never populates","+\t\t\tTokenNameFormat: \"${random_unsupported_var}\",","+\t\t}","+","+\t\tname, err := FormatTokenName(authMethod, nil)","+\t\trequire.Error(t, err)","+\t\trequire.Contains(t, err.Error(), \"unknown variable accessed: random_unsupported_var\")","+\t\trequire.Empty(t, name)","+\t})","+}","+","+func TestParseTokenName(t *testing.T) {","+\tt.Parallel()","+","+\tauthMethod := &structs.ACLAuthMethod{","+\t\tTokenNameFormat: \"${namespace}-${role}\",","+\t}","+","+\tt.Run(\"successful interpolation without random suffix\", func(t *testing.T) {","+\t\tvalues := map[string]string{","+\t\t\t\"namespace\": \"default\",","+\t\t\t\"role\":      \"web\",","+\t\t}","+","+\t\tname, err := ParseTokenName(authMethod, values, false)","+\t\trequire.NoError(t, err)","+\t\trequire.Equal(t, \"default-web\", name)","+\t})","+","+\tt.Run(\"successful interpolation with random suffix\", func(t *testing.T) {","+\t\tvalues := map[string]string{","+\t\t\t\"namespace\": \"default\",","+\t\t\t\"role\":      \"web\",","+\t\t}","+","+\t\tname, err := ParseTokenName(authMethod, values, true)","+\t\trequire.NoError(t, err)","+\t\trequire.True(t, strings.HasPrefix(name, \"default-web-\"))","+","+\t\t// Suffix should be a numeric string","+\t\tparts := strings.Split(name, \"-\")","+\t\trequire.Len(t, parts, 3)","+\t\trequire.NotEmpty(t, parts[2])","+\t})","+","+\tt.Run(\"invalid HIL syntax\", func(t *testing.T) {","+\t\tinvalidAuthMethod := &structs.ACLAuthMethod{","+\t\t\tTokenNameFormat: \"${namespace}-${something-wrong}\",","+\t\t}","+\t\tvalues := map[string]string{","+\t\t\t\"namespace\": \"default\",","+\t\t}","+","+\t\tname, err := ParseTokenName(invalidAuthMethod, values, false)","+\t\trequire.Error(t, err)","+\t\trequire.Contains(t, err.Error(), \"failed to generate ACL token name\")","+\t\trequire.Empty(t, name)","+\t})","+\tt.Run(\"empty format string\", func(t *testing.T) {","+\t\temptyAuthMethod := &structs.ACLAuthMethod{","+\t\t\tTokenNameFormat: \"\",","+\t\t}","+\t\tvalues := map[string]string{\"foo\": \"bar\"}","+","+\t\tname, err := ParseTokenName(emptyAuthMethod, values, true)","+\t\trequire.NoError(t, err)","+","+\t\t// An empty format string should interpolate to \"\",","+\t\t// but the suffixRandomInt logic appends \"-[random]\"","+\t\trequire.True(t, strings.HasPrefix(name, \"-\"))","+\t\trequire.NotEqual(t, \"-\", name)","+\t})","+","+\tt.Run(\"literal format without random suffix\", func(t *testing.T) {","+\t\tliteralAuthMethod := &structs.ACLAuthMethod{","+\t\t\tTokenNameFormat: \"just-a-string\",","+\t\t}","+","+\t\tname, err := ParseTokenName(literalAuthMethod, nil, false)","+\t\trequire.NoError(t, err)","+\t\trequire.Equal(t, \"just-a-string\", name)","+\t})","+","+\tt.Run(\"missing variable in value map\", func(t *testing.T) {","+\t\tmethod := &structs.ACLAuthMethod{","+\t\t\tTokenNameFormat: \"${missing_var}\",","+\t\t}","+","+\t\t// Empty map, so \"missing_var\" cannot be resolved","+\t\tname, err := ParseTokenName(method, map[string]string{}, false)","+\t\trequire.Error(t, err)","+\t\trequire.Contains(t, err.Error(), \"failed to generate ACL token name\")","+\t\trequire.Contains(t, err.Error(), \"unknown variable accessed: missing_var\")","+\t\trequire.Empty(t, name)","+\t})","+","+\tt.Run(\"malformed HIL expression (unclosed brace)