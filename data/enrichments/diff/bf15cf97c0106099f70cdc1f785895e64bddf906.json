nto(out *Json) {","+\tb, err := j.Encode()","+\tif err == nil {","+\t\t_ = out.UnmarshalJSON(b)","+\t}","+}","+","+// DeepCopy will make a deep copy of the JSON object","+func (j *Json) DeepCopy() *Json {","+\tif j == nil {","+\t\treturn nil","+\t}","+\tout := new(Json)","+\tj.DeepCopyInto(out)","+\treturn out","+}","+","+// NewJson returns a pointer to a new `Json` object","+// after unmarshaling `body` bytes","+func NewJson(body []byte) (*Json, error) {","+\tj := new(Json)","+\terr := j.UnmarshalJSON(body)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\treturn j, nil","+}","+","+// MustJson returns a pointer to a new `Json` object, panicking if `body` cannot be parsed.","+func MustJson(body []byte) *Json {","+\tj, err := NewJson(body)","+","+\tif err != nil {","+\t\tpanic(fmt.Sprintf(\"could not unmarshal JSON: %q\", err))","+\t}","+","+\treturn j","+}","+","+// New returns a pointer to a new, empty `Json` object","+func New() *Json {","+\treturn &Json{","+\t\tdata: make(map[string]any),","+\t}","+}","+","+// NewFromAny returns a pointer to a new `Json` object with provided data.","+func NewFromAny(data any) *Json {","+\treturn &Json{data: data}","+}","+","+// Interface returns the underlying data","+func (j *Json) Interface() any {","+\treturn j.data","+}","+","+// Encode returns its marshaled data as `[]byte`","+func (j *Json) Encode() ([]byte, error) {","+\treturn j.MarshalJSON()","+}","+","+// EncodePretty returns its marshaled data as `[]byte` with indentation","+func (j *Json) EncodePretty() ([]byte, error) {","+\treturn json.MarshalIndent(&j.data, \"\", \"  \")","+}","+","+// Implements the json.Marshaler interface.","+func (j *Json) MarshalJSON() ([]byte, error) {","+\treturn json.Marshal(&j.data)","+}","+","+// Set modifies `Json` map by `key` and `value`","+// Useful for changing single key/value in a `Json` object easily.","+func (j *Json) Set(key string, val any) {","+\tm, err := j.Map()","+\tif err != nil {","+\t\treturn","+\t}","+\tm[key] = val","+}","+","+// SetPath modifies `Json`, recursively checking/creating map keys for the supplied path,","+// and then finally writing in the value","+func (j *Json) SetPath(branch []string, val any) {","+\tif len(branch) == 0 {","+\t\tj.data = val","+\t\treturn","+\t}","+","+\t// in order to insert our branch, we need map[string]any","+\tif _, ok := (j.data).(map[string]any); !ok {","+\t\t// have to replace with something suitable","+\t\tj.data = make(map[string]any)","+\t}","+\tcurr := j.data.(map[string]any)","+","+\tfor _, b := range branch[:len(branch)-1] {","+\t\t// key exists?","+\t\tif _, ok := curr[b]; !ok {","+\t\t\tn := make(map[string]any)","+\t\t\tcurr[b] = n","+\t\t\tcurr = n","+\t\t\tcontinue","+\t\t}","+","+\t\t// make sure the value is the right sort of thing","+\t\tif _, ok := curr[b].(map[string]any); !ok {","+\t\t\t// have to replace with something suitable","+\t\t\tn := make(map[string]any)","+\t\t\tcurr[b] = n","+\t\t}","+","+\t\tcurr = curr[b].(map[string]any)","+\t}","+","+\t// add remaining k/v","+\tcurr[branch[len(branch)-1]] = val","+}","+","+// Del modifies `Json` map by deleting `key` if it is present.","+func (j *Json) Del(key string) {","+\tm, err := j.Map()","+\tif err != nil {","+\t\treturn","+\t}","+\tdelete(m, key)","+}","+","+// Get returns a pointer to a new `Json` object","+// for `key` in its `map` representation","+//","+// useful for chaining operations (to traverse a nested JSON):","+//","+//\tjs.Get(\"top_level\").Get(\"dict\").Get(\"value\").Int()","+func (j *Json) Get(key string) *Json {","+\tm, err := j.Map()","+\tif err == nil {","+\t\tif val, ok := m[key]; ok {","+\t\t\treturn &Json{val}","+\t\t}","+\t}","+\treturn &Json{nil}","+}","+","+// GetPath searches for the item as specified by the branch","+// without the need to deep dive using Get()'s.","+//","+//\tjs.GetPath(\"top_level\", \"dict\")","+func (j *Json) GetPath(branch ...string) *Json {","+\tjin := j","+\tfor _, p := range branch {","+\t\tjin = jin.Get(p)","+