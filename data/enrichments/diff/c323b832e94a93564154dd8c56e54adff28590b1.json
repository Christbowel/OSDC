) => {","+    if (noRefreshApplyingAndBlockingWritesEnabled) {","+        return {cmdName: \"_shardsvrReshardDonorCriticalSectionStarted\", numSkips: 0};","+    }","+    return {","         cmdName: \"_flushReshardingStateChange\",","-        numSkips: expectedFlushCount,","-    },","+        numSkips: cloneNoRefreshEnabled ? 1 : 2,","+    };","+})();","+const cmdsToBlock = [","+    criticalSectionDonorBlock,","     {","         cmdName: \"_shardsvrReshardingDonorFetchFinalCollectionStats\",","         // No skipping."],"additions":19,"deletions":16,"truncated":false},{"path":"src/mongo/db/s/resharding/resharding_coordinator.h","lines":["@@ -539,6 +539,12 @@ class ReshardingCoordinator final","      */","     void _tellAllDonorsToRefresh(const std::shared_ptr<executor::ScopedTaskExecutor>& executor);"," ","+    /**","+     * Sends '_shardsvrReshardDonorCriticalSectionStarted' to all donor shards.","+     */","+    void _notifyDonorsCriticalSectionStarted(","+        const std::shared_ptr<executor::ScopedTaskExecutor>& executor);","+","     /**","      * If verification is enabled, sends '_shardsvrReshardingDonorStartChangeStreamsMonitor' to all","      * donor shards."],"additions":6,"deletions":0,"truncated":false},{"path":"src/mongo/db/s/resharding/resharding_coordinator.inl","lines":["@@ -562,7 +562,15 @@ ExecutorFuture<ReshardingCoordinatorDocument> ReshardingCoordinator::_runUntilRe","                            auto span = _startSpan(","                                telemetryCtx,","                                \"ReshardingCoordinator::tellAllParticipantsReshardingReadyToCommit\");","-                           _tellAllDonorsToRefresh(executor);","+                           if (resharding::gFeatureFlagReshardingNoRefreshApplyingAndBlockingWrites","+                                   .isEnabled(resharding::getVersionContextOrDefault(","+                                                  _forwardableOpMetadata),","+                                           