{"id":"24d3461ba71aa892ca5d2b2b4dce6e0107d3068d","axis":"silent","repo":"cockroachdb/cockroach","sha":"24d3461ba71aa892ca5d2b2b4dce6e0107d3068d","parsed":{"files":[{"path":"pkg/cmd/roachtest/tests/BUILD.bazel","lines":["@@ -326,6 +326,7 @@ go_library(","         \"//pkg/workload/debug\",","         \"//pkg/workload/histogram\",","         \"//pkg/workload/histogram/exporter\",","+        \"//pkg/workload/rand\",","         \"//pkg/workload/schemachange\",","         \"//pkg/workload/tpcc\",","         \"//pkg/workload/tpcds\","],"additions":1,"deletions":0,"truncated":false},{"path":"pkg/cmd/roachtest/tests/logical_data_replication.go","lines":["@@ -29,6 +29,7 @@ import ("," \t\"github.com/cockroachdb/cockroach/pkg/testutils/sqlutils\""," \t\"github.com/cockroachdb/cockroach/pkg/util/randutil\""," \t\"github.com/cockroachdb/cockroach/pkg/util/timeutil\"","+\tworkloadrand \"github.com/cockroachdb/cockroach/pkg/workload/rand\""," \t\"github.com/stretchr/testify/require\""," )"," ","@@ -493,11 +494,65 @@ func TestLDRConflict("," \t\tleftURL)"," "," \tt.Status(\"verifying results\")","-\tVerifyCorrectness(ctx, c, t, setup, leftJobID, rightJobID, 2*time.Minute, LDRWorkload{","-\t\tdbName:            \"conflict\",","-\t\ttableNames:        []string{\"conflict\"},","-\t\tmanualSchemaSetup: true,","-\t})","+\tverifyConflictCorrectness(ctx, t, setup, leftJobID, rightJobID)","+}","+","+// verifyConflictCorrectness waits for replication to catch up, checks DLQs,","+// and compares table fingerprints. If fingerprints diverge, it runs a row-level","+// diff. There is a known bug where the conflict workload can produce two","+// conflict rows with the same origin timestamp, causing LDR to resolve them","+// nondeterministically. If all differing rows have identical origin timestamps","+// on both sides, the test passes. Otherwise, the test fails and prints the","+// diffs.","+func verifyConflictCorrectness(","+\tctx context.Context, t test.Test, setup multiClusterSetup, leftJobID, rightJobID int,","+) {","+\tnow := timeutil.Now()","+\tt.Status(\"waiting for replicated times to catchup\")","+\twaitForReplicatedTimeToReachTimestamp(t, leftJobID, setup.left.db, getLogicalDataReplicationJobInfo, 2*time.Minute, now)","+\trequire.NoError(t, replicationtestutils.CheckEmptyDLQs(ctx, setup.left.db, \"conflict\"))","+\twaitForReplicatedTimeToReachTimestamp(t, rightJobID, setup.right.db, getLogicalDataReplicationJobInfo, 2*time.Minute, now)","+\trequire.NoError(t, replicationtestutils.CheckEmptyDLQs(ctx, setup.right.db, \"conflict\"))","+","+\tt.Status(\"comparing fingerprints\")","+\tfpQuery := \"SHOW EXPERIMENTAL_FINGERPRINTS FROM TABLE conflict.conflict\"","+\tfpLeft := setup.left.sysSQL.QueryStr(t, fpQuery)","+\tfpRight := setup.right.sysSQL.QueryStr(t, fpQuery)","+","+\tif fmt.Sprint(fpLeft) == fmt.Sprint(fpRight) {","+\t\tt.L().Printf(\"fingerprints match\")","+\t\treturn","+\t}","+","+\tt.Status(\"running row-level diff\")","+","+\t// Limit to 100 diffs: without a limit, the worst case reports the entire","+\t// database which is millions of rows. In practice we expect only 1-2 rows","+\t// with matching origin timestamps, so if there are 100 or more something","+\t// else is wrong.","+\tconst diffLimit = 100","+\tdiffs, err := workloadrand.Diff(setup.left.db, \"conflict.conflict\", setup.right.db, \"conflict.conflict\", diffLimit)","+\trequire.NoError(t, err)","+\trequire.NotEmpty(t, diffs, \"fingerprints differ but no row diffs found\")","+\trequire.Less(t, len(diffs), diffLimit, \"too many diffs; likely a real divergence, not a timestamp tie\")","+","+\t// Check if all diffs are caused by the known bug: two conflict rows with","+\t// the same origin timestamp cause nondeterministic resolution.","+\tfor _, diff := range diffs {","+\t\tif diff.RowA == nil || diff.RowB == nil {","+\t\t\t// TODO(jeffswenson): this case is a little sad because we don't","+\t\t\t// currently have a way to get the origin timestamp for a tombstone, so","+\t\t\t// we can't assert the only time we see this is on origin timestamp","+\t\t\t// conflicts.","+\t\t\tcontinue","+\t\t}","+\t\tif diff.OriginTimestampA == diff.OriginTimestampB {","+\t\t\t// TODO(#168541): if the origin timestamps are the same, lww conflict","+\t\t\t// resolution will tie and the clusters may diverge.","+\t\t\tcontinue","+\t\t}","+\t\tt.Errorf(\"fingerprints differ with mismatched origin timestamps: %s\", diff)","+\t}"," }"," "," // TestLDRCreateTablesTPCC inits the left cluster with 1000 warehouse tpcc,"],"additions":60,"deletions":5,"truncated":false},{"path":"pkg/crosscluster/ldrrandgen/logical.go","lines":["@@ -22,6 +22,14 @@ func isSupportedType(t *types.T) bool {"," \t\t// We don't support RefCursor columns in LDR tables because they do not"," \t\t// support equality."," \t\treturn false","+\tcase types.TSVectorFamily,","+\t\ttypes.TSQueryFamily,","+\t\ttypes.JsonpathFamily,","+\t\ttypes.PGVectorFamily:","+\t\t// These type families do not support keyside encoding, which means they","+\t\t// cannot be used with crdb_internal.datums_to_bytes. This prevents","+\t\t// fingerprinting and diff hashing from working.","+\t\treturn false"," \tcase types.ArrayFamily:"," \t\t// We don't allow Arrays of bits because rand.LoadTable doesn't correctly identify their bit width."," \t\tif t.ArrayContents().Family() == types.BitFamily {","@@ -63,6 +71,9 @@ func GenerateLDRTable("," \t\t}),"," \t\trandgen.WithPrimaryIndexFilter(func(indexDef *tree.IndexTableDef, columnDefs []*tree.ColumnTableDef) bool {"," \t\t\tfor _, col := range indexDef.Columns {","+\t\t\t\tif col.Expr != nil {","+\t\t\t\t\tcontinue","+\t\t\t\t}"," \t\t\t\tcolumnDef := columnByName(col.Column, columnDefs)"," \t\t\t\t// TODO(127315): types with composite encoding are not supported in the"," \t\t\t\t// primary key by LDR.","@@ -93,10 +104,15 @@ func GenerateLDRTable("," \t\t\t\treturn false"," \t\t\tcase *tree.IndexTableDef:"," \t\t\t\tfor _, col := range indexDef.Columns {","-\t\t\t\t\tif writerType == sqlclustersettings.LDRWriterTypeLegacyKV && col.Expr != nil {","-\t\t\t\t\t\t// Do not allow expression indexes. These cause SQL to generate a","-\t\t\t\t\t\t// hidden computed column, which is not supported by the kv writer.","-\t\t\t\t\t\treturn false","+\t\t\t\t\tif col.Expr != nil {","+\t\t\t\t\t\tif writerType == sqlclustersettings.LDRWriterTypeLegacyKV {","+\t\t\t\t\t\t\t// Expression indexes generate hidden computed","+\t\t\t\t\t\t\t// columns not supported by the KV writer.","+\t\t\t\t\t\t\treturn false","+\t\t\t\t\t\t}","+\t\t\t\t\t\t// Expression columns don't map to a column def;","+\t\t\t\t\t\t// skip column-level checks.","+\t\t\t\t\t\tcontinue"," \t\t\t\t\t}"," \t\t\t\t\tcolumnDef := columnByName(col.Column, columnDefs)"," \t\t\t\t\tif columnDef != nil && columnDef.IsVirtual() &&"],"additions":20,"deletions":4,"truncated":false},{"path":"pkg/workload/conflict/BUILD.bazel","lines":["@@ -5,7 +5,6 @@ go_library(","     srcs = [","         \"conflict.go\",","         \"conflict_worker.go\",","-        \"writer.go\",","     ],","     importpath = \"github.com/cockroachdb/cockroach/pkg/workload/conflict\",","     visibility = [\"//visibility:public\"],","@@ -18,7 +17,6 @@ go_library(","         \"//pkg/workload\",","         \"//pkg/workload/histogram\",","         \"//pkg/workload/rand\",","-        \"@com_github_cockroachdb_errors//:errors\",","         \"@com_github_jackc_pgx_v5//stdlib\",","         \"@com_github_spf13_pflag//:pflag\",","         \"@org_golang_x_sync//errgroup\",","@@ -27,29 +25,16 @@ go_library("," "," go_test(","     name = \"conflict_test\",","-    srcs = [","-        \"main_test.go\",","-        \"writer_test.go\",","-    ],","+    srcs = [\"main_test.go\"],","     data = [\"//c-deps:libgeos\"],","-    embed = [\":conflict\"],","     deps = [","         \"//pkg/base\",","         \"//pkg/ccl\",","-        \"//pkg/crosscluster/ldrrandgen\",","         \"//pkg/security/securityassets\",","         \"//pkg/security/securitytest\",","         \"//pkg/server\",","-        \"//pkg/sql/sem/tree\",","-        \"//pkg/sql/sqlclustersettings\",","-        \"//pkg/testutils\",","         \"//pkg/testutils/serverutils\",","-        \"//pkg/testutils/sqlutils\",","         \"//pkg/testutils/testcluster\",","-        \"//pkg/util/leaktest\",","-        \"//pkg/util/log\",","         \"//pkg/util/randutil\",","-        \"//pkg/workload/rand\",","-        \"@com_github_stretchr_testify//require\",","     ],"," )"],"additions":1,"deletions":16,"truncated":false},{"path":"pkg/workload/conflict/conflict.go","lines":["@@ -104,7 +104,7 @@ func (w *conflict) Ops("," \t\tpoolA := clusterA.Get()"," \t\tpoolB := clusterB.Get()"," \t\tdbs := []*gosql.DB{stdlib.OpenDBFromPool(poolA), stdlib.OpenDBFromPool(poolB)}","-\t\tworker, err := newConflictWorker(ctx, dbs, w.tableName)","+\t\tworker, err := newConflictWorker(dbs, w.tableName)"," \t\tif err != nil {"," \t\t\treturn workload.QueryLoad{}, err"," \t\t}"],"additions":1,"deletions":1,"truncated":false},{"path":"pkg/workload/conflict/conflict_worker.go","lines":["@@ -19,24 +19,19 @@ import ("," type conflictWorker struct {"," \ttable   workloadrand.Table"," \trng     *rand.Rand","-\twriters []*writer","+\twriters []*workloadrand.TableWriter"," \tnullPct int"," }"," ","-func newConflictWorker(","-\tctx context.Context, connections []*gosql.DB, tableName string,","-) (*conflictWorker, error) {","+func newConflictWorker(connections []*gosql.DB, tableName string) (*conflictWorker, error) {"," \ttable, err := workloadrand.LoadTable(connections[0], tableName)"," \tif err != nil {"," \t\treturn nil, err"," \t}"," ","-\twriters := make([]*writer, len(connections))","+\twriters := make([]*workloadrand.TableWriter, len(connections))"," \tfor i := range writers {","-\t\twriters[i], err = newWriter(ctx, connections[i], table)","-\t\tif err != nil {","-\t\t\treturn nil, err","-\t\t}","+\t\twriters[i] = workloadrand.NewTableWriter(connections[i], table)"," \t}"," "," \treturn &conflictWorker{","@@ -71,7 +66,7 @@ func (w *conflictWorker) RunOp(ctx context.Context) (err error) {"," }"," "," func (w *conflictWorker) runOpOnCluster(","-\tctx context.Context, writer *writer, row []any, rng *rand.Rand,","+\tctx context.Context, writer *workloadrand.TableWriter, row []any, rng *rand.Rand,"," ) error {"," \tvar err error"," \t// run between 0, 1, or 2 mutations on each cluster. This way we get coverage of:","@@ -86,11 +81,11 @@ func (w *conflictWorker) runOpOnCluster("," \t\t\t\t\treturn err"," \t\t\t\t}"," \t\t\t}","-\t\t\tif err := writer.upsertRow(ctx, row); err != nil {","+\t\t\tif err := writer.UpsertRow(ctx, row); err != nil {"," \t\t\t\treturn err"," \t\t\t}"," \t\t} else {","-\t\t\tif err := writer.deleteRow(ctx, row); err != nil {","+\t\t\tif err := writer.DeleteRow(ctx, row); err != nil {"," \t\t\t\treturn err"," \t\t\t}"," \t\t}"],"additions":7,"deletions":12,"truncated":false},{"path":"pkg/workload/rand/BUILD.bazel","lines":["@@ -3,8 +3,10 @@ load(\"@io_bazel_rules_go//go:def.bzl\", \"go_library\", \"go_test\")"," go_library(","     name = \"rand\",","     srcs = [","+        \"diff.go\",","         \"rand.go\",","         \"schema.go\",","+        \"writer.go\",","     ],","     importpath = \"github.com/cockroachdb/cockroach/pkg/workload/rand\",","     visibility = [\"//visibility:public\"],","@@ -14,6 +16,7 @@ go_library(","         \"//pkg/sql/randgen\",","         \"//pkg/sql/sem/tree\",","         \"//pkg/sql/types\",","+        \"//pkg/util/hlc\",","         \"//pkg/util/timeutil\",","         \"//pkg/workload\",","         \"//pkg/workload/histogram\",","@@ -27,19 +30,28 @@ go_library("," go_test(","     name = \"rand_test\",","     size = \"small\",","-    srcs = [\"rand_test.go\"],","+    srcs = [","+        \"diff_test.go\",","+        \"rand_test.go\",","+        \"writer_test.go\",","+    ],","+    data = [\"//c-deps:libgeos\"],","     embed = [\":rand\"],","     deps = [","         \"//pkg/base\",","+        \"//pkg/crosscluster/ldrrandgen\",","         \"//pkg/security/securityassets\",","         \"//pkg/security/securitytest\",","         \"//pkg/server\",","         \"//pkg/sql/randgen\",","         \"//pkg/sql/sem/tree\",","+        \"//pkg/sql/sqlclustersettings\",","         \"//pkg/sql/types\",","+        \"//pkg/testutils\",","         \"//pkg/testutils/serverutils\",","         \"//pkg/testutils/skip\",","         \"//pkg/testutils/sqlutils\",","+        \"//pkg/util/hlc\",","         \"//pkg/util/leaktest\",","         \"//pkg/util/log\",","         \"//pkg/util/randutil\","],"additions":13,"deletions":1,"truncated":false},{"path":"pkg/workload/rand/diff.go","lines":["@@ -0,0 +1,329 @@","+// Copyright 2026 The Cockroach Authors.","+//","+// Use of this software is governed by the CockroachDB Software License","+// included in the /LICENSE file.","+","+package rand","+","+import (","+\tgosql \"database/sql\"","+\t\"fmt\"","+\t\"strings\"","+","+\t\"github.com/cockroachdb/cockroach/pkg/sql/sem/tree\"","+\t\"github.com/cockroachdb/cockroach/pkg/util/hlc\"","+\t\"github.com/cockroachdb/errors\"","+)","+","+// RowDiff represents a difference between two tables. If RowA is nil, the row","+// exists only in table B. If RowB is nil, the row exists only in table A. If","+// both are non-nil, the rows have the same primary key but different column","+// values. The MVCC and origin timestamps are included to help diagnose","+// replication convergence issues.","+type RowDiff struct {","+\tColNames         []string","+\tRowA             []any","+\tMVCCTimestampA   hlc.Timestamp // crdb_internal_mvcc_timestamp from table A","+\tOriginTimestampA hlc.Timestamp // crdb_internal_origin_timestamp from table A","+\tRowB             []any","+\tMVCCTimestampB   hlc.Timestamp // crdb_internal_mvcc_timestamp from table B","+\tOriginTimestampB hlc.Timestamp // crdb_internal_origin_timestamp from table B","+}","+","+// formatRow returns a pretty-printed representation of a row as","+// {col1: 'val1', col2: 'val2', ...}.","+func (d RowDiff) formatRow(row []any) string {","+\tif row == nil {","+\t\treturn \"<nil>\"","+\t}","+\tvar b strings.Builder","+\tb.WriteByte('{')","+","+\tfor i := range row {","+\t\tif i != 0 {","+\t\t\tb.WriteString(\", \")","+\t\t}","+\t\tfmt.Fprintf(&b, \"%s: '%v'\", d.ColNames[i], row[i])","+\t}","+","+\tb.WriteByte('}')","+\treturn b.String()","+}","+","+func (d RowDiff) String() string {","+\treturn fmt.Sprintf(","+\t\t\"RowA=%s (mvcc=%s, origin=%s) RowB=%s (mvcc=%s, origin=%s)\",","+\t\td.formatRow(d.RowA), d.MVCCTimestampA, d.OriginTimestampA,","+\t\td.formatRow(d.RowB), d.MVCCTimestampB, d.OriginTimestampB,","+\t)","+}","+","+// fetchedRow holds the data for a single row fetched during diff phase 2.","+type fetchedRow struct {","+\trow             []any","+\tmvccTimestamp   hlc.Timestamp","+\toriginTimestamp hlc.Timestamp","+}","+","+// buildPKHashExpr returns the SQL expression for the primary key hash, using","+// fnv64 to produce a compact int64 instead of raw bytes.","+func buildPKHashExpr(schema *Table) string {","+\tvar b strings.Builder","+\tb.WriteString(\"fnv64(crdb_internal.datums_to_bytes(\")","+\tfor i, pkIdx := range schema.PrimaryKey {","+\t\tif i > 0 {","+\t\t\tb.WriteString(\", \")","+\t\t}","+\t\tb.WriteString(tree.NameString(schema.Cols[pkIdx].Name))","+\t}","+\tb.WriteString(\"))\")","+\treturn b.String()","+}","+","+// buildOrderByClause returns an ORDER BY clause using the primary key columns,","+// ensuring deterministic row ordering for hash and fetch queries.","+func buildOrderByClause(schema *Table) string {","+\tvar b strings.Builder","+\tb.WriteString(\" ORDER BY \")","+\tfor i, pkIdx := range schema.PrimaryKey {","+\t\tif i > 0 {","+\t\t\tb.WriteString(\", \")","+\t\t}","+\t\tb.WriteString(tree.NameString(schema.Cols[pkIdx].Name))","+\t}","+\treturn b.String()","+}","+","+// buildHashQuery returns a lightweight query that computes only pk_hash and","+// row_hash for every row as int64 values using fnv64.","+//","+// Example for a table with PK (id) and columns (id, name, value):","+//","+//\tSELECT fnv64(crdb_internal.datums_to_bytes(id)) AS pk_hash,","+//\t  fnv64(crdb_internal.datums_to_bytes(id, name, value)) AS row_hash","+//\tFROM my_table","+func buildHashQuery(schema *Table, tableName string) string {","+\tvar b strings.Builder","+\tb.WriteString(\"SELECT \")","+\tb.WriteString(buildPKHashExpr(schema))","+\tb.WriteString(\" AS pk_hash, fnv64(crdb_internal.datums_to_bytes(\")","+\tfor i, colIdx := range schema.IndexableColumns() {","+\t\tif i > 0 {","+\t\t\tb.WriteString(\", \")","+\t\t}","+\t\tb.WriteString(tree.NameString(schema.Cols[colIdx].Name))","+\t}","+\tb.WriteString(\")) AS row_hash FROM \")","+\tb.WriteString(tableName)","+\tb.WriteString(buildOrderByClause(schema))","+\treturn b.String()","+}","+","+// queryHashes executes the hash query and returns a map from pk_hash to","+// row_hash. Both are int64 values produced by fnv64.","+func queryHashes(conn *gosql.DB, query string) (map[int64]int64, error) {","+\trows, err := conn.Query(query)","+\tif err != nil {","+\t\treturn nil, errors.Wrap(err, \"loading hashes\")","+\t}","+\tdefer rows.Close()","+","+\tresult := make(map[int64]int64)","+\tfor rows.Next() {","+\t\tvar pkHash, rowHash int64","+\t\tif err := rows.Scan(&pkHash, &rowHash); err != nil {","+\t\t\treturn nil, errors.Wrap(err, \"scanning hash row\")","+\t\t}","+\t\tresult[pkHash] = rowHash","+\t}","+\treturn result, errors.Wrap(rows.Err(), \"iterating hash rows\")","+}","+","+// buildFetchQuery returns a query that retrieves all columns plus MVCC/origin","+// timestamps and the pk_hash for every row.","+//","+// Example for a table with PK (id) and columns (id, name, value):","+//","+//\tSELECT id, name, value,","+//\t  crdb_internal_mvcc_timestamp, crdb_internal_origin_timestamp,","+//\t  fnv64(crdb_internal.datums_to_bytes(id)) AS pk_hash","+//\tFROM my_table","+func buildFetchQuery(schema *Table, pkHashExpr string, tableName string) string {","+\tvar b strings.Builder","+\tb.WriteString(\"SELECT \")","+\tfor i, col := range schema.Cols {","+\t\tif i > 0 {","+\t\t\tb.WriteString(\", \")","+\t\t}","+\t\tb.WriteString(tree.NameString(col.Name))","+\t}","+\tb.WriteString(\", crdb_internal_mvcc_timestamp, crdb_internal_origin_timestamp, \")","+\tb.WriteString(pkHashExpr)","+\tb.WriteString(\" AS pk_hash FROM \")","+\tb.WriteString(tableName)","+\tb.WriteString(buildOrderByClause(schema))","+\treturn b.String()","+}","+","+// fetchDiffRows executes a full table scan but only retains rows whose","+// pk_hash is in the diffPKs set, returning a map from pk_hash to the","+// fetched row data.","+func fetchDiffRows(","+\tconn *gosql.DB, query string, numCols int, diffPKs map[int64]struct{},","+) (map[int64]fetchedRow, error) {","+\trows, err := conn.Query(query)","+\tif err != nil {","+\t\treturn nil, errors.Wrap(err, \"fetching diff rows\")","+\t}","+\tdefer rows.Close()","+","+\tresult := make(map[int64]fetchedRow)","+\tfor rows.Next() {","+\t\t// The fetch query (see buildFetchQuery) appends three columns after the","+\t\t// table's own columns: dest[numCols] is crdb_internal_mvcc_timestamp,","+\t\t// dest[numCols+1] is crdb_internal_origin_timestamp, and dest[numCols+2]","+\t\t// is pk_hash.","+\t\tdest := make([]any, numCols+3)","+\t\tptrs := make([]any, numCols+3)","+\t\tfor i := range dest {","+\t\t\tptrs[i] = &dest[i]","+\t\t}","+\t\tif err := rows.Scan(ptrs...); err != nil {","+\t\t\treturn nil, errors.Wrap(err, \"scanning diff row\")","+\t\t}","+\t\tpk, ok := dest[numCols+2].(int64)","+\t\tif !ok {","+\t\t\treturn nil, errors.Newf(","+\t\t\t\t\"expected int64 for pk_hash, got %T\", dest[numCols+2],","+\t\t\t)","+\t\t}","+\t\tif _, needed := diffPKs[pk]; !needed {","+\t\t\tcontinue","+\t\t}","+\t\tfr := fetchedRow{","+\t\t\trow: dest[:numCols],","+\t\t}","+\t\tif fr.mvccTimestamp, err = decimalToHLC(dest[numCols]); err != nil {","+\t\t\treturn nil, errors.Wrap(err, \"parsing mvcc timestamp\")","+\t\t}","+\t\tif fr.originTimestamp, err = decimalToHLC(dest[numCols+1]); err != nil {","+\t\t\treturn nil, errors.Wrap(err, \"parsing origin timestamp\")","+\t\t}","+\t\tresult[pk] = fr","+\t}","+\treturn result, errors.Wrap(rows.Err(), \"iterating diff rows\")","+}","+","+// Diff compares the contents of two tables across two database connections and","+// returns up to resultLimit differences. Both tables must have the same schema.","+// The schema is loaded from connA/tableA and used for both sides.","+//","+// The comparison uses two queries per table. The first is a lightweight hash","+// query that computes pk_hash and row_hash server-side using","+// crdb_internal.datums_to_bytes, minimizing data sent over pgwire. The second","+// query fetches full row data (all columns plus MVCC/origin timestamps) only","+// for rows whose pk_hash appeared in the diff set.","+//","+// Limitations:","+//   - Columns with types that cannot be keyside-encoded (e.g. TSVECTOR,","+//     PGVECTOR) are excluded from the row hash. Differences in only those","+//     columns will not be detected.","+//   - Primary key hashes use FNV64, so hash collisions would cause rows to be","+//     silently dropped. This is negligible for reasonable table sizes.","+func Diff(","+\tconnA *gosql.DB, tableA string, connB *gosql.DB, tableB string, resultLimit int,","+) ([]RowDiff, error) {","+\tschema, err := LoadTable(connA, tableA)","+\tif err != nil {","+\t\treturn nil, errors.Wrap(err, \"loading table schema\")","+\t}","+","+\tif len(schema.PrimaryKey) == 0 {","+\t\treturn nil, errors.Newf(\"table %s has no primary key\", tableA)","+\t}","+","+\tpkHashExpr := buildPKHashExpr(&schema)","+","+\t// Phase 1: load hashes from both tables.","+\thashesA, err := queryHashes(connA, buildHashQuery(&schema, tableA))","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\thashesB, err := queryHashes(connB, buildHashQuery(&schema, tableB))","+\tif err != nil {","+\t\treturn nil, err","+\t}","+","+\t// Compute the set of pk_hashes that differ between the two tables.","+\tdiffPKs := make(map[int64]struct{})","+\tfor pk, hashA := range hashesA {","+\t\thashB, ok := hashesB[pk]","+\t\tif !ok || hashA != hashB {","+\t\t\tdiffPKs[pk] = struct{}{}","+\t\t}","+\t}","+\tfor pk := range hashesB {","+\t\tif _, ok := hashesA[pk]; !ok {","+\t\t\tdiffPKs[pk] = struct{}{}","+\t\t}","+\t}","+","+\tif len(diffPKs) == 0 {","+\t\treturn nil, nil","+\t}","+","+\t// Phase 2: fetch full row data only for differing rows.","+\tnumCols := len(schema.Cols)","+\tfetchQueryA := buildFetchQuery(&schema, pkHashExpr, tableA)","+\tdataA, err := fetchDiffRows(connA, fetchQueryA, numCols, diffPKs)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\tfetchQueryB := buildFetchQuery(&schema, pkHashExpr, tableB)","+\tdataB, err := fetchDiffRows(connB, fetchQueryB, numCols, diffPKs)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+","+\t// Build diff results from the fetched rows.","+\tcolNames := make([]string, len(schema.Cols))","+\tfor i, col := range schema.Cols {","+\t\tcolNames[i] = col.Name","+\t}","+","+\tvar results []RowDiff","+\tfor pk := range diffPKs {","+\t\tif len(results) >= resultLimit {","+\t\t\tbreak","+\t\t}","+\t\tdiff := RowDiff{ColNames: colNames}","+\t\tif entryA, inA := dataA[pk]; inA {","+\t\t\tdiff.RowA = entryA.row","+\t\t\tdiff.MVCCTimestampA = entryA.mvccTimestamp","+\t\t\tdiff.OriginTimestampA = entryA.originTimestamp","+\t\t}","+\t\tif entryB, inB := dataB[pk]; inB {","+\t\t\tdiff.RowB = entryB.row","+\t\t\tdiff.MVCCTimestampB = entryB.mvccTimestamp","+\t\t\tdiff.OriginTimestampB = entryB.originTimestamp","+\t\t}","+\t\tresults = append(results, diff)","+\t}","+","+\treturn results, nil","+}","+","+// decimalToHLC converts a scanned crdb_internal_mvcc_timestamp or","+// crdb_internal_origin_timestamp value (a DECIMAL) into an hlc.Timestamp.","+// Returns the zero timestamp if the value is nil (e.g. origin timestamp for","+// locally-written data).","+func decimalToHLC(v any) (hlc.Timestamp, error) {","+\tif v == nil {","+\t\treturn hlc.Timestamp{}, nil","+\t}","+\ts, ok := v.([]byte)","+\tif !ok {","+\t\treturn hlc.Timestamp{}, errors.Newf(\"expected []byte for timestamp, got %T\", v)","+\t}","+\treturn hlc.ParseHLC(string(s))","+}"],"additions":329,"deletions":0,"truncated":false},{"path":"pkg/workload/rand/diff_test.go","lines":["@@ -0,0 +1,322 @@","+// Copyright 2026 The Cockroach Authors.","+//","+// Use of this software is governed by the CockroachDB Software License","+// included in the /LICENSE file.","+","+package rand","+","+import (","+\t\"context\"","+\tgosql \"database/sql\"","+\t\"fmt\"","+\t\"math/rand\"","+\t\"testing\"","+","+\t\"github.com/cockroachdb/cockroach/pkg/base\"","+\t\"github.com/cockroachdb/cockroach/pkg/crosscluster/ldrrandgen\"","+\t\"github.com/cockroachdb/cockroach/pkg/sql/sem/tree\"","+\t\"github.com/cockroachdb/cockroach/pkg/sql/sqlclustersettings\"","+\t\"github.com/cockroachdb/cockroach/pkg/testutils/serverutils\"","+\t\"github.com/cockroachdb/cockroach/pkg/testutils/skip\"","+\t\"github.com/cockroachdb/cockroach/pkg/testutils/sqlutils\"","+\t\"github.com/cockroachdb/cockroach/pkg/util/hlc\"","+\t\"github.com/cockroachdb/cockroach/pkg/util/leaktest\"","+\t\"github.com/cockroachdb/cockroach/pkg/util/log\"","+\t\"github.com/cockroachdb/cockroach/pkg/util/randutil\"","+\t\"github.com/stretchr/testify/require\"","+)","+","+func TestRowDiffFormat(t *testing.T) {","+\tdefer leaktest.AfterTest(t)()","+","+\td := RowDiff{","+\t\tColNames:         []string{\"id\", \"name\", \"value\"},","+\t\tRowA:             []any{1, \"alice\", 10},","+\t\tMVCCTimestampA:   hlc.Timestamp{WallTime: 1e9, Logical: 1},","+\t\tOriginTimestampA: hlc.Timestamp{WallTime: 5e8},","+\t\tRowB:             nil,","+\t}","+\trequire.Equal(t,","+\t\t\"RowA={id: '1', name: 'alice', value: '10'} (mvcc=1.000000000,1, origin=0.500000000,0) \"+","+\t\t\t\"RowB=<nil> (mvcc=0,0, origin=0,0)\",","+\t\td.String(),","+\t)","+}","+","+func TestDiff(t *testing.T) {","+\tdefer leaktest.AfterTest(t)()","+\tdefer log.Scope(t).Close(t)","+\tskip.UnderRace(t)","+","+\tctx := context.Background()","+\ts, db, _ := serverutils.StartServer(t, base.TestServerArgs{})","+\tdefer s.Stopper().Stop(ctx)","+\tsqlDB := sqlutils.MakeSQLRunner(db)","+","+\t// Create tables used by most subtests. Fully qualified names exercise the","+\t// schema.table path in diff queries (ensures we don't accidentally quote","+\t// the whole name as a single identifier).","+\tsqlDB.Exec(t, `CREATE TABLE diff_a (id INT PRIMARY KEY, name STRING, value INT)`)","+\tsqlDB.Exec(t, `CREATE TABLE diff_b (id INT PRIMARY KEY, name STRING, value INT)`)","+\tconst diffA = \"defaultdb.public.diff_a\"","+\tconst diffB = \"defaultdb.public.diff_b\"","+","+\t// BIT column tables for the qualified-name regression test.","+\tsqlDB.Exec(t, `CREATE TABLE bit_a (id INT PRIMARY KEY, bits BIT(15))`)","+\tsqlDB.Exec(t, `CREATE TABLE bit_b (id INT PRIMARY KEY, bits BIT(15))`)","+\tconst bitA = \"defaultdb.public.bit_a\"","+\tconst bitB = \"defaultdb.public.bit_b\"","+","+\ttype diffCheck struct {","+\t\tname     string","+\t\ttableA   string // fully qualified table A name","+\t\ttableB   string // fully qualified table B name","+\t\tsetup    []string","+\t\tlimit    int","+\t\twantLen  int","+\t\tvalidate func(t *testing.T, diffs []RowDiff)","+\t}","+","+\ttests := []diffCheck{","+\t\t{","+\t\t\tname:   \"identical\",","+\t\t\ttableA: diffA, tableB: diffB,","+\t\t\tsetup: []string{","+\t\t\t\t\"DELETE FROM diff_a\", \"DELETE FROM diff_b\",","+\t\t\t\t\"INSERT INTO diff_a VALUES (1, 'alice', 10), (2, 'bob', 20)\",","+\t\t\t\t\"INSERT INTO diff_b VALUES (1, 'alice', 10), (2, 'bob', 20)\",","+\t\t\t},","+\t\t\tlimit:   100,","+\t\t\twantLen: 0,","+\t\t},","+\t\t{","+\t\t\tname:   \"only-in-a\",","+\t\t\ttableA: diffA, tableB: diffB,","+\t\t\tsetup: []string{","+\t\t\t\t\"DELETE FROM diff_a\", \"DELETE FROM diff_b\",","+\t\t\t\t\"INSERT INTO diff_a VALUES (1, 'alice', 10), (2, 'bob', 20)\",","+\t\t\t\t\"INSERT INTO diff_b VALUES (1, 'alice', 10)\",","+\t\t\t},","+\t\t\tlimit:   100,","+\t\t\twantLen: 1,","+\t\t\tvalidate: func(t *testing.T, diffs []RowDiff) {","+\t\t\t\trequire.NotNil(t, diffs[0].RowA)","+\t\t\t\trequire.Nil(t, diffs[0].RowB)","+\t\t\t\trequire.True(t, diffs[0].MVCCTimestampA.IsSet())","+\t\t\t\trequire.True(t, diffs[0].OriginTimestampA.IsEmpty())","+\t\t\t\trequire.True(t, diffs[0].MVCCTimestampB.IsEmpty())","+\t\t\t\trequire.True(t, diffs[0].OriginTimestampB.IsEmpty())","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:   \"only-in-b\",","+\t\t\ttableA: diffA, tableB: diffB,","+\t\t\tsetup: []string{","+\t\t\t\t\"DELETE FROM diff_a\", \"DELETE FROM diff_b\",","+\t\t\t\t\"INSERT INTO diff_a VALUES (1, 'alice', 10)\",","+\t\t\t\t\"INSERT INTO diff_b VALUES (1, 'alice', 10), (2, 'bob', 20)\",","+\t\t\t},","+\t\t\tlimit:   100,","+\t\t\twantLen: 1,","+\t\t\tvalidate: func(t *testing.T, diffs []RowDiff) {","+\t\t\t\trequire.Nil(t, diffs[0].RowA)","+\t\t\t\trequire.NotNil(t, diffs[0].RowB)","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:   \"value-mismatch\",","+\t\t\ttableA: diffA, tableB: diffB,","+\t\t\tsetup: []string{","+\t\t\t\t\"DELETE FROM diff_a\", \"DELETE FROM diff_b\",","+\t\t\t\t\"INSERT INTO diff_a VALUES (1, 'alice', 10)\",","+\t\t\t\t\"INSERT INTO diff_b VALUES (1, 'alice', 99)\",","+\t\t\t},","+\t\t\tlimit:   100,","+\t\t\twantLen: 1,","+\t\t\tvalidate: func(t *testing.T, diffs []RowDiff) {","+\t\t\t\trequire.NotNil(t, diffs[0].RowA)","+\t\t\t\trequire.NotNil(t, diffs[0].RowB)","+\t\t\t\trequire.True(t, diffs[0].MVCCTimestampA.IsSet())","+\t\t\t\trequire.True(t, diffs[0].MVCCTimestampB.IsSet())","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:   \"result-limit\",","+\t\t\ttableA: diffA, tableB: diffB,","+\t\t\tsetup: []string{","+\t\t\t\t\"DELETE FROM diff_a\", \"DELETE FROM diff_b\",","+\t\t\t\t\"INSERT INTO diff_a VALUES (1, 'a', 1), (2, 'b', 2), (3, 'c', 3)\",","+\t\t\t},","+\t\t\tlimit:   2,","+\t\t\twantLen: 2,","+\t\t},","+\t\t{","+\t\t\tname:   \"empty-tables\",","+\t\t\ttableA: diffA, tableB: diffB,","+\t\t\tsetup: []string{","+\t\t\t\t\"DELETE FROM diff_a\", \"DELETE FROM diff_b\",","+\t\t\t},","+\t\t\tlimit:   100,","+\t\t\twantLen: 0,","+\t\t},","+\t\t{","+\t\t\t// Regression test: LoadTable previously failed to resolve BIT column","+\t\t\t// widths when using a fully qualified table name because typeForOid","+\t\t\t// queried information_schema.columns with the raw (qualified) name.","+\t\t\tname:   \"qualified-bit-column\",","+\t\t\ttableA: bitA, tableB: bitB,","+\t\t\tsetup: []string{","+\t\t\t\t\"DELETE FROM bit_a\", \"DELETE FROM bit_b\",","+\t\t\t\t\"INSERT INTO bit_a VALUES (1, B'100000000000000')\",","+\t\t\t\t\"INSERT INTO bit_b VALUES (1, B'100000000000000')\",","+\t\t\t},","+\t\t\tlimit:   100,","+\t\t\twantLen: 0,","+\t\t},","+\t}","+","+\tfor _, tc := range tests {","+\t\tt.Run(tc.name, func(t *testing.T) {","+\t\t\tfor _, stmt := range tc.setup {","+\t\t\t\tsqlDB.Exec(t, stmt)","+\t\t\t}","+\t\t\tdiffs, err := Diff(db, tc.tableA, db, tc.tableB, tc.limit)","+\t\t\trequire.NoError(t, err)","+\t\t\trequire.Len(t, diffs, tc.wantLen)","+\t\t\tif tc.validate != nil {","+\t\t\t\ttc.validate(t, diffs)","+\t\t\t}","+\t\t})","+\t}","+}","+","+// TestDiffRandomSchema generates two tables with the same random schema using","+// the LDR table generator, inserts different random data into each, and","+// validates that Diff correctly reports no differences when comparing a table","+// to itself and detects differences when the tables have divergent content.","+func TestDiffRandomSchema(t *testing.T) {","+\tdefer leaktest.AfterTest(t)()","+\tdefer log.Scope(t).Close(t)","+\tskip.UnderRace(t)","+","+\tctx := context.Background()","+\ts, db, _ := serverutils.StartServer(t, base.TestServerArgs{})","+\tdefer s.Stopper().Stop(ctx)","+\tsqlDB := sqlutils.MakeSQLRunner(db)","+","+\trng, seed := randutil.NewTestRand()","+\tt.Logf(\"random seed: %v\", seed)","+","+\tcon