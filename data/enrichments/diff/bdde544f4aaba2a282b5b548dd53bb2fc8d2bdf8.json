rn $response;"," \t}"," ","+\t/**","+\t * Sideloads an external image from a URL into the media library.","+\t *","+\t * Downloads the remote file on the server, avoiding a cross-origin browser","+\t * fetch that fails under cross-origin isolation. Whether sub-sizes are","+\t * generated is governed by the filters applied in create_item().","+\t *","+\t * @param WP_REST_Request $request Full details about the request.","+\t * @return WP_REST_Response|WP_Error Response object on success, WP_Error object on failure.","+\t */","+\tprivate function create_item_from_url( WP_REST_Request $request ) {","+\t\t// Sideloading downloads and stores a file, so require the upload capability.","+\t\tif ( ! current_user_can( 'upload_files' ) ) {","+\t\t\treturn new WP_Error(","+\t\t\t\t'rest_cannot_create',","+\t\t\t\t__( 'Sorry, you are not allowed to upload media on this site.', 'gutenberg' ),","+\t\t\t\tarray( 'status' => rest_authorization_required_code() )","+\t\t\t);","+\t\t}","+","+\t\trequire_once ABSPATH . 'wp-admin/includes/file.php';","+\t\trequire_once ABSPATH . 'wp-admin/includes/media.php';","+\t\trequire_once ABSPATH . 'wp-admin/includes/image.php';","+","+\t\t$url     = $request['url'];","+\t\t$post_id = ! empty( $request['post'] ) ? (int) $request['post'] : 0;","+","+\t\t// Derive the filename from the URL path before downloading anything.","+\t\t$url_path = wp_parse_url( $url, PHP_URL_PATH );","+\t\t$filename = $url_path ? wp_basename( $url_path ) : '';","+\t\tif ( '' === $filename ) {","+\t\t\treturn new WP_Error(","+\t\t\t\t'rest_invalid_url',","+\t\t\t\t__( 'Could not determine a filename from the provided URL.', 'gutenberg' ),","+\t\t\t\tarray( 'status' => 400 )","+\t\t\t);","+\t\t}","+","+\t\t/*","+\t\t * Only download URLs whose extension maps to an allowed image MIME type.","+\t\t * The sideload handler would reject other types anyway (via","+\t\t * wp_check_filetype_and_ext()), but checking first avoids downloading","+\t\t * files that can never be accepte