ame, sessionID)","+\tif err != nil {","+\t\treturn err","+\t}","+","+\tobjectKey := \"\"","+\tif resource != nil {","+\t\tobjectKey = strings.TrimSpace(resource.Name)","+\t}","+\tif objectKey == \"\" {","+\t\tfullFilePath := getOpenClawTranscriptStoragePath(logProvider.Owner, logProvider.Name, sessionID, util.GenerateUUID())","+\t\tobjectKey = getOpenClawTranscriptObjectKey(storageProvider, fullFilePath)","+\t}","+\tif strings.Contains(objectKey, \"..\") {","+\t\treturn fmt.Errorf(\"the objectKey: %s is not allowed\", objectKey)","+\t}","+","+\tif err := putOpenClawRawTranscriptObject(storageProvider, objectKey, transcriptPath); err != nil {","+\t\treturn err","+\t}","+","+\tresource = buildOpenClawRawTranscriptResource(logProvider, storageProvider, sessionID, transcriptPath, fileSize, objectKey, resource)","+\t_, err = AddOrUpdateResource(resource)","+\treturn err","+}","+","+func getOpenClawTranscriptStorageProvider(logProvider *Provider) (*Provider, error) {","+\tif logProvider == nil {","+\t\treturn nil, fmt.Errorf(\"provider is nil\")","+\t}","+","+\tproviders, err := GetProviders(logProvider.Owner)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+","+\tstorageProvider, err := selectOpenClawTranscriptStorageProvider(logProvider, providers)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\tif storageProvider != nil {","+\t\treturn storageProvider, nil","+\t}","+","+\treturn createOpenClawTranscriptDefaultStorageProvider(logProvider)","+}","+","+func selectOpenClawTranscriptStorageProvider(logProvider *Provider, providers []*Provider) (*Provider, error) {","+\tselectedName := strings.TrimSpace(logProvider.ProviderUrl)","+\tif selectedName != \"\" {","+\t\tfor _, provider := range providers {","+\t\t\tif provider == nil || provider.Name != selectedName {","+\t\t\t\tcontinue","+\t\t\t}","+\t\t\tif !isUsableOpenClawTranscriptStorageProviderForOwner(logProvider.Owner, provider) {","+\t\t\t\treturn nil, fmt.Errorf(\"selected provider %s is not an enabled Storage provider\", selectedName)","+\t\t\t}","+\t\t\treturn provider, nil","+\t\t}","+","+\t\treturn nil, fmt.Errorf(\"selected Storage provider %s is not found\", selectedName)","+\t}","+","+\tfor _, provider := range providers {","+\t\tif !isUsableOpenClawTranscriptStorageProviderForOwner(logProvider.Owner, provider) {","+\t\t\tcontinue","+\t\t}","+\t\treturn provider, nil","+\t}","+","+\treturn nil, nil","+}","+","+func isUsableOpenClawTranscriptStorageProvider(provider *Provider) bool {","+\treturn provider != nil && provider.Category == \"Storage\" && !strings.EqualFold(strings.TrimSpace(provider.State), \"Disabled\")","+}","+","+func isUsableOpenClawTranscriptStorageProviderForOwner(owner string, provider *Provider) bool {","+\treturn isUsableOpenClawTranscriptStorageProvider(provider) && strings.TrimSpace(provider.Owner) == strings.TrimSpace(owner)","+}","+","+func createOpenClawTranscriptDefaultStorageProvider(logProvider *Provider) (*Provider, error) {","+\tif logProvider == nil {","+\t\treturn nil, fmt.Errorf(\"provider is nil\")","+\t}","+","+\tprovider := &Provider{","+\t\tOwner:       logProvider.Owner,","+\t\tName:        openClawTranscriptDefaultStorageProviderName,","+\t\tCreatedTime: util.GetCurrentTime(),","+\t\tDisplayName: \"OpenClaw Transcript Storage\",","+\t\tCategory:    \"Storage\",","+\t\tType:        ProviderTypeLocalFileSystem,","+\t\tState:       \"Enabled\",","+\t\tPathPrefix:  \"openclaw-transcripts\",","+\t\tDomain:      getOpenClawDefaultStorageDomain(),","+\t}","+","+\taffected, err := AddProvider(provider)","+\tif err != nil {","+\t\tproviders, getErr := GetProviders(logProvider.Owner)","+\t\tif getErr != nil {","+\t\t\treturn nil, err","+\t\t}","+","+\t\tfor _, existing := range providers {","+\t\t\tif existing != nil && existing.Name == openClawTranscriptDefaultStorageProviderName && isUsableOpenClawTranscriptStorageProviderForOwner(logProvider.Owner, existing) {","+\t\t\t\treturn existing, nil","+\t\t\t}","+\t\t}","+","+\t\treturn nil, err","+\t}","+\tif !affected {","+\t\treturn nil, fmt.Errorf(\"failed to create default OpenClaw transcript Storage provider\")","+\t}","+","+\treturn provider, nil","+}","+","+func getOpenClawDefaultStorageDomain() string {","+\tif origin := strings.TrimSpace(conf.GetConfigString(\"origin\")); origin != \"\" {","+\t\treturn origin","+\t}","+\treturn strings.TrimSpace(conf.GetConfigString(\"originFrontend\"))","+}","+","+func getOpenClawTranscriptStoragePath(owner string, providerName string, sessionID string, nonce string) string {","+\treturn path.Join(","+\t\t\"openclaw\",","+\t\tsanitizeOpenClawStoragePathSegment(owner),","+\t\tsanitizeOpenClawStoragePathSegment(providerName),","+\t\t\"sessions\",","+\t\tsanitizeOpenClawStoragePathSegment(nonce),","+\t\tfmt.Sprintf(\"%s.jsonl\", sanitizeOpenClawStoragePathSegment(sessionID)),","+\t)","+}","+","+func getOpenClawTranscriptObjectKey(provider *Provider, fullFilePath string) string {","+\tescapedPath := util.UrlJoin(provider.PathPrefix, fullFilePath)","+\tobjectKey := util.UrlJoin(util.GetUrlPath(provider.Domain), escapedPath)","+\tif provider.Type == ProviderTypeLocalFileSystem {","+\t\tobjectKey = strings.TrimLeft(objectKey, \"/\")","+\t}","+\tif provider.Type == ProviderTypeTencentCloudCOS {","+\t\tobjectKey = escapePath(objectKey)","+\t}","+\treturn objectKey","+}","+","+func getOpenClawTranscriptResourceParent(owner string, providerName string, sessionID string) string {","+\towner = strings.TrimSpace(owner)","+\tproviderName = strings.TrimSpace(providerName)","+\tsessionID = strings.TrimSpace(sessionID)","+\tif owner == \"\" || providerName == \"\" || sessionID == \"\" {","+\t\treturn \"\"","+\t}","+","+\treturn path.Join(\"openclaw\", util.GetMd5Hash(fmt.Sprintf(\"%s|%s|%s\", owner, providerName, sessionID)))","+}","+","+func getOpenClawRawTranscriptResource(owner string, providerName string, sessionID string) (*Resource, error) {","+\towner = strings.TrimSpace(owner)","+\tparent := getOpenClawTranscriptResourceParent(owner, providerName, sessionID)","+\tif owner == \"\" || parent == \"\" {","+\t\treturn nil, nil","+\t}","+","+\tresource := Resource{}","+\texisted, err := ormer.Engine.","+\t\tWhere(\"owner = ? and tag = ? and parent = ?\", owner, openClawTranscriptResourceTag, parent).","+\t\tDesc(\"created_time\").","+\t\tGet(&resource)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\tif !existed {","+\t\treturn nil, nil","+\t}","+","+\treturn &resource, nil","+}","+","+func getOpenClawRawTranscriptRef(owner string, providerName string, sessionID string) (*OpenClawRawTranscriptRef, error) {","+\tresource, err := getOpenClawRawTranscriptResource(owner, providerName, sessionID)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\treturn buildOpenClawRawTranscriptRef(resource), nil","+}","+","+func buildOpenClawRawTranscriptRef(resource *Resource) *OpenClawRawTranscriptRef {","+\tif resource == nil {","+\t\treturn nil","+\t}","+","+\treturn &OpenClawRawTranscriptRef{","+\t\tFileName: resource.FileName,","+\t\tFileSize: resource.FileSize,","+\t}","+}","+","+func GetOpenClawSessionTranscript(id string, lang string) (*OpenClawSessionTranscriptPreview, error) {","+\tentry, _, payload, err := loadOpenClawSessionEntry(id)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\tif entry == nil {","+\t\treturn nil, nil","+\t}","+","+\tresource, err := getOpenClawRawTranscriptResource(entry.Owner, entry.Provider, payload.SessionID)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\tif resource == nil {","+\t\treturn nil, nil","+\t}","+","+\tprovider, err := getOpenClawTranscriptStorageProviderByName(resource.Owner, resource.Provider)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\tif provider == nil || provider.Category != \"Storage\" {","+\t\treturn nil, fmt.Errorf(\"storage provider %s is not found\", resource.Provider)","+\t}","+","+\tstorageProvider, err := getStorageProvider(provider, lang)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+","