rt { IChatQuota, IChatQuotaService } from '../../../platform/chat/common/chatQuotaService';","-import { Disposable } from '../../../util/vs/base/common/lifecycle';","-","-const QUOTA_NOTIFICATION_ID = 'copilot.quotaStatus';","-const THRESHOLDS = [50, 75, 90, 95];","-","-interface IRateLimitWarning {","-\tpercentUsed: number;","-\ttype: 'session' | 'weekly';","-\tresetDate: Date;","-}","-","-interface IQuotaWarning {","-\tpercentUsed: number;","-\tresetDate: Date;","-}","-","-/**","- * Manages a single chat input notification for quota and rate limit status.","- *","- * Listens to `IChatQuotaService.onDidChange` and determines whether a","- * new threshold has been crossed, then shows the highest-priority notification:","- *","- * 1. **Quota exhausted** — info, not auto-dismissed, only dismissible via X.","- * 2. **Quota approaching** — info, auto-dismissed on next message.","- * 3. **Rate-limit warning** — info, auto-dismissed on next message.","- */","-export class ChatInputNotificationContribution extends Disposable {","-","-\tprivate _notification: vscode.ChatInputNotification | undefined;","-\t/** Tracks whether the current notification is the quota-exhausted variant. */","-\tprivate _showingExhausted = false;","-\t/** Whether a copilot token was present on the last {@link _update} call. */","-\tprivate _hadCopilotToken = false;","-","-\t/**","-\t * Previous percent-used values for threshold crossing detection.","-\t * `undefined` means no data has been seen yet — the first value","-\t * establishes a baseline without triggering a notification.","-\t */","-\tprivate _prevQuotaPercentUsed: number | undefined;","-\tprivate _prevSessionPercentUsed: number | undefined;","-\tprivate _prevWeeklyPercentUsed: number | undefined;","-\tprivate _prevAdditionalUsageEnabled: boolean | undefined;","-","-\tprivate get _quotaUsedUp(): boolean {","-\t\tconst info = this._chatQuotaService.quotaInfo;","-\t\tif (!info) {","-\t\t\treturn false;","-\t\t}","-\t\tif (info.unlimited) {","-\t\t\treturn !info.hasQuota;","-\t\t}","-\t\treturn info.percentRemaining <= 0;","-\t}","-","-\tconstructor(","-\t\t@IAuthenticationService private readonly _authService: IAuthenticationService,","-\t\t@IChatQuotaService private readonly _chatQuotaService: IChatQuotaService,","-\t) {","-\t\tsuper();","-\t\tthis._register(this._authService.onDidAuthenticationChange(() => this._update()));","-\t\tthis._register(this._chatQuotaService.onDidChange(() => this._update()));","-\t}","-","-\t/**","-\t * Single entry point that determines the highest-priority notification","-\t * to show (or whether to hide).","-\t */","-\tprivate _update(): void {","-\t\tconst hasCopilotToken = !!this._authService.copilotToken;","-\t\tconst wasSignedIn = this._hadCopilotToken;","-\t\tthis._hadCopilotToken = hasCopilotToken;","-","-\t\t// Detect signed-in → signed-out transition: clear state and hide.","-\t\tif (wasSignedIn && !hasCopilotToken) {","-\t\t\tthis._prevQuotaPercentUsed = undefined;","-\t\t\tthis._prevSessionPercentUsed = undefined;","-\t\t\tthis._prevWeeklyPercentUsed = undefined;","-\t\t\tthis._prevAdditionalUsageEnabled = undefined;","-\t\t\tthis._hideNotification();","-\t\t\tthis._showingExhausted = false;","-\t\t\treturn;","-\t\t}","-","-\t\t// Skip quota notifications for PRU users — only show for UBB.","-\t\tconst isQuotaNotificationEligible = !hasCopilotToken","-\t\t\t|| !!this._authService.copilotToken?.isUsageBasedBilling;","-","-\t\t// Priority 1: Quota exhausted or fully used — sticky info notification","-\t\tif (isQuotaNotificationEligible && this._quotaUsedUp) {","-\t\t\tconst additionalUsageEnabled = this._chatQuotaService.additionalUsageEnabled;","-\t\t\tconst wasAdditionalUsageEnabled = this._prevAdditionalUsageEnabled;","-\t\t\tthis._prevAdditionalUsageEnabled = additionalUsageEnabled;","-","-\t\t\tif (additionalUsageEnabled) {","-\t\t\t\t// Show overage notification on a live transition to 100%,","-\t\t\t\t// or when overages are enabled while already at 100%.","-\t\t\t\tif (this._prevQuotaPercentUsed !== undefined || wasAdditionalUsageEnabled === false) {","-\t\t\t\t\tthis._showOverageActivationNotification();","-\t\t\t\t}","-\t\t\t} else {","-\t\t\t\tthis._showExhaustedNotification();","-\t\t\t}","-\t\t\treturn;","-\t\t}","-","-\t\t// Priority 2: Quota approaching threshold","-\t\tif (isQuotaNotificationEligible) {","-\t\t\tconst quotaWarning = this._computeQuotaWarning();","-\t\t\tif (quotaWarning) {","-\t\t\t\tthis._fetchAndShowQuotaWarning(quotaWarning);","-\t\t\t\treturn;","-\t\t\t}","-\t\t}","-","-\t\t// Priority 3: Rate-limit warning (session > weekly)","-\t\tconst rateLimitWarning = this._computeRateLimitWarning();","-\t\tif (rateLimitWarning) {","-\t\t\tthis._showRateLimitWarning(rateLimitWarning);","-\t\t\treturn;","-\t\t}","-","-\t\t// Nothing new to show — only hide if the exhausted notification is","-\t\t// active and the quota is no longer exhausted (state-driven).","-\t\tif (this._showingExhausted && !this._quotaUsedUp) {","-\t\t\tthis._hideNotification();","-\t\t}","-\t}","-","-\t// --- Fetch and show quota warning ----------------------------------------","-","-\t/**","-\t * Fetches up-to-date quota data before showing a threshold notification,","-\t * ensuring the displayed percentage reflects the latest server state.","-\t */","-\tprivate async _fetchAndShowQuotaWarning(fallbackWarning: IQuotaWarning): Promise<void> {","-\t\ttry {","-\t\t\tawait this._chatQuotaService.refreshQuota();","-\t\t\t// After the async refresh, quota may have become exhausted or","-\t\t\t// fully used (a re-entrant _update() from onDidChange may have","-\t\t\t// already shown the exhausted notification).","-\t\t\tif (this._quotaUsedUp) {","-\t\t\t\treturn;","-\t\t\t}","-","-\t\t\tconst freshInfo = this._chatQuotaService.quotaInfo;","-\t\t\tif (freshInfo && !freshInfo.unlimited) {","-\t\t\t\tthis._showQuotaApproachingWarning({","-\t\t\t\t\tpercentUsed: Math.floor(100 - freshInfo.percentRemaining),","-\t\t\t\t\tresetDate: freshInfo.resetDate,","-\t\t\t\t});","-\t\t\t} else {","-\t\t\t\tthis._showQuotaApproachingWarning(fallbackWarning);","-\t\t\t}","-\t\t} catch {","-\t\t\tthis._showQuotaApproachingWarning(fallbackWarning);","-\t\t}","-\t}","-","-\t// --- Threshold crossing detection ----------------------------------------","-","-\tprivate _computeQuotaWarning(): IQuotaWarning | undefined {","-\t\tconst info = this._chatQuotaService.quotaInfo;","-\t\tif (!info || info.unlimited) {","-\t\t\tthis._prevQuotaPercentUsed = undefined;","-\t\t\treturn undefined;","-\t\t}","-\t\tconst percentUsed = 100 - info.percentRemaining;","-\t\tconst crossed = this._findCrossedThreshold(percentUsed, this._prevQuotaPercentUsed);","-\t\tthis._prevQuotaPercentUsed = percentUsed;","-\t\tif (crossed !== undefined) {","-\t\t\treturn { percentUsed: Math.floor(percentUsed), resetDate: info.resetDate };","-\t\t}","-\t\treturn undefined;","-\t}","-","-\tprivate _computeRateLimitWarning(): IRateLimitWarning | undefined {","-\t\tconst { session, weekly } = this._chatQuotaService.rateLimitInfo;","-","-\t\t// Always update both prev values so neither becomes stale.","-\t\tconst sessionWarning = this._checkCrossing(session, this._prevSessionPercentUsed);","-\t\tthis._prevSessionPercentUsed = sessionWarning.newPrev;","-","-\t\tconst weeklyWarning = this._checkCrossing(weekly, this._prevWeeklyPercentUsed);","-\t\tthis._prevWeeklyPercentUsed = weeklyWarning.newPrev;","-","-\t\tif (sessionWarning.warning) {","-\t\t\treturn { ...sessionWarning.warning, type: 'session' };","-\t\t}","-\t\tif (weeklyWarning.warning) {","-\t\t\treturn { ...weeklyWarning.warning, type: 'weekly' };","-\t\t}","-\t\treturn undefined;","-\t}","-","-\tprivate _checkCrossing(","-\t\tinfo: IChatQuota | undefined,","-\t\tprevPercentUsed: number | undefined,","-\t): { newPrev: number | undefined; warning?: { percentUsed: number; resetDate: Date } } {","-\t\tif (!info || info.unlimited) {","-\t\t\treturn { newPrev: undefined };","-\t\t}","-\t\tconst percentUsed = 100 - info.percentRemaining;","-\t\tconst crossed = this._findCrossedThreshold(percentUsed, prevPercentUsed);","-\t\treturn {","-\t\t\tnewPrev: percentUsed,","-\t\t\twarning: crossed !== undefined","-\t\t\t\t? { percentUsed: Math.floor(percentUsed), resetDate: info.resetDate }","-\t\t\t\t: undefined,","-\t\t};","-\t}","-","-\t/**","-\t * Returns the highest threshold that was newly crossed, or `undefined`.","-\t * A threshold is \"crossed\" when the previous value was below it and the","-\t * current value is at or above it.  When `previous` is `undefined` (first","-\t * data arrival), no crossing is detected — only the baseline is stored.","-\t */","-\tprivate _findCrossedThreshold(current: number, previous: number | undefined): number | undefined {","-\t\tif (previous === undefined) {","-\t\t\treturn undefined;","-\t\t}","-\t\tfor (let i = THRESHOLDS.length - 1; i >= 0; i--) {","-\t\t\tconst threshold = THRESHOLDS[i];","-\t\t\tif (previous < threshold && current >= threshold) {","-\t\t\t\treturn threshold;","-\t\t\t}","-\t\t}","-\t\treturn undefined;","-\t}","-","-\t// --- Quota exhausted ---------------------------------------------------","-","-\tprivate _showExhaustedNotification(): void {","-\t\tconst notification = this._ensureNotification();","-\t\tthis._showingExhausted = true;","-","-\t\tnotification.severity = vscode.ChatInputNotificationSeverity.Info;","-\t\tnotification.dismissible = true;","-\t\tnotification.autoDismissOnMessage = true;","-\t\tnotification.message = vscode.l10n.t('Credit Limit Reached');","-","-\t\tconst isAnonymous = !!this._authService.copilotToken?.isNoAuthUser;","-\t\tconst isFree = !!this._authService.copilotToken?.isFreeUser;","-\t\tconst isManagedPlan = !!this._authService.copilotToken?.isManagedPlan;","-\t\tconst quotaInfo = this._chatQuotaService.quotaInfo;","-\t\tconst hadOverage = quotaInfo ? quotaInfo.additionalUsageUsed > 0 : false;","-","-\t\tif (isAnonymous) {","-\t\t\tnotification.description = vscode.l10n.t('Sign in to keep going.');","-\t\t\tnotification.actions = [","-\t\t\t\t{ label: vscode.l10n.t('Sign In'), commandId: 'workbench.action.chat.triggerSetup' },","-\t\t\t];","-\t\t} else if (isFree) {","-\t\t\tnotification.description = vscode.l10n.t('Upgrade to keep going.');","-\t\t\tnotification.actions = [","-\t\t\t\t{ label: vscode.l10n.t('Upgrade'), commandId: 'workbench.action.chat.upgradePlan' },","-\t\t\t];","-\t\t} else if (isManagedPlan) {","-\t\t\tnotification.description = vscode.l10n.t('Contact your admin to increase your limits.');","-\t\t\tnotification.actions = [];","-\t\t} else if (hadOverage) {","-\t\t\tnotification.description = vscode.l10n.t('Increase your budget to keep building.');","-\t\t\tnotification.actions = [","-\t\t\t\t{ label: vscode.l10n.t('Manage Budget'), commandId: 'workbench.action.chat.manageAdditionalSpend' },","-\t\t\t];","-\t\t} else {","-\t\t\tnotification.description = vscode.l10n.t('Manage your budget to keep building.');","-\t\t\tnotification.actions = [","-\t\t\t\t{ label: vscode.l10n.t('Manage Budget'), commandId: 'workbench.action.chat.manageAdditionalSpend' },","-\t\t\t];","-\t\t}","-","-\t\tnotification.show();","-\t}","-","-\t// --- Overage notification -----------------------------------------------","-","-\tprivate _showOverageActivationNotification(): void {","-\t\tconst notification = this._ensureNotification();","-\t\tthis._showingExhausted = true;","-","-\t\tnotification.severity = vscode.ChatInputNotificationSeverity.Info;","-\t\tnotification.dismissible = true;","-\t\tnotification.autoDismissOnMessage = true;","-\t\tnotification.message = vscode.l10n.t('Credit Limit Reached');","-\t\tnotification.description = vscode.l10n.t('Additional budget is now covering extra usage.');","-\t\tnotification.actions = [];","-","-\t\tnotification.show();","-\t}","-","-\t// --- Quota approaching --------------------------------------------------","-","-\tprivate _showQuotaApproachingWarning(warning: IQuotaWarning): void {","-\t\tconst notification = this._ensureNotification();","-\t\tthis._showingExhausted = false;","-","-\t\tnotification.severity = vscode.ChatInputNotificationSeverity.Info;","-\t\tnotification.dismissible = true;","-\t\tnotification.autoDismissOnMessage = true;","-\t\tnotification.message = vscode.l10n.t('Credits at {0}%', warning.percentUsed);","-","-\t\tconst isAnonymous = !!this._authService.copilotToken?.isNoAuthUser;","-\t\tconst isFree = !!this._authService.copilotToken?.isFreeUser;","-\t\tconst isManagedPlan = !!this._authService.copilotToken?.isManagedPlan;","-","-\t\tif (isAnonymous || isFree) {","-\t\t\tnotification.description = vscode.l10n.t('Upgrade to continue past the limit.');","-\t\t\tnotification.actions = [","-\t\t\t\t{ label: vscode.l10n.t('Upgrade'), commandId: 'workbench.action.chat.upgradePlan' },","-\t\t\t];","-\t\t} else if (isManagedPlan) {","-\t\t\tnotification.description = vscode.l10n.t('Contact your admin to increase your limits.');","-\t\t\tnotification.actions = [];","-\t\t} else if (this._chatQuotaService.additionalUsageEnabled) {","-\t\t\tnotification.description = vscode.l10n.t('Additional budget is enabled to cover extra usage.');","-\t\t\tnotification.actions = [];","-\t\t} else {","-\t\t\tnotification.description = vscode.l10n.t('Set additional budget to cover extra usage.');","-\t\t\tnotification.actions = [","-\t\t\t\t{ label: vscode.l10n.t('Manage Budget'), commandId: 'workbench.action.chat.manageAdditionalSpend' },","-\t\t\t];","-\t\t}","-","-\t\tnotification.show();","-\t}","-","-\t// --- Rate limit warning -------------------------------------------------","-","-\tprivate _showRateLimitWarning(warning: IRateLimitWarning): void {","-\t\tconst notification = this._ensureNotification();","-\t\tthis._showingExhausted = false;","-","-\t\tconst dateStr = this._formatResetDate(warning.resetDate);","-\t\tnotification.severity = vscode.ChatInputNotificationSeverity.Info;","-\t\tnotification.dismissible = true;","-\t\tnotification.autoDismissOnMessage = true;","-","-\t\tnotification.message = warning.type === 'session'","-\t\t\t? vscode.l10n.t(\"You've used {0}% of your session rate limit.\", warning.percentUsed)","-\t\t\t: vscode.l10n.t(\"You've used {0}% of your weekly rate limit.\", warning.percentUsed);","-\t\tnotification.description = vscode.l10n.t('Resets on {0}.', dateStr);","-\t\tnotification.actions = [];","-","-\t\tnotification.show();","-\t}","-","-\t// --- Helpers ------------------------------------------------------------","-","-\tprivate _formatResetDate(resetDate: Date): string {","-\t\tconst now = new Date();","-\t\tconst includeYear = resetDate.getFullYear() !== now.getFullYear();","-\t\treturn new Intl.DateTimeFormat(undefined, includeYear","-\t\t\t? { month: 'long', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' }","-\t\t\t: { month: 'long', day: 'numeric', hour: 'numeric', minute: '2-digit' }","-\t\t).format(resetDate);","-\t}","-","-\tprivate _ensureNotification(): vscode.ChatInputNotification {","-\t\tif (!this._notification) {","-\t\t\tthis._notification = vscode.chat.createInputNotification(QUOTA_NOTIFICATION_ID);","-\t\t\tthis._register({ dispose: () => this._notification?.dispose() });","-\t\t}","-\t\treturn this._notification;","-\t}","-","-\tprivate _hideNotification(): void {","-\t\tif (this._notification) {","-\t\t\tthis._notification.hide();","-\t\t}","-\t}","-}"],"additions":0,"deletions":381,"truncated":false},{"path":"extensions/copilot/src/extension/chatInputNotification/vscode-node/test/chatInputNotification.contribution.spec.ts","lines":["@@ -1,733 +0,0 @@","-/*---------------------------------------------------------------------------------------------","- *  Copyright (c) Microsoft Corporation. All rights reserved.","- *  Licensed under the MIT License. See License.txt in the project root for license information.","- *--------------------------------------------------------------------------------------------*/","-","-import { afterEach, bef