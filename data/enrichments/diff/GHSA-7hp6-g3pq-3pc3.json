e IPv4\")","-\t}","-\tif !strings.Contains(s, `\"fd00::2\": [\"5.6.7.8:4242\"]`) {","-\t\tt.Error(\"missing second lighthouse IPv6\")","-\t}","-","-\t// Parse to ensure valid YAML","-\tvar parsed map[string]any","+\tvar parsed parsedConfig"," \tif err := yaml.Unmarshal(data, &parsed); err != nil {"," \t\tt.Fatalf(\"invalid YAML: %v\\n%s\", err, string(data))"," \t}","+","+\texpected := map[string]string{","+\t\t\"10.0.0.1\": \"1.2.3.4:4242\",","+\t\t\"fd00::1\":  \"1.2.3.4:4242\",","+\t\t\"10.0.0.2\": \"5.6.7.8:4242\",","+\t\t\"fd00::2\":  \"5.6.7.8:4242\",","+\t}","+\tfor ip, addr := range expected {","+\t\tgot := parsed.StaticHostMap[ip]","+\t\tif len(got) != 1 || got[0] != addr {","+\t\t\tt.Errorf(\"static_host_map[%s] = %v, want [%s]\", ip, got, addr)","+\t\t}","+\t}"," }"," "," func TestGenerate_InlinePEM_RoundTrip(t *testing.T) {"],"additions":99,"deletions":30,"truncated":false},{"path":"internal/configgen/marshal.go","lines":["@@ -0,0 +1,198 @@","+package configgen","+","+import (","+\t\"bytes\"","+\t\"fmt\"","+","+\t\"gopkg.in/yaml.v3\"","+)","+","+// nebulaConfig is the internal typed-struct representation of a Nebula agent","+// config.yml. It exists so Generate can marshal through gopkg.in/yaml.v3","+// instead of string-interpolating into a text/template. Every value is","+// quoted/escaped by yaml.v3 according to YAML spec, so structural-break","+// characters (CR/LF, control chars, \", :, #) in fields like TunDevice can","+// never escape into the YAML structure regardless of what upstream validators","+// allow. Defense-in-depth on top of input validation (GHSA-7hp6, issue #126).","+type nebulaConfig struct {","+\tPKI           pkiSection          `yaml:\"pki\"`","+\tStaticHostMap map[string][]string `yaml:\"static_host_map\"`","+\tLighthouse    lighthouseSection   `yaml:\"lighthouse\"`","+\tListen        listenSection       `yaml:\"listen\"`","+\tPunchy        punchySection       `yaml:\"punchy\"`","+\tTun           *tunSection         `yaml:\"tun,omitempty\"`","+\tRelay         *relaySection       `yaml:\"relay,omitempty\"`","+\tLogging       loggingSection      `yaml:\"logging\"`","+\tFirewall      firewallSection     `yaml:\"firewall\"`","+}","+","+// pkiSection's fields are typed `any` because inline PEMs marshal as","+// literal-block scalars (via literalString.MarshalYAML) while path-based","+// values are plain strings.","+type pkiSection struct {","+\tCA   any `yaml:\"ca\"`","+\tCert any `yaml:\"cert\"`","+\tKey  any `yaml:\"key\"`","+}","+","+// literalString marshals as a YAML literal-block scalar (|). Used for the","+// inline PEM blocks so the multi-line content is preserved verbatim.","+type literalString string","+","+func (l literalString) MarshalYAML() (any, error) {","+\treturn &yaml.Node{","+\t\tKind:  yaml.ScalarNode,","+\t\tStyle: yaml.LiteralStyle,","+\t\tValue: string(l),","+\t}, nil","+}","+","+type lighthouseSection struct {","+\tAmLighthouse bool     `yaml:\"am_lighthouse\"`","+\tHosts        []string `yaml:\"hosts,omitempty\"`","+}","+","+type listenSection struct {","+\tHost string `yaml:\"host\"`","+\tPort int    `yaml:\"port\"`","+}","+","+type punchySection struct {","+\tPunch bool `yaml:\"punch\"`","+}","+","+type tunSection struct {","+\tDev          string        `yaml:\"dev,omitempty\"`","+\tMTU          int           `yaml:\"mtu,omitempty\"`","+\tUnsafeRoutes []unsafeRoute `yaml:\"unsafe_routes,omitempty\"`","+}","+","+type unsafeRoute struct {","+\tRoute string `yaml:\"route\"`","+\tVia   string `yaml:\"via\"`","+}","+","+type relaySection struct {","+\tAmRelay bool     `yaml:\"am_relay,omitempty\"`","+\tRelays  []string `yaml:\"relays,omitempty\"`","+}","+","+type loggingSection struct {","+\tLevel  string `yaml:\"level\"`","+\tFormat string `yaml:\"format\"`","+}","+","+type firewallSection struct {","+\tOutbound []firewallRule `yaml:\"outbound\"`","+\tInbound  []firewallRule `yaml:\"inbound\"`","+}","+","+// firewallRule is constructed with exactly one of {Group, Host} set per rule —","+// matching the shape the previous template emitted: `group: <name>` for named","+// groups, `host: any` for the catch-all.","+type firewallRule struct {","+\tPort  string `yaml:\"port\"`","+\tProto string `yaml:\"proto\"`","+\tGroup string `yaml:\"group,omitempty\"`","+\tHost  string `yaml:\"host,omitempty\"`","+}","+","+// Generate produces a Nebula config.yml from the given input by marshaling","+// a typed struct through gopkg.in/yaml.v3. Replaces the previous","+// text/template-based generator (GHSA-7hp6 follow-up, issue #126).","+func Generate(input GeneratorInput) ([]byte, error) {","+\tcfg := buildConfig(input)","+\tvar buf bytes.Buffer","+\tenc := yaml.NewEncoder(&buf)","+\tenc.SetIndent(2)","+\tif err := enc.Encode(cfg); err != nil {","+\t\treturn nil, fmt.Errorf(\"encode config: %w\", err)","+\t}","+\tif err := enc.Close(); err != nil {","+\t\treturn nil, fmt.Errorf(\"close encoder: %w\", err)","+\t}","+\treturn buf.Bytes(), nil","+}","+","+func buildConfig(input GeneratorInput) nebulaConfig {","+\tcfg := nebulaConfig{","+\t\tLogging: loggingSection{Level: \"info\", Format: \"text\"},","+\t}","+","+\tif input.CACertPEM != \"\" {","+\t\tcfg.PKI = pkiSection{","+\t\t\tCA:   literalString(input.CACertPEM),","+\t\t\tCert: literalString(input.CertPEM),","+\t\t\tKey:  literalString(input.KeyPEM),","+\t\t}","+\t} else {","+\t\tcfg.PKI = pkiSection{","+\t\t\tCA:   input.CACertPath,","+\t\t\tCert: input.CertPath,","+\t\t\tKey:  input.KeyPath,","+\t\t}","+\t}","+","+\tcfg.StaticHostMap = map[string][]string{}","+\tif input.IsLighthouse {","+\t\tcfg.Lighthouse = lighthouseSection{AmLighthouse: true}","+\t} else {","+\t\tvar hosts []string","+\t\tfor _, lh := range input.Lighthouses {","+\t\t\tfor _, ip := range lh.NebulaIPs {","+\t\t\t\tcfg.StaticHostMap[ip] = []string{lh.PublicAddr}","+\t\t\t\thosts = append(hosts, ip)","+\t\t\t}","+\t\t}","+\t\tcfg.Lighthouse = lighthouseSection{AmLighthouse: false, Hosts: hosts}","+\t}","+","+\tlistenHost := input.ListenHost","+\tif listenHost == \"\" {","+\t\tlistenHost = \"0.0.0.0\"","+\t}","+\tlistenPort := input.ListenPort","+\tif listenPort == 0 && input.IsLighthouse {","+\t\tlistenPort = 4242","+\t}","+\tcfg.Listen = listenSection{Host: listenHost, Port: listenPort}","+","+\tpunch := true","+\tif input.PunchyOverride != nil {","+\t\tpunch = *input.PunchyOverride","+\t}","+\tcfg.Punchy = punchySection{Punch: punch}","+","+\tif input.MTU != 0 || input.TunDevice != \"\" || len(input.UnsafeRoutes) > 0 {","+\t\tts := &tunSection{Dev: input.TunDevice, MTU: input.MTU}","+\t\tfor _, r := range input.UnsafeRoutes {","+\t\t\tts.UnsafeRoutes = append(ts.UnsafeRoutes, unsafeRoute(r))","+\t\t}","+\t\tcfg.Tun = ts","+\t}","+","+\tif input.IsRelay {","+\t\tcfg.Relay = &relaySection{AmRelay: true}","+\t} else if len(input.Relays) > 0 {","+\t\tcfg.Relay = &relaySection{Relays: input.Relays}","+\t}","+","+\tcfg.Firewall.Outbound = mapFirewallRules(input.FirewallOutbound)","+\tcfg.Firewall.Inbound = mapFirewallRules(input.FirewallInbound)","+","+\treturn cfg","+}","+","+func mapFirewallRules(in []FirewallRule) []firewallRule {","+\tout := make([]firewallRule, 0, len(in))","+\tfor _, r := range in {","+\t\tfr := firewallRule{Port: r.Port, Proto: r.Proto}","+\t\tif r.Group == \"any\" {","+\t\t\tfr.Host = \"any\"","+\t\t} else {","+\t\t\tfr.Group = r.Group","+\t\t}","+\t\tout = append(out, fr)","+\t}","+\treturn out","+}",""],"additions":198,"deletions":0,"truncated":false}],"additions":368,"deletions":189,"truncated":false,"file_count":4},"error":null,"fetched_at":"2026-06-09T10:50:05.491129+00:00"}