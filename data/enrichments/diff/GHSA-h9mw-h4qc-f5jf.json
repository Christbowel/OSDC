bernetes-graphql-gateway/gateway/resolver\""," \t\"github.com/platform-mesh/kubernetes-graphql-gateway/gateway/schema\""," \tutilscontext \"github.com/platform-mesh/kubernetes-graphql-gateway/gateway/utils/context\"","@@ -24,7 +25,7 @@ type Endpoint struct {"," \tname           string"," \tcluster        *cluster.Cluster"," \tgraphqlServer  *graphql.GraphQLServer","-\thandler        *graphql.GraphQLHandler","+\thandler        http.Handler"," \ttokenValidator authn.Validator"," \tcancelFunc     context.CancelFunc"," }","@@ -34,6 +35,7 @@ func New("," \tname string,"," \tschemaJSON []byte,"," \tgraphqlCfg config.GraphQL,","+\tlimits config.Limits,"," \ttokenReviewCacheTTL time.Duration,"," ) (*Endpoint, error) {"," \tschemaData, err := parseSchema(schemaJSON)","@@ -63,7 +65,20 @@ func New("," \t}"," "," \tgraphqlServer := graphql.NewGraphQLServer(graphqlCfg)","-\thandler := graphqlServer.CreateHandler(schemaProvider.GetSchema())","+\tgqlHandler := graphqlServer.CreateHandler(schemaProvider.GetSchema())","+","+\t// The HTTP layer also checks Accept to route to separate timeout/concurrency pools.","+\thandler := queryvalidation.Middleware(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\tif r.Header.Get(\"Accept\") == \"text/event-stream\" {","+\t\t\tgraphqlServer.HandleSubscription(w, r, gqlHandler.Schema)","+\t\t\treturn","+\t\t}","+\t\tgqlHandler.Handler.ServeHTTP(w, r)","+\t}), queryvalidation.Config{","+\t\tMaxDepth:      limits.MaxQueryDepth,","+\t\tMaxComplexity: limits.MaxQueryComplexity,","+\t\tMaxBatchSize:  limits.MaxQueryBatchSize,","+\t})"," "," \tlog.FromContext(ctx).Info(\"Registered endpoint\", \"cluster\", name)"," ","@@ -78,7 +93,7 @@ func New("," }"," "," func (e *Endpoint) ServeHTTP(w http.ResponseWriter, r *http.Request) {","-\tif e.handler == nil || e.handler.Handler == nil {","+\tif e.handler == nil {"," \t\thttp.Error(w, \"Endpoint not ready\", http.StatusServiceUnavailable)"," \t\treturn"," \t}","@@ -99,13 +114,7 @@ func (e *Endpoint) ServeHTTP(w http.ResponseWriter, r *http.Request) {"," \t\treturn"," \t}"," ","-\t// Handle subscription requests using Server-Sent Events","-\tif r.Header.Get(\"Accept\") == \"text/event-stream\" {","-\t\te.graphqlServer.HandleSubscription(w, r, e.handler.Schema)","-\t\treturn","-\t}","-","-\te.handler.Handler.ServeHTTP(w, r)","+\te.handler.ServeHTTP(w, r)"," }"," "," func (e *Endpoint) Name() string {"],"additions":19,"deletions":10,"truncated":false},{"path":"gateway/gateway/middleware/maxinflight.go","lines":["@@ -0,0 +1,22 @@","+package middleware","+","+import \"net/http\"","+","+// WithMaxInFlightRequests returns a middleware that limits the number of concurrent","+// requests being processed. When the limit is reached, new requests receive a","+// 429 Too Many Requests response. Setting maxInFlight to 0 or less disables the limit.","+func WithMaxInFlightRequests(handler http.Handler, maxInFlight int) http.Handler {","+\tif maxInFlight <= 0 {","+\t\treturn handler","+\t}","+\tsem := make(chan struct{}, maxInFlight)","+\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\tselect {","+\t\tcase sem <- struct{}{}:","+\t\t\tdefer func() { <-sem }()","+\t\t\thandler.ServeHTTP(w, r)","+\t\tdefault:","+\t\t\thttp.Error(w, \"Too Many Requests\", http.StatusTooManyRequests)","+\t\t}","+\t})","+}"],"additions":22,"deletions":0,"truncated":false},{"path":"gateway/gateway/middleware/maxinflight_test.go","lines":["@@ -0,0 +1,144 @@","+package middleware","+","+import (","+\t\"net/http\"","+\t\"net/http/httptest\"","+\t\"sync\"","+\t\"testing\"","+\t\"time\"","+","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+)","+","+func TestWithMaxInFlightRequests(t *testing.T) {","+\ttests := []struct {","+\t\tname         string","+\t\tmaxInFlight  int","+\t\thandler      func(started chan<- struct{}, release <-chan struct{}) http.Handler","+\t\tsendRequests func(t *testing.T, serverURL string, started chan struct{}, release chan struct{})","+\t}{","+\t\t{","+\t\t\tname:        \"disabled when maxInFlight is not positive\",","+\t\t\tmaxInFlight: 0,","+\t\t\thandler: func(_ chan<- struct{}, _ <-chan struct{}) http.Handler {","+\t\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\t\t\t\tw.WriteHeader(http.StatusOK)","+\t\t\t\t})","+\t\t\t},","+\t\t\tsendRequests: func(t *testing.T, serverURL string, _ chan struct{}, _ chan struct{}) {","+\t\t\t\tt.Helper()","+\t\t\t\tresp, err := http.Get(serverURL)","+\t\t\t\trequire.NoError(t, err)","+\t\t\t\tdefer resp.Body.Close() //nolint:errcheck","+\t\t\t\tassert.Equal(t, http.StatusOK, resp.StatusCode)","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:        \"rejects when all slots are occupied\",","+\t\t\tmaxInFlight: 3,","+\t\t\thandler: func(started chan<- struct{}, release <-chan struct{}) http.Handler {","+\t\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\t\t\t\tstarted <- struct{}{}","+\t\t\t\t\t<-release","+\t\t\t\t\tw.WriteHeader(http.StatusOK)","+\t\t\t\t})","+\t\t\t},","+\t\t\tsendRequests: func(t *testing.T, serverURL string, started chan struct{}, release chan struct{}) {","+\t\t\t\tt.Helper()","+","+\t\t\t\tvar wg sync.WaitGroup","+\t\t\t\t// Fill all 3 slots","+\t\t\t\tfor range 3 {","+\t\t\t\t\twg.Add(1)","+\t\t\t\t\tgo func() {","+\t\t\t\t\t\tdefer wg.Done()","+\t\t\t\t\t\tresp, err := http.Get(serverURL)","+\t\t\t\t\t\trequire.NoError(t, err)","+\t\t\t\t\t\tdefer resp.Body.Close() //nolint:errcheck //nolint:errcheck","+\t\t\t\t\t\tassert.Equal(t, http.StatusOK, resp.StatusCode)","+\t\t\t\t\t}()","+\t\t\t\t\t<-started","+\t\t\t\t}","+","+\t\t\t\t// 4th request should be rejected","+\t\t\t\tresp, err := http.Get(serverURL)","+\t\t\t\trequire.NoError(t, err)","+\t\t\t\tdefer resp.Body.Close() //nolint:errcheck","+\t\t\t\tassert.Equal(t, http.StatusTooManyRequests, resp.StatusCode)","+","+\t\t\t\tclose(release)","+\t\t\t\twg.Wait()","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:        \"slot released after handler returns\",","+\t\t\tmaxInFlight: 1,","+\t\t\thandler: func(_ chan<- struct{}, _ <-chan struct{}) http.Handler {","+\t\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\t\t\t\tw.WriteHeader(http.StatusOK)","+\t\t\t\t})","+\t\t\t},","+\t\t\tsendRequests: func(t *testing.T, serverURL string, _ chan struct{}, _ chan struct{}) {","+\t\t\t\tt.Helper()","+\t\t\t\tfor range 5 {","+\t\t\t\t\tresp, err := http.Get(serverURL)","+\t\t\t\t\trequire.NoError(t, err)","+\t\t\t\t\tresp.Body.Close() //nolint:errcheck","+\t\t\t\t\tassert.Equal(t, http.StatusOK, resp.StatusCode)","+\t\t\t\t}","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:        \"slot released after handler panics\",","+\t\t\tmaxInFlight: 1,","+\t\t\thandler: func(_ chan<- struct{}, _ <-chan struct{}) http.Handler {","+\t\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\t\t\t\tdefer func() {","+\t\t\t\t\t\tif r := recover(); r != nil {","+\t\t\t\t\t\t\tw.WriteHeader(http.StatusInternalServerError)","+\t\t\t\t\t\t}","+\t\t\t\t\t}()","+\t\t\t\t\tpanic(\"test panic\")","+\t\t\t\t})","+\t\t\t},","+\t\t\tsendRequests: func(t *testing.T, serverURL string, _ chan struct{}, _ chan struct{}) {","+\t\t\t\tt.Helper()","+","+\t\t\t\t// First request panics","+\t\t\t\tresp, err := http.Get(serverURL)","+\t\t\t\trequire.NoError(t, err)","+\t\t\t\tresp.Body.Close() //nolint:errcheck","+","+\t\t\t\t// Second request should succeed (slot was released)","+\t\t\t\tdone := make(chan struct{})","+\t\t\t\tgo func() {","+\t\t\t\t\tdefer close(done)","+\t\t\t\t\tresp, err := http.Get(serverURL)","+\t\t\t\t\trequire.NoError(t, err)","+\t\t\t\t\tresp.Body.Close() //nolint:errcheck","+\t\t\t\t}()","+","+\t\t\t\tselect {","+\t\t\t\tcase <-done:","+\t\t\t\t\t// success","+\t\t\t\tcase <-time.After(2 * time.Second):","+\t\t\t\t\tt.Fatal(\"second request timed out — slot was not released after panic\")","+\t\t\t\t}","+\t\t\t},","+\t\t},","+\t}","+","+\tfor _, tt := range tests {","+\t\tt.Run(tt.name, func(t *testing.T) {","+\t\t\tstarted := make(chan struct{}, 10)","+\t\t\trelease := make(chan struct{})","+","+\t\t\thandler := WithMaxInFlightRequests(tt.handler(started, release), tt.maxInFlight)","+\t\t\tserver := httptest.NewServer(handler)","+\t\t\tdefer server.Close()","+","+\t\t\ttt.sendRequests(t, server.URL, started, release)","+\t\t})","+\t}","+}"],"additions":144,"deletions":0,"truncated":false},{"path":"gateway/gateway/middleware/timeout.go","lines":["@@ -0,0 +1,87 @@","+package middleware","+","+import (","+\t\"bytes\"","+\t\"context\"","+\t\"encoding/json\"","+\t\"maps\"","+\t\"net/http\"","+\t\"sync\"","+\t\"time\"","+)","+","+// WithTimeout returns a middleware that enforces a request timeout.","+// When the timeout is exceeded, it responds with 504 Gateway Timeout and a","+// GraphQL-formatted JSON error body. Setting timeout to 0 or less disables the limit.","+func WithTimeout(handler http.Handler, timeout time.Duration) http.Handler {","+\tif timeout <= 0 {","+\t\treturn handler","+\t}","+","+\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\tctx, cancel := context.WithTimeout(r.Context(), timeout)","+\t\tdefer cancel()","+","+\t\ttw := &timeoutWriter{header: make(http.Header)}","+\t\tdone := make(chan struct{})","+\t\tgo func() {","+\t\t\thandler.ServeHTTP(tw, r.WithContext(ctx))","+\t\t\tclose(done)","+\t\t}()","+","+\t\tselect {","+\t\tcase <-done:","+\t\t\ttw.mu.Lock()","+\t\t\tdefer tw.mu.Unlock()","+\t\t\tdst := w.Header()","+\t\t\tmaps.Copy(dst, tw.header)","+\t\t\tif tw.code != 0 {","+\t\t\t\tw.WriteHeader(tw.code)","+\t\t\t}","+\t\t\tw.Write(tw.buf.Bytes()) //nolint:errcheck","+\t\tcase <-ctx.Done():","+\t\t\ttw.mu.Lock()","+\t\t\ttw.timedOut = true","+\t\t\ttw.mu.Unlock()","+","+\t\t\tw.Header().Set(\"Content-Type\", \"application/json\")","+\t\t\tw.WriteHeader(http.StatusGatewayTimeout)","+\t\t\tjson.NewEncoder(w).Encode(map[string]any{ //nolint:errcheck","+\t\t\t\t\"errors\": []map[string]string{","+\t\t\t\t\t{\"message\": \"request timeout\"},","+\t\t\t\t},","+\t\t\t})","+\t\t}","+\t})","+}","+","+// timeoutWriter buffers the response so it can be discarded on timeout.","+type timeoutWriter struct {","+\theader   http.Header","+\tbuf      bytes.Buffer","+\tcode     int","+\tmu       sync.Mutex","+\ttimedOut bool","+}","+","+func (tw *timeoutWriter) Header() http.Header {","+\treturn tw.header","+}","+","+func (tw *timeoutWriter) Write(p []byte) (int, error) {","+\ttw.mu.Lock()","+\tdefer tw.mu.Unlock()","+\tif tw.timedOut {","+\t\treturn 0, context.DeadlineExceeded","+\t}","+\treturn tw.buf.Write(p)","+}","+","+func (tw *timeoutWriter) WriteHeader(code int) {","+\ttw.mu.Lock()","+\tdefer tw.mu.Unlock()","+\tif tw.timedOut {","+\t\treturn","+\t}","+\ttw.code = code","+}"],"additions":87,"deletions":0,"truncated":false},{"path":"gateway/gateway/middleware/timeout_test.go","lines":["@@ -0,0 +1,95 @@","+package middleware","+","+import (","+\t\"encoding/json\"","+\t\"net/http\"","+\t\"net/http/httptest\"","+\t\"testing\"","+\t\"time\"","+","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+)","+","+func TestWithTimeout(t *testing.T) {","+\tt.Run(\"handler completes before timeout\", func(t *testing.T) {","+\t\tinner := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\t\tw.Header().Set(\"X-Custom\", \"value\")","+\t\t\tw.WriteHeader(http.StatusOK)","+\t\t\tw.Write([]byte(`{\"data\":{}}`)) //nolint:errcheck","+\t\t})","+","+\t\thandler := WithTimeout(inner, 1*time.Second)","+\t\trec := httptest.NewRecorder()","+\t\treq := httptest.NewRequest(http.MethodPost, \"/graphql\", nil)","+","+\t\thandler.ServeHTTP(rec, req)","+","+\t\tassert.Equal(t, http.StatusOK, rec.Code)","+\t\tassert.Equal(t, `{\"data\":{}}`, rec.Body.String())","+\t\tassert.Equal(t, \"value\", rec.Header().Get(\"X-Custom\"))","+\t})","+","+\tt.Run(\"handler exceeds timeout returns 504 with GraphQL JSON error\", func(t *testing.T) {","+\t\tinner := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\t\t<-r.Context().Done()","+\t\t\ttime.Sleep(10 * time.Millisecond) // ensure timeout path wins the select","+\t\t})","+","+\t\thandler := WithTimeout(inner, 10*time.Millisecond)","+\t\trec := httptest.NewRecorder()","+\t\treq := httptest.NewRequest(http.MethodPost, \"/graphql\", nil)","+","+\t\thandler.ServeHTTP(rec, req)","+","+\t\tassert.Equal(t, http.StatusGatewayTimeout, rec.Code)","+\t\tassert.Equal(t, \"application/json\", rec.Header().Get(\"Content-Type\"))","+","+\t\tvar resp struct {","+\t\t\tErrors []struct {","+\t\t\t\tMessage string `json:\"message\"`","+\t\t\t} `json:\"errors\"`","+\t\t}","+\t\trequire.NoError(t, json.Unmarshal(rec.Body.Bytes(), &resp))","+\t\trequire.Len(t, resp.Errors, 1)","+\t\tassert.Equal(t, \"request timeout\", resp.Errors[0].Message)","+\t})","+","+\tt.Run(\"zero timeout disables middleware\", func(t *testing.T) {","+\t\tinner := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\t\tw.WriteHeader(http.StatusOK)","+\t\t})","+","+\t\thandler := WithTimeout(inner, 0)","+\t\trec := httptest.NewRecorder()","+\t\treq := httptest.NewRequest(http.MethodPost, \"/graphql\", nil)","+","+\t\thandler.ServeHTTP(rec, req)","+","+\t\tassert.Equal(t, http.StatusOK, rec.Code)","+\t})","+","+\tt.Run(\"writes after timeout are discarded\", func(t *testing.T) {","+\t\twriteDone := make(chan struct{})","+\t\tinner := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\t\t<-r.Context().Done()","+\t\t\ttime.Sleep(20 * time.Millisecond) // let timeout response be written first","+\t\t\tw.WriteHeader(http.StatusOK)","+\t\t\tw.Write([]byte(\"late write\")) //nolint:errcheck","+\t\t\tclose(writeDone)","+\t\t})","+","+\t\thandler := WithTimeout(inner, 10*time.Millisecond)","+\t\trec := httptest.NewRecorder()","+\t\treq := httptest.NewRequest(http.MethodPost, \"/graphql\", nil)","+","+\t\thandler.ServeHTTP(rec, req)","+","+\t\t// Wait for the goroutine's late writes to complete","+\t\t<-writeDone","+","+\t\t// Response should be the timeout error, not the late write","+\t\tassert.Equal(t, http.StatusGatewayTimeout, rec.Code)","+\t\tassert.NotContains(t, rec.Body.String(), \"late write\")","+\t})","+}"],"additions":95,"deletions":0,"truncated":false},{"path":"gateway/gateway/queryvalidation/middleware.go","lines":["@@ -0,0 +1,92 @@","+package queryvalidation","+","+import (","+\t\"bytes\"","+\t\"encoding/json\"","+\t\"fmt\"","+\t\"io\"","+\t\"net/http\"","+)","+","+// Middleware returns an http.Handler that validates incoming GraphQL queries","+// against depth and complexity limits before forwarding to the next handler.","+// Supports both single requests and batched query arrays.","+// If all limits are zero, the middleware is a no-op passthrough.","+func Middleware(next http.Handler, cfg Config) http.Handler {","+\tif cfg.MaxDepth <= 0 && cfg.MaxComplexity <= 0 && cfg.MaxBatchSize <= 0 {","+\t\treturn next","+\t}","+","+\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\tif r.Body == nil || r.Method == http.MethodGet {","+\t\t\tnext.ServeHTTP(w, r)","+\t\t\treturn","+\t\t}","+","+\t\tbody, err := io.ReadAll(r.Body)","+\t\tif err != nil {","+\t\t\twriteGraphQLError(w, \"failed to read request body\", http.StatusBadRequest)","+\t\t\treturn","+\t\t}","+\t\tr.Body = io.NopCloser(bytes.NewReader(body))","+","+\t\tqueries := extractQueries(body)","+\t\tif len(queries) == 0 {","+\t\t\t// Not valid JSON or no query field — let the GraphQL handler deal with it","+\t\t\tnext.ServeHTTP(w, r)","+\t\t\treturn","+\t\t}","+","+\t\tif cfg.MaxBatchSize > 0 && len(queries) > cfg.MaxBatchSize {","+\t\t\twriteGraphQLError(w, fmt.Sprintf(\"batch size %d exceeds maximum allowed batch size of %d\", len(queries), cfg.MaxBatchSize), http.StatusBadRequest)","+\t\t\treturn","+\t\t}","+","+\t\tfor _, q := range queries {","+\t\t\tif err := Validate(q, cfg); err != nil {","+\t\t\t\twriteGraphQLError(w, err.Error(), http.StatusBadRequest)","+\t\t\t\treturn","+\t\t\t}","+\t\t}","+","+\t\tnext.ServeHTTP(w, r)","+\t})","+}","+","+type graphqlRequest struct {","+\tQuery string `json:\"query\"`","+}","+","+// extractQueries extracts query strings from a GraphQL request body.","+// Supports both single requests {\"query\":\"...\"} and batched requests [{\"query\":\"...\"}, ...].","+// Returns the queries and true if extraction succeeded, or nil and false if the body","+// is not valid JSON or contains no queries.","+func extractQueries(body []byte) []string {","+\tvar reqs []graphqlRequest","+\tif err := json.Unmarshal(body, &reqs); err != nil {","+\t\tvar req graphqlRequest","+\t\tif err := json.Unmarshal(body, &req); err != nil {","+\t\t\treturn nil","+\t\t}","+\t\treqs = []graphqlRequest{req}","+\t}","+","+\tqueries := make([]string, 0, len(reqs))","+\tfor _, req := range reqs {","+\t\tif req.Query != \"\" {","+\t\t\tqueries = append(queries, req.Query)","+\t\t}","+\t}","+\treturn queries","+}","+","+func writeGraphQLError(w http.ResponseWriter, message string, statusCode int) {","+\tw.Header().Set(\"Content-Type\", \"application/json\")","+\tw.WriteHeader(statusCode)","+\tresp := map[string]any{","+\t\t\"errors\": []map[string]string{","+\t\t\t{\"message\": message},","+\t\t},","+\t}","+\tjson.NewEncoder(w).Encode(resp) //nolint:errcheck","+}"],"additions":92,"deletions":0,"truncated":false},{"path":"gateway/gateway/queryvalidation/middleware_test.go","lines":["@@ -0,0 +1,193 @@","+package queryvalidation","+","+import (","+\t\"encoding/json\"","+\t\"io\"","+\t\"net/http\"","+\t\"net/http/httptest\"","+\t\"strings\"","+\t\"testing\"","+","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+)","+","+func TestMiddleware(t *testing.T) {","+\tokHandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\tw.WriteHeader(http.StatusOK)","+\t\tw.Write([]byte(`{\"data\":{}}`)) //nolint:errcheck","+\t})","+","+\ttests := []struct {","+\t\tname       string","+\t\tcfg        Config","+\t\tbody       string","+\t\tmethod     string","+\t\twantStatus int","+\t\twantError  string","+\t\twantPass   bool // whether request reaches the inner handler","+\t}{","+\t\t{","+\t\t\tname:       \"valid query passes through\",","+\t\t\tcfg:        Config{MaxDepth: 5, MaxComplexity: 100},","+\t\t\tbody:       `{\"query\":\"{ pods { name } }\"}`,","+\t\t\tmethod:     http.MethodPost,","+\t\t\twantStatus: http.StatusOK,","+\t\t\twantPass:   true,","+\t\t},","+\t\t{","+\t\t\tname:       \"deep query rejected\",","+\t\t\tcfg:        Config{MaxDepth: 2},","+\t\t\tbody:       `{\"query\":\"{ a { b { c } } }\"}`,","+\t\t\tmethod:     http.MethodPost,","+\t\t\twantStatus: http.StatusBadRequest,","+\t\t\twantError:  \"query depth 3 exceeds maximum allowed depth of 2\",","+\t\t},","+\t\t{","+\t\t\tname:       \"complex query rejected\",","+\t\t\tcfg:        Config{MaxComplexity: 3},","+\t\t\tbody:       `{\"query\":\"{ a b c d }\"}`,","+\t\t\tmethod:     http.MethodPost,","+\t\t\twantStatus: http.StatusBadRequest,","+\t\t\twantError:  \"query complexity 4 exceeds maximum allowed complexity of 3\",","+\t\t},","+\t\t{","+\t\t\tname:       \"disabled config passes everything\",","+\t\t\tcfg:        Config{MaxDepth: 0, MaxComplexity: 0},","+\t\t\tbody:       `{\"query\":\"{ a { b { c { d { e { f } } } } } }\"}`,","+\t\t\tmethod:     http.MethodPost,","+\t\t\twantStatus: http.StatusOK,","+\t\t\twantPass:   true,","+\t\t},","+\t\t{","+\t\t\tname:       \"GET request passes through\",","+\t\t\tcfg:        Config{MaxDepth: 1},","+\t\t\tbody:       \"\",","+\t\t\tmethod:     http.MethodGet,","+\t\t\twantStatus: http.StatusOK,","+\t\t\twantPass:   true,","+\t\t},","+\t\t{","+\t\t\tname:       \"empty query field passes through\",","+\t\t\tcfg:        Config{MaxDepth: 1},","+\t\t\tbody:       `{\"query\":\"\"}`,","+\t\t\tmethod:     http.MethodPost,","+\t\t\twantStatus: http.StatusOK,","+\t\t\twantPass:   true,","+\t\t},","+\t\t{","+\t\t\tname:       \"non-JSON body passes through to graphql handler\",","+\t\t\tcfg:        Config{MaxDepth: 1},","+\t\t\tbody:       `not json`,","+\t\t\tmethod:     http.MethodPost,","+\t\t\twantStatus: http.StatusOK,","+\t\t\twantPass:   true,","+\t\t},","+\t\t{","+\t\t\tname:       \"batched query rejected when one exceeds depth\",","+\t\t\tcfg:        Config{MaxDepth: 2},","+\t\t\tbody:       `[{\"query\":\"{ a { name } }\"},{\"query\":\"{ a { b { c } } }\"}]`,","+\t\t\tmethod:     http.MethodPost,","+\t\t\twantStatus: http.StatusBadRequest,","+\t\t\twantError:  \"query depth 3 exceeds maximum allowed depth of 2\",","+\t\t},","+\t\t{","+\t\t\tname:       \"batched query passes when all within limits\",","+\t\t\tcfg:        Config{MaxDepth: 5, MaxComplexity: 100},","+\t\t\tbody:       `[{\"query\":\"{ a { name } }\"},{\"query\":\"{ b { name } }\"}]`,","+\t\t\tmethod:     http.MethodPost,","+\t\t\twantStatus: http.StatusOK,","+\t\t\twantPass:   true,","+\t\t},","+\t\t{","+\t\t\tname:       \"empty batched array passes through\",","+\t\t\tcfg:        Config{MaxDepth: 1},","+\t\t\tbody:       `[]`,","+\t\t\tmethod:     http.MethodPost,","+\t\t\twantStatus: http.StatusOK,","+\t\t\twantPass:   true,","+\t\t},","+\t\t{","+\t\t\tname:       \"batch rejected when exceeding max batch size\",","+\t\t\tcfg:        Config{MaxBatchSize: 2},","+\t\t\tbody:       `[{\"query\":\"{ a }\"},{\"query\":\"{ b }\"},{\"query\":\"{ c }\"}]`,","+\t\t\tmethod:     http.MethodPost,","+\t\t\twantStatus: http.StatusBadRequest,","+\t\t\twantError:  \"batch size 3 exceeds maximum allowed batch size of 2\",","+\t\t},","+\t\t{","+\t\t\tname:       \"batch passes when within max batch size\",","+\t\t\tcfg:        Config{MaxBatchSize: 3},","+\t\t\tbody:       `[{\"query\":\"{ a }\"},{\"query\":\"{ b }\"},{\"query\":\"{ c }\"}]`,","+\t\t\tmethod:     http.MethodPost,","+\t\t\twantStatus: http.StatusOK,","+\t\t\twantPass:   true,","+\t\t},","+\t\t{","+\t\t\tname:       \"single request unaffected by batch size limit\",","+\t\t\tcfg:        Config{MaxBatchSize: 2},","+\t\t\tbody:       `{\"query\":\"{ a }\"}`,","+\t\t\tmethod:     http.MethodPost,","+\t\t\twantStatus: http.StatusOK,","+\t\t\twantPass:   true,","+\t\t},","+\t\t{","+\t\t\tname:       \"batch size zero disables limit\",","+\t\t\tcfg:        Config{MaxBatchSize: 0, MaxDepth: 10},","+\t\t\tbody:       `[{\"query\":\"{ a }\"},{\"query\":\"{ b }\"},{\"query\":\"{ c }\"},{\"query\":\"{ d }\"},{\"query\":\"{ e }\"}]`,","+\t\t\tmethod:     http.MethodPost,","+\t\t\twantStatus: http.StatusOK,","+\t\t\twantPass:   true,","+\t\t},","+\t}","+","+\tfor _, tt := range tests {","+\t\tt.Run(tt.name, func(t *testing.T) {","+\t\t\tvar innerCalled bool","+\t\t\tvar innerBody string","+\t\t\tinner := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\t\t\tinnerCalled = true","+\t\t\t\tif r.Body != nil {","+\t\t\t\t\tb, _ := io.ReadAll(r.Body)","+\t\t\t\t\tinnerBody = string(b)","+\t\t\t\t}","+\t\t\t\tokHandler.ServeHTTP(w, r)","+\t\t\t})","+","+\t\t\thandler := Middleware(inner, tt.cfg)","+","+\t\t\tvar body io.Reader","+\t\t\tif tt.body != \"\" {","+\t\t\t\tbody = strings.NewReader(tt.body)","+\t\t\t}","+\t\t\treq := httptest.NewRequest(tt.method, \"/graphql\", body)","+\t\t\tif tt.method == http.MethodPost {","+\t\t\t\treq.Header.Set(\"Content-Type\", \"application/json\")","+\t\t\t}","+\t\t\trec := httptest.NewRecorder()","+","+\t\t\thandler.ServeHTTP(rec, req)","+","+\t\t\tassert.Equal(t, tt.wantStatus, rec.Code)","+","+\t\t\tif tt.wantError != \"\" {","+\t\t\t\tvar resp struct {","+\t\t\t\t\tErrors []struct {","+\t\t\t\t\t\tMessage string `json:\"message\"`","+\t\t\t\t\t} `json:\"errors\"`","+\t\t\t\t}","+\t\t\t\trequire.NoError(t, json.Unmarshal(rec.Body.Bytes(), &resp))","+\t\t\t\trequire.Len(t, resp.Errors, 1)","+\t\t\t\tassert.Contains(t, resp.Errors[0].Message, tt.wantError)","+\t\t\t\tassert.False(t, innerCalled, \"inner handler should not be called on rejection\")","+\t\t\t}","+","+\t\t\tif tt.wantPass {","+\t\t\t\tassert.True(t, innerCalled, \"inner handler should be called\")","+\t\t\t\tif tt.body != \"\" && tt.method == http.MethodPost {","+\t\t\t\t\tassert.Equal(t, tt.body, innerBody, \"body should be preserved for downstream handler\")","+\t\t\t\t}","+\t\t\t}","+\t\t})","+\t}","+}"],"additions":193,"deletions":0,"truncated":false},{"path":"gateway/gateway/queryvalidation/queryvalidation.go","lines":["@@ -0,0 +1,139 @@","+package queryvalidation","+","+import (","+\t\"fmt\"","+","+\t\"github.com/graphql-go/graphql/language/ast\"","+\t\"github.com/graphql-go/graphql/language/parser\"","+\t\"github.com/graphql-go/graphql/language/source\"","+)","+","+// Config holds limits for query validation. Zero values disable the respective check.","+type Config struct {","+\t// MaxDepth is the maximum allowed nesting depth for GraphQL queries.","+\t// 0 disables the limit.","+\tMaxDepth int","+","+\t// MaxComplexity is the maximum allowed complexity score for GraphQL queries.","+\t// Each field resolution counts as 1 point of complexity.","+\t// 0 disables the limit.","+\tMaxComplexity int","+","+\t// MaxBatchSize is the maximum number of queries allowed in a single batched request.","+\t// 0 disables the limit.","+\tMaxBatchSize int","+}","+","+// Validate parses a GraphQL query string and checks depth/complexity limits.","+// Returns a non-nil error if limits are exceeded.","+func Validate(query string, cfg Config) error {","+\tif cfg.MaxDepth <= 0 && cfg.MaxComplexity <= 0 {","+\t\treturn nil","+\t}","+","+\tsrc := source.NewSource(&source.Source{Body: []byte(query)})","+\tdoc, err := parser.Parse(parser.ParseParams{Source: src})","+\tif err != nil {","+\t\treturn fmt.Errorf(\"failed to parse query: %w\", err)","+\t}","+","+\tw := &walker{cfg: cfg, fragments: make(map[string]*ast.FragmentDefinition)}","+\tfor _, def := range doc.Definitions {","+\t\tif frag, ok := def.(*ast.FragmentDefinition); ok {","+\t\t\tw.fragments[frag.Name.Value] = frag","+\t\t}","+\t}","+","+\tvar maxDepth, totalComplexity int","+\tfor _, def := range doc.Definitions {","+\t\tif op, ok := def.(*ast.OperationDefinition); ok && op.SelectionSet != nil {","+\t\t\tw.visiting = make(map[string]bool)","+\t\t\tdepth, complexity := w.walk(op.SelectionSet, 1)","+\t\t\tif depth > maxDepth {","+\t\t\t\tmaxDepth = depth","+\t\t\t}","+\t\t\ttotalComplexity += complexity","+\t\t}","+\t}","+","+\tif cfg.MaxDepth > 0 && maxDepth > cfg.MaxDepth {","+\t\treturn fmt.Errorf(\"query depth %d exceeds maximum allowed depth of %d\", maxDepth, cfg.MaxDepth)","+\t}","+\tif cfg.MaxComplexity > 0 && totalComplexity > cfg.MaxComplexity {","+\t\treturn fmt.Errorf(\"query complexity %d exceeds maximum allowed complexity of %d\", totalComplexity, cfg.MaxComplexity)","+\t}","+","+\treturn nil","+}","+","+// walker holds shared state for recursive AST traversal.","+type walker struct {","+\tcfg       Config","+\tfragments map[string]*ast.FragmentDefinition","+\tvisiting  map[string]bool // per-operation cycle detection for fragment spreads","+}","+","+// walk recursively traverses a selection set and returns the maximum depth","+// and total field complexity. Exits early when configured limits are exceeded.","+func (w *walker) walk(selSet *ast.SelectionSet, depth int) (int, int) {","+\tmaxDepth := depth","+\tvar complexity int","+","+\tif w.cfg.MaxDepth > 0 && depth > w.cfg.MaxDepth {","+\t\treturn maxDepth, complexity","+\t}","+","+\tfor _, sel := range selSet.Selections {","+\t\tswitch s := sel.(type) {","+\t\tcase *ast.Field:","+\t\t\tcomplexity++","+\t\t\tif w.cfg.MaxComplexity > 0 && complexity > w.cfg.MaxComplexity {","+\t\t\t\treturn maxDepth, complexity","+\t\t\t}","+\t\t\tif s.SelectionSet != nil {","+\t\t\t\tchildDepth, childComplexity := w.walk(s.SelectionSet, depth+1)","+\t\t\t\tif childDepth > maxDepth {","+\t\t\t\t\tmaxDepth = childDepth","+\t\t\t\t}","+\t\t\t\tcomplexity += childComplexity","+\t\t\t\tif w.cfg.MaxComplexity > 0 && complexity > w.cfg.MaxComplexity {","+\t\t\t\t\treturn maxDepth, complexity","+\t\t\t\t}","+\t\t\t}","+","+\t\tcase *ast.InlineFragment:","+\t\t\t// Inline fragments don't increase depth — they narrow the type, not the nesting.","+\t\t\tif s.SelectionSet != nil {","+\t\t\t\tchildDepth, childComplexity := w.walk(s.SelectionSet, depth)","+\t\t\t\tif childDepth > maxDepth {","+\t\t\t\t\tmaxDepth = childDepth","+\t\t\t\t}","+\t\t\t\tcomplexity += childComplexity","+\t\t\t\tif w.cfg.MaxComplexity > 0 && complexity > w.cfg.MaxComplexity {","+\t\t\t\t\treturn maxDepth, complexity","+\t\t\t\t}","+\t\t\t}","+","+\t\tcase *ast.FragmentSpread:","+\t\t\tname := s.Name.Value","+\t\t\tif w.visiting[name] {","+\t\t\t\tcontinue // cycle detected, skip","+\t\t\t}","+\t\t\tfrag, ok := w.fragments[name]","+\t\t\tif !ok {","+\t\t\t\tcontinue // unknown fragment, graphql validation will catch this","+\t\t\t}","+\t\t\tw.visiting[name] = true","+\t\t\tif frag.SelectionSet != nil {","+\t\t\t\tchildDepth, childComplexity := w.walk(frag.SelectionSet, depth)","+\t\t\t\tif childDepth > maxDepth {","+\t\t\t\t\tmaxDepth = childDepth","+\t\t\t\t}","+\t\t\t\tcomplexity += childComplexity","+\t\t\t}","+\t\t\tdelete(w.visiting, name)","+\t\t}","+\t}","+","+\treturn maxDepth, complexity","+}"],"additions":139,"deletions":0,"truncated":false},{"path":"gateway/gateway/queryvalidation/queryvalidation_test.go","lines":["@@ -0,0 +1,182 @@","+package queryvalidation","+","+import (","+\t\"testing\"","+","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+)","+","+func TestExtractQueries(t *testing.T) {","+\ttests := []struct {","+\t\tname      string","+\t\tbody      string","+\t\twantCount int","+\t}{","+\t\t{","+\t\t\tname:      \"single request\",","+\t\t\tbody:      `{\"query\":\"{ pods { name } }\"}`,","+\t\t\twantCount: 1,","+\t\t},","+\t\t{","+\t\t\tname:      \"batched request\",","+\t\t\tbody:      `[{\