thConfig); err != nil {","+\t\tlogrus.Warnf(\"refreshGitHubAppUsersOnce: setting annotation: %v\", err)","+\t}","+}"],"additions":50,"deletions":0,"truncated":false},{"path":"pkg/data/management/githubapp_refresh_users_test.go","lines":["@@ -0,0 +1,93 @@","+package management","+","+import (","+\t\"fmt\"","+\t\"testing\"","+","+\tv3 \"github.com/rancher/rancher/pkg/apis/management.cattle.io/v3\"","+\t\"github.com/rancher/wrangler/v3/pkg/generic/fake\"","+\t\"github.com/stretchr/testify/assert\"","+\t\"go.uber.org/mock/gomock\"","+\tk8serrors \"k8s.io/apimachinery/pkg/api/errors\"","+\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"","+\t\"k8s.io/apimachinery/pkg/runtime/schema\"","+)","+","+func TestRefreshGitHubAppUsersOnce(t *testing.T) {","+\tt.Parallel()","+","+\tnotFound := k8serrors.NewNotFound(schema.GroupResource{Resource: \"authconfigs\"}, \"githubapp\")","+","+\ttests := []struct {","+\t\tname            string","+\t\tauthConfig      *v3.AuthConfig","+\t\tgetErr          error","+\t\twantUpdateCalls int","+\t\twantAnnotation  bool","+\t}{","+\t\t{","+\t\t\tname:   \"provider not configured\",","+\t\t\tgetErr: notFound,","+\t\t},","+\t\t{","+\t\t\tname:   \"get authconfig error\",","+\t\t\tgetErr: fmt.Errorf(\"connection refused\"),","+\t\t},","+\t\t{","+\t\t\tname: \"provider not enabled\",","+\t\t\tauthConfig: &v3.AuthConfig{","+\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"githubapp\"},","+\t\t\t\tEnabled:    false,","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname: \"already ran\",","+\t\t\tauthConfig: &v3.AuthConfig{","+\t\t\t\tObjectMeta: metav1.ObjectMeta{","+\t\t\t\t\tName:        \"githubapp\",","+\t\t\t\t\tAnnotations: map[string]string{providerRefreshRequestedAnnotation: \"true\"},","+\t\t\t\t},","+\t\t\t\tEnabled: true,","+\t\t\t},","+\t\t\twantAnnotation: true,","+\t\t},","+\t\t{","+\t\t\tname: \"first run\",","+\t\t\tauthConfig: &v3.AuthConfig{","+\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"githubapp\"},","+\t\t\t\tEnabled:    true,","+\t\t\t},","+\t\t\twantUpdateCalls: 1,","+\t\t\twantAnnotation:  true,","+\t\t},","+\t}","+","+\tfor _, tt := range tests {","+\t\tt.Run(tt.name, func(t *testing.T) {","+\t\t\tt.Parallel()","+","+\t\t\tctrl := gomock.NewController(t)","+","+\t\t\tmock := fake.NewMockNonNamespacedClientInterface[*v3.AuthConfig, *v3.AuthConfigList](ctrl)","+\t\t\tmock.EXPECT().Get(\"githubapp\", metav1.GetOptions{}).Return(tt.authConfig, tt.getErr)","+","+\t\t\tvar updated *v3.AuthConfig","+\t\t\tif tt.wantUpdateCalls > 0 {","+\t\t\t\tmock.EXPECT().Update(gomock.Any()).DoAndReturn(func(cfg *v3.AuthConfig) (*v3.AuthConfig, error) {","+\t\t\t\t\tupdated = cfg","+\t\t\t\t\treturn cfg, nil","+\t\t\t\t}).Times(tt.wantUpdateCalls)","+\t\t\t}","+","+\t\t\tRefreshGitHubAppUsersOnce(t.Context(), mock)","+","+\t\t\tif tt.wantAnnotation {","+\t\t\t\tsource := updated","+\t\t\t\tif source == nil {","+\t\t\t\t\tsource = tt.authConfig","+\t\t\t\t}","+\t\t\t\tassert.Equal(t, \"true\", source.Annotations[providerRefreshRequestedAnnotation])","+\t\t\t}","+\t\t})","+\t}","+}"],"additions":93,"deletions":0,"truncated":false},{"path":"pkg/multiclustermanager/app.go","lines":["@@ -210,6 +210,7 @@ func (m *mcm) Start(ctx context.Context) error {"," \t\tgo adunmigration.UnmigrateAdGUIDUsersOnce(m.ScaledContext)"," \t\ttokens.StartPurgeDaemon(ctx, management)"," \t\tproviderrefresh.StartRefreshDaemon(m.ScaledContext, management)","+\t\tmanagementdata.RefreshGitHubAppUsersOnce(ctx, m.wranglerContext.Mgmt.AuthConfig())"," \t\tmanagementdata.CleanupOrphanedSystemUsers(ctx, management)"," \t\tclusterupstreamrefresher.MigrateEksRefreshCronSetting(m.wranglerContext)"," \t\tgo managementdata.CleanupDuplicateBindings(m.ScaledContext, m.wranglerContext)",""],"additions":1,"deletions":0,"truncated":false}],"additions":180,"deletions":16,"truncated":false,"file_count":6},"error":null,"fetched_at":"2026-07-02T10:20:52.017188+00:00"}