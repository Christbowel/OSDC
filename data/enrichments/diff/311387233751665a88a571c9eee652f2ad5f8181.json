hat/browser/agentSessions/agentHost/agentHostNewSessionFolderService.ts","lines":["@@ -0,0 +1,96 @@","+/*---------------------------------------------------------------------------------------------","+ *  Copyright (c) Microsoft Corporation. All rights reserved.","+ *  Licensed under the MIT License. See License.txt in the project root for license information.","+ *--------------------------------------------------------------------------------------------*/","+","+import { Emitter, Event } from '../../../../../../base/common/event.js';","+import { Disposable } from '../../../../../../base/common/lifecycle.js';","+import { ResourceMap } from '../../../../../../base/common/map.js';","+import { URI } from '../../../../../../base/common/uri.js';","+import { createDecorator } from '../../../../../../platform/instantiation/common/instantiation.js';","+import { InstantiationType, registerSingleton } from '../../../../../../platform/instantiation/common/extensions.js';","+import { IChatService } from '../../../common/chatService/chatService.js';","+","+export const IAgentHostNewSessionFolderService = createDecorator<IAgentHostNewSessionFolderService>('agentHostNewSessionFolderService');","+","+/**","+ * Per-window store of the working directory a user picked for a not-yet-started","+ * agent-host session, keyed by the chat session resource it was picked against","+ * (including the untitled compose resource). An agent-host session's working","+ * directory is an argument to session creation and is immutable afterwards, so","+ * in a multi-root window the Folder picker chip records the choice here and the","+ * working-directory resolution sites consult it before falling back to the","+ * first workspace folder. Keying by the compose resource lets the choice","+ * survive the untitled-to-real rebind that happens when the session is created.","+ */","+export interface IAgentHostNewSessionFolderService {","+\treadonly _serviceBrand: undefined;","+","+\t/**","+\t * Fires with the session resource whose chosen folder changed.","+\t */","+\treadonly onDidChangeFolder: Event<URI>;","+","+\t/**","+\t * The folder chosen for the given session resource, or `undefined` if the","+\t * user has not made an explicit choice.","+\t */","+\tgetFolder(sessionResource: URI): URI | undefined;","+","+\t/**","+\t * Record the folder chosen for the given session resource. Fires","+\t * {@link onDidChangeFolder} when the value actually changes.","+\t */","+\tsetFolder(sessionResource: URI, folder: URI): void;","+","+\t/**","+\t * Forget any choice recorded for the given session resource.","+\t */","+\tclear(sessionResource: URI): void;","+}","+","+export class AgentHostNewSessionFolderService extends Disposable implements IAgentHostNewSessionFolderService {","+\tdeclare readonly _serviceBrand: undefined;","+","+\tprivate readonly _folders = new ResourceMap<URI>();","+","+\tprivate readonly _onDidChangeFolder = this._register(new Emitter<URI>());","+\treadonly onDidChangeFolder = this._onDidChangeFolder.event;","+","+\tconstructor(","+\t\t@IChatService chatService: IChatService,","+\t) {","+\t\tsuper();","+","+\t\t// Forget a session's chosen folder once the session is disposed. This","+\t\t// bounds the store to live sessions while keeping the choice available","+\t\t// for the session's whole lifetime (so the Folder chip keeps showing","+\t\t// the right folder after the session has started).","+\t\tthis._register(chatService.onDidDisposeSession(e => {","+\t\t\tfor (const sessionResource of e.sessionResources) {","+\t\t\t\tthis.clear(sessionResource);","+\t\t\t}","+\t\t}));","+\t}","+","+\tgetFolder(sessionResource: URI): URI | undefined {","+\t\treturn this._folders.get(sessionResource);","+\t}","+","+\tsetFolder(sessionResource: URI, folder: URI): void {","+\t\tconst existing = this._folders.get(sessionResource);","+\t\tif (existing?.toString() === folder.toString()) {","+\t\t\treturn;","+\t\t}","+\t\tthis._folders.set(sessionResource, folder);","+\t\tthis._onDidChangeFolder.fire(sessionResource);","+\t}","+","+\tclear(sessionResource: URI): void {","+\t\tif (this._folders.delete(sessionResource)) {","+\t\t\tthis._onDidChangeFolder.fire(sessionResource);","+\t\t}","+\t}","+}","+","+registerSingleton(IAgentHostNewSessionFolderService, AgentHostNewSessionFolderService, InstantiationType.Delayed);"],"additions":96,"deletions":0,"truncated":false},{"path":"src/vs/workbench/contrib/chat/browser/agentSessions/agentHost/agentHostSessionHandler.ts","lines":["@@ -60,6 +60,7 @@ import { ILanguageModelToolsService, IToolInvocation, IToolResult, ToolInvocatio"," import { IChatWidgetService } from '../../chat.js';"," import { IAgentHostActiveClientService } from './agentHostActiveClientService.js';"," import { IAgentHostSessionWorkingDirectoryResolver } from './agentHostSessionWorkingDirectoryResolver.js';","+import { IAgentHostNewSessionFolderService } from './agentHostNewSessionFolderService.js';"," import { AgentHostSnapshotController } from './agentHostSnapshotController.js';"," import { toolDataToDefinition } from './agentHostToolUtils.js';"," import { IAgentHostUntitledProvisionalSessionService } from './agentHostUntitledProvisionalSessionService.js';","@@ -422,6 +423,7 @@ export class AgentHostSessionHandler extends Disposable implements IChatSessionC"," \t\t@ITerminalChatService private readonly _terminalChatService: ITerminalChatService,"," \t\t@IAgentHostTerminalService private readonly _agentHostTerminalService: IAgentHostTerminalService,"," \t\t@IAgentHostSessionWorkingDirectoryResolver private readonly _workingDirectoryResolver: IAgentHostSessionWorkingDirectoryResolver,","+\t\t@IAgentHostNewSessionFolderService private readonly _newSessionFolderService: IAgentHostNewSessionFolderService,"," \t\t@IAgentHostUntitledProvisionalSessionService private readonly _provisionalService: IAgentHostUntitledProvisionalSessionService,"," \t\t@ILanguageModelToolsService private readonly _toolsService: ILanguageModelToolsService,