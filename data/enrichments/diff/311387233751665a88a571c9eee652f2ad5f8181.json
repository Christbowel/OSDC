Service,","+\t\t@IWorkspaceContextService private readonly _workspaceContextService: IWorkspaceContextService,","+\t\t@IAgentHostNewSessionFolderService private readonly _newSessionFolderService: IAgentHostNewSessionFolderService,","+\t) {","+\t\tconst actionProvider: IActionWidgetDropdownActionProvider = {","+\t\t\tgetActions: () => {","+\t\t\t\tconst selected = this._selectedFolder();","+\t\t\t\treturn this._workspaceContextService.getWorkspace().folders.map(folder => ({","+\t\t\t\t\t...action,","+\t\t\t\t\tid: `agentHostFolder.${folder.uri.toString()}`,","+\t\t\t\t\tlabel: folder.name,","+\t\t\t\t\tchecked: selected?.toString() === folder.uri.toString(),","+\t\t\t\t\ticon: { id: 'folder' },","+\t\t\t\t\tenabled: true,","+\t\t\t\t\ttooltip: folder.uri.fsPath,","+\t\t\t\t\trun: async () => {","+\t\t\t\t\t\tconst sessionResource = this._sessionResource();","+\t\t\t\t\t\tif (sessionResource) {","+\t\t\t\t\t\t\tthis._newSessionFolderService.setFolder(sessionResource, folder.uri);","+\t\t\t\t\t\t}","+\t\t\t\t\t\tif (this.element) {","+\t\t\t\t\t\t\tthis.renderLabel(this.element);","+\t\t\t\t\t\t}","+\t\t\t\t\t},","+\t\t\t\t} satisfies IActionWidgetDropdownAction));","+\t\t\t}","+\t\t};","+","+\t\tconst actionBarActionProvider: IActionProvider = {","+\t\t\tgetActions: () => []","+\t\t};","+","+\t\tconst folderPickerOptions: Omit<IActionWidgetDropdownOptions, 'label' | 'labelRenderer'> = {","+\t\t\tactionProvider,","+\t\t\tactionBarActionProvider,","+\t\t\tshowItemKeybindings: false,","+\t\t\treporter: { id: 'AgentHostFolderPicker', name: 'AgentHostFolderPicker', includeOptions: false },","+\t\t};","+","+\t\tsuper(action, folderPickerOptions, pickerOptions, actionWidgetService, keybindingService, contextKeyService, telemetryService);","+","+\t\tthis._register(this._newSessionFolderService.onDidChangeFolder(() => {","+\t\t\tif (this.element) {","+\t\t\t\tthis.renderLabel(this.element);","+\t\t\t}","+\t\t}));","+\t\tthis._register(this._workspaceContextService.onDidChangeWorkspaceFolders(() => {","+\t\t\tif (this.element) {","+\t\t\t\tthis.renderLabel(this.element);","+\t\t\t}","+\t\t}));","+\t\tthis._register(this._widget.onDidChangeViewModel(() => {","+\t\t\tif (this.element) {","+\t\t\t\tthis.renderLabel(this.element);","+\t\t\t}","+\t\t}));","+\t}","+","+\tprivate _sessionResource(): URI | undefined {","+\t\treturn this._widget.viewModel?.sessionResource;","+\t}","+","+\tprivate _selectedFolder(): URI | undefined {","+\t\tconst folders = this._workspaceContextService.getWorkspace().folders;","+\t\tconst sessionResource = this._sessionResource();","+\t\tconst stored = sessionResource ? this._newSessionFolderService.getFolder(sessionResource) : undefined;","+\t\tif (stored) {","+\t\t\tif (folders.some(folder => folder.uri.toString() === stored.toString())) {","+\t\t\t\treturn stored;","+\t\t\t}","+\t\t\t// The stored folder is no longer part of the workspace (folders","+\t\t\t// changed); drop the stale selection and fall back to the first folder.","+\t\t\tthis._newSessionFolderService.clear(sessionResource!);","+\t\t}","+\t\treturn folders[0]?.uri;","+\t}","+","+\tprotected override renderLabel(element: HTMLElement): IDisposable | null {","+\t\tthis.setAriaLabelAttributes(element);","+\t\tconst selected = this._selectedFolder();","+\t\tconst folder = selected && this._workspaceContextService.getWorkspace().folders.find(f => f.uri.toString() === selected.toString());","+\t\tconst label = folder ? folder.name : (selected ? basename(selected) : localize('agentHost.selectFolder', \"Folder\"));","+\t\tdom.reset(","+\t\t\telement,","+\t\t\t...renderLabelWithIcons(`$(folder)`),","+\t\t\tdom.$('span.chat-input-picker-label', undefined, label),","+\t\t);","+\t\treturn null;","+\t}","+}"],"additions":132,"deletions":0,"truncated":false},{"path":"src/vs/workbench/contrib/chat/browser/agentSessions/agentHost/agentHostGenericConfigChips.ts","lines":["@@ -17,6 +17,7 @@ import { isUntitledChatSession } from '../../../common/model/chatUri.js';","