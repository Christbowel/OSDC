}","+\t\trequire.NoError(t, rerr)","+\t\tproto.Merge(got, chunk.RangeResponse)","+\t}","+\treturn got","+}","+","+// TestV3RangeStreamCount verifies Count semantics on the last streamed chunk,","+// including the case where the stream truncates at Limit with more matching","+// keys pending (exercises the CountOnly fallback query at the pinned revision).","+func TestV3RangeStreamCount(t *testing.T) {","+\tif integration.ThroughProxy {","+\t\tt.Skip(\"RangeStream is not supported by the gRPC proxy\")","+\t}","+\tintegration.BeforeTest(t)","+\tclus := integration.NewCluster(t, &integration.ClusterConfig{Size: 1})","+\tdefer clus.Terminate(t)","+","+\tkvc := integration.ToGRPC(clus.RandClient()).KV","+\tconst nKeys = 25","+\tfor i := 0; i < nKeys; i++ {","+\t\t_, err := kvc.Put(t.Context(), &pb.PutRequest{","+\t\t\tKey:   []byte(fmt.Sprintf(\"k%02d\", i)),","+\t\t\tValue: []byte(\"v\"),","+\t\t})","+\t\trequire.NoError(t, err)","+\t}","+","+\t// The server-side chunker starts at Limit=10 and adapts from there, so","+\t// nKeys=25 reliably produces multi-chunk responses for unlimited/large","+\t// limits, while small limits fit in the first chunk.","+\ttests := []struct {","+\t\tname        string","+\t\tlimit       int64","+\t\twantCount   int64","+\t\twantMore    bool","+\t\twantKeys    int","+\t\twantMinRecv int","+\t}{","+\t\t{","+\t\t\tname:        \"unlimited exhausts with running count\",","+\t\t\tlimit:       0,","+\t\t\twantCount:   nKeys,","+\t\t\twantMore:    false,","+\t\t\twantKeys:    nKeys,","+\t\t\twantMinRecv: 2,","+\t\t},","+\t\t{","+\t\t\tname:        \"limit below total truncates with fallback count\",","+\t\t\tlimit:       5,","+\t\t\twantCount:   nKeys,","+\t\t\twantMore:    true,","+\t\t\twantKeys:    5,","+\t\t\twantMinRecv: 1,","+\t\t},","+\t\t{","+\t\t\tname:        \"limit equal to total, no truncation\",","+\t\t\tlimit:       nKeys,","+\t\t\twantCount:   nKeys,","+\t\t\twantMore:    false,","+\t\t\twantKeys:    nKeys,","+\t\t\twantMinRecv: 2,","+\t\t},","+\t\t{","+\t\t\tname:        \"limit above total, exhausts early\",","+\t\t\tlimit:       100,","+\t\t\twantCount:   nKeys,","+\t\t\twantMore:    false,","+\t\t\twantKeys:    nKeys,","+\t\t\twantMinRecv: 2,","+\t\t},","+\t\t{","+\t\t\tname:        \"limit at first-chunk boundary with fallback count\",","+\t\t\tlimit:       10,","+\t\t\twantCount:   nKeys,","+\t\t\twantMore:    true,","+\t\t\twantKeys:    10,","+\t\t\twantMinRecv: 1,","+\t\t},","+\t}","+","+\tfor _, tt := range tests {","+\t\tt.Run(tt.name, func(t *testing.T) {","+\t\t\tstream, err := kvc.RangeStream(t.Context(), &pb.RangeRequest{","+\t\t\t\tKey:      []byte(\"k00\"),","+\t\t\t\tRangeEnd: []byte(\"l\"),","+\t\t\t\tLimit:    tt.limit,","+\t\t\t})","+\t\t\trequire.NoError(t, err)","+","+\t\t\tmerged := &pb.RangeResponse{}","+\t\t\trecvs := 0","+\t\t\tfor {","+\t\t\t\tchunk, rerr := stream.Recv()","+\t\t\t\tif errors.Is(rerr, io.EOF) {","+\t\t\t\t\tbreak","+\t\t\t\t}","+\t\t\t\trequire.NoError(t, rerr)","+\t\t\t\trecvs++","+\t\t\t\tproto.Merge(merged, chunk.RangeResponse)","+\t\t\t}","+\t\t\trequire.Equalf(t, tt.wantCount, merged.Count, \"Count\")","+\t\t\trequire.Equalf(t, tt.wantMore, merged.More, \"More\")","+\t\t\trequire.Lenf(t, merged.Kvs, tt.wantKeys, \"kv count\")","+\t\t\trequire.GreaterOrEqualf(t, recvs, tt.wantMinRecv, \"chunk count\")","+\t\t})","+\t}","+}","+","+// TestV3RangeStreamPartialThenCompacted verifies that once the stream has","+// emitted partial results at a pinned revision, a compaction past that","+// revision causes the next chunk to surface ErrCompacted instead of silently","+// returning inconsistent data.","+func TestV3RangeStreamPartialThenCompacted(t *testing.T) {","+\tif integration.ThroughProxy {","+\t\tt.Skip(\"RangeStream is not supported by the gRPC proxy\")","+\t}","+","+\tintegration.BeforeTest(t)","+\tclus := integration.NewCluster(t, &integration.ClusterConfig{Size: 1})","+\tdefer clus.Terminate(t)","+","+\tkvc := integration.ToGRPC(clus.RandClient()).KV","+\tvalue := []byte(strings.Repeat(\"x\", 10*1024))","+\tfor i := 0; i < 1000; i++ {","+\t\t_, err := kvc.Put(t.Context(), &pb.PutRequest{","+\t\t\tKey:   []byte(fmt.Sprintf(\"stream-%04d\", i)),","+\t\t\tValue: value,","+\t\t})","+\t\trequire.NoError(t, err)","+\t}","+","+\tstream, err := kvc.RangeStream(t.Context(), &pb.RangeRequest{","+\t\tKey:      []byte(\"stream-\"),","+\t\tRangeEnd: []byte(\"stream.\"),","+\t})","+\trequire.NoError(t, err)","+","+\treceived := 0","+\tfor received < 10 {","+\t\tchunk, rerr := stream.Recv()","+\t\tif errors.Is(rerr, io.EOF) {","+\t\t\tt.Fatalf(\"stream ended before the test could compact; received %d keys\", received)","+\t\t}","+\t\trequire.NoError(t, rerr)","+\t\treceived += len(chunk.GetRangeResponse().GetKvs())","+\t}","+","+\tadvance, err := kvc.Put(t.Context(), &pb.PutRequest{","+\t\tKey:   []byte(\"zz-advance-revision\"),","+\t\tValue: []byte(\"x\"),","+\t})","+\trequire.NoError(t, err)","+","+\t_, err = kvc.Compact(t.Context(), &pb.CompactionRequest{","+\t\tRevision: advance.Header.Revision,","+\t\tPhysical: true,","+\t})","+\trequire.NoError(t, err)","+","+\tfor {","+\t\tchunk, rerr := stream.Recv()","+\t\tif errors.Is(rerr, io.EOF) {","+\t\t\tt.Fatalf(\"expected compacted error after receiving partial keys; received %d keys\", received)","+\t\t}","+","+\t\tif rerr != nil {","+\t\t\trequire.Truef(t, eqErrGRPC(rerr, rpctypes.ErrGRPCCompacted), \"got %v, expected %v\", rerr, rpctypes.ErrGRPCCompacted)","+\t\t\trequire.GreaterOrEqual(t, received, 10)","+\t\t\treturn","+\t\t}","+\t\treceived += len(chunk.GetRangeResponse().GetKvs())","+\t}","+}","+"," // TestTLSGRPCRejectInsecureClient checks that connection is rejected if server is TLS but not client."," func TestTLSGRPCRejectInsecureClient(t *testing.T) {"," \tintegration.BeforeTest(t)",""],"additions":229,"deletions":0,"truncated":false}],"additions":465,"deletions":7,"truncated":false,"file_count":9},"error":null,"fetched_at":"2026-05-20T17:43:34.438548+00:00"}