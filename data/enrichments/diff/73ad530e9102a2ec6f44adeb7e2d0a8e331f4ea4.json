{"id":"73ad530e9102a2ec6f44adeb7e2d0a8e331f4ea4","axis":"silent","repo":"kubernetes/kubernetes","sha":"73ad530e9102a2ec6f44adeb7e2d0a8e331f4ea4","parsed":{"files":[{"path":"pkg/apis/admissionregistration/validation/warnings.go","lines":["@@ -0,0 +1,87 @@","+/*","+Copyright The Kubernetes Authors.","+","+Licensed under the Apache License, Version 2.0 (the \"License\");","+you may not use this file except in compliance with the License.","+You may obtain a copy of the License at","+","+    http://www.apache.org/licenses/LICENSE-2.0","+","+Unless required by applicable law or agreed to in writing, software","+distributed under the License is distributed on an \"AS IS\" BASIS,","+WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.","+See the License for the specific language governing permissions and","+limitations under the License.","+*/","+","+package validation","+","+import (","+\t\"fmt\"","+\t\"slices\"","+","+\t\"k8s.io/apimachinery/pkg/runtime/schema\"","+\t\"k8s.io/apimachinery/pkg/util/sets\"","+\t\"k8s.io/apimachinery/pkg/util/validation/field\"","+\t\"k8s.io/kubernetes/pkg/apis/admissionregistration\"","+)","+","+// WarningsForValidatingWebhookRules returns warnings for rules in a ValidatingWebhookConfiguration","+// that explicitly name a resource in excludedResources (virtual resources that admission webhooks","+// do not intercept). The excluded set is supplied by the caller to avoid depending on server-side","+// packages from here.","+func WarningsForValidatingWebhookRules(webhooks []admissionregistration.ValidatingWebhook, excludedResources []schema.GroupResource) []string {","+\texcluded := sets.New(excludedResources...)","+\twebhooksPath := field.NewPath(\"webhooks\")","+\tvar warnings []string","+\tfor i := range webhooks {","+\t\twarnings = append(warnings, warningsForExcludedRules(webhooksPath.Index(i).Child(\"rules\"), webhooks[i].Rules, excluded)...)","+\t}","+\treturn warnings","+}","+","+// WarningsForMutatingWebhookRules returns warnings for rules in a MutatingWebhookConfiguration","+// that explicitly name a resource in excludedResources.","+func WarningsForMutatingWebhookRules(webhooks []admissionregistration.MutatingWebhook, excludedResources []schema.GroupResource) []string {","+\texcluded := sets.New(excludedResources...)","+\twebhooksPath := field.NewPath(\"webhooks\")","+\tvar warnings []string","+\tfor i := range webhooks {","+\t\twarnings = append(warnings, warningsForExcludedRules(webhooksPath.Index(i).Child(\"rules\"), webhooks[i].Rules, excluded)...)","+\t}","+\treturn warnings","+}","+","+func warningsForExcludedRules(rulesPath *field.Path, rules []admissionregistration.RuleWithOperations, excluded sets.Set[schema.GroupResource]) []string {","+\tvar warnings []string","+\tfor i := range rules {","+\t\tfor _, gr := range excludedResourcesNamedByRule(rules[i].APIGroups, rules[i].Resources, excluded) {","+\t\t\twarnings = append(warnings, fmt.Sprintf(\"%s: %s is excluded from admission webhooks; this rule will have no effect\", rulesPath.Index(i), gr))","+\t\t}","+\t}","+\treturn warnings","+}","+","+// excludedResourcesNamedByRule returns the excluded GroupResources a rule explicitly names.","+// A rule that uses a wildcard (\"*\") in apiGroups or resources is not flagged because its intent","+// toward the excluded resource is ambiguous. apiVersions are not considered because all versions","+// of an excluded resource are excluded.","+func excludedResourcesNamedByRule(apiGroups, resources []string, excluded sets.Set[schema.GroupResource]) []schema.GroupResource {","+\tif slices.Contains(apiGroups, \"*\") || slices.Contains(resources, \"*\") {","+\t\treturn nil","+\t}","+\t// Dedupe with a set so a rule that repeats a group/resource is only reported once,","+\t// preserving the order the rule lists them in.","+\tseen := sets.New[schema.GroupResource]()","+\tvar matched []schema.GroupResource","+\tfor _, group := range apiGroups {","+\t\tfor _, resource := range resources {","+\t\t\tgr := schema.GroupResource{Group: group, Resource: resource}","+\t\t\tif excluded.Has(gr) && !seen.Has(gr) {","+\t\t\t\tseen.Insert(gr)","+\t\t\t\tmatched = append(matched, gr)","+\t\t\t}","+\t\t}","+\t}","+\treturn matched","+}"],"additions":87,"deletions":0,"truncated":false},{"path":"pkg/apis/admissionregistration/validation/warnings_test.go","lines":["@@ -0,0 +1,110 @@","+/*","+Copyright The Kubernetes Authors.","+","+Licensed under the Apache License, Version 2.0 (the \"License\");","+you may not use this file except in compliance with the License.","+You may obtain a copy of the License at","+","+    http://www.apache.org/licenses/LICENSE-2.0","+","+Unless required by applicable law or agreed to in writing, software","+distributed under the License is distributed on an \"AS IS\" BASIS,","+WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.","+See the License for the specific language governing permissions and","+limitations under the License.","+*/","+","+package validation","+","+import (","+\t\"reflect\"","+\t\"testing\"","+","+\t\"k8s.io/apimachinery/pkg/runtime/schema\"","+\t\"k8s.io/kubernetes/pkg/apis/admissionregistration\"","+)","+","+// testExcludedResources is a representative excluded set; the production set is supplied by the","+// caller (see pkg/kubeapiserver/admission/exclusion), so these helpers don't depend on it.","+var testExcludedResources = []schema.GroupResource{","+\t{Group: \"authentication.k8s.io\", Resource: \"tokenreviews\"},","+\t{Group: \"authorization.k8s.io\", Resource: \"subjectaccessreviews\"},","+}","+","+func rule(groups, versions, resources []string) admissionregistration.RuleWithOperations {","+\treturn admissionregistration.RuleWithOperations{","+\t\tRule: admissionregistration.Rule{","+\t\t\tAPIGroups:   groups,","+\t\t\tAPIVersions: versions,","+\t\t\tResources:   resources,","+\t\t},","+\t}","+}","+","+func TestWarningsForWebhookRules(t *testing.T) {","+\ttests := []struct {","+\t\tname     string","+\t\trules    []admissionregistration.RuleWithOperations","+\t\twantWarn []string","+\t}{","+\t\t{","+\t\t\tname:     \"no warnings for normal resources\",","+\t\t\trules:    []admissionregistration.RuleWithOperations{rule([]string{\"\"}, []string{\"v1\"}, []string{\"pods\", \"configmaps\"})},","+\t\t\twantWarn: nil,","+\t\t},","+\t\t{","+\t\t\tname:  \"warning for explicit excluded resource\",","+\t\t\trules: []admissionregistration.RuleWithOperations{rule([]string{\"authentication.k8s.io\"}, []string{\"v1\"}, []string{\"tokenreviews\"})},","+\t\t\twantWarn: []string{","+\t\t\t\t`webhooks[0].rules[0]: tokenreviews.authentication.k8s.io is excluded from admission webhooks; this rule will have no effect`,","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:  \"warning only for the excluded resource in a mixed rule\",","+\t\t\trules: []admissionregistration.RuleWithOperations{rule([]string{\"authorization.k8s.io\"}, []string{\"v1\"}, []string{\"subjectaccessreviews\", \"somethingelse\"})},","+\t\t\twantWarn: []string{","+\t\t\t\t`webhooks[0].rules[0]: subjectaccessreviews.authorization.k8s.io is excluded from admission webhooks; this rule will have no effect`,","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:     \"no warning for all wildcards\",","+\t\t\trules:    []admissionregistration.RuleWithOperations{rule([]string{\"*\"}, []string{\"*\"}, []string{\"*\"})},","+\t\t\twantWarn: nil,","+\t\t},","+\t\t{","+\t\t\tname:     \"no warning for wildcard apiGroups\",","+\t\t\trules:    []admissionregistration.RuleWithOperations{rule([]string{\"*\"}, []string{\"v1\"}, []string{\"tokenreviews\"})},","+\t\t\twantWarn: nil,","+\t\t},","+\t\t{","+\t\t\tname:  \"warning for wildcard apiVersions naming an excluded resource\",","+\t\t\trules: []admissionregistration.RuleWithOperations{rule([]string{\"authentication.k8s.io\"}, []string{\"*\"}, []string{\"tokenreviews\"})},","+\t\t\twantWarn: []string{","+\t\t\t\t`webhooks[0].rules[0]: tokenreviews.authentication.k8s.io is excluded from admission webhooks; this rule will have no effect`,","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:     \"no warning for wildcard resources\",","+\t\t\trules:    []admissionregistration.RuleWithOperations{rule([]string{\"authentication.k8s.io\"}, []string{\"v1\"}, []string{\"*\"})},","+\t\t\twantWarn: nil,","+\t\t},","+\t\t{","+\t\t\tname:     \"no warning for excluded resource in wrong group\",","+\t\t\trules:    []admissionregistration.RuleWithOperations{rule([]string{\"example.com\"}, []string{\"v1\"}, []string{\"tokenreviews\"})},","+\t\t\twantWarn: nil,","+\t\t},","+\t}","+","+\tfor _, tc := range tests {","+\t\tt.Run(tc.name, func(t *testing.T) {","+\t\t\tvalidating := []admissionregistration.ValidatingWebhook{{Name: \"w\", Rules: tc.rules}}","+\t\t\tif got := WarningsForValidatingWebhookRules(validating, testExcludedResources); !reflect.DeepEqual(got, tc.wantWarn) {","+\t\t\t\tt.Errorf(\"WarningsForValidatingWebhookRules() = %v, want %v\", got, tc.wantWarn)","+\t\t\t}","+\t\t\tmutating := []admissionregistration.MutatingWebhook{{Name: \"w\", Rules: tc.rules}}","+\t\t\tif got := WarningsForMutatingWebhookRules(mutating, testExcludedResources); !reflect.DeepEqual(got, tc.wantWarn) {","+\t\t\t\tt.Errorf(\"WarningsForMutatingWebhookRules() = %v, want %v\", got, tc.wantWarn)","+\t\t\t}","+\t\t})","+\t}","+}"],"additions":110,"deletions":0,"truncated":false},{"path":"pkg/registry/admissionregistration/mutatingwebhookconfiguration/strategy.go","lines":["@@ -29,6 +29,7 @@ import ("," \t\"k8s.io/kubernetes/pkg/api/legacyscheme\""," \t\"k8s.io/kubernetes/pkg/apis/admissionregistration\""," \t\"k8s.io/kubernetes/pkg/apis/admissionregistration/validation\"","+\t\"k8s.io/kubernetes/pkg/kubeapiserver/admission/exclusion\""," )"," "," // mutatingWebhookConfigurationStrategy implements verification logic for mutatingWebhookConfiguration.","@@ -54,10 +55,14 @@ func (mutatingWebhookConfigurationStrategy) PrepareForCreate(ctx context.Context"," // WarningsOnCreate returns 