({} as any);","+\t\tvi.mocked(GraphQLService).mockImplementation(() => ({ getSchema: vi.fn().mockResolvedValue(schema) }) as any);","+\t});","+","+\t// The graphql-ws v6 signature is (ctx, id, payload) - the id and payload are separate arguments,","+\t// not a single wrapped SubscribeMessage. Calling with three args guards against regressing it.","+\ttest('accepts a valid subscription operation', async () => {","+\t\tconst result = await onSubscribe(mockContext(), '1', payload({ query: 'subscription { foo }' }));","+","+\t\texpect(Array.isArray(result)).toBe(false);","+\t\texpect(result).toMatchObject({ schema, operationName: undefined, variableValues: undefined });","+\t\texpect(result).toHaveProperty('document');","+\t});","+","+\ttest('passes through variables and operation name from the payload', async () => {","+\t\tconst result = await onSubscribe(","+\t\t\tmockContext(),","+\t\t\t'1',"],"additions":71,"deletions":15,"truncated":false}],"additions":708,"deletions":25,"truncated":true,"file_count":11},"error":null,"fetched_at":"2026-07-02T10:21:19.231555+00:00"}