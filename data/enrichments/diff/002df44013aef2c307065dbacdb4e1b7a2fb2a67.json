GraphQLService {"," \taccountability: Accountability | null;"," \tknex: Knex;","@@ -52,6 +44,8 @@ export class GraphQLService {"," \t}: GraphQLParams): Promise<FormattedExecutionResult> {"," \t\tconst schema = await this.getSchema();"," ","+\t\tconst validationRules = getValidationRules({ operationName });","+"," \t\tconst validationErrors = validate(schema, document, validationRules).map((validationError) =>"," \t\t\taddPathToValidationError(validationError),"," \t\t);"],"additions":4,"deletions":10,"truncated":false},{"path":"api/src/services/graphql/rules/block-field-suggestions.test.ts","lines":["@@ -0,0 +1,59 @@","+import { buildSchema, parse, specifiedRules, validate } from 'graphql';","+import { describe, expect, test } from 'vitest';","+import { BlockFieldSuggestionsRule } from './block-field-suggestions.js';","+","+const schema = buildSchema(/* GraphQL */ `","+\tenum Color {","+\t\tRED","+\t\tGREEN","+\t}","+","+\ttype Query {","+\t\tarticle(color: Color): String","+\t}","+`);","+","+function validateQuery(query: string, withRule: boolean) {","+\tconst rules = withRule ? [...specifiedRules, BlockFieldSuggestionsRule] : [...specifiedRules];","+\treturn validate(schema, parse(query), rules);","+}","+","+describe('BlockFieldSuggestionsRule', () => {","+\ttest('graphql-js leaks field names via suggestions by default', () => {","+\t\t// Sanity check: without the rule, the near-miss field name is leaked back to the client.","+\t\tconst errors = validateQuery('{ artical }', false);","+","+\t\texpect(errors[0]?.message).toContain('Did you mean');","+\t\texpect(errors[0]?.message).toContain('article');","+\t});","+","+\ttest('strips field suggestions from unknown-field errors', () => {","+\t\tconst errors = validateQuery('{ artical }', true);","+","+\t\texpect(errors).toHaveLength(1);","+\t\texpect(errors[0]?.message).not.toContain('Did you mean');","+\t\texpect(errors[0]?.message).not.toContain('article');","+\t\t// The error is still reported, just without the leak.","+\t\texpect(errors[0]?.message).toContain('Cannot query field \"artical\"');","+\t});","+","+\ttest('strips argument suggestions', () => {","+\t\tconst errors = validateQuery('{ article(colr: RED) }', true);","+","+\t\texpect(errors.some((error) => /Did you mean/.test(error.message))).toBe(false);","+\t});","+","+\ttest('strips enum value suggestions', () => {","+\t\tconst errors = validateQuery('{ article(color: REDD) }', true);","+","+\t\texpect(errors.some((error) => /Did you mean/.test(error.message))).toBe(false);","+\t});","+","+\ttest('preserves the error location', () => {","+\t\tconst errors = validateQuery('{ artical }', true);","+","+\t\t// nodes/locations must survive the message rewrite so error paths still point at the field.","+\t\texpect(errors[0]?.nodes?.length).toBeGreaterThan(0);","+\t\texpect(errors[0]?.locations?.length).toBeGreaterThan(0);","+\t});","+});"],"additions":59,"deletions":0,"truncated":false},{"path":"api/src/services/graphql/rules/block-field-suggestions.ts","lines":["@@ -0,0 +1,32 @@","+import type { ASTVisitor, ValidationContext } from 'graphql';","+import { GraphQLError } from 'graphql';","+","+/**","+ * graphql-js appends `Did you mean \"…\"?` hints to validation errors for unknown fields, types,","+ * arguments and enum values. Those hints leak schema details even when introspection is disabled,","+ * allowing a client to reconstruct the schema by probing for near-miss names.","+ */","+const SUGGESTION_REGEX = / ?Did you mean .+$/;","+","+export function BlockFieldSuggestionsRule(context: ValidationContext): ASTVisitor {","+\t// Capture the original reporter before overriding it, so we don't recurse.","+\tconst reportError = context.reportError.bind(context);","+","+\tcontext.reportError = (error: GraphQLError) => {","+\t\tif (SUGGESTION_REGEX.test(error.message)) {","+\t\t\terror = new GraphQLError(error.message.replace(SUGGESTION_REGEX, ''), {","+\t\t\t\tnodes: error.nodes ?? null,","+\t\t\t\tsource: error.source ?? null,","+\t\t\t\tpositions: error.positions ?? null,","+\t\t\t\tpath: error.path ?? null,","+\t\t\t\toriginalError: error.originalError ?? null,","+\t\t\t\textensions: error.extensions,","+\t\t\t});","+\t\t}","+","+\t\treportError(error);","+\t};","+","+\t// No hooks needed, this rule only intercepts errors.","+\treturn {};","+}"],"additions":32,"deletions":0,"truncated":false},{"path":"api/src/services/graphql/rules/get-validation-rules.test.ts","lines":["@@ -0,0 +1,32 @@","+import { useEnv } from '@directus/env';","+import { NoSchemaIntrospectionCustomRule } from 'graphql';","+import { afterEach, beforeEach, describe, expect, test, vi } from 'vitest';","+import { BlockFieldSuggestionsRule, getValidationRules } from './index.js';","+","+vi.mock('@directus/env', () => ({ useEnv: vi.fn() }));","+","+beforeEach(() => {","+\tvi.mocked(useEnv).mockReturnValue({ GRAPHQL_INTROSPECTION: true });","+});","+","+afterEach(() => {","+\tvi.clearAllMocks();","+});","+","+describe('getValidationRules', () => {","+\ttest('omits the introspection rules when introspection is enabled', () => {","+\t\tconst rules = getValidationRules();","+","+\t\texpect(rules).not.toContain(NoSchemaIntrospectionCustomRule);","+\t\texpect(rules).not.toContain(BlockFieldSuggestionsRule);","+\t});","+","+\ttest('adds the introspection rules when introspection is disabled', () => {","+\t\tvi.mocked(useEnv).mockReturnValue({ GRAPHQL_INTROSPECTION: false });","+","+\t\tconst rules = getValidationRules();","+","+\t\texpect(rules).toContain(NoSchemaIntrospectionCustomRule);","+\t\texpect(rules).toContain(BlockFieldSuggestionsRule);","+\t});","+});"],"additions":32,"deletions":0,"truncated":false},{"path":"api/src/services/graphql/rules/get-validation-rules.ts","lines":["@@ -0,0 +1,25 @@","+import { useEnv } from '@directus/env';","+import type { ValidationRule } from 'graphql';","+import { NoSchemaIntrospectionCustomRule, specifiedRules } from 'graphql';","+import { BlockFieldSuggestionsRule } from './block-field-suggestions.js';","+import { limitSensitiveMutations } from './limit-sensitive-mutations.js';","+","+export interface GetValidationRulesOptions {","+\toperationName?: string | null | undefined;","+}","+","+/**","+ * Build the GraphQL validation rules.","+ */","+export function getValidationRules({ operationName }: GetValidationRulesOptions = {}): ValidationRule[] {","+\tconst env = useEnv();","+","+\tconst rules: ValidationRule[] = [...specifiedRules, limitSensitiveMutations(operationName)];","+","+\tif (env['GRAPHQL_INTROSPECTION'] === false) {","+\t\trules.push(NoSchemaIntrospectionCustomRule);","+\t\trules.push(BlockFieldSuggestionsRule);","+\t}","+","+\treturn rules;","+}"],"additions":25,"deletions":0,"truncated":false},{"path":"api/src/services/graphql/rules/index.ts","lines":["@@ -0,0 +1,3 @@","+export { BlockFieldSuggestionsRule } from './block-field-suggestions.js';","+export { assertSensitiveMutationLimit, limitSensitiveMutations } from './limit-sensitive-mutations.js';","+export { getValidationRules, type GetValidationRulesOptions } from './get-validation-rules.js';"],"additions":3,"deletions":0,"truncated":false},{"path":"api/src/services/graphql/rules/limit-sensitive-mutations.test.ts","lines":["@@ -0,0 +1,371 @@","+import { useEnv } from '@directus/env';","+import type { FieldNode, FragmentDefinitionNode, OperationDefinitionNode } from 'graphql';","+import { buildSchema, GraphQLError, Kind, parse, validate } from 'graphql';","+import { beforeEach, describe, expect, test, vi } from 'vitest';","+import { assertSensitiveMutationLimit, limitSensitiveMutations } from './limit-sensitive-mutations.js';","+","+vi.mock('@directus/env', () => ({ useEnv: vi.fn() }));","+","+const DEFAULT_SENSITIVE_MUTATIONS = [","+\t'auth_login',","+\t'auth_refresh',","+\t'auth_password_request',","+\t'auth_password_reset',","+\t'users_register',","+\t'users_register_verify',","+\t'users_invite_accept',","+];","+","+const SENSITIVE_MUTATIONS = new Set(DEFAULT_SENSITIVE_MUTATIONS);","+","+beforeEach(() => {","+\tvi.mocked(useEnv).mockReturnValue({ GRAPHQL_SINGLE_USE_MUTATIONS: DEFAULT_SENSITIVE_MUTATIONS });","+});","+","+const schema = buildSchema(`","+\ttype Query {","+\t\tping: String","+\t}","+","+\ttype AuthTokens {","+\t\taccess_token: String","+\t}","+","+\ttype Mutation {","+\t\tauth_login(email: String!, password: String!): AuthTokens","+\t\tauth_password_request(email: String!): Boolean","+\t\tauth_password_reset(token: String!, password: String!): Boolean","+\t\tusers_register(email: String!, password: String!): Boolean","+\t\tauth_logout: Boolean","+\t}","+`);","+","+function validateQuery(query: string, operationName?: string | null) {","+\treturn validate(schema, parse(query), [limitSensitiveMutations(operationName)]);","+}","+","+/** Parse a document and expose its operation (by name, or the first) plus a fragment lookup. */","+function parseOperation(query: string, operationName?: string) {","+\tconst document = parse(query);","+\tconst fragments = new Map<string, FragmentDefinitionNode>();","+","+\tfor (const definition of document.definitions) {","+\t\tif (definition.kind === Kind.FRAGMENT_DEFINITION) fragments.set(definition.name.value, definition);","+\t}","+","+\tconst operation = document.definitions.find(","+\t\t(definition): definition is OperationDefinitionNode =>","+\t\t\tdefinition.kind === Kind.OPERATION_DEFINITION &&","+\t\t\t(operationName === undefined || definition.name?.value === operationName),","+\t);","+","+\tif (!operation) throw new Error(`No operation${operationName ? ` named ${operationName}` : ''} found`);","+","+\treturn { operation, getFragment: (name: string) => fragments.get(name) };","+}","+","+/** Run `fn` and return the GraphQLError it throws, or `undefined` if it returns normally. */","+function captureError(fn: () => void): GraphQLError | undefined {","+\ttry {","+\t\tfn();","+\t\treturn undefined;","+\t} catch (error) {","+\t\treturn error as GraphQLError;","+\t}","+}","+","+describe('limitSensitiveMutations', () => {","+\ttest('allows a single invocation of a sensitive mutation', () => {","+\t\tconst errors = validateQuery(`mutation { auth_login(email: \"a@b.c\", password: \"x\") { access_token } }`);","+\t\texpect(errors).toHaveLength(0);","+\t});","+","+\ttest('allows distinct sensitive mutations once each', () => {","+\t\tconst errors = validateQuery(`mutation {","+\t\t\tauth_login(email: \"a@b.c\", password: \"x\") { access_token }","+\t\t\tauth_password_request(email: \"a@b.c\")","+\t\t\tusers_register(email: \"a@b.c\", password: \"x\")","+\t\t}`);","+","+\t\texpect(errors).toHaveLength(0);","+\t});","+","+\ttest('rejects aliased duplicate auth_login (account-lockout amplifier)', () => {","+\t\tconst errors = validateQuery(`mutation {","+\t\t\ta: auth_login(email: \"a@b.c\", password: \"1\") { access_token }","+\t\t\tb: auth_login(email: \"a@b.c\", password: \"2\") { access_token }","+\t\t}`);","+","+\t\texpect(errors).toHaveLength(1);","+\t\texpect(errors[0]!.message).toContain('\"auth_login\" can only be used once per request');","+\t});","+","+\ttest('reports a single error and stops early on the first excess invocation', () => {","+\t\tconst aliases = Array.from(","+\t\t\t{ length: 30 },","+\t\t\t(_, i) => `l${i}: auth_login(email: \"a@b.c\", password: \"${i}\") { access_token }`,","+\t\t);","+","+\t\tconst errors = validateQuery(`mutation { ${aliases.join(' ')} }`);","+","+\t\t// The walk short-circuits at the second invocation, so a single error is enough to reject.","+\t\texpect(errors).toHaveLength(1);","+\t\texpect(errors[0]!.message).toContain('\"auth_login\" can only be used once per request');","+\t});","+","+\ttest('rejects aliased duplicate auth_password_request (mail-flood amplifier)', () => {","+\t\tconst errors = validateQuery(`mutation {","+\t\t\tp1: auth_password_request(email: \"victim@b.c\")","+\t\t\tp2: auth_password_request(email: \"victim@b.c\")","+\t\t\tp3: auth_password_request(email: \"other@b.c\")","+\t\t}`);","+","+\t\texpect(errors).toHaveLength(1);","+\t\texpect(errors[0]!.message).toContain('\"auth_password_request\" can only be used once per request');","+\t});","+","+\ttest('ignores non-sensitive mutations invoked repeatedly', () => {","+\t\tconst errors = validateQuery(`mutation {","+\t\t\ta: auth_logout","+\t\t\tb: auth_logout","+\t\t\tc: auth_logout","+\t\t}`);","+","+\t\texpect(errors).toHaveLength(0);","+\t});","+","+\ttest('allows the same sensitive mutation once in each of several named operations', () => {","+\t\t// Only the operation selected via operationName executes, so counting must","+\t\t// not sum invocations across sibling operations.","+\t\tconst errors = validateQuery(`","+\t\t\tmutation Login1 { auth_login(email: \"a@b.c\", password: \"primary\") { access_token } }","+\t\t\tmutation Login2 { auth_login(email: \"a@b.c\", password: \"fallback\") { access_token } }","+\t\t`);","+","+\t\texpect(errors).toHaveLength(0);","+\t});","+","+\ttest('still rejects aliased duplicates within a single named operation', () => {","+\t\tconst errors = validateQuery(`","+\t\t\tmutation Good { auth_login(email: \"a@b.c\", password: \"x\") { access_token } }","+\t\t\tmutation Bad {","+\t\t\t\ta: auth_login(email: \"a@b.c\", password: \"1\") { access_token }","+\t\t\t\tb: auth_login(email: \"a@b.c\", password: \"2\") { access_token }","+\t\t\t}","+\t\t`);","+","+\t\texpect(errors).toHaveLength(1);","+\t\texpect(errors[0]!.message).toContain('\"auth_login\" can only be used once per request');","+\t});","+","+\ttest('only validates the operation selected by operationName', () => {","+\t\tconst query = `","+\t\t\tmutation Safe { auth_login(email: \"a@b.c\", password: \"x\") { access_token } }","+\t\t\tmutation Amplify {","+\t\t\t\ta: auth_login(email: \"a@b.c\", password: \"1\") { access_token }","+\t\t\t\tb: auth_login(email: \"a@b.c\", password: \"2\") { access_token }","+\t\t\t}","+\t\t`;","+","+\t\t// Executing the safe operation passes, even though a sibling operation is over the limit.","+\t\texpect(validateQuery(query, 'Safe')).toHaveLength(0);","+","+\t\t// Executing the offending operation is still rejected.","+\t\tconst errors = validateQuery(query, 'Amplify');","+\t\texpect(errors).toHaveLength(1);","+\t\texpect(errors[0]!.message).toContain('\"auth_login\" can only be used once per request');","+\t});","+","+\ttest('skips anonymous operations when an operationName is supplied', () => {","+\t\tconst errors = validateQuery(","+\t\t\t`mutation {","+\t\t\t\ta: auth_login(email: \"a@b.c\", password: \"1\") { access_token }","+\t\t\t\tb: auth_login(email: \"a@b.c\", password: \"2\") { access_token }","+\t\t\t}`,","+\t\t\t'Named',","+\t\t);","+","+\t\texpect(errors).toHaveLength(0);","+\t});","+","+\ttest('counts a fragment spread more than once in the same operation', () => {","+\t\tconst errors = validateQuery(`","+\t\t\tmutation { ...Once ...Once }","+\t\t\tfragment Once on Mutation {","+\t\t\t\tauth_login(email: \"a@b.c\", password: \"1\") { access_token }","+\t\t\t}","+\t\t`);","+","+\t\texpect(errors).toHaveLength(1);","+\t\texpect(errors[0]!.message).toContain('\"auth_login\" can only be used once per request');","+\t});","+","+\ttest('does not count fragments that are only spread in a sibling operation', () => {","+\t\tconst errors = validateQuery(`","+\t\t\tmutation A { ...F }","+\t\t\tmutation B { ...F }","+\t\t\tfragment F on Mutation {","+\t\t\t\tauth_login(email: \"a@b.c\", password: \"x\") { access_token }","+\t\t\t}","+\t\t`);","+","+\t\texpect(errors).toHaveLength(0);","+\t});","+","+\ttest('counts sensitive fields smuggled through a mutation-typed fragment', () => {","+\t\tconst errors = validateQuery(`","+\t\t\tmutation { ...Amplify }","+\t\t\tfragment Amplify on Mutation {","+\t\t\t\ta: auth_login(email: \"a@b.c\", password: \"1\") { access_token }","+\t\t\t\tb: auth_login(email: \"a@b.c\", password: \"2\") { access_token }","+\t\t\t}","+\t\t`);","+","+\t\texpect(errors).toHaveLength(1);","+\t\texpect(errors[0]!.message).toContain('\"auth_login\" can only be used once per request');","+\t});","+","+\ttest('guards only the mutations configured via GRAPHQL_SINGLE_USE_MUTATIONS', () => {","+\t\tvi.mocked(useEnv).mockReturnValue({ GRAPHQL_SINGLE_USE_MUTATIONS: ['users_register'] });","+","+\t\t// auth_login is no longer in the configured set, so aliased duplicates are allowed.","+\t\texpect(","+\t\t\tvalidateQuery(`mutation {","+\t\t\t\ta: auth_login(email: \"a@b.c\", password: \"1\") { access_token }","+\t\t\t\tb: auth_login(email: \"a@b.c\", password: \"2\") { access_token }","+\t\t\t}`),","+\t\t).toHaveLength(0);","+","+\t\t// users_register is now guarded, so its duplicates are rejected.","+\t\tconst errors = validateQuery(`mutation {","+\t\t\ta: users_register(email: \"a@b.c\", password: \"1\")","+\t\t\tb: users_register(email: \"a@b.c\", password: \"2\")","+\t\t}`);","+","+\t\texpect(errors).toHaveLength(1);","+\t\texpect(errors[0]!.message).toContain('\"users_register\" can only be used once per request');","+\t});","+});","+","+describe('assertSensitiveMutationLimit', () => {","+\ttest('does not throw when every sensitive mutation stays within the limit', () => {","+\t\tconst { operation, getFragment } = parseOperation(`mutation {","+\t\t\tauth_login(email: \"a@b.c\", password: \"1\") { access_token }","+\t\t\tauth_password_request(email: \"a@b.c\")","+\t\t}`);","+","+\t\texpect(() => assertSensitiveMutationLimit(operation, getFragment, SENSITIVE_MUTATIONS)).not.toThrow();","+\t});","+","+\ttest('throws on the first invocation that exceeds the limit', () => {","+\t\tconst { operation, getFragment } = parseOperation(`mutation {","+\t\t\ta: auth_login(email: \"a@b.c\", password: \"1\") { access_token }","+\t\t\tb: auth_login(email: \"a@b.c\", password: \"2\") { access_token }","+\t\t\tc: auth_login(email: \"a@b.c\", password: \"3\") { access_token }","+\t\t}`);","+","+\t\tconst error = captureError(() => assertSensitiveMutationLimit(operation, getFragment, SENSITIVE_MUTATIONS));","+","+\t\texpect(error).toBeInstanceOf(GraphQLError);","+\t\texpect(error?.message).toContain('\"auth_login\" can only be used once per request');","+\t\texpect((error?.nodes?.[0] as FieldNode | undefined)?.alias?.value).toBe('b');","+\t});","+","+\ttest('stops walking once the limit is exceeded', () => {","+\t\tconst { operation, getFragment } = parseOperation(`","+\t\t\tmutation { ...A ...B }","+\t\t\tfragment A on Mutation {","+\t\t\t\ta: auth_login(email: \"a@b.c\", password: \"1\") { access_token }","+\t\t\t\tb: auth_login(email: \"a@b.c\", password: \"2\") { access_token }","+\t\t\t}","+\t\t\tfragment B on Mutation { auth_password_request(email: \"a@b.c\") }","+\t\t`);","+","+\t\tconst seen: string[] = [];","+","+\t\tcaptureError(() =>","+\t\t\tassertSensitiveMutationLimit(","+\t\t\t\toperation,","+\t\t\t\t(name: string) => {","+\t\t\t\t\tseen.push(name);","+\t\t\t\t\treturn getFragment(name);","+\t\t\t\t},","+\t\t\t\tSENSITIVE_MUTATIONS,","+\t\t\t),","+\t\t);","+","+\t\t// Fragment A trips the limit, so the sibling spread B is never resolved.","+\t\texpect(seen).toEqual(['A']);","+\t});","+","+\ttest('ignores non-sensitive fields entirely', () => {","+\t\tconst { operation, getFragment } = parseOperation(`mutation {","+\t\t\ta: auth_logout","+\t\t\tb: auth_logout","+\t\t}`);","+","+\t\texpect(() => assertSensitiveMutationLimit(operation, getFragment, SENSITIVE_MUTATIONS)).not.toThrow();","+\t});","+","+\ttest('flags the same fragment spread more than once', () => {","+\t\tconst { operation, getFragment } = parseOperation(`","+\t\t\tmutation { ...Once ...Once }","+\t\t\tfragment Once on Mutation { auth_login(email: \"a@b.c\", password: \"1\") { access_token } }","+\t\t`);","+","+\t\tconst error = captureError(() => assertSensitiveMutationLimit(operation, getFragment, SENSITIVE_MUTATIONS));","+","+\t\texpect(error?.message).toContain('\"auth_login\" can only be used once per request');","+\t});","+","+\ttest('resolves inline fragments', () => {","+\t\tconst { operation, getFragment } = parseOperation(`mutation {","+\t\t\t... on Mutation {","+\t\t\t\ta: auth_login(email: \"a@b.c\", password: \"1\") { access_token }","+\t\t\t\tb: auth_login(email: \"a@b.c\", password: \"2\") { access_token }","+\t\t\t}","+\t\t}`);","+","+\t\tconst error = captureError(() => assertSensitiveMutationLimit(operation, getFragment, SENSITIVE_MUTATIONS));","+","+\t\texpect(error?.message).toContain('\"auth_login\" can only be used once per request');","+\t});","+","+\ttest('scopes counting to the given operation', () => {","+\t\tconst query = `","+\t\t\tmutation Login1 { auth_login(email: \"a@b.c\", password: \"primary\") { access_token } }","+\t\t\tmutation Login2 { auth_login(email: \"a@b.c\", password: \"fallback\") { access_token } }","+\t\t`;","+","+\t\tfor (const name of ['Login1', 'Login2']) {","+\t\t\tconst { operation, getFragment } = parseOperation(query, name);","+\t\t\texpect(() => assertSensitiveMutationLimit(operation, getFragment, SENSITIVE_MUTATIONS)).not.toThrow();","+\t\t}","+\t});","+","+\ttest('terminates on a fragment cycle within the limit', () => {","+\t\tconst { operation, getFragment } = parseOperation(`","+\t\t\tmutation { ...A }","+\t\t\tfragment A on Mutation { auth_login(email: \"a@b.c\", password: \"1\") { access_token } ...B }","+\t\t\tfragment B on Mutation { auth_password_request(email: \"a@b.c\") ...A }","+\t\t`);","+","+\t\texpect(() => assertSensitiveMutationLimit(operation, getFragment, SENSITIVE_MUTATIONS)).not.toThrow();","+\t});","+","+\ttest('ignores unresolvable fragment spreads', () => {","+\t\tconst { operation, getFragment } = parseOperation(`mutation { ...Missing }`);","+","+\t\texpect(() => assertSensitiveMutationLimit(operation, getFragment, SENSITIVE_MUTATIONS)).not.toThrow();","+\t});","+","+\ttest('only guards the field names in the provided set', () => {","+\t\tconst { operation, getFragment } = parseOperation(`mutation {","+\t\t\ta: auth_login(email: \"a@b.c\", password: \"1\") { access_token }","+\t\t\tb: auth_login(email: \"a@b.c\", password: \"2\") { access_token }","+\t\t}`);","+","+\t\t// auth_login is not in this custom set, so the duplicates are allowed.","+\t\texpect(() => assertSensitiveMutationLimit(operation, getFragment, new Set(['users_register']))).not.toThrow();","+\t});","+});"],"additions":371,"deletions":0,"truncated":false},{"path":"api/src/services/graphql/rules/limit-sensitive-mutations.ts","lines":["@@ -0,0 +1,100 @@","+import { useEnv } from '@directus/env';","+import type {","+\tFieldNode,","+\tFragmentDefinitionNode,","+\tOperationDefinitionNode,","+\tSelectionSetNode,","+\tValidationRule,","+} from 'graphql';","+import { GraphQLError, Kind } from 'graphql';","+","+const MAX_INVOCATIONS_PER_OPERATION = 1;","+","+export interface SensitiveMutationLimitError {","+\tfieldName: string;","+\tnode: FieldNode;","+}","+","+/**","+ * Walk a mutation operation's selection set, resolving fragment spreads and","+ * inline fragments, and return the first invocation of a `sensitiveMutations`","+ * field whose running per-operation count exceeds `MAX_INVOCATIONS_PER_OPERATION`,","+ * or `undefined` if every sensitive mutation stays within the limit.","+ *","+ * `sensitiveMutations` is the configured set of guarded field names (see","+ * `GRAPHQL_SINGLE_USE_MUTATIONS`).","+ */","+export function assertSensitiveMutationLimit(","+\toperation: OperationDefinitionNode,","+\tgetFragment: (name: string) => FragmentDefinitionNode | null | undefined,","+\tsensitiveMutations: ReadonlySet<string>,","+): void {","+\tconst counts = new Map<string, number>();","+","+\tconst walk = (selectionSet: SelectionSetNode, visiting: Set<string>): void => {","+\t\tfor (const selection of selectionSet.selections) {","+\t\t\tif (selection.kind === Kind.FIELD) {","+\t\t\t\tconst fieldName = selection.name.value;","+\t\t\t\tif (!sensitiveMutations.has(fieldName)) continue;","+","+\t\t\t\tconst count = (counts.get(fieldName) ?? 0) + 1;","+\t\t\t\tcounts.set(fieldName, count);","+","+\t\t\t\tif (count > MAX_INVOCATIONS_PER_OPERATION) {","+\t\t\t\t\tthrow new GraphQLError(`\"${fieldName}\" can only be used once per request`, { nodes: selection });","+\t\t\t\t}","+\t\t\t} else if (selection.kind === Kind.INLINE_FRAGMENT) {","+\t\t\t\twalk(selection.selectionSet, visiting);","+\t\t\t} else if (selection.kind === Kind.FRAGMENT_SPREAD) {","+\t\t\t\tconst name = selection.name.value;","+\t\t\t\tif (visiting.has(name)) continue;","+","+\t\t\t\tconst fragment = getFragment(name);","+\t\t\t\tif (!fragment) continue;","+","+\t\t\t\tvisiting.add(name);","+\t\t\t\twalk(fragment.selectionSet, visiting);","+\t\t\t\tvisiting.delete(name);","+\t\t\t}","+\t\t}","+\t};","+","+\twalk(operation.selectionSet, new Set());","+}","+","+/**","+ * GraphQL validation rule that rejects operations invoking any mutation listed in","+ * `GRAPHQL_SINGLE_USE_MUTATIONS` more than `MAX_INVOCATIONS_PER_OPERATION` times","+ * (aliases included). These are system mutations that perform expensive or","+ * sensitive side effects (account lockout counters, outbound email, user","+ * creation) and are reachable anonymously.","+ */","+export function limitSensitiveMutations(operationName?: string | null): ValidationRule {","+\tconst env = useEnv();","+\tconst sensitiveMutations = new Set(env['GRAPHQL_SINGLE_USE_MUTATIONS'] as string[]);","+","+\treturn (context) => {","+\t\tconst mutationType = context.getSchema().getMutationType();","+","+\t\treturn {","+\t\t\tOperationDefinition(operation): void {","+\t\t\t\tif (!mutationType || operation.operation !== 'mutation') return;","+","+\t\t\t\t// Only validate the operation that will be executed.","+\t\t\t\tif (operationName != null && operation.name?.value !== operationName) return;","+","+\t\t\t\ttry {","+\t\t\t\t\tassertSensitiveMutationLimit(operation, (name) => context.getFragment(name), sensitiveMutations);","+\t\t\t\t} catch (error) {","+\t\t\t\t\tif (error instanceof GraphQLError) {","+\t\t\t\t\t\tcontext.reportError(error);","+\t\t\t\t\t} else if (error instanceof Error) {","+\t\t\t\t\t\tcontext.reportError(new GraphQLError(error.message));","+\t\t\t\t\t} else {","+\t\t\t\t\t\tthrow error;","+\t\t\t\t\t}","+\t\t\t\t}","+\t\t\t},","+\t\t};","+\t};","+}"],"additions":100,"deletions":0,"truncated":false},{"path":"api/src/websocket/controllers/graphql.test.ts","lines":["@@ -1,17 +1,17 @@"," import type { Server as httpServer } from 'http';"," import type { IncomingMessage } from 'http';"," import type internal from 'stream';","+import { useEnv } from '@directus/env';","+import { buildSchema, GraphQLError, NoSchemaIntrospectionCustomRule, validate } from 'graphql';","+import type { Context, SubscribePayload } from 'graphql-ws';"," import { afterEach, beforeEach, describe, expect, test, vi } from 'vitest';","-import type { UpgradeContext } from '../types.js';","-","-vi.mock('@directus/env', () => ({","-\tuseEnv: vi.fn().mockReturnValue({","-\t\tWEBSOCKETS_GRAPHQL_PATH: '/graphql',","-\t\tWEBSOCKETS_GRAPHQL_AUTH: 'handshake',","-\t\tWEBSOCKETS_GRAPHQL_AUTH_TIMEOUT: 10,","-\t\tRATE_LIMITER_ENABLED: false,","-\t}),","-}));","+import { GraphQLService } from '../../services/index.js';","+import { getSchema } from '../../utils/get-schema.js';","+import type { ConnectionParams } from '../messages.js';","+import type { GraphQLSocket, UpgradeContext } from '../types.js';","+import { GraphQLSubscriptionController, onSubscribe } from './graphql.js';","+","+vi.mock('@directus/env', () => ({ useEnv: vi.fn().mockReturnValue({}) }));"," "," vi.mock('graphql-ws', async (importOriginal) => {"," \tconst actual = await importOriginal<typeof import('graphql-ws')>();","@@ -21,19 +21,155 @@ vi.mock('graphql-ws', async (importOriginal) => {"," \t};"," });"," ","-vi.mock('../../services/index.js', () => ({ GraphQLService: vi.fn() }));","-vi.mock('../../services/graphql/subscription.js', () => ({ bindPubSub: vi.fn() }));","+// Partially mock `graphql` so we keep the real parse/validate behaviour while being