| prev != it.Content {","+\t\t\ttoEmbed = append(toEmbed, it)"," \t\t}","+\t}","+","+\textracted, embedded, deleted := len(desired), len(toEmbed), len(stored)-len(present)","+\tspan.SetAttributes(","+\t\tattribute.Int(\"subresources.extracted\", extracted),","+\t\tattribute.Int(\"subresources.embedded\", embedded),","+\t\tattribute.Int(\"subresources.deleted\", deleted),","+\t)","+\trecordCounts := func() {","+\t\tif s.metrics == nil {","+\t\t\treturn","+\t\t}","+\t\ts.metrics.ReconcilerSubresourcesExtractedTotal.WithLabelValues(ev.group, ev.resource).Add(float64(extracted))","+\t\ts.metrics.ReconcilerSubresourcesEmbeddedTotal.WithLabelValues(ev.group, ev.resource).Add(float64(embedded))","+\t\ts.metrics.ReconcilerSubresourcesDeletedTotal.WithLabelValues(ev.group, ev.resource).Add(float64(deleted))","+\t}","+","+\tif embedded == 0 && deleted == 0 {","+\t\trecordCounts()"," \t\treturn nil"," \t}"," ","+\tvar changed []vector.Vector","+\tif len(toEmbed) > 0 {","+\t\tchanged, err = s.batchEmbedder.Embed(ctx, ev.namespace, builder.Resource(), ev.rv, toEmbed)","+\t\tif err != nil {","+\t\t\tstatusLabel = \"embed_error\"","+\t\t\treturn fmt.Errorf(\"embed: %w\", err)","+\t\t}","+\t}","+"," \t// UpsertReplaceSubresources commits the stale-delete and the new"," \t// inserts atomically — a failure mid-way leaves the dashboard in"," \t// its previous self-consistent state.","-\tif err := s.vectorBackend.UpsertReplaceSubresources(ctx, vectors); err != nil {","+\tif err := s.vectorBackend.UpsertReplaceSubresources(ctx, ev.namespace, model, builder.Resource(), uid, changed, desired); err != nil {"," \t\tstatusLabel = \"upsert_error\""," \t\treturn fmt.Errorf(\"upsert: %w\", err)"," \t}","+\trecordCounts()"," \treturn nil"," }"," "],"additions":56,"deletions":12,"truncated":false},{"path":"pkg/storage/unified/search/embed/reconciler/reconciler_test.go","lines":["@@ -251,6 +251,156 @@ func TestReconciler_StaleSubresources_AreDeletedBeforeUpsert(t *testing.T) {"," \trequire.Len(t, vec.upserts, 1)"," }"," ","+// threePanelDashboard builds a 3-panel dashboard with distinct per-panel content.","+func threePanelDashboard(panel2Title string) []byte {","+\tbody, _ := json.Marshal(map[string]any{","+\t\t\"uid\": \"dash-1\", \"title\": \"Dash\",","+\t\t\"panels\": []any{","+\t\t\tmap[string]any{\"id\": 1, \"title\": \"CPU\", \"description\": \"cpu\"},","+\t\t\tmap[string]any{\"id\": 2, \"title\": panel2Title, \"description\": \"mem\"},","+\t\t\tmap[string]any{\"id\": 3, \"title\": \"Disk\", \"description\": \"disk\"},","+\t\t},","+\t})","+\treturn body","+}","+","+// Re-processing with one panel changed re-embeds only that panel.","+func TestReconciler_PartialReembed_OnlyChangedPanel(t *testing.T) {","+\tvec := newFakeVector()","+\ts, text := newReconciler(t, &fakeStorage{}, vec)","+","+\ts.enqueue(dashEvent(resourcepb.WatchEvent_ADDED, \"ns\", \"dash-1\", 100, threePanelDashboard(\"Mem\")))","+\ts.processPending(context.Background())","+\trequire.Len(t, vec.upserts, 1)","+\trequire.Len(t, vec.upserts[0], 3, \"first write embeds all three panels\")","+\trequire.Equal(t, 1, text.calls)","+","+\t// Only panel/2's title changes.","+\ts.enqueue(dashEvent(resourcepb.WatchEvent_MODIFIED, \"ns\", \"dash-1\", 200, threePanelDashboard(\"Memory\")))","+\ts.processPending(context.Background())","+","+\trequire.Len(t, vec.upserts, 2, \"second write happened\")","+\trequire.Len(t, vec.upserts[1], 1, \"only the changed panel is re-embedded\")","+\tassert.Equal(t, \"panel/2\", vec.upserts[1][0].Subresource)","+\tassert.Equal(t, 2, text.calls)","+\tassert.Equal(t, []int{1}, text.textSets[1], \"embedder called with exactly one text\")","+\tassert.Empty(t, vec.delsubs, \"nothing deleted; every panel is still desired\")","+\tassert.Equal(t, int64(200), vec.latestRV)","+}","+","+// Re-processing identical content writes nothing but still advances the checkpoint.","+func TestReconciler_PartialReembed_NoChangeSkipsWrite(t *testing.T) {","+\tvec := newFakeVector()","+\ts, text := newReconciler(t, &fakeStorage{}, vec)","+","+\ts.enqueue(dashEvent(resourcepb.WatchEvent_ADDED, \"ns\", \"dash-1\", 100, minimalDashboard(\"dash-1\", \"Dash 1\")))","+\ts.processPending(context.Background())","+\trequire.Len(t, vec.upserts, 1)","+\trequire.Equal(t, 1, text.calls)","+","+\t// Re-process byte-identical content at a higher RV.","+\ts.enqueue(dashEvent(resourcepb.WatchEvent_MODIFIED, \"ns\", \"dash-1\", 200, minimalDashboard(\"dash-1\", \"Dash 1\")))","+\ts.processPending(context.Background())","+","+\trequire.Len(t, vec.upserts, 1, \"no re-embed when content is unchanged\")","+\tassert.Equal(t, 1, text.calls, \"embedder not called again\")","+\tassert.Empty(t, vec.delsubs, \"nothing deleted\")","+\tassert.Equal(t, int64(200), vec.latestRV, \"cursor still advances on a no-op write\")","+}","+","+// dashboardInFolder sets the folder UID via the grafana.app/folder annotation.","+func dashboardInFolder(uid, title, folderUID string) []byte {","+\tbody, _ := json.Marshal(map[string]any{","+\t\t\"uid\": uid, \"title\": title,","+\t\t\"metadata\": map[string]any{","+\t\t\t\"annotations\": map[string]any{\"grafana.app/folder\": folderUID},","+\t\t},","+\t\t\"panels\": []any{","+\t\t\tmap[string]any{\"id\": 1, \"title\": \"CPU\", \"description\": \"CPU usage\"},","+\t\t},","+\t})","+\treturn body","+}","+","+// A folder move doesn't change content but must refresh the authz","+// folder, so it forces a re-embed.","+func TestReconciler_PartialReembed_FolderMoveReembeds(t *testing.T) {","+\tvec := newFakeVector()","+\ts, text := newReconciler(t, &fakeStorage{}, vec)","+","+\ts.enqueue(dashEvent(resourcepb.WatchEvent_ADDED, \"ns\", \"dash-1\", 100, dashboardInFolder(\"dash-1\", \"Dash\", \"folder-a\")))","+\ts.processPending(context.Background())","+\trequire.Len(t, vec.upserts, 1)","+\trequire.Equal(t, \"folder-a\", vec.upserts[0][0].Folder)","+\trequire.Equal(t, 1, text.calls)","+","+\t// Move to folder-b; panel content is identical.","+\ts.enqueue(dashEv