intValidator;","+import jakarta.validation.ConstraintValidatorContext;","+","+import org.hibernate.validator.constraints.py.RUC;","+","+/**","+ * Validator for {@link RUC}.","+ */","+public class RUCValidator implements ConstraintValidator<RUC, CharSequence> {","+","+\tprivate static final Pattern UNFORMATTED_PATTERN = Pattern.compile( \"[0-9A-Za-z]+[0-9]\" );","+\tprivate static final Pattern FORMATTED_PATTERN = Pattern.compile( \"[0-9A-Za-z]+-[0-9]\" );","+\tprivate static final int BASE_MAX = 11;","+","+\t@Override","+\tpublic boolean isValid(CharSequence value, ConstraintValidatorContext context) {","+\t\tif ( value == null ) {","+\t\t\treturn true;","+\t\t}","+","+\t\tString ruc = value.toString();","+\t\tString number;","+\t\tchar checkDigit;","+\t\tif ( FORMATTED_PATTERN.matcher( ruc ).matches() ) {","+\t\t\tint separatorIndex = ruc.length() - 2;","+\t\t\tnumber = ruc.substring( 0, separatorIndex );","+\t\t\tcheckDigit = ruc.charAt( ruc.length() - 1 );","+\t\t}","+\t\telse if ( UNFORMATTED_PATTERN.matcher( ruc ).matches() ) {","+\t\t\tnumber = ruc.substring( 0, ruc.length() - 1 );","+\t\t\tcheckDigit = ruc.charAt( ruc.length() - 1 );","+\t\t}","+\t\telse {","+\t\t\treturn false;","+\t\t}","+","+\t\tint calculatedCheckDigit = calculateCheckDigit( number );","+\t\treturn calculatedCheckDigit == Character.digit( checkDigit, 10 );","+\t}","+","+\tprivate int calculateCheckDigit(String number) {","+\t\tString normalizedNumber = replaceLettersWithAscii( number );","+","+\t\tint total = 0;","+\t\tint multiplier = 2;","+\t\tfor ( int i = normalizedNumber.length() - 1; i >= 0; i-- ) {","+\t\t\tif ( multiplier > BASE_MAX ) {","+\t\t\t\tmultiplier = 2;","+\t\t\t}","+\t\t\ttotal += Character.digit( normalizedNumber.charAt( i ), 10 ) * multiplier;","+\t\t\tmultiplier++;","+\t\t}","+","+\t\tint remainder = total % 11;","+\t\tif ( remainder > 1 ) {","+\t\t\treturn 11 - remainder;","+\t\t}","+\t\treturn 0;","+\t}","+","+\tprivate String replaceLettersWithAscii(String number)