,"-func (s shareBackend) DeleteWithPathPrefix(pathPrefix string) error {","+func (s shareBackend) DeleteWithPathPrefix(pathPrefix string, userID uint) error {"," \tvar links []share.Link"," \tif err := s.db.Prefix(\"Path\", pathPrefix, &links); err != nil {","+\t\tif errors.Is(err, storm.ErrNotFound) {","+\t\t\treturn nil","+\t\t}"," \t\treturn err"," \t}"," ","+\tprefix := strings.TrimRight(pathPrefix, \"/\")","+"," \tvar err error"," \tfor _, link := range links {","+\t\tif link.UserID != userID {","+\t\t\tcontinue","+\t\t}","+","+\t\tif link.Path != prefix && !strings.HasPrefix(link.Path, prefix+\"/\") {","+\t\t\tcontinue","+\t\t}","+"," \t\terr = errors.Join(err, s.db.DeleteStruct(&share.Link{Hash: link.Hash}))"," \t}"," \treturn err"],"additions":15,"deletions":1,"truncated":false},{"path":"storage/bolt/share_test.go","lines":["@@ -0,0 +1,97 @@","+package bolt","+","+import (","+\t\"os\"","+\t\"sort\"","+\t\"testing\"","+","+\t\"github.com/asdine/storm/v3\"","+","+\t\"github.com/filebrowser/filebrowser/v2/share\"","+)","+","+func newTestShareBackend(t *testing.T) shareBackend {","+\tt.Helper()","+","+\tf, err := os.CreateTemp(t.TempDir(), \"shares-*.db\")","+\tif err != nil {","+\t\tt.Fatalf(\"failed to create temp db: %v\", err)","+\t}","+\t_ = f.Close()","+","+\tdb, err := storm.Open(f.Name())","+\tif err != nil {","+\t\tt.Fatalf(\"failed to open db: %v\", err)","+\t}","+\tt.Cleanup(func() { _ = db.Close() })","+","+\treturn shareBackend{db: db}","+}","+","+func remainingHashes(t *testing.T, s shareBackend) []string {","+\tt.Helper()","+","+\tlinks, err := s.All()","+\tif err != nil {","+\t\tt.Fatalf(\"All returned error: %v\", err)","+\t}","+","+\thashes := make([]string, 0, len(links))","+\tfor _, link := range links {","+\t\thashes = append(hashes, link.Hash)","+\t}","+\tsort.Strings(hashes)","+\treturn hashes","+}","+","+func TestDeleteWithPathPrefix(t *testing.T) {","+\tt.Parallel()","+","+\ts := newTestShareBackend(t)","+","+\tlinks := []*share.Link{","+\t\t// user 1's links","+\t\t{Hash: \"u1-a\", Path: \"/a\", UserID: 1},","+\t\t{Hash: \"u1-a-child\", Path: \"/a/child.txt\", UserID: 1},","+\t\t{Hash: \"u1-abc\", Path: \"/abc\", UserID: 1}, // not a descendant of /a","+\t\t{Hash: \"u1-other\", Path: \"/other\", UserID: 1},","+\t\t// user 2's links — must never be touched when user 1 deletes","+\t\t{Hash: \"u2-a\", Path: \"/a\", UserID: 2},","+\t\t{Hash: \"u2-a-child\", Path: \"/a/child.txt\", UserID: 2},","+\t}","+\tfor _, l := range links {","+\t\tif err := s.Save(l); err != nil {","+\t\t\tt.Fatalf(\"failed to save link %s: %v\", l.Hash, err)","+\t\t}","+\t}","+","+\t// User 1 deletes their directory /a. Only user 1's /a and its descendants","+\t// should be removed; /abc (sibling sharing a byte prefix) and all of user","+\t// 2's links must remain.","+\tif err := s.DeleteWithPathPrefix(\"/a\", 1); err != nil {","+\t\tt.Fatalf(\"DeleteWithPathPrefix returned error: %v\", err)","+\t}","+","+\tgot := remainingHashes(t, s)","+\twant := []string{\"u1-abc\", \"u1-other\", \"u2-a\", \"u2-a-child\"}","+\tif len(got) != len(want) {","+\t\tt.Fatalf(\"remaining hashes = %v, want %v\", got, want)","+\t}","+\tfor i := range want {","+\t\tif got[i] != want[i] {","+\t\t\tt.Fatalf(\"remaining hashes = %v, want %v\", got, want)","+\t\t}","+\t}","+}","+","+func TestDeleteWithPathPrefixNoMatch(t *testing.T) {","+\tt.Parallel()","+","+\ts := newTestShareBackend(t)","+","+\t// No links exist at all: the storm Prefix query returns ErrNotFound, which","+\t// must be treated as a no-op rather than surfaced as an error.","+\tif err := s.DeleteWithPathPrefix(\"/a\", 1); err != nil {","+\t\tt.Fatalf(\"DeleteWithPathPrefix on empty store returned error: %v\", err)","+\t}","+}",""],"additions":97,"deletions":0,"truncated":false}],"additions":117,"deletions":6,"truncated":false,"file_count":5},"error":null,"fetched_at":"2026-06-13T10:21:20.555487+00:00"}