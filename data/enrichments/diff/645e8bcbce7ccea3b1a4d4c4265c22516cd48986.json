->clonesIndex = ++$this->clonesCount;","     }"," ","+    /**","+     * Sets CSP nonces to apply to every {@see HtmlDumper} this collector creates.","+     *","+     * If $styleNonce is omitted, $scriptNonce is reused for both <script> and","+     * <style> tags emitted by the dumper.","+     */","+    public function setNonce(?string $scriptNonce, ?string $styleNonce = null): void","+    {","+        $this->scriptNonce = $scriptNonce;","+        $this->styleNonce = $styleNonce;","+    }","+","     public function dump(Data $data): ?string","     {","         $this->stopwatch?->start('dump');","@@ -121,6 +135,7 @@ public function collect(Request $request, Response $response, ?\\Throwable $excep","         ) {","             if ($response->headers->has('Content-Type') && str_contains($response->headers->get('Content-Type') ?? '', 'html')) {","                 $dumper = new HtmlDumper('php://output', $this->charset);","+                $this->applyNonceTo($dumper);","             } else {","                 $dumper = new CliDumper('php://output', $this->charset);","             }","@@ -133,6 +148,13 @@ public function collect(Request $request, Response $response, ?\\Throwable $excep","         }","     }"," ","+    private function applyNonceTo(HtmlDumper $dumper): void","+    {","+        if (null !== $this->scriptNonce || null !== $this->styleNonce) {","+            $dumper->setNonce($this->scriptNonce, $this->styleNonce);","+        }","+    }","+","     public function reset(): void","     {","         $this->stopwatch?->reset();","@@ -188,6 +210,7 @@ public function getDumps(string $format, int $maxDepthLimit = -1, int $maxItemsP","         if ('html' === $format) {","             $dumper = new HtmlDumper($data, $this->charset);","             $dumper->setDisplayOptions(['fileLinkFormat' => $this->fileLinkFormat]);","+            $this->applyNonceTo($dumper);","         } else {","             throw new \\InvalidArgumentException(\\sprintf('Invalid dump format: \