 from trace to warn log levels","+\t\t// Warn makes a pretty noticeable change","+\t\t{","+\t\t\trespW := httptest.NewRecorder()","+\t\t\ttoken := mock.CreatePolicyAndToken(t, state, 1007, \"valid\", mock.AgentPolicy(acl.PolicyWrite))","+\t\t\tsetToken(req, token)","+","+\t\t\t// Grab the initial log level.","+\t\t\tinitalLogLevel := s.Agent.logger.GetLevel().String()","+\t\t\treloadedLogLevel := \"WARN\"","+","+\t\t\treloadCalls := 0","+\t\t\ts.Agent.configReloader = func() error {","+\t\t\t\treloadCalls++","+\t\t\t\tnewConfig := s.Agent.GetConfig().Copy()","+\t\t\t\tnewConfig.LogLevel = reloadedLogLevel","+\t\t\t\treturn s.Agent.Reload(newConfig)","+\t\t\t}","+","+\t\t\tobj, err := s.Server.AgentReloadRequest(respW, req)","+\t\t\tmust.NoError(t, err)","+\t\t\tmust.Nil(t, obj)                                            // this will need changed if the API ever returns something other than nil","+\t\t\tmust.Eq(t, 1, reloadCalls)                                  // confirm that the reloader was called","+\t\t\tmust.NotEq(t, initalLogLevel, s.Agent.GetConfig().LogLevel) // confirm that the log level was actually changed","+\t\t\tmust.Eq(t, reloadedLogLevel, s.Agent.GetConfig().LogLevel)  // confirm that the log level was updated in the agent's config","+\t\t}","+\t})","+}"],"additions":74,"deletions":0,"truncated":false},{"path":"command/agent/command.go","lines":["@@ -1,4 +1,4 @@","-// Copyright IBM Corp. 2015, 2025","+// Copyright IBM Corp. 2015, 2026"," // SPDX-License-Identifier: BUSL-1.1"," "," package agent","@@ -262,6 +262,10 @@ func (c *Command) readConfig() *Config {"," \t// Merge in the enterprise overlay"," \tconfig = config.Merge(DefaultEntConfig())"," ","+\tif len(configPath) > 0 {","+\t\tconfig.ConfigPaths = append([]string(nil), configPath...)","+\t}","+"," \tfor _, path := range configPath {"," \t\tcurrent, err := LoadConfig(path)"," \t\tif err != nil {","@@ -673,6 +677,9 @@ func (c *Command) setupAgent(config *Config, logger hclog.InterceptLogger, log