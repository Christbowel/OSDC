CustomKey tests SetupPluginCatalog with a custom PGP key","+func TestPluginCatalog_SetupWithCustomKey(t *testing.T) {","+\tt.Parallel()","+","+\t// Generate a test PGP key pair","+\t_, pubKeyArmored := generatePGPKeyPair(t)","+","+\t// Create temporary directories","+\ttmpDir := t.TempDir()","+\tpluginDir := filepath.Join(tmpDir, \"plugins\")","+\terr := os.MkdirAll(pluginDir, 0o755)","+\trequire.NoError(t, err)","+","+\tkeyPath := filepath.Join(tmpDir, \"custom-key.asc\")","+\terr = os.WriteFile(keyPath, []byte(pubKeyArmored), 0o644)","+\trequire.NoError(t, err)","+","+\t// Setup plugin catalog with custom key","+\tcatalog, err := SetupPluginCatalog(context.Background(), &PluginCatalogInput{","+\t\tBuiltinRegistry: corehelpers.NewMockBuiltinRegistry(),","+\t\tCatalogView:     &logical.InmemStorage{},","+\t\tPluginDirectory: pluginDir,","+\t\tLogger:          log.NewNullLogger(),","+\t\tPluginPGPKey:    keyPath,","+\t})","+","+\trequire.NoError(t, err)","+\tassert.NotNil(t, catalog)","+\tassert.Equal(t, keyPath, catalog.pluginPGPKey, \"custom key path should be set\")","+","+\t// Verify that getVerifyFunc returns a function that uses the custom key","+\tverifyFunc := catalog.getVerifyFunc()","+\tassert.NotNil(t, verifyFunc)","+}","+","+// TestPluginCatalog_verifyOfficialPlugins_WithCustomKey tests verifyOfficialPlugins with custom key","+func TestPluginCatalog_verifyOfficialPlugins_WithCustomKey(t *testing.T) {","+\tt.Parallel()","+","+\t// Generate a test PGP key pair","+\tprivKey, pubKeyArmored := generatePGPKeyPair(t)","+","+\t// Create temporary directories","+\ttmpDir := t.TempDir()","+\tpluginDir := filepath.Join(tmpDir, \"plugins\")","+\terr := os.MkdirAll(pluginDir, 0o755)","+\trequire.NoError(t, err)","+","+\tkeyPath := filepath.Join(tmpDir, \"custom-key.asc\")","+\terr = os.WriteFile(keyPath, []byte(pubKeyArmored), 0o644)","+\trequire.NoError(t, err)","+","+\t// Create a plugin artifact with proper signatures","+\tpluginName := \"vault-plugin-test\"","+\tpluginVersion := \"1.0.0\"","+\tartifactDir := filepath.Join(pluginDir, GetExtractedArtifactDir(pluginName, pluginVersion))","+\terr = os.MkdirAll(artifactDir, 0o755)","+\trequire.NoError(t, err)","+","+\tcontents := generatePluginArtifactContents(t, pluginName, pluginVersion, consts.PluginTypeSecrets, true, privKey)","+\tfor filename, data := range contents {","+\t\terr := os.WriteFile(filepath.Join(artifactDir, filename), data, 0o644)","+\t\trequire.NoError(t, err)","+\t}","+","+\tstorage := &logical.InmemStorage{}","+\t// Setup plugin catalog with custom key","+\tcatalog, err := SetupPluginCatalog(context.Background(), &PluginCatalogInput{","+\t\tBuiltinRegistry: corehelpers.NewMockBuiltinRegistry(),","+\t\tCatalogView:     storage,","+\t\tPluginDirectory: pluginDir,","+\t\tLogger:          log.NewNullLogger(),","+\t\tPluginPGPKey:    keyPath,","+\t})","+\trequire.NoError(t, err)","+","+\t// Register the plugin as official","+\tpluginEntry := &pluginutil.PluginRunner{","+\t\tName:    pluginName,","+\t\tType:    consts.PluginTypeSecrets,","+\t\tVersion: pluginVersion,","+\t\tCommand: filepath.Join(GetExtractedArtifactDir(pluginName, pluginVersion), pluginName),","+\t\tBuiltin: false,","+\t}","+","+\t// Store the plugin in catalog","+\tentry, err := logical.StorageEntryJSON(pluginEntry.Name, pluginEntry)","+\trequire.NoError(t, err)","+\terr = storage.Put(context.Background(), entry)","+\trequire.NoError(t, err)","+","+\t// Verify official plugins - should succeed with custom key","+\terr = catalog.verifyOfficialPlugins(context.Background())","+\trequire.NoError(t, err)","+}","+","+// TestPluginCatalog_SetupWithRawCustomKey tests SetupPluginCatalog with a raw PGP key (not a file path)","+func TestPluginCatalog_SetupWithRawCustomKey(t *testing.T) {","+\tt.Parallel()","+","+\t// Generate a test PGP key pair","+\t_, pubKeyArmored := generatePGPKeyPair(t)","+","+\t// Create temporary directories","+\ttmpDir := t.TempDir()","+\tpluginDir := filepath.Join(tmpDir, \"plugins\")","+\terr := os.MkdirAll(pluginDir, 0o755)","+\trequire.NoError(t, err)","+","+\t// Setup plugin catalog with raw PGP key (not a file path)","+\tcatalog, err := SetupPluginCatalog(context.Background(), &PluginCatalogInput{","+\t\tBuiltinRegistry: corehelpers.NewMockBuiltinRegistry(),","+\t\tCatalogView:     &logical.InmemStorage{},","+\t\tPluginDirectory: pluginDir,","+\t\tLogger:          log.NewNullLogger(),","+\t\tPluginPGPKey:    pubKeyArmored, // Pass raw key directly","+\t})","+","+\trequire.NoError(t, err)","+\tassert.NotNil(t, catalog)","+\tassert.Equal(t, pubKeyArmored, catalog.pluginPGPKey, \"raw custom key should be set\")","+","+\t// Verify that getVerifyFunc returns a function that uses the custom key","+\tverifyFunc := catalog.getVerifyFunc()","+\tassert.NotNil(t, verifyFunc)","+}","+","+// TestPluginCatalog_verifyOfficialPlugins_WithRawCustomKey tests verifyOfficialPlugins with raw custom key","+func TestPluginCatalog_verifyOfficialPlugins_WithRawCustomKey(t *testing.T) {","+\tt.Parallel()","+","+\t// Generate a test PGP key pair","+\tprivKey, pubKeyArmored := generatePGPKeyPair(t)","+","+\t// Create temporary directories","+\ttmpDir := t.TempDir()","+\tpluginDir := filepath.Join(tmpDir, \"plugins\")","+\terr := os.MkdirAll(pluginDir, 0o755)","+\trequire.NoError(t, err)","+","+\t// Create a plugin artifact with proper signatures","+\tpluginName := \"vault-plugin-test-raw\"","+\tpluginVersion := \"1.0.0\"","+\tartifactDir := filepath.Join(pluginDir, GetExtractedArtifactDir(pluginName, pluginVersion))","+\terr = os.MkdirAll(artifactDir, 0o755)","+\trequire.NoError(t, err)","+","+\tcontents := generatePluginArtifactContents(t, pluginName, pluginVersion, consts.PluginTypeSecrets, true, privKey)","+\tfor filename, data := range contents {","+\t\terr := os.WriteFile(filepath.Join(artifactDir, filename), data, 0o644)","+\t\trequire.NoError(t, err)","+\t}","+","+\tstorage := &logical.InmemStorage{}","+\t// Setup plugin catalog with raw PGP key (not a file path)","+\tcatalog, err := SetupPluginCatalog(context.Background(), &PluginCatalogInput{","+\t\tBuiltinRegistry: corehelpers.NewMockBuiltinRegistry(),","+\t\tCatalogView:     storage,","+\t\tPluginDirectory: pluginDir,","+\t\tLogger:          log.NewNullLogger(),","+\t\tPluginPGPKey:    pubKeyArmored, // Pass raw key directly","+\t})","+\trequire.NoError(t, err)","+","+\t// Register the plugin as official","+\tpluginEntry := &pluginutil.PluginRunner{","+\t\tName:    pluginName,","+\t\tType:    consts.PluginTypeSecrets,","+\t\tVersion: pluginVersion,","+\t\tCommand: filepath.Join(GetExtractedArtifactDir(pluginName, pluginVersion), pluginName),","+\t\tBuiltin: false,","+\t}","+","+\t// Store the plugin in catalog","+\tentry, err := logical.StorageEntryJSON(pluginEntry.Name, pluginEntry)","+\trequire.NoError(t, err)","+\terr = storage.Put(context.Background(), entry)","+\trequire.NoError(t, err)","+","+\t// Verify official plugins - should succeed with raw custom key","+\terr = catalog.verifyOfficialPlugins(context.Background())","+\trequire.NoError(t, err)","+}",""],"additions":203,"deletions":0,"truncated":false}],"additions":562,"deletions":18,"truncated":false,"file_count":6},"error":null,"fetched_at":"2026-05-20T17:41:22.598682+00:00"}