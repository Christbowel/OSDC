{"id":"7bc111c6eb96bd7331f822d29c26b268212c841b","axis":"silent","repo":"golang/go","sha":"7bc111c6eb96bd7331f822d29c26b268212c841b","parsed":{"files":[{"path":"api/next/77626.txt","lines":["@@ -0,0 +1,41 @@","+pkg crypto, const MLDSAMu = 20 #77626","+pkg crypto, const MLDSAMu Hash #77626","+pkg crypto/mldsa, const MLDSA44PublicKeySize = 1312 #77626","+pkg crypto/mldsa, const MLDSA44PublicKeySize ideal-int #77626","+pkg crypto/mldsa, const MLDSA44SignatureSize = 2420 #77626","+pkg crypto/mldsa, const MLDSA44SignatureSize ideal-int #77626","+pkg crypto/mldsa, const MLDSA65PublicKeySize = 1952 #77626","+pkg crypto/mldsa, const MLDSA65PublicKeySize ideal-int #77626","+pkg crypto/mldsa, const MLDSA65SignatureSize = 3309 #77626","+pkg crypto/mldsa, const MLDSA65SignatureSize ideal-int #77626","+pkg crypto/mldsa, const MLDSA87PublicKeySize = 2592 #77626","+pkg crypto/mldsa, const MLDSA87PublicKeySize ideal-int #77626","+pkg crypto/mldsa, const MLDSA87SignatureSize = 4627 #77626","+pkg crypto/mldsa, const MLDSA87SignatureSize ideal-int #77626","+pkg crypto/mldsa, const PrivateKeySize = 32 #77626","+pkg crypto/mldsa, const PrivateKeySize ideal-int #77626","+pkg crypto/mldsa, func GenerateKey(Parameters) (*PrivateKey, error) #77626","+pkg crypto/mldsa, func MLDSA44() Parameters #77626","+pkg crypto/mldsa, func MLDSA65() Parameters #77626","+pkg crypto/mldsa, func MLDSA87() Parameters #77626","+pkg crypto/mldsa, func NewPrivateKey(Parameters, []uint8) (*PrivateKey, error) #77626","+pkg crypto/mldsa, func NewPublicKey(Parameters, []uint8) (*PublicKey, error) #77626","+pkg crypto/mldsa, func Verify(*PublicKey, []uint8, []uint8, *Options) error #77626","+pkg crypto/mldsa, method (*Options) HashFunc() crypto.Hash #77626","+pkg crypto/mldsa, method (*PrivateKey) Bytes() []uint8 #77626","+pkg crypto/mldsa, method (*PrivateKey) Equal(crypto.PrivateKey) bool #77626","+pkg crypto/mldsa, method (*PrivateKey) Public() crypto.PublicKey #77626","+pkg crypto/mldsa, method (*PrivateKey) PublicKey() *PublicKey #77626","+pkg crypto/mldsa, method (*PrivateKey) Sign(io.Reader, []uint8, crypto.SignerOpts) ([]uint8, error) #77626","+pkg crypto/mldsa, method (*PrivateKey) SignDeterministic([]uint8, crypto.SignerOpts) ([]uint8, error) #77626","+pkg crypto/mldsa, method (*PublicKey) Bytes() []uint8 #77626","+pkg crypto/mldsa, method (*PublicKey) Equal(crypto.PublicKey) bool #77626","+pkg crypto/mldsa, method (*PublicKey) Parameters() Parameters #77626","+pkg crypto/mldsa, method (Parameters) PublicKeySize() int #77626","+pkg crypto/mldsa, method (Parameters) SignatureSize() int #77626","+pkg crypto/mldsa, method (Parameters) String() string #77626","+pkg crypto/mldsa, type Options struct #77626","+pkg crypto/mldsa, type Options struct, Context string #77626","+pkg crypto/mldsa, type Parameters struct #77626","+pkg crypto/mldsa, type PrivateKey struct #77626","+pkg crypto/mldsa, type PublicKey struct #77626"],"additions":41,"deletions":0,"truncated":false},{"path":"doc/next/6-stdlib/70-mldsa.md","lines":["@@ -0,0 +1,6 @@","+### crypto/mldsa","+","+<!-- https://go.dev/issue/77626 --->","+","+The new [crypto/mldsa] package implements the post-quantum ML-DSA signature","+scheme specified in FIPS 204."],"additions":6,"deletions":0,"truncated":false},{"path":"doc/next/6-stdlib/99-minor/crypto/77626.md","lines":["@@ -0,0 +1,2 @@","+The new [MLDSAMu] [Hash] value is meant to be used as a signaling mechanism for","+External μ ML-DSA signing."],"additions":2,"deletions":0,"truncated":false},{"path":"doc/next/6-stdlib/99-minor/crypto/mldsa/77626.md","lines":["@@ -0,0 +1 @@","+<!-- crypto/mldsa is documented in doc/next/6-stdlib/70-mldsa.md. -->"],"additions":1,"deletions":0,"truncated":false},{"path":"src/crypto/crypto.go","lines":["@@ -60,6 +60,8 @@ func (h Hash) String() string {"," \t\treturn \"BLAKE2b-384\""," \tcase BLAKE2b_512:"," \t\treturn \"BLAKE2b-512\"","+\tcase MLDSAMu:","+\t\treturn \"ML-DSA μ message representative\""," \tdefault:"," \t\treturn \"unknown hash value \" + strconv.Itoa(int(h))"," \t}","@@ -85,6 +87,14 @@ const ("," \tBLAKE2b_256                 // import golang.org/x/crypto/blake2b"," \tBLAKE2b_384                 // import golang.org/x/crypto/blake2b"," \tBLAKE2b_512                 // import golang.org/x/crypto/blake2b","+","+\t// MLDSAMu is a sentinel value for a [pre-hashed μ message representative].","+\t// It has no implementation, but is used as a [SignerOpts.HashFunc] return","+\t// value for [crypto/mldsa.PrivateKey.Sign].","+\t//","+\t// [pre-hashed μ message representative]: https://www.rfc-editor.org/rfc/rfc9881.html#externalmu","+\tMLDSAMu","+"," \tmaxHash"," )"," ","@@ -108,6 +118,7 @@ var digestSizes = []uint8{"," \tBLAKE2b_256: 32,"," \tBLAKE2b_384: 48,"," \tBLAKE2b_512: 64,","+\tMLDSAMu:     64,"," }"," "," // Size returns the length, in bytes, of a digest resulting from the given hash","@@ -146,6 +157,9 @@ func RegisterHash(h Hash, f func() hash.Hash) {"," \tif h == 0 || h >= maxHash {"," \t\tpanic(\"crypto: RegisterHash of unknown hash function\")"," \t}","+\tif h == MLDSAMu {","+\t\tpanic(\"crypto: cannot RegisterHash for MLDSAMu\")","+\t}"," \thashes[h] = f"," }"," "],"additions":14,"deletions":0,"truncated":false},{"path":"src/crypto/crypto_test.go","lines":["@@ -147,7 +147,7 @@ func TestDisallowedAssemblyInstructions(t *testing.T) {"," func TestRegisterHashLimits(t *testing.T) {"," \t// maxHash is not exported, so we just use its value. If maxHash ever changes"," \t// this will need to be updated.","-\tfor _, h := range []crypto.Hash{0, 20} {","+\tfor _, h := range []crypto.Hash{0, 21, crypto.MLDSAMu} {"," \t\tt.Run(fmt.Sprintf(\"h=%d\", h), func(t *testing.T) {"," \t\t\tdefer func() {"," \t\t\t\tif r := recover(); r == nil {","@@ -158,3 +158,27 @@ func TestRegisterHashLimits(t *testing.T) {"," \t\t})"," \t}"," }","+","+func TestMLDSAMu(t *testing.T) {","+\th := crypto.MLDSAMu","+\tif got := h.Size(); got != 64 {","+\t\tt.Errorf(\"MLDSAMu.Size() = %d, want 64\", got)","+\t}","+\tif got := h.String(); got != \"ML-DSA μ message representative\" {","+\t\tt.Errorf(\"MLDSAMu.String() = %q\", got)","+\t}","+\tif h.Available() {","+\t\tt.Errorf(\"MLDSAMu.Available() = true, want false\")","+\t}","+\tif got := h.HashFunc(); got != h {","+\t\tt.Errorf(\"MLDSAMu.HashFunc() = %v, want itself\", got)","+\t}","+\tfunc() {","+\t\tdefer func() {","+\t\t\tif r := recover(); r == nil {","+\t\t\t\tt.Errorf(\"MLDSAMu.New() did not panic\")","+\t\t\t}","+\t\t}()","+\t\t_ = h.New()","+\t}()","+}"],"additions":25,"deletions":1,"truncated":false},{"path":"src/crypto/mldsa/example_test.go","lines":["@@ -0,0 +1,47 @@","+// Copyright 2026 The Go Authors. All rights reserved.","+// Use of this source code is governed by a BSD-style","+// license that can be found in the LICENSE file.","+","+//go:build !fips140v1.0","+","+package mldsa_test","+","+import (","+\t\"crypto/mldsa\"","+\t\"fmt\"","+\t\"log\"","+)","+","+func Example() {","+\t// The signer generates a new ML-DSA-44 key pair.","+\tsk, err := mldsa.GenerateKey(mldsa.MLDSA44())","+\tif err != nil {","+\t\tlog.Fatal(err)","+\t}","+","+\t// The signer publishes the public key encoding.","+\tpublicKey := sk.PublicKey().Bytes()","+\tfmt.Printf(\"public key: %d bytes\\n\", len(publicKey))","+","+\t// The signer signs a message and publishes the signature.","+\tmsg := []byte(\"hello, world\")","+\tsig, err := sk.Sign(nil, msg, &mldsa.Options{Context: \"example\"})","+\tif err != nil {","+\t\tlog.Fatal(err)","+\t}","+\tfmt.Printf(\"signature: %d bytes\\n\", len(sig))","+","+\t// The verifier reconstructs the public key and checks the signature.","+\t// The context string must match the one used by the signer.","+\tpk, err := mldsa.NewPublicKey(mldsa.MLDSA44(), publicKey)","+\tif err != nil {","+\t\tlog.Fatal(err)","+\t}","+\tif err := mldsa.Verify(pk, msg, sig, &mldsa.Options{Context: \"example\"}); err != nil {","+\t\tlog.Fatal(\"invalid signature: \", err)","+\t}","+","+\t// Output:","+\t// public key: 1312 bytes","+\t// signature: 2420 bytes","+}"],"additions":47,"deletions":0,"truncated":false},{"path":"src/crypto/mldsa/mldsa.go","lines":["@@ -0,0 +1,97 @@","+// Copyright 2026 The Go Authors. All rights reserved.","+// Use of this source code is governed by a BSD-style","+// license that can be found in the LICENSE file.","+","+// Package mldsa implements the post-quantum ML-DSA signature scheme specified","+// in [FIPS 204].","+//","+// This package is unavailable if using the [FIPS 140-3 Go Cryptographic Module]","+// v1.0.0, in which case [GenerateKey], [NewPrivateKey], [NewPublicKey], and","+// [Verify] will return an error. It is available if using v1.26.0 or later.","+//","+// [FIPS 204]: https://nvlpubs.nist.gov/nistpubs/FIPS/NIST.FIPS.204.pdf","+// [FIPS 140-3 Go Cryptographic Module]: https://go.dev/doc/security/fips140","+package mldsa","+","+import \"crypto\"","+","+const (","+\tPrivateKeySize = 32","+","+\tMLDSA44PublicKeySize = 1312","+\tMLDSA65PublicKeySize = 1952","+\tMLDSA87PublicKeySize = 2592","+","+\tMLDSA44SignatureSize = 2420","+\tMLDSA65SignatureSize = 3309","+\tMLDSA87SignatureSize = 4627","+)","+","+// Parameters represents one of the fixed parameter sets defined in FIPS 204.","+//","+// Most applications should use [MLDSA44].","+//","+// Multiple invocations of [MLDSA44], [MLDSA65], or [MLDSA87] will return the","+// same respective value, which can be used for equality checks and switch","+// statements. The returned value is safe for concurrent use.","+type Parameters struct {","+\tname          string","+\tpublicKeySize int","+\tsignatureSize int","+}","+","+// MLDSA44 returns the ML-DSA-44 parameter set defined in FIPS 204.","+func MLDSA44() Parameters {","+\treturn Parameters{","+\t\tname:          \"ML-DSA-44\",","+\t\tpublicKeySize: MLDSA44PublicKeySize,","+\t\tsignatureSize: MLDSA44SignatureSize,","+\t}","+}","+","+// MLDSA65 returns the ML-DSA-65 parameter set defined in FIPS 204.","+func MLDSA65() Parameters {","+\treturn Parameters{","+\t\tname:          \"ML-DSA-65\",","+\t\tpublicKeySize: MLDSA65PublicKeySize,","+\t\tsignatureSize: MLDSA65SignatureSize,","+\t}","+}","+","+// MLDSA87 returns the ML-DSA-87 parameter set defined in FIPS 204.","+func MLDSA87() Parameters {","+\treturn Parameters{","+\t\tname:          \"ML-DSA-87\",","+\t\tpublicKeySize: MLDSA87PublicKeySize,","+\t\tsignatureSize: MLDSA87SignatureSize,","+\t}","+}","+","+// PublicKeySize returns the size of public keys for this parameter set, in bytes.","+func (params Parameters) PublicKeySize() int {","+\treturn params.publicKeySize","+}","+","+// SignatureSize returns the size of signatures for this parameter set, in bytes.","+func (params Parameters) SignatureSize() int {","+\treturn params.signatureSize","+}","+","+// String returns the name of the parameter set, e.g. \"ML-DSA-44\".","+func (params Parameters) String() string {","+\treturn params.name","+}","+","+// Options contains additional options for signing and verifying ML-DSA signatures.","+type Options struct {","+\t// Context can be used to distinguish signatures created for different","+\t// purposes. It must be at most 255 bytes long, and it is empty by default.","+\t//","+\t// The same context must be used when signing and verifying a signature.","+\tContext string","+}","+","+// HashFunc returns zero, to implement the [crypto.SignerOpts] interface.","+func (opts *Options) HashFunc() crypto.Hash {","+\treturn 0","+}"],"additions":97,"deletions":0,"truncated":false},{"path":"src/crypto/mldsa/mldsa_fips140v1.0.go","lines":["@@ -0,0 +1,116 @@","+// Copyright 2026 The Go Authors. All rights reserved.","+// Use of this source code is governed by a BSD-style","+// license that can be found in the LICENSE file.","+","+//go:build fips140v1.0","+","+package mldsa","+","+import (","+\t\"crypto\"","+\t\"errors\"","+\t\"io\"","+)","+","+// This file provides stub implementations of the ML-DSA API for building","+// against the FIPS 140-3 Go Cryptographic Module v1.0.0, which does not include","+// ML-DSA. Top-level functions return an error, and methods are unreachable","+// since there is no way to construct a valid PublicKey or PrivateKey.","+","+var errUnavailable = errors.New(\"mldsa: unavailable in FIPS 140-3 Go Cryptographic Module v1.0.0\")","+","+// PrivateKey is an in-memory ML-DSA private key. It implements [crypto.Signer]","+// and the informal extended [crypto.PrivateKey] interface.","+//","+// A PrivateKey is safe for concurrent use.","+type PrivateKey struct{}","+","+// GenerateKey generates a new random ML-DSA private key.","+func GenerateKey(params Parameters) (*PrivateKey, error) {","+\treturn nil, errUnavailable","+}","+","+// NewPrivateKey decodes an ML-DSA private key from the given seed.","+//","+// The seed must be exactly [PrivateKeySize] bytes long.","+func NewPrivateKey(params Parameters, seed []byte) (*PrivateKey, error) {","+\treturn nil, errUnavailable","+}","+","+// Public returns the corresponding [PublicKey] for this private key.","+//","+// It implements the [crypto.Signer] interface.","+func (sk *PrivateKey) Public() crypto.PublicKey {","+\tpanic(\"mldsa: methods are unreachable in FIPS 140-3 Go Cryptographic Module v1.0.0\")","+}","+","+// Equal reports whether sk and x are the same key (i.e. they are derived from","+// the same seed).","+//","+// If x is not a *PrivateKey, Equal returns false.","+func (sk *PrivateKey) Equal(x crypto.PrivateKey) bool {","+\tpanic(\"mldsa: methods are unreachable in FIPS 140-3 Go Cryptographic Module v1.0.0\")","+}","+","+// PublicKey returns the corresponding [PublicKey] for this private key.","+func (sk *PrivateKey) PublicKey() *PublicKey {","+\tpanic(\"mldsa: methods are unreachable in FIPS 140-3 Go Cryptographic Module v1.0.0\")","+}","+","+// Bytes returns the private key seed.","+func (sk *PrivateKey) Bytes() []byte {","+\tpanic(\"mldsa: methods are unreachable in FIPS 140-3 Go Cryptographic Module v1.0.0\")","+}","+","+// Sign returns a signature of the given message using this private key.","+//","+// If opts is nil or opts.HashFunc returns zero, the message is signed directly.","+// If opts.HashFunc returns [crypto.MLDSAMu], the provided message must be a","+// [pre-hashed μ message representative]. opts can be of type *[Options].","+// The io.Reader argument is ignored.","+//","+// [pre-hashed μ message representative]: https://www.rfc-editor.org/rfc/rfc9881.html#externalmu","+func (sk *PrivateKey) Sign(_ io.Reader, message []byte, opts crypto.SignerOpts) (signature []byte, err error) {","+\tpanic(\"mldsa: methods are unreachable in FIPS 140-3 Go Cryptographic Module v1.0.0\")","+}","+","+// SignDeterministic works like [PrivateKey.Sign], but the signature is","+// deterministic.","+func (sk *PrivateKey) SignDeterministic(message []byte, opts crypto.SignerOpts) (signature []byte, err error) {","+\tpanic(\"mldsa: methods are unreachable in FIPS 140-3 Go Cryptographic Module v1.0.0\")","+}","+","+// PublicKey is an ML-DSA public key. It implements the informal extended","+// [crypto.PublicKey] interface.","+//","+// A PublicKey is safe for concurrent use.","+type PublicKey struct{}","+","+// NewPublicKey creates a new ML-DSA public key from the given encoding.","+func NewPublicKey(params Parameters, encoding []byte) (*PublicKey, error) {","+\treturn nil, errUnavailable","+}","+","+// Bytes returns the public key encoding.","+func (pk *PublicKey) Bytes() []byte {","+\tpanic(\"mldsa: methods are unreachable in FIPS 140-3 Go Cryptographic Module v1.0.0\")","+}","+","+// Equal reports whether pk and x are the same key (i.e. they have the same","+// encoding).","+//","+// If x is not a *PublicKey, Equal returns false.","+func (pk *PublicKey) Equal(x crypto.PublicKey) bool {","+\tpanic(\"mldsa: methods are unreachable in FIPS 140-3 Go Cryptographic Module v1.0.0\")","+}","+","+// Parameters returns the parameters associated with this public key.","+func (pk *PublicKey) Parameters() Parameters {","+\tpanic(\"mldsa: methods are unreachable in FIPS 140-3 Go Cryptographic Module v1.0.0\")","+}","+","+// Verify reports whether signature is a valid signature of message by pk.","+// If opts is nil, it's equivalent to the zero value of Options.","+func Verify(pk *PublicKey, message []byte, signature []byte, opts *Options) error {","+\treturn errUnavailable","+}"],"additions":116,"deletions":0,"truncated":false},{"path":"src/crypto/mldsa/mldsa_fips140v1.0_test.go","lines":["@@ -0,0 +1,93 @@","+// Copyright 2026 The Go Authors. All rights reserved.","+// Use of this source code is governed by a BSD-style","+// license that can be found in the LICENSE file.","+","+//go:build fips140v1.0","+","+package mldsa_test","+","+import (","+\t\"crypto\"","+\t. \"crypto/mldsa\"","+\t\"testing\"","+)","+","+var _ crypto.Signer = (*PrivateKey)(nil)","+","+func TestUnavailable(t *testing.T) {","+\tfor _, params := range []Parameters{MLDSA44(), MLDSA65(), MLDSA87()} {","+\t\tt.Run(params.String(), func(t *testing.T) {","+\t\t\tif _, err := GenerateKey(params); err == nil {","+\t\t\t\tt.Errorf(\"GenerateKey: want error, got nil\")","+\t\t\t}","+\t\t\tif _, err := NewPrivateKey(params, make([]byte, PrivateKeySize)); err == nil {","+\t\t\t\tt.Errorf(\"NewPrivateKey: want error, got nil\")","+\t\t\t}","+\t\t\tif _, err := NewPublicKey(params, make([]byte, params.PublicKeySize())); err == nil {","+\t\t\t\tt.Errorf(\"NewPublicKey: want error, got nil\")","+\t\t\t}","+\t\t\tif err := Verify(&PublicKey{}, nil, nil, nil); err == nil {","+\t\t\t\tt.Errorf(\"Verify: want error, got nil\")","+\t\t\t}","+\t\t})","+\t}","+}","+","+func TestMethodsPanic(t *testing.T) {","+\t// All PrivateKey and PublicKey methods are unreachable in the v1.0 stub","+\t// (since there is no way to construct a non-zero key) and panic if invoked","+\t// on the zero value.","+\tsk := &PrivateKey{}","+\tpk := &PublicKey{}","+\tcases := []struct {","+\t\tname string","+\t\tfn   func()","+\t}{","+\t\t{\"PrivateKey.Public\", func() { sk.Public() }},","+\t\t{\"PrivateKey.Equal\", func() { sk.Equal(sk) }},","+\t\t{\"PrivateKey.PublicKey\", func() { sk.PublicKey() }},","+\t\t{\"PrivateKey.Bytes\", func() { sk.Bytes() }},","+\t\t{\"PrivateKey.Sign\", func() { sk.Sign(nil, nil, nil) }},","+\t\t{\"PrivateKey.SignDeterministic\", func() { sk.SignDeterministic(nil, nil) }},","+\t\t{\"PublicKey.Bytes\", func() { pk.Bytes() }},","+\t\t{\"PublicKey.Equal\", func() { pk.Equal(pk) }},","+\t\t{\"PublicKey.Parameters\", func() { pk.Parameters() }},","+\t}","+\tfor _, tc := range cases {","+\t\tt.Run(tc.name, func(t *testing.T) {","+\t\t\tdefer func() {","+\t\t\t\tif r := recover(); r == nil {","+\t\t\t\t\tt.Errorf(\"%s: did not panic\", tc.name)","+\t\t\t\t}","+\t\t\t}()","+\t\t\ttc.fn()","+\t\t})","+\t}","+}","+","+func TestParametersAvailable(t *testing.T) {","+\t// The Parameters value type and its methods must remain usable even under","+\t// the v1.0 stub, so callers can introspect parameter sets without invoking","+\t// the unavailable key APIs.","+\tcases := []struct {","+\t\tparams  Parameters","+\t\tname    string","+\t\tpkSize  int","+\t\tsigSize int","+\t}{","+\t\t{MLDSA44(), \"ML-DSA-44\", MLDSA44PublicKeySize, MLDSA44SignatureSize},","+\t\t{MLDSA65(), \"ML-DSA-65\", MLDSA65PublicKeySize, MLDSA65SignatureSize},","+\t\t{MLDSA87(), \"ML-DSA-87\", MLDSA87PublicKeySize, MLDSA87SignatureSize},","+\t}","+\tfor _, tc := range cases {","+\t\tif got := tc.params.String(); got != tc.name {","+\t\t\tt.Errorf(\"String() = %q, want %q\", got, tc.name)","+\t\t}","+\t\tif got := tc.params.PublicKeySize(); got != tc.pkSize {","+\t\t\tt.Errorf(\"%s PublicKeySize() = %d, want %d\", tc.name, got, tc.pkSize)","+\t\t}","+\t\tif got := tc.params.SignatureSize(); got != tc.sigSize {","+\t\t\tt.Errorf(\"%s SignatureSize() = %d, want %d\", tc.name, got, tc.sigSize)","+\t\t}","+\t}","+}"],"additions":93,"deletions":0,"truncated":false},{"path":"src/crypto/mldsa/mldsa_fips140v1.26.go","lines":["@@ -0,0 +1,212 @@","+// Copyright 2026 The Go Authors. All rights reserved.","+// Use of this source code is governed by a BSD-style","+// license that can be found in the LICENSE file.","+","+//go:build !fips140v1.0","+","+package mldsa","+","+import (","+\t\"crypto\"","+\t\"crypto/internal/fips140/mldsa\"","+\t\"errors\"","+\t\"io\"","+)","+","+// PrivateKey is an in-memory ML-DSA private key. It implements [crypto.Signer]","+// and the informal extended [crypto.PrivateKey] interface.","+//","+// A PrivateKey is safe for concurrent use.","+type PrivateKey struct {","+\tk mldsa.PrivateKey","+}","+","+var errInvalidParameters = errors.New(\"mldsa: invalid parameters\")","+","+// GenerateKey generates a new random ML-DSA private key.","+func GenerateKey(params Parameters) (*PrivateKey, error) {","+\tswitch params {","+\tcase MLDSA44():","+\t\treturn &PrivateKey{k: *mldsa.GenerateKey44()}, nil","+\tcase MLDSA65():","+\t\treturn &PrivateKey{k: *mldsa.GenerateKey65()}, nil","+\tcase MLDSA87():","+\t\treturn &PrivateKey{k: *mldsa.GenerateKey87()}, nil","+\tdefault:","+\t\treturn nil, errInvalidParameters","+\t}","+}","+","+// NewPrivateKey decodes an ML-DSA private key from the given seed.","+//","+// The seed must be exactly [PrivateKeySize] bytes long.","+func NewPrivateKey(params Parameters, seed []byte) (*PrivateKey, error) {","+\tvar err error","+\tvar k *mldsa.PrivateKey","+\tswitch params {","+\tcase MLDSA44():","+\t\tk, err = mldsa.NewPrivateKey44(seed)","+\tcase MLDSA65():","+\t\tk, err = mldsa.NewPrivateKey65(seed)","+\tcase MLDSA87():","+\t\tk, err = mldsa.NewPrivateKey87(seed)","+\tdefault:","+\t\treturn nil, errInvalidParameters","+\t}","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\treturn &PrivateKey{k: *k}, nil","+}","+","+// Public returns the corresponding [PublicKey] for this private key.","+//","+// It implements the [crypto.Signer] interface.","+func (sk *PrivateKey) Public() crypto.PublicKey {","+\treturn sk.PublicKey()","+}","+","+// Equal reports whether sk and x are the same key (i.e. they are derived from","+// the same seed).","+//","+// If x is not a *PrivateKey, Equal returns false.","+func (sk *PrivateKey) Equal(x crypto.PrivateKey) bool {","+\tother, ok := x.(*PrivateKey)","+\tif !ok || other == nil {","+\t\treturn false","+\t}","+\treturn sk.k.Equal(&other.k)","+}","+","+// PublicKey returns the corresponding [PublicKey] for this private key.","+func (sk *PrivateKey) PublicKey() *PublicKey {","+\t// Making a copy severs the pointer relationship between the private and","+\t// public keys, so that keeping the public key around doesn't keep the","+\t// private key alive. This costs a copy and an allocation.","+\treturn &PublicKey{p: *sk.k.PublicKey()}","+}","+","+// Bytes returns the private key seed.","+func (sk *PrivateKey) Bytes() []byte {","+\treturn sk.k.Bytes()","+}","+","+var errInvalidSignerOpts = errors.New(\"mldsa: invalid SignerOpts\")","+","+// Sign returns a signature of the given message using this private key.","+//","+// If opts is nil or opts.HashFunc returns zero, the message is signed directly.","+// If opts.HashFunc returns [crypto.MLDSAMu], the provided message must be a","+// [pre-hashed μ message representative]. opts can be of type *[Options] if a","+// context string is desired along with a directly-signed message. The io.Reader","+// argument is ignored.","+//","+// [pre-hashed μ message representative]: https://www.rfc-editor.org/rfc/rfc9881.html#externalmu","+func (sk *PrivateKey) Sign(_ io.Reader, message []byte, opts crypto.SignerOpts) (signature []byte, err error) {","+\tif opts == nil {","+\t\topts = &Options{}","+\t}","+\tswitch opts.HashFunc() {","+\tcase 0:","+\t\tvar context string","+\t\tif opts, ok := opts.(*Options); ok {","+\t\t\tcontext = opts.Context","+\t\t}","+\t\treturn mldsa.Sign(&sk.k, message, context)","+\tcase crypto.MLDSAMu:","+\t\treturn mldsa.SignExternalMu(&sk.k, message)","+\tdefault:","+\t\treturn nil, errInvalidSignerOpts","+\t}","+}","+","+// SignDeterministic works like [PrivateKey.Sign], but t