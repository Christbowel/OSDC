he legacy per-request settings are still populated.","+\t\tassert.Equal(t, \"https://grafana.example.com\", config.AppURL)","+\t})","+","+\tt.Run(\"builds full frontend settings when flag enabled\", func(t *testing.T) {","+\t\tcfg := newCfg()","+\t\tlicense := &licensing.OSSLicensingService{Cfg: cfg}","+","+\t\treqCtx := &contextmodel.ReqContext{","+\t\t\tContext:      &web.Context{Req: httptest.NewRequest(\"GET\", \"/\", nil)},","+\t\t\tSignedInUser: &user.SignedInUser{},","+\t\t\tLogger:       log.NewNopLogger(),","+\t\t}","+\t\tctx := ctxkey.Set(context.Background(), reqCtx)","+","+\t\tconfig, err := NewFSRequestConfig(ctx, cfg, license, true)","+\t\trequire.NoError(t, err)","+","+\t\trequire.NotNil(t, config.FullFrontendSettings)","+\t\tassert.Equal(t, \"https://grafana.example.com\", config.FullFrontendSettings.AppUrl)","+\t})"," }",""],"additions":100,"deletions":9,"truncated":false}],"additions":274,"deletions":34,"truncated":false,"file_count":8},"error":null,"fetched_at":"2026-06-20T10:27:51.266434+00:00"}