)`, and `sb.snapshotFilesystem(30000, params)` to `sb.snapshotFilesystem({ timeoutMs: 30000, ...params })`."],"additions":1,"deletions":0,"truncated":false},{"path":"js/eslint.config.js","lines":["@@ -55,10 +55,7 @@ export default defineConfig([","     },","   },","   {","-    files: [","-      \"test/legacy/**/*.{ts,mts,cts}\",","-      \"examples/legacy/**/*.{ts,mts,cts}\",","-    ],","+    files: [\"examples/legacy/**/*.{ts,mts,cts}\"],","     rules: {","       \"@typescript-eslint/no-deprecated\": \"off\",","     },"],"additions":1,"deletions":4,"truncated":false},{"path":"js/src/app.ts","lines":["@@ -1,10 +1,7 @@"," import { ClientError, Status } from \"nice-grpc\";"," import { ObjectCreationType } from \"../proto/modal_proto/api\";","-import { getDefaultClient, type ModalClient } from \"./client\";","-import { Image } from \"./image\";","-import { Sandbox, SandboxCreateParams } from \"./sandbox\";","+import { type ModalClient } from \"./client\";"," import { NotFoundError } from \"./errors\";","-import { Secret } from \"./secret\";"," import { GPUConfig } from \"../proto/modal_proto/api\";"," "," /**","@@ -56,22 +53,6 @@ export type AppFromNameParams = {","   createIfMissing?: boolean;"," };"," ","-/** @deprecated Use specific Params types instead. */","-export type LookupOptions = {","-  environment?: string;","-  createIfMissing?: boolean;","-};","-","-/** @deprecated Use specific Params types instead. */","-export type DeleteOptions = {","-  environment?: string;","-};","-","-/** @deprecated Use specific Params types instead. */","-export type EphemeralOptions = {","-  environment?: string;","-};","-"," /**","  * Parse a GPU configuration string into a GPUConfig object.","  * @param gpu - GPU string in format \"type\" or \"type:count\" (e.g. \"T4\", \"A100:2\")","@@ -112,48 +93,4 @@ export class App {","     this.appId = appId;","     this.name = name;","   }","-","-  /**","-   * @deprecated Use {@link AppService#fromName client.apps.fromName()} instead.","