pp'), { recursive: true });","+\t\tawait fs.writeFile(join(dir, 'app', 'main.ts'), 'committed');","+\t\tawait fs.writeFile(join(dir, 'app', 'config.local'), 'local');","+\t\tcp.execFileSync('git', ['add', 'app/main.ts'], { cwd: dir, env, stdio: 'pipe' });","+\t\tcp.execFileSync('git', ['commit', '-q', '-m', 'add tracked'], { cwd: dir, env, stdio: 'pipe' });","+\t\t// Uncommitted change to the tracked file: if the folder were wrongly","+\t\t// collapsed/copied, the worktree checkout would be overwritten with this.","+\t\tawait fs.writeFile(join(dir, 'app', 'main.ts'), 'MODIFIED');","+","+\t\tconst wtPath = join(dir, '..', `wt-${Date.now()}`);","+\t\ttry {","+\t\t\tawait svc!.addWorktree(URI.file(dir), URI.file(wtPath), 'agents/include-files', 'main');","+\t\t\tawait svc!.copyWorktreeIncludeFiles(URI.file(dir), URI.file(wtPath), ['.env', 'secrets/**', 'partial/*.txt', 'app/**']);","+","+\t\t\tconst read = async (relativePath: string) => {","+\t\t\t\ttry { return await fs.readFile(join(wtPath, relativePath), 'utf8'); } catch { return undefined; }","+\t\t\t};","+","+\t\t\tassert.deepStrictEqual({","+\t\t\t\tenv: await read('.env'),","+\t\t\t\tsecretKey: await read(join('secrets', 'key.txt')),","+\t\t\t\tsecretDeep: await read(join('secrets', 'nested', 'deep.txt')),","+\t\t\t\tbuildArtifact: await read(join('build', 'output.txt')),","+\t\t\t\tpartialKeep: await read(join('partial', 'keep.txt')),","+\t\t\t\tpartialSkip: await read(join('partial', 'skip.bin')),","+\t\t\t\tappConfig: await read(join('app', 'config.local')),","+\t\t\t\tappTracked: await read(join('app', 'main.ts')),","+\t\t\t}, {","+\t\t\t\tenv: 'SECRET=1',","+\t\t\t\tsecretKey: 'key',","+\t\t\t\tsecretDeep: 'deep',","+\t\t\t\tbuildArtifact: undefined,","+\t\t\t\tpartialKeep: 'keep',","+\t\t\t\tpartialSkip: undefined,","+\t\t\t\tappConfig: 'local',","+\t\t\t\tappTracked: 'committed',","+\t\t\t});","+\t\t} finally {","+\t\t\ttry { await svc!.removeWorktree(URI.file(dir), URI.file(wtPath)); } catch { /* best-e