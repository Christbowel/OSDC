epositoryRoot: URI, worktree: URI, globs: readonly string[]): Promise<void> {","+\t\ttry {","+\t\t\tconst worktreeIncludePaths = await this._getWorktreeIncludePaths(repositoryRoot, globs);","+\t\t\tif (worktreeIncludePaths.length === 0) {","+\t\t\t\treturn;","+\t\t\t}","+","+\t\t\tconst startTime = performance.now();","+\t\t\tconst limiter = new Limiter<void>(15);","+\t\t\tconst results = await Promise.allSettled(worktreeIncludePaths.map(sourcePath => limiter.queue(async () => {","+\t\t\t\tconst targetPath = path.join(worktree.fsPath, path.relative(repositoryRoot.fsPath, sourcePath));","+\t\t\t\tawait fsPromises.mkdir(path.dirname(targetPath), { recursive: true });","+\t\t\t\tawait copyFile(sourcePath, targetPath, { force: true, recursive: true, verbatimSymlinks: true });","+\t\t\t})));","+","+\t\t\tconst failedOperations = results.filter((result): result is PromiseRejectedResult => result.status === 'rejected');","+\t\t\tthis._logService.info(`[AgentHostGitService][copyWorktreeIncludeFiles] Copied ${worktreeIncludePaths.length - failedOperations.length}/${worktreeIncludePaths.length} folder(s)/file(s) to worktree ${worktree.fsPath}. [${(performance.now() - startTime).toFixed(2)}ms]`);","+","+\t\t\tif (failedOperations.length > 0) {","+\t\t\t\tthis._logService.warn(`[AgentHostGitService][copyWorktreeIncludeFiles] Failed to copy ${failedOperations.length} folder(s)/file(s) to worktree ${worktree.fsPath}.`);","+\t\t\t\tfor (const error of failedOperations) {","+\t\t\t\t\tthis._logService.warn(`[AgentHostGitService][copyWorktreeIncludeFiles] ${error.reason}`);","+\t\t\t\t}","+\t\t\t}","+\t\t} catch (error) {","+\t\t\tthis._logService.warn(`[AgentHostGitService][copyWorktreeIncludeFiles] Failed to copy folder(s)/file(s) to worktree ${worktree.fsPath}: ${error}`);","+\t\t}","+\t}","+"," \tasync addExistingWorktree(repositoryRoot: URI, worktree: URI, branchName: string): Promise<void> {"," \t\tawait this._runGit(repositoryRoot, ['-c', 'checkout.workers=0', 'worktree', 'add', worktree.fsPath, branchName], { timeout: 180_000, throwOnError: true });"," \t}","@@ -330,6 +363,97 @@ export class AgentHostGitService implements IAgentHostGitService {"," \t\treturn output !== undefined ? remoteBranch : undefined;"," \t}"," ","+\tprivate async _getWorktreeIncludePaths(repositoryRoot: URI, globs: readonly string[]): Promise<string[]> {","+\t\tif (globs.length === 0) {","+\t\t\treturn [];","+\t\t}","+","+\t\t// List the git-ignored (but untracked) files: `--others` selects","+\t\t// untracked files, `--ignored` restricts to those matched by an exclude","+\t\t// source, and `--exclude-standard` uses the standard sources (.gitignore,","+\t\t// .git/info/exclude, core.excludesFile). `-z` NUL-separates entries so","+\t\t// paths containing spaces or other special characters survive intact.","+\t\t//","+\t\t// The `--directory` variant additionally collapses a *wholly*-ignored","+\t\t// directory (one containing no tracked files) into a single `dir/`","+\t\t// entry. It is enumerated in parallel and used below to copy such","+\t\t// directories as one recursive unit rather than file-by-file.","+\t\tconst baseArgs = ['ls-files', '--others', '--ignored', '--exclude-standard', '-z'];","+\t\tconst [filesOutput, directoryOutput] = await Promise.all([","+\t\t\tthis._runGit(repositoryRoot, baseArgs, { timeout: 30_000 }),","+\t\t\tthis._runGit(repositoryRoot, [...baseArgs, '--directory', '--no-empty-directory'], { timeout: 30_000 }),","+\t\t]);","+\t\tif (!filesOutput) {","+\t\t\treturn [];","+\t\t}","+","+\t\t// git emits repository-relative, forward-slash paths.","+\t\tconst ignoredFiles = filesOutput.split('\\x00').filter(entry => entry.length > 0);","+\t\tif (ignoredFiles.length === 0) {","+\t\t\treturn [];","+\t\t}","+","+\t\t// Keep only the ignored files that match one of the configured","+\t\t// `git.worktreeIncludeFiles` glob patterns (VS Code glob semantics),","+\t\t// and — in the same pass — tally which wholly-ignored directories","+\t\t// contain an *unmatched* ignored file (and therefore cannot be","+\t\t// collapsed). `git ls-files --directory` reports a wholly-ignored","+\t\t// directory as a single `dir/` entry and never nests these entries","+\t\t// (it stops descending once a directory is wholly ignored), so each","+\t\t// file has at most one containing directory and no de-duplication of","+\t\t// the directory set is required.","+\t\tconst matchers = globs.map(pattern => parse(pattern));","+\t\tconst wholeDirectories = new Set((directoryOutput ?? '')","+\t\t\t.split('\\x00').filter(entry => entry.endsWith('/')));","+","+\t\tconst matchedFiles: string[] = [];","+\t\tconst nonCollapsibleDirectories = new Set<string>();","+\t\tfor (const file of ignoredFiles) {","+\t\t\tif (matchers.some(matcher => matcher(file))) {","+\t\t\t\tmatchedFiles.push(file);","+\t\t\t} else if (wholeDirectories.size > 0) {","+\t\t\t\tconst containingDirectory = findContainingDirectory(file, wholeDirectories);","+\t\t\t\tif (containingDirectory !== undefined) {","+\t\t\t\t\tnonCollapsibleDirectories.add(containingDirectory);","+\t\t\t\t}","+\t\t\t}","+\t\t}","+\t\tif (matchedFiles.length === 0) {","+\t\t\treturn [];","+\t\t}","+","+\t\t// Collapse matched files into their containing directory when the whole","+\t\t// directory can be copied as a single recursive unit — i.e. it is","+\t\t// wholly ignored (so it has no tracked files a recursive copy would","+\t\t// clobber) and every ignored file it contains matched a glob (so","+\t\t// nothing unwanted is copied, tracked by `nonCollapsibleDirectories` above).","+\t\t// This turns a large tree such as `node_modules/` into one copy instead","+\t\t// of one per file, while a partially-matched or partially-tracked","+\t\t// directory falls back to its individual matched files. `--directory`","+\t\t// with `--no-empty-directory` never reports an empty directory, so every","+\t\t// entry in `wholeDirectories` is known to contain at least one ignored file.","+\t\tconst collapsedDirectories = new Set<string>();","+\t\tfor (const dir of wholeDirectories) {","+\t\t\tif (!nonCollapsibleDirectories.has(dir)) {","+\t\t\t\tcollapsedDirectories.add(dir);","+\t\t\t}","+\t\t}","+","+\t\t// Emit the collapsed directories plus every matched file not already","+\t\t// covered by one of them.","+\t\tconst includePaths: string[] = [...collapsedDirectories];","+\t\tfor (const file of matchedFiles) {","+\t\t\tif (","+\t\t\t\tcollapsedDirectories.size === 0 ||","+\t\t\t\tfindContainingDirectory(file, collapsedDirectories) === undefined","+\t\t\t) {","+\t\t\t\tincludePaths.push(file);","+\t\t\t}","+\t\t}","+","+\t\treturn includePaths.map(entry => path.join(repositoryRoot.fsPath, entry));","+\t}","+"," \tasync showBlob(workingDirectory: URI, ref: string, repoRelativePath: string): Promise<VSBuffer | undefined> {"," \t\tconst repositoryRoot = await this.getRepositoryRoot(workingDirectory);"," \t\tif (!repositoryRoot) {","@@ -587,6 +711,26 @@ export class AgentHostGitService implements IAgentHostGitService {"," \t}"," }"," ","+/**","+ * Returns the shallowest directory from `directories` that contains `file`, or","+ * `undefined` if none does. `file` is a repository-relative, forward-slash path","+ * and every entry in `directories` is expected to end with a trailing `/` (as","+ * produced by `git ls-files --directory`). Walking the path's `/` boundaries","+ * and probing the set is O(path depth) per file, avoiding an O(directories)","+ * scan for each file.","+ */","+function findContainingDirectory(file: string, directories: ReadonlySet<string>): string | undefined {","+\tlet index = file.indexOf('/');","+\twhile (index !== -1) {","+\t\tconst prefix = file.slice(0, index + 1);","+\t\tif (directories.has(prefix)) {","+\t\t\treturn prefix;","+\t\t}","+\t\tindex = file.indexOf('/', index + 1);","+\t}","+\treturn undefined;","+}","+"," /**","  * Builds a diagnostic error message for a failed `git` invocation that","  * preserves the reason (timeout / signal / exit c