ce","+ *   ts     - the wall-clock timestamp for the log record","+ *   err    - indirect pointer to error message string","+ *","+ * DESCRIPTION","+ *   Processes all log records configured in <scope>.  For each record, checks","+ *   whether the logger is enabled for the configured severity, evaluates the","+ *   sample expressions into a body string, resolves the optional span reference","+ *   against the runtime context, and emits the log record via the logger's","+ *   log_span operation.","+ *","+ * RETURN VALUE","+ *   Returns FLT_OTEL_RET_OK on success, FLT_OTEL_RET_ERROR on failure.","+ */","+static int flt_otel_scope_run_log_record(struct stream *s, struct filter *f, uint dir, struct flt_otel_conf_scope *scope, struct otelc_logger *logger, const struct timespec *ts, char **err)","+{","+\tstruct flt_otel_conf_log_record *conf_log;","+\tint                              retval = FLT_OTEL_RET_OK;","+","+\tOTELC_FUNC(\"%p, %p, %u, %p, %p, %p, %p:%p\", s, f, dir, scope, logger, ts, OTELC_DPTR_ARGS(err));","+","+\tlist_for_each_entry(conf_log, &(scope->log_records), list) {","+\t\tstruct flt_otel_conf_sample      *sample;","+\t\tstruct flt_otel_conf_sample_expr *expr;","+\t\tstruct sample                     smp;","+\t\tstruct otelc_span                *otel_span = NULL;","+\t\tstruct buffer                     buffer;","+\t\tint                               rc;","+","+\t\tOTELC_DBG(DEBUG, \"run log-record '%s' -> '%s'\", scope->id, conf_log->id);","+","+\t\t/* Skip if the logger is not enabled for this severity. */","+\t\tif (OTELC_OPS(logger, enabled, conf_log->severity) == 0)","+\t\t\tcontinue;","+","+\t\t/* The samples list has exactly one entry. */","+\t\tsample = LIST_NEXT(&(conf_log->samples), typeof(sample), list);","+","+\t\t(void)memset(&buffer, 0, sizeof(buffer));","+","+\t\tif (sample->lf_used) {","+\t\t\t/*","+\t\t\t * Log-format path: evaluate the log-format expression","+\t\t\t * into a dynamically allocated buffer.","+\t\t\t */","+\t\t\tchunk_init(&buffer, OTELC_CALLOC(1, global.tune.bufsize), global.tune.bufsize);","+\t\t\tif (buffer.area != NULL)","+\t\t\t\tbuffer.data = build_logline(s, buffer.area, buffer.size, &(sample->lf_expr));","+\t\t} else {","+\t\t\t/*","+\t\t\t * Bare sample expression path: evaluate each expression","+\t\t\t * and concatenate the results.","+\t\t\t */","+\t\t\tlist_for_each_entry(expr, &(sample->exprs), list) {","+\t\t\t\t(void)memset(&smp, 0, sizeof(smp));","+","+\t\t\t\tif (sample_process(s->be, s->sess, s, dir | SMP_OPT_FINAL, expr->expr, &smp) == NULL) {","+\t\t\t\t\tOTELC_DBG(NOTICE, \"WARNING: failed to fetch '%s'\", expr->fmt_expr);","+","+\t\t\t\t\tretval = FLT_OTEL_RET_ERROR;","+","+\t\t\t\t\tbreak;","+\t\t\t\t}","+","+\t\t\t\tif (buffer.area == NULL) {","+\t\t\t\t\tchunk_init(&buffer, OTELC_CALLOC(1, global.tune.bufsize), global.tune.bufsize);","+\t\t\t\t\tif (buffer.area == NULL)","+\t\t\t\t\t\tbreak;","+\t\t\t\t}","+","+\t\t\t\trc = flt_otel_sample_to_str(&(smp.data), buffer.area + buffer.data, buffer.size - buffer.data, err);","+\t\t\t\tif (rc == FLT_OTEL_RET_ERROR) {","+\t\t\t\t\tretval = FLT_OTEL_RET_ERROR;","+","+\t\t\t\t\tbreak;","+\t\t\t\t}","+","+\t\t\t\tbuffer.data += rc;","+\t\t\t}","+\t\t}","+","+\t\tif (buffer.area == NULL) {","+\t\t\tFLT_OTEL_ERR(\"out of memory\");","+","+\t\t\tretval = FLT_OTEL_RET_ERROR;","+","+\t\t\tcontinue;","+\t\t}","+","+\t\t/*","+\t\t * If the log record references a span, resolve it against the","+\t\t * runtime context.  A missing span is not fatal -- the log","+\t\t * record is emitted without span correlation.","+\t\t */","+\t\tif (conf_log->span != NULL) {","+\t\t\tstruct flt_otel_runtime_context *rt_ctx = FLT_OTEL_RT_CTX(f->ctx);","+\t\t\tstruct flt_otel_scope_span      *sc_span;","+","+\t\t\tlist_for_each_entry(sc_span, &(rt_ctx->spans), list)","+\t\t\t\tif (strcmp(sc_span->id, conf_log->span) == 0) {","+\t\t\t\t\totel_span = sc_span->span;","+","+\t\t\t\t\tbreak;","+\t\t\t\t}","+","+\t\t\tif (otel_span == NULL)","+\t\t\