*","+ * SYNOPSIS","+ *   static int flt_otel_parse_cfg_log_record(const char *file, int line, char **args, const struct flt_otel_parse_data *pdata, char **err)","+ *","+ * ARGUMENTS","+ *   file  - configuration file path","+ *   line  - configuration file line number","+ *   args  - configuration line arguments array","+ *   pdata - keyword metadata (name, usage, argument limits)","+ *   err   - indirect pointer to error message string","+ *","+ * DESCRIPTION","+ *   Parses the \"log-record\" keyword inside an otel-scope section.  The first","+ *   argument is a required severity level string.  Optional keywords \"id\",","+ *   \"event\", \"span\", and \"attr\" follow in any order.  The remaining arguments","+ *   at the end are parsed as fetch expressions or a log-format string.","+ *","+ * RETURN VALUE","+ *   Returns ERR_NONE (== 0) in case of success,","+ *   or a combination of ERR_* flags if an error is encountered.","+ */","+static int flt_otel_parse_cfg_log_record(const char *file, int line, char **args, const struct flt_otel_parse_data *pdata, char **err)","+{","+\tstruct flt_otel_conf_log_record *log;","+\totelc_log_severity_t             severity;","+\tint                              i, retval = ERR_NONE;","+","+\tOTELC_FUNC(\"\\\"%s\\\", %d, %p, %p, %p:%p\", OTELC_STR_ARG(file), line, args, pdata, OTELC_DPTR_ARGS(err));","+","+\t/* Look up the severity level from args[1]. */","+\tseverity = otelc_logger_severity_parse(args[1]);","+\tif (severity == OTELC_LOG_SEVERITY_INVALID) {","+\t\tFLT_OTEL_PARSE_ERR(err, \"'%s' : invalid log severity\", args[1]);","+","+\t\tOTELC_RETURN_INT(retval);","+\t}","+","+\tlog = flt_otel_conf_log_record_init(FLT_OTEL_CONF_HDR_SPECIAL \"log-record\", line, &(flt_otel_current_scope->log_records), err);","+\tif (log == NULL) {","+\t\tretval |= ERR_ABORT | ERR_ALERT;","+","+\t\tOTELC_RETURN_INT(retval);","+\t}","+","+\tlog->severity = severity;","+","+\t/* Parse optional keywords starting from args[2]. */","+\tfor (i = 2; !(retval & ERR_CODE) && FLT_OTEL_ARG_ISVALID(i); i++) {","+\t\tif (FLT_OTEL_PARSE_KEYWORD(i, FLT_OTEL_PARSE_LOG_RECORD_ID)) {","+\t\t\tif (!FLT_OTEL_ARG_ISVALID(i + 1))","+\t\t\t\tFLT_OTEL_PARSE_ERR(err, \"'%s' : too few arguments (use '%s%s')\", args[i], pdata->name, pdata->usage);","+\t\t\telse if (log->event_id != 0)","+\t\t\t\tFLT_OTEL_PARSE_ERR(err, \"'%s' : already set (use '%s%s')\", args[i], pdata->name, pdata->usage);","+\t\t\telse if (!flt_otel_strtoll(args[++i], &(log->event_id), 0, LLONG_MAX, err))","+\t\t\t\tretval |= ERR_ABORT | ERR_ALERT;","+\t\t}","+\t\telse if (FLT_OTEL_PARSE_KEYWORD(i, FLT_OTEL_PARSE_LOG_RECORD_EVENT)) {","+\t\t\tif (!FLT_OTEL_ARG_ISVALID(i + 1))","+\t\t\t\tFLT_OTEL_PARSE_ERR(err, \"'%s' : too few arguments (use '%s%s')\", args[i], pdata->name, pdata->usage);","+\t\t\telse if (log->event_name != NULL)","+\t\t\t\tFLT_OTEL_PARSE_ERR(err, \"'%s' : already set (use '%s%s')\", args[i], pdata->name, pdata->usage);","+\t\t\telse","+\t\t\t\tretval = flt_otel_parse_strdup(&(log->event_name), NULL, args[++i], err, args[0]);","+\t\t}","+\t\telse if (FLT_OTEL_PARSE_KEYWORD(i, FLT_OTEL_PARSE_LOG_RECORD_SPAN)) {","+\t\t\tif (!FLT_OTEL_ARG_ISVALID(i + 1))","+\t\t\t\tFLT_OTEL_PARSE_ERR(err, \"'%s' : too few arguments (use '%s%s')\", args[i], pdata->name, pdata->usage);","+\t\t\telse if (log->span != NULL)","+\t\t\t\tFLT_OTEL_PARSE_ERR(err, \"'%s' : already set (use '%s%s')\", args[i], pdata->name, pdata->usage);","+\t\t\telse","+\t\t\t\tretval = flt_otel_parse_strdup(&(log->span), NULL, args[++i], err, args[0]);","+\t\t}","+\t\telse if (FLT_OTEL_PARSE_KEYWORD(i, FLT_OTEL_PARSE_LOG_RECORD_ATTR)) {","+\t\t\tif (!FLT_OTEL_ARG_ISVALID(i + 1) || !FLT_OTEL_ARG_ISVALID(i + 2))","+\t\t\t\tFLT_OTEL_PARSE_ERR(err, \"'%s' : too few arguments (use '%s%s')\", args[i], pdata->name, pdata->usage);","+\t\t\telse if (otelc_kv_add(&(log->attr), &(log->attr_len), args[i + 1], args[i + 2], strlen(args[i + 2])) == OTELC_RET_ERROR)","+\t\t\t\tFLT_OTEL_PARSE_ERR(err, \"'%s'