onst result = await tokenCredential.getToken();","+    assert.strictEqual(result.token, opaqueToken);","+    assert.strictEqual(result.expiresOnTimestamp, Date.now() + 3600 * 1000);","+  });","+","+  it(\"throws for a whitespace-only token\", function () {","+    assert.throws(() => new AzureCommunicationTokenCredential(\"   \"), /Invalid token/);","+  });","+","+  it(\"accepts a decodable JWT without exp using the fallback expiry\", async function () {","+    const noExpPayload = uint8ArrayToString(","+      stringToUint8Array(JSON.stringify({ sub: \"x\" }), \"utf-8\"),","+      \"base64\",","+    );","+    const noExpToken = `a.${noExpPayload}.c`;","+    const tokenCredential = new AzureCommunicationTokenCredential(noExpToken);","+    const result = await tokenCredential.getToken();","+    assert.strictEqual(result.token, noExpToken);","+    assert.strictEqual(result.expiresOnTimestamp, Date.now() + 10 * 60 * 1000);","+  });","+","+  it(\"proactively refreshes an undecodable token at half its fallback lifetime\", async function () {","+    const tokenRefresher = vi.fn().mockResolvedValue(generateEncryptedToken());","+    new AzureCommunicationTokenCredential({","+      tokenRefresher,","+      refreshProactively: true,","+      token: generateEncryptedToken(),","+    });","+    // 10-min fallback lands on the expiring-soon boundary, so refresh is scheduled at half-life (5 min)","+    vi.advanceTimersByTime(4 * 60 * 1000);","+    expect(tokenRefresher).not.toHaveBeenCalled();","+    vi.advanceTimersByTime(60 * 1000 + 1000);","+    expect(tokenRefresher).toHaveBeenCalledOnce();","+  });","+","+  it(\"accepts a non-JWT (opaque) token string using the fallback expiry\", async function () {","+    const tokenCredential = new AzureCommunicationTokenCredential(\"not.a.real.token\");","+    const result = await tokenCredential.getToken();","+    assert.strictEqual(result.token, \"not.a.real.token\");","+    assert.strictEqual(result.expiresOnTimestamp, Date.now() + 10 * 6