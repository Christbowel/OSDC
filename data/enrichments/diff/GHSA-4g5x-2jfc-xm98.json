;","+","+    return {","+      localPath,","+      contentType: fetched.contentType ?? \"application/octet-stream\",","+      originalUrl: url,","+    };","+  } catch (error: unknown) {","+    console.error(","+      `[tlon-media] Error downloading ${url}: ${error instanceof Error ? error.message : String(error)}`,","+    );","+    return null;","+  }","+}","+","+function getExtensionFromFileName(fileName?: string): string | null {","+  if (!fileName) {","     return null;","   }","+  const ext = path.extname(fileName).replace(/^\\./, \"\");","+  return ext || null;"," }"," "," function getExtensionFromContentType(contentType: string): string | null {",""],"additions":54,"deletions":48,"truncated":false}],"additions":156,"deletions":48,"truncated":false,"file_count":3},"error":null,"fetched_at":"2026-05-20T17:36:07.608292+00:00"}