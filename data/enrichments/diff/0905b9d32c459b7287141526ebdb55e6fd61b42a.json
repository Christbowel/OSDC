 Copyright (c) Microsoft Corporation. All rights reserved.","+ *  Licensed under the MIT License. See License.txt in the project root for license information.","+ *--------------------------------------------------------------------------------------------*/","+","+import type { SessionEventPayload } from '@github/copilot-sdk';","+import { localize } from '../../../../nls.js';","+","+export interface ICopilotSystemNotification {","+\t/** Body shown inside an active turn; cleaned from SDK `system.notification.data.content`. */","+\treadonly content: string;","+\t/** Text for a new system-origin AHP turn; derived from SDK `data.kind` metadata, e.g. shell completion `description`. */","+\treadonly messageText: string;","+}","+","+export function buildCopilotSystemNotification(event: SessionEventPayload<'system.notification'>): ICopilotSystemNotification | undefined {","+\tconst data = event.data;","+\tconst kind = data.kind;","+\tconst content = cleanSystemNotificationContent(data.content);","+\tif (!content) {","+\t\treturn undefined;","+\t}","+","+\tswitch (kind.type) {","+\t\tcase 'shell_completed':","+\t\tcase 'shell_detached_completed': {","+\t\t\tconst description = kind.description;","+\t\t\tconst shellId = kind.shellId;","+\t\t\treturn {","+\t\t\t\tcontent,","+\t\t\t\tmessageText: description","+\t\t\t\t\t? localize('agentHost.copilot.systemNotification.shellDescriptionCompleted', \"`{0}` completed\", description)","+\t\t\t\t\t: shellId","+\t\t\t\t\t\t? localize('agentHost.copilot.systemNotification.shellIdCompleted', \"Shell `{0}` completed\", shellId)","+\t\t\t\t\t\t: localize('agentHost.copilot.systemNotification.shellCompleted', \"Shell completed\"),","+\t\t\t};","+\t\t}","+\t\tcase 'agent_completed':","+\t\t\treturn {","+\t\t\t\tcontent,","+\t\t\t\tmessageText: localize('agentHost.copilot.systemNotification.agentCompleted', \"Background agent completed\"),","+\t\t\t};","+\t\tdefault:","+\t\t\treturn undefined;","+\t}","+}","+","+function cleanSystemNotific