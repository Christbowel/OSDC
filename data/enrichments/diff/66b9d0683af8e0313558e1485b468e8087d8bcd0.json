ilder builder"," "," \t\t\t\t\tforeach (var field in sqlTable.Fields.Where(f => f.IsUpdatable).Except(keys))"," \t\t\t\t\t{","-\t\t\t\t\t\tvar sourceMemberInfo = sourceRef.Type.GetMemberEx(field.ColumnDescriptor.MemberInfo);","-\t\t\t\t\t\tif (sourceMemberInfo is null)","-\t\t\t\t\t\t\tthrow new InvalidOperationException($\"Member '{field.ColumnDescriptor.MemberInfo}' not found in type '{sourceRef.Type}'.\");","-","-\t\t\t\t\t\tvar sourceExpression = ExpressionExtensions.GetMemberGetter(sourceMemberInfo, sourceRef);","-\t\t\t\t\t\tvar targetExpression = ExpressionExtensions.GetMemberGetter(field.ColumnDescriptor.MemberInfo, targetRef);","-\t\t\t\t\t\tvar tgtExpr          = builder.ConvertToSql(mergeContext.TargetContext, targetExpression);","-\t\t\t\t\t\tvar srcExpr          = builder.ConvertToSql(mergeContext.SourceContext, sourceExpression);","+\t\t\t\t\t\tvar sourceExpression = field.ColumnDescriptor.GetMemberAccessExpression(sourceRef);","+\t\t\t\t\t\tvar targetExpression = field.ColumnDescriptor.GetMemberAccessExpression(targetRef);","+","+\t\t\t\t\t\tvar tgtExpr = builder.ConvertToSql(mergeContext.TargetContext, targetExpression);","+\t\t\t\t\t\tvar srcExpr = builder.ConvertToSql(mergeContext.SourceContext, sourceExpression);"," "," \t\t\t\t\t\toperation.Items.Add(new SqlSetExpression(tgtExpr, srcExpr));"," \t\t\t\t\t}"],"additions":7,"deletions":11,"truncated":false},{"path":"Source/LinqToDB/Internal/Linq/Builder/MergeBuilder.UpdateWhenMatchedThenDelete.cs","lines":["@@ -4,6 +4,7 @@"," "," using LinqToDB.Expressions;"," using LinqToDB.Internal.Expressions;","+using LinqToDB.Internal.Mapping;"," using LinqToDB.Internal.SqlQuery;"," "," using static LinqToDB.Internal.Reflection.Methods.LinqToDB.Merge;","@@ -57,8 +58,8 @@ protected override BuildSequenceResult BuildMethodCall(ExpressionBuilder builder"," "," \t\t\t\t\tforeach (var field in sqlTable.Fields.Where(f => f.IsUpdatable).Except(keys))"," \t\t\t\t\t{","-\t\t\t\t\t\tvar sourceExpr = ExpressionExtensions.GetMemberGetter(field.ColumnDescriptor.MemberInfo, sourceProp);","-\t\t\t\t\t\tvar targetExpr = ExpressionExtensions.GetMemberGetter(field.ColumnDescriptor.MemberInfo, targetProp);","+\t\t\t\t\t\tvar sourceExpr = field.ColumnDescriptor.GetMemberAccessExpression(sourceProp);","+\t\t\t\t\t\tvar targetExpr = field.ColumnDescriptor.GetMemberAccessExpression(targetProp);"," "," \t\t\t\t\t\tvar tgtExpr = builder.ConvertToSql(mergeContext.SourceContext.SourceContextRef.BuildContext, targetExpr);"," \t\t\t\t\t\tvar srcExpr = builder.ConvertToSql(mergeContext.SourceContext.SourceContextRef.BuildContext, sourceExpr);"],"additions":3,"deletions":2,"truncated":false},{"path":"Source/LinqToDB/Internal/Mapping/ColumnDescriptorExtensions.cs","lines":["@@ -0,0 +1,57 @@","+﻿using System;","+using System.Linq.Expressions;","+","+using LinqToDB.Expressions;","+using LinqToDB.Internal.Expressions;","+using LinqToDB.Internal.Extensions;","+using LinqToDB.Mapping;","+using LinqToDB.Reflection;","+","+namespace LinqToDB.Internal.Mapping","+{","+\tpublic static class ColumnDescriptorExtensions","+\t{","+\t\t/// <summary>","+\t\t/// Builds a member-access expression from <paramref name=\"instance\"/> to the CLR","+\t\t/// member this column is mapped to, following the dot-path in","+\t\t/// <see cref=\"ColumnDescriptor.MemberName\"/> when the mapping is nested","+\t\t/// (e.g. <c>o =&gt; o.Sub.Field</c>).","+\t\t/// </summary>","+\t\t/// <remarks>","+\t\t/// Unlike <see cref=\"MemberAccessor.GetGetterExpression(Expression)\"/>, the result has no","+\t\t/// null-check block wrapping intermediate reference-type members, so it is","+\t\t/// suitable for SQL conversion. When <paramref name=\"instance\"/>'s CLR type","+\t\t/// doesn't match the column's entity root (e.g. <c>Merge().Using&lt;TSource&gt;()</c>","+\t\t/// with TSource ≠ TTarget), the column's leaf member is looked up on the","+\t\t/// instance type by name; for dynamic columns the call is forwarded through","+\t\t/// <see cref=\"ExpressionExtensions.GetMemberGetter\"/>, which may return a","+\t\t/// <see cref=\"MethodCallExpression\"/>.","+\t\t/// </remarks>","+\t\t/// <exception cref=\"InvalidOperationException\">","+\t\t/// Thrown when no matching member exists on <paramref name=\"instance\"/>'s type.","+\t\t/// </exception>","+\t\tpublic static Expression GetMemberAccessExpression(this ColumnDescriptor descriptor, Expression instance)","+\t\t{","+\t\t\t// IsComplex is true only for nested member paths and dynamic columns. Gating on it (rather than","+\t\t\t// MemberName.Contains('.')) keeps explicit-interface members — whose CLR name itself contains","+\t\t\t// dots — on the leaf-lookup branch below; dynamic columns are excluded there too and resolved","+\t\t\t// via GetMemberGetter. Mirrors the canonical guard at TableBuilder.TableContext.cs.","+\t\t\tif (descriptor.MemberAccessor.IsComplex","+\t\t\t\t&& !descriptor.MemberInfo.IsDynamicColumnProperty","+\t\t\t\t&& instance.Type == descriptor.MemberAccessor.TypeAccessor.Type)","+\t\t\t{","+\t\t\t\tvar expr = instance;","+\t\t\t\tforeach (var part in descriptor.MemberName.Split('.'))","+\t\t\t\t\texpr = ExpressionHelper.PropertyOrField(expr, part);","+\t\t\t\treturn expr;","+\t\t\t}","+","+\t\t\tvar leaf = instance.Type.GetMemberEx(descriptor.MemberInfo);","+\t\t\tif (leaf is null)","+\t\t\t\tthrow new InvalidOperationException(","+\t\t\t\t\t$\"Member '{descriptor.MemberInfo}' not found in type '{instance.Type}'.\");","+","+\t\t\treturn ExpressionExtensions.GetMemberGetter(leaf, instance);","+\t\t}","+\t}","+}"],"additions":57,"deletions":0,"truncated":false},{"path":"Tests/Linq/Update/MergeTests.ComplexProperty.cs","lines":["@@ -0,0 +1,327 @@","+﻿using System.Linq;","+","+using LinqToDB;","+using LinqToDB.Mapping;","+","+using NUnit.Framework;","+","+namespace Tests.xUpdate","+{","+\tpublic partial class MergeTests","+\t{","+\t\t// Exercises FluentMappingBuilder's nested-member column mapping","+\t\t// (e.g. `o => o.Nested.Field`), where the column's CLR path crosses an","+\t\t// intermediate object on the entity graph. The implicit-setter branches of","+\t\t// MergeBuilder.UpdateWhenMatched / UpdateWhenMatchedThenDelete must walk the","+\t\t// full path (Target -> Nested -> Field) rather than look up the leaf member","+\t\t// by name on the entity root.","+","+\t\tpublic sealed class ComplexPropertyTarget","+\t\t{","+\t\t\tpublic int                   Id     { get; set; }","+\t\t\tpublic string?               Code   { get; set; }","+\t\t\tpublic ComplexPropertyNested Nested { get; set; } = new();","+\t\t}","+","+\t\tpublic sealed class ComplexPropertyNested","+\t\t{","+\t\t\tpublic bool Field { get; set; }","+\t\t}","+","+\t\tstatic MappingSchema BuildComplexPropertyMappingSchema()","+\t\t{","+\t\t\tvar ms = new MappingSchema();","+","+\t\t\tnew FluentMappingBuilder(ms)","+\t\t\t\t.Entity<ComplexPropertyTarget>()","+\t\t\t\t\t.HasTableName(\"ComplexPropertyTarget\")","+\t\t\t\t\t.Property(o => o.Id).IsPrimaryKey().HasColumnName(\"Id\")","+\t\t\t\t\t.Property(o => o.Code).HasColumnName(\"Code\").HasLength(50)","+\t\t\t\t\t.Property(o => o.Nested.Field).HasColumnName(\"Field\")","+\t\t\t\t.Build();","+","+\t\t\treturn ms;","+\t\t}","+","+\t\t[Test]","+\t\tpublic void ComplexProperty_UpdateWhenMatched([MergeDataContextSource] string context)","+\t\t{","+\t\t\tusing var db    = GetDataContext(context, BuildComplexPropertyMappingSchema());","+\t\t\tusing var table = db.CreateLocalTable<ComplexPropertyTarget>();","+","+\t\t\tdb.Insert(new ComplexPropertyTarget { Id = 1, Code = \"first\",   Nested = new ComplexPropertyNested { Field = false } });","+\t\t\tdb.Insert(new ComplexPropertyTarget { Id = 2, Code = \"skipped\", Nested = new ComplexPropertyNested { Field = false } });","+","+\t\t\tvar source = new[]","+\t\t\t{","+\t\t\t\tnew ComplexPropertyTarget { Id = 1, Code = \"first-updated\", Nested = new ComplexPropertyNested { Field = true } },","+\t\t\t};","+","+\t\t\tvar rows = table.Merge()","+\t\t\t\t.Using(source)","+\t\t\t\t.OnTargetKey()","+\t\t\t\t.UpdateWhenMatched()","+\t\t\t\t.Merge();","+","+\t\t\tvar result = table.OrderBy(r => r.Id).ToList();","+","+\t\t\tusing (Assert.EnterMultipleScope())","+\t\t\t{","+\t\t\t\tAssertRowCount(1, rows, context);","+\t\t\t\tAssert.That(result,                 Has.Count.EqualTo(2));","+\t\t\t\tAssert.That(result[0].Id,           Is.EqualTo(1));","+\t\t\t\tAssert.That(result[0].Code,         Is.EqualTo(\"first-updated\"));","+\t\t\t\tAssert.That(result[0].Nested.Field, Is.True);","+\t\t\t\tAssert.That(result[1].Id,           Is.EqualTo(2));","+\t\t\t\tAssert.That(result[1].Code,         Is.EqualTo(\"skipped\"));","+\t\t\t\tAssert.That(result[1].Nested.Field, Is.False);","+\t\t\t}","+\t\t}","+","+\t\t[Test]","+\t\tpublic void ComplexProperty_InsertUpdate([MergeDataContextSource] string context)","+\t\t{","+\t\t\tusing var db    = GetDataContext(context, BuildComplexPropertyMappingSchema());","+\t\t\tusing var table = db.CreateLocalTable<ComplexPropertyTarget>();","+","+\t\t\tdb.Insert(new ComplexPropertyTarget { Id = 1, Code = \"alpha\", Nested = new ComplexPropertyNested { Field = false } });","+\t\t\tdb.Insert(new ComplexPropertyTarget { Id = 2, Code = \"beta\",  Nested = new ComplexPropertyNested { Field = false } });","+","+\t\t\tvar rows = table.Merge()","+\t\t\t\t.Using(new[]","+\t\t\t\t{","+\t\t\t\t\tnew ComplexPropertyTarget { Id = 1, Code = \"alpha-new\", Nested = new ComplexPropertyNested { Field = true } },","+\t\t\t\t\tnew ComplexPropertyTarget { Id = 3, Code = \"gamma\",     Nested = new ComplexPropertyNested { Field = true } },","+\t\t\t\t})","+\t\t\t\t.OnTargetKey()","+\t\t\t\t.UpdateWhenMatched()","+\t\t\t\t.InsertWhenNotMatched()","+\t\t\t\t.Merge();","+","+\t\t\tvar result = table.OrderBy(r => r.Id).ToList();","+","+\t\t\tusing (Assert.EnterMultipleScope())","+\t\t\t{","+\t\t\t\tAssertRowCount(2, rows, context);","+\t\t\t\tAssert.That(result,                  Has.Count.EqualTo(3));","+\t\t\t\tAssert.That(result[0].Id,            Is.EqualTo(1));","+\t\t\t\tAssert.That(result[0].Code,          Is.EqualTo(\"alpha-new\"));","+\t\t\t\tAssert.That(result[0].Nested.Field,  Is.True);","+\t\t\t\tAssert.That(result[1].Id,            Is.EqualTo(2));","+\t\t\t\tAssert.That(result[1].Code,          Is.EqualTo(\"beta\"));","+\t\t\t\tAssert.That(result[1].Nested.Field,  Is.False);","+\t\t\t\tAssert.That(result[2].Id,            Is.EqualTo(3));","+\t\t\t\tAssert.That(result[2].Code,          Is.EqualTo(\"gamma\"));","+\t\t\t\tAssert.That(result[2].Nested.Field,  Is.True);","+\t\t\t}","+\t\t}","+","+\t\t[Test]","+\t\tpublic void ComplexProperty_UpdateWithDelete([IncludeDataSources(true, TestProvName.AllOracle)] string context)","+\t\t{","+\t\t\tusing var db    = GetDataContext(context, BuildComplexPropertyMappingSchema());","+\t\t\tusing var table = db.CreateLocalTable<ComplexPropertyTarget>();","+","+\t\t\tdb.Insert(new ComplexPropertyTarget { Id = 1, Code = \"keep\",   Nested = new ComplexPropertyNested { Field = false } });","+\t\t\tdb.Insert(new ComplexPropertyTarget { Id = 2, Code = \"remove\", Nested = new ComplexPropertyNested { Field = false } });","+","+\t\t\tvar source = new[]","+\t\t\t{","+\t\t\t\tnew ComplexPropertyTarget { Id = 1, Code = \"keep-updated\",   Nested = new ComplexPropertyNested { Field = true } },","+\t\t\t\tnew ComplexPropertyTarget { Id = 2, Code = \"remove-updated\", Nested = new ComplexPropertyNested { Field = true } },","+\t\t\t};","+","+\t\t\ttable.Merge()","+\t\t\t\t.Using(source)","+\t\t\t\t.OnTargetKey()","+\t\t\t\t.UpdateWhenMatchedAndThenDelete((t, s) => true, (t, s) => s.Code == \"remove-updated\")","+\t\t\t\t.Merge();","+","+\t\t\tvar result = table.OrderBy(r => r.Id).ToList();","+","+\t\t\tusing (Assert.EnterMultipleScope())","+\t\t\t{","+\t\t\t\tAssert.That(result,                 Has.Count.EqualTo(1));","+\t\t\t\tAssert.That(result[0].Id,           Is.EqualTo(1));","+\t\t\t\tAssert.That(result[0].Code,         Is.EqualTo(\"keep-updated\"));","+\t\t\t\tAssert.That(result[0].Nested.Field, Is.True);","+\t\t\t}","+\t\t}","+","+\t\t// An explicit interface implementation's CLR member name itself contains dots","+\t\t// (e.g. \"…IExplicitComplexProperty.Field\"). The implicit-setter dot-path walk must NOT","+\t\t// treat that as a nested member path — it has to fall through to the leaf-member lookup,","+\t\t// otherwise MERGE query build throws InvalidOperationException. Regression for the #5543 fix.","+","+\t\tpublic interface IExplicitComplexProperty","+\t\t{","+\t\t\tbool Field { get; set; }","+\t\t}","+","+\t\tpublic sealed class ExplicitComplexPropertyTarget : IExplicitComplexProperty","+\t\t{","+\t\t\tpublic int Id { get; set; }","+","+\t\t\t[Column(\"Field\")]","+\t\t\tbool IExplicitComplexProperty.Field { get; set; }","+\t\t}","+","+\t\t[Test]","+\t\tpublic void ExplicitInterfaceProperty_UpdateWhenMatched([MergeDataContextSource] string context)","+\t\t{","+\t\t\tvar ms = new MappingSchema();","+","+\t\t\tnew FluentMappingBuilder(ms)","+\t\t\t\t.Entity<ExplicitComplexPropertyTarget>()","+\t\t\t\t\t.HasTableName(\"ExplicitComplexPropertyTarget\")","+\t\t\t\t\t.Property(o => o.Id).IsPrimaryKey().HasColumnName(\"Id\")","+\t\t\t\t.Build();","+","+\t\t\tvar target = new ExplicitComplexPropertyTarget { Id = 1 };","+\t\t\t((IExplicitComplexProperty)target).Field = false;","+","+\t\t\tvar source = new ExplicitComplexPropertyTarget { Id = 1 };","+\t\t\t((IExplicitComplexProperty)source).Field = true;","+","+\t\t\tusing var db    = GetDataContext(context, ms);","+\t\t\tusing var table = db.CreateLocalTable<ExplicitComplexPropertyTarget>();","+","+\t\t\tdb.Insert(target);","+","+\t\t\ttable.Merge()","+\t\t\t\t.Using(new[] { source })","+\t\t\t\t.OnTargetKey()","+\t\t\t\t.UpdateWhenMatched()","+\t\t\t\t.Merge();","+","+\t\t\tvar result = table.Single();","+","+\t\t\tAssert.That(((IExplicitComplexProperty)result).Field, Is.True);","+\t\t}","+","+\t\t// The inheritance discriminator can itself be mapped through a nested member path","+\t\t// (Property(o => o.Meta.Kind)). This PR routes the discriminator 'is'/OfType predicate sites","+\t\t// (ExpressionBuilder.SqlBuilder.cs / ExpressionBuildVisitor.cs) through the same helper, so the","+\t\t// nested path has to be dot-walked there the way the MERGE implicit setters are. Not a MERGE test,","+\t\t// but it lives here to keep the #5543 nested-mapping regressions together.","+","+\t\tpublic class NestedDiscriminatorMeta","+\t\t{","+\t\t\tpublic string? Kind { get; set; }","+\t\t}","+","+\t\tpublic class NestedDiscriminatorBase","+\t\t{","+\t\t\tpublic int                     Id   { get; set; }","+\t\t\tpublic NestedDiscriminatorMeta Meta { get; set; } = new();","+\t\t}","+","+\t\tpublic sealed class NestedDiscriminatorDog : NestedDiscriminatorBase","+\t\t{","+\t\t\tpublic string? DogName { get; set; }","+\t\t}","+","+\t\tpublic sealed class NestedDiscriminatorCat : NestedDiscriminatorBase","+\t\t{","+\t\t\tpublic string? CatName { get; set; }","+\t\t}","+","+\t\tstatic MappingSchema BuildNestedDiscriminatorMappingSchema()","+\t\t{","+\t\t\tvar ms = new MappingSchema();","+","+\t\t\tvar b = new FluentMappingBuilder(ms);","+","+\t\t\tb.Entity<NestedDiscriminatorBase>()","+\t\t\t\t.HasTableName(\"NestedDiscriminator\")","+\t\t\t\t.Inheritance(o => o.Meta.Kind, \"Dog\", typeof(NestedDiscriminatorDog))","+\t\t\t\t.Inheritance(o => o.Meta.Kind, \"Cat\", typeof(NestedDiscriminatorCat))","+\t\t\t\t.Property(o => o.Id).IsPrimaryKey().HasColumnName(\"Id\")","+\t\t\t\t.Property(o => o.Meta.Kind).IsDiscriminator().HasColumnName(\"Kind\").HasLength(20);","+","+\t\t\tb.Entity<NestedDiscriminatorDog>()","+\t\t\t\t.HasTableName(\"NestedDiscriminator\")","+\t\t\t\t.Property(o => o.DogName).HasColumnName(\"DogName\").HasLength(40);","+","+\t\t\tb.Entity<NestedDiscriminatorCat>()","+\t\t\t\t.HasTableName(\"NestedDiscriminator\")","+\t\t\t\t.Property(o => o.CatName).HasColumnName(\"CatName\").HasLength(40);","+","+\t\t\tb.Build();","+","+\t\t\treturn ms;","+\t\t}","+","+\t\t[Test]","+\t\tpublic void ComplexProperty_NestedDiscriminator([DataSources] string context)","+\t\t{","+\t\t\tusing var db    = GetDataContext(context, BuildNestedDiscriminatorMappingSchema());","+\t\t\tusing var table = db.CreateLocalTable<NestedDiscriminatorBase>();","+","+\t\t\tdb.Insert(new NestedDiscriminatorDog { Id = 1, DogName = \"Rex\", Meta = new() { Kind = \"Dog\" } });","+\t\t\tdb.Insert(new NestedDiscriminatorCat { Id = 2, CatName = \"Tom\", Meta = new() { Kind = \"Cat\" } });","+","+\t\t\tvar dogs = table.OfType<NestedDiscriminatorDog>().OrderBy(d => d.Id).ToList();","+","+\t\t\tusing (Assert.EnterMultipleScope())","+\t\t\t{","+\t\t\t\tAssert.That(dogs,            Has.Count.EqualTo(1));","+\t\t\t\tAssert.That(dogs[0].Id,      Is.EqualTo(1));","+\t\t\t\tAssert.That(dogs[0].DogName, Is.EqualTo(\"Rex\"));","+\t\t\t}","+\t\t}","+","+\t\t// OnTargetKey() builds its primary-key match condition through the same GetMemberAccessExpression","+\t\t// helper, so a primary key mapped via a nested member path ([Column(MemberName = \"Key.Value\", IsPrimaryKey = true)])","+\t\t// must dot-walk both sides of the ON condition (t.Key.Value = s.Key.Value). Before the MergeBuilder.On.cs","+\t\t// fix this threw \"Member 'Value' is not defined in 't'\" because the leaf member was looked up on the entity root.","+","+\t\t[Table(\"NestedKeyTarget\")]","+\t\t[Column(\"Id\", MemberName = \"Key.Value\", IsPrimaryKey = true)]","+\t\tpublic sealed class NestedKeyTarget","+\t\t{","+\t\t\tpublic NestedKey Key { get; set; } = new();","+","+\t\t\t[Column(\"Code\", Length = 50)]","+\t\t\tpublic string? Code { get; set; }","+\t\t}","+","+\t\tpublic sealed class NestedKey","+\t\t{","+\t\t\tpublic int Value { get; set; }","+\t\t}","+","+\t\t[Test]","+\t\tpublic void ComplexProperty_NestedPrimaryKey_OnTargetKey([MergeDataContextSource] string context)","+\t\t{","+\t\t\tusing var db    = GetDataContext(context);","+\t\t\tusing var table = db.CreateLocalTable<Nested