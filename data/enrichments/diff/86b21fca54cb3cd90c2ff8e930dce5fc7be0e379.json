{"id":"86b21fca54cb3cd90c2ff8e930dce5fc7be0e379","axis":"silent","repo":"grafana/tempo","sha":"86b21fca54cb3cd90c2ff8e930dce5fc7be0e379","parsed":{"files":[{"path":"CHANGELOG.md","lines":["@@ -1,5 +1,6 @@"," ## main / unreleased"," ","+* [FEATURE] metrics-generator: add `service-graphs-*` subprocessors and an opt-in `traces_service_graph_connection_info` presence gauge for topology detection under heavy sampling. [#7202](https://github.com/grafana/tempo/pull/7202) (@jcreixell)"," * [FEATURE] Support arithmetic operations in TraceQL Metrics [#6866](https://github.com/grafana/tempo/pull/6866) (@ruslan-mikhailov)"," * [FEATURE] jsonnet: Add KEDA autoscaling for live-store via Prometheus trigger on expected bytes held. Enable with `live_store.keda.enabled: true`. Configure block-builder coupling via `live_store.keda.block_builder_scaling`: `'rollout-operator'` (default, requires `rollout_operator_replica_template_access_enabled: true`) mirrors live-store zone-a replicas to block-builder; `'keda'` creates a dedicated block-builder KEDA ScaledObject using a kubernetes-workload trigger without requiring rollout-operator RBAC. [#7142](https://github.com/grafana/tempo/pull/7142) (@zachfi)"," * [ENHANCEMENT] cache: enforce a configurable MaxItemSize for Redis. [#7311](https://github.com/grafana/tempo/pull/7311) (@electron0zero)"],"additions":1,"deletions":0,"truncated":false},{"path":"cmd/tempo/app/overrides_validation_test.go","lines":["@@ -314,6 +314,25 @@ func Test_overridesValidator(t *testing.T) {"," \t\t\t},"," \t\t\texpErr: fmt.Sprintf(\"metrics_generator.processor \\\"span-span\\\" is not a known processor, valid values: %v\", validation.SupportedProcessors),"," \t\t},","+\t\t{","+\t\t\tname: \"metrics_generator.processor - all supported names including sub-names\",","+\t\t\tcfg:  Config{},","+\t\t\tlimits: client.Limits{","+\t\t\t\tMetricsGenerator: client.LimitsMetricsGenerator{","+\t\t\t\t\tProcessors: &listtomap.ListToMap{","+\t\t\t\t\t\tprocessor.ServiceGraphsName:               {},","+\t\t\t\t\t\tprocessor.ServiceGraphsRequestName:        {},","+\t\t\t\t\t\tprocessor.ServiceGraphsLatencyName:        {},","+\t\t\t\t\t\tprocessor.ServiceGraphsConnectionInfoName: {},","+\t\t\t\t\t\tprocessor.SpanMetricsName:                 {},","+\t\t\t\t\t\tprocessor.SpanMetricsCountName:            {},","+\t\t\t\t\t\tprocessor.SpanMetricsLatencyName:          {},","+\t\t\t\t\t\tprocessor.SpanMetricsSizeName:             {},","+\t\t\t\t\t\tprocessor.HostInfoName:                    {},","+\t\t\t\t\t},","+\t\t\t\t},","+\t\t\t},","+\t\t},"," \t\t{"," \t\t\tname: \"filter policies\","," \t\t\tcfg:  Config{},"],"additions":19,"deletions":0,"truncated":false},{"path":"docs/sources/tempo/configuration/_index.md","lines":["@@ -2357,7 +2357,17 @@ overrides:","       # Per-user configuration of the metrics-generator processors. The following processors are","       # supported:","       #  - service-graphs","+      #  - service-graphs-request          only emits traces_service_graph_request_total and","+      #                                     traces_service_graph_request_failed_total","+      #  - service-graphs-latency          only emits the request_server_seconds,","+      #                                     request_client_seconds, and request_messaging_system_seconds","+      #                                     histograms","+      #  - service-graphs-connection-info  only emits traces_service_graph_connection_info;","+      #                                     opt-in, not enabled by the bare \"service-graphs\" name","       #  - span-metrics","+      #  - span-metrics-count              (only emits traces_spanmetrics_calls_total)","+      #  - span-metrics-latency            (only emits traces_spanmetrics_latency histogram)","+      #  - span-metrics-size               (only emits traces_spanmetrics_size_total)","       #  - host-info","       [processors: <list of strings>]"," "],"additions":10,"deletions":0,"truncated":false},{"path":"docs/sources/tempo/configuration/manifest.md","lines":["@@ -463,10 +463,6 @@ metrics_generator:","             enable_target_info: false","             span_multiplier_key: \"\"","             enable_tracestate_span_multiplier: false","-            subprocessors:","-                0: true","-                1: true","-                2: true","             filter_policies: []","             target_info_excluded_dimensions: []","             enable_instance_label: true"],"additions":0,"deletions":4,"truncated":false},{"path":"docs/sources/tempo/metrics-from-traces/service_graphs/_index.md","lines":["@@ -68,6 +68,43 @@ The processor identifies a database node when the span has at least one `db.name"," "," The processor determines the database node name using the following span attributes in order of precedence: `peer.service`, `server.address`, `network.peer.address:network.peer.port`, `db.namespace`, `db.name`."," ","+### Enabling specific metrics (subprocessors)","+","+Instead of enabling all service graph metrics, you can enable individual metric categories using subprocessors in the overrides configuration:","+","+- `service-graphs-request` — Enables only the `traces_service_graph_request_total` and `traces_service_graph_request_failed_total` counters","+- `service-graphs-latency` — Enables only the `traces_service_graph_request_server_seconds` and `traces_service_graph_request_client_seconds` histograms. The `traces_service_graph_request_messaging_system_seconds` histogram additionally requires `enable_messaging_system_latency_histogram: true` in the metrics-generator config.","+- `service-graphs-connection-info` — Enables only the `traces_service_graph_connection_info` gauge","+","+The bare `service-graphs` name enables request and latency metrics.","+The `service-graphs-connection-info` subprocessor is off by default and must be listed explicitly.","+Listing it alongside the bare name enables the subprocessor additively without disabling RED.","+Listing `service-graphs-request` or `service-graphs-latency` alongside the bare name is redundant and silently dropped.","+","+Example overrides configuration:","+","+```yaml","+overrides:","+  defaults:","+    metrics_generator:","+      processors:","+        - service-graphs","+        - service-graphs-connection-info","+```","+","+### Connection information metric","+","+The `traces_service_graph_connection_info` metric is a presence-only gauge held at `1` while an edge between two services is being observed.","+","+The metric is intended for topology discovery rather than rate calculations.","+A single observed span keeps the gauge present, so service-to-service relationships stay visible on low-traffic endpoints even when `rate(traces_service_graph_request_total[...])` is noisy or zero under aggressive head sampling.","+","+Example query with a long range window:","+","+```promql","+last_over_time(traces_service_graph_connection_info[1h]) > 0","+```","+"," ### Metrics"," "," The following metrics are exported:","@@ -81,6 +118,7 @@ The following metrics are exported:"," | `traces_service_graph_request_server_seconds`           | Histogram | client, server, connection_type | Time for a request between two nodes as seen from the server                                               |"," | `traces_service_graph_request_client_seconds`           | Histogram | client, server, connection_type | Time for a request between two nodes as seen from the client                                               |"," | `traces_service_graph_request_messaging_system_seconds` | Histogram | client, server, connection_type | (Off by default) Time between publisher and consumer for services communicating through a messaging system |","+| `traces_service_graph_connection_info`                  | Gauge     | client, server, connection_type | (Off by default) Presence signal for service-to-service edges (value 1 per active edge)                    |"," | `traces_service_graph_unpaired_spans_total`             | Counter   | client, server, connection_type | Total count of unpaired spans                                                                              |"," | `traces_service_graph_dropped_spans_total`              | Counter   | client, server, connection_type | Total count of dropped spans                                                                               |"," "],"additions":38,"deletions":0,"truncated":false},{"path":"integration/metrics-generator/config-connection-info.yaml","lines":["@@ -0,0 +1,13 @@","+metrics_generator:","+  processor:","+    service_graphs:","+      histogram_buckets: [1, 2]  # seconds","+    span_metrics:","+      histogram_buckets: [1, 2]","+","+overrides:","+  defaults:","+    metrics_generator:","+      max_active_series: 1000","+      # Bare \"service-graphs\" keeps RED defaults; the sub-name additively opts in to connection_info.","+      processors: [service-graphs, service-graphs-connection-info, span-metrics]"],"additions":13,"deletions":0,"truncated":false},{"path":"integration/metrics-generator/metrics_generator_test.go","lines":["@@ -24,6 +24,7 @@ const ("," \tconfigMetricsGenerator                = \"config-remote-write.yaml\""," \tconfigMetricsGeneratorTargetInfo      = \"config-targetinfo.yaml\""," \tconfigMetricsGeneratorMessagingSystem = \"config-messaging-system.yaml\"","+\tconfigMetricsGeneratorConnectionInfo  = \"config-connection-info.yaml\""," )"," "," func TestMetricsGeneratorSingleBinaryPushesInProcess(t *testing.T) {","@@ -211,6 +212,74 @@ func TestMetricsGeneratorRemoteWrite(t *testing.T) {"," \t})"," }"," ","+func TestMetricsGeneratorConnectionInfo(t *testing.T) {","+\tutil.RunIntegrationTests(t, util.TestHarnessConfig{","+\t\tConfigOverlay: configMetricsGeneratorConnectionInfo,","+\t\tComponents:    util.ComponentsMetricsGeneration,","+\t}, func(h *util.TempoHarness) {","+\t\th.WaitTracesWritable(t)","+","+\t\t// Send a single client/server span pair.","+\t\tr := rand.New(rand.NewSource(time.Now().UnixMilli()))","+\t\ttraceIDLow := r.Int63()   // nolint:gosec // G404","+\t\ttraceIDHigh := r.Int63()  // nolint:gosec // G404","+\t\tparentSpanID := r.Int63() // nolint:gosec // G404","+","+\t\trequire.NoError(t, h.WriteJaegerBatch(&thrift.Batch{","+\t\t\tProcess: &thrift.Process{ServiceName: \"lb\"},","+\t\t\tSpans: []*thrift.Span{","+\t\t\t\t{","+\t\t\t\t\tTraceIdLow:    traceIDLow,","+\t\t\t\t\tTraceIdHigh:   traceIDHigh,","+\t\t\t\t\tSpanId:        parentSpanID,","+\t\t\t\t\tParentSpanId:  0,","+\t\t\t\t\tOperationName: \"lb-get\",","+\t\t\t\t\tStartTime:     time.Now().UnixMicro(),","+\t\t\t\t\tDuration:      int64(2 * time.Second / time.Microsecond),","+\t\t\t\t\tTags:          []*thrift.Tag{{Key: \"span.kind\", VStr: stringPtr(\"client\")}},","+\t\t\t\t},","+\t\t\t},","+\t\t}, \"\"))","+","+\t\trequire.NoError(t, h.WriteJaegerBatch(&thrift.Batch{","+\t\t\tProcess: &thrift.Process{ServiceName: \"app\"},","+\t\t\tSpans: []*thrift.Span{","+\t\t\t\t{","+\t\t\t\t\tTraceIdLow:    traceIDLow,","+\t\t\t\t\tTraceIdHigh:   traceIDHigh,","+\t\t\t\t\tSpanId:        r.Int63(), // nolint:gosec // G404","+\t\t\t\t\tParentSpanId:  parentSpanID,","+\t\t\t\t\tOperationName: \"app-handle\",","+\t\t\t\t\tStartTime:     time.Now().UnixMicro(),","+\t\t\t\t\tDuration:      int64(1 * time.Second / time.Microsecond),","+\t\t\t\t\tTags:          []*thrift.Tag{{Key: \"span.kind\", VStr: stringPtr(\"server\")}},","+\t\t\t\t},","+\t\t\t},","+\t\t}, \"\"))","+","+\t\t// Wait for connection_info specifically — it's only present once the gauge is remote-written.","+\t\tvar metricFamilies map[string]*io_prometheus_client.MetricFamily","+\t\tvar err error","+\t\tfor {","+\t\t\tmetricFamilies, err = extractMetricsFromPrometheus(h.Services[util.ServicePrometheus], `traces_service_graph_connection_info`)","+\t\t\trequire.NoError(t, err)","+\t\t\tif _, ok := metricFamilies[\"traces_service_graph_connection_info\"]; ok {","+\t\t\t\tbreak","+\t\t\t}","+\t\t\ttime.Sleep(time.Second)","+\t\t}","+","+\t\tlbls := []string{\"client\", \"lb\", \"server\", \"app\"}","+\t\t// Gauge held at 1 per active edge.","+\t\tassert.Equal(t, 1.0, sumValues(metricFamilies, \"traces_service_graph_connection_info\", lbls))","+","+\t\t// Sanity: RED metrics also still emit (bare service-graphs + sub-name is additive).","+\t\tredMetrics, err := extractMetricsFromPrometheus(h.Services[util.ServicePrometheus], `traces_service_graph_request_total`)","+\t\trequire.NoError(t, err)","+\t\tassert.Equal(t, 1.0, sumValues(redMetrics, \"traces_service_graph_request_total\", lbls))","+\t})","+}","+"," func TestMetricsGeneratorTargetInfoEnabled(t *testing.T) {"," \tutil.RunIntegrationTests(t, util.TestHarnessConfig{"," \t\tConfigOverlay: configMetricsGeneratorTargetInfo,"],"additions":69,"deletions":0,"truncated":false},{"path":"modules/generator/config.go","lines":["@@ -269,5 +269,11 @@ func (cfg *ProcessorConfig) copyWithOverrides(o metricsGeneratorOverrides, userI"," \t}"," \tcopyCfg.SpanMetrics.Subprocessors = copySubprocessors"," ","+\tcopyServiceGraphSubprocessors := make(map[servicegraphs.Subprocessor]bool)","+\tfor sp, enabled := range cfg.ServiceGraphs.Subprocessors {","+\t\tcopyServiceGraphSubprocessors[sp] = enabled","+\t}","+\tcopyCfg.ServiceGraphs.Subprocessors = copyServiceGraphSubprocessors","+"," \treturn copyCfg, nil"," }"],"additions":6,"deletions":0,"truncated":false},{"path":"modules/generator/config_test.go","lines":["@@ -18,6 +18,7 @@ func TestProcessorConfig_copyWithOverrides(t *testing.T) {"," \t\tServiceGraphs: servicegraphs.Config{"," \t\t\tHistogramBuckets: []float64{1},"," \t\t\tDimensions:       []string{},","+\t\t\tSubprocessors:    map[servicegraphs.Subprocessor]bool{},"," \t\t},"," \t\tSpanMetrics: spanmetrics.Config{"," \t\t\tHistogramBuckets:    []float64{1, 2},"],"additions":1,"deletions":0,"truncated":false},{"path":"modules/generator/instance.go","lines":["@@ -151,9 +151,14 @@ func (i *instance) watchOverrides() {"," \t}"," }"," ","-// Look at the processors defined and see if any are actually span-metrics subprocessors","-// If they are, set the appropriate flags in the spanmetrics struct","+// updateSubprocessors resolves subprocessor sub-names into Subprocessors flags on the parent processor's config."," func (i *instance) updateSubprocessors(desiredProcessors map[string]struct{}, desiredCfg ProcessorConfig) (map[string]struct{}, ProcessorConfig) {","+\tdesiredProcessors, desiredCfg = i.updateSpanMetricsSubprocessors(desiredProcessors, desiredCfg)","+\tdesiredProcessors, desiredCfg = i.updateServiceGraphsSubprocessors(desiredProcessors, desiredCfg)","+\treturn desiredProcessors, desiredCfg","+}","+","+func (i *instance) updateSpanMetricsSubprocessors(desiredProcessors map[string]struct{}, desiredCfg ProcessorConfig) (map[string]struct{}, ProcessorConfig) {"," \tdesiredProcessorsFound := false"," \tfor d := range desiredProcessors {"," \t\tif (d == processor.SpanMetricsName) || (spanmetrics.ParseSubprocessor(d)) {","@@ -200,6 +205,56 @@ func (i *instance) updateSubprocessors(desiredProcessors map[string]struct{}, de"," \treturn newDesiredProcessors, desiredCfg"," }"," ","+// updateServiceGraphsSubprocessors resolves service-graphs-* sub-names. Bare \"service-graphs\"","+// enables Request and Latency; listing service-graphs-connection-info alongside adds it on top.","+func (i *instance) updateServiceGraphsSubprocessors(desiredProcessors map[string]struct{}, desiredCfg ProcessorConfig) (map[string]struct{}, ProcessorConfig) {","+\tdesiredProcessorsFound := false","+\tfor d := range desiredProcessors {","+\t\tif (d == processor.ServiceGraphsName) || (servicegraphs.ParseSubprocessor(d)) {","+\t\t\tdesiredProcessorsFound = true","+\t\t}","+\t}","+","+\tif !desiredProcessorsFound {","+\t\treturn desiredProcessors, desiredCfg","+\t}","+","+\t_, allOk := desiredProcessors[processor.ServiceGraphsName]","+\t_, requestOk := desiredProcessors[servicegraphs.Request.String()]","+\t_, latencyOk := desiredProcessors[servicegraphs.Latency.String()]","+\t_, connectionInfoOk := desiredProcessors[servicegraphs.ConnectionInfo.String()]","+","+\t// Copy the map before modifying it. This map can be shared by multiple instances and is not safe to write to.","+\tnewDesiredProcessors := map[string]struct{}{}","+\tmaps.Copy(newDesiredProcessors, desiredProcessors)","+","+\tif !allOk {","+\t\tnewDesiredProcessors[processor.ServiceGraphsName] = struct{}{}","+\t\tdesiredCfg.ServiceGraphs.Subprocessors[servicegraphs.Request] = false","+\t\tdesiredCfg.ServiceGraphs.Subprocessors[servicegraphs.Latency] = false","+\t\tdesiredCfg.ServiceGraphs.Subprocessors[servicegraphs.ConnectionInfo] = false","+","+\t\tif requestOk {","+\t\t\tdesiredCfg.ServiceGraphs.Subprocessors[servicegraphs.Request] = true","+\t\t}","+\t\tif latencyOk {","+\t\t\tdesiredCfg.ServiceGraphs.Subprocessors[servicegraphs.Latency] = true","+\t\t}","+\t\tif connectionInfoOk {","+\t\t\tdesiredCfg.ServiceGraphs.Subprocessors[servicegraphs.ConnectionInfo] = true","+\t\t}","+\t} else if connectionInfoOk {","+\t\t// Additive opt-in alongside bare service-graphs; defaults already have Request and Latency on.","+\t\tdesiredCfg.ServiceGraphs.Subprocessors[servicegraphs.ConnectionInfo] = true","+\t}","+","+\tdelete(newDesiredProcessors, servicegraphs.Request.String())","+\tdelete(newDesiredProcessors, servicegraphs.Latency.String())","+\tdelete(newDesiredProcessors, servicegraphs.ConnectionInfo.String())","+","+\treturn newDesiredProcessors, desiredCfg","+}","+"," func (i *instance) updateProcessors() error {"," \tdesiredProcessors := i.filterSupportedProcessors(i.overrides.MetricsGeneratorProcessors(i.instanceID))"," \tdesiredCfg, err := i.cfg.Processor.copyWithOverrides(i.overrides, i.instanceID)"],"additions":57,"deletions":2,"truncated":false},{"path":"modules/generator/instance_test.go","lines":["@@ -22,6 +22,7 @@ import ("," \t\"github.com/stretchr/testify/require\""," "," \t\"github.com/grafana/tempo/modules/generator/processor/hostinfo\"","+\t\"github.com/grafana/tempo/modules/generator/processor/servicegraphs\""," \t\"github.com/grafana/tempo/modules/generator/processor/spanmetrics\""," \t\"github.com/grafana/tempo/modules/generator/storage\""," \t\"github.com/grafana/tempo/pkg/tempopb\"","@@ -444,6 +445,115 @@ func Test_instance_updateProcessors(t *testing.T) {"," \t\tassert.NoError(t, err)"," \t\tassertHistogramsNoChange(t)"," \t})","+","+\tt.Run(\"add service-graphs-connection-info subprocessor only\", func(t *testing.T) {","+\t\toverrides.processors = map[string]struct{}{","+\t\t\tservicegraphs.ConnectionInfo.String(): {},","+\t\t}","+\t\terr := instance.updateProcessors()","+\t\trequire.NoError(t, err)","+","+\t\t// service-graphs sub-name should be folded into the bare service-graphs processor entry.","+\t\t_, hasBare := instance.processors[processor.ServiceGraphsName]","+\t\trequire.True(t, hasBare, \"expected bare service-graphs processor to be registered\")","+\t\t_, hasSubName := instance.processors[processor.ServiceGraphsConnectionInfoName]","+\t\trequire.False(t, hasSubName, \"sub-name should not appear in the processors map\")","+","+\t\tcfg := instance.processors[processor.ServiceGraphsName].(*servicegraphs.Processor).Cfg","+\t\trequire.False(t, cfg.Subprocessors[servicegraphs.Request], \"Request should be disabled when only connection-info requested\")","+\t\trequire.False(t, cfg.Subprocessors[servicegraphs.Latency], \"Latency should be disabled when only connection-info requested\")","+\t\trequire.True(t, cfg.Subprocessors[servicegraphs.ConnectionInfo], \"ConnectionInfo should be enabled\")","+\t})","+","+\tt.Run(\"bare service-graphs keeps connection-info opt-in\", func(t *testing.T) {","+\t\toverrides.processors = map[string]struct{}{","+\t\t\tprocessor.ServiceGraphsName: {},","+\t\t}","+\t\terr := instance.updateProcessors()","+\t\trequire.NoError(t, err)","+","+\t\tcfg := instance.processors[processor.ServiceGraphsName].(*servicegraphs.Processor).Cfg","+\t\trequire.True(t, cfg.Subprocessors[servicegraphs.Request])","+\t\trequire.True(t, cfg.Subprocessors[servicegraphs.Latency])","+\t\trequire.False(t, cfg.Subprocessors[servicegraphs.ConnectionInfo], \"ConnectionInfo must remain off under bare service-graphs\")","+\t})","+","+\tt.Run(\"service-graphs + connection-info sub-name combines RED and connection_info\", func(t *testing.T) {","+\t\toverrides.processors = map[string]struct{}{","+\t\t\tprocessor.ServiceGraphsName:           {},","+\t\t\tservicegraphs.ConnectionInfo.String(): {},","+\t\t}","+\t\terr := instance.updateProcessors()","+\t\trequire.NoError(t, err)","+","+\t\tcfg := instance.processors[processor.ServiceGraphsName].(*servicegraphs.Processor).Cfg","+\t\trequire.True(t, cfg.Subprocessors[servicegraphs.Request])","+\t\trequire.True(t, cfg.Subprocessors[servicegraphs.Latency])","+\t\trequire.True(t, cfg.Subprocessors[servicegraphs.ConnectionInfo])","+\t})","+","+\tt.Run(\"service-graphs-request subprocessor only\", func(t *testing.T) {","+\t\toverrides.processors = map[string]struct{}{","+\t\t\tservicegraphs.Request.String(): {},","+\t\t}","+\t\terr := instance.updateProcessors()","+\t\trequire.NoError(t, err)","+","+\t\tcfg := instance.processors[processor.ServiceGraphsName].(*servicegraphs.Processor).Cfg","+\t\trequire.True(t, cfg.Subprocessors[servicegraphs.Request])","+\t\trequire.False(t, cfg.Subprocessors[servicegraphs.Latency])","+\t\trequire.False(t, cfg.Subprocessors[servicegraphs.ConnectionInfo])","+","+\t\t_, hasSubName := instance.processors[processor.ServiceGraphsRequestName]","+\t\trequire.False(t, hasSubName, \"sub-name should be folded into the bare service-graphs entry\")","+\t})","+","+\tt.Run(\"service-graphs-latency subprocessor only\", func(t *testing.T) {","+\t\toverrides.processors = map[string]struct{}{","+\t\t\tservicegraphs.Latency.String(): {},","+\t\t}","+\t\terr := instance.updateProcessors()","+\t\trequire.NoError(t, err)","+","+\t\tcfg := instance.processors[processor.ServiceGraphsName].(*servicegraphs.Processor).Cfg","+\t\trequire.False(t, cfg.Subprocessors[servicegraphs.Request])","+\t\trequire.True(t, cfg.Subprocessors[servicegraphs.Latency])","+\t\trequire.False(t, cfg.Subprocessors[servicegraphs.ConnectionInfo])","+\t})","+","+\tt.Run(\"transition between service-graphs subprocessor subsets triggers replace\", func(t *testing.T) {","+\t\t// Start with bare service-graphs (Request + Latency).","+\t\toverrides.processors = map[string]struct{}{","+\t\t\tprocessor.ServiceGraphsName: {},","+\t\t}","+\t\terr := instance.updateProcessors()","+\t\trequire.NoError(t, err)","+","+\t\t// Now request connection-info only. diffProcessors should mark the service-graphs","+\t\t// processor for replacement (config changed) rather than removal.","+\t\toverrides.processors = map[string]struct{}{","+\t\t\tservicegraphs.ConnectionInfo.String(): {},","+\t\t}","+","+\t\tdesiredProcessors := instance.filterSupportedProcessors(instance.overrides.MetricsGeneratorProcessors(instance.instanceID))","+\t\tdesiredCfg, err := instance.cfg.Processor.copyWithOverrides(instance.overrides, instance.instanceID)","+\t\trequire.NoError(t, err)","+\t\tdesiredProcessors, desiredCfg = instance.updateSubprocessors(desiredProcessors, desiredCfg)","+","+\t\ttoAdd, toRemove, toReplace, err := instance.diffProcessors(desiredProcessors, desiredCfg)","+\t\trequire.NoError(t, err)","+\t\trequire.Empty(t, toAdd, \"service-graphs already exists; no add\")","+\t\trequire.Empty(t, toRemove, \"service-graphs should not be removed; sub-name folds into it\")","+\t\trequire.Equal(t, []string{processor.ServiceGraphsName}, toReplace, \"config diff (Request+Latency -> ConnectionInfo only) must trigger replace\")","+","+\t\terr = instance.updateProcessors()","+\t\trequire.NoError(t, err)","+","+\t\tcfg := instance.processors[processor.ServiceGraphsName].(*servicegraphs.Processor).Cfg","+\t\trequire.False(t, cfg.Subprocessors[servicegraphs.Request])","+\t\trequire.False(t, cfg.Subprocessors[servicegraphs.Latency])",