holds change_scripts that should fire after the","+\t// initial template render once the task reaches the running state.","+\tfirstRenderScripts []*structs.ChangeScript","+"," \t// shutdown marks whether the manager has been shutdown"," \tshutdown     bool"," \tshutdownLock sync.Mutex","@@ -652,6 +656,38 @@ func (tm *TaskTemplateManager) allTemplatesNoop() bool {"," \treturn true"," }"," ","+// collectFirstRenderScripts returns the set of ChangeScript objects from","+// templates that have change_mode \"script\" with RunOnFirstRender enabled.","+func (tm *TaskTemplateManager) collectFirstRenderScripts() []*structs.ChangeScript {","+\tvar scripts []*structs.ChangeScript","+\tfor _, tmpl := range tm.config.Templates {","+\t\tif tmpl.ChangeMode == structs.TemplateChangeModeScript &&","+\t\t\ttmpl.ChangeScript != nil &&","+\t\t\ttmpl.ChangeScript.RunOnFirstRender {","+\t\t\tscripts = append(scripts, tmpl.ChangeScript)","+\t\t}","+\t}","+\treturn scripts","+}","+","+// RunFirstRenderScripts executes the change_scripts collected during the","+// first template render. It is called by the template hook's Poststart","+// method once the task is running and Exec is available.","+func (tm *TaskTemplateManager) RunFirstRenderScripts() {","+\tscripts := tm.firstRenderScripts","+\tif len(scripts) == 0 {","+\t\treturn","+\t}","+\ttm.firstRenderScripts = nil","+","+\tvar wg sync.WaitGroup","+\tfor _, script := range scripts {","+\t\twg.Add(1)","+\t\tgo tm.processScript(script, &wg)","+\t}","+\twg.Wait()","+}","+"," // templateRunner returns a consul-template runner for the given templates and a"," // lookup by destination to the template. If no templates are in the config, a"," // nil template runner and lookup is returned."],"additions":36,"deletions":0,"truncated":false},{"path":"client/allocrunner/taskrunner/template/template_test.go","lines":["@@ -1403,6 +1403,59 @@ OUTER:"," \t}"," }"," ","+// TestTaskTemplateManager_FirstRenderScript verifies that a template with","+// change_mode \"script\" and RunOnFirstRender collects the script so it can","+// be executed once the task reaches the running state via RunFirstRenderScripts.","+func TestTaskTemplateManager_FirstRenderScript(t *testing.T) {","+\tci.Parallel(t)","+\tclienttestutil.RequireConsul(t)","+","+\tkey := \"first_render_key\"","+\tt1 := &structs.Template{","+\t\tEmbeddedTmpl: `FOO={{key \"first_render_key\"}}` + \"\\n\",","+\t\tDestPath:     \"first_render.env\",","+\t\tChangeMode:   structs.TemplateChangeModeScript,","+\t\tChangeScript: &structs.ChangeScript{","+\t\t\tCommand:          \"/bin/foo\",","+\t\t\tArgs:             []string{},","+\t\t\tTimeout:          5 * time.Second,","+\t\t\tFailOnError:      false,","+\t\t\tRunOnFirstRender: true,","+\t\t},","+\t\tEnvvars: true,","+\t}","+","+\tharness := newTestHarness(t, []*structs.Template{t1}, true, false)","+\tharness.mockHooks.SetupExecTest(0, nil)","+\tharness.start(t)","+\tdefer harness.stop()","+","+\t// Write key so the template renders","+\tharness.consul.SetKV(t, key, []byte(\"hello\"))","+","+\t// Wait for unblock (first render complete)","+\tselect {","+\tcase <-harness.mockHooks.UnblockCh:","+\tcase <-time.After(time.Duration(5*testutil.TestMultiplier()) * time.Second):","+\t\tt.Fatal(\"Task unblock should have been called\")","+\t}","+","+\t// Simulate the Poststart hook by calling RunFirstRenderScripts directly","+\tharness.mockHooks.HasHandle = true","+\tharness.manager.RunFirstRenderScripts()","+","+\t// Verify script execution event was emitted","+\ttimeout := time.After(time.Duration(5*testutil.TestMultiplier()) * time.Second)","+\tselect {","+\tcase ev := <-harness.mockHooks.EmitEventCh:","+\t\tif !strings.Contains(ev.DisplayMessage, t1.ChangeScript.Command) {","+\t\t\tt.Fatalf(\"expected script event, got: %s\", ev.DisplayMessage)","+\t\t}","+\tcase <-timeout:","+\t\tt.Fatal(\"should have received a script execution event\")","+\t}","+}","+"," // TestTaskTemplateManager_ScriptExecutionFailTask tests whether we fail the"," // task upon script execution failure if that's how it's configured."," func TestTaskTemplateManager_ScriptExecutionFailTask(t *testing.T) {"],"additions":53,"deletions":0,"truncated":false},{"path":"client/allocrunner/taskrunner/template_hook.go","lines":["@@ -239,6 +239,16 @@ func (h *templateHook) newManager(tmpls []*structs.Template) (manager *template."," \treturn m, unblock, nil"," }"," ","+func (h *templateHook) Poststart(_ context.Context, _ *interfaces.TaskPoststartRequest, _ *interfaces.TaskPoststartResponse) error {","+\th.managerLock.Lock()","+\tdefer h.managerLock.Unlock()","+","+\tif h.templateManager != nil {","+\t\th.templateManager.RunFirstRenderScripts()","+\t}","+\treturn nil","+}","+"," func (h *templateHook) Stop(_ context.Context, req *interfaces.TaskStopRequest, resp *interfaces.TaskStopResponse) error {"," \th.managerLock.Lock()"," \tdefer h.managerLock.Unlock()"],"additions":10,"deletions":0,"truncated":false},{"path":"command/agent/job_endpoint.go","lines":["@@ -1550,10 +1550,11 @@ func apiChangeScriptToStructsChangeScript(changeScript *api.ChangeScript) *struc"," \t}"," "," \treturn &structs.ChangeScript{","-\t\tCommand:     *changeScript.Command,","-\t\tArgs:        changeScript.Args,","-\t\tTimeout:     *changeScript.Timeout,","-\t\tFailOnError: *changeScript.FailOnError,","+\t\tCommand:          *changeScript.Command,","+\t\tArgs:             changeScript.Args,","+\t\tTimeout:          *changeScript.Timeout,","+\t\tFailOnError:      *changeScript.FailOnError,","+\t\tRunOnFirstRender: *changeScript.RunOnFirstRender,"," \t}"," }"," "],"additions":5,"deletions":4,"truncated":false},{"path":"jobspec2/parse_job.go","lines":["@@ -163,4 +163,7 @@ func normalizeChangeScript(ch *api.ChangeScript) {"," \tif ch.FailOnError == nil {"," \t\tch.FailOnError = pointerOf(false)"," \t}","+\tif ch.RunOnFirstRender == nil {","+\t\tch.RunOnFirstRender = pointerOf(false)","+\t}"," }"],"additions":3,"deletions":0,"truncated":false},{"path":"no