cdsa.c ssh-ed25519.c mac.c umac.c umac128.c hmac.c misc.c","+SRCS+=ssherr.c uidswap.c cleanup.c xmalloc.c match.c krl.c fatal.c","+SRCS+=addr.c addrmatch.c bitmap.c","+SRCS+=cipher-chachapoly.c chacha.c poly1305.c ssh-ecdsa-sk.c ssh-sk.c","+SRCS+=ssh-ed25519-sk.c sk-usbhid.c ssh-pkcs11-client.c","+SRCS+=utf8.c ssherr-libcrypto.c","+SRCS+=kex.c kex-names.c packet.c dispatch.c compat.c canohost.c","+SRCS+=digest-openssl.c ed25519-openssl.c","+","+REGRESS_TARGETS=run-regress-${PROG}","+","+run-regress-${PROG}: ${PROG}","+\tenv ${TEST_ENV} ./${PROG} ${UNITTEST_ARGS}","+","+.include <bsd.regress.mk>"],"additions":25,"deletions":0,"truncated":false},{"path":"regress/unittests/servconf/tests.c","lines":["@@ -0,0 +1,362 @@","+/* \t$OpenBSD: tests.c,v 1.1 2026/05/31 11:39:44 djm Exp $ */","+/*","+ * Regress tests for servconf.h server configuration API","+ *","+ * Placed in the public domain","+ */","+","+#include <sys/types.h>","+#include <limits.h>","+#include <stdio.h>","+#include <stdint.h>","+#include <stdlib.h>","+#include <string.h>","+","+#include \"../test_helper/test_helper.h\"","+","+#include \"log.h\"","+#include \"misc.h\"","+#include \"servconf.h\"","+#include \"sshbuf.h\"","+#include \"ssherr.h\"","+#include \"xmalloc.h\"","+","+struct sshbuf *cfg;","+","+/* stub */","+int auth2_methods_valid(const char *methods, int need_enable);","+int","+auth2_methods_valid(const char *methods, int need_enable)","+{","+\treturn 1;","+}","+","+static void","+onerror(void *fuzz)","+{","+\tfprintf(stderr, \"Failed during fuzz:\\n\");","+\tfuzz_dump((struct fuzz *)fuzz);","+}","+","+static void","+set_string(char **dst, const char *s)","+{","+\t*dst = s == NULL ? NULL : xstrdup(s);","+}","+","+static char **","+new_string_array(u_int n)","+{","+\treturn xcalloc(n, sizeof(char *));","+}","+","+static void","+set_test_options(ServerOptions *o)","+{","+\tinitialize_server_options(o);","+","+\to->num_ports = 2;","+\to->ports[0] = 22;","+\to->ports[1] = 2022;","+\to->ip_qos_interactive = 0x10;","+\to->ip_qos_bulk = 0x08;","+\to->log_facility = SYSLOG_FACILITY_AUTH;","+\to->log_level = SYSLOG_LEVEL_DEBUG3;","+\to->fwd_opts.gateway_ports = 1;","+\to->fwd_opts.streamlocal_bind_mask = 0177;","+\to->fwd_opts.streamlocal_bind_unlink = 1;","+\to->permit_user_env = 1;","+\tset_string(&o->permit_user_env_allowlist, \"\");","+\to->rekey_limit = 123456789;","+\to->rekey_interval = 600;","+\to->timing_secret = 0x0102030405060708ULL;","+","+\tset_string(&o->routing_domain, \"\");","+\tset_string(&o->banner, NULL);","+\tset_string(&o->adm_forced_command, \"internal-sftp\");","+\tset_string(&o->chroot_directory, \"\");","+\tset_string(&o->host_key_agent, NULL);","+\tset_string(&o->authorized_keys_command, \"/bin/echo\");","+\tset_string(&o->authorized_keys_command_user, \"\");","+\tset_string(&o->authorized_principals_file, NULL);","+","+\to->num_authkeys_files = 3;","+\to->authorized_keys_files = new_string_array(o->num_authkeys_files);","+\tset_string(&o->authorized_keys_files[0], NULL);","+\tset_string(&o->authorized_keys_files[1], \"\");","+\tset_string(&o->authorized_keys_files[2], \".ssh/authorized_keys\");","+","+\to->num_log_verbose = 2;","+\to->log_verbose = new_string_array(o->num_log_verbose);","+\tset_string(&o->log_verbose[0], NULL);","+\tset_string(&o->log_verbose[1], \"kex.c:*\");","+","+\to->num_host_key_files = 3;","+\to->host_key_file_userprovided =","+\t    xcalloc(o->num_host_key_files,","+\t    sizeof(*o->host_key_file_userprovided));","+\to->host_key_files = new_string_array(o->num_host_key_files);","+\to->host_key_file_userprovided[0] = 0;","+\to->host_key_file_userprovided[1] = 1;","+\to->host_key_file_userprovided[2] = -1;","+\tset_string(&o->host_key_files[0], NULL);","+\tset_string(&o->host_key_files[1], \"\");","+\tset_string(&o->host_key_files[2], \"/tmp/ssh_host_ed25519_key\");","+","+\to->num_queued_listens = 2;","+\to->queued_listen_addrs = xcalloc(o->num_queued_listens,","+\t    sizeof(*o->queued_listen_addrs));","+\tset_string(&o->queued_listen_addrs[0].addr, \"127.0.0.1\");","+\to->queued_listen_addrs[0].port = 2222;","+\tset_string(&o->queued_listen_addrs[0].rdomain, NULL);","+\tset_string(&o->queued_listen_addrs[1].addr, \"::1\");","+\to->queued_listen_addrs[1].port = -1;","+\tset_string(&o->queued_listen_addrs[1].rdomain, \"\");","+","+\to->num_subsystems = 2;","+\to->subsystem_name = new_string_array(o->num_subsystems);","+\to->subsystem_command = new_string_array(o->num_subsystems);","+\to->subsystem_args = new_string_array(o->num_subsystems);","+\tset_string(&o->subsystem_name[0], \"sftp\");","+\tset_string(&o->subsystem_command[0], \"internal-sftp\");","+\tset_string(&o->subsystem_args[0], \"internal-sftp -f AUTH\");","+\tset_string(&o->subsystem_name[1], \"echo\");","+\tset_string(&o->subsystem_command[1], \"/bin/echo\");","+\tset_string(&o->subsystem_args[1], \"/bin/echo hello\");","+}","+","+static void","+check_roundtrip(const ServerOptions *o)","+{","+\tstruct sshbuf *buf = NULL;","+\tServerOptions out;","+","+\tinitialize_server_options(&out);","+\tASSERT_INT_EQ(serialise_server_options(o, &buf), 0);","+\tASSERT_PTR_NE(buf, NULL);","+\tASSERT_INT_EQ(deserialise_server_options(buf, &out), 0);","+\tASSERT_SIZE_T_EQ(sshbuf_len(buf), 0);","+","+\tASSERT_U_INT_EQ(out.num_ports, 2);","+\tASSERT_INT_EQ(out.ports[0], 22);","+\tASSERT_INT_EQ(out.ports[1], 2022);","+\tASSERT_INT_EQ(out.ip_qos_interactive, 0x10);","+\tASSERT_INT_EQ(out.ip_qos_bulk, 0x08);","+\tASSERT_INT_EQ(out.log_facility, SYSLOG_FACILITY_AUTH);","+\tASSERT_INT_EQ(out.log_level, SYSLOG_LEVEL_DEBUG3);","+\tASSERT_INT_EQ(out.fwd_opts.gateway_ports, 1);","+\tASSERT_INT_EQ(out.fwd_opts.streamlocal_bind_mask, 0177);","+\tASSERT_INT_EQ(out.fwd_opts.streamlocal_bind_unlink, 1);","+\tASSERT_INT_EQ(out.permit_user_env, 1);","+\tASSERT_STRING_EQ(out.permit_user_env_allowlist, \"\");","+\tASSERT_LONG_LONG_EQ(out.rekey_limit, 123456789);","+\tASSERT_INT_EQ(out.rekey_interval, 600);","+\tASSERT_U64_EQ(out.timing_secret, 0x0102030405060708ULL);","+","+\tASSERT_STRING_EQ(out.routing_domain, \"\");","+\tASSERT_PTR_EQ(out.banner, NULL);","+\tASSERT_STRING_EQ(out.adm_forced_command, \"internal-sftp\");","+\tASSERT_STRING_EQ(out.chroot_directory, \"\");","+\tASSERT_PTR_EQ(out.host_key_agent, NULL);","+\tASSERT_STRING_EQ(out.authorized_keys_command, \"/bin/echo\");","+\tASSERT_STRING_EQ(out.authorized_keys_command_user, \"\");","+\tASSERT_PTR_EQ(out.authorized_principals_file, NULL);","+","+\tASSERT_U_INT_EQ(out.num_authkeys_files, 3);","+\tASSERT_PTR_EQ(out.authorized_keys_files[0], NULL);","+\tASSERT_STRING_EQ(out.authorized_keys_files[1], \"\");","+\tASSERT_STRING_EQ(out.authorized_keys_files[2], \".ssh/authorized_keys\");","+","+\tASSERT_U_INT_EQ(out.num_log_verbose, 2);","+\tASSERT_PTR_EQ(out.log_verbose[0], NULL);","+\tASSERT_STRING_EQ(out.log_verbose[1], \"kex.c:*\");","+","+\tASSERT_U_INT_EQ(out.num_host_key_files, 3);","+\tASSERT_INT_EQ(out.host_key_file_userprovided[0], 0);","+\tASSERT_INT_EQ(out.host_key_file_userprovided[1], 1);","+\tASSERT_INT_EQ(out.host_key_file_userprovided[2], -1);","+\tASSERT_PTR_EQ(out.host_key_files[0], NULL);","+\tASSERT_STRING_EQ(out.host_key_files[1], \"\");","+\tASSERT_STRING_EQ(out.host_key_files[2], \"/tmp/ssh_host_ed25519_key\");","+","+\tASSERT_U_INT_EQ(out.num_queued_listens, 2);","+\tASSERT_STRING_EQ(out.queued_listen_addrs[0].addr, \"127.0.0.1\");","+\tASSERT_INT_EQ(out.queued_listen_addrs[0].port, 2222);","+\tASSERT_PTR_EQ(out.queued_listen_addrs[0].rdomain, NULL);","+\tASSERT_STRING_EQ(out.queued_listen_addrs[1].addr, \"::1\");","+\tASSERT_INT_EQ(out.queued_listen_addrs[1].port, -1);","+\tASSERT_STRING_EQ(out.queued_listen_addrs[1].rdomain, \"\");","+","+\tASSERT_U_INT_EQ(out.num_subsystems, 2);","+\tASSERT_STRING_EQ(out.subsystem_name[0], \"sftp\");","+\tASSERT_STRING_EQ(out.subsystem_command[0], \"internal-sftp\");","+\tASSERT_STRING_EQ(out.subsystem_args[0], \"internal-sftp -f AUTH\");","+\tASSERT_STRING_EQ(out.subsystem_name[1], \"echo\");","+\tASSERT_STRING_EQ(out.subsystem_command[1], \"/bin/echo\");","+\tASSERT_STRING_EQ(out.subsystem_args[1], \"/bin/echo hello\");","+","+\tfree_server_options(&out);","+\tsshbuf_free(buf);","+}","+","+static void","+check_rejects_trailing_data(const ServerOptions *o)","+{","+\tstruct sshbuf *buf = NULL;","+\tServerOptions out;","+\tint r;","+","+\tinitialize_server_options(&out);","+\tASSERT_INT_EQ(serialise_server_options(o, &buf), 0);","+\tASSERT_PTR_NE(buf, NULL);","+\tASSERT_INT_EQ(sshbuf_put_u8(buf, 0), 0);","+\tr = deserialise_server_options(buf, &out);","+\tASSERT_INT_EQ(r, SSH_ERR_INVALID_FORMAT);","+\tfree_server_options(&out);","+\tsshbuf_free(buf);","+}","+","+static void","+check_rejects_bad_version(const ServerOptions *o)","+{","+\tstruct sshbuf *buf = NULL;","+\tServerOptions out;","+\tint r;","+","+\tinitialize_server_options(&out);","+\tASSERT_INT_EQ(serialise_server_options(o, &buf), 0);","+\tASSERT_PTR_NE(buf, NULL);","+\tASSERT_PTR_NE(sshbuf_mutable_ptr(buf), NULL);","+\tPOKE_U32(sshbuf_mutable_ptr(buf), 2);","+\tr = deserialise_server_options(buf, &out);","+\tASSERT_INT_EQ(r, SSH_ERR_INVALID_FORMAT);","+\tfree_server_options(&out);","+\tsshbuf_free(buf);","+}","+","+static void","+check_rejects_bad_port_count(const ServerOptions *o)","+{","+\tstruct sshbuf *buf = NULL;","+\tServerOptions out;","+\tint r;","+","+\tinitialize_server_options(&out);","+\tASSERT_INT_EQ(serialise_server_options(o, &buf), 0);","+\tASSERT_PTR_NE(buf, NULL);","+\tASSERT_SIZE_T_GT(sshbuf_len(buf), 8);","+\tASSERT_PTR_NE(sshbuf_mutable_ptr(buf), NULL);","+\tPOKE_U32(sshbuf_mutable_ptr(buf) + 4, MAX_PORTS + 1);","+\tr = deserialise_server_options(buf, &out);","+\tASSERT_INT_EQ(r, SSH_ERR_INVALID_FORMAT);","+\tfree_server_options(&out);","+\tsshbuf_free(buf);","+}","+","+static void","+check_roundtrip_signed_limits(const ServerOptions *o)","+{","+\tstruct sshbuf *buf = NULL;","+\tServerOptions out, in;","+","+\tinitialize_server_options(&out);","+\tin = *o;","+\tin.fwd_opts.streamlocal_bind_mask = (mode_t)-1;","+\tin.ip_qos_bulk = INT_MIN;","+\tin.rekey_limit = INT64_MIN;","+\tASSERT_INT_EQ(serialise_server_options(&in, &buf), 0);","+\tASSERT_PTR_NE(buf, NULL);","+\tASSERT_INT_EQ(deserialise_server_options(buf, &out), 0);","+\tASSERT_INT_EQ(out.fwd_opts.streamlocal_bind_mask == (mode_t)-1, 1);","+\tASSERT_INT_EQ(out.ip_qos_bulk, INT_MIN);","+\tASSERT_LONG_LONG_EQ(out.rekey_limit, INT64_MIN);","+\tfree_server_options(&out);","+\tsshbuf_free(buf);","+}","+","+static void","+attempt_deserialise_blob(const u_char *p, size_t len)","+{","+\tstruct sshbuf *buf;","+\tServerOptions out;","+","+\tinitialize_server_options(&out);","+\tASSERT_PTR_NE(buf = sshbuf_from(p, len), NULL);","+\t(void)deserialise_server_options(buf, &out);","+\tfree_server_options(&out);","+\tsshbuf_free(buf);","+}","+","+static void","+check_fuzz_deserialise(const ServerOptions *o)","+{","+\tstruct sshbuf *buf = NULL;","+\tstruct fuzz *fuzz;","+\tu_int fuzzers = FUZZ_1_BIT_FLIP | FUZZ_1_BYTE_FLIP |","+\t    FUZZ_TRUNCATE_START | FUZZ_TRUNCATE_END;","+","+\tif (test_is_fast())","+\t\tfuzzers &= ~FUZZ_1_BIT_FLIP;","+\tif (test_is_slow())","+\t\tfuzzers |= FUZZ_2_BYTE_FLIP;","+","+\tASSERT_INT_EQ(serialise_server_options(o, &buf), 0);","+\tASSERT_PTR_NE(buf, NULL);","+\tfuzz = fuzz_begin(fuzzers, sshbuf_ptr(buf), sshbuf_len(buf));","+\tTEST_ONERROR(onerror, fuzz);","+\tfor (; !fuzz_done(fuzz); fuzz_next(fuzz))","+\t\tattempt_deserialise_blob(fuzz_ptr(fuzz), fuzz_len(fuzz));","+\tTEST_ONERROR(NULL, NULL);","+\tfuzz_cleanup(fuzz);","+\tsshbuf_free(buf);","+}","+","+void","+tests(void)","+{","+\tServerOptions o;","+","+\tlog_init(\"test_servconf\", SYSLOG_LEVEL_QUIET, SYSLOG_FACILITY_AUTH, 1);","+","+\tTEST_START(\"server options round trip preserves nullable state\");","+\tset_test_options(&o);","+\tcheck_roundtrip(&o);","+\tfree_server_options(&o);","+\tTEST_DONE();","+","+\tTEST_START(\"server options reject trailing data\");","+\tset_test_options(&o);","+\tcheck_rejects_trailing_data(&o);","+\tfree_server_options(&o);","+\tTEST_DONE();","+","+\tTEST_START(\"server options reject unsupported version\");","+\tset_test_options(&o);","+\tcheck_rejects_bad_version(&o);","+\tfree_server_options(&o);","+\tTEST_DONE();","+","+\tTEST_START(\"server options reject bad port count\");","+\tset_test_options(&o);","+\tcheck_rejects_bad_port_count(&o);","+\tfree_server_options(&o);","+\tTEST_DONE();","+","+\tTEST_START(\"server options round trip signed limits\");","+\tset_test_options(&o);","+\tcheck_roundtrip_signed_limits(&o);","+\tfree_server_options(&o);","+\tTEST_DONE();","+","+\tTEST_START(\"server options deserialise fuzz\");","+\tset_test_options(&o);","+\tcheck_fuzz_deserialise(&o);","+\tfree_server_options(&o);","+\tTEST_DONE();","+}","+","+void","+benchmarks(void)","+{","+\tprintf(\"no benchmarks\\n\");","+}",""],"additions":362,"deletions":0,"truncated":false}],"additions":409,"deletions":2,"truncated":false,"file_count":5},"error":null,"fetched_at":"2026-06-01T13:15:47.172782+00:00"}