ct {","+\ttypes.AuthInfo","+\textra map[string][]string","+}","+","+func (f *fakeAuthInfo) GetExtra() map[string][]string { return f.extra }"],"additions":99,"deletions":0,"truncated":false},{"path":"pkg/registry/apis/secret/decrypt/grpc_client.go","lines":["@@ -140,11 +140,23 @@ func (g *GRPCDecryptClient) Decrypt(ctx context.Context, serviceName string, nam"," \t\treturn map[string]decrypt.DecryptResult{}, nil"," \t}"," ","-\ttokenExchangerInterceptor := authnlib.NewGrpcClientInterceptor(","-\t\tg.tokenExchanger,","+\topts := []authnlib.GrpcClientInterceptorOption{"," \t\tauthnlib.WithClientInterceptorTracer(g.tracer),"," \t\tauthnlib.WithClientInterceptorNamespace(namespace),"," \t\tauthnlib.WithClientInterceptorAudience([]string{secretv1beta1.APIGroup}),","+\t}","+","+\t// if the incoming context has an access token, use it as the subject token for exchange","+\tauthInfo, ok := types.AuthInfoFrom(ctx)","+\tif ok && authInfo != nil {","+\t\tif at := authInfo.GetAccessToken(); at != \"\" {","+\t\t\topts = append(opts, authnlib.WithClientInterceptorSubjectToken(at))","+\t\t}","+\t}","+","+\ttokenExchangerInterceptor := authnlib.NewGrpcClientInterceptor(","+\t\tg.tokenExchanger,","+\t\topts...,"," \t)"," "," \tclientConn := grpchan.InterceptClientConn("],"additions":14,"deletions":2,"truncated":false},{"path":"pkg/services/apiserver/builder/helper.go","lines":["@@ -95,6 +95,11 @@ func GetDefaultBuildHandlerChainFunc(builders []APIGroupBuilder, reg prometheus."," \treturn func(delegateHandler http.Handler, c *genericapiserver.Config) http.Handler {"," \t\thandler := filters.WithTracingHTTPLoggingAttributes(delegateHandler)"," ","+\t\t// auditing.HTTPInjectAuditAnnotationMiddleware extracts the innermost service caller identity from the request","+\t\t// and injects it into the k8s audit event context (used for audit log suppression).","+\t\t// Runs after WithRequester so auth info is available for the first-hop fallback.","+\t\thandler = auditing.HTTPInjectAuditAnnot