"","+\t\"k8s.io/apiserver/pkg/audit\"","+)","+","+const AuditAnnotationInnermostServiceIdentity = \"grafana.app/innermost-service-identity\"","+","+// HTTPInjectAuditAnnotationMiddleware extracts the innermost service identity from the request,","+// and injects it into the k8s audit event context (used for audit log suppression).","+func HTTPInjectAuditAnnotationMiddleware(next http.Handler) http.Handler {","+\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\tif authInfo, ok := types.AuthInfoFrom(r.Context()); ok {","+\t\t\tif innermostSvcIdentity := authInfo.GetExtra()[\"innermostServiceIdentity\"]; len(innermostSvcIdentity) > 0 {","+\t\t\t\t// Annotate the K8s audit event so the audit backend can make a decision based on it.","+\t\t\t\taudit.AddAuditAnnotation(r.Context(), AuditAnnotationInnermostServiceIdentity, innermostSvcIdentity[0])","+\t\t\t}","+\t\t}","+","+\t\tnext.ServeHTTP(w, r)","+\t})","+}"],"additions":25,"deletions":0,"truncated":false},{"path":"pkg/apiserver/auditing/middleware_test.go","lines":["@@ -0,0 +1,99 @@","+package auditing","+","+import (","+\t\"net/http\"","+\t\"net/http/httptest\"","+\t\"testing\"","+","+\t\"github.com/grafana/authlib/types\"","+\t\"github.com/stretchr/testify/require\"","+\t\"k8s.io/apiserver/pkg/audit\"","+)","+","+func TestHTTPInjectAuditAnnotationMiddleware(t *testing.T) {","+\tt.Parallel()","+","+\ttests := []struct {","+\t\tname           string","+\t\tauthInfo       types.AuthInfo","+\t\twantAnnotation string","+\t\twantPresent    bool","+\t}{","+\t\t{","+\t\t\tname: \"single innermostServiceIdentity value is injected as the audit annotation\",","+\t\t\tauthInfo: &fakeAuthInfo{extra: map[string][]string{","+\t\t\t\t\"innermostServiceIdentity\": {\"my-service\"},","+\t\t\t}},","+\t\t\twantAnnotation: \"my-service\",","+\t\t\twantPresent:    true,","+\t\t},","+\t\t{","+\t\t\tname: \"only the first value is used when multiple are present\",","+\t\t\tauthInfo: &fakeAuthInfo{extra: map[str