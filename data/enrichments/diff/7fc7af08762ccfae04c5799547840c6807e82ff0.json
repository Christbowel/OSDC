ump.Replace('\\\\', '/')}' (FORMAT PARQUET)\";","+\t\t\t\t\tec.ExecuteNonQuery();","+\t\t\t\t}","+","+\t\t\t\tusing var ic = master.CreateCommand();","+\t\t\t\tic.CommandText = $\"IMPORT DATABASE '{dump.Replace('\\\\', '/')}'\";","+\t\t\t\tic.ExecuteNonQuery();","+\t\t\t\tTestContext.Progress.WriteLine($\"[duckdb-inmemory] preloaded from {srcFile}\");","+\t\t\t}","+\t\t\tfinally","+\t\t\t{","+\t\t\t\ttry { File.Delete(work); } catch { /* best effort */ }","+\t\t\t\ttry { if (Directory.Exists(dump)) Directory.Delete(dump, true); } catch { /* best effort */ }","+\t\t\t}","+\t\t}","+"," \t\tTestContext.Progress.WriteLine($\"[duckdb-inmemory] keep-alive open ({cs})\");"," \t}"," #endif"],"additions":45,"deletions":7,"truncated":false},{"path":"Tests/Linq/UserTests/Issue1373Tests.cs","lines":["@@ -2,7 +2,6 @@"," "," using LinqToDB;"," using LinqToDB.Data;","-using LinqToDB.Internal.Linq;"," using LinqToDB.Mapping;"," "," using NUnit.Framework;","@@ -62,8 +61,6 @@ public class Issue1363CustomRecord2"," \t\t[Test]"," \t\tpublic void Test1([DataSources] string context)"," \t\t{","-\t\t\tQuery.ClearCaches();","-"," \t\t\tvar ms = new MappingSchema();"," \t\t\tms.SetConvertExpression<string?, CustomFieldType?>(s => CustomFieldType.FromString(s));"," \t\t\tms.SetConvertExpression<CustomFieldType, DataParameter>(","@@ -94,8 +91,6 @@ public void Test1([DataSources] string context)"," \t\t[Test]"," \t\tpublic void Test2([DataSources] string context)"," \t\t{","-\t\t\tQuery.ClearCaches();","-"," \t\t\tvar ms = new MappingSchema();"," "," \t\t\tms.SetConvertExpression<string?, CustomFieldType?>(s => CustomFieldType.FromString(s));","@@ -129,8 +124,6 @@ public void Test2([DataSources] string context)"," \t\t[Test]"," \t\tpublic void Test3([DataSources] string context)"," \t\t{","-\t\t\tQuery.ClearCaches();","-"," \t\t\tvar ms = new MappingSchema();"," "," \t\t\tms.SetConvertExpression<string?, CustomFieldType?>(s => CustomFieldType.FromString(s));","@@ -162,8 +155,6 @@ public void T