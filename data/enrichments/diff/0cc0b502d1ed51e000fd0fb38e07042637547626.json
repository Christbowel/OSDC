postmarketos/mkosi.extra/usr/lib/systemd/resolved.conf.d/disable-mdns.conf","lines":["@@ -0,0 +1,7 @@","+# This overrides the following dropin file installed by postmarketos-base-systemd-resolved,","+# which disables MulticastDNS= and breaks integration tests for resolved.","+","+[Resolve]","+# CUPS doesn't work with systemd-resolved's mdns:","+# https://github.com/OpenPrinting/libcups/issues/81","+#MulticastDNS=no"],"additions":7,"deletions":0,"truncated":false},{"path":"mkosi/mkosi.conf.d/postmarketos/mkosi.extra/usr/lib/sysusers.d/10-testuser.conf","lines":["@@ -0,0 +1,4 @@","+# postmarketOS does not support userdbd, so creating the test user via","+# userdbd credentials does not work. We need to create the user entries","+# in /etc/passwd and /etc/group using sysusers instead.","+u testuser 4711 testuser /home/testuser /bin/bash"],"additions":4,"deletions":0,"truncated":false},{"path":"mkosi/mkosi.conf.d/postmarketos/mkosi.extra/usr/lib/tmpfiles.d/10-testuser.conf","lines":["@@ -0,0 +1,4 @@","+# postmarketOS does not support userdbd, so creating the test user via","+# userdbd credentials does not work. We need to create the user's home","+# directory using tmpfiles instead.","+Q /home/testuser 0700 testuser testuser - -"],"additions":4,"deletions":0,"truncated":false},{"path":"mkosi/mkosi.conf.d/postmarketos/mkosi.extra/usr/lib/udev/udev.conf","lines":["@@ -0,0 +1,2 @@","+# This overrides udev.conf installed by postmarketos-base package,","+# which sets udev_log=err and breaks TEST-17-UDEV.verify."],"additions":2,"deletions":0,"truncated":false},{"path":"mkosi/mkosi.extra.common/usr/lib/systemd/system-preset/00-mkosi.preset","lines":["@@ -19,6 +19,13 @@ enable systemd-networkd-wait-online.service"," # systemd-resolved is disabled by default on CentOS so make sure it is enabled."," enable systemd-resolved.service"," ","+# systemd-time-wait-sync.service is enabled by default on postmarketOS.","+# It pulls in time-sync.target, but the target is never reached because the","+# test environment has no Internet connectivity. As a result, timer units","+# cannot be started. Disable the service explicitly to allow timer units to","+# start in the test environment.","+disable systemd-time-wait-sync.service","+"," # systemd-userdbd.socket is disabled by default on OpenSUSE"," enable systemd-userdbd.socket"," ","@@ -61,3 +68,12 @@ disable multipathd.service"," # The socket unit is disabled by default in the upstream:"," # https://github.com/opensvc/multipath-tools/commit/346e9adda4e5f0ccfcbb7a3eccf5f96001d95027"," disable multipathd.socket","+","+# rtkit-daemon.service randomly fails with the following error on postmarketOS:","+# rtkit-daemon[54]: pthread_create failed: Resource temporarily unavailable","+# The service is not necessary on our test suites, let's disable it.","+disable rtkit-daemon.service","+","+# Disable postmarketOS specific zram swap service.","+# Maybe better to replace it with zram-generator?","+disable zram_swap.service"],"additions":16,"deletions":0,"truncated":false},{"path":"mkosi/mkosi.images/build/mkosi.conf.d/postmarketos/mkosi.build.chroot","lines":["@@ -0,0 +1,77 @@","+#!/usr/bin/env bash","+# SPDX-License-Identifier: LGPL-2.1-or-later","+set -e","+","+if [[ \"$1\" == \"clangd\" ]]; then","+    exit 0","+fi","+","+if [[ ! -f \"pkg/$PKG_SUBDIR${GIT_SUBDIR:+/$GIT_SUBDIR}/APKBUILD\" ]]; then","+    echo \"APKBUILD not found at pkg/$PKG_SUBDIR${GIT_SUBDIR:+/$GIT_SUBDIR}/APKBUILD, run mkosi once with -ff to make sure the APKBUILD is cloned\" >&2","+    exit 1","+fi","+","+. mkosi/mkosi.functions","+","+mkdir -p \"$HOME/.abuild\"","+cat >\"$HOME/.abuild/abuild.conf\" <<EOF","+PACKAGER=\"mkosi <mkosi@localhost>\"","+CBUILD=$DISTRIBUTION_ARCHITECTURE","+EOF","+","+# shellcheck disable=SC2046","+abuild-keygen \\","+    $( ((MESON_VERBOSE)) || echo \"--quiet\") \\","+    -n --append","+","+DOWNSTREAM_SRCDIR=\"$(mktemp -d)/$DISTRIBUTION/systemd\"","+mkdir -p \"$DOWNSTREAM_SRCDIR\"","+","+# Copy downstream files.","+cp -vr \"$SRCDIR/pkg/$PKG_SUBDIR${GIT_SUBDIR:+/$GIT_SUBDIR}\"/* \"$DOWNSTREAM_SRCDIR/.\"","+","+# Before RC1, the version in meson.version ends with \"~devel\", e.g. \"261-devel\".","+# After RC1, the RC number prefixed with \"~rc\" is suffixed, e.g. \"261~rc1\".","+# After the final release, the version in meson.version has only number, e.g. \"261\" or \"261.1\".","+VERSION=\"$(sed -e 's/~/_/; s/devel/rc0/' meson.version)\"","+TS=\"${SOURCE_DATE_EPOCH:-$(date +%s)}\"","+RELEASE=\"$(date \"+%Y%m%d%H%M%S\" --date \"@$TS\")\"","+","+# abuild-meson internally sets -Dwerror=false, hence we cannot override it with --werror.","+MESON_OPTIONS=\"${MESON_OPTIONS//--werror/-D werror=true}\"","+","+# Patch version number.","+sed -i \\","+    -e \"/^pkgver=/ s|=.*|=$VERSION|\" \\","+    -e \"/^pkgrel=/ s|=.*|=$RELEASE|\" \\","+    \"$DOWNSTREAM_SRCDIR/APKBUILD\"","+","+# Drop systemd-dbg package when WITH_DEBUG is unset.","+if ! ((WITH_DEBUG)); then","+    sed -i \\","+        -e '/pkgname-dbg/ d' \\","+        \"$DOWNSTREAM_SRCDIR/APKBUILD\"","+fi","+","+# Remove previously built packages.","+rm -rf \"${BUILDDIR:?}/$DISTRIBUTION\"","+","+# shellcheck disable=SC2046","+env \\","+    srcdir=\"$DOWNSTREAM_SRCDIR\" \\","+    APKBUILD=\"$DOWNSTREAM_SRCDIR/APKBUILD\" \\","+    CFLAGS=\"$MKOSI_CFLAGS $CFLAGS\" \\","+    CXXFLAGS=\"$MKOSI_CFLAGS $CFLAGS\" \\","+    LDFLAGS=\"$MKOSI_LDFLAGS $LDFLAGS\" \\","+    REPODEST=\"$BUILDDIR\" \\","+    _systemd_upstream=1 \\","+    _meson_extra_configure_options=\"$MKOSI_MESON_OPTIONS $MESON_OPTIONS\" \\","+    _meson_builddir=\"$BUILDDIR\" \\","+    _upstream_srcdir=\"$SRCDIR\" \\","+    abuild -F \\","+    $( ((MESON_VERBOSE)) && echo \"-v\") \\","+    build \\","+    $( ((WITH_TESTS)) && echo \"check\") \\","+    rootpkg","+","+cp -vr \"$BUILDDIR/$DISTRIBUTION/$DISTRIBUTION_ARCHITECTURE\"/*.apk \"$PACKAGEDIR/.\""],"additions":77,"deletions":0,"truncated":false},{"path":"mkosi/mkosi.images/build/mkosi.conf.d/postmarketos/mkosi.conf","lines":["@@ -0,0 +1,10 @@","+# SPDX-License-Identifier: LGPL-2.1-or-later","+","+[Match]","+Distribution=postmarketos","+","+[Content]","+Packages=","+        alpine-sdk","+        bash","+        kmod"],"additions":10,"deletions":0,"truncated":false},{"path":"mkosi/mkosi.images/build/mkosi.conf.d/postmarketos/mkosi.prepare","lines":["@@ -0,0 +1,21 @@","+#!/usr/bin/env bash","+# SPDX-License-Identifier: LGPL-2.1-or-later","+set -e","+","+if [[ \"$1\" == \"build\" ]] || ((NO_BUILD)); then","+    exit 0","+fi","+","+APKBUILD=\"pkg/$PKG_SUBDIR${GIT_SUBDIR:+/$GIT_SUBDIR}/APKBUILD\"","+if [[ ! -f \"$APKBUILD\" ]]; then","+    echo \"APKBUILD not found at $APKBUILD, run mkosi once with -ff to make sure the APKBUILD is cloned\" >&2","+    exit 1","+fi","+","+# shellcheck source=/dev/null","+CARCH=\"$DISTRIBUTION_ARCHITECTURE\" \\","+     _systemd_upstream=1 \\","+     . \"$APKBUILD\"","+","+# shellcheck disable=SC2086","+mkosi-install ${makedepends:?}"],"additions":21,"deletions":0,"truncated":false},{"path":"mkosi/mkosi.images/minimal-base/mkosi.conf.d/postmarketos.conf","lines":["@@ -0,0 +1,15 @@","+# SPDX-License-Identifier: LGPL-2.1-or-later","+","+[Match]","+Distribution=postmarketos","+","+[Content]","+Packages=","+        coreutils","+        iproute2","+        libcap-utils","+        net-tools","+        nmap-ncat","+","+VolatilePackages=","+        systemd-libs"],"additions":15,"deletions":0,"truncated":false},{"path":"mkosi/mkosi.initrd.conf/mkosi.conf.d/postmarketos.conf","lines":["@@ -0,0 +1,27 @@","+# SPDX-License-Identifier: LGPL-2.1-or-later","+","+[Match]","+Distribution=postmarketos","+","+[Content]","+Packages=","+        btrfs-progs","+        coreutils","+        device-mapper","+        e2fsprogs","+        musl-utils","+        tpm2-tools","+        # For TEST-92-TPM2-SWTPM, install following packages when","+        # https://github.com/systemd/systemd/pull/42760","+        # https://gitlab.alpinelinux.org/alpine/aports/-/work_items/18293","+        # are r