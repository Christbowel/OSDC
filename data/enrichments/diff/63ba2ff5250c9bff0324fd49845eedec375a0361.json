ds Disposable implements IAgentHo"," \tgetCustomizations(sessionType: string): IObservable<readonly ClientPluginCustomization[]> {"," \t\treturn derived(reader => this._customizationsByType.read(reader).get(sessionType)?.read(reader) ?? EMPTY_CUSTOMIZATIONS);"," \t}","+","+\tgetClientTools(sessionType: string): IObservable<readonly ToolDefinition[]> {","+\t\tlet obs = this._clientToolsByType.get(sessionType);","+\t\tif (!obs) {","+\t\t\tobs = derived(reader => {","+\t\t\t\tconst tools = this._allToolsObs.read(reader);","+\t\t\t\tconst toolSets = this._allToolSetsObs.read(reader);","+\t\t\t\tconst enablement = this._toolSetEnablementService.observe(sessionType).read(reader);","+","+\t\t\t\t// Collect the ids of tools that are enabled members of at least one tool set surfaced in","+\t\t\t\t// the Agents window Tools section (non-deprecated).","+\t\t\t\tconst enabledToolIds = new Set<string>();","+\t\t\t\tfor (const ts of toolSets) {","+\t\t\t\t\tif (ts.deprecated) {","+\t\t\t\t\t\tcontinue;","+\t\t\t\t\t}","+\t\t\t\t\tfor (const tool of ts.getTools(reader)) {","+\t\t\t\t\t\tif (isToolEnabledInSet(enablement, ts.id, tool.id)) {","+\t\t\t\t\t\t\tenabledToolIds.add(tool.id);","+\t\t\t\t\t\t}","+\t\t\t\t\t}","+\t\t\t\t}","+\t\t\t\treturn tools.filter(t => enabledToolIds.has(t.id)).map(toolDataToDefinition);","+\t\t\t});","+\t\t\tthis._clientToolsByType.set(sessionType, obs);","+\t\t}","+\t\treturn obs;","+\t}"," }"," "," const EMPTY_CUSTOMIZATIONS: readonly ClientPluginCustomization[] = Object.freeze([]);"],"additions":50,"deletions":17,"truncated":false},{"path":"src/vs/workbench/contrib/chat/browser/agentSessions/agentHost/agentHostChatContribution.ts","lines":["@@ -29,7 +29,7 @@ import { authenticateProtectedResources, AgentHostAuthTokenCache, resolveAuthent"," import { AgentHostLanguageModelProvider, agentHostProviderSupportsAutoModel } from './agentHostLanguageModelProvider.js';"," import { AgentHostSessionHandler } from './agentHostSessionHandler.js';"," import { IAgentHostActiveClientService } from './agentHostActiveClientService.js';","-import { AICustomizationSources } from '../../../common/aiCustomizationWorkspaceService.js';","+import { AICustomizationManagementSection, AICustomizationSources } from '../../../common/aiCustomizationWorkspaceService.js';"," "," const LOCAL_AGENT_HOST_SESSION_TYPE_PREFIX = 'agent-host-';"," ","@@ -247,7 +247,8 @@ export class AgentHostContribution extends Disposable implements IWorkbenchContr"," \t\t\tid: sessionType,"," \t\t\tlabel: localize('agentHostHarnessLabel.local', \"{0} [Agent Host]\", agent.displayName),"," \t\t\ticon: ThemeIcon.fromId(Codicon.server.id),","-\t\t\thiddenSections: [],","+\t\t\t// The Tools section is surfaced for the Copilot CLI agent host only.","+\t\t\thiddenSections: agent.provider === 'copilotcli' ? [] : [AICustomizationManagementSection.Tools],"," \t\t\thideGenerateButton: true,"," \t\t\tgetStorageSourceFilter: () => ({ sources: AICustomizationSources.all }),"," \t\t\tsyncProvider,"],"additions":3,"deletions":2,"truncated":false},{"path":"src/vs/workbench/contrib/chat/browser/agentSessions/agentHost/agentHostSessionHandler.ts","lines":["@@ -582,7 +582,7 @@ export class AgentHostSessionHandler extends Disposable implements IChatSessionC"," \t\tthis._config = config;"," "," \t\tthis._register(autorun(reader => {","-\t\t\tconst defs = this._activeClientService.clientTools.read(reader);","+\t\t\tconst defs = this._activeClientService.getClientTools(this._config.sessionType).read(reader);"," \t\t\tfor (const [sessionResource] of this._activeSessions) {"," \t\t\t\tconst backendSession = this._resolveSessionUri(sessionResource);"," \t\t\t\tconst state = this._getSessionState(backendSession.toString());"],"additions":1,"deletions":1,"truncated":false},{"path":"src/vs/workbench/contrib/chat/browser/agentSessions/agentHost/agentHostToolSetEnablementService.ts","lines":["@@ -0,0 +1,217 @@","+/*---------------------------------------------------------------------------------------------","+ *  Copyright (c) Microsoft Corporation. All rights reserved.","+ *  Licensed under the MIT License. See License.txt in the project root for license information.","+ *--------------------------------------------------------------------------------------------*/","+","+import { Disposable, DisposableStore } from '../../../../../../base/common/lifecycle.js';","+import { derived, IObservable, IReader, ISettableObservable, observableValue } from '../../../../../../base/common/observable.js';","+import { InstantiationType, registerSingleton } from '../../../../../../platform/instantiation/common/extensions.js';","+import { createDecorator } from '../../../../../../platform/instantiation/common/instantiation.js';","+import { IStorageService, StorageScope, StorageTarget } from '../../../../../../platform/storage/common/storage.js';","+","+export const IAgentHostToolSetEnablementService = createDecorator<IAgentHostToolSetEnablementService>('agentHostToolSetEnablementService');","+","+/**","+ * The Copilot CLI agent-host session type. Tool enablement is scoped per session type; this is the","+ * only target for the Chat Customizations → Tools section today.","+ */","+export const AGENT_HOST_COPILOT_CLI_SESSION_TYPE = 'agent-host-copilotcli';","+","+/**","+ * Tool / tool-set enablement state. Both maps are keyed by id and store only deviations from the","+ * default (\"enabled\"). A tool's effective state resolves child → parent → default:","+ * `tools[toolId] ?? toolSets[setId] ?? true`. Storing the tool-set default (rather than every","+ * member) lets a disabled group also cover member tools that register later.","+ */","+export interface IToolEnablementState {","+\treadonly toolSets: ReadonlyMap<string, boolean>;","+\treadonly tools: ReadonlyMap<string, boolean>;","+}","+","+export type TriState = boolean | 'mixed';","+","+/** Whether `toolId`, as a member of `toolSetId`, is effectively enabled. */","+export function isToolEnabledInSet(state: IToolEnablementState, toolSetId: string, toolId: string): boolean {","+\treturn state.tools.get(toolId) ?? state.toolSets.get(toolSetId) ?? true;","+}","+","+/** Aggregate tri-state of a tool set, derived from its member tools' effective states. */","+export function getToolSetTriState(state: IToolEnablementState, toolSetId: string, toolIds: readonly string[]): TriState {","+\tlet anyOn = false;","+\tlet anyOff = false;","+\tfor (const toolId of toolIds) {","+\t\tif (isToolEnabledInSet(state, toolSetId, toolId)) {","+\t\t\tanyOn = true;","+\t\t} else {","+\t\t\tanyOff = true;","+\t\t}","+\t\tif (anyOn && anyOff) {","+\t\t\treturn 'mixed';","+\t\t}","+\t}","+\treturn anyOn;","+}","+","+/** The subset of a tool set needed to count its enabled tools. {@link IToolSet} satisfies this shape. */","+export interface ICountableToolSet {","+\treadonly id: string;","+\treadonly deprecated?: boolean;","+\tgetTools(reader?: IReader): Iterable<{ readonly id: string }>;","+}","+","+/** Counts the enabled tools across the non-deprecated tool sets surfaced in Chat Customizations → Tools. */","+export function countEnabledCustomizationTools(toolSets: Iterable<ICountableToolSet>, state: IToolEnablementState, reader?: IReader): number {","+\tlet count = 0;","+\tfor (const ts of toolSets) {","+\t\tif (ts.deprecated) {","+\t\t\tcontinue;","+\t\t}","+\t\tfor (const tool of ts.getTools(reader)) {","+\t\t\tif (isToolEnabledInSet(state, ts.id, tool.id)) {","+\t\t\t\tcount++;","+\t\t\t}","+\t\t}","+\t}","+\treturn count;","+}","+","+/**","+ * Per-session-type tool / tool-set enablement for the Chat Customizations → Tools section,","+ * persisted profile-wide. Settings are consumed by the agent host (the only target for Tools","+ * customizations today).","+ */","+export interface IAgentHostToolSetEnablementService {","+\treadonly _serviceBrand: undefined;","+","+\t/** Observable enablement state for `sessionType`. Missing keys default to enabled. */","+\tobserve(sessionType: string): IObservable<IToolEnablementState>;","+","+\t/** Current enablement state for `sessionType`. */","+\tgetState(sessionType: string): IToolEnablementState;","+","+\t/** Enable/disable a whole tool set; clears any per-tool overrides for its members. */","+\tsetToolSetEnabled(sessionType: string, toolSetId: string, toolIds: readonly string[], enabled: boolean): void;","+","+\t/** Enable/disable a single tool within `toolSetId`. */","+\tsetToolEnabled(sessionType: string, toolSetId: string, toolId: string, enabled: boolean): void;","+}","+","+const STORAGE_KEY = 'chat.agentHost.toolSetEnablement';","+const EMPTY_STATE: IToolEnablementState = { toolSets: new Map(), tools: new Map() };","+","+interface IStoredShape {","+\treadonly [sessionType: string]: {","+\t\treadonly toolSets?: { readonly [id: string]: boolean };","+\t\treadonly tools?: { readonly [id: string]: boolean };","+\t};","+}","+","+export class AgentHostToolSetEnablementService extends Disposable implements IAgentHostToolSetEnablementService {","+\tdeclare readonly _serviceBrand: undefined;","+","+\tprivate readonly _state: ISettableObservable<ReadonlyMap<string, IToolEnablementState>>;","+","+\tconstructor(","+\t\t@IStorageService private readonly _storageService: IStorageService,","+\t) {","+\t\tsuper();","+\t\tthis._state = observableValue('agentHostToolSetEnablement', this._load());","+\t\tconst storeForListener = this._register(new DisposableStore());","+\t\tthis._register(this._storageService.onDidChangeValue(StorageScope.PROFILE, STORAGE_KEY, storeForListener)(() => {","+\t\t\tthis._state.set(this._load(), undefined);","+\t\t}));","+\t}","+","+\tobserve(sessionType: string): IObservable<IToolEnablementState> {","+\t\treturn derived(reader => this._state.read(reader).get(sessionType) ?? EMPTY_STATE);","+\t}","+","+\tgetState(sessionType: string): IToolEnablementState {","+\t\treturn this._state.get().get(sessionType) ?? EMPTY_STATE;","+\t}","+","+\tsetToolSetEnabled(sessionType: string, toolSetId: string, toolIds: readonly string[], enabled: boolean): void {","+\t\tconst state = this.getState(sessionType);","+\t\tconst toolSets = new Map(state.toolSets);","+\t\tconst tools = new Map(state.tools);","+\t\t// Default is enabled, so an enabled set is the absence of an entry.","+\t\tif (enabled) {","+\t\t\ttoolSets.delete(toolSetId);","+\t\t} else {","+\t\t\ttoolSets.set(toolSetId, false);","+\t\t}","+\t\t// The set toggle is authoritative: drop any per-tool overrides so members follow it.","+\t\tfor (const toolId of toolIds) {","+\t\t\ttools.delete(toolId);","+\t\t}","+\t\tthis._setState(sessionType, { toolSets, tools });","+\t}","+","+\tsetToolEnabled(sessionType: string, toolSetId: string, toolId: string, enabled: boolean): void {","+\t\tconst state = this.getState(sessionType);","+\t\tconst tools = new Map(state.tools);","+\t\t// Keep storage sparse: only record overrides that differ from the set's default.","+\t\tconst setDefault = state.toolSets.get(toolSetId) ?? true;","+\t\tif (enabled === setDefault) {","+\t\t\ttools.delete(toolId);","+\t\t} else {","+\t\t\ttools.set(toolId, enabled);","+\t\t}","+\t\tthis._setState(sessionType, { toolSets: state.toolSets, tools });","+\t}","+","+\tprivate _setState(sessionType: string, next: IToolEnablementState): void {","+\t\tconst current = new Map(this._state.get());","+\t\tif (next.toolSets.size === 0 && next.tools.size === 0) {","+\t\t\tcurrent.delete(sessionType);","+\t\t} else {","+\t\t\tcurrent.set(sessionType, { toolSets: new Map(next.toolSets), tools: new Map(next.tools) });","+\t\t}","+\t\tthis._state.set(current, undefined);","+\t\tthis._save(current);","+\t}","+","+\tprivate _load(): ReadonlyMap<string, IToolEnablementState> {","+\t\tconst raw = this._storageService.get(STORAGE_KEY, StorageScope.PROFILE);","+\t\tif (!raw) {","+\t\t\treturn new Map();","+\t\t}","+\t\ttry {","+\t\t\tconst parsed = JSON.parse(raw) as IStoredShape;","+\t\t\tconst out = new Map<string, IToolEnablementState>();","+\t\t\tfor (const [sessionType, entry] of Object.entries(parsed)) {","+\t\t\t\tconst toolSets = new Map<string, boolean>();","+\t\t\t\tconst tools = new Map<string, boolean>();","+\t\t\t\tfor (const [id, value] of Object.entries(entry.toolSets ?? {})) {","+\t\t\t\t\ttoolSets.set(id, value);","+\t\t\t\t}","+\t\t\t\tfor (const [id, value] of Object.entries(entry.tools ?? {})) {","+\t\t\t\t\ttools.set(id, value);","+\t\t\t\t}","+\t\t\t\tif (toolSets.size > 0 || tools.size > 0) {","+\t\t\t\t\tout.set(sessionType, { toolSets, tools });","+\t\t\t\t}","+\t\t\t}","+\t\t\treturn out;","+\t\t} catch {","+\t\t\treturn new Map();","+\t\t}","+\t}","+","+\tprivate _save(state: ReadonlyMap<string, IToolEnablementState>): void {","+\t\tif (state.size === 0) {","+\t\t\tthis._storageService.remove(STORAGE_KEY, StorageScope.PROFILE);","+\t\t\treturn;","+\t\t}","+\t\tconst out: Record<string, { toolSets: Record<string, boolean>; tools: Record<string, boolean> }> = {};","+\t\tfor (const [sessionType, entry] of state) {","+\t\t\tout[sessionType] = {","+\t\t\t\ttoolSets: Object.fromEntries(entry.toolSets),","+\t\t\t\ttools: Object.fromEntries(entry.tools),","+\t\t\t};","+\t\t}","+\t\tthis._storageService.store(STORAGE_KEY, JSON.stringify(out), StorageScope.PROFILE, StorageTarget.MACHINE);","+\t}","+}","+","+registerSingleton(IAgentHostToolSetEnablementService, AgentHostToolSetEnablementService, InstantiationType.Delayed);"],"additions":217,"deletions":0,"truncated":false},{"path":"src/vs/workbench/contrib/chat/browser/aiCustomization/aiCustomizationIcons.ts","lines":["@@ -69,6 +69,11 @@ export const extensionIcon = registerIcon('ai-customization-extension', Codicon.","  */"," export const pluginIcon = registerIcon('ai-customization-plugin', Codicon.plug, localize('aiCustomizationPluginIcon', \"Icon for plugin-contributed items.\"));"],"additions":0,"deletions":0,"truncated":false}],"additions":323,"deletions":23,"truncated":true,"file_count":11},"error":null,"fetched_at":"2026-06-25T10:32:31.540721+00:00"}