\treturn &property{","+\t\tstate: newState(value),","+\t}","+}","+","+func (p *property) Value() any {","+\tp.mu.Lock()","+\tdefer p.mu.Unlock()","+","+\treturn p.state.value","+}","+","+func (p *property) Update(value any) {","+\tp.mu.Lock()","+\tdefer p.mu.Unlock()","+","+\tnext := newState(value)","+\tp.state.next = next","+\tclose(p.state.done)","+\tp.state = next","+}","+","+func (p *property) Observe() Stream {","+\tp.mu.Lock()","+\tdefer p.mu.Unlock()","+","+\treturn &stream{","+\t\tproperty: p,","+\t\tstate:    p.state,","+\t}","+}","+","+func (s *stream) Value() any {","+\ts.property.mu.Lock()","+\tdefer s.property.mu.Unlock()","+","+\treturn s.state.value","+}","+","+func (s *stream) Changes() chan struct{} {","+\ts.property.mu.Lock()","+\tdefer s.property.mu.Unlock()","+","+\treturn s.state.done","+}","+","+func (s *stream) Next() any {","+\ts.property.mu.Lock()","+\tdefer s.property.mu.Unlock()","+","+\tif s.state.next != nil {","+\t\ts.state = s.state.next","+\t}","+\treturn s.state.value","+}","+","+func (s *stream) WaitNext() any {","+\t<-s.Changes()","+\treturn s.Next()","+}","+","+func (s *stream) HasNext() bool {","+\ts.property.mu.Lock()","+\tdefer s.property.mu.Unlock()","+","+\treturn s.state.next != nil","+}","+","+func (s *stream) Clone() Stream {","+\ts.property.mu.Lock()","+\tdefer s.property.mu.Unlock()","+","+\treturn &stream{","+\t\tproperty: s.property,","+\t\tstate:    s.state,","+\t}","+}","+","+func newState(value any) *state {","+\treturn &state{","+\t\tvalue: value,","+\t\tdone:  make(chan struct{}),","+\t}","+}"],"additions":123,"deletions":0,"truncated":false},{"path":"pkg/common/observer/observer_test.go","lines":["@@ -0,0 +1,132 @@","+package observer","+","+import (","+\t\"testing\"","+\t\"time\"","+","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+)","+","+func TestPropertyStreamObservesUpdate(t *testing.T) {","+\tproperty := NewProperty(\"initial\")","+\tstream := property.Observe()","+","+\tassert.Equal(t, \"initial\", property.Value())","+\tassert.Equal(t, \"initial\", stream.Value())","+\tassert.False(t, stream.HasNext())","+","+\tproperty.Update(\"updated\")","+","+\trequireChange(t, stream.Changes())","+\tassert.True(t, stream.HasNext())","+\tassert.Equal(t, \"updated\", stream.Next())","+\tassert.Equal(t, \"updated\", stream.Value())","+\tassert.Equal(t, \"updated\", property.Value())","+\tassert.False(t, stream.HasNext())","+}","+","+func TestWaitNextBlocksUntilUpdate(t *testing.T) {","+\tproperty := NewProperty(\"initial\")","+\tstream := property.Observe()","+","+\tready := make(chan struct{})","+\tresult := make(chan any, 1)","+\tgo func() {","+\t\tclose(ready)","+\t\tresult <- stream.WaitNext()","+\t}()","+","+\t<-ready","+\tselect {","+\tcase value := <-result:","+\t\tt.Fatalf(\"WaitNext returned before update: %v\", value)","+\tcase <-time.After(20 * time.Millisecond):","+\t}","+","+\tproperty.Update(\"updated\")","+","+\tselect {","+\tcase value := <-result:","+\t\tassert.Equal(t, \"updated\", value)","+\tcase <-time.After(time.Second):","+\t\tt.Fatal(\"timed out waiting for WaitNext\")","+\t}","+}","+","+func TestStreamDeliversSequentialUpdatesInOrder(t *testing.T) {","+\tproperty := NewProperty(0)","+\tstream := property.Observe()","+","+\tproperty.Update(1)","+\tproperty.Update(2)","+\tproperty.Update(3)","+","+\tfor _, expected := range []int{1, 2, 3} {","+\t\trequire.True(t, stream.HasNext())","+\t\trequireChange(t, stream.Changes())","+\t\tassert.Equal(t, expected, stream.Next())","+\t\tassert.Equal(t, expected, stream.Value())","+\t}","+\tassert.False(t, stream.HasNext())","+\trequireNoChange(t, stream.Changes())","+}","+","+func TestIndependentStreamsObserveCurrentValue(t *testing.T) {","+\tproperty := NewProperty(\"initial\")","+\tstreamA := property.Observe()","+","+\tproperty.Update(\"current\")","+\tstreamB := property.Observe()","+","+\tassert.Equal(t, \"initial\", streamA.Value())","+\tassert.True(t, streamA.HasNext())","+\tassert.Equal(t, \"current\", streamB.Value())","+\tassert.False(t, streamB.HasNext())","+","+\tassert.Equal(t, \"current\", streamA.Next())","+\tproperty.Update(\"next\")","+","+\tassert.Equal(t, \"next\", streamA.Next())","+\tassert.Equal(t, \"next\", streamB.Next())","+\tassert.Equal(t, \"next\", streamA.Value())","+\tassert.Equal(t, \"next\", streamB.Value())","+}","+","+func TestStreamCloneCopiesCursor(t *testing.T) {","+\tproperty := NewProperty(\"initial\")","+\tstream := property.Observe()","+","+\tproperty.Update(\"first\")","+\tclone := stream.Clone()","+","+\tassert.Equal(t, \"initial\", stream.Value())","+\tassert.Equal(t, \"initial\", clone.Value())","+\tassert.Equal(t, \"first\", stream.Next())","+\tassert.Equal(t, \"first\", clone.Next())","+","+\tproperty.Update(\"second\")","+","+\tassert.Equal(t, \"second\", stream.Next())","+\tassert.Equal(t, \"second\", clone.Next())","+}","+","+func requireChange(t *testing.T, changes chan struct{}) {","+\tt.Helper()","+","+\tselect {","+\tcase <-changes:","+\tcase <-time.After(time.Second):","+\t\tt.Fatal(\"timed out waiting for change\")","+\t}","+}","+","+func requireNoChange(t *testing.T, changes chan struct{}) {","+\tt.Helper()","+","+\tselect {","+\tcase <-changes:","+\t\tt.Fatal(\"unexpected change\")","+\tcase <-time.After(20 * time.Millisecond):","+\t}","+}"],"additions":132,"deletions":0,"truncated":false},{"path":"pkg/server/svid/rotator.go","lines":["@@ -6,8 +6,8 @@ import ("," \t\"crypto/x509\""," \t\"time\""," ","-\t\"github.com/imkira/go-observer\""," \t\"github.com/sirupsen/logrus\"","+\t\"github.com/spiffe/spire/pkg/common/observer\""," \t\"github.com/spiffe/spire/pkg/common/telemetry\""," \ttelemetry_server \"github.com/spiffe/spire/pkg/common/telemetry/server\""," \t\"github.com/spiffe/spire/pkg/server/ca\""],"additions":1,"deletions":1,"truncated":false},{"path":"pkg/server/svid/rotator_config.go","lines":["@@ -4,8 +4,8 @@ import ("," \t\"time\""," "," \t\"github.com/andres-erbsen/cloc