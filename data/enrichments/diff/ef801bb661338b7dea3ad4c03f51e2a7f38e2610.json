r/testify/require\"","+)","+","+func TestOAuth2AvatarFromPicture(t *testing.T) {","+\tdefer tests.PrepareTestEnv(t)()","+\tdefer test.MockVariableValue(&setting.OAuth2Client.UpdateAvatar, true)()","+","+\tmockServer := createOAuth2MockProvider()","+\tdefer mockServer.Close()","+\taddOAuth2Source(t, \"test-oidc-avatar\", oauth2.Source{","+\t\tProvider:                      \"openidConnect\",","+\t\tClientID:                      \"test-client-id\",","+\t\tOpenIDConnectAutoDiscoveryURL: mockServer.URL + \"/.well-known/openid-configuration\",","+\t})","+\tauthSource, err := auth_model.GetActiveOAuth2SourceByAuthName(t.Context(), \"test-oidc-avatar\")","+\trequire.NoError(t, err)","+\tproviderName := authSource.Cfg.(*oauth2.Source).Provider","+","+\tt.Run(\"AutoRegister\", func(t *testing.T) {","+\t\tdefer test.MockVariableValue(&setting.OAuth2Client.Username, \"\")()","+\t\tdefer test.MockVariableValue(&setting.OAuth2Client.EnableAutoRegistration, true)()","+\t\tdefer test.MockVariableValue(&gothic.CompleteUserAuth, func(res http.ResponseWriter, req *http.Request) (goth.User, error) {","+\t\t\treturn goth.User{","+\t\t\t\tProvider:  providerName,","+\t\t\t\tUserID:    \"oidc-user-ua-pic\",","+\t\t\t\tEmail:     \"oidc-user-ua-pic@example.com\",","+\t\t\t\tName:      \"OIDC UA Pic\",","+\t\t\t\tAvatarURL: mockServer.URL + \"/avatar.png\",","+\t\t\t}, nil","+\t\t})()","+","+\t\treq := NewRequest(t, \"GET\", \"/user/oauth2/test-oidc-avatar/callback?code=XYZ&state=XYZ\")","+\t\temptyTestSession(t).MakeRequest(t, req, http.StatusSeeOther)","+","+\t\tuser := unittest.AssertExistsAndLoadBean(t, &user_model.User{LoginName: \"oidc-user-ua-pic\"})","+\t\tassert.True(t, user.UseCustomAvatar, \"avatar must sync (requires Gitea UA)\")","+\t\tassert.NotEmpty(t, user.Avatar)","+\t})","+","+\tt.Run(\"LinkAccountRegister\", func(t *testing.T) {","+\t\tconst newUserName = \"oidc-link-register\"","+\t\tdefer web.RouteMockReset()","+\t\tweb.RouteMock(web.MockAfterMiddlewares, func(ctx *context.Context) {","+\t\t\trequire.NoError(t, auth.Oauth2SetLinkAccountData(ctx, auth.LinkAccountData{","+\t\t\t\tAuthSourceID: authSource.ID,","+\t\t\t\tGothUser: goth.User{","+\t\t\t\t\tProvider:  providerName,","+\t\t\t\t\tUserID:    \"oidc-link-register-sub\",","+\t\t\t\t\tEmail:     \"oidc-link-register-a@example.com\",","+\t\t\t\t\tName:      \"OIDC Link Register\",","+\t\t\t\t\tAvatarURL: mockServer.URL + \"/avatar.png\",","+\t\t\t\t},","+\t\t\t}))","+\t\t})","+","+\t\treq := NewRequestWithValues(t, \"POST\", \"/user/link_account_signup\", map[string]string{","+\t\t\t\"user_name\": newUserName,","+\t\t\t\"email\":     \"oidc-link-register-b@example.com\",","+\t\t\t\"password\":  \"AVeryStrongPassword!1\",","+\t\t\t\"retype\":    \"AVeryStrongPassword!1\",","+\t\t})","+\t\temptyTestSession(t).MakeRequest(t, req, http.StatusSeeOther)","+","+\t\tuser := unittest.AssertExistsAndLoadBean(t, &user_model.User{LowerName: newUserName})","+\t\trequire.Equal(t, auth_model.OAuth2, user.LoginType)","+\t\tassert.True(t, user.UseCustomAvatar, \"register-link flow must sync avatar from `picture` claim\")","+\t\tassert.NotEmpty(t, user.Avatar)","+\t})","+}"],"additions":92,"deletions":0,"truncated":false},{"path":"tests/integration/oauth_test.go","lines":["@@ -7,6 +7,8 @@ import ("," \t\"bytes\""," \t\"encoding/base64\""," \t\"fmt\"","+\t\"image\"","+\t\"image/png\""," \t\"io\""," \t\"net/http\""," \t\"net/http/httptest\"","@@ -1062,6 +1064,13 @@ func createOAuth2MockProvider() *httptest.Server {"," \tvar mockServer *httptest.Server"," \tmockServer = httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {"," \t\tswitch r.URL.Path {","+\t\tcase \"/avatar.png\":","+\t\t\tif !strings.HasPrefix(r.Header.Get(\"User-Agent\"), \"Gitea \") {","+\t\t\t\thttp.Error(w, \"user agent doesn't match\", http.StatusForbidden)","+\t\t\t\treturn","+\t\t\t}","+\t\t\tw.Header().Set(\"Content-Type\", \"image/png\")","+\t\t\t_ = png.Encode(w, image.NewRGBA(image.Rect(0, 0,