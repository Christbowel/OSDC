rotection_error(&mut self, _error: ProtectionError) -> Response<B> {","+        let mut response = Response::new(B::default());","+        *response.status_mut() = StatusCode::FORBIDDEN;","+","+        response","+    }","+}"],"additions":45,"deletions":0,"truncated":false},{"path":"tower-http/src/csrf/service.rs","lines":["@@ -0,0 +1,216 @@"],"additions":0,"deletions":0,"truncated":false}],"additions":1273,"deletions":0,"truncated":true,"file_count":6},"error":null,"fetched_at":"2026-05-31T10:02:40.586670+00:00"}