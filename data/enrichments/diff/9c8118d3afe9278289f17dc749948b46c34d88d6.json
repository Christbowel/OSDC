     *bool             `yaml:\"enabled\" json:\"enabled\" doc:\"description=Override shard_streams.enabled for a specific policy.\"`","+\tDesiredRate              *flagext.ByteSize `yaml:\"desired_rate\" json:\"desired_rate\" doc:\"description=Override shard_streams.desired_rate for a specific policy.\"`","+\tTimeShardingEnabled      *bool             `yaml:\"time_sharding_enabled\" json:\"time_sharding_enabled\" doc:\"description=Override shard_streams.time_sharding_enabled for a specific policy.\"`","+\tTimeShardingIgnoreRecent *model.Duration   `yaml:\"time_sharding_ignore_recent\" json:\"time_sharding_ignore_recent\" doc:\"description=Override shard_streams.time_sharding_ignore_recent for a specific policy.\"`","+\tLoggingEnabled           *bool             `yaml:\"logging_enabled\" json:\"logging_enabled\" doc:\"description=Override shard_streams.logging_enabled for a specific policy.\"`","+}","+","+// ApplyTo returns base with only the override's non-nil fields replaced. A nil override (or one","+// with all-nil fields) returns base unchanged.","+func (o *PerPolicyConfigOverride) ApplyTo(base shardstreams.Config) shardstreams.Config {","+\tif o == nil {","+\t\treturn base","+\t}","+\tif o.Enabled != nil {","+\t\tbase.Enabled = *o.Enabled","+\t}","+\tif o.DesiredRate != nil {","+\t\tbase.DesiredRate = *o.DesiredRate","+\t}","+\tif o.TimeShardingEnabled != nil {","+\t\tbase.TimeShardingEnabled = *o.TimeShardingEnabled","+\t}","+\tif o.TimeShardingIgnoreRecent != nil {","+\t\tbase.TimeShardingIgnoreRecent = time.Duration(*o.TimeShardingIgnoreRecent)","+\t}","+\tif o.LoggingEnabled != nil {","+\t\tbase.LoggingEnabled = *o.LoggingEnabled","+\t}","+\treturn base","+}","+","+// PolicyOverridableLimits holds the per-policy overrides for a single policy. Every field is a","+// pointer: a nil field means \"not overridden\" (the tenant value is inherited); a non-nil field","+// overrides the tenant value for streams resolved to the policy.","+type PolicyOverridableLimits struct {","+\tMaxLocalStreamsPerUser  *int                     `yaml:\"max_streams_per_user\" json:\"max_streams_per_user\" doc:\"hidden\"`","+\tMaxGlobalStreamsPerUser *int                     `yaml:\"max_global_streams_per_user\" json:\"max_global_streams_per_user\" doc:\"hidden\"`","+\tIngestionRateMB         *float64                 `yaml:\"ingestion_rate_mb\" json:\"ingestion_rate_mb\" doc:\"hidden\"`","+\tIngestionBurstSizeMB    *float64                 `yaml:\"ingestion_burst_size_mb\" json:\"ingestion_burst_size_mb\" doc:\"hidden\"`","+\tPerStreamRateLimit      *flagext.ByteSize        `yaml:\"per_stream_rate_limit\" json:\"per_stream_rate_limit\" doc:\"hidden\"`","+\tPerStreamRateLimitBurst *flagext.ByteSize        `yaml:\"per_stream_rate_limit_burst\" json:\"per_stream_rate_limit_burst\" doc:\"hidden\"`","+\tShardStreams            *PerPolicyConfigOverride `yaml:\"shard_streams\" json:\"shard_streams\" doc:\"hidden\"`","+}","+","+// Validate checks that the overridden values are non-negative. Returned errors are field-scoped;","+// callers add the policy context.","+func (p PolicyOverridableLimits) Validate() error {","+\tif (p.IngestionRateMB != nil && *p.IngestionRateMB < 0) || (p.IngestionBurstSizeMB != nil && *p.IngestionBurstSizeMB < 0) {","+\t\treturn errors.New(\"ingestion_rate_mb and ingestion_burst_size_mb must be >= 0\")","+\t}","+\tif (p.PerStreamRateLimit != nil && p.PerStreamRateLimit.Val() < 0) || (p.PerStreamRateLimitBurst != nil && p.PerStreamRateLimitBurst.Val() < 0) {","+\t\treturn errors.New(\"per_stream_rate_limit and per_stream_rate_limit_burst must be >= 0\")","+\t}","+\tif p.ShardStreams != nil && p.ShardStreams.DesiredRate != nil && p.ShardStreams.DesiredRate.Val() < 0 {","+\t\treturn errors.New(\"shard_streams.desired_rate must be >= 0\")","+\t}","+\treturn nil","+}","+","+// IngestionPolicyOverrideLimits exposes the per-policy limit overrides. Each scalar accessor","+// returns (value, overridden) where overridden reports whether the policy explicitly set that","+// limit; when false the caller should fall back to the tenant-level limit.","+type IngestionPolicyOverrideLimits interface {","+\tPolicyMaxLocalStreamsPerUser(userID, policy string) (int, bool)","+\tPolicyMaxGlobalStreamsPerUser(userID, policy string) (int, bool)","+\tPolicyIngestionRateBytes(userID, policy string) (float64, bool)","+\tPolicyIngestionBurstSizeBytes(userID, policy string) (int, bool)","+\tPolicyPerStreamRateLimit(userID, policy string) (RateLimit, bool)","+\tPolicyShardStreams(userID, policy string) (shardstreams.Config, bool)","+}","+","+// policyOverride returns the override entry for the given policy, or (zero, false) when the policy","+// is empty or has no entry.","+func (o *Overrides) policyOverride(userID, policy string) (PolicyOverridableLimits, bool) {","+\tif policy == \"\" {","+\t\treturn PolicyOverridableLimits{}, false","+\t}","+\tpl, ok := o.getOverridesForUser(userID).PolicyOverrideLimits[policy]","+\treturn pl, ok","+}","+","+func (o *Overrides) PolicyMaxLocalStreamsPerUser(userID, policy string) (int, bool) {","+\tif pl, ok := o.policyOverride(userID, policy); ok && pl.MaxLocalStreamsPerUser != nil {","+\t\treturn *pl.MaxLocalStreamsPerUser, true","+\t}","+\treturn 0, false","+}","+","+func (o *Overrides) PolicyMaxGlobalStreamsPerUser(userID, policy string) (int, bool) {","+\tif pl, ok := o.policyOverride(userID, policy); ok && pl.MaxGlobalStreamsPerUser != nil {","+\t\treturn *pl.MaxGlobalStreamsPerUser, true","+\t}","+\treturn 0, false","+}","+","+func (o *Overrides) PolicyIngestionRateBytes(userID, policy string) (float64, bool) {","+\tif pl, ok := o.policyOverride(userID, policy); ok && pl.IngestionRateMB != nil {","+\t\treturn *pl.IngestionRateMB * bytesInMB, true","+\t}","+\treturn 0, false","+}","+","+// PolicyIngestionBurstSizeBytes returns the per-policy ingestion burst and whether it was","+// overridden. overridden is true whenever the policy explicitly sets the burst, including an","+// explicit 0 (which blocks ingestion); callers must gate on the bool, not on a non-zero value.","+func (o *Overrides) PolicyIngestionBurstSizeBytes(userID, policy string) (int, bool) {","+\tif pl, ok := o.policyOverride(userID, policy); ok && pl.IngestionBurstSizeMB != nil {","+\t\treturn int(*pl.IngestionBurstSizeMB * bytesInMB), true","+\t}","+\treturn 0, false","+}","+","+// PolicyPerStreamRateLimit is overridden iff either the rate or the burst is set; the unset half","+// inherits the tenant per-stream limit so the returned RateLimit is always complete.","+func (o *Overrides) PolicyPerStreamRateLimit(userID, policy string) (RateLimit, bool) {","+\tpl, ok := o.policyOverride(userID, policy)","+\tif !ok || (pl.PerStreamRateLimit == nil && pl.PerStreamRateLimitBurst == nil) {","+\t\treturn RateLimit{}, false","+\t}","+\trl := o.PerStreamRateLimit(userID)","+\tif pl.PerStreamRateLimit != nil {","+\t\trl.Limit = rate.Limit(float64(pl.PerStreamRateLimit.Val()))","+\t}","+\tif pl.PerStreamRateLimitBurst != nil {","+\t\trl.Burst = pl.PerStreamRateLimitBurst.Val()","+\t}","+\treturn rl, true","+}","+","+// PolicyShardStreams returns the effective shard_streams config for the policy (the tenant config","+// with the policy's overrides applied) and whether the policy overrides shard_streams. The","+// returned config is always usable (it is the tenant config when not overridden).","+func (o *Overrides) PolicyShardStreams(userID, policy string) (shardstreams.Config, bool) {","+\tbase := o.getOverridesForUser(userID).ShardStreams","+\tif pl, ok := o.policyOverride(userID, policy); ok && pl.ShardStreams != nil {","+\t\treturn pl.ShardStreams.ApplyTo(base), true","+\t}","+\treturn base, false","+}"],"additions":150,"deletions":0,"truncated":false},{"path":"pkg/validation/ingestion_policies_test.go","lines":["@@ -5,10 +5,15 @@ import ("," \t\"net/http\""," \t\"net/http/httptest\""," \t\"testing\"","+\t\"time\""," ","+\t\"github.com/prometheus/common/model\""," \t\"github.com/pr