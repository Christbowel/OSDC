\t\tname: \"all fields overridden\",","+\t\t\toverride: &PerPolicyConfigOverride{","+\t\t\t\tEnabled:                  ptr(false),","+\t\t\t\tDesiredRate:              ptr(flagext.ByteSize(512 * 1024)),","+\t\t\t\tTimeShardingEnabled:      ptr(true),","+\t\t\t\tTimeShardingIgnoreRecent: ptr(model.Duration(10 * time.Minute)),","+\t\t\t\tLoggingEnabled:           ptr(true),","+\t\t\t},","+\t\t\texpected: shardstreams.Config{","+\t\t\t\tEnabled:                  false,","+\t\t\t\tDesiredRate:              flagext.ByteSize(512 * 1024),","+\t\t\t\tTimeShardingEnabled:      true,","+\t\t\t\tTimeShardingIgnoreRecent: 10 * time.Minute,","+\t\t\t\tLoggingEnabled:           true,","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:     \"zero-value fields replace, not inherit\",","+\t\t\toverride: &PerPolicyConfigOverride{Enabled: ptr(false), DesiredRate: ptr(flagext.ByteSize(0))},","+\t\t\texpected: withBase(func(c *shardstreams.Config) {","+\t\t\t\tc.Enabled = false","+\t\t\t\tc.DesiredRate = 0","+\t\t\t}),","+\t\t},","+\t} {","+\t\tt.Run(tc.name, func(t *testing.T) {","+\t\t\trequire.Equal(t, tc.expected, tc.override.ApplyTo(base))","+\t\t})","+\t}","+}"],"additions":78,"deletions":0,"truncated":false},{"path":"pkg/validation/limits.go","lines":["@@ -663,14 +663,8 @@ func (l *Limits) Validate() error {"," \t}"," "," \tfor policy, pl := range l.PolicyOverrideLimits {","-\t\tif pl.IngestionRateMB < 0 || pl.IngestionBurstSizeMB < 0 {","-\t\t\treturn fmt.Errorf(\"policy_override_limits[%q]: ingestion_rate_mb and ingestion_burst_size_mb must be >= 0\", policy)","-\t\t}","-\t\tif pl.PerStreamRateLimit.Val() < 0 || pl.PerStreamRateLimitBurst.Val() < 0 {","-\t\t\treturn fmt.Errorf(\"policy_override_limits[%q]: per_stream_rate_limit and per_stream_rate_limit_burst must be >= 0\", policy)","-\t\t}","-\t\tif pl.ShardStreams != nil && pl.ShardStreams.DesiredRate != nil && pl.ShardStreams.DesiredRate.Val() < 0 {","-\t\t\treturn fmt.Errorf(\"policy_override_limits[%q]: shard_streams.desired_ra