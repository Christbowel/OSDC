","+\torigDefault := settings.Rke2ProvisioningPrimeDefault.Get()","+\tdefer func() { _ = settings.Rke2ProvisioningPrimeDefault.Set(origDefault) }()","+","+\tt.Run(\"k3s runtime is skipped\", func(t *testing.T) {","+\t\t_ = settings.Rke2ProvisioningPrimeDefault.Set(\"true\")","+\t\tcp := newTestControlPlane(\"v1.35.0+k3s1\", nil)","+\t\tconfig := map[string]interface{}{}","+\t\taddRKE2Prime(config, cp, newServerEntry())","+\t\tassert.NotContains(t, config, \"prime\")","+\t})","+","+\tt.Run(\"worker node is skipped\", func(t *testing.T) {","+\t\t_ = settings.Rke2ProvisioningPrimeDefault.Set(\"true\")","+\t\tcp := newTestControlPlane(\"v1.35.0+rke2r1\", nil)","+\t\tconfig := map[string]interface{}{}","+\t\taddRKE2Prime(config, cp, newWorkerEntry())","+\t\tassert.NotContains(t, config, \"prime\")","+\t})","+","+\tt.Run(\"existing prime key is not overridden\", func(t *testing.T) {","+\t\t_ = settings.Rke2ProvisioningPrimeDefault.Set(\"true\")","+\t\tcp := newTestControlPlane(\"v1.35.0+rke2r1\", nil)","+\t\tconfig := map[string]interface{}{\"prime\": false}","+\t\taddRKE2Prime(config, cp, newServerEntry())","+\t\tassert.Equal(t, false, config[\"prime\"])","+\t})","+","+\tt.Run(\"setting false means prime not enabled\", func(t *testing.T) {","+\t\t_ = settings.Rke2ProvisioningPrimeDefault.Set(\"false\")","+\t\tcp := newTestControlPlane(\"v1.35.0+rke2r1\", nil)","+\t\tconfig := map[string]interface{}{}","+\t\taddRKE2Prime(config, cp, newServerEntry())","+\t\tassert.NotContains(t, config, \"prime\")","+\t})","+","+\tt.Run(\"annotation false overrides true setting\", func(t *testing.T) {","+\t\t_ = settings.Rke2ProvisioningPrimeDefault.Set(\"true\")","+\t\tcp := newTestControlPlane(\"v1.35.0+rke2r1\", map[string]string{","+\t\t\tcapr.RKE2PrimeEnabledAnnotation: \"false\",","+\t\t})","+\t\tconfig := map[string]interface{}{}","+\t\taddRKE2Prime(config, cp, newServerEntry())","+\t\tassert.NotContains(t, config, \"prime\")","+\t})","+","+\tt.Run(\"annotation true overrides false setting but KDM not available\", func(t *testing.T) {","+\t\t_ = settings.Rke2ProvisioningPrimeDefault.Set(\"false\")","+\t\tcp := newTestControlPlane(\"v1.35.0+rke2r1\", map[string]string{","+\t\t\tcapr.RKE2PrimeEnabledAnnotation: \"true\",","+\t\t})","+\t\tconfig := map[string]interface{}{}","+\t\taddRKE2Prime(config, cp, newServerEntry())","+\t\t// Without KDM release data, prime won't be added (safety check)","+\t\tassert.NotContains(t, config, \"prime\")","+\t})","+","+\tt.Run(\"setting true but KDM not available\", func(t *testing.T) {","+\t\t_ = settings.Rke2ProvisioningPrimeDefault.Set(\"true\")","+\t\tcp := newTestControlPlane(\"v1.35.0+rke2r1\", nil)","+\t\tconfig := map[string]interface{}{}","+\t\taddRKE2Prime(config, cp, newServerEntry())","+\t\t// Without KDM release data, prime won't be added (safety check)","+\t\tassert.NotContains(t, config, \"prime\")","+\t})","+","+\tt.Run(\"empty annotation falls through to global setting\", func(t *testing.T) {","+\t\t_ = settings.Rke2ProvisioningPrimeDefault.Set(\"false\")","+\t\t// An empty annotation value (e.g. propagated from a cluster without the annotation)","+\t\t// should be treated as absent, falling through to the global setting.","+\t\tcp := newTestControlPlane(\"v1.35.0+rke2r1\", map[string]string{","+\t\t\tcapr.RKE2PrimeEnabledAnnotation: \"\",","+\t\t})","+\t\tconfig := map[string]interface{}{}","+\t\taddRKE2Prime(config, cp, newServerEntry())","+\t\tassert.NotContains(t, config, \"prime\")","+\t})","+}"],"additions":146,"deletions":0,"truncated":false},{"path":"pkg/controllers/provisioningv2/provisioningcluster/template.go","lines":["@@ -644,7 +644,8 @@ func rkeControlPlane(cluster *provv1.Cluster) (*rkev1.RKEControlPlane, error) {"," \t\t\t\tcapr.InitNodeMachineIDLabel: cluster.Labels[capr.InitNodeMachineIDLabel],"," \t\t\t},"," \t\t\tAnnotations: map[string]string{","-\t\t\t\tcapr.ClusterSpecAnnotation: b64GZCluster,","+\t\t\t\tcapr.ClusterSpecAnnotation:      b64GZCluster,","+\t\t\t\tcapr.RKE2