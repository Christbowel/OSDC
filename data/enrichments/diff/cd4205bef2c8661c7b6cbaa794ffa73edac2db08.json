+\t\t}","+\t}","+","+\tcm.Data[rke2PrimeAnnotationMigratedKey] = \"true\"","+\treturn createOrUpdateConfigMap(w.Core.ConfigMap(), cm)","+}"],"additions":67,"deletions":0,"truncated":false},{"path":"pkg/settings/setting.go","lines":["@@ -169,6 +169,13 @@ var ("," \tRke2DefaultVersion = NewSetting(\"rke2-default-version\", \"\")"," \tK3sDefaultVersion  = NewSetting(\"k3s-default-version\", \"\")"," ","+\t// Rke2ProvisioningPrimeDefault controls whether newly provisioned RKE2 clusters automatically get","+\t// the --prime server argument. When \"true\", all new RKE2 clusters will have prime=true added to","+\t// server args (unless overridden by the per-cluster provisioning.cattle.io/rke2-prime-enabled annotation).","+\t// Defaults to empty (treated as \"false\") in standard builds; Prime builds set","+\t// CATTLE_BASE_RKE2_PROVISIONING_PRIME_DEFAULT=true to override.","+\tRke2ProvisioningPrimeDefault = NewSetting(\"rke2-provisioning-prime-default\", os.Getenv(\"CATTLE_BASE_RKE2_PROVISIONING_PRIME_DEFAULT\"))","+"," \t// AuthTokenMaxTTLMinutes is the max allowable time to live for tokens. Excluding those created for UI sessions which is controlled by AuthUserSessionTTLMinutes."," \tAuthTokenMaxTTLMinutes = NewSetting(\"auth-token-max-ttl-minutes\", \"129600\") // 90 days"," ",""],"additions":7,"deletions":0,"truncated":false}],"additions":281,"deletions":1,"truncated":false,"file_count":7},"error":null,"fetched_at":"2026-06-09T10:50:49.234524+00:00"}