ring(ptr, std::min(length, (size_t)5000)) +","-                \", length: \" + std::to_string(length) +","-                // Using std::min with hex dump length, too, to ensure we do not throw in hexdump()","-                // because of exceeded length and miss out on the core dump of the fassert below.","-                \", hex dump: \" + hexdump(ptr, std::min(length, kHexDumpMaxSize - 1));","-            Status builtStatus(ErrorCodes::InvalidBSON, redact(msg));","-            fassertFailedWithStatus(50761, builtStatus);","-        }","-        return status;","+    explicit operator const BSONObj&() const& {","+        return _val;","     }"," ","-    static Status validateStore(const BSONObj& toStore) {","-        return Status::OK();","+    explicit operator BSONObj() && {","+        return std::move(_val);","     }","+","+private:","+    BSONObj _val;","+};","+}  // namespace rpc","+","+template <>","+struct DataType::Handler<rpc::ValidatedBSONObj> {","+    static Status load(rpc::ValidatedBSONObj* vt,","+                       const char* ptr,","+                       size_t length,","+                       size_t* advanced,","+                       std::ptrdiff_t debugOffset);","+","+    static Status store(const rpc::ValidatedBSONObj& vt,","+                        char* ptr,","+                        size_t length,","+                        size_t* advanced,","+                        std::ptrdiff_t debugOffset);","+","+    static rpc::ValidatedBSONObj defaultConstruct();"," };"," }  // namespace mongo"],"additions":60,"deletions":35,"truncated":false},{"path":"src/mongo/rpc/object_check_test.cpp","lines":["@@ -27,9 +27,11 @@","  *    it in the license file.","  */"," ","-#include \"mongo/rpc/object_check.h\"  // IWYU pragma: keep","+#include \"mongo/rpc/object_check.h\""," "," #include \"mongo/base/data_range_cursor.h\"","+#include \"mongo/base/error_codes.h\"","+#include \"mongo/base/status.h\""," #include \"mongo/bson/bsonmisc.h\""," #include \