WithShape(level.Info(logger), req.Context(),","+\t\trecordResult(level.Info(logger), req.Context(),"," \t\t\t\"msg\", \"trace id response\","," \t\t\t\"tenant\", tenant,"," \t\t\t\"traceID\", traceID,"],"additions":2,"deletions":2,"truncated":false},{"path":"modules/frontend/traceid_sharder.go","lines":["@@ -68,7 +68,6 @@ func (s asyncTraceSharder) RoundTrip(pipelineRequest pipeline.Request) (pipeline"," \tctx, span := tracer.Start(pipelineRequest.Context(), \"frontend.ShardQuery\")"," \tdefer span.End()"," \tpipelineRequest.SetContext(ctx)","-\tsetQueryShapeSpanAttrs(span, pipelineRequest.QueryShape())"," "," \t_, _, _, startTime, endTime, err := api.ParseTraceByIDRequest(pipelineRequest.HTTPRequest())"," \tif err != nil {"],"additions":0,"deletions":1,"truncated":false},{"path":"modules/frontend/util.go","lines":["@@ -2,6 +2,7 @@ package frontend"," "," import ("," \t\"context\"","+\t\"fmt\""," \t\"io\""," \t\"net/http\""," \t\"strings\"","@@ -32,20 +33,86 @@ func extractTenant(req *http.Request, logger log.Logger) (string, *http.Response"," func acceptAllBlocks(_ *backend.BlockMeta) bool { return true }"," "," // setQueryShapeSpanAttrs stamps the query-shape attributes on the given span.","-// Called from each sharder after starting its span."," func setQueryShapeSpanAttrs(span trace.Span, qs pipeline.QueryShape) {"," \tspan.SetAttributes(","-\t\tattribute.String(\"queryType\", qs.Type),","-\t\tattribute.Int(\"queryWeight\", qs.Weight),","-\t\tattribute.Int(\"querySubQueries\", qs.SubQueries),","-\t\tattribute.Int(\"queryConditions\", qs.Conditions),","-\t\tattribute.Int(\"queryRegexConditions\", qs.RegexConditions),","-\t\tattribute.Bool(\"queryHasOr\", qs.HasOr),","-\t\tattribute.Bool(\"queryNeedsFullTrace\", qs.NeedsFullTrace),","-\t\tattribute.Bool(\"querySelectAll\", qs.SelectAll),","+\t\tattribute.String(\"query_type\", qs.Type),","+\t\tattribute.Int(\"query_weight\", qs.Weight),","+\t\tattribute.Int(\"query_sub_queries\", qs.SubQueries),","+\t\tattribute.Int(\"query_conditions\", qs.Conditions),","+\t\tattribute.Int(\"query_regex_conditions\", qs.RegexConditions),","+\t\tattribute.Bool(\"query_has_or\", qs.HasOr),","+\t\tattribute.Bool(\"query_needs_full_trace\", qs.NeedsFullTrace),","+\t\tattribute.Bool(\"query_select_all\", qs.SelectAll),"," \t)"," }"," ","+// recordResult logs the response fields and mirrors them as span attributes.","+//","+//nolint:revive // logger first to match logWithShape's calling convention: recordResult(level.Info(logger), ctx, ...)","+func recordResult(logger log.Logger, ctx context.Context, fields ...any) {","+\tlogWithShape(logger, ctx, fields...)","+\tsetSpanAttrsWithShape(ctx, fields...)","+}","+","+// setSpanAttrsWithShape mirrors response log fields plus query-shape fields as","+// attributes on the span in ctx, if one is recording.","+func setSpanAttrsWithShape(ctx context.Context, fields ...any) {","+\tspan := trace.SpanFromContext(ctx)","+\tif !span.IsRecording() {","+\t\treturn","+\t}","+","+\tattrs := make([]attribute.KeyValue, 0, len(fields)/2)","+\tfor i := 0; i+1 < len(fields); i += 2 {","+\t\tkey, ok := fields[i].(string)","+\t\t// skip log field keys that are redundant on a span: the span has its own","+\t\t// name, trace ID and duration, and the server middleware records the","+\t\t// tenant, status code and path.","+\t\tif !ok || key == \"msg\" || key == \"traceID\" || key == \"tenant\" ||","+\t\t\tkey == \"duration_seconds\" || key == \"status_code\" || key == \"path\" {","+\t\t\tcontinue","+\t\t}","+\t\tif attr, ok := spanAttr(key, fields[i+1]); ok {","+\t\t\tattrs = append(attrs, attr)","+\t\t}","+\t}","+\tspan.SetAttributes(attrs...)","+","+\tif qs, ok := pipeline.QueryShapeFromContext(ctx); ok {","+\t\tsetQueryShapeSpanAttrs(span, qs)","+\t}","+}","+","+// spanAttr converts one log field value to a span attribute. ok=false for nil values.","+func spanAttr(key string, val any) (attribute.KeyValue, bool) {","+\tswitch v := val.(type) {","+\tcase nil:","+\t\treturn attribute.KeyValue{}, false","+\tcase string:","+\t\treturn attribute.String(key, v), true","+\tcase bool:","+\t\treturn attribute.Bool(key, v), true","+\tcase int:","+\t\treturn attribute.Int(key, v), true","+\tcase int64:","+\t\treturn attribute.Int64(key, v), true","+\tcase uint32:","+\t\treturn attribute.Int64(key, int64(v)), true","+\tcase uint64:","+\t\t// OTel attributes don't support uint64; cast to int64 when safe, otherwise fall back to string.","+\t\tif v > ^uint64(0)>>1 {","+\t\t\treturn attribute.String(key, fmt.Sprint(v)), true","+\t\t}","+\t\treturn attribute.Int64(key, int64(v)), true //nolint:gosec // G115","+\tcase float64:","+\t\treturn attribute.Float64(key, v), true","+\tcase error:","+\t\treturn attribute.String(key, v.Error()), true","+\tdefault:","+\t\treturn attribute.String(key, fmt.Sprint(v)), true","+\t}","+}","+"," // logWithShape emits a per-query response log line with query-shape fields"," // appended when a shape is stamped on the context. The caller picks the level"," // by wrapping the logger, e.g. logWithShape(level.Info(logger), ctx, ...)."],"additions":76,"deletions":9,"truncated":false},{"path":"modules/frontend/util_test.go","lines":["@@ -1,14 +1,22 @@"," package frontend"," "," import (","+\t\"context\"","+\t\"errors\""," \t\"io\""," \t\"net/http\"","+\t\"net/url\""," \t\"testing\"","+\t\"time\""," "," \t\"github.com/go-kit/log\""," \t\"github.com/grafana/dskit/user\"","+\t\"github.com/grafana/tempo/modules/frontend/pipeline\""," \t\"github.com/stretchr/testify/assert\""," \t\"github.com/stretchr/testify/require\"","+\t\"go.opentelemetry.io/otel/attribute\"","+\tsdktrace \"go.opentelemetry.io/otel/sdk/trace\"","+\t\"go.opentelemetry.io/otel/sdk/trace/tracetest\""," )"," "," func TestExtractTenant(t *testing.T) {","@@ -73,3 +81,115 @@ func TestExtractTenant(t *testing.T) {"," \t\tassert.Contains(t, bodyStr, \"no org id\")"," \t})"," }","+","+func TestSpanAttr(t *testing.T) {","+\ttests := []struct {","+\t\tname string","+\t\tval  any","+\t\twant attribute.KeyValue","+\t\tok   bool","+\t}{","+\t\t{\"nil\", nil, attribute.KeyValue{}, false},","+\t\t{\"string\", \"foo\", attribute.String(\"k\", \"foo\"), true},","+\t\t{\"bool\", true, attribute.Bool(\"k\", true), true},","+\t\t{\"int\", 42, attribute.Int(\"k\", 42), true},","+\t\t{\"int64\", int64(-7), attribute.Int64(\"k\", -7), true},","+\t\t{\"uint32\", uint32(3600), attribute.Int64(\"k\", 3600), true},","+\t\t{\"uint64\", uint64(123456), attribute.Int64(\"k\", 123456), true},","+\t\t{\"uint64_overflow\", ^uint64(0), attribute.String(\"k\", \"18446744073709551615\"), true},","+\t\t{\"float64\", 1.5, attribute.Float64(\"k\", 1.5), true},","+\t\t{\"error\", errors.New(\"boom\"), attribute.String(\"k\", \"boom\"), true},","+\t\t{\"fallback\", time.Second, attribute.String(\"k\", \"1s\"), true},","+\t}","+\tfor _, tt := range tests {","+\t\tt.Run(tt.name, func(t *testing.T) {","+\t\t\tgot, ok := spanAttr(\"k\", tt.val)","+\t\t\trequire.Equal(t, tt.ok, ok)","+\t\t\tif ok {","+\t\t\t\tassert.Equal(t, tt.want, got)","+\t\t\t}","+\t\t})","+\t}","+}","+","+func TestSetSpanAttrsWithShape(t *testing.T) {","+\tattrsOf := func(rec *tracetest.SpanRecorder) map[attribute.Key]attribute.Value {","+\t\tended := rec.Ended()","+\t\trequire.Len(t, ended, 1)","+\t\tout := map[attribute.Key]attribute.Value{}","+\t\tfor _, kv := range ended[0].Attributes() {","+\t\t\tout[kv.Key] = kv.Value","+\t\t}","+\t\treturn out","+\t}","+","+\tt.Run(\"mirrors fields, skips nil values and redundant keys\", func(t *testing.T) {","+\t\trec := tracetest.NewSpanRecorder()","+\t\ttp := sdktrace.NewTracerProvider(sdktrace.WithSpanProcessor(rec))","+\t\tctx, span := tp.Tracer(\"test\").Start(context.Background(), \"test\")","+","+\t\tsetSpanAttrsWithShape(ctx,","+\t\t\t\"msg\", \"search response\",","+\t\t\t\"traceID\", \"abcd\",","+\t\t\t\"tenant\", \"test-tenant\",","+\t\t\t\"duration_seconds\", 1.5,","+\t\t\t\"status_code\", 200,","+\t\t\t\"path\", \"/api/search\",","+\t\t\t\"query\", \"{}\",","+\t\t\t\"inspected_bytes\", uint64(1024),","+\t\t\t\"error\", nil,","+\t\t)","+\t\tspan.End()","+","+\t\tattrs := attrsOf(rec)","+\t\tassert.NotContains(t, attrs, attribute.Key(\"msg\"))","+\t\tassert.NotContains(t, attrs, attribute.Key(\"traceID\"))","+\t\tassert.NotContains(t, attrs, attribute.Key(\"tenant\"))","+\t\tassert.NotContains(t, attrs, attribute.Key(\"duration_seconds\"))","+\t\tassert.NotContains(t, attrs, attribute.Key(\"status_code\"))","+\t\tassert.NotContains(t, attrs, attribute.Key(\"path\"))","+\t\tassert.NotContains(t, attrs, attribute.Key(\"error\"))","+\t\tassert.Equal(t, \"{}\", attrs[\"query\"].AsString())","+\t\tassert.Equal(t, int64(1024), attrs[\"inspected_bytes\"].AsInt64())","+\t\t// no shape stamped on ctx -> no shape attrs","+\t\tassert.NotContains(t, attrs, attribute.Key(\"query_type\"))","+\t})","+","+\tt.Run(\"appends query-shape attrs when stamped on ctx\", func(t *testing.T) {","+\t\trec := tracetest.NewSpanRecorder()","+\t\ttp := sdktrace.NewTracerProvider(sdktrace.WithSpanProcessor(rec))","+\t\tctx, span := tp.Tracer(\"test\").Start(context.Background(), \"test\")","+\t\tctx = pipeline.WithQueryShapeCell(ctx)","+","+\t\t// stamp the shape the same way production does: via the weight middleware","+\t\thttpReq, err := http.NewRequest(http.MethodGet, \"http://example.com/api/search?q=\"+url.QueryEscape(\"{ span.foo = `bar` }\"), nil)","+\t\trequire.NoError(t, err)","+\t\thttpReq = httpReq.WithContext(ctx)","+\t\trt := pipeline.NewWeightRequestWare(pipeline.TraceQLSearch, pipeline.WeightsConfig{","+\t\t\tRequestWithWeights:   true,","+\t\t\tMaxTraceQLConditions: 4,","+\t\t\tMaxRegexConditions:   1,","+\t\t}).Wrap(pipeline.GetRoundTripperFunc())","+\t\t_, err = rt.RoundTrip(pipeline.NewHTTPRequest(httpReq))","+\t\trequire.NoError(t, err)","+","+\t\tsetSpanAttrsWithShape(ctx, \"query\", \"{ span.foo = `bar` }\")","+\t\tspan.End()","+","+\t\tattrs := attrsOf(rec)","+\t\tassert.Equal(t, \"{ span.foo = `bar` }\", attrs[\"query\"].AsString())","+\t\tassert.Equal(t, pipeline.QueryTypeSearch, attrs[\"query_type\"].AsString())","+\t\tassert.GreaterOrEqual(t, attrs[\"query_weight\"].AsInt64(), int64(1))","+\t\tassert.Equal(t, int64(1), attrs[\"query_sub_queries\"].AsInt64())","+\t\tassert.Equal(t, int64(1), attrs[\"query_conditions\"].AsInt64())","+\t\tassert.Equal(t, int64(0), attrs[\"query_regex_conditions\"].AsInt64())","+\t\tassert.False(t, attrs[\"query_has_or\"].AsBool())","+\t\tassert.False(t, attrs[\"query_needs_full_trace\"].AsBool())","+\t\tassert.False(t, attrs[\"query_select_all\"].AsBool())","+\t})","+","+\tt.Run(\"no-op without a recording span\", func(_ *testing.T) {","+\t\t// must not panic with a noop span from a bare context","+\t\tsetSpanAttrsWithShape(context.Background(), \"query\", \"{}\")","+\t})","+}",""],"additions":120,"deletions":0,"truncated":false}],"additions":230,"deletions":26,"truncated":false,"file_count":12},"error":null,"fetched_at":"2026-07-18T09:24:36.667878+00:00"}