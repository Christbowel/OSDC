ector &typed_value, idx_t offset,","-\t                                                idx_t length, idx_t total_size);","-\tstatic vector<VariantValue> ConvertShreddedArray(Vector &metadata, Vector &value, Vector &typed_value, idx_t offset,","-\t                                                 idx_t length, idx_t total_size);","-\tstatic vector<VariantValue> ConvertShreddedObject(Vector &metadata, Vector &value, Vector &typed_value,","-\t                                                  idx_t offset, idx_t length, idx_t total_size);","-\t//! Inverse of GetTransformFunction: decode a binary Variant value (metadata followed by value) into a VARIANT.","-\tstatic ScalarFunction GetBytesToVariantFunction();","-};","-","-} // namespace duckdb"],"additions":0,"deletions":27,"truncated":false},{"path":"extension/parquet/parquet_extension.cpp","lines":["@@ -80,7 +80,7 @@"," #include \"duckdb/storage/storage_info.hpp\""," #include \"parquet_field_id.hpp\""," #include \"parquet_types.h\"","-#include \"reader/variant/variant_shredded_conversion.hpp\"","+#include \"reader/variant/parquet_variant_iterator.hpp\""," "," namespace duckdb {"," class ClientContext;","@@ -973,7 +973,7 @@ static void LoadInternal(ExtensionLoader &loader) {"," \tloader.RegisterFunction(VariantColumnWriter::GetTransformFunction());"," "," \t// bytes_to_variant","-\tloader.RegisterFunction(VariantShreddedConversion::GetBytesToVariantFunction());","+\tloader.RegisterFunction(ParquetVariantConversion::GetBytesToVariantFunction());"," "," \tCopyFunction function(\"parquet\");"," \tfunction.copy_to_select = ParquetWriteSelect;"],"additions":2,"deletions":2,"truncated":false},{"path":"extension/parquet/reader/variant/CMakeLists.txt","lines":["@@ -1,5 +1,5 @@"," add_library_unity(duckdb_parquet_reader_variant OBJECT","-                  variant_binary_decoder.cpp variant_shredded_conversion.cpp)","+                  variant_binary_decoder.cpp parquet_variant_iterator.cpp)"," "," set(PARQUET_EXTENSION_FILES","     ${PARQUET_EXTENSION_FILES} $<TARGET_OBJECTS:duckdb_parquet_reader_variant>"],"additions":1,"deletions":1,"truncated":false},{"path":"extension/parquet/reader/variant/parquet_variant_iterator.cpp","lines":["@@ -0,0 +1,736 @@","+#include \"reader/variant/parquet_variant_iterator.hpp\"","+","+#include \"duckdb/common/types/variant/variant_builder.hpp\"","+#include \"duckdb/common/vector/struct_vector.hpp\"","+#include \"duckdb/common/vector/list_vector.hpp\"","+#include \"duckdb/common/types/decimal.hpp\"","+#include \"duckdb/common/types/hugeint.hpp\"","+#include \"duckdb/common/hugeint.hpp\"","+#include \"duckdb/common/helper.hpp\"","+#include \"duckdb/common/exception.hpp\"","+#include \"duckdb/common/numeric_utils.hpp\"","+#include \"reader/uuid_column_reader.hpp\"","+#include \"utf8proc_wrapper.hpp\"","+","+#include <algorithm>","+#include <cmath>","+#include <set>","+#include <type_traits>","+","+namespace duckdb {","+","+namespace {","+","+//! Throw if reading 'size' bytes starting at 'ptr' would read past the end of the value buffer","+void CheckBinaryRead(const_data_ptr_t ptr, idx_t size, const_data_ptr_t end) {","+\tif (ptr + size > end) {","+\t\tthrow IOException(\"Data corruption detected, read of length_in_bytes (%d) would exceed buffer capacity\", size);","+\t}","+}","+","+//! Read a little-endian unsigned integer of 'size' bytes (without advancing), bounds-checked against 'end'","+idx_t ReadVarLE(idx_t size, const_data_ptr_t ptr, const_data_ptr_t end) {","+\tD_ASSERT(size <= sizeof(idx_t));","+\tCheckBinaryRead(ptr, size, end);","+\tidx_t result = 0;","+\tmemcpy(&result, ptr, size);","+\treturn result;","+}","+","+//! Read a fixed-width little-endian value, bounds-checked against 'end'","+template <class T>","+T LoadChecked(const_data_ptr_t ptr, const_data_ptr_t end) {","+\tCheckBinaryRead(ptr, sizeof(T), end);","+\treturn Load<T>(ptr);","+}","+","+//! Lazy reader over a Spark variant-encoded OBJECT (the value starts at its header byte). All structural","+//! reads are bounds-checked against 'end' (one past the end of the 'value' blob).","+struct BinaryObjectReader {","+\tBinaryObjectReader(const VariantMetadata &metadata, const_data_ptr_t value_start, const_data_ptr_t end)","+\t    : metadata(metadata), end(end) {","+\t\tauto value_metadata = VariantValueMetadata::FromHeaderByte(value_start[0]);","+\t\tD_ASSERT(value_metadata.basic_type == VariantBasicType::OBJECT);","+\t\tfield_id_size = value_metadata.field_id_size;","+\t\tfield_offset_size = value_metadata.field_offset_size;","+\t\tauto data = value_start + 1;","+\t\tif (value_metadata.is_large) {","+\t\t\tcount = LoadChecked<uint32_t>(data, end);","+\t\t\tdata += sizeof(uint32_t);","+\t\t} else {","+\t\t\tcount = LoadChecked<uint8_t>(data, end);","+\t\t\tdata += sizeof(uint8_t);","+\t\t}","+\t\tfield_ids = data;","+\t\tfield_offsets = data + (count * field_id_size);","+\t\tvalues = field_offsets + (NumericCast<idx_t>(count + 1) * field_offset_size);","+\t}","+","+\tstring_t Key(idx_t i) const {","+\t\tauto field_id = ReadVarLE(field_id_size, field_ids + (i * field_id_size), end);","+\t\tif (field_id >= metadata.strings.size()) {","+\t\t\tthrow IOException(\"Corrupted VARIANT 'value' buffer\");","+\t\t}","+\t\tauto &key = metadata.strings[field_id];","+\t\treturn string_t(key.c_str(), NumericCast<uint32_t>(key.size()));","+\t}","+\tconst_data_ptr_t Child(idx_t i) const {","+\t\tauto offset = ReadVarLE(field_offset_size, field_offsets + (i * field_offset_size), end);","+\t\tauto child = values + offset;","+\t\t//! The child's header byte must be readable","+\t\tCheckBinaryRead(child, 1, end);","+\t\treturn child;","+\t}","+","+\tconst VariantMetadata &metadata;","+\tconst_data_ptr_t end;","+\tconst_data_ptr_t field_ids;","+\tconst_data_ptr_t field_offsets;","+\tconst_data_ptr_t values;","+\tuint32_t field_id_size;","+\tuint32_t field_offset_size;","+\tidx_t count;","+};","+","+//! Lazy reader over a Spark variant-encoded ARRAY (the value starts at its header byte). All structural","+//! reads are bounds-checked against 'end' (one past the end of the 'value' blob).","+struct BinaryArrayReader {","+\tBinaryArrayReader(const_data_ptr_t value_start, const_data_ptr_t end) : end(end) {","+\t\tauto value_metadata = VariantValueMetadata::FromHeaderByte(value_start[0]);","+\t\tD_ASSERT(value_metadata.basic_type == VariantBasicType::ARRAY);","+\t\tfield_offset_size = value_metadata.field_offset_size;","+\t\tauto data = value_start + 1;","+\t\tif (value_metadata.is_large) {","+\t\t\tcount = LoadChecked<uint32_t>(data, end);","+\t\t\tdata += sizeof(uint32_t);","+\t\t} else {","+\t\t\tcount = LoadChecked<uint8_t>(data, end);","+\t\t\tdata += sizeof(uint8_t);","+\t\t}","+\t\tfield_offsets = data;","+\t\tvalues = field_offsets + (NumericCast<idx_t>(count + 1) * field_offset_size);","+\t}","+","+\tconst_data_ptr_t end;","+\tconst_data_ptr_t field_offsets;","+\tconst_data_ptr_t values;","+\tuint32_t field_offset_size;","+\tidx_t count;","+};","+","+//! The VariantLogicalType of a (valid) shredded leaf at logical position 'index'. Mirrors the writer's","+//! type mapping; note BINARY is kept as a BLOB so the type is preserved (the base64 conversion happens","+//! only when serializing the VARIANT to JSON).","+VariantLogicalType ShreddedLeafTypeId(const ShreddedGroupView &view, idx_t index) {","+\tswitch (view.typed_type.id()) {","+\tcase LogicalTypeId::BOOLEAN: {","+\t\tauto leaf_index = view.leaf_format.sel->get_index(index);","+\t\treturn UnifiedVectorFormat::GetData<bool>(view.leaf_format)[leaf_index] ? VariantLogicalType::BOOL_TRUE","+\t\t                                                                        : VariantLogicalType::BOOL_FALSE;","+\t}","+\tcase LogicalTypeId::TINYINT:","+\t\treturn VariantLogicalType::INT8;","+\tcase LogicalTypeId::SMALLINT:","+\t\treturn VariantLogicalType::INT16;","+\tcase LogicalTypeId::INTEGER:","+\t\treturn VariantLogicalType::INT32;","+\tcase LogicalTypeId::BIGINT:","+\t\treturn VariantLogicalType::INT64;","+\tcase LogicalTypeId::FLOAT:","+\t\treturn VariantLogicalType::FLOAT;","+\tcase LogicalTypeId::DOUBLE:","+\t\treturn VariantLogicalType::DOUBLE;","+\tcase LogicalTypeId::DECIMAL:","+\t\treturn VariantLogicalType::DECIMAL;","+\tcase LogicalTypeId::DATE:","+\t\treturn VariantLogicalType::DATE;","+\tcase LogicalTypeId::TIME:","+\t\treturn VariantLogicalType::TIME_MICROS;","+\tcase LogicalTypeId::TIMESTAMP_TZ:","+\t\treturn VariantLogicalType::TIMESTAMP_MICROS_TZ;","+\tcase LogicalTypeId::TIMESTAMP_TZ_NS:","+\t\treturn VariantLogicalType::TIMESTAMP_NANOS_TZ;","+\tcase LogicalTypeId::TIMESTAMP:","+\t\treturn VariantLogicalType::TIMESTAMP_MICROS;","+\tcase LogicalTypeId::TIMESTAMP_NS:","+\t\treturn VariantLogicalType::TIMESTAMP_NANOS;","+\tcase LogicalTypeId::BLOB:","+\t\treturn VariantLogicalType::BLOB;","+\tcase LogicalTypeId::VARCHAR:","+\t\treturn VariantLogicalType::VARCHAR;","+\tcase LogicalTypeId::UUID:","+\t\treturn VariantLogicalType::UUID;","+\tdefault:","+\t\tthrow NotImplementedException(\"Variant shredding on type: '%s' is not implemented\", view.typed_type.ToString());","+\t}","+}","+","+//! The VariantLogicalType of a Spark variant-encoded value (the value starts at its header byte)","+VariantLogicalType BinaryTypeId(const_data_ptr_t data) {","+\tauto value_metadata = VariantValueMetadata::FromHeaderByte(data[0]);","+\tswitch (value_metadata.basic_type) {","+\tcase VariantBasicType::SHORT_STRING:","+\t\treturn VariantLogicalType::VARCHAR;","+\tcase VariantBasicType::OBJECT:","+\t\treturn VariantLogicalType::OBJECT;","+\tcase VariantBasicType::ARRAY:","+\t\treturn VariantLogicalType::ARRAY;","+\tcase VariantBasicType::PRIMITIVE:","+\t\tbreak;","+\tdefault:","+\t\tthrow InternalException(\"Unexpected VariantBasicType\");","+\t}","+\tswitch (value_metadata.primitive_type) {","+\tcase VariantPrimitiveType::NULL_TYPE:","+\t\treturn VariantLogicalType::VARIANT_NULL;","+\tcase VariantPrimitiveType::BOOLEAN_TRUE:","+\t\treturn VariantLogicalType::BOOL_