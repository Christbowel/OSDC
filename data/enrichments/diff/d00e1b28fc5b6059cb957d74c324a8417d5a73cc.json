{"id":"d00e1b28fc5b6059cb957d74c324a8417d5a73cc","axis":"silent","repo":"owncloud/core","sha":"d00e1b28fc5b6059cb957d74c324a8417d5a73cc","parsed":{"files":[{"path":"changelog/unreleased/41623","lines":["@@ -0,0 +1,14 @@","+Bugfix: Decrypt versions and trashbin so encryption can be disabled","+","+\"occ encryption:decrypt-all\" only walked the regular \"files\" folder, leaving the","+\"encrypted\" flag set on entries in \"files_versions\" and \"files_trashbin\". Because","+\"occ encryption:disable\" refuses while any file cache row is still flagged as","+encrypted, administrators were left unable to disable encryption even though","+decrypt-all reported success.","+","+decrypt-all now also descends into \"files_versions\" and \"files_trashbin\", and the","+disable command now lists the paths that are still flagged as encrypted together","+with a hint on how to clean them up, instead of printing a generic message.","+","+https://github.com/owncloud/core/issues/41623","+https://github.com/owncloud/core/pull/41624"],"additions":14,"deletions":0,"truncated":false},{"path":"core/Command/Encryption/Disable.php","lines":["@@ -28,6 +28,13 @@"," use Symfony\\Component\\Console\\Output\\OutputInterface;"," "," class Disable extends Command {","+\t/**","+\t * Maximum number of still-encrypted paths to print so the output fits","+\t * on screen on systems with many leftover entries. The remaining count","+\t * is reported as a summary.","+\t */","+\tprivate const MAX_REPORTED_PATHS = 20;","+"," \t/** @var IDBConnection */"," \tprotected $db;"," \t/** @var IConfig */","@@ -52,15 +59,35 @@ protected function configure() {"," "," \tprotected function execute(InputInterface $input, OutputInterface $output): int {"," \t\t$qb = $this->db->getQueryBuilder();","-\t\t$qb->select($qb->expr()->literal('1'))","+\t\t$qb->select($qb->createFunction('COUNT(*)'))"," \t\t\t->from('filecache', 'fc')","-\t\t\t->where($qb->expr()->gte('fc.encrypted', $qb->expr()->literal('1')))","-\t\t\t->setMaxResults(1);","+\t\t\t->where($qb->expr()->gte('fc.encrypted', $qb->expr()->literal('1')));"," \t\t$results = $qb->execute();","-\t\t$hasEncryptedFiles = (bool) $results->fetchOne();","+\t\t$encryptedCount = (int) $results->fetchOne();"," \t\t$results->free();","-\t\tif ($hasEncryptedFiles !== false) {","-\t\t\t$output->writeln('<info>The system still has encrypted files. Please decrypt them all before disabling encryption.</info>');","+\t\tif ($encryptedCount > 0) {","+\t\t\t$qb = $this->db->getQueryBuilder();","+\t\t\t$qb->select('fc.path')","+\t\t\t\t->from('filecache', 'fc')","+\t\t\t\t->where($qb->expr()->gte('fc.encrypted', $qb->expr()->literal('1')))","+\t\t\t\t->setMaxResults(self::MAX_REPORTED_PATHS);","+\t\t\t$results = $qb->execute();","+\t\t\t$encryptedPaths = $results->fetchFirstColumn();","+\t\t\t$results->free();","+","+\t\t\t$output->writeln('<error>The system still has encrypted files. Please decrypt them all before disabling encryption.</error>');","+\t\t\t$output->writeln('The following paths in the file cache are still flagged as encrypted:');","+\t\t\tforeach ($encryptedPaths as $path) {","+\t\t\t\t$output->writeln(\"    $path\");","+\t\t\t}","+\t\t\t$remaining = $encryptedCount - \\count($encryptedPaths);","+\t\t\tif ($remaining > 0) {","+\t\t\t\t$output->writeln(\"    ... and $remaining more still encrypted\");","+\t\t\t}","+\t\t\t$output->writeln('');","+\t\t\t$output->writeln('Run \"occ encryption:decrypt-all\" to decrypt these. Entries on shared or');","+\t\t\t$output->writeln('external storage are skipped by decrypt-all and have to be decrypted by');","+\t\t\t$output->writeln('their owner, e.g. via \"occ encryption:decrypt-all <user>\".');"," \t\t\treturn 1;"," \t\t}"," "],"additions":33,"deletions":6,"truncated":false},{"path":"lib/private/Encryption/DecryptAll.php","lines":["@@ -214,7 +214,15 @@ protected function decryptAllUsersFiles($user = '') {"," \tprotected function decryptUsersFiles($uid, ProgressBar $progress, $userCount) {"," \t\t$this->setupUserFS($uid);"," \t\t$directories = [];","-\t\t$directories[] = '/' . $uid . '/files';","+\t\t// also decrypt files stored outside of the regular \"files\" folder,","+\t\t// otherwise their filecache \"encrypted\" flag survives and blocks","+\t\t// \"occ encryption:disable\" afterwards","+\t\tforeach (['files', 'files_versions', 'files_trashbin'] as $folder) {","+\t\t\t$root = '/' . $uid . '/' . $folder;","+\t\t\tif ($this->rootView->is_dir($root)) {","+\t\t\t\t$directories[] = $root;","+\t\t\t}","+\t\t}"," "," \t\twhile ($root = \\array_pop($directories)) {"," \t\t\t$content = $this->rootView->getDirectoryContent($root);"],"additions":9,"deletions":1,"truncated":false},{"path":"tests/Core/Command/Encryption/DisableTest.php","lines":["@@ -59,12 +59,15 @@ protected function setUp(): void {"," "," \tpublic function dataDisable() {"," \t\treturn [","-\t\t\t['yes', true, '1', false, 'Encryption disabled'],","-\t\t\t['yes', true, '', false, 'Encryption disabled'],","-\t\t\t['no', false, false, false, 'Encryption is already disabled'],","-\t\t\t['yes', true, '1', true, 'Encryption disabled'],","-\t\t\t['yes', true, '', true, 'Encryption disabled'],","-\t\t\t['no', false, false, true, 'Encryption is already disabled'],","+\t\t\t// [oldStatus, isUpdating, masterKeyEnabled, encryptedCount, reportedPaths, expectedString]","+\t\t\t['yes', true, '1', 0, [], 'Encryption disabled'],","+\t\t\t['yes', true, '', 0, [], 'Encryption disabled'],","+\t\t\t['no', false, false, 0, [], 'Encryption is already disabled'],","+\t\t\t['yes', true, '1', 1, ['files_versions/foo.txt'], 'Encryption disabled'],","+\t\t\t['yes', true, '', 1, ['files_trashbin/files/bar.txt.d123'], 'Encryption disabled'],","+\t\t\t['no', false, false, 1, ['files/baz.txt'], 'Encryption is already disabled'],","+\t\t\t// more rows encrypted than are reported -> \"... and N more\" summary","+\t\t\t['no', false, false, 25, ['files/a.txt', 'files_versions/b.txt'], 'Encryption is already disabled'],"," \t\t];"," \t