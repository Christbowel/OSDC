other","+\t}","+\treturn in.Addr == other.Addr","+}","+","+// Addr deliberately does not define IsZero: netip.Addr's only invalid state","+// is its zero value, so encoding/json's reflect-based zero check for the","+// `omitzero` tag option produces the same result. See Prefix.IsZero for the","+// case where an explicit method is required.","+","+// Prefix wraps netip.Prefix, same rationale as Addr.","+//","+// +k8s:deepcopy-gen=false","+// +deepequal-gen=false","+// +kubebuilder:validation:Type=string","+// +kubebuilder:validation:Format=cidr","+type Prefix struct {","+\tnetip.Prefix","+}","+","+// PrefixFrom wraps a netip.Prefix.","+func PrefixFrom(p netip.Prefix) Prefix { return Prefix{Prefix: p} }","+","+func (in *Prefix) DeepCopyInto(out *Prefix) { *out = *in }","+","+func (in *Prefix) DeepCopy() *Prefix {","+\tif in == nil {","+\t\treturn nil","+\t}","+\tout := new(Prefix)","+\tin.DeepCopyInto(out)","+\treturn out","+}","+","+func (in *Prefix) DeepEqual(other *Prefix) bool {","+\tif in == nil || other == nil {","+\t\treturn in == other","+\t}","+\treturn in.Prefix == other.Prefix","+}","+","+// IsZero reports whether p is unset or invalid, for encoding/json's `omitzero`","+// tag option. A Prefix built from a valid Addr with an out-of-range bit count","+// (e.g. PrefixFrom(addr, -1)) is non-zero by reflect's definition but invalid","+// by IsValid(), and would otherwise be emitted as `\"\"`.","+func (p Prefix) IsZero() bool { return !p.Prefix.IsValid() }"],"additions":91,"deletions":0,"truncated":false},{"path":"pkg/ip/netip_test.go","lines":["@@ -0,0 +1,136 @@","+// SPDX-License-Identifier: Apache-2.0","+// Copyright Authors of Cilium","+","+package ip","+","+import (","+\t\"encoding/json\"","+\t\"net/netip\"","+\t\"testing\"","+","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+)","+","+func TestAddrJSONRoundTrip(t *testing.T) {","+\ttests := []struct {","+\t\tname string","+\t\tin   Addr","+\t\twant string","+\t}{",