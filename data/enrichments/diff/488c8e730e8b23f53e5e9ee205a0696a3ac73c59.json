arent().isNested()) {","-            // Handle a nested object that doesn't contain an array. Arrays are handled in #parseNonDynamicArray.","+            // Handle a nested object that doesn't contain an array. Arrays are handled in #parseArrayElements.","             context = context.createNestedContext((NestedObjectMapper) context.parent());","         }"," ","@@ -652,7 +652,7 @@ private static void parseArray(DocumentParserContext context, String lastFieldNa","             if (parsesArrayValue(mapper)) {","                 parseObjectOrField(context, mapper);","             } else {","-                parseNonDynamicArray(context, mapper, lastFieldName, lastFieldName);","+                parseArrayElements(context, mapper, lastFieldName, lastFieldName);","             }","         } else {","             parseArrayDynamic(context, lastFieldName);","@@ -717,7 +717,7 @@ private static void parseArrayDynamic(DocumentParserContext context, String curr","                 return;","             }"," ","-            parseNonDynamicArray(context, null, currentFieldName, currentFieldName);","+            parseArrayElements(context, null, currentFieldName, currentFieldName);","         } else {","             MapperBuilderContext builderContext = context.createDynamicMapperBuilderContext();","             Mapper objectMapperFromTemplate = builderFromTemplate.build(builderContext);","@@ -731,7 +731,7 @@ private static void parseArrayDynamic(DocumentParserContext context, String curr","                 parseObjectOrField(context, mapper);","                 context.path().remove();","             } else {","-                parseNonDynamicArray(context, objectMapperFromTemplate, currentFieldName, currentFieldName);","+                parseArrayElements(context, objectMapperFromTemplate, currentFieldName, currentFieldName);","             }","         }","     }","@@ -740,7 +740,7 @@ private static boolean parsesArrayValue(Mapper mapper) {","         return mapper instanceof FieldMapper && ((FieldMapper) mapper).parsesArrayValue();","     }"," ","-    private static void parseNonDynamicArray(","+    private static void parseArrayElements(","         DocumentParserContext context,","         @Nullable Mapper mapper,","         final String lastFieldName,","@@ -790,6 +790,7 @@ private static void parseNonDynamicArray(","         int valueElements = 0;","         while ((token = parser.nextToken()) != XContentParser.Token.END_ARRAY) {","             if (token == XContentParser.Token.START_OBJECT) {","+                context.incrementAndCheckObjectArrayElementLimit();","                 parseObject(context, lastFieldName);","             } else if (token == XContentParser.Token.START_ARRAY) {","                 parseArray(context, lastFieldName);"],"additions":6,"deletions":5,"truncated":false},{"path":"server/src/main/java/org/elasticsearch/index/mapper/DocumentParserContext.java","lines":["@@ -160,6 +160,22 @@ public int get() {","         }","     }"," ","+    /**","+     * Tracks the cumulative number of object elements encountered inside arrays while parsing the","+     * current document. The same mutable instance is shared across every {@link DocumentParserContext}","+     * spawned from the root context (child, nested, copy-to, switched parser, etc.) so the count","+     * reflects every nested or sibling array in the same document. This is what","+     * {@link MapperService#INDEX_MAPPING_ARRAY_OBJECTS_LIMIT_SETTING} bounds; tracking per array","+     * invocation would let a caller bypass the limit by chunking a payload across many arrays.","+     */","+    private static final class ObjectArrayElementCounter {","+        private long count = 0;","+","+        long incrementAndGet() {","+            return ++count;","+        }","+    }","+","     /**","      * Defines the scope parser is currently in.","      * This is used for synthetic source related logic during parsing.","@@ -194,6 +210,8 @@ private enum Scope {"," ","     