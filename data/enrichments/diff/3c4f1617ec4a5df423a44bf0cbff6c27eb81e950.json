ationpb.New(d.lastEvent.GetTime().Sub(d.startTime))","+\td.metadata.StartTime = timestamppb.New(d.startTime)","+\td.metadata.EndTime = timestamppb.New(d.lastEvent.GetTime())","+","+\treturn d.metadata, d.thumbnail","+}"],"additions":107,"deletions":0,"truncated":false},{"path":"lib/auth/recordingmetadata/recordingmetadatav1/desktopprocessor_test.go","lines":["@@ -0,0 +1,217 @@","+//go:build desktop_access_rdp || rust_rdp_decoder","+","+/**","+ * Teleport","+ * Copyright (C) 2026 Gravitational, Inc.","+ *","+ * This program is free software: you can redistribute it and/or modify","+ * it under the terms of the GNU Affero General Public License as published by","+ * the Free Software Foundation, either version 3 of the License, or","+ * (at your option) any later version.","+ *","+ * This program is distributed in the hope that it will be useful,","+ * but WITHOUT ANY WARRANTY; without even the implied warranty of","+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the","+ * GNU Affero General Public License for more details.","+ *","+ * You should have received a copy of the GNU Affero General Public License","+ * along with this program.  If not, see <http://www.gnu.org/licenses/>.","+ */","+","+package recordingmetadatav1","+","+import (","+\t\"bytes\"","+\t\"image/png\"","+\t\"io\"","+\t\"log/slog\"","+\t\"testing\"","+\t\"time\"","+","+\t\"github.com/stretchr/testify/require\"","+","+\tpb \"github.com/gravitational/teleport/api/gen/proto/go/teleport/recordingmetadata/v1\"","+\tapievents \"github.com/gravitational/teleport/api/types/events\"","+\t\"github.com/gravitational/teleport/lib/auth/recordingmetadata\"","+\t\"github.com/gravitational/teleport/lib/srv/desktop/rdpstate/rdpstatetest\"","+)","+","+func TestDesktopRecordingProcessor(t *testing.T) {","+\tstartTime := time.Now()","+","+\ttests := []struct {","+\t\tname              string","+\t\tevents            []apievents.AuditEvent","+\t\texpectedMetadata  func(t *testing.T, metadata *pb.SessionRecordingMetadata)","+\t\texpectedThumbnail func(t *testing.T, thumbnail *pb.SessionRecordingThumbnail)","+\t}{","+\t\t{","+\t\t\tname:   \"complete session populates metadata and produces thumbnail\",","+\t\t\tevents: generateCompleteDesktopSession(t, startTime, 64, 48, nil),","+\t\t\texpectedMetadata: func(t *testing.T, metadata *pb.SessionRecordingMetadata) {","+\t\t\t\trequire.NotNil(t, metadata)","+\t\t\t\trequire.NotNil(t, metadata.StartTime)","+\t\t\t\trequire.NotNil(t, metadata.EndTime)","+","+\t\t\t\trequire.Equal(t, \"test-cluster\", metadata.ClusterName)","+\t\t\t\trequire.Equal(t, \"test-user\", metadata.User)","+\t\t\t\trequire.Equal(t, \"test-desktop\", metadata.ResourceName)","+\t\t\t\trequire.Equal(t, pb.SessionRecordingType_SESSION_RECORDING_TYPE_WINDOWS_DESKTOP, metadata.Type)","+\t\t\t\trequire.Equal(t, 10*time.Second, metadata.Duration.AsDuration())","+\t\t\t},","+\t\t\texpectedThumbnail: func(t *testing.T, thumbnail *pb.SessionRecordingThumbnail) {","+\t\t\t\trequire.NotNil(t, thumbnail)","+\t\t\t\trequire.NotEmpty(t, thumbnail.Png)","+","+\t\t\t\t_, err := png.Decode(bytes.NewReader(thumbnail.Png))","+\t\t\t\trequire.NoError(t, err)","+","+\t\t\t\trequire.Equal(t, int32(64), thumbnail.ScreenWidth)","+\t\t\t\trequire.Equal(t, int32(48), thumbnail.ScreenHeight)","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname: \"recovered session without start event populates metadata from end event\",","+\t\t\tevents: []apievents.AuditEvent{","+\t\t\t\tdesktopServerHelloEvent(t, startTime.Add(100*time.Millisecond), 64, 48),","+\t\t\t\tdesktopFastPathEvent(t, startTime.Add(1*time.Second), rdpstatetest.BuildBitmapPDU(0, 0, 4, 2, rdpstatetest.RGB565White)),","+\t\t\t\tdesktopRecoveredSessionEndEvent(startTime, startTime.Add(10*time.Second)),","+\t\t\t},","+\t\t\texpectedMetadata: func(t *testing.T, metadata *pb.SessionRecordingMetadata) {","+\t\t\t\trequire.NotNil(t, metadata)","+\t\t\t\trequire.NotNil(t, metadata.StartTime)","+\t\t\t\trequire.NotNil(t, metadata.EndTime)","+","+\t\t\t\trequire.True(t, metadata.StartTime.AsTime().Equal(startTime))","+\t\t\t\trequire.Equal(t, \"test-cluster\", metadata.ClusterName)","+\t\t\t\trequire.Equal(t, \"test-user\", metadata.User)","+\t\t\t\trequire.Equal(t, \"test-desktop\", metadata.ResourceName)","+\t\t\t\trequire.Equal(t, pb.SessionRecordingType_SESSION_RECORDING_TYPE_WINDOWS_DESKTOP, metadata.Type)","+\t\t\t\trequire.Equal(t, 10*time.Second, metadata.Duration.AsDuration())","+\t\t\t},","+\t\t\texpectedThumbnail: func(t *testing.T, thumbnail *pb.SessionRecordingThumbnail) {","+\t\t\t\trequire.NotNil(t, thumbnail)","+\t\t\t\trequire.NotEmpty(t, thumbnail.Png)","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname: \"unhandled events are silently ignored\",","+\t\t\tevents: generateCompleteDesktopSession(t, startTime, 64, 48, []apievents.AuditEvent{","+\t\t\t\t&apievents.SessionJoin{Metadata: apievents.Metadata{Time: startTime.Add(2 * time.Second)}},","+\t\t\t\t&apievents.SessionLeave{Metadata: apievents.Metadata{Time: startTime.Add(3 * time.Second)}},","+\t\t\t}),","+\t\t\texpectedMetadata: func(t *testing.T, metadata *pb.SessionRecordingMetadata) {","+\t\t\t\trequire.NotNil(t, metadata)","+","+\t\t\t\trequire.Equal(t, \"test-cluster\", metadata.ClusterName)","+\t\t\t\trequire.Equal(t, pb.SessionRecordingType_SESSION_RECORDING_TYPE_WINDOWS_DESKTOP, metadata.Type)","+\t\t\t},","+\t\t\texpectedThumbnail: func(t *testing.T, thumbnail *pb.SessionRecordingThumbnail) {","+\t\t\t\trequire.NotNil(t, thumbnail)","+\t\t\t\trequire.NotEmpty(t, thumbnail.Png)","+\t\t\t},","+\t\t},","+\t}","+","+\tfor _, tt := range tests {","+\t\tt.Run(tt.name, func(t *testing.T) {","+\t\t\tlastEventTime := tt.events[len(tt.events)-1].GetTime()","+\t\t\tduration := lastEventTime.Sub(startTime)","+","+\t\t\tprocessor := newTestDesktopProcessor(startTime, duration)","+\t\t\tdefer processor.release()","+","+\t\t\tfor _, evt := range tt.events {","+\t\t\t\trequire.NoError(t, processor.handleEvent(evt))","+\t\t\t}","+","+\t\t\tmetadata, thumbnail := processor.collect()","+","+\t\t\tif tt.expectedMetadata != nil {","+\t\t\t\ttt.expectedMetadata(t, metadata)","+\t\t\t}","+","+\t\t\tif tt.expectedThumbnail != nil {","+\t\t\t\ttt.expectedThumbnail(t, thumbnail)","+\t\t\t}","+\t\t})","+\t}","+}","+","+func TestDesktopRecordingProcessor_ThumbnailsWrittenToWriter(t *testing.T) {","+\tstartTime := time.Now()","+\tevents := generateCompleteDesktopSession(t, startTime, 64, 48, nil)","+","+\tlastEventTime := events[len(events)-1].GetTime()","+\tduration := lastEventTime.Sub(startTime)","+","+\tvar buf bytes.Buffer","+\tprocessor := newRecordingProcessor(&nopCloser{&buf}, slog.Default(), recordingmetadata.SessionTypeDesktop, startTime, duration)","+\tdefer processor.release()","+","+\tfor _, evt := range events {","+\t\trequire.NoError(t, processor.handleEvent(evt))","+\t}","+","+\tprocessor.collect()","+","+\trequire.NotEmpty(t, buf.Bytes(), \"thumbnails should have been written to the writer\")","+}","+","+func newTestDesktopProcessor(startTime time.Time, duration time.Duration) recordingProcessor {","+\treturn newRecordingProcessor(&nopCloser{io.Discard}, slog.Default(), recordingmetadata.SessionTypeDesktop, startTime, duration)","+}","+","+func generateCompleteDesktopSession(t *testing.T, startTime time.Time, width, height uint32, extraEvents []apievents.AuditEvent) []apievents.AuditEvent {","+\tt.Helper()","+","+\tevents := []apievents.AuditEvent{","+\t\tdesktopSessionStartEvent(startTime),","+\t\tdesktopServerHelloEvent(t, startTime.Add(100*time.Millisecond), width, height),","+\t\tdesktopFastPathEvent(t, startTime.Add(1*time.Second), rdpstatetest.BuildBitmapPDU(0, 0, 4, 2, rdpstatetest.RGB565White)),","+\t}","+","+\tevents = append(events, extraEvents...)","+","+\tevents = append(events,","+\t\tdesktopFastPathEvent(t, startTime.Add(8*time.Second), rdpstatetest.BuildBitmapPDU(10, 10, 4, 2, rdpstatetest.RGB565Red)),","+\t\tdesktopSessionEndEvent(startTime.Add(10*time.Second)),","+\t)","+","+\treturn events","+}","+","+func desktopSessionStartEvent(eventTime time.Time) *apievents.WindowsDesktopSessionStart {","+\treturn &apievents.WindowsDesktopSessionStart{","+\t\tMetadata: apievents.Metadata{","+\t\t\tClusterName: \"test-cluster\",","+\t\t\tTime:        eventTime,","+\t\t},","+\t\tUserMetadata: apievents.UserMetadata{","+\t\t\tUser: \"test-user\",","+\t\t},","+\t\tDesktopName: \"test-desktop\",","+\t}","+}","+","+func desktopSessionEndEvent(eventTime time.Time) *apievents.WindowsDesktopSessionEnd {","+\treturn &apievents.WindowsDesktopSessionEnd{","+\t\tMetadata: apievents.Metadata{","+\t\t\tTime: eventTime,","+\t\t},","+\t}","+}","+","+func desktopRecoveredSessionEndEvent(sessionStart, eventTime time.Time) *apievents.WindowsDesktopSessionEnd {","+\treturn &apievents.WindowsDesktopSessionEnd{","+\t\tMetadata: apievents.Metadata{","+\t\t\tClusterName: \"test-cluster\",","+\t\t\tTime:        eventTime,","+\t\t},","+\t\tUserMetadata: apievents.UserMetadata{","+\t\t\tUser: \"test-user\",","+\t\t},","+\t\tDesktopName: \"test-desktop\",","+\t\tStartTime:   sessionStart,","+\t}","+}"],"additions":217,"deletions":0,"truncated":false},{"path":"lib/auth/recordingmetadata/recordingmetadatav1/desktopthumbnail.go","lines":["@@ -0,0 +1,170 @@","+/**","+ * Teleport","+ * Copyright (C) 2026 Gravitational, Inc.","+ *","+ * This program is free software: you can redistribute it and/or modify","+ * it under the terms of the GNU Affero General Public License as published by","+ * the Free Software Foundation, either version 3 of the License, or","+ * (at your option) any later version.","+ *","+ * This program is distributed in the hope that it will be useful,","+ * but WITHOUT ANY WARRANTY; without even the implied warranty of","+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the","+ * GNU Affero General Public License for more details.","+ *","+ * You should have received a copy of the GNU Affero General Public License","+ * along with this program.  If not, see <http://www.gnu.org/licenses/>.","+ */","+","+package recordingmetadatav1","+","+import (","+\t\"bytes\"","+\t\"image\"","+\t\"image/png\"","+\t\"math\"","+","+\t\"github.com/gravitational/trace\"","+\t\"golang.org/x/image/draw\"","+","+\tpb \"github.com/gravitational/teleport/api/gen/proto/go/teleport/recordingmetadata/v1\"","+\tapievents \"github.com/gravitational/teleport/api/types/events\"","+\t\"github.com/gravitational/teleport/lib/srv/desktop/rdp/decoder\"","+\t\"github.com/gravitational/teleport/lib/srv/desktop/rdpstate\"","+)","+","+const (","+\t// thumbnailMaxDimensions is the maximum dimension (width or height) for the representative","+\t// session thumbnail. The other dimension is computed from the screen's actual aspect ratio","+\t// to avoid black bars.","+\tthumbnailMaxDimensions = 1536","+","+\t// frameMaxDimensions is the maximum dimension for streamed timeline frames. Frames are","+\t// rendered smaller than the representative thumbnail since they're displayed at low","+\t// resolution in the scrubber UI, which keeps the metadata file size reasonable.","+\tframeMaxDimensions = 1024","+","+\t// cursorVisibleZoom is the zoom level applied when the cursor is visible","+\tcursorVisibleZoom = 2.0","+)","+","+type desktopThumbnailGenerator struct {","+\trdpstate   *rdpstate.RDPState","+\tpngEncoder png.Encoder","+\tbuf        bytes.Buffer","+\t// disabled is set when the RDP decoder is not available (e.g. nop builds without desktop_access_rdp). Once set, all","+\t// subsequent events are skipped so that metadata processing degrades to a no-op instead of failing.","+\tdisabled bool","+}","+","+func newDesktopThumbnailGenerator() *desktopThumbnailGenerator {","+\treturn &desktopThumbnailGenerator{","+\t\trdpstate:   rdpstate.New(),","+\t\tpngEncoder: png.Encoder{CompressionLevel: png.BestSpeed},","+\t}","+}","+","+func (d *desktopThumbnailGenerator) handleEvent(evt apievents.AuditEvent) error {","+\tswitch e := evt.(type) {","+\tcase *apievents.DesktopRecording:","+\t\treturn d.handleDesktopRecording(e)","+\t}","+","+\treturn nil","+}","+","+func (d *desktopThumbnailGenerator) handleDesktopRecording(evt *apievents.DesktopRecording) error {","+\tif d.disabled {","+\t\treturn nil","+\t}","+","+\terr := d.rdpstate.HandleMessage(evt)","+\tif trace.IsNotImplemented(err) {","+\t\td.disabled = true","+","+\t\treturn nil","+\t}","+","+\treturn err","+}","+","+// produceThumbnail generates a thumbnail from the current RDP state. If the cursor is visible, the thumbnail is zoomed","+// to the area around the cursor. maxDim caps the longer side (in pixels) of the encoded PNG.","+// NOTE: If the decoder is not available (e.g. in nop builds without desktop_access_rdp), this will return nil without","+// error and all subsequent calls will be no-ops.","+func (d *desktopThumbnailGenerator) produceThumbnail(maxDim int) (*pb.SessionRecordingThumbnail, error) {","+\tif d.disabled {","+\t\treturn nil, nil","+\t}","+","+\timg := d.rdpstate.Image()","+\tif img == nil {","+\t\treturn nil, trace.BadParameter(\"rdp state has no image\")","+\t}","+","+\tcursor := d.rdpstate.CursorState()","+","+\tbounds := img.Bounds()","+","+\tscreenWidth := bounds.Dx()","+\tscreenHeight := bounds.Dy()","+","+\tif cursor.Visible {","+\t\tbounds = calculateCropBounds(bounds, cursor)","+\t}","+","+\tcropW := bounds.Dx()","+\tcropH := bounds.Dy()","+","+\t// Scale the crop to fit within maxDim.","+\tthumbW, thumbH := cropW, cropH","+\tif thumbW > thumbH {","+\t\tif thumbW > maxDim {","+\t\t\tthumbH = thumbH * maxDim / thumbW","+\t\t\tthumbW = maxDim","+\t\t}","+\t} else {","+\t\tif thumbH > maxDim {","+\t\t\tthumbW = thumbW * maxDim / thumbH","+\t\t\tthumbH = maxDim","+\t\t}","+\t}","+","+\tthumbImg := image.NewRGBA(image.Rect(0, 0, thumbW, thumbH))","+\tdraw.CatmullRom.Scale(thumbImg, thumbImg.Bounds(), img, bounds, draw.Over, nil)","+","+\td.buf.Reset()","+\tif err := d.pngEncoder.Encode(&d.buf, thumbImg); err != nil {","+\t\treturn nil, trace.Wrap(err, \"encoding thumbnail PNG\")","+\t}","+","+\treturn &pb.SessionRecordingThumbnail{","+\t\tCursorX:       int32(cursor.X),","+\t\tCursorY:       int32(cursor.Y),","+\t\tCursorVisible: cursor.Visible,","+\t\tScreenWidth:   int32(screenWidth),","+\t\tScreenHeight:  int32(screenHeight),","+\t\tPng:           bytes.Clone(d.buf.Bytes()),","+\t}, nil","+}","+","+func (d *desktopThumbnailGenerator) release() {","+\td.rdpstate.Release()","+}","+","+func calculateCropBounds(bounds image.Rectangle, cursor decoder.CursorState) image.Rectangle {","+\tscreenW := float64(bounds.Dx())","+\tscreenH := float64(bounds.Dy())"],"additions":157,"deletions":0,"truncated":false}],"additions":548,"deletions":10,"truncated":true,"file_count":15},"error":null,"fetched_at":"2026-05-20T17:48:54.363301+00:00"}