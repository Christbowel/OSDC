           # Append headers are stored under their lowercase key so every","+            # case-variant lands on (and appends to) the same entry.","+            existing = merged.get(lower)","+            if isinstance(existing, str) and isinstance(value, str):","+                merged[lower] = _append_header_value(existing, value)","+            else:","+                # `Omit` (removal) can't take part in an append; the later","+                # value overrides, as it does for any other header.","+                merged[lower] = value","+","+    return cast(\"Dict[str, str]\", merged)"," "," "," def _middleware_entry_mode(request: APIRequest) -> Literal[\"raw\", \"stream\", \"true\"] | None:"],"additions":66,"deletions":3,"truncated":false},{"path":"src/anthropic/_client.py","lines":["@@ -34,6 +34,7 @@","     DEFAULT_MAX_RETRIES,","     SyncAPIClient,","     AsyncAPIClient,","+    merge_headers,"," )"," "," # --- credentials support (hand-written, upstream to Stainless) ---","@@ -448,7 +449,7 @@ def copy("," ","         headers = self._custom_headers","         if default_headers is not None:","-            headers = {**headers, **default_headers}","+            headers = merge_headers(headers, default_headers)","         elif set_default_headers is not None:","             headers = set_default_headers"," ","@@ -861,7 +862,7 @@ def copy("," ","         headers = self._custom_headers","         if default_headers is not None:","-            headers = {**headers, **default_headers}","+            headers = merge_headers(headers, default_headers)","         elif set_default_headers is not None:","             headers = set_default_headers"," "],"additions":3,"deletions":2,"truncated":false},{"path":"src/anthropic/lib/bedrock/_client.py","lines":["@@ -23,6 +23,7 @@","     SyncAPIClient,","     AsyncAPIClient,","     FinalRequestOptions,","+    merge_headers,"," )"," from ._stream_decoder import AWSEventStreamDecoder"," from ...resources.messages import Messages, A