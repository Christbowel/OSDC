id} rejects remove on /region\", func(t *testing.T) {","+\t\t// Create an identity with a region.","+\t\tcreated := send(t, \"POST\", \"/identities\", http.StatusCreated,","+\t\t\tjson.RawMessage(`{\"schema_id\":\"default\",\"traits\":{\"bar\":\"baz\"},\"region\":\"eu-central\"}`),","+\t\t)","+\t\tid := created.Get(\"id\").String()","+\t\trequire.NotEmpty(t, id)","+","+\t\t// remove is not allowed on /region: callers must always set the region","+\t\t// explicitly via add/replace.","+\t\tsend(t, \"PATCH\", \"/identities/\"+id, http.StatusBadRequest,","+\t\t\tjson.RawMessage(`[{\"op\":\"remove\",\"path\":\"/region\"}]`),","+\t\t)","+\t})","+","+\tt.Run(\"case=PATCH /admin/identities/{id} rejects move on /region\", func(t *testing.T) {","+\t\tcreated := send(t, \"POST\", \"/identities\", http.StatusCreated,","+\t\t\tjson.RawMessage(`{\"schema_id\":\"default\",\"traits\":{\"bar\":\"baz\"},\"region\":\"eu-central\"}`),","+\t\t)","+\t\tid := created.Get(\"id\").String()","+\t\trequire.NotEmpty(t, id)","+","+\t\t// move is not in the op-allowlist; expect a 400.","+\t\tsend(t, \"PATCH\", \"/identities/\"+id, http.StatusBadRequest,","+\t\t\tjson.RawMessage(`[{\"op\":\"move\",\"from\":\"/region\",\"path\":\"/traits/x\"}]`),","+\t\t)","+\t})","+","+\tt.Run(\"case=PATCH /admin/identities/{id} rejects invalid region value\", func(t *testing.T) {","+\t\tcreated := send(t, \"POST\", \"/identities\", http.StatusCreated,","+\t\t\tjson.RawMessage(`{\"schema_id\":\"default\",\"traits\":{\"bar\":\"baz\"},\"region\":\"eu-central\"}`),","+\t\t)","+\t\tid := created.Get(\"id\").String()","+\t\trequire.NotEmpty(t, id)","+","+\t\tsend(t, \"PATCH\", \"/identities/\"+id, http.StatusBadRequest,","+\t\t\tjson.RawMessage(`[{\"op\":\"replace\",\"path\":\"/region\",\"value\":\"mars\"}]`),","+\t\t)","+\t})","+","+\tt.Run(\"case=PUT /admin/identities/{id} updates region\", func(t *testing.T) {","+\t\t// Create with region us-east, then PUT with region eu-central.","+\t\tcreated := send(t, \"POST\",