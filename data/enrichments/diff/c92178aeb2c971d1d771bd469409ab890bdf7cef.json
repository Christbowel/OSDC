y.Namespace, s.embedder.Model, req.Key.Resource,","+\t\treq.Key.Namespace, s.embedder.Model, coll.PartitionKey,"," \t\tdense, limit, translateVectorSearchFilters(req.Filters)...)"," \tif err != nil {"," \t\tif ctx.Err() != nil {","@@ -686,20 +700,26 @@ func (s *searchServer) VectorSearch(ctx context.Context, req *resourcepb.VectorS"," \t\treturn nil, status.Error(codes.Unauthenticated, \"no user in context\")"," \t}"," ","-\tallowed, err := s.batchCheckVectorSearchResults(ctx, user, req.Key, results)","-\tif err != nil {","-\t\tif ctx.Err() != nil {","-\t\t\treturn nil, status.FromContextError(ctx.Err()).Err()","+\t// External rows aren't unified-storage resources — the authz service","+\t// has nothing to answer for them, so per-result checks are skipped","+\t// and the caller does its own post-filtering.","+\tvar allowed map[vectorAuthzKey]bool","+\tif !coll.IsExternal {","+\t\tallowed, err = s.batchCheckVectorSearchResults(ctx, user, req.Key, results)","+\t\tif err != nil {","+\t\t\tif ctx.Err() != nil {","+\t\t\t\treturn nil, status.FromContextError(ctx.Err()).Err()","+\t\t\t}","+\t\t\ts.log.Error(\"vector search: authz batch check\", \"err\", err)","+\t\t\treturn nil, status.Error(codes.Internal, \"authz batch check\")"," \t\t}","-\t\ts.log.Error(\"vector search: authz batch check\", \"err\", err)","-\t\treturn nil, status.Error(codes.Internal, \"authz batch check\")"," \t}"," "," \tresp = &resourcepb.VectorSearchResponse{"," \t\tResults: make([]*resourcepb.VectorSearchResult, 0, len(results)),"," \t}"," \tfor _, r := range results {","-\t\tif !allowed[vectorAuthzKey{r.UID, r.Folder}] {","+\t\tif !coll.IsExternal && !allowed[vectorAuthzKey{r.UID, r.Folder}] {"," \t\t\tcontinue"," \t\t}"," \t\tresp.Results = append(resp.Results, &resourcepb.VectorSearchResult{","@@ -715,6 +735,31 @@ func (s *searchServer) VectorSearch(ctx context.Context, req *resourcepb.VectorS"," \treturn resp, nil"," }"," ","+// vectorSearchResponseCode maps a VectorSearch outcome to the gRPC code label","+// on the search-duration metric. ErrorResult carries HTTP-style codes; an","+// unmapped code labels as Unknown — a signal to add a mapping, not a silent","+// mislabel.","+func vectorSearchResponseCode(resp *resourcepb.VectorSearchResponse, retErr error) codes.Code {","+\tswitch {","+\tcase retErr != nil:","+\t\treturn status.Code(retErr)","+\tcase resp == nil || resp.Error == nil:","+\t\treturn codes.OK","+\t}","+\tswitch resp.Error.Code {","+\tcase http.StatusBadRequest:","+\t\treturn codes.InvalidArgument","+\tcase http.StatusNotFound:","+\t\treturn codes.NotFound","+\tcase http.StatusForbidden:","+\t\treturn codes.PermissionDenied","+\tcase http.StatusUnauthorized:","+\t\treturn codes.Unauthenticated","+\tdefault:","+\t\treturn codes.Unknown","+\t}","+}","+"," // validateVectorSearchRequest returns a non-nil response with a"," // BadRequestError when the request fails validation; nil means valid."," // Pulled out of VectorSearch to keep that function under the cyclomatic"],"additions":63,"deletions":18,"truncated":false},{"path":"pkg/storage/unified/resource/search_vector_test.go","lines":["@@ -64,6 +64,26 @@ type fakeVectorBackend struct {"," \tgotFilters                          []vector.SearchFilter"," \tresults                             []vector.VectorSearchResult"," \terr                                 error","+","+\t// ResolveCollection behavior: default resolves any pair to","+\t// {PartitionKey: resource}. Set collection to override, or","+\t// resolveNotFound/resolveErr to exercise those paths.","+\tcollection      *vector.Collection","+\tresolveNotFound bool","+\tresolveErr      error","+}","+","+func (f *fakeVectorBackend) ResolveCollection(_ context.Context, group, resource string) (vector.Collection, bool, error) {","+\tif f.resolveErr != nil {","+\t\treturn vector.Collection{}, false, f.resolveErr","+\t}","+\tif f.resolveNotFound {","+\t\treturn vector.Collection{}, false, nil","+\t}","+\tif f.collection != nil {","+\t\treturn *f.collection, true, nil","+\t}","+\treturn vector.Collection{Group: group, Resource: resource, PartitionKey: resource}, true, nil"," }"," "," func (f *fakeVectorBackend) Search(_ context.Context, namespace, model, resource string,","@@ -133,14 +153,17 @@ func newTestSearchServer(emb *embedder.Embedder, backend vector.VectorBackend, a"," \t\tvectorBackend: backend,"," \t\tembedder:      emb,"," \t\taccess:        ac,","+\t\t// validKey()'s pair, allowed on both lists so tests exercise paths past the allowlist.","+\t\tcollectionAllowlist: vector.NewCollectionAllowlist([]string{\"g/r\"}, []string{\"g/r\"}),"," \t}"," }"," ","-// authedCtx returns a context with a static user — required by the","-// VectorSearch handler's AuthInfoFrom check.","+// authedCtx returns a context with a static user in namespace \"ns\" —","+// required by the handler's requireUserNamespace and AuthInfoFrom checks","+// (validKey() uses the same namespace)."," func authedCtx() context.Context {"," \treturn authlib.WithAuthInfo(context.Background(),","-\t\t&identity.StaticRequester{UserID: 1, UserUID: \"u\", Type: authlib.TypeUser},","+\t\t&identity.StaticRequester{UserID: 1, UserUID: \"u\", Namespace: \"ns\", Type: authlib.TypeUser},"," \t)"," }"," ","@@ -449,12 +472,17 @@ func TestVectorSearch_NoUserInContextReturnsUnauthenticated(t *testing.T) {"," \t}"," \ts := newTestSearchServer(newTestEmbedder(&fakeTextEmbedder{dim: 4}), backend)"," ","-\t// context.Background() has no auth info — handler should reject.","-\t_, err := s.VectorSearch(context.Background(), &resourcepb.VectorSearchRequest{","+\t// context.Background() has no auth info — requireUserNamespace rejects","+\t// with a 401 ErrorResult before any work happens (same shape as the","+\t// other delegated-only RPCs).","+\tresp, err := s.VectorSearch(context.Background(), &resourcepb.VectorSearchRequest{"," \t\tKey: validKey(), Query: \"q\","," \t})","-\trequire.Error(t, err)","-\tassert.Equal(t, codes.Unauthenticated, status.Code(err)