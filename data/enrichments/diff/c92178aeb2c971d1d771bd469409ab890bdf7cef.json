\ts := newTestSearchServer(newTestEmbedder(&fakeTextEmbedder{dim: 4}), backend)","+","+\tctx := authlib.WithAuthInfo(context.Background(),","+\t\t&identity.StaticRequester{UserID: 1, UserUID: \"u\", Namespace: \"other-tenant\", Type: authlib.TypeUser},","+\t)","+\tresp, err := s.VectorSearch(ctx, &resourcepb.VectorSearchRequest{","+\t\tKey: validKey(), Query: \"q\", Limit: 1, // validKey() is namespace \"ns\"","+\t})","+\trequire.NoError(t, err)","+\trequire.NotNil(t, resp.Error)","+\tassert.Equal(t, int32(403), resp.Error.Code)","+\tassert.Empty(t, resp.Results)","+\tassert.Empty(t, backend.gotResource, \"backend search must not run\")","+}","+","+func TestVectorSearch_CollectionNotInAllowlistIsNotFound(t *testing.T) {","+\t// A provisioned collection outside the config allowlist answers exactly","+\t// like an unprovisioned one.","+\tbackend := &fakeVectorBackend{}","+\ts := newTestSearchServer(newTestEmbedder(&fakeTextEmbedder{dim: 4}), backend)","+\ts.collectionAllowlist = vector.NewCollectionAllowlist(nil, nil)","+","+\tresp, err := s.VectorSearch(authedCtx(), &resourcepb.VectorSearchRequest{","+\t\tKey: validKey(), Query: \"q\", Limit: 1,","+\t})","+\trequire.NoError(t, err)","+\trequire.NotNil(t, resp.Error)","+\tassert.Equal(t, int32(404), resp.Error.Code)","+\tassert.Empty(t, backend.gotResource, \"backend search must not run\")","+}","+","+func TestVectorSearch_AllowlistSeparatesInternalAndExternal(t *testing.T) {","+\t// An external collection is not covered by the internal list.","+\tbackend := &fakeVectorBackend{","+\t\tcollection: &vector.Collection{Group: \"g\", Resource: \"r\", PartitionKey: \"r\", IsExternal: true},","+\t}","+\ts := newTestSearchServer(newTestEmbedder(&fakeTextEmbedder{dim: 4}), backend)","+\ts.collectionAllowlist = vector.NewCollectionAllowlist([]string{\"g/r\"}, nil)","+","+\tresp, err := s.VectorSearch(authedCtx(), &resourcepb.VectorSearchRequest{","+\t\tKey: validKey(), Query: \"q\", Limit: 1,","+\t})","+\trequire.NoError(t, err)","+\trequire.NotNil(t, resp.Error)","+\tassert.Equal(t, int32(404), resp.Error.Code)","+}"],"additions":156,"deletions":7,"truncated":false},{"path":"pkg/storage/unified/resource/server.go","lines":["@@ -320,6 +320,10 @@ type SearchOptions struct {"," \tRateLimiter        vector.RateLimiter"," \tRateLimitPerTenant int"," \tRateLimitWindow    time.Duration","+","+\t// Vector API collection allowlists: \"group/resource\" entries; empty allows nothing.","+\tAllowedInternalCollections []string","+\tAllowedExternalCollections []string"," }"," "," type ResourceServerOptions struct {"],"additions":4,"deletions":0,"truncated":false},{"path":"pkg/storage/unified/search/embed/backfill/fakes_test.go","lines":["@@ -223,6 +223,10 @@ func (f *fakeVector) markExists(ns, model, res, uid string) {"," \tf.existsSet[existsKey(ns, model, res, uid)] = true"," }"," ","+func (f *fakeVector) ResolveCollection(_ context.Context, group, resource string) (vector.Collection, bool, error) {","+\treturn vector.Collection{Group: group, Resource: resource, PartitionKey: resource}, true, nil","+}","+"," func (f *fakeVector) Search(context.Context, string, string, string, []float32, int, ...vector.SearchFilter) ([]vector.VectorSearchResult, error) {"," \treturn nil, nil"," }"],"additions":4,"deletions":0,"truncated":false},{"path":"pkg/storage/unified/search/embed/reconciler/fakes_test.go","lines":["@@ -207,6 +207,10 @@ func newFakeVector() *fakeVector {"," "," func subsKey(ns, model, res, uid string) string { return ns + \"|\" + model + \"|\" + res + \"|\" + uid }"," ","+func (f *fakeVector) ResolveCollection(_ context.Context, group, resource string) (vector.Collection, bool, error) {","+\treturn vector.Collection{Group: group, Resource: resource, PartitionKey: resource}, true, nil","+}","+"," func (f *fakeVector) Search(context.Context, string, string, string, []float32, int, ...vector.SearchFilter) ([]vector.VectorSearchResult, error) {"," \treturn nil, nil"," }"],"additions":4,"deletions":0,"truncated":false},{"path":"pkg/storage/unified/search/vector/allowlist.go","lines":["@@ -0,0 +1,45 @@","+package vector","+","+import \"strings\"","+","+// CollectionAllowlist is config-defined policy for which collections may be","+// served through the vector APIs. The catalog maps names to partitions; this","+// decides whether a resolved collection is addressable at all.","+type CollectionAllowlist struct {","+\tinternal map[string]struct{}","+\texternal map[string]struct{}","+}","+","+// NewCollectionAllowlist builds an allowlist from \"group/resource\" entries.","+// Surrounding whitespace is ignored and empty entries are dropped; the zero","+// value (and empty lists) allow nothing.","+func NewCollectionAllowlist(internal, external []string) CollectionAllowlist {","+\treturn CollectionAllowlist{","+\t\tinternal: allowlistSet(internal),","+\t\texternal: allowlistSet(external),","+\t}","+}","+","+func allowlistSet(entries []string) map[string]struct{} {","+\tset := make(map[string]struct{}, len(entries))","+\tfor _, e := range entries {","+\t\te = strings.TrimSpace(e)","+\t\tif e == \"\" {","+\t\t\tcontinue","+\t\t}","+\t\tset[e] = struct{}{}","+\t}","+\treturn set","+}","+","+// Allows reports whether the collection may be served. Internal and external","+// collections are gated by separate lists.","+func (a CollectionAllowlist) Allows(c Collection) bool {","+\tkey := c.Group + \"/\" + c.Resource","+\tif c.IsExternal {","+\t\t_, ok := a.external[key]","+\t\treturn ok","+\t}","+\t_, ok := a.internal[key]","+\treturn ok","+}"],"additions":45,"deletions":0,"truncated":false},{"path":"pkg/storage/unified/search/vector/allowlist_test.go","lines":["@@ -0,0 +1,28 @@","+package vector","+","+import (","+\t\"testing\"","+","+\t\"github.com/stretchr/testify/require\"","+)","+","+func TestCollectionAllowlist(t *testing.T) {","+\ta := NewCollectionAllowlist(","+\t\t[]string{\"dashboard.grafana.app/dashboards\", \" spaced.group/things \"},","+\t\t[]string{\"ext.example.com/my-things\", \"\"},","+\t)","+","+\tinternal := Collection{Group: \"dashboard.grafana.app\", Resource: \"dashboards\"}","+\trequire.True(t, a.Allows(internal))","+\trequire.True(t, a.Allows(Collection{Group: \"spaced.group\", Resource: \"things\"}), \"entries are trimmed\")","+","+\texternal := Collection{Group: \"ext.example.com\", Resource: \"my-things\", IsExternal: true}","+\trequire.True(t, a.Allows(external))","+","+\t// Internal and external lists don't cross over.","+\trequire.False(t, a.Allows(Collection{Group: \"dashboard.grafana.app\", Resource: \"dashboards\", IsExternal: true}))","+\trequire.False(t, a.Allows(Collection{Group: \"ext.example.com\", Resource: \"my-things\"}))","+","+\trequire.False(t, a.Allows(Collection{Group: \"unknown\", Resource: \"nope\"}))","+\trequire.False(t, CollectionAllowlist{}.Allows(internal), \"zero value allows nothing\")","+}"],"additions":28,"deletions":0,"truncated":false},{"path":"pkg/storage/unified/search/vector/catalog.go","lines":["@@ -0,0 +1,71 @@","+package vector","+","+import (","+\t\"context\"","+\t\"fmt\"","+","+\t\"github.com/grafana/grafana/pkg/storage/unified/sql/dbutil\"","+\t\"github.com/grafana/grafana/pkg/storage/unified/sql/sqltemplate\"","+)","+","+// Collection is one row of the embedding_collections catalog: a (group,","+// resource) pair provisioned for vector storage. The catalog does two","+// things: maps resource names to partition keys (resource names may contain","+// chars a table name can't, e.g. hyphens), and disambiguates same-named","+// resources across groups (the partition name doesn't encode the group).","+type Collection struct {","+\tGroup        string // e.g. \"dashboard.grafana.app\"","+\tResource     string // resource name as callers send it, e.g. \"dashboards\"","+\tPartitionKey string // value stored in embeddings.resource (LIST partition key)","+\tIsExternal   bool   // externally-pushed rows; reads skip per-result authz","+}","+","+func (b *pgvectorBackend) ResolveCollection(ctx context.Context, group, resource string) (Collection, bool, error) {","+\tcollections, err := b.listCollections(ctx)","+\tif err != nil {","+\t\treturn Collection{}, false, err","+\t}","+\tfor _, c := range collections {","+\t\tif c.Group == group && c.Resource == resource {","+\t\t\treturn c, true, nil","+\t\t}","+\t}","+\treturn Collection{}, false, nil","+}","+","+// hasPartitionKey reports whether any catalog row owns the given partition","+// key. Internal callers (reconciler, backfill) work in partition keys","+// directly, so validateResource checks this side of the mapping.","+func (b *pgvectorBackend) hasPartitionKey(ctx context.Context, key string) (bool, error) {","+\tcollections, err := b.listCollections(ctx)","+\tif err != nil {","+\t\treturn false, err","+\t}","+\tfor _, c := range collections {","+\t\tif c.PartitionKey == key {","+\t\t\treturn true, nil","+\t\t}","+\t}","+\treturn false, nil","+}","+","+func (b *pgvectorBackend) listCollections(ctx context.Context) ([]Collection, error) {","+\treq := &sqlVectorCatalogListRequest{","+\t\tSQLTemplate: sqltemplate.New(b.dialect),","+\t\tResponse:    &sqlVectorCatalogListResponse{},","+\t}","+\trows, err := dbutil.Query(ctx, b.db, sqlVectorCatalogList, req)","+\tif err != nil {","+\t\treturn nil, fmt.Errorf(\"list embedding collections: %w\", err)","+\t}","+\tout := make([]Collection, 0, len(rows))","+\tfor _, r := range rows {","+\t\tout = append(out, Collection{","+\t\t\tGroup:        r.GroupName,","+\t\t\tResource:     r.Resource,","+\t\t\tPartitionKey: r.PartitionKey,","+\t\t\tIsExternal:   r.IsExternal,","+\t\t})","+\t}","+\treturn out, nil","+}"],"additions":71,"deletions":0,"truncated":false},{"path":"pkg/storage/unified/search/vector/catalog_test.go","lines":["@@ -0,0 +1,51 @@","+package vector","+","+import (","+\t\"context\"","+\t\"errors\"","+\t\"testing\"","+","+\tsqlmock \"github.com/DATA-DOG/go-sqlmock\"","+\t\"github.com/stretchr/testify/require\"","+","+\t\"github.com/grafana/grafana/pkg/storage/unified/sql/test\"","+\t\"github.com/grafana/grafana/pkg/util/testutil\"","+)","+","+func TestResolveCollection_CatalogRows(t *testing.T) {","+\trdb := test.NewDBProviderNopSQL(t)","+\tb := NewPgvectorBackend(context.Background(), rdb.DB, 1000, 0, false, nil)","+\tctx := testutil.NewDefaultTestContext(t)","+","+\t// A resource name with chars a table name can't hold maps to its","+\t// catalog-assigned partition key.","+\trdb.SQLMock.ExpectQuery(\"SELECT\").WillReturnRows(","+\t\tsqlmock.NewRows([]string{\"group_name\", \"resource\", \"partition_key\", \"is_external\"}).","+\t\t\tAddRow(\"ext.example.com\", \"my-things\", \"my_things\", true))","+","+\tc, found, err := b.ResolveCollection(ctx, \"ext.example.com\", \"my-things\")","+\trequire.NoError(t, err)","+\trequire.True(t, found)","+\trequire.Equal(t, \"my_things\", c.PartitionKey)","+\trequire.True(t, c.IsExternal)","+","+\t// Unknown pairs are not found rather than erroring.","+\trdb.SQLMock.ExpectQuery(\"SELECT\").WillReturnRows(emptyCatalogRows())","+\t_, found, err = b.ResolveCollection(ctx, \"nope\", \"nope\")","+\trequire.NoError(t, err)","+\trequire.False(t, found)","+\trequire.NoError(t, rdb.SQLMock.ExpectationsWereMet())","+}","+","+func TestResolveCollection_DBErrorSurfaces(t *testing.T) {","+\t// Non-builtin lookups propagate catalog errors instead of silently","+\t// narrowing the catalog to the built-in entries.","+\trdb := test.NewDBProviderNopSQL(t)","+\tb := NewPgvectorBackend(context.Background(), rdb.DB, 1000, 0, false, nil)","+\tctx := testutil.NewDefaultTestContext(t)","+","+\trdb.SQLMock.ExpectQuery(\"SELECT\").WillReturnError(errors.New(\"db down\"))","+\t_, _, err := b.ResolveCollection(ctx, \"ext.example.com\", \"my-things\")","+\trequire.Error(t, err)","+\trequire.NoError(t, rdb.SQLMock.ExpectationsWereMet())","+}"],"additions":51,"deletions":0,"truncated":false},{"path":"pkg/storage/unified/search/vector/data/vector_catalog_list.sql","lines":["@@ -0,0 +1,7 @@","+SELECT","+    {{ .Ident \"group_name\"    | .Into .Response.GroupName }},","+    {{ .Ident \"resource\"      | .Into .Response.Resource }},","+    {{ .Ident \"partition_key\" | .Into .Response.PartitionKey }},","+    {{ .Ident \"is_external\"   | .Into .Response.IsExternal }}","+    FROM embedding_collections","+;"],"additions":7,"deletions":0,"truncated":false},{"path":"pkg/storage/unified/search/vector/integration_test.go","lines":["@@ -617,3 +617,43 @@ func readEmbeddingTimestamps(t *testing.T, engine *xorm.Engine, namespace, model"," \trequire.NoError(t, row.Scan(&createdAt, &updatedAt))"," \treturn createdAt, updatedAt"," }","+","+func TestIntegrationVectorCollectionCatalog(t *testing.T) {","+\tbackend, engine, ctx := setupIntegrationTest(t)","+","+\t// The migration seeds the dashboards row.","+\tc, found, err := backend.ResolveCollection(ctx, \"dashboard.grafana.app\", \"dashboards\")","+\trequire.NoError(t, err)","+\trequire.True(t, found)","+\tassert.Equal(t, \"dashboards\", c.PartitionKey)","+\tassert.False(t, c.IsExternal)","+","+\t// Unknown pair: not found, no error.","+\t_, found, err = backend.ResolveCollection(ctx, \"nope.grafana.app\", \"nope\")","+\trequire.NoError(t, err)","+\tassert.False(t, found)","+","+\t// Insert an external collection whose resource name is not a valid SQL","+\t// identifier — the catalog decouples resource names from partition keys.","+\t_, err = engine.DB().ExecContext(ctx, `","+\t\tINSERT INTO embedding_collections (group_name, resource, partition_key, is_external)","+\t\tVALUES ('ext.example.com', 'my-things', 'my_things', true)","+\t\tON CONFLICT DO NOTHING`)","+\trequire.NoError(t, err)","+\tt.Cleanup(func() {","+\t\t_, _ = engine.DB().ExecContext(context.Background(),","+\t\t\t`DELETE FROM embedding_collections WHERE group_name = 'ext.example.com'`)","+\t})","+","+\tc, found, err = backend.ResolveCollection(ctx, \"ext.example.com\", \"my-things\")","+\trequire.NoError(t, err)","+\trequire.True(t, found)","+\tassert.Equal(t, \"my_things\", c.PartitionKey)","+\tassert.True(t, c.IsExternal)","+","+\t// validateResource rides the catalog: operations on an unprovisioned","+\t// partition key are rejected before touching the embeddings table.","+\t_, err = backend.Search(ctx, \"ns\", testModel, \"not-provisioned\", make([]float32, 3), 5)","+\trequire.Error(t, err)","+\trequire.Contains(t, err.Error(), \"unsupported resource\")","+}"],"additions":40,"deletions":0,"truncated":false},{"path":"pkg/storage/unified/search/vector/pgvector.go","lines":["@@ -98,10 +98,18 @@ func truncateRunes(s string, max int) string {"],"additions":0,"deletions":0,"truncated":false}],"additions":520,"deletions":36,"truncated":true,"file_count":15},"error":null,"fetched_at":"2026-07-23T10:10:31.145147+00:00"}