nc (c *Client) getImageBuilderVersion(ctx context.Context, environmentName string) (string, error) {","+\tif c.profile.ImageBuilderVersion != \"\" {","+\t\treturn c.profile.ImageBuilderVersion, nil","+\t}","+\treturn c.environmentManager.GetImageBuilderVersion(ctx, firstNonEmpty(environmentName, c.profile.Environment))","+}","+"," // Close closes all gRPC connections."," func (c *Client) Close() {"," \tctx := context.Background()"],"additions":11,"deletions":0,"truncated":false},{"path":"go/cls.go","lines":["@@ -59,7 +59,7 @@ func (s *clsServiceImpl) FromName(ctx context.Context, appName string, name stri"," \tserviceFunction, err := s.client.cpClient.FunctionGet(ctx, pb.FunctionGetRequest_builder{"," \t\tAppName:         appName,"," \t\tObjectTag:       serviceFunctionName,","-\t\tEnvironmentName: environmentName(params.Environment, s.client.profile),","+\t\tEnvironmentName: firstNonEmpty(params.Environment, s.client.profile.Environment),"," \t}.Build())"," "," \tif status, ok := status.FromError(err); ok && status.Code() == codes.NotFound {"],"additions":1,"deletions":1,"truncated":false},{"path":"go/config.go","lines":["@@ -138,11 +138,3 @@ func firstNonEmpty(values ...string) string {"," \t}"," \treturn \"\""," }","-","-func environmentName(environment string, profile Profile) string {","-\treturn firstNonEmpty(environment, profile.Environment)","-}","-","-func imageBuilderVersion(version string, profile Profile) string {","-\treturn firstNonEmpty(version, profile.ImageBuilderVersion, \"2024.10\")","-}"],"additions":0,"deletions":8,"truncated":false},{"path":"go/environment.go","lines":["@@ -0,0 +1,128 @@","+package modal","+","+import (","+\t\"context\"","+\t\"fmt\"","+\t\"log/slog\"","+\t\"sync\"","+\t\"time\"","+","+\tpb \"github.com/modal-labs/modal-client/go/proto/modal_proto\"","+\t\"golang.org/x/sync/singleflight\"","+)","+","+// fetchEnvironmentTimeout bounds a single environment fetch. The RPC runs on a","+// context detached from the caller, so without this bound a hung server would","+// block every concurrent waiter sharing the singleflight call indefinitely.","+const fetchEnvironmentTimeout = 30 * time.Second","+","+type environmentSettings struct {","+\tImageBuilderVersion string","+\tWebhookSuffix       string","+}","+","+type environment struct {","+\tID       string","+\tName     string","+\tSettings environmentSettings","+}","+","+type environmentManager struct {","+\tclient pb.ModalClientClient","+\tlogger *slog.Logger","+","+\tmu    sync.RWMutex","+\tcache map[string]*environment","+\tgroup singleflight.Group","+}","+","+func newEnvironmentManager(client pb.ModalClientClient, logger *slog.Logger) *environmentManager {","+\tmanager := &environmentManager{","+\t\tclient: client,","+\t\tlogger: logger,","+\t\tcache:  make(map[string]*environment),","+\t}","+\treturn manager","+}","+","+// fetchEnvironment fetches the environment from the server and caches the result. Passing","+// an empty name returns the default environment","+func (manager *environmentManager) fetchEnvironment(ctx context.Context, name string) (*environment, error) {","+\tmanager.mu.RLock()","+\tenv, ok := manager.cache[name]","+\tmanager.mu.RUnlock()","+\tif ok {","+\t\treturn env, nil","+\t}","+","+\tch := manager.group.DoChan(name, func() (any, error) {","+\t\tmanager.mu.RLock()","+\t\tenv, ok := manager.cache[name]","+\t\tmanager.mu.RUnlock()","+\t\tif ok {","+\t\t\treturn env, nil","+\t\t}","+\t\t// Run the RPC on a context detached from any individual caller so that","+\t\t// one caller leaving cannot fail the others sharing this flight. The","+\t\t// detached context is bounded by fetchEnvironmentTimeout rather than a","+\t\t// caller's deadline, keeping the flight's lifetime independent of which","+\t\t// caller happens to win it. Each caller still honors its own deadline","+\t\t// below by selecting on its ctx while waiting for the result.","+\t\trpcCtx, cancel := context.WithTimeout(context.WithoutCancel(ctx), fetchEnvironmentTimeout)","+\t\tdefer cancel()","+\t\tmanager.logger.DebugContext(rpcCtx, \"Fetching environment from server\", \"environment_name\", name)","+","+\t\tresp, err := manager.client.EnvironmentGetOrCreate(rpcCtx, pb.EnvironmentGetOrCreateRequest_builder{","+\t\t\tDeploymentName: name,","+\t\t}.Build())","+\t\tif err != nil {","+\t\t\treturn nil, err","+\t\t}","+","+\t\tmetadata := resp.GetMetadata()","+\t\tsettings := metadata.GetSettings()","+","+\t\tenv = &environment{","+\t\t\tID:   resp.GetEnvironmentId(),","+\t\t\tName: metadata.GetName(),","+\t\t\tSettings: environmentSettings{","+\t\t\t\tImageBuilderVersion: settings.GetImageBuilderVersion(),","+\t\t\t\tWebhookSuffix:       settings.GetWebhookSuffix(),","+\t\t\t},","+\t\t}","+","+\t\tmanager.mu.Lock()","+\t\tmanager.cache[name] = env","+\t\tmanager.mu.Unlock()","+\t\tmanager.logger.DebugContext(rpcCtx, \"Cached environment\",","+\t\t\t\"environment_name\", name,","+\t\t\t\"environment_id\", env.ID,","+\t\t\t\"image_builder_version\", env.Settings.ImageBuilderVersion,","+\t\t)","+","+\t\treturn env, nil","+\t})","+","+\t// Wait for the shared flight, but honor this caller's own deadline or","+\t// cancellation. If ctx is done first, this caller returns early while the","+\t// flight keeps running for the remaining waiters and still populates the","+\t// cache for the next caller.","+\tselect {","+\tcase <-ctx.Done():","+\t\treturn nil, ctx.Err()","+\tcase res := <-ch:","+\t\tif res.Err != nil {","+\t\t\treturn nil, res.Err","+\t\t}","+\t\treturn res.Val.(*environment), nil","+\t}","+}","+","+// GetImageBuilderVersion returns the image builder version","+func (manager *environmentManager) GetImageBuilderVersion(ctx context.Context, environmentName string) (string, error) {","+\tenv, err := manager.fetchEnvironment(ctx, environmentName)","+\tif err != nil {","+\t\treturn \"\", fmt.Errorf(\"failed to get environment for image builder version: %w\", err)","+\t}","+\treturn env.Settings.ImageBuilderVersion, nil","+}"],"additions":128,"deletions":0,"truncated":false},{"path":"go/environment_test.go","lines":["@@ -0,0 +1,192 @@","+package modal","+","+import (","+\t\"context\"","+\t\"encoding/base64\"","+\t\"fmt\"","+\t\"sync\"","+\t\"sync/atomic\"","+\t\"testing\"","+","+\tpb \"github.com/modal-labs/modal-client/go/proto/modal_proto\"","+\t. \"github.com/onsi/gomega\"","+\t\"google.golang.org/grpc\"","+)","+","+type mockEnvironmentClient struct {","+\tpb.ModalClientClient","+\tEnvironmentGetOrCreateCallCount atomic.Uint64","+\tEnvs                            sync.Map","+}","+","+func (m *mockEnvironmentClient) EnvironmentGetOrCreate(ctx context.Context, req *pb.EnvironmentGetOrCreateRequest, opts ...grpc.CallOption) (*pb.EnvironmentGetOrCreateResponse, error) {","+\tm.EnvironmentGetOrCreateCallCount.Add(1)","+\tname := req.GetDeploymentName()","+\tif resp, ok := m.Envs.Load(name); ok {","+\t\treturn resp.(*pb.EnvironmentGetOrCreateResponse), nil","+\t}","+\treturn pb.EnvironmentGetOrCreateResponse_builder{","+\t\tEnvironmentId: \"en-custom-id\",","+\t\tMetadata: pb.EnvironmentMetadata_builder{","+\t\t\tName: name,","+\t\t\tSettings: pb.EnvironmentSettings_builder{","+\t\t\t\tImageBuilderVersion: \"2025.06\",","+\t\t\t\tWebhookSuffix:       \"\",","+\t\t\t}.Build(),","+\t\t}.Build(),","+\t}.Build(), nil","+}","+","+func (m *mockEnvironmentClient) AuthTokenGet(ctx context.Context, req *pb.AuthTokenGetRequest, opts ...grpc.CallOption) (*pb.AuthTokenGetResponse, error) {","+\texpMsg := []byte(\"{'exp': 9999999999}\")","+\tencodedString := base64.URLEncoding.EncodeToString(expMsg)","+\tmockJWT := fmt.Sprintf(\"x.%s.x\", encodedString)","+\treturn pb.AuthTokenGetResponse_builder{Token: mockJWT}.Build(), nil","+}","+","+func TestGetEnvironmentLocalConfig(t *testing.T) {","+\tg := NewWithT(t)","+\tctx := t.Context()","+","+\tt.Setenv(\"MODAL_PROFILE\", \"\")","+\t// Unset `MODAL_IMAGE_BUILDER_VERSION` so that this test uses the image builder version from `EnvironmentGetOrCreate`.","+\tt.Setenv(\"MODAL_IMAGE_BUILDER_VERSION\", \"\")","+","+\tmockClient := &mockEnvironmentClient{}","+\tmockClient.Envs.Store(\"\", pb.EnvironmentGetOrCreateResponse_builder{","+\t\tEnvironmentId: \"en-custom-id\",","+\t\tMetadata: pb.EnvironmentMetadata_builder{","+\t\t\tSettings: pb.EnvironmentSettings_builder{","+\t\t\t\tImageBuilderVersion: \"2024.10\",","+\t\t\t}.Build(),","+\t\t}.Build()}.Build())","+","+\tclient, err := NewClientWithOptions(&ClientParams{","+\t\tControlPlaneClient: mockClient,","+\t\tConfig: &config{","+\t\t\t\"default\": rawProfile{","+\t\t\t\tImageBuilderVersion: \"2024.04\",","+\t\t\t\tActive:              true,","+\t\t\t},","+\t\t},","+\t})","+\tg.Expect(err).ShouldNot(HaveOccurred())","+\tdefer client.Close()","+","+\tversion, err := client.getImageBuilderVersion(ctx, \"\")","+\tg.Expect(err).ShouldNot(HaveOccurred())","+\tg.Expect(version).Should(Equal(\"2024.04\"))","+\tg.Expect(int(mockClient.EnvironmentGetOrCreateCallCount.Load())).Should(Equal(0))","+}","+","+func TestGetEnvironment(t *testing.T) {","+\tg := NewWithT(t)","+\tctx := t.Context()","+","+\t// Unset `MODAL_IMAGE_BUILDER_VERSION` so that this test uses the image builder version from `EnvironmentGetOrCreate`.","+\tt.Setenv(\"MODAL_IMAGE_BUILDER_VERSION\", \"\")","+","+\tmockClient := &mockEnvironmentClient{}","+\tmockClient.Envs.Store(\"\", pb.EnvironmentGetOrCreateResponse_builder{","+\t\tEnvironmentId: \"en-main-123\",","+\t\tMetadata: pb.EnvironmentMetadata_builder{","+\t\t\tName: \"main\",","+\t\t\tSettings: pb.EnvironmentSettings_builder{","+\t\t\t\tImageBuilderVersion: \"2024.10\",","+\t\t\t\tWebhookSuffix:       \"modal.run\",","+\t\t\t}.Build(),","+\t\t}.Build()}.Build())","+","+\tmockClient.Envs.Store(\"dev\", pb.EnvironmentGetOrCreateResponse_builder{","+\t\tEnvironmentId: \"en-dev-321\",","+\t\tMetadata: pb.EnvironmentMetadata_builder{","+\t\t\tName: \"dev\",","+\t\t\tSettings: pb.EnvironmentSettings_builder{","+\t\t\t\tImageBuilderVersion: \"2025.06\",","+\t\t\t\tWebhookSuffix:       \"modal.dev.run\",","+\t\t\t}.Build(),","+\t\t}.Build(),","+\t}.Build())","+","+\tclient, err := NewClientWithOptions(&ClientParams{ControlPlaneClient: mockClient})","+\tg.Expect(err).ShouldNot(HaveOccurred())","+\tdefer client.Close()","+","+\tenv, err := client.environmentManager.fetchEnvironment(ctx, \"\")","+\tg.Expect(err).ShouldNot(HaveOccurred())","+\tg.Expect(env.ID).Should(Equal(\"en-main-123\"))","+\tg.Expect(env.Name).Should(Equal(\"main\"))","+\tg.Expect(env.Settings.ImageBuilderVersion).Should(Equal(\"2024.10\"))","+\tg.Expect(env.Settings.WebhookSuffix).Should(Equal(\"modal.run\"))","+\tg.Expect(int(mockClient.EnvironmentGetOrCreateCallCount.Load())).Should(Equal(1))","+","+\tversion, err := client.environmentManager.GetImageBuilderVersion(ctx, \"\")","+\tg.Expect(err).ShouldNot(HaveOccurred())","+\tg.Expect(version).Should(Equal(\"2024.10\"))","+\tg.Expect(int(mockClient.EnvironmentGetOrCreateCallCount.Load())).Should(Equal(1))","+","+\t// Used cached value","+\tenv2, err := client.environmentManager.fetchEnvironment(ctx, \"\")","+\tg.Expect(err).ShouldNot(HaveOccurred())","+\tg.Expect(env2).Should(BeIdenticalTo(env))","+\tg.Expect(int(mockClient.EnvironmentGetOrCreateCallCount.Load())).Should(Equal(1))","+","+\tversion, err = client.environmentManager.GetImageBuilderVersion(ctx, \"\")","+\tg.Expect(err).ShouldNot(HaveOccurred())","+\tg.Expect(version).Should(Equal(\"2024.10\"))","+\tg.Expect(int(mockClient.EnvironmentGetOrCreateCallCount.Load())).Should(Equal(1))","+","+\t// New fetch from the server","+\tenvDev, err := client.environmentManager.fetchEnvironment(ctx, \"dev\")","+\tg.Expect(err).ShouldNot(HaveOccurred())","+\tg.Expect(envDev.ID).Should(Equal(\"en-dev-321\"))","+\tg.Expect(envDev.Name).Should(Equal(\"dev\"))","+\tg.Expect(envDev.Settings.ImageBuilderVersion).Should(Equal(\"2025.06\"))","+\tg.Expect(envDev.Settings.WebhookSuffix).Should(Equal(\"modal.dev.run\"))","+\tg.Expect(int(mockClient.EnvironmentGetOrCreateCallCount.Load())).Should(Equal(2))","+","+\tversion, err = client.environmentManager.GetImageBuilderVersion(ctx, \"dev\")","+\tg.Expect(err).ShouldNot(HaveOccurred())","+\tg.Expect(version).Should(Equal(\"2025.06\"))","+\tg.Expect(int(mockClient.EnvironmentGetOrCreateCallCount.Load())).Should(Equal(2))","+","+}","+","+func TestGetImageBuilderVersionWithEnvironmentOverride(t *testing.T) {","+\tg := NewWithT(t)","+\tctx := t.Context()","+","+\tt.Setenv(\"MODAL_IMAGE_BUILDER_VERSION\", \"\")","+","+\tmockClient := &mockEnvironmentClient{}","+\tmockClient.Envs.Store(\"\", pb.EnvironmentGetOrCreateResponse_builder{","+\t\tEnvironmentId: \"en-main-123\",","+\t\tMetadata: pb.EnvironmentMetadata_builder{","+\t\t\tName: \"main\",","+\t\t\tSettings: pb.EnvironmentSettings_builder{","+\t\t\t\tImageBuilderVersion: \"2024.10\",","+\t\t\t}.Build(),","+\t\t}.Build(),","+\t}.Build())","+\tmockClient.Envs.Store(\"dev\", pb.EnvironmentGetOrCreateResponse_builder{","+\t\tEnvironmentId: \"en-dev-321\",","+\t\tMetadata: pb.EnvironmentMetadata_builder{","+\t\t\tName: \"dev\",","+\t\t\tSettings: pb.EnvironmentSettings_builder{","+\t\t\t\tImageBuilderVersion: \"2025.06\",","+\t\t\t}.Build(),","+\t\t}.Build(),","+\t}.Build())","+","+\tclient, err := NewClientWithOptions(&ClientParams{ControlPlaneClient: mockClient})","+\tg.Expect(err).ShouldNot(HaveOccurred())","+\tdefer client.Close()","+","+\t// App created with a per-call environment override, profile default is \"\".","+\tapp := &App{AppID: \"ap-123\", Name: \"my-app\", Environment: \"dev\"}","+","+\tversion, err := client.getImageBuilderVersion(ctx, app.Environment)","+\tg.Expect(err).ShouldNot(HaveOccurred())","+\tg.Expect(version).Should(Equal(\"2025.06\"))","+\tg.Expect(int(mockClient.EnvironmentGetOrCreateCallCount.Load())).Should(Equal(1))","+}"],"additions":192,"deletions":0,"truncated":false},{"path":"go/examples/image-building/main.go","lines":["@@ -22,7 +22,7 @@ func main() {"," \t}"," "," \tsecret, err := mc.Secrets.FromMap(ctx, 