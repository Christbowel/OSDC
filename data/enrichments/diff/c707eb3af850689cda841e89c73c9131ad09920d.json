"5\", md: \"6\" }}","+      focusVisibleRing=\"outside\"","+      transition=\"border-color 0.2s ease\"","+      _hover={{ borderColor: \"teal.emphasized\" }}","+    >","+      <Link href=\"/shipped\">","+        <Stack","+          direction={{ base: \"column\", md: \"row\" }}","+          justify=\"space-between\"","+          align={{ base: \"flex-start\", md: \"center\" }}","+          gap=\"4\"","+        >","+          <Stack gap=\"1.5\">","+            <Span","+              fontFamily={mono}","+              fontSize=\"xs\"","+              textTransform=\"uppercase\"","+              letterSpacing=\"wider\"","+              color=\"teal.fg\"","+            >","+              Chakra Shipped is live","+            </Span>","+            <Text textStyle={{ base: \"md\", md: \"lg\" }} fontWeight=\"medium\">","+              &ldquo;{story.quote}&rdquo;","+            </Text>","+            <Text fontSize=\"sm\" color=\"fg.muted\">","+              {story.person}, {story.role} at {story.product}","+            </Text>","+          </Stack>","+          <HStack","+            gap=\"2\"","+            fontFamily={mono}","+            fontSize=\"sm\"","+            color=\"teal.fg\"","+            flexShrink=\"0\"","+          >","+            <Span>Read the stories</Span>","+            <Span aria-hidden>&rarr;</Span>","+          </HStack>","+        </Stack>","+      </Link>","+    </Box>","+  )","+}","+"," export default function ShowcasePage() {","   return (","     <Box py=\"20\" width=\"full\">","       <Container>","-        <Stack gap={{ base: \"5\", md: \"10\" }} mb=\"20\">","+        <Stack gap={{ base: \"5\", md: \"10\" }} mb=\"12\">","           <Stack gap=\"5\" pr=\"4\" maxW=\"3xl\" px=\"1.5\">","             <Heading as=\"h1\" textStyle={{ base: \"4xl\", md: \"5xl\" }}>","               Showcase","             </Heading>","             <Subheading>Beautiful websites built with Chakra UI</Subheading>","           </Stack>","+","+          <ShippedCallout />","         </Stack>"," ","         <SimpleGrid columns={{ base: 1, md: 2, lg: 3 }} gap=\"6\">"],"additions":66,"deletions":1,"truncated":false},{"path":"apps/www/components/mdx-content.tsx","lines":["@@ -147,7 +147,7 @@ const useMDXComponent = (code: string) => {"," "," interface MDXProps {","   code: string","-  components?: Record<string, React.ComponentType>","+  components?: Record<string, React.ComponentType<any>>"," }"," "," export const MDXContent = (props: MDXProps) => {"],"additions":1,"deletions":1,"truncated":false},{"path":"apps/www/components/site/hero.section.tsx","lines":["@@ -147,9 +147,9 @@ export const HeroSection = () => (","     <Container>","       <Stack gap={{ base: \"5\", md: \"10\" }} mb=\"20\">","         <Announcement alignSelf=\"flex-start\" asChild>","-          <Link href=\"/docs/components/floating-panel\">","+          <Link href=\"/shipped\">","             <LuPartyPopper />","-            New: FloatingPanel","+            Chakra Shipped is live","             <HiArrowRight />","           </Link>","         </Announcement>"],"additions":2,"deletions":2,"truncated":false},{"path":"apps/www/content/shipped/tm-code.mdx","lines":["@@ -0,0 +1,47 @@","+---","+product: TM Code","+person: Célio Garcia","+role: CEO","+avatar: /shipped/celio-garcia.png","+logo: /shipped/tm-code-logo.svg","+category: IDE","+url: https://code.toquemedia.net","+quote: Go on, try Chakra and thank me later!","+description: How TM Code uses Chakra UI to build an agent first IDE.","+x: hackgarcia","+shippedAt: \"2026-07-16\"","+images:","+  - /shipped/tm-code-1.png","+  - /shipped/tm-code-2.png","+  - /shipped/tm-code-3.png","+  - /shipped/tm-code-4.png","+---","+","+## 👋🏽 A bit of context","+","+[TM Code](https://code.toquemedia.net) is an agent first IDE where I describe","+what I want built, and the agent writes the code, shows the diff, opens a live","+preview, and deploys the project.","+","+I'm Célio Garcia, the CEO and founder of TM Code. Before building TM code, I was","+familiar with mobile UI frameworks like Jetpack Compose and SwiftUI. I","+understood how those tools worked and the approach behind them, so finding the","+right UI library for my IDE was one of the first decisions I had to make.","+","+That search led me to Chakra UI.","+","+<QuoteCard","+  quote=\"It reminds me a lot of Jetpack Compose and SwiftUI, that's why I loved Chakra UI on day one.\"","+  image=\"/shipped/celio-garcia.png\"","+/>","+","+## 💙 Fav thing about Chakra UI","+","+With Chakra, I didn't need to spend time learning a new way of building","+interfaces. Instead, I could focus on the product itself. What Chakra let me do","+faster or better than I expected was simple: **\"Definitely user interfaces.\"**","+","+Chakra v3's theming was the early hurdle. The v3 release changed how themes are","+defined, but once I understood the new approach, Chakra carried the rest of the","+interface work through to launch at","+[code.toquemedia.net](https://code.toquemedia.net). Nothing else slowed me down."],"additions":47,"deletions":0,"truncated":false},{"path":"apps/www/content/shipped/tree-structured-planning.mdx","lines":["@@ -0,0 +1,116 @@","+---","+product: Tree-Structured Planning"],"additions":2,"deletions":0,"truncated":false}],"additions":953,"deletions":4,"truncated":true,"file_count":12},"error":null,"fetched_at":"2026-07-10T10:53:04.506325+00:00"}