{"id":"4e51025e3e18a59c6094652ad4e41213e1e8fc4a","axis":"silent","repo":"golang/go","sha":"4e51025e3e18a59c6094652ad4e41213e1e8fc4a","parsed":{"files":[{"path":"api/next/78888.txt","lines":["@@ -0,0 +1,8 @@","+pkg crypto/x509, const MLDSA = 5 #78888","+pkg crypto/x509, const MLDSA PublicKeyAlgorithm #78888","+pkg crypto/x509, const MLDSA44 = 17 #78888","+pkg crypto/x509, const MLDSA44 SignatureAlgorithm #78888","+pkg crypto/x509, const MLDSA65 = 18 #78888","+pkg crypto/x509, const MLDSA65 SignatureAlgorithm #78888","+pkg crypto/x509, const MLDSA87 = 19 #78888","+pkg crypto/x509, const MLDSA87 SignatureAlgorithm #78888"],"additions":8,"deletions":0,"truncated":false},{"path":"doc/next/6-stdlib/70-mldsa.md","lines":["@@ -1,6 +1,8 @@"," ### crypto/mldsa"," ","-<!-- https://go.dev/issue/77626 --->","+<!-- https://go.dev/issue/77626, https://go.dev/issue/78888 --->"," "," The new [crypto/mldsa] package implements the post-quantum ML-DSA signature"," scheme specified in FIPS 204.","+","+[crypto/x509] now supports ML-DSA private keys, public keys, and signatures."],"additions":3,"deletions":1,"truncated":false},{"path":"doc/next/6-stdlib/99-minor/crypto/x509/78888.md","lines":["@@ -0,0 +1 @@","+<!-- crypto/x509 ML-DSA support is documented in doc/next/6-stdlib/70-mldsa.md. -->"],"additions":1,"deletions":0,"truncated":false},{"path":"src/crypto/internal/cryptotest/fips140.go","lines":["@@ -8,6 +8,8 @@ import ("," \t\"crypto/internal/fips140\""," \t\"internal/testenv\""," \t\"regexp\"","+\t\"strconv\"","+\t\"strings\""," \t\"testing\""," )"," ","@@ -18,6 +20,35 @@ func MustSupportFIPS140(t *testing.T) {"," \t}"," }"," ","+// MustMinimumFIPS140ModuleVersion skips the test if compiled against a lower","+// minor version of the FIPS 140-3 module than min (such as \"v1.26.0\").","+func MustMinimumFIPS140ModuleVersion(t *testing.T, min string) {","+\tt.Helper()","+\tif fips140.Version() == \"latest\" {","+\t\treturn","+\t}","+\tif parseFIPS140MinorVersion(t, fips140.Version()) < parseFIPS140MinorVersion(t, min) {","+\t\tt.Skipf(\"test requires FIPS 140-3 module %s or later\", min)","+\t}","+}","+","+func parseFIPS140MinorVersion(t *testing.T, version string) int {","+\tt.Helper()","+\tv, ok := strings.CutPrefix(version, \"v1.\")","+\tif !ok {","+\t\tt.Fatalf(\"unexpected FIPS 140 version format: %q\", version)","+\t}","+\tv, _, ok = strings.Cut(v, \".\")","+\tif !ok {","+\t\tt.Fatalf(\"unexpected FIPS 140 version format: %q\", version)","+\t}","+\ti, err := strconv.Atoi(v)","+\tif err != nil {","+\t\tt.Fatalf(\"unexpected FIPS 140 version format %q: %v\", version, err)","+\t}","+\treturn i","+}","+"," func RerunWithFIPS140Enabled(t *testing.T) {"," \tt.Helper()"," \tMustSupportFIPS140(t)"],"additions":31,"deletions":0,"truncated":false},{"path":"src/crypto/x509/example_test.go","lines":["@@ -8,6 +8,7 @@ import ("," \t\"crypto/dsa\""," \t\"crypto/ecdsa\""," \t\"crypto/ed25519\"","+\t\"crypto/mldsa\""," \t\"crypto/rsa\""," \t\"crypto/x509\""," \t\"encoding/pem\"","@@ -131,7 +132,42 @@ AIU+2GKjyT3iMuzZxxFxPFMCAwEAAQ=="," \t\tfmt.Println(\"pub is of type ECDSA:\", pub)"," \tcase ed25519.PublicKey:"," \t\tfmt.Println(\"pub is of type Ed25519:\", pub)","+\tcase *mldsa.PublicKey:","+\t\tfmt.Println(\"pub is of type ML-DSA:\", pub)"," \tdefault:"," \t\tpanic(\"unknown type of public key\")"," \t}"," }","+","+func ExampleMarshalPKCS8PrivateKey_mlDSA() {","+\t// Generate an ML-DSA-44 key, marshal it to PKCS #8, and PEM-encode it.","+\t// ML-DSA private keys are encoded in their seed-only representation per","+\t// RFC 9881.","+\tpriv, err := mldsa.GenerateKey(mldsa.MLDSA44())","+\tif err != nil {","+\t\tpanic(err)","+\t}","+","+\tder, err := x509.MarshalPKCS8PrivateKey(priv)","+\tif err != nil {","+\t\tpanic(err)","+\t}","+","+\tpemBytes := pem.EncodeToMemory(&pem.Block{","+\t\tType:  \"PRIVATE KEY\",","+\t\tBytes: der,","+\t})","+","+\t// Round-trip the PEM-encoded key back into an *mldsa.PrivateKey.","+\tblock, _ := pem.Decode(pemBytes)","+\tif block == nil {","+\t\tpanic(\"failed to decode PEM block\")","+\t}","+\tparsed, err := x509.ParsePKCS8PrivateKey(block.Bytes)","+\tif err != nil {","+\t\tpanic(err)","+\t}","+\tif !parsed.(*mldsa.PrivateKey).Equal(priv) {","+\t\tpanic(\"round-tripped key does not match original\")","+\t}","+}"],"additions":36,"deletions":0,"truncated":false},{"path":"src/crypto/x509/parser.go","lines":["@@ -10,6 +10,7 @@ import ("," \t\"crypto/ecdh\""," \t\"crypto/ecdsa\""," \t\"crypto/ed25519\"","+\t\"crypto/mldsa\""," \t\"crypto/rsa\""," \t\"crypto/x509/pkix\""," \t\"encoding/asn1\"","@@ -362,6 +363,15 @@ func parsePublicKey(keyData *publicKeyInfo) (any, error) {"," \t\t\treturn nil, errors.New(\"x509: wrong Ed25519 public key size\")"," \t\t}"," \t\treturn ed25519.PublicKey(data), nil","+\tcase oid.Equal(oidPublicKeyMLDSA44), oid.Equal(oidPublicKeyMLDSA65), oid.Equal(oidPublicKeyMLDSA87):","+\t\tif len(params.FullBytes) != 0 {","+\t\t\treturn nil, errors.New(\"x509: ML-DSA key encoded with illegal parameters\")","+\t\t}","+\t\tparams, ok := mldsaParametersFromOID(oid)","+\t\tif !ok {","+\t\t\treturn nil, errors.New(\"x509: unsupported ML-DSA parameters\")","+\t\t}","+\t\treturn mldsa.NewPublicKey(params, data)"," \tcase oid.Equal(oidPublicKeyX25519):"," \t\t// RFC 8410, Section 3"," \t\t// > For all of the OIDs, the parameters MUST be absent."],"additions":10,"deletions":0,"truncated":false},{"path":"src/crypto/x509/parser_fips140v1.0_test.go","lines":["@@ -0,0 +1,73 @@","+// Copyright 2026 The Go Authors. All rights reserved.","+// Use of this source code is governed by a BSD-style","+// license that can be found in the LICENSE file.","+","+//go:build fips140v1.0","+","+package x509","+","+import \"testing\"","+","+// TestParseMLDSACertificateFIPS140v1_0 verifies that ML-DSA certificates can","+// still be parsed under the FIPS 140-3 module v1.0.0, which doesn't support","+// ML-DSA. The parsed certificate has PublicKeyAlgorithm set to","+// UnknownPublicKeyAlgorithm and a nil PublicKey, so callers can inspect the","+// rest of the certificate without erroring.","+func TestParseMLDSACertificateFIPS140v1_0(t *testing.T) {","+\tfor _, tt := range []struct {","+\t\tname string","+\t\tpem  string","+\t}{","+\t\t{\"ML-DSA-44\", rfc9881ExampleCertificateMLDSA44},","+\t\t{\"ML-DSA-65\", rfc9881ExampleCertificateMLDSA65},","+\t\t{\"ML-DSA-87\", rfc9881ExampleCertificateMLDSA87},","+\t} {","+\t\tt.Run(tt.name, func(t *testing.T) {","+\t\t\tcert, err := ParseCertificate(pemDecode(t, tt.pem))","+\t\t\tif err != nil {","+\t\t\t\tt.Fatalf(\"ParseCertificate failed: %v\", err)","+\t\t\t}","+\t\t\tif cert.PublicKeyAlgorithm != UnknownPublicKeyAlgorithm {","+\t\t\t\tt.Errorf(\"PublicKeyAlgorithm = %v, want UnknownPublicKeyAlgorithm\", cert.PublicKeyAlgorithm)","+\t\t\t}","+\t\t\tif cert.PublicKey != nil {","+\t\t\t\tt.Errorf(\"PublicKey = %v, want nil\", cert.PublicKey)","+\t\t\t}","+\t\t\t// The rest of the certificate should still be inspectable.","+\t\t\tif cert.Subject.CommonName == \"\" {","+\t\t\t\tt.Error(\"Subject.CommonName is empty; expected the certificate to be parsed\")","+\t\t\t}","+\t\t})","+\t}","+}","+","+// TestMLDSAUnavailableErrorsNotPanics asserts that the public x509 entry","+// points return errors (rather than panicking) when ML-DSA is unavailable.","+// The mldsa package documents that \"methods are unreachable\" on v1.0.0; this","+// test ensures x509 callers stay on the error path.","+func TestMLDSAUnavailableErrorsNotPanics(t *testing.T) {","+\t// ParsePKIXPublicKey: extracts the raw SPKI from a parsed cert and parses","+\t// the public key directly. Should return an error, not panic.","+\tcert, err := ParseCertificate(pemDecode(t, rfc9881ExampleCertificateMLDSA44))","+\tif err != nil {","+\t\tt.Fatalf(\"ParseCertificate failed: %v\", err)","+\t}","+\tif _, err := ParsePKIXPublicKey(cert.RawSubjectPublicKeyInfo); err == nil {","+\t\tt.Error(\"ParsePKIXPublicKey: expected error, got nil\")","+\t}","+\t// ParsePKCS8PrivateKey: ML-DSA seed-only private keys.","+\tfor _, tt := range []struct {","+\t\tname string","+\t\tpem  string","+\t}{","+\t\t{\"ML-DSA-44\", rfc9881ExamplePrivateKeyMLDSA44},","+\t\t{\"ML-DSA-65\", rfc9881ExamplePrivateKeyMLDSA65},","+\t\t{\"ML-DSA-87\", rfc9881ExamplePrivateKeyMLDSA87},","+\t} {","+\t\tt.Run(tt.name, func(t *testing.T) {","+\t\t\tif _, err := ParsePKCS8PrivateKey(pemDecode(t, tt.pem)); err == nil {","+\t\t\t\tt.Error(\"ParsePKCS8PrivateKey: expected error, got nil\")","+\t\t\t}","+\t\t})","+\t}","+}"],"additions":73,"deletions":0,"truncated":false},{"path":"src/crypto/x509/pkcs8.go","lines":["@@ -8,6 +8,7 @@ import ("," \t\"crypto/ecdh\""," \t\"crypto/ecdsa\""," \t\"crypto/ed25519\"","+\t\"crypto/mldsa\""," \t\"crypto/rsa\""," \t\"crypto/x509/pkix\""," \t\"encoding/asn1\"","@@ -28,8 +29,8 @@ type pkcs8 struct {"," // ParsePKCS8PrivateKey parses an unencrypted private key in PKCS #8, ASN.1 DER form."," //"," // It returns a *[rsa.PrivateKey], an *[ecdsa.PrivateKey], an [ed25519.PrivateKey] (not","-// a pointer), or an *[ecdh.PrivateKey] (for X25519). More types might be supported","-// in the future.","+// a pointer), a *[mldsa.PrivateKey], or an *[ecdh.PrivateKey] (for X25519).","+// More types might be supported in the future."," //"," // This kind of key is commonly encoded in PEM blocks of type \"PRIVATE KEY\"."," //","@@ -79,6 +80,36 @@ func ParsePKCS8PrivateKey(der []byte) (key any, err error) {"," \t\t}"," \t\treturn ed25519.NewKeyFromSeed(curvePrivateKey), nil"," ","+\tcase privKey.Algo.Algorithm.Equal(oidPublicKeyMLDSA44),","+\t\tprivKey.Algo.Algorithm.Equal(oidPublicKeyMLDSA65),","+\t\tprivKey.Algo.Algorithm.Equal(oidPublicKeyMLDSA87):","+\t\tif l := len(privKey.Algo.Parameters.FullBytes); l != 0 {","+\t\t\treturn nil, errors.New(\"x509: invalid ML-DSA private key parameters\")","+\t\t}","+\t\tif l := len(privKey.PrivateKey); l == 0 {","+\t\t\treturn nil, fmt.Errorf(\"x509: invalid ML-DSA private key length: %d\", l)","+\t\t}","+\t\tswitch privKey.PrivateKey[0] {","+\t\tcase 0x80: // IMPLICIT [0] OCTET STRING (seed)","+\t\tcase 0x04: // OCTET STRING (expandedKey)","+\t\t\treturn nil, errors.New(\"x509: semi-expanded ML-DSA private keys without seed are not supported\")","+\t\tcase 0x30: // SEQUENCE (both)","+\t\t\treturn nil, errors.New(`x509: ML-DSA private keys with both seed and expanded key are not supported, use e.g. \"openssl pkey -provparam ml-dsa.output_formats=seed-only\" to convert to a seed-only key`)","+\t\tdefault:","+\t\t\treturn nil, fmt.Errorf(\"x509: invalid ML-DSA private key: invalid ASN.1 tag %02x\", privKey.PrivateKey[0])","+\t\t}","+\t\tif l := len(privKey.PrivateKey); l != 2+mldsa.PrivateKeySize {","+\t\t\treturn nil, fmt.Errorf(\"x509: invalid ML-DSA private key length: %d\", l)","+\t\t}","+\t\tif privKey.PrivateKey[1] != mldsa.PrivateKeySize {","+\t\t\treturn nil, fmt.Errorf(\"x509: invalid ML-DSA private key ASN.1 encoding\")","+\t\t}","+\t\tparams, ok := mldsaParametersFromOID(privKey.Algo.Algorithm)","+\t\tif !ok {","+\t\t\treturn nil, errors.New(\"x509: unknown ML-DSA parameters\")","+\t\t}","+\t\treturn mldsa.NewPrivateKey(params, privKey.PrivateKey[2:])","+"," \tcase privKey.Algo.Algorithm.Equal(oidPublicKeyX25519):"," \t\tif l := len(privKey.Algo.Parameters.FullBytes); l != 0 {"," \t\t\treturn nil, errors.New(\"x509: invalid X25519 private key parameters\")","@@ -97,8 +128,8 @@ func ParsePKCS8PrivateKey(der []byte) (key any, err error) {"," // MarshalPKCS8PrivateKey converts a private key to PKCS #8, ASN.1 DER form."," //"," // The following key types are currently supported: *[rsa.PrivateKey],","-// *[ecdsa.PrivateKey], [ed25519.PrivateKey] (not a pointer), and *[ecdh.PrivateKey].","-// Unsupported key types result in an error.","+// *[ecdsa.PrivateKey], [ed25519.PrivateKey] (not a pointer), *[mldsa.PrivateKey],","+// and *[ecdh.PrivateKey]. Unsupported key types result in an error."," //"," // This kind of key is commonly encoded in PEM blocks of type \"PRIVATE KEY\"."," //","