lags: func(fs *pflag.FlagSet) {","+\t\t\t\tfs.StringP(\"output\", \"o\", \"table\", \"Format to write in (table, json)\")","+\t\t\t\tfs.BoolP(\"diff\", \"d\", false, \"Display the difference from the existing policy map.\")","+\t\t\t\tfs.StringP(\"endpoint\", \"e\", \"\", \"Endpoint, either numeric ID or <namespace/name>, to stage this policy\")","+\t\t\t\tfs.StringSliceP(\"filename\", \"f\", nil, \"YAML or JSON policy resource to stage\")","+\t\t\t},","+\t\t\tAutocompleteFlag: func(state *script.State, _ []string, flag, cur string) []string {","+\t\t\t\tswitch flag {","+\t\t\t\tcase \"o\", \"output\":","+\t\t\t\t\treturn filterPrefix([]string{\"table\", \"json\"}, cur)","+\t\t\t\tcase \"e\", \"endpoint\":","+\t\t\t\t\treturn autocompleteEndpointsImpl(params, cur)","+\t\t\t\tcase \"f\", \"filename\":","+\t\t\t\t\treturn autocompleteFilenameImpl(state, cur)","+\t\t\t\t}","+\t\t\t\treturn nil","+\t\t\t},","+\t\t\tDetail: []string{","+\t\t\t\t\"Display the resulting mapstate for applying a given poliy to an endpoint.\",","+\t\t\t\t\"All existing policies are preserved unless overwritten by the proposed policy.\",","+\t\t\t\t\"Optionally, will display the difference between the existing policy.\",","+\t\t\t},","+\t\t},","+\t\tfunc(state *script.State, args ...string) (script.WaitFunc, error) {","+\t\t\treturn func(state *script.State) (stdout, stderr string, err error) {","+\t\t\t\tformat, err := state.Flags.GetString(\"output\")","+\t\t\t\tif err != nil {","+\t\t\t\t\treturn \"\", \"\", err","+\t\t\t\t}","+\t\t\t\tif format != \"json\" && format != \"table\" {","+\t\t\t\t\treturn \"\", \"\", fmt.Errorf(\"unsupported output format %s\", format)","+\t\t\t\t}","+","+\t\t\t\tdiff, err := state.Flags.GetBool(\"diff\")","+\t\t\t\tif err != nil {","+\t\t\t\t\treturn \"\", \"\", err","+\t\t\t\t}","+","+\t\t\t\tcmd, err := newStageCmd(params, state)","+\t\t\t\tif err != nil {","+\t\t\t\t\treturn \"\", \"\", err","+\t\t\t\t}","+","+\t\t\t\tif len(cmd.toAddPaths) == 0 && diff {","+\t\t\t\t\treturn \"\", \"\", fmt.Errorf(\"--filename is required\")","+\t\t\t\t}","+","+\t\t\t\tvar entriesBefore, entriesAfter map[policytypes.Key]entryOut","+\t\t\t\tif diff {","+\t\t\t\t\tentriesBefore, err = cmd.getEPEntries()","+\t\t\t\t\tif err != nil {","+\t\t\t\t\t\treturn \"\", \"\", fmt.Errorf(\"failed to get existing policy map for endpoint: %w\", err)","+\t\t\t\t\t}","+\t\t\t\t}","+","+\t\t\t\t// apply policy","+\t\t\t\terr = cmd.applyPolicies()","+\t\t\t\tif err != nil {","+\t\t\t\t\treturn \"\", \"\", fmt.Errorf(\"failed to apply new policy: %w\", err)","+\t\t\t\t}","+","+\t\t\t\tentriesAfter, err = cmd.getEPEntries()","+\t\t\t\tif err != nil {","+\t\t\t\t\treturn \"\", \"\", fmt.Errorf(\"failed to compute endpoint's policy map: %w\", err)","+\t\t\t\t}","+","+\t\t\t\tif len(entriesAfter) > params.PMFactory.PolicyMaxEntries() {","+\t\t\t\t\tcmd.log.Warn(\"Endpoint BPF policy map will overflow!\",","+\t\t\t\t\t\tlogfields.Limit, params.PMFactory.PolicyMaxEntries(),","+\t\t\t\t\t\tlogfields.Size, len(entriesAfter),","+\t\t\t\t\t)","+\t\t\t\t}","+","+\t\t\t\tres := toResult(entriesBefore, entriesAfter)","+","+\t\t\t\t// generate json output","+\t\t\t\tif format == \"json\" {","+\t\t\t\t\tb, err := json.MarshalIndent(&res, \"\", \"\\t\")","+\t\t\t\t\tif err != nil {","+\t\t\t\t\t\treturn \"\", \"\", fmt.Errorf(\"json marshal failed: %w\", err)","+\t\t\t\t\t}","+\t\t\t\t\treturn string(b), \"\", nil","+\t\t\t\t}","+","+\t\t\t\t// Output table","+\t\t\t\tbuf := &strings.Builder{}","+\t\t\t\ttw := tabwriter.NewWriter(buf, 5, 0, 3, ' ', 0)","+\t\t\t\tfmt.Fprintf(tw, \" \\tDirection\\tIdentity\\tProto+Port\\tPriority\\tListenerPrio\\tVerdict\\tProxied\\tOrigins\\n\")","+\t\t\t\tif diff {","+\t\t\t\t\tfor _, row := range res.Diff {","+\t\t\t\t\t\tif row.Deleted != nil {","+\t\t\t\t\t\t\tprintDiffRow(tw, cmd.ids, '-', *row.Deleted)","+\t\t\t\t\t\t}","+\t\t\t\t\t\tif row.Added != nil {","+\t\t\t\t\t\t\tprintDiffRow(tw, cmd.ids, '+', *row.Added)","+\t\t\t\t\t\t}","+\t\t\t\t\t}","+\t\t\t\t} else {","+\t\t\t\t\tfor _, row := range res.MapState {","+\t\t\t\t\t\tprintDiffRow(tw, cmd.ids, ' ', row)","+\t\t\t\t\t}","+\t\t\t\t}","+\t\t\t\ttw.Flush()","+\t\t\t\treturn buf.String(), \"\", nil","+\t\t\t}, nil","+\t\t},","+\t)","+}","+","+type stageCmd struct {","+\tparams CmdParams","+","+\tlog *slog.Logger","+\tpr  *policy.Repository","+\tids identity.IdentityMap","+","+\ttoAddPaths []string","+","+\tep   *endpoint.Endpoint","+\tepID *identity.Identity","+}","+","+type result struct {","+\tMapState []entryOut  `json:\"mapState\"`","+\tDiff     []diffEntry `json:\"diff\"`","+}","+","+type diffEntry struct {","+\tDeleted *entryOut `json:\"deleted,omitempty\"`","+\tAdded   *entryOut `json:\"added,omitempty\"`","+}","+","+func newStageCmd(params CmdParams, state *script.State) (*stageCmd, error) {","+\ts := &stageCmd{","+\t\tparams: params,","+\t\tlog:    slog.New(slog.NewTextHandler(state.LogWriter(), nil)),","+\t}","+","+\tvar err error","+\ts.toAddPaths, err = state.Flags.GetStringSlice(\"filename\")","+\tif err != nil {","+\t\treturn nil, err","+\t}","+","+\tepSpec, _ := state.Flags.GetString(\"endpoint\")","+\tif epSpec == \"\" {","+\t\treturn nil, fmt.Errorf(\"endpoint is required\")","+\t}","+","+\teps, _ := lookupEPs(params.EPL, []string{epSpec})","+\tif len(eps) != 1 {","+\t\treturn nil, fmt.Errorf(\"endpoint not found!\")","+\t}","+\ts.ep = eps[0]","+\ts.epID, err = s.ep.GetSecurityIdentity()","+\tif err != nil {","+\t\treturn nil, err","+\t}","+","+\tpr := params.Repository.(*policy.Repository)","+\tif pr == nil {","+\t\treturn nil, fmt.Errorf(\"BUG: could not cast policy repository\")","+\t}","+\t// Take a snapshot of the repository so we can make changes","+\ts.pr, s.ids = pr.Snapshot(s.log,","+\t\t&mockCertificateManager{},","+\t\tenvoypolicy.NewEnvoyL7RulesTranslator(s.log, certificatemanager.NewMockSecretManagerSDS()))","+","+\t// add this endpoint to the subject selector cache","+\twg := sync.WaitGroup{}","+\ts.pr.GetSubjectSelectorCache().UpdateIdentities(identity.IdentityMap{s.epID.ID: s.epID.LabelArray}, nil, &wg)","+\twg.Wait()","+","+\treturn s, nil","+}","+","+// applyPolicy applies the given policy to the repository","+func (s *stageCmd) applyPolicies() error {","+\tfor _, path := range s.toAddPaths {","+\t\t// Parse policy file, then apply to repository.","+\t\tfp, err := os.Open(path)","+\t\tif err != nil {","+\t\t\treturn fmt.Errorf(\"failed to open file %s: %w\", path, err)","+\t\t}","+","+\t\tdecoder := yaml.NewYAMLOrJSONDecoder(fp, 4096)","+\t\tapplied := false","+\t\tfor {","+\t\t\tu := unstructured.Unstructured{}","+\t\t\tif err := decoder.Decode(&u); err != nil {","+\t\t\t\tif errors.Is(err, io.EOF) {","+\t\t\t\t\tbreak","+\t\t\t\t}","+\t\t\t\treturn fmt.Errorf(\"failed to parse policy: %w\", err)","+\t\t\t}","+\t\t\tif err := s.applyPolicy(&u); err != nil {","+\t\t\t\treturn err","+\t\t\t}","+\t\t\tapplied = true","+\t\t}","+","+\t\tif !applied {","+\t\t\treturn fmt.Errorf(\"policy file %s was empty\", path)","+\t\t}","+\t}","+\treturn nil","+}","+","+type makeEntriesFunc func(s *stageCmd, obj *unstructured.Unstructured) (policytypes.PolicyEntries, ipcacheTypes.ResourceKind, error)","+","+var makeEntriesFuncs = map[schema.GroupKind]makeEntriesFunc{","+\t{Group: \"cilium.io\", Kind: ciliumv2.CNPKindDefinition}:  makeCNPEntries,","+\t{Group: \"cilium.io\", Kind: ciliumv2.CCNPKindDefinition}: makeCNPEntries,","+\t{Group: \"networking.k8s.io\", Kind: \"NetworkPolicy\"}:     makeKNPEntries,","+}","+","+// applyPolicy inserts the policy in to the repository","+func (s *stageCmd) applyPolicy(obj *unstructured.Unstructured) error {","+\t// Sometimes we get an empty object -- ignore","+\tif obj.GetKind() == \"\" {","+\t\treturn nil","+\t}","+","+\tpolicyDescription := fmt.Sprintf(\"%s %s/%s\", obj.GroupVersionKind().Kind, obj.GetNamespace(), obj.GetName())","+","+\ttoEntriesFunc, ok := makeEntriesFuncs[obj.GroupVersionKind().GroupKind()]","+\tif !ok {","+\t\ts.log.Warn(\"Non-policy type in yaml, ignoring\", logfields.PolicyID, policyDescription)","+\t\treturn nil","+\t}","+","+\tentries, resourceKind, err := toEntriesFunc(s, obj)","+\tif err != nil {","+\t\treturn fmt.Errorf(\"could not parse policy %s: %w\", policyDescription, err)","+\t}","+","+\t// allocate CIDR identities","+\ts.ensureCIDRIdentities(entries)","+","+\t// Insert in to policy repository","+\tresourceID := ipcacheTypes.NewResourceID(","+\t\tresourceKind,","+\t\tobj.GetNamespace(),","+\t\tobj.GetName(),","+\t)","+\tids, _, _ := s.pr.ReplaceByResource(entries, resourceID)","+\tif !ids.Has(s.ep.GetIdentity()) {","+\t\ts.log.Warn(\"Supplied policy does not select endpoint!\", logfields.PolicyID, policyDescription)","+\t}","+\ts.log.Info(\"Successfully applied policy\", logfields.PolicyID, policyDescription)","+","+\treturn nil","+}","+","+func makeCNPEntries(s *stageCmd, obj *unstructured.Unstructured) (policytypes.PolicyEntries, ipcacheTypes.ResourceKind, error) {","+\tclusterName := cmtypes.LocalClusterNameForPolicies(s.params.ClusterMeshPolicyConfig, s.params.Config.ClusterName)","+\t// parse to CNP","+\tcnp := ciliumv2.CiliumNetworkPolicy{}","+\tif err := convertInto(obj, &cnp); err != nil {","+\t\treturn nil, \"\", err","+\t}","+\tresourceKind := ipcacheTypes.ResourceKindCNP","+\tif obj.GroupVersionKind().Kind == \"CiliumClusterwideNetworkPolicy\" {","+\t\tresourceKind = ipcacheTypes.ResourceKindCCNP","+\t} else if cnp.Namespace == \"\" {","+\t\tcnp.Namespace = s.ep.GetK8sNamespace()","+\t}","+","+\t// Translate ToServices","+\tpolicyk8s.ResolveToServices(s.params.DB.ReadTxn(), s.params.Services, s.params.Backends, &cnp)","+\trules, err := cnp.Parse(s.log, clusterName)","+\tif err != nil {","+\t\treturn nil, \"\", err","+\t}","+\tentries := policyutils.RulesToPolicyEntries(rules)","+\treturn entries, resourceKind, nil","+}","+","+func makeKNPEntries(s *stageCmd, obj *unstructured.Unstructured) (policytypes.PolicyEntries, ipcacheTypes.ResourceKind, error) {","+\tclusterName := cmtypes.LocalClusterNameForPolicies(s.params.ClusterMeshPolicyConfig, s.params.Config.ClusterName)","+\tknp := slim_networkingv1.NetworkPolicy{}","+\tif err := convertInto(obj, &knp); err != nil {","+\t\treturn nil, \"\", err","+\t}","+\tif knp.Namespace == \"\" {","+\t\tknp.Namespace = s.ep.GetK8sNamespace()","+\t}","+","+\tentries, err := k8s.ParseNetworkPolicy(s.log, clusterName, &knp)","+\tif err != nil {","+\t\treturn nil, \"\", err","+\t}","+\treturn entries, ipcacheTypes.ResourceKindNetpol, nil","+}","+","+// getExistingEntries evaluates the policy state as-is for the given endpoint,","+func (s *stageCmd) getEPEntries() (map[policytypes.Key]entryOut, error) {","+\tsp, err := s.pr.ResolvePolicy(s.epID)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+","+\towner := &dummyPolicyOwner{","+\t\tlog: s.log,","+\t\tep:  s.ep,","+\t}","+\tepp := sp.DistillPolicy(s.log, owner, dummyRedirects)","+\tepp.Ready()","+\tepp.Detach(s.log)","+\tsp.Detach()","+","+\tout := make(map[policytypes.Key]entryOut, epp.Len())","+\tfor key, entry := range epp.Entries() {","+\t\tentry.Cookie = 0 // don't want to compare cookie","+\t\tmeta, _ := epp.GetRuleMeta(key)","+\t\tout[key] = makeEntry(key, entry, meta)","+\t}","+","+\treturn out, nil","+}","+","+// ensureCIDRIdentities emulates allocating identities for CIDR selectors.","+//","+// It just tweaks the SelectorCache, it doesn't actually allocate any identities.","+//","+// Horribly slow, but this is for interactive use, so it should be OK","+func (s *stageCmd) ensureCIDRIdentities(e policytypes.PolicyEntries) {","+\tprefixes := policy.GetCIDRPrefixes(e)","+","+\ttoAllocate := identity.IdentityMap{}","+","+\t// For every prefix, see if the IDMap already has an identity with exactly","+\t// this CIDR","+prefixLoop:","+\tfor _, prefix := range prefixes {","+\t\tlbls := labels.GetCIDRLabelArray(prefix)","+\t\twantLabel := lbls[0]","+\t\tfor _, existingLabels := range s.ids {","+\t\t\tfor _, existingLbl := range existingL