tcase <-time.After(delay):","+\t\t\t}","+\t\t\tdelay *= 2","+\t\t}","+\t}","+\treturn zero, lastErr","+}","+","+func blobUpload(ctx context.Context, client pb.ModalClientClient, logger *slog.Logger, data []byte) (string, error) {","+\tmd5sum := md5.Sum(data)","+\tsha256sum := sha256.Sum256(data)","+\tcontentMd5 := base64.StdEncoding.EncodeToString(md5sum[:])","+\tcontentSha256 := base64.StdEncoding.EncodeToString(sha256sum[:])","+","+\tresp, err := client.BlobCreate(ctx, pb.BlobCreateRequest_builder{","+\t\tContentMd5:          contentMd5,","+\t\tContentSha256Base64: contentSha256,","+\t\tContentLength:       int64(len(data)),","+\t}.Build())","+\tif err != nil {","+\t\treturn \"\", fmt.Errorf(\"failed to create blob: %w\", err)","+\t}","+","+\tswitch resp.WhichUploadTypeOneof() {","+\tcase pb.BlobCreateResponse_Multipart_case:","+\t\treturn \"\", fmt.Errorf(\"Function input size exceeds multipart upload threshold, unsupported by this SDK version\")","+","+\tcase pb.BlobCreateResponse_UploadUrl_case:","+\t\treturn retryHTTPRequest(ctx, logger, \"blob upload\", blobUploadRetryAttempts, blobUploadRetryDelay, func() (string, error) {","+\t\t\treq, err := http.NewRequestWithContext(ctx, \"PUT\", resp.GetUploadUrl(), bytes.NewReader(data))","+\t\t\tif err != nil {","+\t\t\t\treturn \"\", fmt.Errorf(\"failed to create upload request: %w\", err)","+\t\t\t}","+\t\t\treq.Header.Set(\"Content-Type\", \"application/octet-stream\")","+\t\t\treq.Header.Set(\"Content-MD5\", contentMd5)","+\t\t\tuploadResp, err := http.DefaultClient.Do(req)","+\t\t\tif err != nil {","+\t\t\t\treturn \"\", fmt.Errorf(\"failed to upload blob: %w\", err)","+\t\t\t}","+\t\t\tdefer func() {","+\t\t\t\tif err := uploadResp.Body.Close(); err != nil {","+\t\t\t\t\tlogger.DebugContext(ctx, \"failed to close upload response body\", \"error\", err.Error())","+\t\t\t\t}","+\t\t\t}()","+\t\t\tif uploadResp.StatusCode < 200 || uploadResp.StatusCode >= 300 {","+\t\t\t\treturn \"\", fmt.Errorf(\"failed blob uploa