uble2 double3 double4","+syn keyword hipType\t\tdim3 texture textureReference","+syn keyword hipType\t\thipError_t hipDeviceProp hipMemcpyKind","+syn keyword hipType\t\thipArray hipChannelFormatKind","+syn keyword hipType\t\thipChannelFormatDesc hipTextureAddressMode","+syn keyword hipType\t\thipTextureFilterMode hipTextureReadMode","+syn keyword hipVariable\t\tgridDim blockIdx blockDim threadIdx warpSize","+syn keyword hipConstant\t\t__HIP_ARCH__","+syn keyword hipConstant\t\t__DEVICE_EMULATION__","+\" There are too many HIP enumeration constants. We only define a subset of commonly used constants.","+\" Reference: https://docs.amd.com/en/latest/develop-perf-tips/hip-programming-guide/","+syn keyword hipConstant\t\thipSuccess","+","+hi def link hipStorageClass\tStorageClass","+hi def link hipType\t\tType","+hi def link hipVariable\t\tIdentifier","+hi def link hipConstant\t\tConstant","+","+let b:current_syntax = \"hip\"","+","+\" vim: ts=8"],"additions":52,"deletions":0,"truncated":false},{"path":"test/old/testdir/test_filetype.vim","lines":["@@ -377,6 +377,7 @@ func s:GetFilenameChecks() abort","     \\ 'hercules': ['file.vc', 'file.ev', 'file.sum', 'file.errsum'],","     \\ 'hex': ['file.hex', 'file.ihex', 'file.ihe', 'file.ihx', 'file.int', 'file.mcs', 'file.h32', 'file.h80', 'file.h86', 'file.a43', 'file.a90'],","     \\ 'hgcommit': ['hg-editor-file.txt'],","+    \\ 'hip': ['file.hip'],","     \\ 'hjson': ['file.hjson'],","     \\ 'hlsplaylist': ['file.m3u', 'file.m3u8'],","     \\ 'hog': ['file.hog', 'snort.conf', 'vision.conf'],",""],"additions":1,"deletions":0,"truncated":false}],"additions":82,"deletions":0,"truncated":false,"file_count":7},"error":null,"fetched_at":"2026-07-19T10:07:05.857001+00:00"}