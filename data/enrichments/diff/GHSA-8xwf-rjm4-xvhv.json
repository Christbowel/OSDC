k","+\t\t// to outside/secret.txt, escaping workingDir.","+\t\t_, err = s.resolveWritePath(\"out/secret.txt\")","+\t\tif !errors.Is(err, ErrPathTraversalDisallowed) {","+\t\t\tt.Errorf(\"resolveWritePath() error = %v, want %v\", err, ErrPathTraversalDisallowed)","+\t\t}","+\t})","+","+\tt.Run(\"regular subdirectory write within workingDir still works\", func(t *testing.T) {","+\t\ttempDir := t.TempDir()","+\t\tworkingDir := filepath.Join(tempDir, \"store\")","+\t\tsubDir := filepath.Join(workingDir, \"sub\")","+\t\tif err := os.MkdirAll(subDir, 0755); err != nil {","+\t\t\tt.Fatal(err)","+\t\t}","+","+\t\ts, err := New(workingDir)","+\t\tif err != nil {","+\t\t\tt.Fatal(err)","+\t\t}","+\t\tdefer s.Close()","+","+\t\tgot, err := s.resolveWritePath(\"sub/file.txt\")","+\t\tif err != nil {","+\t\t\tt.Fatalf(\"resolveWritePath() unexpected error: %v\", err)","+\t\t}","+\t\tif want := filepath.Join(workingDir, \"sub/file.txt\"); got != want {","+\t\t\tt.Errorf(\"resolveWritePath() = %v, want %v\", got, want)","+\t\t}","+\t})","+}","+"," func TestStore_resolveWritePath_Overwrite(t *testing.T) {"," \tt.Run(\"Target file already exists\", func(t *testing.T) {"," \t\ttempDir := t.TempDir()",""],"additions":57,"deletions":0,"truncated":false}],"additions":113,"deletions":0,"truncated":false,"file_count":2},"error":null,"fetched_at":"2026-07-02T10:21:03.875855+00:00"}