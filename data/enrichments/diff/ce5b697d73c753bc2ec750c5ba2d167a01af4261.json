{"id":"ce5b697d73c753bc2ec750c5ba2d167a01af4261","axis":"silent","repo":"envoyproxy/envoy","sha":"ce5b697d73c753bc2ec750c5ba2d167a01af4261","parsed":{"files":[{"path":"changelogs/current/new_features/quic__added-support-for-tls-key-log.rst","lines":["@@ -0,0 +1,5 @@","+Added support for TLS key logging in QUIC via :ref:`key_log <envoy_v3_api_field_extensions.transport_sockets.tls.v3.CommonTlsContext.key_log>`,","+applying the same local/remote IP-list filtering as TCP TLS key log. When ``key_log`` is configured","+and runtime guard ``envoy.restart_features.quic_keylog_support`` is enabled, Envoy writes NSS key log","+lines for QUIC connections so captured QUIC traffic can be decrypted for debugging. The runtime guard","+defaults to ``false``."],"additions":5,"deletions":0,"truncated":false},{"path":"source/common/quic/BUILD","lines":["@@ -127,6 +127,7 @@ envoy_cc_library(","     hdrs = envoy_select_enable_http3([\"envoy_tls_server_handshaker.h\"]),","     external_deps = [\"ssl\"],","     deps = envoy_select_enable_http3([","+        \":envoy_quic_server_session_lib\",","         \"//source/common/common:assert_lib\",","         \"//source/common/common:macros\",","         \"//source/common/tls:server_context_lib\",","@@ -147,6 +148,7 @@ envoy_cc_library(","         \":quic_transport_socket_factory_lib\",","         \"//envoy/ssl:tls_certificate_config_interface\",","         \"//source/common/quic:quic_server_transport_socket_factory_lib\",","+        \"//source/common/runtime:runtime_features_lib\",","         \"//source/common/stream_info:stream_info_lib\",","         \"//source/server:listener_stats\",","         \"@quiche//:quic_core_crypto_certificate_view_lib\",","@@ -302,12 +304,12 @@ envoy_cc_library(","     ]),","     deps = envoy_select_enable_http3([","         \":envoy_quic_connection_debug_visitor_factory_interface\",","-        \":envoy_quic_proof_source_lib\",","         \":envoy_quic_server_connection_lib\",","         \":envoy_quic_server_crypto_s