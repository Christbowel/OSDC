{"id":"GHSA-7wvc-rvp7-w99x","axis":"advisories","repo":"go-gitea/gitea","sha":"42513398c05ca6bdf71da76cb6f9baaebe8cb924","parsed":{"files":[{"path":"cmd/serv.go","lines":["@@ -113,23 +113,25 @@ func handleCliResponseExtra(extra private.ResponseExtra) error {"," \treturn nil"," }"," ","-func getAccessMode(verb, lfsVerb string) perm.AccessMode {","+// getAccessMode maps an SSH git/LFS verb to the access mode it requires, with","+// ok=false for an unrecognised verb. Callers MUST reject the request when ok is","+// false: AccessModeNone would otherwise pass the `userMode < mode` permission","+// check in routers/private/serv.go and grant access.","+func getAccessMode(verb, lfsVerb string) (mode perm.AccessMode, ok bool) {"," \tswitch verb {"," \tcase git.CmdVerbUploadPack, git.CmdVerbUploadArchive:","-\t\treturn perm.AccessModeRead","+\t\treturn perm.AccessModeRead, true"," \tcase git.CmdVerbReceivePack:","-\t\treturn perm.AccessModeWrite","+\t\treturn perm.AccessModeWrite, true"," \tcase git.CmdVerbLfsAuthenticate, git.CmdVerbLfsTransfer:"," \t\tswitch lfsVerb {"," \t\tcase git.CmdSubVerbLfsUpload:","-\t\t\treturn perm.AccessModeWrite","+\t\t\treturn perm.AccessModeWrite, true"," \t\tcase git.CmdSubVerbLfsDownload:","-\t\t\treturn perm.AccessModeRead","+\t\t\treturn perm.AccessModeRead, true"," \t\t}"," \t}","-\t// should be unreachable","-\tsetting.PanicInDevOrTesting(\"unknown verb: %s %s\", verb, lfsVerb)","-\treturn perm.AccessModeNone","+\treturn perm.AccessModeNone, false"," }"," "," func runServ(ctx context.Context, c *cli.Command) error {","@@ -247,7 +249,10 @@ func runServ(ctx context.Context, c *cli.Command) error {"," \t\t}"," \t}"," ","-\trequestedMode := getAccessMode(verb, lfsVerb)","+\trequestedMode, ok := getAccessMode(verb, lfsVerb)","+\tif !ok {","+\t\treturn fail(ctx, \"Unknown git command\", \"Unknown git command %s %s\", verb, lfsVerb)","+\t}"," "," \tresults, extra := private.ServCommand(ctx, keyID, username, reponame, requestedMode, verb, lfsVerb)"," \tif extra.HasError() {"],"additions":14,"deletions":9,"truncated":false},{"path":"cmd/serv_test.go","lines":["@@ -0,0 +1,56 @@","+// Copyright 2026 The Gitea Authors. All rights reserved.","+// SPDX-License-Identifier: MIT","+","+package cmd","+","+import (","+\t\"testing\"","+","+\t\"gitea.dev/models/perm\"","+\t\"gitea.dev/modules/git\"","+","+\t\"github.com/stretchr/testify/assert\"","+)","+","+func TestGetAccessMode(t *testing.T) {","+\tcases := []struct {","+\t\tverb, lfsVerb string","+\t\texpected      perm.AccessMode","+\t}{","+\t\t{git.CmdVerbUploadPack, \"\", perm.AccessModeRead},","+\t\t{git.CmdVerbUploadArchive, \"\", perm.AccessModeRead},","+\t\t{git.CmdVerbReceivePack, \"\", perm.AccessModeWrite},","+\t\t{git.CmdVerbLfsAuthenticate, git.CmdSubVerbLfsUpload, perm.AccessModeWrite},","+\t\t{git.CmdVerbLfsAuthenticate, git.CmdSubVerbLfsDownload, perm.AccessModeRead},","+\t\t{git.CmdVerbLfsTransfer, git.CmdSubVerbLfsUpload, perm.AccessModeWrite},","+\t\t{git.CmdVerbLfsTransfer, git.CmdSubVerbLfsDownload, perm.AccessModeRead},","+\t}","+\tfor _, tc := range cases {","+\t\tt.Run(tc.verb+\"/\"+tc.lfsVerb, func(t *testing.T) {","+\t\t\tmode, ok := getAccessMode(tc.verb, tc.lfsVerb)","+\t\t\tassert.True(t, ok)","+\t\t\tassert.Equal(t, tc.expected, mode)","+\t\t})","+\t}","+}","+","+// TestGetAccessModeUnknownVerb locks in the invariant that getAccessMode reports","+// ok=false for unrecognised verbs and LFS sub-verbs, so runServ rejects them. An","+// unknown verb has no valid access mode; if it were treated as AccessModeNone (0)","+// it would pass the `userMode < mode` permission check in routers/private/serv.go","+// and hand out valid LFS JWTs for any private repository.","+func TestGetAccessModeUnknownVerb(t *testing.T) {","+\tcases := []struct{ verb, lfsVerb string }{","+\t\t{git.CmdVerbLfsAuthenticate, \"\"},","+\t\t{git.CmdVerbLfsAuthenticate, \"badverb\"},","+\t\t{git.CmdVerbLfsTransfer, \"badverb\"},","+\t\t{\"git-unknown-verb\", \"\"},","+\t}","+\tfor _, tc := range cases {","+\t\tt.Run(tc.verb+\"/\"+tc.lfsVerb, func(t *testing.T) {","+\t\t\tmode, ok := getAccessMode(tc.verb, tc.lfsVerb)","+\t\t\tassert.False(t, ok)","+\t\t\tassert.Equal(t, perm.AccessModeNone, mode)","+\t\t})","+\t}","+}",""],"additions":56,"deletions":0,"truncated":false}],"additions":70,"deletions":9,"truncated":false,"file_count":2},"error":null,"fetched_at":"2026-07-22T10:12:09.909338+00:00"}