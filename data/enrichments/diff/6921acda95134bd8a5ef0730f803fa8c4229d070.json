nstructured\"","+\t\"k8s.io/apimachinery/pkg/runtime\"","+\t\"k8s.io/apimachinery/pkg/runtime/schema\"","+)","+","+// ControllerOwnerKey is the shared operation-type key for encryption key rotation coordination.","+// Beacon ownership uses a per-operation key derived from the operation UID.","+const ControllerOwnerKey = \"encryption-key-rotation\"","+const beaconOwnerRefAnnotation = \"rke.cattle.io/operation-owner-ref\"","+","+// dynamicResolver is the subset of *dynamic.Controller this handler needs:","+// Get for resolving cluster refs and Enqueue for nudging the backing cluster","+// after terminal beacon transitions.","+type dynamicResolver interface {","+\tGet(gvk schema.GroupVersionKind, namespace, name string) (runtime.Object, error)","+\tEnqueue(gvk schema.GroupVersionKind, namespace, name string) error","+}","+","+type handler struct {","+\tencryptionkeyrotations operationcontrollers.EncryptionKeyRotationController","+","+\tbeacons     plancontrollers.BeaconClient","+\tbeaconCache plancontrollers.BeaconCache","+","+\tsecrets corecontrollers.SecretClient","+","+\tstore *plan.Store","+","+\tdynamic dynamicResolver","+","+\tclients *wrangler.CAPIContext","+}","+","+func Register(ctx context.Context, clients *wrangler.CAPIContext) {","+\th := &handler{","+\t\tencryptionkeyrotations: clients.Operation.EncryptionKeyRotation(),","+\t\tbeacons:                clients.Plan.Beacon(),","+\t\tbeaconCache:            clients.Plan.Beacon().Cache(),","+\t\tsecrets:                clients.Core.Secret(),","+\t\tdynamic:                clients.Dynamic,","+\t\tstore:                  plan.NewStore(clients.Core.Secret()),","+\t\tclients:                clients,","+\t}","+","+\toperationcontrollers.RegisterEncryptionKeyRotationStatusHandler(ctx, clients.Operation.EncryptionKeyRotation(), \"\", \"encryption-key-rotation-handler\", h.OnChange)","+}","+","+func (h *handler) OnChange(op *opv1alpha1.EncryptionKeyRotation, status opv1alpha1.EncryptionKeyRotationStatus) (opv1alpha1.EncryptionKeyRotationStatus, error) {","+\tif op == nil {","+\t\treturn status, nil","+\t}","+\tif op.DeletionTimestamp != nil {","+\t\treturn status, nil","+\t}","+\tif ops.IsPaused(&op.Spec.OperationSpec) {","+\t\tlogrus.Debugf(\"[encryptionkeyrotation] %s/%s: skipping paused operation\", op.Namespace, op.Name)","+\t\treturn status, nil","+\t}","+","+\tstatus, err := h.onChange(op, status)","+\tif err != nil {","+\t\treturn status, err","+\t}","+\tstatus = updateStatus(op, status)","+","+\tif equality.Semantic.DeepEqual(op.Status, status) {","+\t\th.encryptionkeyrotations.EnqueueAfter(op.Namespace, op.Name, 5*time.Second)","+\t}","+\treturn status, nil","+}","+","+func (h *handler) onChange(op *opv1alpha1.EncryptionKeyRotation, status opv1alpha1.EncryptionKeyRotationStatus) (opv1alpha1.EncryptionKeyRotationStatus, error) {","+\tif status.Phase == \"\" {","+\t\tstatus.Phase = opv1alpha1.OperationPhasePending","+\t\tstatus.LastUpdated = metav1.Now()","+\t}","+","+\tgvk := schema.FromAPIVersionAndKind(op.Spec.ClusterRef.APIVersion, op.Spec.ClusterRef.Kind)","+\tref, err := h.dynamic.Get(gvk, op.Spec.ClusterRef.Namespace, op.Spec.ClusterRef.Name)","+\tif apierrors.IsNotFound(err) {","+\t\tkey := fmt.Sprintf(\"apiVersion=%s, kind=%s\", op.Spec.ClusterRef.APIVersion, op.Spec.ClusterRef.Kind)","+\t\tif op.Spec.ClusterRef.Namespace != \"\" {","+\t\t\tkey += fmt.Sprintf(\", namespace=%s\", op.Spec.ClusterRef.Namespace)","+\t\t}","+\t\tkey += fmt.Sprintf(\", name=%s\", op.Spec.ClusterRef.Name)","+\t\tlogrus.Errorf(\"[encryptionkeyrotation]: %s/%s failed to find cluster for %s\", op.Namespace, op.Name, key)","+","+\t\topv1alpha1.FailedCondition.True(&status)","+\t\topv1alpha1.FailedCondition.Reason(&status, opv1alpha1.ClusterNotFoundReason)","+\t\topv1alpha1.FailedCondition.Message(&status, fmt.Sprintf(\"cluster %s not found\", key))","+","+\t\tstatus.Phase = opv1alpha1.OperationPhaseFailed","+\t\tstatus.LastUpdated = metav1.Now()","+\t\treturn status, nil","+\t}","+\tif err != nil {","+\t\treturn status, err","+\t}","+","+\tustrMap, err := runtime.DefaultUnstructuredConverter.ToUnstructured(ref)","+\tif err != nil {","+\t\treturn status, err","+\t}","+","+\tustr := unstructured.Unstructured{Object: ustrMap}","+","+\tnamespace := op.Spec.ClusterRef.Namespace","+\tif namespace == \"\" {","+\t\tmapping, err := h.clients.RESTMapper.RESTMapping(gvk.GroupKind(), gvk.Version)","+\t\tif err != nil {","+\t\t\treturn status, err","+\t\t}","+\t\tif mapping.Scope.Name() == meta.RESTScopeNameNamespace {","+\t\t\tnamespace = op.Namespace","+\t\t} else {","+\t\t\t// cluster-scoped objects: beacon namespace is the name of the object","+\t\t\tnamespace = op.Spec.ClusterRef.Name","+\t\t}","+\t}","+","+\tbeacon, err := h.beacons.Get(namespace, ustr.GetName(), metav1.GetOptions{})","+\tif apierrors.IsNotFound(err) && status.Phase == opv1alpha1.OperationPhasePending {","+\t\tkey := fmt.Sprintf(\"apiVersion=%s, kind=%s\", ustr.GetAPIVersion(), ustr.GetKind())","+\t\tif ustr.GetNamespace() != \"\" {","+\t\t\tkey += fmt.Sprintf(\", namespace=%s\", ustr.GetNamespace())","+\t\t}","+\t\tkey += fmt.Sprintf(\", name=%s\", ustr.GetName())","+\t\tlogrus.Warnf(\"[encryptionkeyrotation]: %s/%s failed to find beacon for %s\", op.Namespace, op.Name, key)","+","+\t\topv1alpha1.PendingCondition.True(&status)","+\t\topv1alpha1.PendingCondition.Reason(&status, opv1alpha1.WaitingForBeaconReason)","+\t\topv1alpha1.PendingCondition.Message(&status, \"waiting for beacon creation\")","+","+\t\treturn status, nil","+\t} else if err != nil {","+\t\treturn status, err","+\t}","+","+\tadapter, err := ops.NewAdapter(h.clients, &ustr)","+\tif err != nil {","+\t\treturn status, err","+\t}","+","+\ts := &scope{","+\t\top:         op,","+\t\tbeacon:     beacon,","+\t\tnamespace:  namespace,","+\t\tclusterObj: &ustr,","+\t\tadapter:    adapter,","+\t}","+","+\tif status.Phase == opv1alpha1.OperationPhasePending {","+\t\treturn h.handlePending(s, status)","+\t}","+\tif status.Phase == opv1alpha1.OperationPhaseInProgress {","+\t\treturn h.handleInProgress(s, status)","+\t}","+\tif status.Phase == opv1alpha1.OperationPhaseCanceled {","+\t\treturn status, nil","+\t}","+","+\t// Failed and Succeeded run their cleanup and then fall through to the shared TTL deletion block.","+\tif status.Phase == opv1alpha1.OperationPhaseFailed {","+\t\tstatus, err = h.handleFailed(s, status)","+\t} else if status.Phase == opv1alpha1.OperationPhaseSucceeded {","+\t\tstatus, err = h.handleSucceeded(s, status)","+\t} else {","+\t\topv1alpha1.FailedCondition.True(&status)","+\t\topv1alpha1.FailedCondition.Reason(&status, opv1alpha1.UnknownPhaseReason)","+\t\topv1alpha1.FailedCondition.Message(&status, fmt.Sprintf(\"unknown phase [%s]\", op.Status.Phase))","+\t\treturn status, nil","+\t}","+","+\tif err != nil {","+\t\treturn status, err","+\t}","+","+\t// Delete expired terminal CRs after cleanup has run.","+\tif ops.IsTerminal(status.Phase) && ops.IsExpired(&op.Spec.OperationSpec, &status.OperationStatus) {","+\t\terr = h.encryptionkeyrotations.Delete(op.Namespace, op.Name, &metav1.DeleteOptions{})","+\t\tif err != nil {","+\t\t\treturn status, err","+\t\t}","+\t\treturn status, generic.ErrSkip","+\t}","+","+\treturn status, nil","+}","+","+type scope struct {","+\top        *opv1alpha1.EncryptionKeyRotation","+\tnamespace string","+","+\tbeacon     *planv1alpha1.Beacon","+\tclusterObj *unstructured.Unstructured","+\tadapter    ops.Adapter","+}","+","+func (h *handler) handlePending(s *scope, status opv1alpha1.EncryptionKeyRotationStatus) (opv1alpha1.EncryptionKeyRotationStatus, error) {","+\townerKey := beaconOwnerKey(s.op)","+\tif err := h.reclaimStaleBeaconOwnerIfNeeded(s); err != nil {","+\t\treturn status, err","+\t}","+","+\tbeacon, err := plan.AcquireBeacon(s.beacon, h.beacons, ownerKey)","+\tif err != nil {","+\t\treturn status, err","+\t}","+\tif beacon == nil {","+\t\topv1alpha1.PendingCondition.True(&status)","+\t\topv1alpha1.PendingCondition.Reason(&status, opv1a