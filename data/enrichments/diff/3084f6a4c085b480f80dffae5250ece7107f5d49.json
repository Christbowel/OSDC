Version) TemplateVersion() uint {","+\tif v.IsOpenSearch() {","+\t\treturn 7","+\t}","+\tswitch v {","+\tcase ElasticV6:","+\t\treturn 6","+\tcase ElasticV7:","+\t\treturn 7","+\tdefault:","+\t\treturn 8","+\t}","+}","+","+// UsesV8API returns true if the backend requires the v8 index template API.","+func (v BackendVersion) UsesV8API() bool {","+\treturn v == ElasticV8 || v == ElasticV9","+}","+","+// SupportsTypedIndices returns true if index requests require a _type parameter.","+// Only ES 6.x requires this; ES 7+ and all OpenSearch versions ignore it.","+func (v BackendVersion) SupportsTypedIndices() bool {","+\treturn v == ElasticV6","+}","+","+// SupportsILM returns true if the backend supports Index Lifecycle Management.","+// ILM requires ES 7+ or OpenSearch (which uses ISM, the equivalent feature).","+func (v BackendVersion) SupportsILM() bool {","+\treturn v != ElasticV6","+}","+","+// DetectBackendVersion determines the BackendVersion from the ping response.","+func DetectBackendVersion(tagLine string, majorVersion int) BackendVersion {","+\tif strings.Contains(tagLine, \"OpenSearch\") {","+\t\tswitch majorVersion {","+\t\tcase 1:","+\t\t\treturn OpenSearch1","+\t\tcase 2:","+\t\t\treturn OpenSearch2","+\t\tdefault:","+\t\t\treturn OpenSearch3","+\t\t}","+\t}","+\tswitch majorVersion {","+\tcase 6:","+\t\treturn ElasticV6","+\tcase 7:","+\t\treturn ElasticV7","+\tcase 9:","+\t\treturn ElasticV9","+\tdefault:","+\t\treturn ElasticV8","+\t}","+}"],"additions":108,"deletions":0,"truncated":false},{"path":"internal/storage/elasticsearch/backend_version_test.go","lines":["@@ -0,0 +1,141 @@","+// Copyright (c) 2026 The Jaeger Authors.","+// SPDX-License-Identifier: Apache-2.0","+","+package elasticsearch","+","+import (","+\t\"testing\"","+","+\t\"github.com/stretchr/testify/assert\"","+)","+","+func TestBackendVersion_String(t *testing.T) {","+\ttests := []struct {","+\t\tversion  BackendVersion","+\t\texpected string","+\t}{","+\t\t{ElasticV6, \"Elasticsearch 6.x\"},","+\t\t{ElasticV7, \"Elasticsearch 7.x\"},","+\t\t{ElasticV8, \"Elasticsearch 8.x\"},","+\t\t{ElasticV9, \"Elasticsearch 9.x\"},","+\t\t{OpenSearch1, \"OpenSearch 1.x\"},","+\t\t{OpenSearch2, \"OpenSearch 2.x\"},","+\t\t{OpenSearch3, \"OpenSearch 3.x\"},","+\t\t{BackendVersion(999), \"Unknown(999)\"},","+\t}","+\tfor _, tt := range tests {","+\t\tassert.Equal(t, tt.expected, tt.version.String())","+\t}","+}","+","+func TestBackendVersion_IsOpenSearch(t *testing.T) {","+\ttests := []struct {","+\t\tversion  BackendVersion","+\t\texpected bool","+\t}{","+\t\t{ElasticV6, false},","+\t\t{ElasticV7, false},","+\t\t{ElasticV8, false},","+\t\t{ElasticV9, false},","+\t\t{OpenSearch1, true},","+\t\t{OpenSearch2, true},","+\t\t{OpenSearch3, true},","+\t}","+\tfor _, tt := range tests {","+\t\tassert.Equal(t, tt.expected, tt.version.IsOpenSearch(), tt.version.String())","+\t}","+}","+","+func TestBackendVersion_TemplateVersion(t *testing.T) {","+\ttests := []struct {","+\t\tversion  BackendVersion","+\t\texpected uint","+\t}{","+\t\t{ElasticV6, 6},","+\t\t{ElasticV7, 7},","+\t\t{ElasticV8, 8},","+\t\t{ElasticV9, 8},","+\t\t{OpenSearch1, 7},","+\t\t{OpenSearch2, 7},","+\t\t{OpenSearch3, 7},","+\t}","+\tfor _, tt := range tests {","+\t\tassert.Equal(t, tt.expected, tt.version.TemplateVersion(), tt.version.String())","+\t}","+}","+","+func TestBackendVersion_UsesV8API(t *testing.T) {","+\ttests := []struct {","+\t\tversion  BackendVersion","+\t\texpected bool","+\t}{","+\t\t{ElasticV6, false},","+\t\t{ElasticV7, false},","+\t\t{ElasticV8, true},","+\t\t{ElasticV9, true},","+\t\t{OpenSearch1, false},","+\t\t{OpenSearch2, false},","+\t\t{OpenSearch3, false},","+\t}","+\tfor _, tt := range tests {","+\t\tassert.Equal(t, tt.expected, tt.version.UsesV8API(), tt.version.String())","+\t}","+}","+","+func TestBackendVersion_SupportsTypedIndices(t *testing.T) {","+\ttests := []struct {","+\t\tversion  BackendVersion","+\t\texpected bool","+\t}{","+\t\t{ElasticV6, true},","+\t\t{ElasticV7, false},","+\t\t{ElasticV8, false},","+\t\t{ElasticV9, false},","+\t\t{OpenSearch1, false},","+\t\t{OpenSearch2, false},","+\t\t{OpenSearch3, false},","+\t}","+\tfor _, tt := range tests {","+\t\tassert.Equal(t, tt.expected, tt.version.SupportsTypedIndices(), tt.version.String())","+\t}","+}","+","+func TestBackendVersion_SupportsILM(t *testing.T) {","+\ttests := []struct {","+\t\tversion  BackendVersion","+\t\texpected bool","+\t}{","+\t\t{ElasticV6, false},","+\t\t{ElasticV7, true},","+\t\t{ElasticV8, true},","+\t\t{ElasticV9, true},","+\t\t{OpenSearch1, true},","+\t\t{OpenSearch2, true},","+\t\t{OpenSearch3, true},","+\t}","+\tfor _, tt := range tests {","+\t\tassert.Equal(t, tt.expected, tt.version.SupportsILM(), tt.version.String())","+\t}","+}","+","+func TestDetectBackendVersion(t *testing.T) {","+\ttests := []struct {","+\t\ttagLine      string","+\t\tmajorVersion int","+\t\texpected     BackendVersion","+\t}{","+\t\t{\"You Know, for Search\", 6, ElasticV6},","+\t\t{\"You Know, for Search\", 7, ElasticV7},","+\t\t{\"You Know, for Search\", 8, ElasticV8},","+\t\t{\"You Know, for Search\", 9, ElasticV9},","+\t\t{\"You Know, for Search\", 5, ElasticV8},","+\t\t{\"The OpenSearch Project: https://opensearch.org/\", 1, OpenSearch1},","+\t\t{\"The OpenSearch Project: https://opensearch.org/\", 2, OpenSearch2},","+\t\t{\"The OpenSearch Project: https://opensearch.org/\", 3, OpenSearch3},","+\t\t{\"The OpenSearch Project: https://opensearch.org/\", 4, OpenSearch3},","+\t}","+\tfor _, tt := range tests {","+\t\tresult := DetectBackendVersion(tt.tagLine, tt.majorVersion)","+\t\tassert.Equal(t, tt.expected, result, \"tagLine=%q major=%d\", tt.tagLine, tt.majorVersion)","+\t}","+}"],"additions":141,"deletions":0,"truncated":false},{"path":"internal/storage/elasticsearch/client.go","lines":["@@ -21,7 +21,7 @@ type Client interface {"," \tMultiSearch() MultiSearchService"," \tDeleteIndex(index string) IndicesDeleteService"," \tio.Closer","-\tGetVersion() uint","+