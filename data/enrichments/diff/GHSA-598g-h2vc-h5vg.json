 {","+\tif !s.isActiveAdmin(r.Context()) {"," \t\twriteError(w, http.StatusForbidden, \"admin role required\")"," \t\treturn"," \t}"],"additions":2,"deletions":2,"truncated":false},{"path":"internal/web/oidc_disable_cascade_test.go","lines":["@@ -0,0 +1,99 @@","+package web","+","+import (","+\t\"context\"","+\t\"net/http\"","+\t\"net/http/httptest\"","+\t\"testing\"","+","+\t\"github.com/juev/nebula-mesh/internal/models\"","+\t\"github.com/juev/nebula-mesh/internal/store\"","+)","+","+// TestDisableOperator_KillsActiveOIDCSession pins the disable-cascade","+// contract for OIDC-authenticated sessions. Local-auth sessions are","+// already covered in store/sqlite_operators_test.go; this variant","+// guards against a future refactor that partitions sessions by","+// auth_provider against the OIDC path specifically.","+func TestDisableOperator_KillsActiveOIDCSession(t *testing.T) {","+\tctx := context.Background()","+\ts, err := store.NewSQLiteStore(\":memory:\")","+\tif err != nil {","+\t\tt.Fatalf(\"open store: %v\", err)","+\t}","+\tt.Cleanup(func() { _ = s.Close() })","+\tif err := s.Migrate(ctx); err != nil {","+\t\tt.Fatalf(\"migrate: %v\", err)","+\t}","+","+\top := &models.Operator{","+\t\tID:           \"oidc-user-id\",","+\t\tUsername:     \"oidc-user@example.com\",","+\t\tDisplayName:  \"OIDC User\",","+\t\tPasswordHash: \"oidc\", // matches oidc.go::upsertOperator's placeholder","+\t\tRole:         \"admin\",","+\t\tAuthProvider: models.OperatorAuthOIDC,","+\t\tOIDCIssuer:   \"https://idp.example.com\",","+\t\tOIDCSubject:  \"sub-12345\",","+\t}","+\tif err := s.CreateOperator(ctx, op); err != nil {","+\t\tt.Fatalf(\"create OIDC operator: %v\", err)","+\t}","+","+\tsm := NewSessionManager(s)","+","+\t// Mint a session via the same SessionManager method the OIDC","+\t// callback uses (oidc.go HandleCallback -> session.StartAuthenticatedSession).","+\trec := httptest.NewRecorder()","+\tstartReq := httptest.NewRequest(http.MethodGet, \"/\", nil)","+\tif err := sm.StartAuthenticatedSession(rec, startReq, op); err != nil {","+\t\tt.Fatalf(\"StartAuthenticatedSession: %v\", err)","+\t}","+","+\t// Lift the session cookie back into a request, the way a browser","+\t// would carry it across calls.","+\tvar sessionCookie *http.Cookie","+\tfor _, c := range rec.Result().Cookies() {","+\t\tif c.Name == sessionCookieName {","+\t\t\tsessionCookie = c","+\t\t\tbreak","+\t\t}","+\t}","+\tif sessionCookie == nil {","+\t\tt.Fatal(\"StartAuthenticatedSession did not set a session cookie\")","+\t}","+","+\tcarryCookie := func() *http.Request {","+\t\tr := httptest.NewRequest(http.MethodGet, \"/\", nil)","+\t\tr.AddCookie(sessionCookie)","+\t\treturn r","+\t}","+","+\t// Pre-disable: the session authenticates the OIDC operator.","+\tif !sm.IsAuthenticated(carryCookie()) {","+\t\tt.Fatal(\"OIDC session should authenticate before disable\")","+\t}","+\tif got := sm.CurrentOperator(carryCookie()); got == nil || got.ID != op.ID {","+\t\tt.Fatalf(\"CurrentOperator pre-disable = %v, want operator %q\", got, op.ID)","+\t}","+","+\t// Disable the OIDC operator. DisableOperator's atomic transaction","+\t// must delete the session row alongside the status flip — same","+\t// cascade local-auth operators get.","+\tif err := s.DisableOperator(ctx, op.ID); err != nil {","+\t\tt.Fatalf(\"DisableOperator: %v\", err)","+\t}","+","+\t// Post-disable: the session must no longer authenticate.","+\tif sm.IsAuthenticated(carryCookie()) {","+\t\tt.Error(\"OIDC session still authenticates after DisableOperator (cascade broken)\")","+\t}","+\tif got := sm.CurrentOperator(carryCookie()); got != nil {","+\t\tt.Errorf(\"CurrentOperator post-disable = %v, want nil\", got)","+\t}","+","+\t// Verify the row is gone, not just filtered.","+\tif _, err := s.GetOperatorBySession(ctx, sessionCookie.Value); err == nil {","+\t\tt.Error(\"expected ErrNotFound from GetOperatorBySession; row still present\")","+\t}","+}",""],"additions":99,"deletions":0,"truncated":false}],"additions":220,"deletions":18,"truncated":false,"file_count":10},"error":null,"fetched_at":"2026-06-09T10:50:04.273976+00:00"}