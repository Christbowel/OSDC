{"id":"6d2ade97958fdfdeb75a8244047aaea862925d57","axis":"silent","repo":"jaegertracing/jaeger","sha":"6d2ade97958fdfdeb75a8244047aaea862925d57","parsed":{"files":[{"path":"cmd/jaeger/internal/extension/jaegerquery/config.go","lines":["@@ -9,6 +9,7 @@ import ("," \t\"strings\""," "," \t\"github.com/asaskevich/govalidator\"","+\t\"go.opentelemetry.io/collector/component\""," \t\"go.opentelemetry.io/collector/confmap/xconfmap\""," "," \tqueryapp \"github.com/jaegertracing/jaeger/cmd/jaeger/internal/extension/jaegerquery/internal\"","@@ -21,6 +22,16 @@ type Config struct {"," \tqueryapp.QueryOptions `mapstructure:\",squash\"`"," \t// Storage holds configuration related to the various data stores that are to be queried."," \tStorage Storage `mapstructure:\"storage\"`","+\t// QueryInterceptors lists extension IDs that implement","+\t// queryinterceptor.Interceptor. jaeger-query resolves them from the","+\t// collector host and applies them, in order, around every trace query:","+\t// OnQuery before the search executes, OnResult on the returned traces.","+\t// Empty by default, in which case the read path is unchanged.","+\t//","+\t// These IDs are also reported from Dependencies(), so the collector starts","+\t// each listed extension before jaeger-query — guaranteeing it is initialized","+\t// by the time its hooks are invoked.","+\tQueryInterceptors []component.ID `mapstructure:\"query_interceptors\"`"," }"," "," type Storage struct {"],"additions":11,"deletions":0,"truncated":false},{"path":"cmd/jaeger/internal/extension/jaegerquery/queryinterceptor/package_test.go","lines":["@@ -0,0 +1,14 @@","+// Copyright (c) 2026 The Jaeger Authors.","+// SPDX-License-Identifier: Apache-2.0","+","+package queryinterceptor","+","+import (","+\t\"testing\"","+","+\t\"github.com/jaegertracing/jaeger/internal/testutils\"","+)","+","+func TestMain(m *testing.M) {","+\ttestutils.VerifyGoLeaks(m)","+}"],"additions":14,"deletions":0,"truncated":false},{"path":"cmd/jaeger/internal/extension/jaegerquery/queryinterceptor/reader_decorator.go","lines":["@@ -0,0 +1,181 @@","+// Copyright (c) 2026 The Jaeger Authors.","+// SPDX-License-Identifier: Apache-2.0","+","+package queryinterceptor","+","+import (","+\t\"context\"","+\t\"iter\"","+","+\t\"go.opentelemetry.io/collector/pdata/ptrace\"","+","+\tpub \"github.com/jaegertracing/jaeger/components/extension/jaegerquery/queryinterceptor\"","+\t\"github.com/jaegertracing/jaeger/internal/storage/v2/api/tracestore\"","+)","+","+type reader struct {","+\tnext         tracestore.Reader","+\tinterceptors []pub.Interceptor","+}","+","+// NewReaderDecorator decorates next so the given interceptors are applied around","+// every trace query: OnQuery on the query parameters of FindTraces,","+// FindTraceIDs, and FindTraceSummaries, and OnResult on every batch of traces","+// yielded by FindTraces and GetTraces. Interceptors run in the order given.","+// Callers wrap only when there is at least one interceptor, so this always","+// returns a decorator.","+//","+// The interceptors see the public queryinterceptor.Query; this decorator","+// converts to and from the internal tracestore.TraceQueryParams at the boundary,","+// so the internal query type never crosses the contract.","+func NewReaderDecorator(next tracestore.Reader, interceptors ...pub.Interceptor) tracestore.Reader {","+\treturn &reader{next: next, interceptors: interceptors}","+}","+","+func toPublicQuery(q tracestore.TraceQueryParams) pub.Query {","+\treturn pub.Query{","+\t\tServiceName:   q.ServiceName,","+\t\tOperationName: q.OperationName,","+\t\tAttributes:    q.Attributes,","+\t\tStartTimeMin:  q.StartTimeMin,","+\t\tStartTimeMax:  q.StartTimeMax,","+\t\tDurationMin:   q.DurationMin,","+\t\tDurationMax:   q.DurationMax,","+\t\tSearchDepth:   q.SearchDepth,","+\t}","+}","+","+func fromPublicQuery(q pub.Query) tracestore.TraceQueryParams {","+\treturn tracestore.TraceQueryParams{","+\t\tServiceName:   q.ServiceName,","+\t\tOperationName: q.OperationName,","+\t\tAttributes:    q.Attributes,","+\t\tStartTimeMin:  q.StartTimeMin,","+\t\tStartTimeMax:  q.StartTimeMax,","+\t\tDurationMin:   q.DurationMin,","+\t\tDurationMax:   q.DurationMax,","+\t\tSearchDepth:   q.SearchDepth,","+\t}","+}","+","+func (r *reader) onQuery(ctx context.Context, query tracestore.TraceQueryParams) (tracestore.TraceQueryParams, error) {","+\tpq := toPublicQuery(query)","+\tvar err error","+\tfor _, interceptor := range r.interceptors {","+\t\tpq, err = interceptor.OnQuery(ctx, pq)","+\t\tif err != nil {","+\t\t\treturn query, err","+\t\t}","+\t}","+\treturn fromPublicQuery(pq), nil","+}","+","+func (r *reader) onResult(ctx context.Context, traces []ptrace.Traces) ([]ptrace.Traces, error) {","+\tvar err error","+\tfor _, interceptor := range r.interceptors {","+\t\ttraces, err = interceptor.OnResult(ctx, traces)","+\t\tif err != nil {","+\t\t\treturn nil, err","+\t\t}","+\t}","+\treturn traces, nil","+}","+","+func (r *reader) FindTraces(ctx context.Context, query tracestore.TraceQueryParams) iter.Seq2[[]ptrace.Traces, error] {","+\treturn func(yield func([]ptrace.Traces, error) bool) {","+\t\tgated, err := r.onQuery(ctx, query)","+\t\tif err != nil {","+\t\t\tyield(nil, err)","+\t\t\treturn","+\t\t}","+\t\tfor traces, err := range r.next.FindTraces(ctx, gated) {","+\t\t\tif err != nil {","+\t\t\t\tif !yield(nil, err) {","+\t\t\t\t\treturn","+\t\t\t\t}","+\t\t\t\tcontinue","+\t\t\t}","+\t\t\tsanitized, serr := r.onResult(ctx, traces)","+\t\t\tif serr != nil {","+\t\t\t\t// Per the Interceptor contract, an OnResult error aborts the stream:","+\t\t\t\t// stop rather than emit further batches, which could leak results the","+\t\t\t\t// failed sanitize/redaction was meant to withhold.","+\t\t\t\tyield(nil, serr)","+\t\t\t\treturn","+\t\t\t}","+\t\t\tif !yield(sanitized, nil) {","+\t\t\t\treturn","+\t\t\t}","+\t\t}","+\t}","+}","+","+func (r *reader) FindTraceIDs(ctx context.Context, query tracestore.TraceQueryParams) iter.Seq2[[]tracestore.FoundTraceID, error] {","+\treturn func(yield func([]tracestore.FoundTraceID, error) bool) {","+\t\tgated, err := r.onQuery(ctx, query)","+\t\tif err != nil {","+\t\t\tyield(nil, err)","+\t\t\treturn","+\t\t}","+\t\tfor ids, err := range r.next.FindTraceIDs(ctx, gated) {","+\t\t\tif !yield(ids, err) {","+\t\t\t\treturn","+\t\t\t}","+\t\t}","+\t}","+}","+","+func (r *reader) GetTraces(ctx context.Context, traceIDs ...tracestore.GetTraceParams) iter.Seq2[[]ptrace.Traces, error] {","+\treturn func(yield func([]ptrace.Traces, error) bool) {","+\t\tfor traces, err := range r.next.GetTraces(ctx, traceIDs...) {","+\t\t\tif err != nil {","+\t\t\t\tif !yield(nil, err) {","+\t\t\t\t\treturn","+\t\t\t\t}","+\t\t\t\tcontinue","+\t\t\t}","+\t\t\tsanitized, serr := r.onResult(ctx, traces)","+\t\t\tif serr != nil {","+\t\t\t\t// Per the Interceptor contract, an OnResult error aborts the stream:","+\t\t\t\t// stop rather than emit further batches, which could leak results the","+\t\t\t\t// failed sanitize/redaction was meant to withhold.","+\t\t\t\tyield(nil, serr)","+\t\t\t\treturn","+\t\t\t}","+\t\t\tif !yield(sanitized, nil) {","+\t\t\t\treturn","+\t\t\t}","+\t\t}","+\t}","+}","+","+func (r *reader) GetServices(ctx context.Context) ([]string, error) {","+\treturn r.next.GetServices(ctx)","+}","+","+func (r *reader) GetOperations(ctx context.Context, query tracestore.OperationQueryParams) ([]tracestore.Operation, error) {","+\treturn r.next.GetOperations(ctx, query)","+}","+","+// FindTraceSummaries forwards to the wrapped reader's FindTraceSummaries,","+// applying OnQuery gating to the search. When the wrapped reader has no native","+// summary support it yields errors.ErrUnsupported and the query service falls","+// back to FindTraces (which this decorator also gates). OnResult is not applied","+// here: summaries carry only per-trace metadata (not spans), and the Interceptor","+// contract has no summary hook — so an interceptor gates/constrains the summary","+// search via OnQuery, but cannot drop or redact individual summaries. A dedicated","+// summary hook is left as a contract extension.","+func (r *reader) FindTraceSummaries(ctx context.Context, query tracestore.TraceQueryParams) iter.Seq2[[]tracestore.TraceSummary, error] {","+\treturn func(yield func([]tracestore.TraceSummary, error) bool) {","+\t\tgated, err := r.onQuery(ctx, query)","+\t\tif err != nil {","+\t\t\tyield(nil, err)","+\t\t\treturn","+\t\t}","+\t\tfor summaries, err := range r.next.FindTraceSummaries(ctx, gated) {","+\t\t\tif !yield(summaries, err) {","+\t\t\t\treturn","+\t\t\t}","+\t\t}","+\t}","+}"],"additions":181,"deletions":0,"truncated":false},{"path":"cmd/jaeger/internal/extension/jaegerquery/queryinterceptor/reader_decorator_test.go","lines":["@@ -0,0 +1,460 @@","+// Copyright (c) 2026 The Jaeger Authors.","+// SPDX-License-Identifier: Apache-2.0","+","+package queryinterceptor","+","+import (","+\t\"context\"","+\t\"errors\"","+\t\"iter\"","+\t\"testing\"","+","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+\t\"go.opentelemetry.io/collector/pdata/ptrace\"","+","+\tpub \"github.com/jaegertracing/jaeger/components/extension/jaegerquery/queryinterceptor\"","+\t\"github.com/jaegertracing/jaeger/internal/storage/v2/api/tracestore\"","+)","+","+// fakeReader is a minimal tracestore.Reader that records the query it received","+// and yields a single configured batch (or error).","+type fakeReader struct {","+\tgotQuery        tracestore.TraceQueryParams","+\tfindCalled      bool","+\tbatch           []ptrace.Traces","+\tids             []tracestore.FoundTraceID","+\tservices        []string","+\terr             error","+\tidsErr          error","+\tleadingErr      error","+\tsummaryCalled   bool","+\tgotSummaryQuery tracestore.TraceQueryParams","+\tsummaries       []tracestore.TraceSummary","+\tsummaryErr      error","+}","+","+func (f *fakeReader) FindTraces(_ context.Context, q tracestore.TraceQueryParams) iter.Seq2[[]ptrace.Traces, error] {","+\tf.findCalled = true","+\tf.gotQuery = q","+\treturn func(yield func([]ptrace.Traces, error) bool) {","+\t\tif f.err != nil {","+\t\t\tyield(nil, f.err)","+\t\t\treturn","+\t\t}","+\t\tyield(f.batch, nil)","+\t}","+}","+","+func (f *fakeReader) GetTraces(_ context.Context, _ ...tracestore.GetTraceParams) iter.Seq2[[]ptrace.Traces, error] {","+\treturn func(yield func([]ptrace.Traces, error) bool) {","+\t\tif f.leadingErr != nil {","+\t\t\tif !yield(nil, f.leadingErr) {","+\t\t\t\treturn","+\t\t\t}","+\t\t}","+\t\tif f.err != nil {","+\t\t\tyield(nil, f.err)","+\t\t\treturn","+\t\t}","+\t\tyield(f.batch, nil)","+\t}","+}","+","+func (f *fakeReader) FindTraceIDs(_ context.Context, q tracestore.TraceQueryParams) iter.Seq2[[]tracestore.FoundTraceID, error] {","+\tf.gotQuery = q","+\treturn func(yield func([]tracestore.FoundTraceID, error) bool) {","+\t\tif f.idsErr != nil {","+\t\t\tyield(nil, f.idsErr)","+\t\t\treturn","+\t\t}","+\t\tyield(f.ids, nil)","+\t}","+}","+","+func (f *fakeReader) GetServices(context.Context) ([]string, error) {","+\treturn f.services, nil","+}","+","+func (*fakeReader) GetOperations(context.Context, tracestore.OperationQueryParams) ([]tracestore.Operation, error) {","+\treturn []tracestore.Operation{{Name: \"op\"}}, nil","+}","+","+func (f *fakeReader) FindTraceSummaries(_ context.Context, q tracestore.TraceQueryParams) iter.Seq2[[]tracestore.TraceSummary, error] {","+\tf.summaryCalled = true","+\tf.gotSummaryQuery = q","+\treturn func(yield func([]tracestore.TraceSummary, error) bool) {","+\t\tif f.summaryErr != nil {","+\t\t\tyield(nil, f.summaryErr)","+\t\t\treturn","+\t\t}","+\t\tyield(f.summaries, nil)","+\t}","+}","+","+// fakeInterceptor lets each test supply the hook behavior it needs. It receives","+// the public Query, exactly as a real interceptor would.","+type fakeInterceptor struct {","+\tonQuery  func(pub.Query) (pub.Query, error)","+\tonResult func([]ptrace.Traces) ([]ptrace.Traces, error)","+}","+","+func (f fakeInterceptor) OnQuery(_ context.Context, q pub.Query) (pub.Query, error) {","+\tif f.onQuery != nil {","+\t\treturn f.onQuery(q)","+\t}","+\treturn q, nil","+}","+","+func (f fakeInterceptor) OnResult(_ context.Context, t []ptrace.Traces) ([]ptrace.Traces, error) {","+\tif f.onResult != nil {","+\t\treturn f.onResult(t)","+\t}","+\treturn t, nil","+}","+","+func tracesWith(key, val string) []ptrace.Traces {","+\ttd := ptrace.NewTraces()","+\tspan := td.ResourceSpans().AppendEmpty().ScopeSpans().AppendEmpty().Spans().AppendEmpty()","+\tspan.Attributes().PutStr(key, val)","+\treturn []ptrace.Traces{td}","+}","+","+func firstSpanAttr(t *testing.T, batch []ptrace.Traces, key string) string {","+\tt.Helper()","+\trequire.NotEmpty(t, batch)","+\tattrs := batch[0].ResourceSpans().At(0).ScopeSpans().At(0).Spans().At(0).Attributes()","+\tv, ok := attrs.Get(key)","+\trequire.True(t, ok, \"attribute %q not present\", key)","+\treturn v.Str()","+}","+","+func collectTraces(it iter.Seq2[[]ptrace.Traces, error]) ([][]ptrace.Traces, error) {","+\tvar out [][]ptrace.Traces","+\tfor batch, err := range it {","+\t\tif err != nil {","+\t\t\treturn out, err","+\t\t}","+\t\tout = append(out, batch)","+\t}","+\treturn out, nil","+}","+","+func redactResult(key string) func([]ptrace.Traces) ([]ptrace.Traces, error) {","+\treturn func(batch []ptrace.Traces) ([]ptrace.Traces, error) {","+\t\tfor _, td := range batch {","+\t\t\trss := td.ResourceSpans()","+\t\t\tfor i := 0; i < rss.Len(); i++ {","+\t\t\t\tsss := rss.At(i).ScopeSpans()","+\t\t\t\tfor j := 0; j < sss.Len(); j++ {","+\t\t\t\t\tspans := sss.At(j).Spans()","+\t\t\t\t\tfor k := 0; k < spans.Len(); k++ {","+\t\t\t\t\t\tif _, ok := spans.At(k).Attributes().Get(key); ok {","+\t\t\t\t\t\t\tspans.At(k).Attributes().PutStr(key, \"REDACTED\")","+\t\t\t\t\t\t}","+\t\t\t\t\t}","+\t\t\t\t}","+\t\t\t}","+\t\t}","+\t\treturn batch, nil","+\t}","+}","+","+func TestReader_FindTraces_AppliesQueryAndResultHooks(t *testing.T) {","+\tnext := &fakeReader{batch: tracesWith(\"secret\", \"value\")}","+\tic := fakeInterceptor{","+\t\tonQuery: func(q pub.Query) (pub.Query, error) {","+\t\t\tq.ServiceName = \"gated\"","+\t\t\treturn q, nil","+\t\t},","+\t\tonResult: redactResult(\"secret\"),","+\t}","+\tr := NewReaderDecorator(next, ic)","+","+\tout, err := collectTraces(r.FindTraces(context.Background(), tracestore.TraceQueryParams{ServiceName: \"original\"}))","+\trequire.NoError(t, err)","+\tassert.Equal(t, \"gated\", next.gotQuery.ServiceName, \"pre-query hook must reach storage\")","+\trequire.Len(t, out, 1)","+\tassert.Equal(t, \"REDACTED\", firstSpanAttr(t, out[0], \"secret\"), \"result hook must redact\")","+}","+","+func TestReader_FindTraces_QueryRejectionSkipsStorage(t *testing.T) {","+\tsentinel := errors.New(\"denied\")","+\tnext := &fakeReader{batch: tracesWith(\"k\", \"v\")}","+\tr := NewReaderDecorator(next, fakeInterceptor{","+\t\tonQuery: func(q pub.Query) (pub.Query, error) { return q, sentinel },","+\t})","+","+\t_, err := collectTraces(r.FindTraces(context.Background(), tracestore.TraceQueryParams{}))","+\trequire.ErrorIs(t, err, sentinel)","+\tassert.False(t, next.findCalled, \"storage must not be queried when the query is rejected\")","+}","+","+func TestReader_FindTraces_ResultErrorAborts(t *testing.T) {","+\tsentinel := errors.New(\"sanitize failed\")","+\tnext := &fakeReader{batch: tracesWith(\"k\", \"v\")}","+\tr := NewReaderDecorator(next, fakeInterceptor{","+\t\tonResult: func([]ptrace.Traces) ([]ptrace.Traces, error) { return nil, sentinel },","+\t})","+","+\t_, err := collectTraces(r.FindTraces(context.Background(), tracestore.TraceQueryParams{}))","+\trequire.ErrorIs(t, err, sentinel)","+}","+","+func TestReader_FindTraces_StorageErrorPropagates(t *testing.T) {","+\tsentinel := errors.New(\"storage down\")","+\tnext := &fakeReader{err: sentinel}","+\tr := NewReaderDecorator(next, fakeInterceptor{})","+","+\t_, err := collectTraces(r.FindTraces(context.Background(), tracestore.TraceQueryParams{}))","+\trequire.ErrorIs(t, err, sentinel)","+}","+","+func TestReader_GetTraces_AppliesResultHook(t *testing.T) {","+\tnext := &fakeReader{batch: tracesWith(\"secret\", \"value\")}","+\tr := NewReaderDecorator(next, fakeInterceptor{onResult: redactResult(\"secret\")})","+","+\tout, err := collectTraces(r.GetTraces(context.Background(), tracestore.GetTraceParams{}))","+\trequire.NoError(t, err)","+\trequire.Len(t, out, 1)","+\tassert.Equal(t, \"REDACTED\", firstSpanAttr(t, out[0], \"secret\"))","+}","+","+func TestReader_GetTraces_StorageErrorPropagates(t *testing.T) {","+\tsentinel := errors.New(\"storage down\")","+\tr := NewReaderDecorator(&fakeReader{err: sentinel}, fakeInterceptor{})","+\t_, err := collectTraces(r.GetTraces(context.Background(), tracestore.GetTraceParams{}))","+\trequire.ErrorIs(t, err, sentinel)","+}","+","+func TestReader_GetTraces_ResultErrorAborts(t *testing.T) {","+\tsentinel := errors.New(\"sanitize failed\")","+\tnext := &fakeReader{batch: tracesWith(\"k\", \"v\")}","+\tr := NewReaderDecorator(next, fakeInterceptor{","+\t\tonResult: func([]ptrace.Traces) ([]ptrace.Traces, error) { return nil, sentinel },","+\t})","+\t_, err := collectTraces(r.GetTraces(context.Background(), tracestore.GetTraceParams{}))","+\trequire.ErrorIs(t, err, sentinel)","+}","+","+func TestReader_GetTraces_ContinuesAfterError(t *testing.T) {","+\tsentinel := errors.New(\"transient\")","+\tnext := &fakeReader{leadingErr: sentinel, batch: tracesWith(\"secret\", \"value\")}","+\tr := NewReaderDecorator(next, fakeInterceptor{onResult: redactResult(\"secret\")})","+","+\tvar errs, batches int","+\tfor batch, err := range r.GetTraces(context.Background(), tracestore.GetTraceParams{}) {","+\t\tif err != nil {","+\t\t\trequire.ErrorIs(t, err, sentinel)","+\t\t\terrs++","+\t\t\tcontinue","+\t\t}","+\t\tassert.Equal(t, \"REDACTED\", firstSpanAttr(t, batch, \"secret\"))","+\t\tbatches++","+\t}","+\tassert.Equal(t, 1, errs)","+\tassert.Equal(t, 1, batches)","+}","+","+// multiBatchReader yields a fixed sequence of trace batches, so a test can","+// assert what the decorator does with batches after the first.","+type multiBatchReader struct {","+\t*fakeReader","+\tbatches [][]ptrace.Traces","+}","+","+func (r *multiBatchReader) FindTraces(context.Context, tracestore.TraceQueryParams) iter.Seq2[[]ptrace.Traces, error] {","+\treturn r.yieldBatches","+}","+","+func (r *multiBatchReader) GetTraces(context.Context, ...tracestore.GetTraceParams) iter.Seq2[[]ptrace.Traces, error] {","+\treturn r.yieldBatches","+}","+","+func (r *multiBatchReader) yieldBatches(yield func([]ptrace.Traces, error) bool) {","+\tfor _, b := range r.batches {","+\t\tif !yield(b, nil) {","+\t\t\treturn","+\t\t}","+\t}","+}","+","+// assertResultErrorStops verifies that an OnResult failure aborts the stream:","+// even a consumer that keeps ranging after the error must never receive a later","+// batch, and OnResult must not run again. This guards the redaction/authorization","+// use case, where emitting a later batch after a failed sanitize would leak data.","+func assertResultErrorStops(t *testing.T, call func(tracestore.Reader) iter.Seq2[[]ptrace.Traces, error]) {","+\tsentinel := errors.New(\"sanitize failed\")","+\tnext := &multiBatchReader{","+\t\tfakeReader: &fakeReader{},","+\t\tbatches:    [][]ptrace.Traces{tracesWith(\"k\", \"1\"), tracesWith(\"k\", \"2\")},","+\t}","+\tonResultCalls := 0","+\tr := NewReaderDecorator(next, fakeInterceptor{","+\t\tonResult: func([]ptrace.Traces) ([]ptrace.Traces, error) {","+\t\t\tonResultCalls++","+\t\t\treturn nil, sentinel","+\t\t},","+\t})","+","+\tvar errs, batches int","+\tfor _, err := range call(r) {","+\t\tif err != nil {","+\t\t\trequire.ErrorIs(t, err, sentinel)","+\t\t\terrs++","+\t\t\tcontinue","+\t\t}","+\t\tbatches++","+\t}","+\tassert.Equal(t, 1, errs, \"exactly one error, then the stream aborts\")","+\tassert.Zero(t, batches, \"no batch may be delivered after an OnResult error\")","+\tassert.Equal(t, 1, onResultCalls, \"OnResult must not run on batches after it fails\")","+}","+","+func TestReader_FindTraces_ResultErrorStopsIteration(t *testing.T) {","+\tassertResultErrorStops(t, func(r tracestore.Reader) iter.Seq2[[]ptrace.Traces, error] {","+\t\treturn r.FindTraces(context.Background(), tracestore.TraceQueryParams{})","+\t})","+}","+","+func TestReader_GetTraces_ResultErrorStopsIteration(t *testing.T) {","+\tassertResultErrorStops(t, func(r tracestore.Reader) iter.Seq2[[]ptrace.Traces, error] {","+\t\treturn r.GetTraces(context.Background(), tracestore.GetTraceParams{})","+\t})","+}","+","+func TestReader_FindTraceIDs_AppliesQueryHook(t *testing.T) {","+\tnext := &fakeReader{ids: []tracestore.FoundTraceID{{}}}","+\tr := NewReaderDecorator(next, fakeInterceptor{","+\t\tonQuery: func(q pub.Query) (pub.Query, error) {","+\t\t\tq.ServiceName = \"gated\"","+\t\t\treturn q, nil","+\t\t},","+\t})","+","+\tvar got [][]tracestore.FoundTraceID","+\tfor ids, err := range r.FindTraceIDs(context.Background(), tracestore.TraceQueryParams{}) {","+\t\trequire.NoError(t, err)","+\t\tgot = append(got, ids)","+\t}","+\tassert.Equal(t, \"gated\", next.gotQuery.ServiceName)","+\tassert.Len(t, got, 1)","+}","+","+func TestReader_FindTraceIDs_QueryRejectionSkipsStorage(t *testing.T) {","+\tsentinel := errors.New(\"denied\")","+\tnext := &fakeReader{ids: []tracestore.FoundTraceID{{}}}","+\tr := NewReaderDecorator(next, fakeInterceptor{","+\t\tonQuery: func(q pub.Query) (pub.Query, error) { return q, sentinel },","+\t})","+\tvar err error","+\tfor _, e := range r.FindTraceIDs(context.Background(), tracestore.TraceQueryParams{}) {","+\t\terr = e","+\t}","+\trequire.ErrorIs(t, err, sentinel)","+}","+","+func TestReader_FindTraceIDs_StorageErrorPropagates(t *testing.T) {","+\tsentinel := errors.New(\"storage down\")","+\tr := NewReaderDecorator(&fakeReader{idsErr: sentinel}, fakeInterceptor{})","+\tvar err error","+\tfor _, e := range r.FindTraceIDs(context.Background(), tracestore.TraceQueryParams{}) {","+\t\terr = e","+\t}","+\trequire.ErrorIs(t, err, sentinel)","+}","+","+// The early-stop tests exercise the \"consumer stopped iterating\" branches: when","+// the range loop breaks, yield returns false and the decorator must return.","+func TestReader_EarlyStop(*testing.T) {","+\tnext := &fakeReader{batch: tracesWith(\"k\", \"v\"), ids: []tracestore.FoundTraceID{{}}}","+\tr := NewReaderDecorator(next, fakeInterceptor{})","+","+\tfor range r.FindTraces(context.Background(), tracestore.TraceQueryParams{}) {","+\t\tbreak","+\t}","+\tfor range r.GetTraces(context.Background(), tracestore.GetTraceParams{}) {","+\t\tbreak","+\t}","+\tfor range r.FindTraceIDs(context.Background(), tracestore.TraceQueryParams{}) {","+\t\tbreak","+\t}","+}","+","+func TestReader_PassThroughMethods(t *testing.T) {","+\tnext := &fakeReader{services: []string{\"svc\"}}","+\tr := NewReaderDecorator(next, fakeInterceptor{})","+","+\tsvcs, err := r.GetServices(context.Background())","+\trequire.NoError(t, err)","+\tassert.Equal(t, []string{\"svc\"}, svcs)","+","+\tops, err := r.GetOperations(context.Background(), tracestore.OperationQueryParams{})","+\trequire.NoError(t, err)","+\tassert.Equal(t, []tracestore.Operation{{Name: \"op\"}}, ops)","+}","+","+func TestReader_ChainAppliesInOrder(t *testing.T) {","+\tnext := &fakeReader{batch: tracesWith(\"v\", \"0\")}","+\tvar order []string","+\tfirst := fakeInterceptor{onQuery: func(q pub.Query) (pub.Query, error) {","+\t\torder = append(order, \"first\")","+\t\treturn q, nil","+\t}}","+\tsecond := fakeInterceptor{onQuery: func(q pub.Query) (pub.Query, error) {","+\t\torder = append(order, \"second\")","+\t\treturn q, nil","+\t}}","+\tr := NewReaderDecorator(next, first, second)","+","+\t_, err := collectTraces(r.FindTraces(context.Background(), tracestore.TraceQueryParams{}))","+\trequire.NoError(t, err)","+\tassert.Equal(t, []string{\"first\", \"second\"}, order)","+}","+","+func TestReader_FindTraceSummaries_AppliesQueryHook(t *testing.T) {","+\tnext := &fakeReader{summaries: []tracestore.TraceSummary{{RootServiceName: \"svc\"}}}","+\tr := NewReaderDecorator(next, fakeInterceptor{","+\t\tonQuery: func(q pub.Query) (pub.Query, error) {","+\t\t\tq.ServiceName = \"gated\"","+\t\t\treturn q, nil","+\t\t},","+\t})","+","+\tvar got [][]tracestore.TraceSummary","+\tfor s, err := range r.FindTraceSummaries(context.Background(), tracestore.TraceQueryParams{ServiceName: \"original\"}) {","+\t\trequire.NoError(t, err)","+\t\tgot = append(got, s)","+\t}","+\tassert.Equal(t, \"gated\", next.gotSummaryQuery.ServiceName, \"pre-query hook must reach storage\")","+\trequire.Len(t, got, 1)","+\trequire.Len(t, got[0], 1)","+\tassert.Equal(t, \"svc\", got[0][0].RootServiceName)","+}","+","+func TestReader_FindTraceSummaries_QueryRejectionSkipsStorage(t *testing.T) {","+\tsentinel := errors.New(\"denied\")","+\tnext := &fakeReader{summaries: []tracestore.TraceSummary{{}}}","+\tr := NewReaderDecorator(next, fakeInterceptor{","+\t\tonQuery: func(q pub.Query) (pub.Query, error) { return q, sentinel },","+\t})","+","+\tvar err error","+\tfor _, e := range r.FindTraceSummaries(context.Background(), tracestore.TraceQueryParams{}) {","+\t\terr = e","+\t}","+\trequire.ErrorIs(t, err, sentinel)","+\tassert.False(t, next.summaryCalled, \"storage must not be queried when the query is rejected\")","+}","+","+func TestReader_FindTraceSummaries_StorageErrorPropagates(t *testing.T) {","+\tsentinel := errors.New(\"storage down\")","+\tnext := &fakeReader{summaryErr: sentinel}","+\tr := NewReaderDecorator(next, fakeInterceptor{})","+","+\tvar err error","+\tfor _, e := range r.FindTraceSummaries(context.Background(), tracestore.TraceQueryParams{}) {","+\t\terr = e","+\t}","+\trequire.ErrorIs(t, err, sentinel)","+}"],"additions":460,"deletions":0,"truncated":false},{"path":"cmd/jaeger/internal/extension/jaegerquery/queryinterceptor/resolver.go","lines":["@@ -0,0 +1,52 @@","+// Copyright (c) 2026 The Jaeger Authors.","+// SPDX-License-Identifier: Apache-2.0","+","+// Package queryinterceptor wires the public query-interceptor contract into","+// jaeger-query's read path: it resolves the configured interceptor extensions","+// from the collector host and decorates the storage Reader with them, converting","+// between the internal query type and the public Query at the boundary.","+//","+// The public contract that extensions implement — the Interceptor interface and","+// the Query type — lives at","+// github.com/jaegertracing/jaeger/components/extension/jaegerquery/queryinterceptor","+// and depends only on public packages. This package is jaeger-query-private","+// machinery and is not part of that contract.","+package queryinterceptor","+","+import (","+\t\"fmt\"","+","+\t\"go.opentelemetry.io/collector/component\"","+","+\tpub \"github.com/jaegertracing/jaeger/components/extension/jaegerquery/queryinterceptor\"","+)","+","+// Resolve looks up the extensions named by ids on the collector host and asserts","+// that each implements the public Interceptor contract, returning them in order.","+// An empty ids slice yields no interceptors (and no error).","+//","+// This mirrors the OpenTelemetry Collector's auth-extension mechanism: a","+// component references an extension by component.ID in its config and resolves","+// it from host.GetExtensions() at start time.","+func Resolve(host component.Host, ids []component.ID) ([]pub.Interceptor, error) {","+\tif len(ids) == 0 {","+\t\treturn nil, nil","+\t}","+\textensions := host.GetExtensions()","+\tinterceptors := make([]pub.Interceptor, 0, len(ids))","+\tfor _, id := range ids {","+\t\tcomp, ok := extensions[id]","+\t\tif !ok {","+\t\t\treturn nil, fmt.Errorf(","+\t\t\t\t\"cannot find query interceptor extension %q (make sure it is defined under extensions: and enabled in service.extensions)\",","+\t\t\t\tid,","+\t\t\t)","+\t\t}","+\t\tinterceptor, ok := comp.(pub.Interceptor)","+\t\tif !ok {","+\t\t\treturn nil, fmt.Errorf(\"extension %q does not implement queryinterceptor.Interceptor\", id)","+\t\t}","+\t\tinterceptors = append(interceptors, interceptor)","+\t}","+\treturn interceptors, nil","+}"],"additions":52,"deletions":0,"truncated":false},{"path":"cmd/jaeger/internal/extension/jaegerquery/queryinterceptor/resolver_test.go","lines":["@@ -0,0 +1,68 @@","+// Copyright (c) 2026 The Jaeger Authors.","+// SPDX-License-Identifier: Apache-2.0","+","+package queryinterceptor","+","+import (","+\t\"context\"","+\t\"testing\"","+","+\t\"github.com/open-telemetry/opentelemetry-collector-contrib/extension/storage/storagetest\"","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+\t\"go.opentelemetry.io/collector/component\"","+\t\"go.opentelemetry.io/collector/pdata/ptrace\"","+","+\tpub \"github.com/jaegertracing/jaeger/components/extension/jaegerquery/queryinterceptor\"","+)","+","+// stubInterceptor is both a component.Component (an OTel extension) and a public","+// Interceptor — the shape a real plugin must have.","+type stubInterceptor struct{}","+","+func (stubInterceptor) Start(context.Context, component.Host) error { return nil }","+func (stubInterceptor) Shutdown(context.Context) error              { return nil }","+func (stubInterceptor) OnQuery(_ context.Context, q pub.Query) (pub.Query, error) {","+\treturn q, nil","+}","+","+func (stubInterceptor) OnResult(_ context.Context, t []ptrace.Traces) ([]ptrace.Traces, error) {","+\treturn t, nil","+}","+","+// plainExtension is an extension that does NOT implement Interceptor.","+type plainExtension struct{}","+","+func (plainExtension) Start(context.Context, component.Host) error { return nil }","+func (plainExtension) Shutdown(context.Context) error              { return nil }","+","+func TestResolve(t *testing.T) {","+\tinterceptorID := component.MustNewID(\"query_interceptor_example\")","+\tplainID := component.MustNewID(\"expvar\")","+","+\thost := storagetest.NewStorageHost().","+\t\tWithExtension(interceptorID, stubInterceptor{}).","+\t\tWithExtension(plainID, plainExtension{})","+","+\tt.Run(\"no ids\", func(t *testing.T) {","+\t\tgot, err := Resolve(host, nil)","+\t\trequire.NoError(t, err)","+\t\tassert.Empty(t, got)","+\t})","+","+\tt.Run(\"resolves in order\", func(t *testing.T) {","+\t\tgot, err := Resolve(host, []component.ID{interceptorID})","+\t\trequire.NoError(t, err)","+\t\trequire.Len(t, got, 1)","+\t})","+","+\tt.Run(\"missing extension\", func(t *testing.T) {","+\t\t_, err := Resolve(host, []component.ID{component.MustNewID(\"nonexistent\")})","+\t\trequire.ErrorContains(t, err, \"cannot find query interceptor extension\")","+\t})","+","+\tt.Run(\"wrong type\", func(t *testing.T) {","+\t\t_, err := Resolve(host, []component.ID{plainID})","+\t\trequire.ErrorContains(t, err, \"does not implement queryinterceptor.Interceptor\")","+\t})","+}"],"additions":68,"deletions":0,"truncated":false},{"path":"cmd/jaeger/internal/extension/jaegerquery/server.go","lines":["@@ -15,6 +15,7 @@ import ("," "," \tqueryapp \"github.com/jaegertracing/jaeger/cmd/jaeger/internal/extension/jaegerquery/internal\""," \t\"github.com/jaegertracing/jaeger/cmd/jaeger/internal/extension/jaegerquery/internal/jaegerai/aihealth\"","+\t\"github.com/jaegertracing/jaeger/cmd/jaeger/internal/extension/jaegerquery/queryinterceptor\""," \t\"github.com/jaegertracing/jaeger/cmd/jaeger/internal/extension/jaegerquery/querysvc\""," \t\"github.com/jaegertracing/jaeger/cmd/jaeger/internal/extension/jaegerstorage\""," \t\"github.com/jaegertracing/jaeger/internal/metrics\"","@@ -48,10 +49,16 @@ func newServer(config *Config, otel component.TelemetrySettings) *server {"," \t}"," }"," ","-// Dependencies implements extensioncapabilities.Dependent","-// to ensure this always starts after jaegerstorage extension.","-func (*server) Dependencies() []component.ID {","-\treturn []component.ID{jaegerstorage.ID}","+// Dependencies implements extensioncapabilities.Dependent so the collector","+// starts this extension after the ones it consumes: the jaegerstorage extension","+// (for the trace reader) and every configured query-interceptor extension. The","+// latter guarantees each interceptor's own Start has run before jaeger-query","+// begins serving queries, so it is ready when OnQuery/OnResult are invoked.","+func (s *server) Dependencies() []component.ID {","+\tdeps := make([]component.ID, 0, 1+len(s.config.QueryInterceptors))","+\tdeps = append(deps, jaegerstorage.ID)","+\tdeps = append(deps, s.config.QueryInterceptors...)","+\treturn deps"," }"," "," func (s *server) Start(ctx context.Context, host component.Host) error {","@@ -71,6 +78,19 @@ func (s *server) Start(ctx context.Context, host component.Host) error {"," \t\treturn fmt.Errorf(\"cannot create trace reader: %w\", err)"],"additions":11,"deletions":4,"truncated":false}],"additions":797,"deletions":4,"truncated":true,"file_count":7},"error":null,"fetched_at":"2026-07-22T10:13:30.919703+00:00"}