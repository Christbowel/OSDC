ce-storage equivalent today.","+\t\treturn undefined;","+\t}","+","+\tgetWriteRoots(): readonly URI[] {","+\t\treturn this._workingDirectory ? [this._workingDirectory] : [];","+\t}","+","+\tasync checkSandboxDependencies(): Promise<ISandboxDependencyStatus | undefined> {","+\t\treturn this._sandboxHelper.checkSandboxDependencies();","+\t}","+","+\tasync getWindowsMxcFilesystemPolicy() {","+\t\treturn this._sandboxHelper.getWindowsMxcFilesystemPolicy();","+\t}","+","+\tasync getWindowsMxcEnvironment() {","+\t\treturn this._sandboxHelper.getWindowsMxcEnvironment();","+\t}","+","+\tgetSandboxSetting<T>(settingId: string): T | undefined {","+\t\t// The agent host stores sandbox settings nested under a single","+\t\t// top-level `sandbox` object with prefix-free sub-keys (e.g.","+\t\t// `sandbox.enabled` rather than `chat.agent.sandbox.enabled`). Map","+\t\t// from the engine's modern setting ID into that sub-key namespace;","+\t\t// unknown IDs (which include all deprecated keys — handled host-side","+\t\t// by the workbench client) resolve to undefined.","+\t\tconst innerKey = sandboxSettingIdToAgentHostKey[settingId];","+\t\tif (innerKey === undefined) {","+\t\t\treturn undefined;","+\t\t}","+\t\tconst sandbox = this._agentConfigurationService.getRootValue(sandboxConfigSchema, AgentHostSandboxConfigKey.Sandbox);","+\t\treturn sandbox?.[innerKey] as T | undefined;","+\t}","+}","+","+/**","+ * Construct a per-session {@link TerminalSandboxEngine} for the agent host.","+ * The returned engine is registered with the caller's instantiation service","+ * but the caller is responsible for disposing it (typically by registering it","+ * alongside the per-session {@link ShellManager}).","+ */","+export function createAgentHostSandboxEngine(","+\tinstantiationService: IInstantiationService,","+\tenvironmentService: IEnvironmentService,","+\tproductService: IProductService,","+\tagentConfigurationService: IAgentConfigurationService,","+\tsandboxHelper: ISandboxHelperService,","+