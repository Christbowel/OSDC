eSystem = 'fileSystem.mac',","+\tWindowsFileSystem = 'fileSystem.windows',","+\tAdvancedRuntime = 'advanced.runtime',","+\tAllowedNetworkDomains = 'allowedNetworkDomains',","+\tDeniedNetworkDomains = 'deniedNetworkDomains',","+}","+","+/** Shape of the persisted/forwarded `sandbox` object. */","+export type ISandboxConfigValue = Partial<{","+\t[AgentHostSandboxKey.Enabled]: AgentSandboxEnabledValue;","+\t[AgentHostSandboxKey.WindowsEnabled]: AgentSandboxEnabledValue;","+\t[AgentHostSandboxKey.AllowUnsandboxedCommands]: boolean;","+\t[AgentHostSandboxKey.AutoApproveUnsandboxedCommands]: boolean;","+\t[AgentHostSandboxKey.LinuxFileSystem]: Record<string, unknown>;","+\t[AgentHostSandboxKey.MacFileSystem]: Record<string, unknown>;","+\t[AgentHostSandboxKey.WindowsFileSystem]: Record<string, unknown>;","+\t[AgentHostSandboxKey.AdvancedRuntime]: Record<string, unknown>;","+\t[AgentHostSandboxKey.AllowedNetworkDomains]: string[];","+\t[AgentHostSandboxKey.DeniedNetworkDomains]: string[];","+}>;","+","+/**","+ * Schema for the subset of workbench sandbox settings that hosts (today: the","+ * workbench client) may forward into the agent host's root config bag.","+ *","+ * The agent host's terminal sandbox engine reads these values through","+ * {@link IAgentConfigurationService.getRootValue}. Only the modern,","+ * normalized form of each setting is declared here — the workbench is","+ * expected to:","+ *","+ *  - map the legacy boolean form of `chat.agent.sandbox.enabled` to the","+ *    `'on' | 'off' | 'allowNetwork'` enum, and","+ *  - migrate values from any deprecated setting IDs to their modern key","+ *","+ * before pushing a `RootConfigChanged` action. That keeps the agent-host","+ * schema (and validation) free of backward-compat baggage.","+ */","+export const sandboxConfigSchema = createSchema({","+\t[AgentHostSandboxConfigKey.Sandbox]: schemaProperty<ISandboxConfigValue>({","+\t\ttype: 'object',","+\t\ttitle: localize('agentHost.config.sandbox.title', \"Agent Sandbox\"),","+\t\tproperties: {","+\t\t\t[AgentHostSandboxKey.Enabled]: {","+\t\t\t\ttype: 'string',","+\t\t\t\ttitle: localize('agentHost.config.sandbox.enabled.title', \"Sandbox Enabled\"),","+\t\t\t\tenum: [AgentSandboxEnabledValue.Off, AgentSandboxEnabledValue.On, AgentSandboxEnabledValue.AllowNetwork],","+\t\t\t},","+\t\t\t[AgentHostSandboxKey.WindowsEnabled]: {","+\t\t\t\ttype: 'string',","+\t\t\t\ttitle: localize('agentHost.config.sandbox.windowsEnabled.title', \"Sandbox Enabled (Windows)\"),","+\t\t\t\tenum: [AgentSandboxEnabledValue.Off, AgentSandboxEnabledValue.On, AgentSandboxEnabledValue.AllowNetwork],","+\t\t\t},","+\t\t\t[AgentHostSandboxKey.AllowUnsandboxedCommands]: {","+\t\t\t\ttype: 'boolean',","+\t\t\t\ttitle: localize('agentHost.config.sandbox.allowUnsandboxedCommands.title', \"Allow Unsandboxed Commands\"),","+\t\t\t},","+\t\t\t[AgentHostSandboxKey.AutoApproveUnsandboxedCommands]: {","+\t\t\t\ttype: 'boolean',","+\t\t\t\ttitle: localize('agentHost.config.sandbox.autoApproveUnsandboxedCommands.title', \"Auto-Approve Unsandboxed Commands\"),","+\t\t\t},","+\t\t\t[AgentHostSandboxKey.LinuxFileSystem]: {","+\t\t\t\ttype: 'object',","+\t\t\t\ttitle: localize('agentHost.config.sandbox.linuxFileSystem.title', \"Linux Sandbox Filesystem\"),","+\t\t\t},","+\t\t\t[AgentHostSandboxKey.MacFileSystem]: {","+\t\t\t\ttype: 'object',","+\t\t\t\ttitle: localize('agentHost.config.sandbox.macFileSystem.title', \"macOS Sandbox Filesystem\"),","+\t\t\t},","+\t\t\t[AgentHostSandboxKey.WindowsFileSystem]: {","+\t\t\t\ttype: 'object',","+\t\t\t\ttitle: localize('agentHost.config.sandbox.windowsFileSystem.title', \"Windows Sandbox Filesystem\"),","+\t\t\t},","+\t\t\t[AgentHostSandboxKey.AdvancedRuntime]: {","+\t\t\t\ttype: 'object',","+\t\t\t\ttitle: localize('agentHost.config.sandbox.advancedRuntime.title', \"Advanced Sandbox Runtime\"),","+\t\t\t},","+\t\t\t[AgentHostSandboxKey.AllowedNetworkDomains]: {","+\t\t\t\ttype: 'array',","+\t\t\t\ttitle: localize('agentHost.c