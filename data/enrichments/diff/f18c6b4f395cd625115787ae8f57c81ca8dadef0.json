de === 'cancelled') {","+\t\treturn 'userCancelled';","+\t}","+\treturn 'error';","+}","+","+/**","+ * Maps a tool call's contributor to the telemetry `toolSourceKind`. A tool with","+ * no contributor is provided by the agent host itself; an MCP contributor maps","+ * to `mcp` and a client contributor to `client`.","+ */","+export function toolSourceKindFromContributor(contributor: ToolCallContributor | undefined): string {","+\tif (!contributor) {","+\t\treturn 'agentHost';","+\t}","+\t// Widen to `string` so an unrecognized kind from a newer protocol version","+\t// falls through to a valid telemetry value rather than `undefined`.","+\tconst kind: string = contributor.kind;","+\tswitch (kind) {","+\t\tcase ToolCallContributorKind.MCP:","+\t\t\treturn 'mcp';","+\t\tcase ToolCallContributorKind.Client:","+\t\t\treturn 'client';","+\t\tdefault:","+\t\t\treturn kind;","+\t}","+}","+","+/** Per-tool-call timing state, keyed by `session:toolCallId`. */","+interface IToolCallTiming {","+\treadonly stopWatch: StopWatch;","+\treadonly provider: string;","+\treadonly session: string;","+\treadonly toolId: string;","+\treadonly toolSourceKind: string;","+}","+","+/**","+ * Tracks per-tool-call timing for agent host sessions and reports a","+ * `languageModelToolInvoked` event via the provided","+ * {@link AgentHostTelemetryReporter} when a tool call completes.","+ *","+ * Lifecycle per tool call:","+ *   1. {@link toolCallStarted} — begins a stopwatch and records the tool's","+ *      name and source kind (only the start action carries these)","+ *   2. {@link toolCallCompleted} — emits the telemetry event and clears state","+ *","+ * In-flight tool calls that never complete (e.g. the turn is cancelled mid","+ * tool call) are dropped via {@link clearSession} / {@link clear} so the","+ * tracking map cannot leak.","+ */","+export class AgentHostToolCallTracker {","+","+\tprivate readonly _toolCalls = new Map<string, IToolCallTiming>();","+","+\tconstructor(private readonly _reporter: AgentHostTelemetryReporter) { }","+","+\ttoolCallStarted(provider: string, session: string, toolCallId: string, toolName: string, contributor: ToolCallContributor | undefined): void {","+\t\tthis._toolCalls.set(this._key(session, toolCallId), {","+\t\t\tstopWatch: StopWatch.create(true),","+\t\t\tprovider,","+\t\t\tsession,","+\t\t\ttoolId: toolName,","+\t\t\ttoolSourceKind: toolSourceKindFromContributor(contributor),","+\t\t});","+\t}","+","+\ttoolCallCompleted(session: string, toolCallId: string, result: ToolCallResult): void {","+\t\tconst key = this._key(session, toolCallId);","+\t\tconst timing = this._toolCalls.get(key);","+\t\tif (!timing) {","+\t\t\t// No matching start: either the start was never observed, or this is","+\t\t\t// a duplicate completion (the entry was already consumed). Either","+\t\t\t// way, do not emit so volume stays accurate.","+\t\t\treturn;","+\t\t}","+\t\tthis._toolCalls.delete(key);","+","+\t\tthis._reporter.toolInvoked({","+\t\t\tprovider: timing.provider,","+\t\t\tsession: timing.session,","+\t\t\ttoolId: timing.toolId,","+\t\t\ttoolSourceKind: timing.toolSourceKind,","+\t\t\tresult: deriveToolInvokedResult(result),","+\t\t\tinvocationTimeMs: timing.stopWatch.elapsed(),","+\t\t});","+\t}","+","+\t/**","+\t * Drops any in-flight (never-completed) tool calls for a session. Called","+\t * when a turn ends or a session is torn down so the tracking map cannot","+\t * leak. A no-op in the normal case where every tool call completes.","+\t */","+\tclearSession(session: string): void {","+\t\tconst prefix = `${session}\\0`;","+\t\tfor (const key of this._toolCalls.keys()) {","+\t\t\tif (key.startsWith(prefix)) {","+\t\t\t\tthis._toolCalls.delete(key);","+\t\t\t}","+\t\t}","+\t}","+","+\tclear(): void {","+\t\tthis._toolCalls.clear();","+\t}","+","+\tprivate _key(session: string, toolCallId: string): string {","+\t\treturn `${session}\\0${toolCallId}`;","+\t}","+}"],"additions":132,"deletions":0,"truncated":false},{"path":"src/vs