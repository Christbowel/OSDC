 an optional read alias that spans both the data stream","+// and old indices.","+//","+// Data streams are append-only: every write uses the \"create\" bulk op type","+// (WriteOpCreate) instead of \"index\". The data stream name has no date suffix —","+// rollover into backing indices is handled by ES/OpenSearch via the lifecycle","+// policy referenced in the data stream's index template. See RFC 0004.","+type DataStreamRotation struct {","+\tdataStream string","+\treadAlias  string","+}","+","+var _ Rotation = (*DataStreamRotation)(nil)","+","+// NewDataStreamRotation creates a DataStreamRotation for the given data stream","+// name (e.g. \"jaeger.spans\" or \"prod.jaeger.spans\" when an index prefix is set).","+//","+// readAlias is optional: when non-empty, reads target the alias instead of the","+// data stream name directly. This lets operators unify the data stream and legacy","+// indices under a single alias during migration. Jaeger does not create or manage","+// that alias — it only queries it (see RFC 0004 §4.1).","+func NewDataStreamRotation(dataStream, readAlias string) *DataStreamRotation {","+\treturn &DataStreamRotation{","+\t\tdataStream: dataStream,","+\t\treadAlias:  readAlias,","+\t}","+}","+","+func (s *DataStreamRotation) WriteTarget(time.Time) string {","+\treturn s.dataStream","+}","+","+func (s *DataStreamRotation) ReadTargets(time.Time, time.Time) []string {","+\tif s.readAlias != \"\" {","+\t\treturn []string{s.readAlias}","+\t}","+\treturn []string{s.dataStream}","+}","+","+func (*DataStreamRotation) WriteOpType() es.WriteOpType     { return es.WriteOpCreate }","+func (*DataStreamRotation) RequiresDocumentTimestamp() bool { return true }"],"additions":54,"deletions":0,"truncated":false},{"path":"internal/storage/elasticsearch/indices/rotation_data_stream_test.go","lines":["@@ -0,0 +1,48 @@","+// Copyright (c) 2026 The Jaeger Authors.","+// SPDX-License-Identifier: Apache-2.0","+","+package indices","+","+import (","+\t\"testing\"","+\t\"time\"","+","+\t\"github.com/stretchr/testify/assert\"","+","+\tes \"github.com/jaegertracing/jaeger/internal/storage/elasticsearch\"","+)","+","+func TestDataStreamRotation_WriteTarget(t *testing.T) {","+\tr := NewDataStreamRotation(\"jaeger.spans\", \"\")","+\tdate := time.Date(2024, time.June, 18, 10, 0, 0, 0, time.UTC)","+\t// The write target is the data stream name itself, with no date suffix.","+\tassert.Equal(t, \"jaeger.spans\", r.WriteTarget(date))","+}","+","+func TestDataStreamRotation_ReadTargets_DataStreamName(t *testing.T) {","+\tr := NewDataStreamRotation(\"jaeger.spans\", \"\")","+\tstart := time.Date(2024, time.June, 17, 0, 0, 0, 0, time.UTC)","+\tend := time.Date(2024, time.June, 18, 0, 0, 0, 0, time.UTC)","+\t// With no read alias configured, reads go to the data stream name directly.","+\tassert.Equal(t, []string{\"jaeger.spans\"}, r.ReadTargets(start, end))","+}","+","+func TestDataStreamRotation_ReadTargets_ReadAliasOverride(t *testing.T) {","+\tr := NewDataStreamRotation(\"jaeger.spans\", \"jaeger-legacy-read-alias\")","+\tstart := time.Date(2024, time.June, 17, 0, 0, 0, 0, time.UTC)","+\tend := time.Date(2024, time.June, 18, 0, 0, 0, 0, time.UTC)","+\t// When a read alias is configured (migration), reads target the alias instead.","+\tassert.Equal(t, []string{\"jaeger-legacy-read-alias\"}, r.ReadTargets(start, end))","+}","+","+func TestDataStreamRotation_WriteOpType(t *testing.T) {","+\tr := NewDataStreamRotation(\"jaeger.spans\", \"\")","+\t// Data streams are append-only and require the \"create\" bulk op type.","+\tassert.Equal(t, es.WriteOpCreate, r.WriteOpType())","+}","+","+func TestDataStreamRotation_RequiresDocumentTimestamp(t *testing.T) {","+\tr := NewDataStreamRotation(\"jaeger.spans\", \"\")","+\t// Data streams have no date-suffixed index, so documents must carry a timestamp.","+\tassert.True(t, r.RequiresDocumentTimestamp())","+}"],"additions":48,"deletions":0,"truncated":false},{"path":"internal/storage/elasticsearch/indice