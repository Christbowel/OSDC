","-var CompatibilityCacheSize = 2000","-","-// compatCache stores the result of each template compatibility check, keyed by SHA-256 of the raw template.","-var compatCache atomic.Pointer[lruCache]","-","-// compatCacheCancel cancels the eviction goroutine of the current compatCache instance.","-var compatCacheCancel context.CancelFunc","-","-// compatCacheMu serialises concurrent calls to InitCompatibilityCache.","-var compatCacheMu sync.Mutex","-","-func init() {","-\tcompatCache.Store(newLRUCache(CompatibilityCacheSize))","-}","-","-// CacheEntryTTL is how long an unaccessed entry lives before being swept.","-var CacheEntryTTL = 1 * time.Hour","-","-// InitCompatibilityCache reinitialises the cache with the given size and starts background TTL eviction.","-// Safe to call multiple times (e.g. in tests): the previous eviction goroutine is stopped before the","-// new cache is installed.","-func InitCompatibilityCache(ctx context.Context, size int) {","-\tcompatCacheMu.Lock()","-\tdefer compatCacheMu.Unlock()","-\tif compatCacheCancel != nil {","-\t\tcompatCacheCancel()","-\t}","-\tCompatibilityCacheSize = size","-\tc := newLRUCache(CompatibilityCacheSize)","-\tif size > 0 {","-\t\tcacheCtx, cancel := context.WithCancel(ctx)","-\t\tcompatCacheCancel = cancel","-\t\tc.startEvictionLoop(cacheCtx)","-\t} else {","-\t\tcompatCacheCancel = nil","-\t}","-\tcompatCache.Store(c)","-}","-","-// templateHash returns the SHA-256 hex digest of s, used as the cache key.","-func templateHash(s string) string {","-\tsum := sha256.Sum256([]byte(s))","-\treturn fmt.Sprintf(\"%x\", sum)","-}","-","-// compatEntry is the cached result for a single template.","-// upgraded always holds the normalised (and possibly semantically rewritten) template.","-// requiresUpgrade is true only when semantic fixes were applied.","-type compatEntry struct {","-\trequiresUpgrade bool","-\tupgraded        string","-}","-","-// lruCache is a goroutine-safe LRU cache with TTL eviction.","-type lruCache struct {","-\tmu       sync.Mutex","-\tcapacity int","-\tll       *list.List","-\titems    map[string]*list.Element","-}","-","-type lruEntry struct {","-\tkey        string","-\tvalue      compatEntry","-\tlastAccess time.Time","-}","-","-func newLRUCache(capacity int) *lruCache {","-\treturn &lruCache{","-\t\tcapacity: capacity,","-\t\tll:       list.New(),","-\t\titems:    make(map[string]*list.Element, capacity),","-\t}","-}","-","-func (c *lruCache) startEvictionLoop(ctx context.Context) {","-\tgo func() {","-\t\tticker := time.NewTicker(CacheEntryTTL / 2)","-\t\tdefer ticker.Stop()","-\t\tfor {","-\t\t\tselect {","-\t\t\tcase <-ctx.Done():","-\t\t\t\treturn","-\t\t\tcase <-ticker.C:","-\t\t\t\tc.evictStale()","-\t\t\t}","-\t\t}","-\t}()","-}","-","-func (c *lruCache) evictStale() {","-\tc.mu.Lock()","-\tdefer c.mu.Unlock()","-\tnow := time.Now()","-\tfor key, el := range c.items {","-\t\tif now.Sub(el.Value.(*lruEntry).lastAccess) > CacheEntryTTL {","-\t\t\tc.ll.Remove(el)","-\t\t\tdelete(c.items, key)","-\t\t\tCUECompatCacheEvictionsTotal.WithLabelValues(\"ttl\").Inc()","-\t\t}","-\t}","-}","-","-func (c *lruCache) get(key string) (compatEntry, bool) {","-\tc.mu.Lock()","-\tdefer c.mu.Unlock()","-\tel, ok := c.items[key]","-\tif !ok {","-\t\treturn compatEntry{}, false","-\t}","-\tentry := el.Value.(*lruEntry)","-\tentry.lastAccess = time.Now()","-\tc.ll.MoveToFront(el)","-\treturn entry.value, true","-}","-","-func (c *lruCache) put(key string, value compatEntry) {","-\tif c.capacity <= 0 {","-\t\treturn","-\t}","-\tc.mu.Lock()","-\tdefer c.mu.Unlock()","-\tif el, ok := c.items[key]; ok {","-\t\tentry := el.Value.(*lruEntry)","-\t\tentry.value = value","-\t\tentry.lastAccess = time.Now()","-\t\tc.ll.MoveToFront(el)","-\t\treturn","-\t}","-\tif c.ll.Len() >= c.capacity {","-\t\toldest := c.ll.Back()","-\t\tif oldest != nil {","-\t\t\tc.ll.Remove(oldest)","-\t\t\tdelete(c.items, oldest.Value.(*lruEntry).key)","-\t\t\tCUECompatCacheEvictionsTotal.WithLabelValues(\"capacity\").Inc()","-\t\t}","-\t}","-\tel := c.ll.PushFront(&lruEntry{key: key, value: value, lastAccess: time.Now()})","-\tc.items[key] = el","-}","-","-func (c *lruCache) len() int {","-\tc.mu.Lock()","-\tdefer c.mu.Unlock()","-\treturn c.ll.Len()","-}"],"additions":0,"deletions":175,"truncated":false},{"path":"pkg/cue/upgrade/cache_test.go","lines":["@@ -1,120 +0,0 @@","-/*","-Copyright 2026 The KubeVela Authors.","-","-Licensed under the Apache License, Version 2.0 (the \"License\");","-you may not use this file except in compliance with the License.","-You may obtain a copy of the License at","-","-    http://www.apache.org/licenses/LICENSE-2.0"],"additions":0,"deletions":8,"truncated":false}],"additions":454,"deletions":208,"truncated":true,"file_count":14},"error":null,"fetched_at":"2026-07-04T10:48:30.283299+00:00"}