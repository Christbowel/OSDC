{"id":"7c44c4794943e2a74d4fc753c7931a66bb5a2707","axis":"silent","repo":"grafana/grafana","sha":"7c44c4794943e2a74d4fc753c7931a66bb5a2707","parsed":{"files":[{"path":"conf/defaults.ini","lines":["@@ -1007,9 +1007,11 @@ username_attribute_path ="," jwk_set_url ="," jwk_set_bearer_token_file ="," jwk_set_file =","+jwk_set_value ="," cache_ttl = 60m"," expect_claims = {}"," key_file =","+key_value ="," key_id ="," role_attribute_path ="," role_attribute_strict = false"],"additions":2,"deletions":0,"truncated":false},{"path":"conf/sample.ini","lines":["@@ -951,10 +951,14 @@"," ;jwk_set_url = https://foo.bar/.well-known/jwks.json"," ;jwk_set_bearer_token_file = /path/to/token/file"," ;jwk_set_file = /path/to/jwks.json","+# Inline JWKS, base64-encoded, as an alternative to jwk_set_file (e.g. base64 < jwks.json | tr -d '\\n')","+;jwk_set_value ="," ;cache_ttl = 60m"," ;expect_claims = {\"aud\": [\"foo\", \"bar\"]}"," ;key_file = /path/to/key/file","-# Use in conjunction with key_file in case the JWT token's header specifies a key ID in \"kid\" field","+# Inline PEM public key, base64-encoded, as an alternative to key_file (e.g. base64 < key.pub | tr -d '\\n')","+;key_value =","+# Use in conjunction with key_file or key_value in case the JWT token's header specifies a key ID in \"kid\" field"," ;key_id = some-key-id"," ;role_attribute_path ="," ;role_attribute_strict = false"],"additions":5,"deletions":1,"truncated":false},{"path":"docs/sources/setup-grafana/configure-access/configure-authentication/jwt/index.md","lines":["@@ -200,6 +200,28 @@ If the JWT token's header specifies a `kid` (Key ID), then the Key ID must be se"," key_id = my-key-id"," ```"," ","+### Verify token using an inline key or key set","+","+When you can't place a file on disk, put the key material directly in the configuration. This is useful when you provision configuration to a managed instance. Both options use the same content as their file-based counterparts, base64-encoded so it fits on one line.","+","+Inline a single PEM-encoded public key instead of `key_file`:","+","+```ini","+key_value = <base64-encoded PEM key>","+```","+","+Inline a JWKS document instead of `jwk_set_file`:","+","+```ini","+jwk_set_value = <base64-encoded JWKS JSON>","+```","+","+To generate a value from an existing file, run `base64 < key.pem | tr -d '\\n'`. The `key_id` option applies to `key_value` just as it does to `key_file`.","+","+{{< admonition type=\"note\" >}}","+Configure the key set with exactly one of `key_file`, `key_value`, `jwk_set_file`, `jwk_set_value`, or `jwk_set_url`. Setting more than one is an error.","+{{< /admonition >}}","+"," ## Validate claims"," "," By default, only `\"exp\"`, `\"nbf\"` and `\"iat\"` claims are validated."],"additions":22,"deletions":0,"truncated":false},{"path":"pkg/services/auth/jwt/auth_test.go","lines":["@@ -124,6 +124,92 @@ func TestIntegrationVerifyUsingJWKSetFile(t *testing.T) {"," \t}, configure)"," }"," ","+func TestIntegrationVerifyUsingPKIXPublicKeyValue(t *testing.T) {","+\ttestutil.SkipIntegrationTestInShortMode(t)","+","+\tkey := rsaKeys[0]","+\tunknownKey := rsaKeys[1]","+","+\tscenario(t, \"verifies a token\", func(t *testing.T, sc scenarioContext) {","+\t\ttoken := sign(t, key, jwt.Claims{","+\t\t\tSubject: subject,","+\t\t}, nil)","+\t\tverifiedClaims, err := sc.authJWTSvc.Verify(sc.ctx, token)","+\t\trequire.NoError(t, err)","+\t\tassert.Equal(t, verifiedClaims[\"sub\"], subject)","+\t}, configurePKIXPublicKeyValue)","+","+\tscenario(t, \"rejects a token signed by unknown key\", func(t *testing.T, sc scenarioContext) {","+\t\ttoken := sign(t, unknownKey, jwt.Claims{","+\t\t\tSubject: subject,","+\t\t}, nil)","+\t\t_, err := sc.authJWTSvc.Verify(sc.ctx, token)","+\t\trequire.Error(t, err)","+\t}, configurePKIXPublicKeyValue)","+","+\tpublicKeyID := \"some-key-id\"","+\tscenario(t, \"verifies a token with a specified kid\", func(t *testing.T, sc scenarioContext) {","+\t\ttoken := sign(t, key, jwt.Claims{","+\t\t\tSubject: