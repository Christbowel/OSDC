+\t\"net\"","+\t\"sort\"","+\t\"strconv\"","+\t\"strings\"","+\t\"sync\"","+\t\"sync/atomic\"","+\t\"time\"","+","+\t\"github.com/projectdiscovery/gologger\"","+\t\"github.com/projectdiscovery/nuclei/v3/pkg/catalog/loader\"","+\t\"github.com/projectdiscovery/nuclei/v3/pkg/input/provider\"","+\tinputtypes \"github.com/projectdiscovery/nuclei/v3/pkg/input/types\"","+\t\"github.com/projectdiscovery/nuclei/v3/pkg/protocols/common/contextargs\"","+\t\"github.com/projectdiscovery/nuclei/v3/pkg/protocols/common/protocolstate\"","+\t\"github.com/projectdiscovery/nuclei/v3/pkg/templates\"","+\t\"github.com/projectdiscovery/utils/errkit\"","+\tiputil \"github.com/projectdiscovery/utils/ip\"","+\tmapsutil \"github.com/projectdiscovery/utils/maps\"","+\tsliceutil \"github.com/projectdiscovery/utils/slice\"","+\tstringsutil \"github.com/projectdiscovery/utils/strings\"","+\tsyncutil \"github.com/projectdiscovery/utils/sync\"","+\turlutil \"github.com/projectdiscovery/utils/url\"","+)","+","+const preflightWorkers = 100","+","+// preflightDialTimeout is intentionally short: this is a coarse filter to skip","+// obviously-dead targets before the real scan (which will use full timeouts).","+const preflightDialTimeout = 750 * time.Millisecond","+","+type filteringInputProvider struct {","+\tbase     provider.InputProvider","+\tallowed  *mapsutil.SyncLockMap[string, struct{}]","+\tallowCnt int64","+\texecID   string","+}","+","+func (f *filteringInputProvider) Count() int64      { return f.allowCnt }","+func (f *filteringInputProvider) InputType() string { return f.base.InputType() }","+func (f *filteringInputProvider) Close()            { f.base.Close() }","+func (f *filteringInputProvider) Set(executionId string, value string) {","+\tf.base.Set(executionId, value)","+}","+func (f *filteringInputProvider) SetWithProbe(executionId string, value string, probe inputtypes.InputLivenessProbe) error {","+\treturn f.base.SetWithProbe(executionId, value, probe)","+}","+func (f *filteringInputProvider) SetWithExclusions(executionId string, value string) error {","+\treturn f.base.SetWithExclusions(executionId, value)","+}","+func (f *filteringInputProvider) Iterate(callback func(value *contextargs.MetaInput) bool) {","+\tf.base.Iterate(func(mi *contextargs.MetaInput) bool {","+\t\tkey, err := mi.MarshalString()","+\t\tif err != nil {","+\t\t\treturn callback(mi)","+\t\t}","+\t\tif _, ok := f.allowed.Get(key); !ok {","+\t\t\treturn true","+\t\t}","+\t\treturn callback(mi)","+\t})","+}","+","+// preflightResolveAndPortScan resolves hostname targets and performs a TCP connect scan for ports","+// required by loaded templates. Targets that are non-resolvable hostnames or have no relevant open","+// ports are filtered out from the input provider.","+func (r *Runner) preflightResolveAndPortScan(store *loader.Store) error {","+\tif r.inputProvider == nil {","+\t\treturn nil","+\t}","+\t// MultiFormat inputs may represent complete requests; skip preflight for now.","+\tif r.inputProvider.InputType() == provider.MultiFormatInputProvider {","+\t\treturn nil","+\t}","+","+\tfinalTemplates := []*templates.Template{}","+\tfinalTemplates = append(finalTemplates, store.Templates()...)","+\tfinalTemplates = append(finalTemplates, store.Workflows()...)","+\tif len(finalTemplates) == 0 {","+\t\treturn nil","+\t}","+","+\tdialers := protocolstate.GetDialersWithId(r.options.ExecutionId)","+\tif dialers == nil || dialers.Fastdialer == nil {","+\t\treturn fmt.Errorf(\"dialers not initialized for %s\", r.options.ExecutionId)","+\t}","+","+\tportsPopularity := portsPopularityFromTemplates(finalTemplates)","+\t// Also include ports explicitly present in input list (ip:port or URL with port),","+\t// so that a user-provided port isn't dropped even if templates didn't specify it.","+\tvar inputs []preflightTarget","+\tportsFromInputs := map[string]struct{}{}","+\tvar totalTargets atomic.Int64","+\tr.inputProvider.Iterate(func(mi *contextargs.MetaInput) bool {","+\t\ttotalTargets.Add(1)","+\t\tkey, err := mi.MarshalString()","+\t\tif err != nil {","+\t\t\treturn true","+\t\t}","+\t\t// Use Target()/CustomIP so preflight resolves the same address the real","+\t\t// scan would connect to (honors ReqResp-backed targets and CustomIP),","+\t\t// instead of only the raw Input which can mismatch routing state.","+\t\tinputs = append(inputs, preflightTarget{key: key, target: mi.Target(), customIP: mi.CustomIP})","+\t\textractPortsFromInput(portsFromInputs, mi.Target())","+\t\treturn true","+\t})","+","+\tportsToScan := sliceutil.Dedupe(append(keysOfPopularity(portsPopularity), keysOf(portsFromInputs)...))","+\tportsToScan = filterValidPorts(portsToScan)","+\t// Sort by \"likely-open\" order (nmap-ish/common ports first), then numeric for determinism.","+\tlikelyRank := likelyOpenPortRank()","+\tsort.Slice(portsToScan, func(i, j int) bool {","+\t\tpi, pj := portsToScan[i], portsToScan[j]","+\t\tri, okRi := likelyRank[pi]","+\t\trj, okRj := likelyRank[pj]","+\t\t// ranked ports first","+\t\tif okRi != okRj {","+\t\t\treturn okRi","+\t\t}","+\t\t// among ranked ports, lower rank wins","+\t\tif okRi && okRj && ri != rj {","+\t\t\treturn ri < rj","+\t\t}","+\t\t// numeric asc","+\t\tni, _ := strconv.Atoi(pi)","+\t\tnj, _ := strconv.Atoi(pj)","+\t\treturn ni < nj","+\t})","+","+\t// If no ports were found, nothing to scan -> keep all.","+\tif len(portsToScan) == 0 {","+\t\treturn nil","+\t}","+","+\tif !r.options.Silent {","+\t\tr.Logger.Info().Msgf(\"Running preflight portscan (workers=%d, ports=%d, targets=%d)\", preflightWorkers, len(portsToScan), totalTargets.Load())","+\t}","+","+\tswg, err := syncutil.New(syncutil.WithSize(preflightWorkers))","+\tif err != nil {","+\t\treturn err","+\t}","+","+\t// Resolve all targets (once) up-front so we can optionally run a single batched TCP dial scan.","+\t// Map original input key -> resolved IPs (deduped).","+\t// SyncLockMap requires comparable values; store resolved IPs as a comma-separated string.","+\tresolvedIPsByKey := mapsutil.NewSyncLockMap[string, string]()","+\tallIPsSet := mapsutil.NewSyncLockMap[string, struct{}]()","+\tvar resolveProcessed atomic.Int64","+\tvar resolveDNSFail atomic.Int64","+","+\tfor _, t := range inputs {","+\t\tswg.Add()","+\t\tgo func(t preflightTarget) {","+\t\t\tdefer swg.Done()","+\t\t\thost, _, _, _ := hostForResolveAndScan(t.target)","+\t\t\tif t.customIP != \"\" {","+\t\t\t\thost = t.customIP","+\t\t\t}","+\t\t\tif host == \"\" {","+\t\t\t\tresolveDNSFail.Add(1)","+\t\t\t\tresolveProcessed.Add(1)","+\t\t\t\treturn","+\t\t\t}","+\t\t\tips := []string{}","+\t\t\tif iputil.IsIP(host) {","+\t\t\t\tips = append(ips, host)","+\t\t\t} else {","+\t\t\t\tdns, err := dialers.Fastdialer.GetDNSData(host)","+\t\t\t\tif err != nil || (len(dns.A) == 0 && len(dns.AAAA) == 0) {","+\t\t\t\t\tresolveDNSFail.Add(1)","+\t\t\t\t\tresolveProcessed.Add(1)","+\t\t\t\t\treturn","+\t\t\t\t}","+\t\t\t\tips = append(ips, dns.A...)","+\t\t\t\tips = append(ips, dns.AAAA...)","+\t\t\t}","+\t\t\tips = sliceutil.Dedupe(ips)","+\t\t\tif len(ips) == 0 {","+\t\t\t\tresolveDNSFail.Add(1)","+\t\t\t\tresolveProcessed.Add(1)","+\t\t\t\treturn","+\t\t\t}","+","+\t\t\t// store","+\t\t\t// (small contention; acceptable at preflight scale)","+\t\t\t_ = resolvedIPsByKey.Set(t.key, strings.Join(ips, \",\"))","+\t\t\tfor _, ip := range ips {","+\t\t\t\t_ = allIPsSet.Set(ip, struct{}{})","+\t\t\t}","+\t\t\tresolveProcessed.Add(1)","+\t\t}(t)","+\t}","+\tswg.Wait()","+","+\t// Prepare list of all IPs for scan.","+\tallIPsMap := allIPsSet.GetAll()","+\tallIPs := make([]string, 0, len(allIPsMap))","+\tfor ip := range allIPsMap {","+\t\tallIPs = append(allIPs, ip)","+\t}","+\tsort.Strings(allIPs)","+","+\t// we do fast TCP dial scanning against resolved IPs.","+\tif !r.options.Silent {","+\t\tr.Logger.Info().Msgf(\"Preflight resolution: total=%d resolvable=%d unresolvable=%d\", totalTargets.Load(), int64(len(resolvedIPsByKey.GetAll())), resolveDNSFail.Load())","+\t}","+","+\tallowed := mapsutil.NewSyncLockMap[string, struct{}]()","+","+\tvar dnsFail atomic.Int64","+\tvar portFail atomic.Int64","+\tvar kept atomic.Int64","+\tvar processed atomic.Int64","+","+\tperPortOpen := mapsutil.NewSyncLockMap[string, *atomic.Int64]()","+","+\t// Periodic progress logging","+\t// Always enabled unless running in silent mode.","+\tdebugProgress := true","+\tstopProgress := make(chan struct{})","+\tif debugProgress && !r.options.Silent {","+\t\tstart := time.Now()","+\t\tgo func() {","+\t\t\tt := time.NewTicker(1 * time.Second)","+\t\t\tdefer t.Stop()","+\t\t\tvar lastProcessed int64","+\t\t\tfor {","+\t\t\t\tselect {","+\t\t\t\tcase <-t.C:","+\t\t\t\t\tp := processed.Load()","+\t\t\t\t\tif p == lastProcessed {","+\t\t\t\t\t\tcontinue","+\t\t\t\t\t}","+\t\t\t\t\tlastProcessed = p","+\t\t\t\t\ttotal := totalTargets.Load()","+\t\t\t\t\tk := kept.Load()","+\t\t\t\t\tdf := dnsFail.Load()","+\t\t\t\t\tpf := portFail.Load()","+\t\t\t\t\tdropped := p - k","+\t\t\t\t\tr.Logger.Info().Msgf(\"Preflight progress: %d/%d processed (kept=%d dropped=%d dns_fail=%d port_fail=%d elapsed=%s)\",","+\t\t\t\t\t\tp, total, k, dropped, df, pf, time.Since(start).Truncate(time.Second))","+\t\t\t\tcase <-stopProgress:","+\t\t\t\t\treturn","+\t\t\t\t}","+\t\t\t}","+\t\t}()","+\t}","+","+\tfor _, t := range inputs {","+\t\tswg.Add()","+\t\tgo func(t preflightTarget) {","+\t\t\tdefer swg.Done()","+\t\t\tok, openPort, reason := r.preflightOneResolved(t.key, t.target, portsToScan, resolvedIPsByKey)","+\t\t\tprocessed.Add(1)","+\t\t\tif ok {","+\t\t\t\t_ = allowed.Set(t.key, struct{}{})","+\t\t\t\tkept.Add(1)","+\t\t\t\tif openPort != \"\" {","+\t\t\t\t\tcounter, _ := perPortOpen.Get(openPort)","+\t\t\t\t\tif counter == nil {","+\t\t\t\t\t\tcounter = &atomic.Int64{}","+\t\t\t\t\t\t_ = perPortOpen.Set(openPort, counter)","+\t\t\t\t\t}","+\t\t\t\t\tcounter.Add(1)","+\t\t\t\t}","+\t\t\t\treturn","+\t\t\t}","+\t\t\tswitch reason {","+\t\t\tcase preflightReasonDNS:","+\t\t\t\tdnsFail.Add(1)","+\t\t\tcase preflightReasonPorts:","+\t\t\t\tportFail.Add(1)","+\t\t\t}","+\t\t}(t)","+\t}","+\tswg.Wait()","+\tclose(stopProgress)","+","+\t// Apply filtering wrapper","+\tallowedAll := allowed.GetAll()","+\tr.inputProvider = &filteringInputProvider{","+\t\tbase:     r.inputProvider,","+\t\tallowed:  allowed,","+\t\tallowCnt: int64(len(allowedAll)),","+\t\texecID:   r.options.ExecutionId,","+\t}","+","+\t// Summary","+\tif !r.options.Silent {","+\t\tdropped := totalTargets.Load() - kept.Load()","+\t\tr.Logger.Info().Msgf(\"Preflight summary: total=%d kept=%d filtered_dns=%d filtered_ports=%d\",","+\t\t\ttotalTargets.Load(), kept.Load(), dnsFail.Load(), portFail.Load())","+\t\tr.Logger.Info().Msgf(\"Preflight targets: dropped=%d left=%d\", dropped, kept.Load())","+\t\tperPortOpenAll := perPortOpen.GetAll()","+\t\tif len(perPortOpenAll) > 0 {","+\t\t\ttype kv struct {","+\t\t\t\tport  string","+\t\t\t\tcount int64","+\t\t\t}","+\t\t\tkvs := make([]kv, 0, len(perPortOpenAll))","+\t\t\tfor p, c := range perPortOpenAll {","+\t\t\t\tif c == nil {","+\t\t\t\t\tcontinue","+\t\t\t\t}","+\t\t\t\tkvs = append(kvs, kv{port: p, count: c.Load()})","+\t\t\t}","+\t\t\tsort.Slice(kvs, func(i, j int) bool {","+\t\t\t\tif kvs[i].count == kvs[j].count {","+\t\t\t\t\treturn kvs[i].port < kvs[j].port","+\t\t\t\t}","+\t\t\t\treturn kvs[i].count > kvs[j].count","+\t\t\t})","+\t\t\tparts := make([]string, 0, len(kvs))","+\t\t\tfor _, item := range kvs {","+\t\t\t\tparts = append(parts, fmt.Sprintf(\"%s=%d\", item.port, item.count))","+\t\t\t}","+\t\t\tr.Logger.Info().Msgf(\"Preflight open-port distribution: %s\", strings.Join(parts, \" \"))","+\t\t}","+\t}","+","+\t_ = gologger.DefaultLogger // ensure logger imported even when silent builds vary","+\treturn nil","+}","+","+type preflightTarget struct {","+\tkey      string","+\ttarget   string","+\tcustomIP string","+}","+","+type preflightReason int","+","+const (","+\tpreflightReasonNone preflightReason = iota","+\tpreflightReasonDNS","+\tpreflightReasonPorts","+)","+","+func (r *Runner) preflightOneResolved(key string, raw string, ports []string, resolved *mapsutil.SyncLockMap[string, string]) (ok bool, openPort string, reason preflightReason) {","+\tresolvedIPsCSV, _ := resolved.Get(key)","+\tif resolvedIPsCSV == \"\" {","+\t\treturn false, \"\", preflightReasonDNS","+\t}","+\tips := strings.Split(resolvedIPsCSV, \",\")","+","+\t// TCP dial scan using resolved IPs","+\thost, schemePort, hasSchemePort, _ := hostForResolveAndScan(raw)","+\tordered := ports","+\tif hasSchemePort && schemePort != \"\" {","+\t\tordered = append([]string{schemePort}, ports...)","+\t\tordered = sliceutil.Dedupe(ordered)","+\t}","+","+\ttimeout := preflightDialTimeout","+\tif r.options.Timeout > 0 {","+\t\tt := time.Duration(r.options.Timeout) * time.Second","+\t\tif t > 0 && t < timeout {","+\t\t\ttimeout = t","+\t\t}","+\t}","+\t// Use net.Dialer directly for strict timeout enforcement.","+\t// We already resolved IPs, so we don't need fastdialer DNS behavior here.","+\t// This avoids rare cases where proxy dialers / custom dial stacks may not respect ctx cancellation promptly.","+\td := &net.Dialer{Timeout: timeout}","+","+\t// Per-host parallelism: probe up to 3 ports concurrently, stop on first success.","+\tctx, cancelAll := context.WithCancel(context.Background())","+\tdefer cancelAll()","+","+\ttype hit struct {","+\t\tport string","+\t}","+\tresultCh := make(chan hit, 1)","+\tportsCh := make(chan string)","+","+\tworker := func() {","+\t\tfor p := range portsCh {","+\t\t\t// Stop quickly if someone already found an open port.","+\t\t\tselect {","+\t\t\tcase <-ctx.Done():","+\t\t\t\treturn","+\t\t\tdefault:","+\t\t\t}","+","+\t\t\tfor _, ip := range ips {","+\t\t\t\t_ = host // keep for debugging parity","+\t\t\t\tdctx, cancel := context.WithTimeout(ctx, timeout)","+\t\t\t\tconn, err := d.DialContext(dctx, \"tcp\", net.JoinHostPort(ip, p))","+\t\t\t\tcancel()","+\t\t\t\tif err == nil {","+\t\t\t\t\t_ = conn.Close