, err = fs.Glob(c.templatesFS, relPath)"," \t} else {"," \t\tmatches, err = filepath.Glob(absPath)"],"additions":18,"deletions":10,"truncated":false},{"path":"pkg/catalog/disk/find_test.go","lines":["@@ -0,0 +1,58 @@","+package disk","+","+import (","+\t\"testing/fstest\"","+\t\"path/filepath\"","+\t\"testing\"","+","+\t\"github.com/stretchr/testify/require\"","+)","+","+// TestFindGlobPathMatchesUsesCanonicalContainment ensures that when an","+// absPath shares a lexical prefix with templatesDirectory but is not actually","+// inside it (a sibling-prefix path), the embedded-FS lookup does NOT silently","+// strip part of the prefix and resolve into the templates root.","+func TestFindGlobPathMatchesUsesCanonicalContainment(t *testing.T) {","+\t// Build a small in-memory FS that simulates an embedded templates tree","+\t// and a sibling tree. fs.Glob is rooted at the FS root, so the test","+\t// asserts that with the buggy prefix-trim a sibling-prefix glob would","+\t// match the in-bounds entry; with the fix it does not.","+\tmemFS := fstest.MapFS{","+\t\t\"http/test.yaml\":      {Data: []byte(\"legit\")},","+\t\t\"http-evil/test.yaml\": {Data: []byte(\"sibling\")},","+\t}","+","+\ttemplatesDir := filepath.Join(t.TempDir(), \"templates\")","+","+\tcat := NewFSCatalog(memFS, templatesDir)","+","+\t// Glob for siblings of templatesDir (the previous TrimPrefix would have","+\t// silently aliased \"/.../templates-evil/*.yaml\" into \"-evil/*.yaml\" and","+\t// then collapsed to a glob with no leading separator that ran against","+\t// memFS root — observable as confused matches in production code paths","+\t// that rely on this method).","+\tsibling := templatesDir + \"-evil\"","+\tmatches, err := cat.findGlobPathMatches(filepath.Join(sibling, \"*.yaml\"), map[string]struct{}{})","+\trequire.NoError(t, err)","+\t// Whatever the glob produces, it must NOT include the in-bounds","+\t// http/test.yaml from inside the templates directory.","+\tfor _, m := range matches {","+\t\trequire.NotContains(t, m, \"http/test.yaml\",","+\t\t\t\"sibling-prefix glob must not alias into the templates root\")","+\t}","+}","+","+func TestFindGlobPathMatchesResolvesContainedPath(t *testing.T) {","+\tmemFS := fstest.MapFS{","+\t\t\"http/test.yaml\": {Data: []byte(\"legit\")},","+\t}","+","+\ttemplatesDir := filepath.Join(t.TempDir(), \"templates\")","+\tcat := NewFSCatalog(memFS, templatesDir)","+","+\t// A glob that lives inside templatesDir resolves correctly via the","+\t// canonical relative path (no surprises from the rewrite).","+\tmatches, err := cat.findGlobPathMatches(filepath.Join(templatesDir, \"http\", \"*.yaml\"), map[string]struct{}{})","+\trequire.NoError(t, err)","+\trequire.Equal(t, []string{\"http/test.yaml\"}, matches)","+}"],"additions":58,"deletions":0,"truncated":false},{"path":"pkg/catalog/disk/path.go","lines":["@@ -5,12 +5,10 @@ import ("," \t\"io/fs\""," \t\"os\""," \t\"path/filepath\"","-\t\"strings\""," "," \t\"github.com/pkg/errors\""," \t\"github.com/projectdiscovery/nuclei/v3/pkg/catalog/config\""," \tfileutil \"github.com/projectdiscovery/utils/file\"","-\turlutil \"github.com/projectdiscovery/utils/url\""," )"," "," // ResolvePath resolves the path to an absolute one in various ways.","@@ -69,51 +67,3 @@ func (c *DiskCatalog) tryResolve(fullPath string) (string, error) {"," \t}"," \treturn \"\", errNoValidCombination"," }","-","-// BackwardsCompatiblePaths returns new paths for all old/legacy template paths","-// Note: this is a temporary function and will be removed in the future release","-//","-// Deprecated: No longer used since the official Nuclei Templates repository","-// have restructured this a long time ago.","-func BackwardsCompatiblePaths(templateDir string, oldPath string) string {","-\t// TODO: remove this function in the future release","-\t// 1. all http related paths are now moved at path /http","-\t// 2. network related CVES are now moved at path /network/cves","-\tnewPathCallback := func(path string) string {","-\t\t// trim prefix slash if any","-\t\tpath = strings.TrimPrefix(path, \"/\")","-\t\t// try to resolve path at /http subdirectory","-\t\tif fileutil.FileOrFolderExists(filepath.Join(templateDir, \"http\", path)) {","-\t\t\treturn filepath.Join(templateDir, \"http\", path)","-\t\t\t// try to resolve path at /network/cves subdirectory","-\t\t} else if strings.HasPrefix(path, \"cves\") && fileutil.FileOrFolderExists(filepath.Join(templateDir, \"network\", \"cves\", path)) {","-\t\t\treturn filepath.Join(templateDir, \"network\", \"cves\", path)","-\t\t}","-\t\t// most likely the path is not found","-\t\treturn filepath.Join(templateDir, path)","-\t}","-\tswitch {","-\tcase fileutil.FileOrFolderExists(oldPath):","-\t\t// new path specified skip processing","-\t\treturn oldPath","-\tcase filepath.IsAbs(oldPath):","-\t\ttmp := strings.TrimPrefix(oldPath, templateDir)","-\t\tif tmp == oldPath {","-\t\t\t// user provided absolute path which is not in template directory","-\t\t\t// skip processing","-\t\t\treturn oldPath","-\t\t}","-\t\t// trim the template directory from the path","-\t\treturn newPathCallback(tmp)","-\tcase strings.Contains(oldPath, urlutil.SchemeSeparator):","-\t\t// scheme separator is used to identify the path as url","-\t\t// TBD: add support for url directories ??","-\t\treturn oldPath","-\tcase strings.Contains(oldPath, \"*\"):","-\t\t// this is most likely a glob path skip processing","-\t\treturn oldPath","-\tdefault:","-\t\t// this is most likely a relative path","-\t\treturn newPathCallback(oldPath)","-\t}","-}"],"additions":0,"deletions":50,"truncated":false},{"path":"pkg/external/customtemplates/azure_blob.go","lines":["@@ -89,8 +89,16 @@ func (bk *customTemplateAzureBlob) Download(ctx context.Context) {"," \t\tfor _, blob := range resp.Segment.BlobItems {"," \t\t\t// If the blob is a .yaml download the file to the local filesystem"," \t\t\tif strings.HasSuffix(*blob.Name, \".yaml\") {","+\t\t\t\t// Resolve the destination path safely so a blob name carrying","+\t\t\t\t// path-traversal segments cannot escape the configured download","+\t\t\t\t// directory.","+\t\t\t\toutputPath, err := safeJoinWithinDirectory(downloadPath, *blob.Name)","+\t\t\t\tif err != nil {","+\t\t\t\t\tgologger.Error().Msgf(\"Skipping unsafe Azure blob name %q: %v\", *blob.Name, err)","+\t\t\t\t\tcontinue","+\t\t\t\t}"," \t\t\t\t// Download the template to the local filesystem at the downloadPath","-\t\t\t\terr := downloadTemplate(bk.azureBlobClient, bk.containerName, *blob.Name, filepath.Join(downloadPath, *blob.Name), ctx)","+\t\t\t\terr = downloadTemplate(bk.azureBlobClient, bk.containerName, *blob.Name, outputPath, ctx)"," \t\t\t\tif err != nil {"," \t\t\t\t\tgologger.Error().Msgf(\"Error downloading template: %v\", err)"," \t\t\t\t} else {"],"additions":9,"deletions":1,"truncated":false},{"path":"pkg/external/customtemplates/azure_blob_test.go","lines":["@@ -0,0 +1,57 @@","+package customtemplates","+","+import (","+\t\"path/filepath\"","+\t\"testing\"","+","+\t\"github.com/stretchr/testify/require\"","+)","+","+// The Azure Download path validates blob names through safeJoinWithinDirectory.","+// These tests cover that validation directly, mirroring the per-blob iteration","+// in customTemplateAzureBlob.Download so we lock in the same allow/deny shape","+// the runtime applies to server-controlled blob names.","+","+func TestAzureSafeJoinRejectsTraversalBlobNames(t *testing.T) {","+\tdownloadPath := t.TempDir()","+","+\tcases := []struct {","+\t\tname     string","+\t\tblobName string","+\t}{","+\t\t{\"parent traversal\", \"../evil.yaml\"},","+\t\t{\"deep traversal\", \"a/b/../../../etc/evil.yaml\"},","+\t\t{\"bare dotdot\", \"..\"},","+\t\t{\"sibling prefix via dotdot\", \"../\" + filepath.Base(downloadPath) + \"-evil/template.yaml\"},","+\t\t{\"absolute escape via dotdot prefix\", \"../../etc/evil.yaml\"},","+\t}","+","+\tfor _, tc := range cases {","+\t\tt.Run(tc.name, func(t *testing.T) {","+\t\t\t_, err := safeJoinWithinDirectory(downloadPath, tc.blobName)","+\t\t\trequire.Errorf(t, err, \"blob name %q must be rejected\", tc.blobName)","+\t\t})","+\t}","+}","+","+func TestAzureSafeJoinPreservesNestedBlobNames(t *testing.T) {","+\tdownloadPath := t.TempDir()","+","+\tcases := []struct {","+\t\tname     string","+\t\tblobName string","+\t\twant     string","+\t}{","+\t\t{\"flat\", \"template.yaml\", filepath.Join(downloadPath, \"template.yaml\")},","+\t\t{\"nested\", \"dir/sub/template.yaml\", filepath.Join(downloadPath, \"dir\", \"sub\", \"template.yaml\")},","+\t\t{\"sibling-basename in different dirs A\", \"alpha/template.yaml\", filepath.Join(downloadPath, \"alpha\", \"template.yaml\")},","+\t\t{\"sibling-basename in different dirs B\", \"beta/template.yaml\", filepath.Join(downloadPath, \"beta\", \"template.yaml\")},","+\t}","+\tfor _, tc := range cases {","+\t\tt.Run(tc.name, func(t *testing.T) {","+\t\t\tgot, err := safeJoinWithinDirectory(downloadPath, tc.blobName)","+\t\t\trequire.NoError(t, err)","+\t\t\trequire.Equal(t, tc.want, got)","+\t\t})","+\t}","+}"],"additions":57,"deletions":0,"truncated":false},{"path":"pkg/external/customtemplates/gitlab.go","lines":["@@ -13,6 +13,21 @@ import ("," \tgitlab \"gitlab.com/gitlab-org/api/client-go\""," )"," ","+// safeProjectOutputPath joins the GitLab project's path component to the","+// custom-templates directory, ensuring the resulting path stays inside","+// downloadDir even if the GitLab server returns a malicious project path.","+func safeProjectOutputPath(downloadDir, projectPath string) (string, error) {","+\treturn safeJoinWithinDirectory(downloadDir, projectPath)","+}","+","+// safeProjectFileOutputPath joins a per-file path to the per-project output","+// directory, again ensuring containment. fileRelPath is preferred over the","+// API-returned basename so that nested directory structure is preserved and a","+// malicious server cannot collapse multiple files onto one another.","+func safeProjectFileOutputPath(projectDir, fileRelPath string) (string, error) {","+\treturn safeJoinWithinDirectory(projectDir, fileRelPath)","+}","+"," var _ Provider = &customTemplateGitLabRepo{}"," "," type customTemplateGitLabRepo struct {","@@ -73,8 +88,28 @@ func (bk *customTemplateGitLabRepo) Download(_ context.Context) {"," \t\t\treturn"," \t\t}"," ","-\t\t// Add a subdirectory with the project ID as the subdirectory within the location","-\t\tprojectOutputPath := filepath.Join(location, project.Path)","+\t\t// Add a subdirectory with the project path as the subdirectory within","+\t\t// the location. The project path is attacker-controllable on a","+\t\t// malicious or self-hosted GitLab server, so it must be validated for","+\t\t// containment before we MkdirAll into it.","+\t\t//","+\t\t// Use PathWithNamespace (e.g. \"group/sub/repo\") rather than the bare","+\t\t// repo slug Path so that two configured projects sharing a slug in","+\t\t// different namespaces land in distinct directories and cannot","+\t\t// silently overwrite each other's templates. PathWithNamespace is","+\t\t// still server-controlled, so it goes through the same containment","+\t\t// check as before.","+\t\tprojectKey := project.PathWithNamespace","+\t\tif projectKey == \"\" {","+\t\t\t// Defensive fallback for older API responses where","+\t\t\t// PathWithNamespace might not be populated.","+\t\t\tprojectKey = project.Path","+\t\t}","+\t\tprojectOutputPath, err := safeProjectOutputPath(location, projectKey)","+\t\tif err != nil {","+\t\t\tgologger.Error().Msgf(\"Skipping unsafe GitLab project path %q: %v\", projectKey, err)","+\t\t\tcontinue","+\t\t}"," "," \t\t// Ensure the subdirectory exists or create it if it doesn't yet exist"," \t\terr = os.MkdirAll(projectOutputPath, 0755)","@@ -96,6 +131,16 @@ func (bk *customTemplateGitLabRepo) Download(_ context.Context) {"," \t\tfor _, file := range tree {"," \t\t\t// If the object is not a file or file extension is not .yaml, skip it"," \t\t\tif file.Type == \"blob\" && filepath.Ext(file.Path) == \".yaml\" {","+\t\t\t\t// Resolve the destination path before reaching out to the","+\t\t\t\t// server so a malicious tree path cannot escape projectOutputPath","+\t\t\t\t// even if the server later returns a basename that points","+\t\t\t\t// elsewhere.","+\t\t\t\toutputPath, err := safeProjectFileOutputPath(projectOutputPath, file.Path)","+\t\t\t\tif err != nil {","+\t\t\t\t\tgologger.Error().Msgf(\"Skipping unsafe GitLab tree path %q: %v\", file.Path, err)","+\t\t\t\t\tcontinue","+\t\t\t\t}","+"," \t\t\t\tgf := &gitlab.GetFileOptions{"," \t\t\t\t\tRef: gitlab.Ptr(project.DefaultBranch),"," \t\t\t\t}","@@ -112,10 +157,22 @@ func (bk *customTemplateGitLabRepo) Download(_ context.Context) {"," \t\t\t\t\treturn"," \t\t\t\t}"," ","-\t\t\t\t// Write the downloaded template to the local filesystem at the location with the filename of the blob name","-\t\t\t\terr = os.WriteFile(filepath.Join(projectOutputPath, f.FileName), contents, 0644)","+\t\t\t\t// Make sure the parent directory of the output file exists.","+\t\t\t\t// This preserves nested directory structure inside the project","+\t\t\t\t// (the previous implementation flattened everything by writing","+\t\t\t\t// only the basename, silently clobbering files with identical","+\t\t\t\t// names in different directories).","+\t\t\t\tif err := os.MkdirAll(filepath.Dir(outputPath), 0755); err != nil {","+\t\t\t\t\tgologger.Error().Msgf(\"error creating parent directory for GitLab project (%s) file: %s %s\", project.Name, file.Path, err)","+\t\t\t\t\treturn","+\t\t\t\t}","+","+\t\t\t\t// Write the downloaded template to the local filesystem at","+\t\t\t\t// the precomputed safe output path (preserves directory","+\t\t\t\t// structure and prevents traversal).","+\t\t\t\terr = os.WriteFile(outputPath, contents, 0644)"," \t\t\t\tif err != nil {","-\t\t\t\t\tgologger.Error().Msgf(\"error writing GitLab project (%s) file: %s %s\", project.Name, f.FileName, err)","+\t\t\t\t\tgologger.Error().Msgf(\"error writing GitLab project (%s) file: %s %s\", project.Name, file.Path, err)"," \t\t\t\t\treturn"," \t\t\t\t}"," "],"additions":62,"deletions":5,"truncated":false},{"path":"pkg/external/customtemplates/gitlab_test.go","lines":["@@ -0,0 +1,71 @@","+package customtemplates","+","+import (","+\t\"path/filepath\"","+\t\"testing\"","+","+\t\"github.com/stretchr/testify/require\"","+)","+","+func TestSafeProjectOutputPathRejectsTraversal(t *testing.T) {","+\tlocation := t.TempDir()","+","+\tcases := []struct {","+\t\tname        string","+\t\tprojectPath string","+\t}{","+\t\t{\"parent traversal\", \"../etc\"},","+\t\t{\"deep traversal\", \"a/b/../../../etc\"},","+\t\t{\"empty base loop via dotdot\", \"..\"},","+\t\t{\"absolute escape via dotdot\", \"../\" + filepath.Base(location) + \"-evil\"},","+\t}","+\tfor _, tc := range cases {","+\t\tt.Run(tc.name, func(t *testing.T) {","+\t\t\t_, err := safeProjectOutputPath(location, tc.projectPath)","+\t\t\trequire.Error(t, err, \"expected %q to be rejected\", tc.projectPath)","+\t\t})","+\t}","+}","+","+func TestSafeProjectOutputPathAllowsExpectedShape(t *testing.T) {","+\tlocation := t.TempDir()","+\tprojectPath := \"owner-foo/repo-bar\"","+\tgot, err := safeProjectOutputPath(location, projectPath)","+\trequire.NoError(t, err)","+\trequire.Equal(t, filepath.Join(location, projectPath), got)","+}","+","+func TestSafeProjectFileOutputPathPreservesNestedStructure(t *testing.T) {","+\tprojectDir := t.TempDir()","+","+\t// Two files in different subdirectories with the same basename must","+\t// resolve to two different output paths so they don't clobber each other","+\t// (regression test for the previous flatten-via-basename behaviour).","+\tpathA := \"alpha/template.yaml\"","+\tpathB := \"beta/template.yaml\"","+","+\tgotA, err := safeProjectFileOutputPath(projectDir, pathA)","+\trequire.NoError(t, err)","+\tgotB, err := safeProjectFileOutputPath(projectDir, pathB)","+\trequire.NoError(t, err)","+\trequire.NotEqual(t, gotA, gotB, \"nested files with identical basenames must not collide\")","+","+\trequire.Equal(t, filepath.Join(projectDir, \"alpha\", \"template.yaml\"), gotA)","+\trequire.Equal(t, filepath.Join(projectDir, \"beta\", \"template.yaml\"), gotB)","+}","+","+func TestSafeProjectFileOutputPathRejectsTraversal(t *testing.T) {","+\tprojectDir := t.TempDir()","+","+\tcases := []string{","+\t\t\"../escape.yaml\",","+\t\t\"sub/../../escape.yaml\",","+\t\t\"sub/sub2/../../../escape.yaml\",","+\t}","+\tfor _, c := range cases {","+\t\tt.Run(c, func(t *testing.T) {","+\t\t\t_, err := safeProjectFileOutputPath(projectDir, c)","+\t\t\trequire.Error(t, err)","+\t\t})","+\t}","+}"],"additions":71,"deletions":0,"truncated":false},{"path":"pkg/external/customtemplates/s3.go","lines":["@@ -14,6 +14,7 @@ import ("," \t\"github.com/projectdiscovery/gologger\""," \tnucleiConfig \"github.com/projectdiscovery/nuclei/v3/pkg/catalog/config\""," \t\"github.com/projectdiscovery/nuclei/v3/pkg/types\"","+\tfilepathutil \"github.com/projectdiscovery/nuclei/v3/pkg/utils/filepath\""," \t\"github.com/projectdiscovery/utils/errkit\""," \tstringsutil \"github.com/projectdiscovery/utils/strings\""," )","@@ -83,8 +84,11 @@ func NewS3Providers(options *types.Options) ([]*customTemplateS3Bucket, error) {"," }"," "," func downloadToFile(downloader *manager.Downloader, targetDirectory, bucket, key string) error {","-\t// Create the directories in the path","-\tfile := filepath.Join(targetDirectory, key)","+\tfile, err := safeJoinWithinDirectory(targetDirectory, key)","+\tif err != nil {","+\t\treturn errkit.Wrapf(err, \"skipping s3 object %q with unsafe key\", key)","+\t}","+"," \t// If empty dir in s3"," \tif stringsutil.HasSuffixI(key, \"/\") {"," \t\treturn os.MkdirAll(file, 0775)","@@ -108,6 +112,21 @@ func downloadToFile(downloader *manager.Downloader, targetDirectory, bucket, key"," \treturn err"," }"," ","+// safeJoinWithinDirectory joins relPath to baseDir and ensures the resulting","+// path stays inside baseDir after canonicalization. It is used to defend","+// custom-template downloaders against path-traversal in attacker-controlled","+// keys/blob names/file paths.","+func safeJoinWithinDirectory(baseDir, relPath string) (string, error) {","+\tif baseDir == \"\" {","+\t\treturn \"\", errkit.New(\"base directory must not be empty\")","+\t}","+\tcleaned := filepath.Clean(filepath.Join(baseDir, relPath))","+\tif !filepathutil.IsPathWithinDirectory(cleaned, baseDir) {","+\t\treturn \"\", errkit.Newf(\"relative path %q escapes %q\", relPath, baseDir)","+\t}","+\treturn cleaned, nil","+}","+"," func getS3Client(ctx context.Context, accessKey string, secretKey string, region string, profile string) (*s3.Client, error) {"," \tvar cfg aws.Config"," \tvar err error"],"additions":21,"deletions":2,"truncated":false},{"path":"pkg/external/customtemplates/s3_test.go","lines":["@@ -0,0 +1,225 @@","+package customtemplates","+","+import (","+\t\"os\"","+\t\"path/filepath\"","+\t\"runtime\"","+\t\"strings\"","+\t\"testing\"","+","+\t\"github.com/stretchr/testify/require\"","+)","+","+func TestSafeJoinWithinDirectoryRejectsTraversal(t *testing.T) {","+\tbaseDir := t.TempDir()","+","+\ttraversalKeys := []string{","+\t\t\"../etc/passwd\",","+\t\t\"../../etc/passwd\",","+\t\t\"foo/../../etc/passwd\",","+\t\t\"./../etc/passwd\",","+\t\t\"a/b/../../../etc/passwd\",","+\t}","+","+\tfor _, key := range traversalKeys {","+\t\tt.Run(key, func(t *testing.T) {","+\t\t\t_, err := safeJoinWithinDirectory(baseDir, key)","+\t\t\trequire.Error(t, err, \"expected key %q to be rejected\", key)","+\t\t})","+\t}","+}","+","+func TestSafeJoinWithinDirectoryAllowsContainedPaths(t *testing.T) {","+\tbaseDir := t.TempDir()","+","+\ttests := map[string]string{","+\t\t\"file.yaml\":             filepath.Join(baseDir, \"file.yaml\"),","+\t\t\"sub/file.yaml\":         filepath.Join(baseDir, \"sub\", \"file.yaml\"),","+\t\t\"a/b/c/file.yaml\":       filepath.Join(baseDir, \"a\", \"b\", \"c\", \"file.yaml\"),","+\t\t\"sub/../sibling.yaml\":   filepath.Join(baseDir, \"sibling.yaml\"),","+\t\t\"sub/inner/../i.yaml\":   filepath.Join(baseDir, \"sub\", \"i.yaml\"),","+\t\t\"./relative-file.yaml\":  filepath.Join(baseDir, \"relative-file.yaml\"),","+\t\t\"trailing/dir/\":         filepath.Join(baseDir, \"trailing\", \"dir\"),","+\t\t\"name-with-dotdot..bar\": filepath.Join(baseDir, \"name-with-dotdot..bar\"),","+\t}","+","+\tfor key, want := range tests {","+\t\tt.Run(key, func(t *testing.T) {","+\t\t\tgot, err := safeJoinWithinDirectory(baseDir, key)","+\t\t\trequire.NoError(t, err)","+\t\t\trequire.Equal(t, want, got)","+\t\t})","+\t}","+}","+","+func TestSafeJoinWithinDirectoryRejectsSiblingPrefix(t *testing.T) {","+\tparent := t.TempDir()","+\tbaseDir := filepath.Join(parent, \"templates\")","+\trequire.NoError(t, os.MkdirAll(baseDir, 0o755))","+","+\t// Sibling directory that shares the templates prefix lexically but is","+\t// not actually inside the templates directory.","+\tsibling := baseDir + \"-evil\"","+\trequire.NoError(t, os.MkdirAll(sibling, 0o755))","+","+\t// An S3 object key that lexically prefix-matches templates would have","+\t// been treated as in-bounds by a HasPrefix check. The canonical","+\t// containment check must reject it.","+\tkey := \"../\" + filepath.Base(sibling) + \"/file.yaml\"","+\t_, err := safeJoinWithinDirectory(baseDir, key)","+\trequire.Error(t, err)","+}","+","+func TestSafeJoinWithinDirectoryEmptyBase(t *testing.T) {","+\t_, err := safeJoinWithinDirectory(\"\", \"anything\")","+\trequire.Error(t, err)","+}","+","+func TestDownloadToFileRejectsTraversalKey(t *testing.T) {","+\tbaseDir := t.TempDir()","+\t// Use a unique sibling outside baseDir we want to make sure we never write to.","+\tparent := filepath.Dir(baseDir)","+\tmaliciousKey := \"../\" + filepath.Base(baseDir) + \"-evil/poc.yaml\"","+","+\t// downloader is nil on purpose: with a safe-join failure we must return","+\t// before any download attempt is made (otherwise we'd panic on the nil","+\t// downloader, which itself is a regression assertion).","+\terr := downloadToFile(nil, baseDir, \"irrelevant-bucket\", maliciousKey)","+\trequire.Error(t, err)","+","+\t// Belt-and-suspenders: nothing got written under the sibling.","+\t_, statErr := os.Stat(filepath.Join(parent, filepath.Base(baseDir)+\"-evil\"))","+\trequire.True(t, os.IsNotExist(statErr), \"no sibling directory should have been created\")","+}","+","+func TestSafeJoinWithinDirectoryHandlesLeadingSlash(t *testing.T) {","+\tif runtime.GOOS == \"windows\" {","+\t\tt.Skip(\"absolute path semantics differ on Windows\")","+\t}","+\tbaseDir := t.TempDir()","+\t// filepath.Join discards the leading \"/\" of the relative segment, so a","+\t// \"rooted\" key like \"/etc/passwd\" lands at <baseDir>/etc/passwd. That is","+\t// still inside baseDir, so we accept it (no escape happened).","+\tgot, err := safeJoinWithinDirectory(baseDir, \"/etc/passwd\")","+\trequire.NoError(t, err)","+\trequire.Equal(t, filepath.Join(baseDir, \"etc\", \"passwd\"), got)","+}","+","+// TestSafeJoinWithinDirectoryRejectsSymlinkEscape covers the case where","+// baseDir already contains a pre-existing symlink that points OUTSIDE of","+// baseDir, and an attacker-controlled key tries to ride that symlink to write","+// somewhere on the filesystem the operator doesn't control. The canonicalized","+// IsPathWithinDirectory check inside safeJoinWithinDirectory must reject this","+// even though the lexical Clean of (baseDir + relPath) looks fine.","+func TestSafeJoinWithinDirectoryRejectsSymlinkEscape(t *testing.T) {","+\tif runtime.GOOS == \"windows\" {","+\t\tt.Skip(\"symlink creation is not reliable on all Windows runners\")","+\t}","+\tparent := t.TempDir()","+\tbaseDir := filepath.Join(parent, \"templates\")","+\trequire.NoError(t, os.MkdirAll(baseDir, 0o755))","+","+\t// A pre-existing escape symlink under baseDir. EvalSymlinks resolves it","+\t// before we Rel against baseDir, so any key that would write through it","+\t// must be rejected.","+\toutside := filepath.Join(parent, \"outside\")","+\trequire.NoError(t, os.MkdirAll(outside, 0o755))","+\trequire.NoError(t, os.Symlink(outside, filepath.Join(baseDir, \"escape\")))","+","+\t_, err := safeJoinWithinDirectory(baseDir, \"escape/poc.yaml\")","+\trequire.Error(t, err, \"must reject keys that ride a symlink out of baseDir\")","+}","+","+// TestSafeJoinWithinDirectoryAcceptsInBoundsSymlink is a positive companion","+// to the symlink-escape test: a symlink that stays inside baseDir must be","+// honoured, otherwise users would lose support for legitimate setups (e.g.","+// macOS /tmp -> /private/tmp aliases).","+func TestSafeJoinWithinDirectoryAcceptsInBoundsSymlink(t *testing.T) {","+\tif runtime.GOOS == \"windows\" {","+\t\tt.Skip(\"symlink creation is not reliable on all Windows runners\")","+\t}","+\tbaseDir := t.TempDir()","+\tinner := filepath.Join(baseDir, \"real\")","+\trequire.NoError(t, os.MkdirAll(inner, 0o755))","+\trequire.NoError(t, os.Symlink(inner, filepath.Join(baseDir, \"alias\")))","+","+\tgot, err := safeJoinWithinDirectory(baseDir, \"alias/file.yaml\")","+\trequire.NoError(t, err)","+\trequire.Equal(t, filepath.Join(baseDir, \"alias\", \"file.yaml\"), got)","+}","+","+// TestSafeJoinWithinDirectoryAdversarialKeys exhaustively probes"],"additions":151,"deletions":0,"truncated":false}],"additions":539,"deletions":72,"truncated":true,"file_count":13},"error":null,"fetched_at":"2026-06-05T11:14:21.179453+00:00"}