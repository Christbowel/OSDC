manager/config\"","+\t\"github.com/prometheus/alertmanager/dispatch\"","+\t\"github.com/prometheus/alertmanager/pkg/labels\"","+\t\"github.com/prometheus/common/model\"","+)","+","+var (","+\tErrInvalidMatchers         = errors.New(\"only equality matchers are allowed\")","+\tErrDuplicateMatchers       = errors.New(\"matchers should be unique\")","+\tErrSubtreeMatchersConflict = errors.New(\"subtree matchers conflict with existing Grafana routes, merging will break existing notifications\")","+)","+","+type MergeOpts struct {","+\t// DedupSuffix is a string suffix that will be appended to any resources (receivers or time intervals)","+\t// from the secondary configuration that have name conflicts with the primary configuration.","+\t//","+\t// The deduplication process works as follows:","+\t// 1. If a resource from the secondary config has the same name as one in the primary config,","+\t//    this suffix is appended to create a new name (e.g., \"webhook\" becomes \"webhooksuffix\")","+\t// 2. If the new name still conflicts, a sequential number is added (e.g., \"webhooksuffix_01\")","+\t// 3. All references to renamed resources are automatically updated throughout the configuration","+\t//","+\t// When left empty, only numeric suffixes will be used for deduplication (e.g., \"webhook_01\").","+\t//","+\t// Example usage:","+\t//   MergeOpts{","+\t//     DedupSuffix: \"_secondary\",  // Results in names like \"webhook_secondary\" or \"webhook_secondary_01\"","+\t//   }","+\t//","+\t// This field helps maintain distinct resource identities while preserving relationships","+\t// between components during the merge process.","+\tDedupSuffix string","+\t// SubtreeMatchers specifies a list of matchers that will be applied to the root route","+\t// of the routing tree being merged. These matchers are essential for properly isolating","+\t// and identifying alerts from the secondary configuration after merging.","+\t//","+\t// The matchers must follow these requirements:","+\t// - Each matcher must use the equality operator (labels.MatchEqual type)","+\t// - Each matcher name must be unique within the list","+\t//","+\t// Example usage:","+\t//   SubtreeMatchers: config.Matchers{","+\t//     {Name: \"source\", Value: \"external\", Type: labels.MatchEqual},","+\t//     {Name: \"environment\", Value: \"production\", Type: labels.MatchEqual},","+\t//   }","+\t//","+\t// These matchers will be:","+\t// 1. Added to the root of the secondary routing tree during merge","+\t// 2. Added to both source and target matchers of all inhibit rules from the secondary config","+\t// 3. Used to ensure alerts are properly routed after configurations are merged","+\t//","+\t// Warning: If these matchers conflict with existing routes in the primary configuration,","+\t// the merge operation will fail with ErrSubtreeMatchersConflict to prevent breaking","+\t// existing notification flows.","+\tSubtreeMatchers config.Matchers","+}","+","+func (o MergeOpts) Validate() error {","+\tseenNames := make(map[string]struct{}, len(o.SubtreeMatchers))","+\tfor _, matcher := range o.SubtreeMatchers {","+\t\tif _, ok := seenNames[matcher.Name]; ok {","+\t\t\treturn ErrDuplicateMatchers","+\t\t}","+\t\tif matcher.Type != labels.MatchEqual {","+\t\t\treturn ErrInvalidMatchers","+\t\t}","+\t\tseenNames[matcher.Name] = struct{}{}","+\t}","+\treturn nil","+}","+","+// MergeResult represents the result of merging two Alertmanager configurations.","+// It contains the unified configuration and maps of renamed receivers and time intervals.","+//","+// Identifier, ExtraRoute and ExtraInhibitRules are populated by GetMergedAlertmanagerConfig","+// when the merge consumed an imported (Mimir-format) configuration; they expose the","+// imported route subtree and inhibit rules separately so callers can register them as","+// managed routes / managed inhibit rules. Plain calls to Merge leave these fields zero."],"additions":95,"deletions":0,"truncated":false}],"additions":221,"deletions":186,"truncated":true,"file_count":7},"error":null,"fetched_at":"2026-05-20T17:48:06.165719+00:00"}