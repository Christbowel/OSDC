{"id":"9a6a531dbca91ebf3a3fc1aa5bec6eaad040d2aa","axis":"silent","repo":"linq2db/linq2db","sha":"9a6a531dbca91ebf3a3fc1aa5bec6eaad040d2aa","parsed":{"files":[{"path":"Source/CodeGenerators/AnalyzerReleases.Shipped.md","lines":["@@ -0,0 +1,2 @@","+; Shipped analyzer releases","+; https://github.com/dotnet/roslyn-analyzers/blob/main/src/Microsoft.CodeAnalysis.Analyzers/ReleaseTrackingAnalyzers.Help.md"],"additions":2,"deletions":0,"truncated":false},{"path":"Source/CodeGenerators/AnalyzerReleases.Unshipped.md","lines":["@@ -0,0 +1,8 @@","+; Unshipped analyzer release","+; https://github.com/dotnet/roslyn-analyzers/blob/main/src/Microsoft.CodeAnalysis.Analyzers/ReleaseTrackingAnalyzers.Help.md","+","+### New Rules","+","+Rule ID | Category | Severity | Notes","+--------|----------|----------|-------","+LINQ2DB0001 | Usage | Warning | SqlBuilderAliasAnalyzer"],"additions":8,"deletions":0,"truncated":false},{"path":"Source/CodeGenerators/CodeGenerators.csproj","lines":["@@ -20,4 +20,9 @@"," \t\t<PackageReference Include=\"Meziantou.Polyfill\" PrivateAssets=\"All\" />"," \t</ItemGroup>"," ","+\t<ItemGroup>","+\t\t<AdditionalFiles Include=\"AnalyzerReleases.Shipped.md\" />","+\t\t<AdditionalFiles Include=\"AnalyzerReleases.Unshipped.md\" />","+\t</ItemGroup>","+"," </Project>"],"additions":5,"deletions":0,"truncated":false},{"path":"Source/CodeGenerators/SqlBuilderAliasAnalyzer.cs","lines":["@@ -0,0 +1,128 @@","+using System.Collections.Generic;","+using System.Collections.Immutable;","+","+using Microsoft.CodeAnalysis;","+using Microsoft.CodeAnalysis.Diagnostics;","+using Microsoft.CodeAnalysis.Operations;","+","+namespace CodeGenerators","+{","+\t/// <summary>","+\t/// Guards the SQL render path: inside a <c>BasicSqlBuilder</c>-derived type the finalized identifiers","+\t/// (table / column aliases and CTE field names) live in <c>AliasesContext</c>, not on the AST nodes -","+\t/// non-mutating aliasing keeps them off the nodes so a cached statement can be aliased / rendered","+\t/// concurrently. A builder must therefore resolve them through the context:","+\t/// <list type=\"bullet\">","+\t/// <item><c>SqlColumn.Alias</c>       -&gt; <c>AliasesContext.GetColumnAlias</c></item>","+\t/// <item><c>SqlTableSource.Alias</c>  -&gt; <c>AliasesContext.GetTableAlias</c></item>","+\t/// <item><c>SqlCteTableField.Name</c> -&gt; <c>AliasesContext.GetFieldName</c></item>","+\t/// <item><c>SqlCteField.Name</c>      -&gt; <c>AliasesContext.GetFieldName</c></item>","+\t/// </list>","+\t/// Reading the node's own property bypasses the context and renders a stale/raw name.","+\t/// (<c>RawAlias</c> remains the un-flagged escape hatch for the raw stored alias.)","+\t/// </summary>","+\t/// <remarks>","+\t/// <c>SqlTable.Alias</c> and <c>SqlField.PhysicalName</c> are intentionally not guarded: they are the","+\t/// source of truth on the node. SqlTable aliases are not migrated into <c>AliasesContext</c>","+\t/// (<c>GetTableAlias</c> itself falls back to <c>SqlTable.Alias</c>), and <c>SqlField.PhysicalName</c>","+\t/// is the physical column name used verbatim in DDL as well as - via <c>GetFieldName</c> - in the","+\t/// render path, so a blanket guard would produce false positives. Only the CTE field types","+\t/// (<c>SqlCteTableField</c> / <c>SqlCteField</c>), which exist solely in the query/CTE render path and","+\t/// whose <c>Name</c> always delegates to the un-renamed definition, are guarded for their name.","+\t/// </remarks>","+\t[DiagnosticAnalyzer(LanguageNames.CSharp)]","+\tpublic sealed class SqlBuilderAliasAnalyzer : DiagnosticAnalyzer","+\t{","+\t\tconst string BuilderTypeName = \"LinqToDB.Internal.SqlProvider.BasicSqlBuilder\";","+","+\t\t// Guarded (owner type, property) -> the AliasesContext accessor that must be used instead.","+\t\tstatic readonly (string TypeName, string Property, string Kind, string Accessor)[] Guards =","+\t\t[","+\t\t\t(\"LinqToDB.Internal.SqlQuery.SqlColumn\",        \"Alias\", \"column alias\",       \"GetColumnAlias\"),","+\t\t\t(\"LinqToDB.Internal.SqlQuery.SqlTableSource\",   \"Alias\", \"table-source alias\", \"GetTableAlias\"),","+\t\t\t(\"LinqToDB.Internal.SqlQuery.SqlCteTableField\", \"Name\",  \"CTE field name\",     \"GetFieldName\"),","+\t\t\t(\"LinqToDB.Internal.SqlQuery.SqlCteField\",      \"Name\",  \"CTE field name\",     \"GetFieldName\"),","+\t\t];","+","+\t\tstatic readonly DiagnosticDescriptor Rule = new(","+\t\t\tid:                 \"LINQ2DB0001\",","+\t\t\ttitle:              \"Read the finalized alias / name via AliasesContext\",","+\t\t\tmessageFormat:      \"Read the finalized {0} via AliasesContext.{1}(...) instead of the node's {2} property: inside a SQL builder the node's {2} is not the finalized name (it lives in AliasesContext)\",","+\t\t\tcategory:           \"Usage\",","+\t\t\tdefaultSeverity:    DiagnosticSeverity.Warning,","+\t\t\tisEnabledByDefault: true,","+\t\t\tdescription:        \"Non-mutating aliasing stores finalized names in AliasesContext, not on the AST nodes. SQL builders must resolve aliases / CTE field names through AliasesContext.GetColumnAlias / GetTableAlias / GetFieldName; RawAlias is the escape hatch for the raw stored value.\");","+","+\t\t/// <inheritdoc/>","+\t\tpublic override ImmutableArray<DiagnosticDescriptor> SupportedDiagnostics => [Rule];","+","+\t\t/// <inheritdoc/>","+\t\tpublic override void Initialize(AnalysisContext context)","+\t\t{","+\t\t\tcontext.EnableConcurrentExecution();","+\t\t\tcontext.ConfigureGeneratedCodeAnalysis(GeneratedCodeAnalysisFlags.None);","+","+\t\t\tcontext.RegisterCompilationStartAction(static startContext =>","+\t\t\t{","+\t\t\t\tvar builderType = startContext.Compilation.GetTypeByMetadataName(BuilderTypeName);","+\t\t\t\tif (builderType == null)","+\t\t\t\t\treturn;","+","+\t\t\t\t// Resolve each guarded owner type once; skip any absent from this compilation.","+\t\t\t\tvar guards = new List<(INamedTypeSymbol Type, string Property, string Kind, string Accessor)>();","+\t\t\t\tforeach (var (typeName, property, kind, accessor) in Guards)","+\t\t\t\t{","+\t\t\t\t\tvar type = startContext.Compilation.GetTypeByMetadataName(typeName);","+\t\t\t\t\tif (type != null)","+\t\t\t\t\t\tguards.Add((type, property, kind, accessor));","+\t\t\t\t}","+","+\t\t\t\tif (guards.Count == 0)","+\t\t\t\t\treturn;","+","+\t\t\t\tstartContext.RegisterOperationAction(opContext =>","+\t\t\t\t{","+\t\t\t\t\tvar op = (IPropertyReferenceOperation)opContext.Operation;","+","+\t\t\t\t\t// reads only - writing the alias / name is not a render-path concern.","+\t\t\t\t\tif (op.Parent is IAssignmentOperation assignment && ReferenceEquals(assignment.Target, op))","+\t\t\t\t\t\treturn;","+","+\t\t\t\t\tvar owner = op.Property.ContainingType;","+","+\t\t\t\t\tstring? kind = null, accessor = null, property = null;","+\t\t\t\t\tforeach (var (type, prop, gKind, gAccessor) in guards)","+\t\t\t\t\t{","+\t\t\t\t\t\tif (op.Property.Name == prop && SymbolEqualityComparer.Default.Equals(owner, type))","+\t\t\t\t\t\t{","+\t\t\t\t\t\t\tkind     = gKind;","+\t\t\t\t\t\t\taccessor = gAccessor;","+\t\t\t\t\t\t\tproperty = prop;","+\t\t\t\t\t\t\tbreak;","+\t\t\t\t\t\t}","+\t\t\t\t\t}","+","+\t\t\t\t\tif (kind == null)","+\t\t\t\t\t\treturn;","+","+\t\t\t\t\tvar enclosingType = opContext.ContainingSymbol as INamedTypeSymbol","+\t\t\t\t\t\t?? opContext.ContainingSymbol?.ContainingType;","+","+\t\t\t\t\tif (!DerivesFrom(enclosingType, builderType))","+\t\t\t\t\t\treturn;","+","+\t\t\t\t\topContext.ReportDiagnostic(Diagnostic.Create(Rule, op.Syntax.GetLocation(), kind, accessor, property));","+\t\t\t\t}, OperationKind.PropertyReference);","+\t\t\t});","+\t\t}","+","+\t\tstatic bool DerivesFrom(INamedTypeSymbol? type, INamedTypeSymbol baseType)","+\t\t{","+\t\t\tfor (var current = type; current != null; current = current.BaseType)","+\t\t\t\tif (SymbolEqualityComparer.Default.Equals(current, baseType))","+\t\t\t\t\treturn true;","+","+\t\t\treturn false;","+\t\t}","+\t}","+}"],"additions":128,"de