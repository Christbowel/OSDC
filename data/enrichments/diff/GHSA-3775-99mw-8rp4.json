/argo-workflows/v4/pkg/apis/workflow/v1alpha1\""," )"," ","+// allowedUserOverrideFields lists WorkflowSpec fields that users may set when","+// submitting a workflow via workflowTemplateRef under Strict/Secure mode.","+// Any field NOT in this set is blocked by default, ensuring new fields added","+// to WorkflowSpec are denied until explicitly reviewed.","+var allowedUserOverrideFields = map[string]bool{","+\t\"Arguments\":             true,","+\t\"Entrypoint\":            true,","+\t\"Shutdown\":              true,","+\t\"Suspend\":               true,","+\t\"ActiveDeadlineSeconds\": true,","+\t\"Priority\":              true,","+\t\"TTLStrategy\":           true,","+\t\"PodGC\":                 true,","+\t\"VolumeClaimGC\":         true,","+\t\"ArchiveLogs\":           true,","+\t\"WorkflowMetadata\":      true,","+\t\"WorkflowTemplateRef\":   true,","+\t\"Metrics\":               true,","+\t\"ArtifactGC\":            true,","+}","+","+// ValidateUserOverrides checks that a user-submitted WorkflowSpec only sets","+// fields from the allow-list. Returns an error listing all violations.","+func ValidateUserOverrides(userSpec *wfv1.WorkflowSpec) error {","+\tif userSpec == nil {","+\t\treturn nil","+\t}","+\tv := reflect.ValueOf(userSpec).Elem()","+\tt := v.Type()","+\tzero := reflect.New(t).Elem()","+","+\tvar violations []string","+\tfor i := 0; i < t.NumField(); i++ {","+\t\tfieldName := t.Field(i).Name","+\t\tif allowedUserOverrideFields[fieldName] {","+\t\t\tcontinue","+\t\t}","+\t\tif !reflect.DeepEqual(v.Field(i).Interface(), zero.Field(i).Interface()) {","+\t\t\tviolations = append(violations, fieldName)","+\t\t}","+\t}","+\tif len(violations) > 0 {","+\t\tsort.Strings(violations)","+\t\treturn fmt.Errorf(\"fields %v are not permitted when using workflowTemplateRef with templateReferencing restriction\", violations)","+\t}","+\treturn nil","+}","+","+// SanitizeUserWorkflowSpec returns a copy of userSpec with only allow-listed","+// fields preserved. This provides defense-in-depth after validation.","+func SanitizeUserWorkflowSpec(userSpec *wfv1.WorkflowSpec) *wfv1.WorkflowSpec {","+\tif userSpec == nil {","+\t\treturn nil","+\t}","+\tsanitized := &wfv1.WorkflowSpec{}","+\tsrc := reflect.ValueOf(userSpec).Elem()","+\tdst := reflect.ValueOf(sanitized).Elem()","+\tt := src.Type()","+","+\tfor i := 0; i < t.NumField(); i++ {","+\t\tif allowedUserOverrideFields[t.Field(i).Name] {","+\t\t\tdst.Field(i).Set(src.Field(i))","+\t\t}","+\t}","+\treturn sanitized","+}","+"," // MergeTo will merge one workflow (the \"patch\" workflow) into another (the \"target\" workflow."," // If the target workflow defines a field, this take precedence over the patch."," func MergeTo(patch, target *wfv1.Workflow) error {"],"additions":70,"deletions":0,"truncated":false},{"path":"workflow/util/merge_test.go","lines":["@@ -1,11 +1,14 @@"," package util"," "," import (","+\t\"reflect\""," \t\"testing\""," "," \t\"github.com/stretchr/testify/assert\""," \t\"github.com/stretchr/testify/require\"","+\tapiv1 \"k8s.io/api/core/v1\""," \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"","+\t\"k8s.io/utils/ptr\""," "," \twfv1 \"github.com/argoproj/argo-workflows/v4/pkg/apis/workflow/v1alpha1\""," )","@@ -79,40 +82,40 @@ func TestMergeMetaDataTo(t *testing.T) {"," }"," "," var wfDefault = `","-metadata: ","-  annotations: ","+metadata:","+  annotations:","     testAnnotation: default","-  labels: ","+  labels:","     testLabel: default","-spec: ","+spec:","   entrypoint: whalesay","   activeDeadlineSeconds: 7200","-  arguments: ","-    artifacts: ","+  arguments:","+    artifacts:","       -","         name: message","         path: /tmp/message","-    parameters: ","-      - ","+    parameters:","+      -","         name: message","         value: \"hello world\"","   onExit: whalesay-exit","   serviceAccountName: default","-  templates: ","-    - ","-      container: ","-        args: ","+  templates:","+    -","+      container:","+        args:","    