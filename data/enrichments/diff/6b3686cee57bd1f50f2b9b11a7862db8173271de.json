ountAttributions)","+\tmergeMountAttributions(&i.SshCertMountAttributions, other.SshCertMountAttributions)","+\tmergeMountAttributions(&i.SshOtpMountAttributions, other.SshOtpMountAttributions)","+}","+","+// mergeMountAttributions merges src into *dst, accumulating numeric counts for","+// mounts that already exist in *dst.","+func mergeMountAttributions(dst *map[string]MountAttribution, src map[string]MountAttribution) {","+\tif len(src) == 0 {","+\t\treturn","+\t}","+\tif *dst == nil {","+\t\t*dst = make(map[string]MountAttribution)","+\t}","+","+\tasFloat64 := func(v interface{}) float64 {","+\t\tswitch n := v.(type) {","+\t\tcase float64:","+\t\t\treturn n","+\t\tcase float32:","+\t\t\treturn float64(n)","+\t\tcase int:","+\t\t\treturn float64(n)","+\t\tcase int64:","+\t\t\treturn float64(n)","+\t\tcase uint:","+\t\t\treturn float64(n)","+\t\tcase uint64:","+\t\t\treturn float64(n)","+\t\tcase interface{ Float64() (float64, error) }:","+\t\t\tf, _ := n.Float64()","+\t\t\treturn f","+\t\tdefault:","+\t\t\treturn 0","+\t\t}","+\t}","+","+\tfor accessor, attr := range src {","+\t\tif existing, ok := (*dst)[accessor]; ok {","+\t\t\texisting.Count = asFloat64(existing.Count) + asFloat64(attr.Count)","+\t\t\t(*dst)[accessor] = existing","+\t\t\tcontinue","+\t\t}","+\t\t(*dst)[accessor] = attr","+\t}"," }"," "," func (i *CertCount) IsZero() bool {","-\treturn i.IssuedCerts == 0 && i.StoredCerts == 0 && i.PkiDurationAdjustedCerts == 0 && i.SSHIssuedCerts == 0 && i.SSHIssuedOTPs == 0","+\treturn i.IssuedCerts == 0 &&","+\t\ti.StoredCerts == 0 &&","+\t\ti.PkiDurationAdjustedCerts == 0 &&","+\t\ti.SSHIssuedCerts == 0 &&","+\t\ti.SSHIssuedOTPs == 0 &&","+\t\tlen(i.PkiMountAttributions) == 0 &&","+\t\tlen(i.SshCertMountAttributions) == 0 &&","+\t\tlen(i.SshOtpMountAttributions) == 0"," }"," "," // durationAdjustedCertificateCount calculates the billable units for a certificate based on its","@@ -67,13 +132,19 @@ func durationAdjustedCertificateCount(validitySeconds int64) float64 {"," }"," "," type CertCountIncrementer interface {","+\t// WithMountInfo attaches mount and namespace metadata to the AddIssuedCertificate,","+\t// AddSSHCertificate, or AddSSHOTP call that follows, to record per-mount attribution","+\t// for that operation. MountAttribution.Count is not set here, it will be set to the","+\t// billable units calculated in the following Add* call.","+\tWithMountInfo(mount MountAttribution) CertCountIncrementer"," \tAddIssuedCertificate(stored bool, cert *x509.Certificate) CertCountIncrementer"," \tAddSSHCertificate(ttl time.Duration) CertCountIncrementer"," \tAddSSHOTP() CertCountIncrementer"," }"," "," type certCountIncrementer struct {","-\tcounter CertificateCounter","+\tcounter   CertificateCounter","+\tmountInfo *MountAttribution"," }"," "," var _ CertCountIncrementer = (*certCountIncrementer)(nil)","@@ -83,38 +154,69 @@ func NewCertCountIncrementer(counter CertificateCounter) CertCountIncrementer {"," \treturn &certCountIncrementer{counter: counter}"," }"," ","+// WithMountInfo attaches mount/namespace metadata that will be recorded as attribution","+// on the next Add* call. Count on the provided MountAttribution is ignored.","+func (c *certCountIncrementer) WithMountInfo(mount MountAttribution) CertCountIncrementer {","+\tc.mountInfo = &mount","+\treturn c","+}","+"," // AddIssuedCertificate increments the issued certificate count by 1, the stored certificate"," // count if stored is true, and adds the calculated billable units based on the certificate's"," // validity duration."," // cert: The X.509 certificate to extract validity duration from."," func (c *certCountIncrementer) AddIssuedCertificate(stored bool, cert *x509.Certificate) CertCountIncrementer {"," \tvalidity := int64(cert.NotAfter.Unix() - cert.NotBefore.Unix())","+\tunits := durationAdjustedCertificateCount(validity)"," \tcount := CertCount{"," \t\tIssuedCerts:              1,","-\t\tPkiDurationAdjustedCerts: durationAdjustedCertificateCount(validity),","+\t\tPkiDurationAdjustedCerts: units,"," \t}"," \tif stored {"," \t\tcount.StoredCerts = 1"," \t}","+\tif c.mountInfo != nil {","+\t\tif c.mountInfo.MountAccessor != \"\" {","+\t\t\tattr := *c.mountInfo","+\t\t\tattr.Count = units","+\t\t\tcount.PkiMountAttributions = map[string]MountAttribution{attr.MountAccessor: attr}","+\t\t}","+\t\tc.mountInfo = nil // always consume, even when accessor was blank","+\t}"," \tc.counter.AddCount(count)","-"," \treturn c"," }"," "," func (c *certCountIncrementer) AddSSHCertificate(ttl time.Duration) CertCountIncrementer {","+\tunits := durationAdjustedCertificateCount(int64(ttl.Seconds()))"," \tcount := CertCount{","-\t\tSSHIssuedCerts: durationAdjustedCertificateCount(int64(ttl.Seconds())),","+\t\tSSHIssuedCerts: units,","+\t}","+\tif c.mountInfo != nil {","+\t\tif c.mountInfo.MountAccessor != \"\" {","+\t\t\tattr := *c.mountInfo","+\t\t\tattr.Count = units","+\t\t\tcount.SshCertMountAttributions = map[string]MountAttribution{attr.MountAccessor: attr}","+\t\t}","+\t\tc.mountInfo = nil // always consume"," \t}","-"," \tc.counter.AddCount(count)","-"," \treturn c"," }"," "," func (c *certCountIncrementer) AddSSHOTP() CertCountIncrementer {","-\tc.counter.AddCount(CertCount{","-\t\tSSHIssuedOTPs: 0.0014,","-\t})","-","+\tconst otpUnits = 0.0014","+\tcount := CertCount{","+\t\tSSHIssuedOTPs: otpUnits,","+\t}","+\tif c.mountInfo != nil {","+\t\tif c.mountInfo.MountAccessor != \"\" {","+\t\t\tattr := *c.mountInfo","+\t\t\tattr.Count = otpUnits","+\t\t\tcount.SshOtpMountAttributions = map[string]MountAttribution{attr.MountAccessor: attr}","+\t\t}","+\t\tc.mountInfo = nil // always consume","+\t}","+\tc.counter.AddCount(count)"," \treturn c"," }"],"additions":113,"deletions":11,"truncated":false},{"path":"sdk/logical/certificate_counter_test.go","lines":["@@ -4,8 +4,12 @@"," package logical"," "," import (","+\t\"crypto/x509\""," \t\"math\""," \t\"testing\"","+\t\"time\"","+","+\t\"github.com/stretchr/testify/require\""," )"," "," func Test_durationAdjustedCertificateCount(t *testing.T) {","@@ -219,4 +223,220 @@ func Benchmark_durationAdjustedCertificateCount_Various(b *testing.B) {"," \t}"," }"," ","-// Made with Bob","+// makeCert creates a test certificate with the given validity.","+func makeCert(t *testing.T, validity time.Duration) *x509.Certificate {","+\tt.Helper()","+","+\t// AddIssuedCertificate only uses NotBefore/NotAfter, so a minimal x509.Certificate is sufficient.","+\tnotBefore := time.Now()","+\treturn &x509.Certificate{","+\t\tNotBefore: notBefore,","+\t\tNotAfter:  notBefore.Add(validity),","+\t}","+}","+","+// TestWithMountInfo_PKI verifies that WithMountInfo followed by AddIssuedCertificate","+// populates PkiMountAttributions with the correct count (duration-adjusted units) and","+// metadata, while leaving SshCertMountAttributions and SshOtpMountAttributions empty.","+func TestWithMountInfo_PKI(t *testing.T) {","+\trecording := &TestCertificateCounter{}","+","+\tmount := MountAttribution{","+\t\tMountAccessor:    \"pki_abc123\",","+\t\tMountPath:        \"pki/\",","+\t\tMountType:        \"pki\",","+\t\tNamespaceID:      \"root\",","+\t\tNamespacePath:    \"\",","+\t\tBackendAwareUUID: \"pki-backend-uuid-001\",","+\t}","+","+\t// 730 h = 1 standard duration = 1.0000 billing unit","+\tcert := makeCert(t, 730*time.Hour)","+\tNewCertCountIncrementer(recording).WithMountInfo(mount).AddIssuedCertificate(true, cert)","+","+\trequire.Equal(t, uint64(1), recording.Record.IssuedCerts)","+\trequire.Equal(t, uint64(1), recording.Record.StoredCerts)","+\trequire.InDelta(t, 1.0, recording.Record.PkiDurationAdjustedCerts, 0.0001)","+","+\trequire.Len(t, recording.Record.PkiMountAttributions, 1)","+\tattr := recording.Record.PkiMountAttributions[mount.MountAccessor]","+\trequire.Equal(t, mount.MountAccessor, attr.MountAccessor)","+\trequire.Equal(t, mount.MountPath, attr.MountPath)","+\trequire.Equal(t, mount.MountType, attr.MountType)","+\trequire.Equal(t, mount.NamespaceID, attr.NamespaceID)","+\trequire.Equal(t, mount.BackendAwareUUID, attr.BackendAwareUUID)","+\trequire.InDelta(t, 1.0, attr.Count.(float64), 0.0001, \"per-mount count should equal billing units\")","+","+\trequire.Empty(t, recording.Record.SshCertMountAttributions)","+\trequire.Empty(t, recording.Record.SshOtpMountAttributions)","+}","+","+// TestWithMountInfo_SSH verifies that WithMountInfo followed by AddSSHCertificate","+// populates SshCertMountAttributions.","+func TestWithMountInfo_SSH(t *testing.T) {","+\trecording := &TestCertificateCounter{}","+","+\tmount := MountAttribution{","+\t\tMountAccessor:    \"ssh_xyz789\",","+\t\tMountPath:        \"ssh/\",","+\t\tMountType:        \"ssh\",","+\t\tNamespaceID:      \"ns1\",","+\t\tNamespacePath:    \"ns1/\",","+\t\tBackendAwareUUID: \"ssh-backend-uuid-001\",","+\t}","+","+\t// 730 h = 1.0 billing unit","+\tNewCertCountIncrementer(recording).WithMountInfo(mount).AddSSHCertificate(730 * time.Hour)","+","+\trequire.InDelta(t, 1.0, recording.Record.SSHIssuedCerts, 0.0001)","+\trequire.Len(t, recording.Record.SshCertMountAttributions, 1)","+\tattr := recording.Record.SshCertMountAttributions[mount.MountAccessor]","+\trequire.Equal(t, mount.MountAccessor, attr.MountAccessor)","+\trequire.Equal(t, mount.MountPath, attr.MountPath)","+\trequire.Equal(t, mount.MountType, attr.MountType)","+\trequire.Equal(t, mount.NamespaceID, attr.NamespaceID)","+\trequire.Equal(t, mount.NamespacePath, attr.NamespacePath)","+\trequire.Equal(t, mount.BackendAwareUUID, attr.BackendAwareUUID)","+\trequire.InDelta(t, 1.0, attr.Count.(float64), 0.0001)","+","+\trequire.Empty(t, recording.Record.PkiMountAttributions)","+\trequire.Empty(t, recording.Record.SshOtpMountAttributions)","+}","+","+// TestWithMountInfo_SSHOTP verifies that WithMountInfo followed by AddSSHOTP","+// populates SshOtpMountAttributions with the fixed OTP unit value.","+func TestWithMountInfo_SSHOTP(t *testing.T) {","+\trecording := &TestCertificateCounter{}","+","+\tmount := MountAttribution{","+\t\tMountAccessor:    \"ssh_otp_001\",","+\t\tMountPath:        \"ssh/\",","+\t\tMountType:        \"ssh\",","+\t\tNamespaceID:      \"root\",","+\t\tBackendAwareUUID: \"ssh-backend-uuid-002\",","+\t}","+","+\tNewCertCountIncrementer(recording).WithMountInfo(mount).AddSSHOTP()","+","+\trequire.InDelta(t, 0.0014, recording.Record.SSHIssuedOTPs, 0.00001)","+\trequire.Len(t, recording.Record.SshOtpMountAttributions, 1)","+\tattr := recording.Record.SshOtpMountAttributions[mount.MountAccessor]","+\trequire.Equal(t, mount.MountAccessor, attr.MountAccessor)","+\trequire.Equal(t, mount.MountPath, attr.MountPath)","+\trequire.Equal(t, mount.MountType, attr.MountType)","+\trequire.Equal(t, mount.NamespaceID, attr.NamespaceID)","+\trequire.Equal(t, mount.BackendAwareUUID, attr.BackendAwareUUID)","+\trequire.InDelta(t, 0.0014, attr.Count.(float64), 0.00001)","+","+\trequire.Empty(t, recording.Record.PkiMountAttributions)","+\trequire.Empty(t, recording.Record.SshCertMountAttributions)","+}","+","+// TestWithMountInfo_EmptyAccessorSkipped verifies that when MountAccessor is empty","+// no attribution entry is recorded (guards against a blank map key), and that","+// mountInfo is consumed so a subsequent Add* on the same incrementer also has no attribution.","+func TestWithMountInfo_EmptyAccessorSkipped(t *testing.T) {","+\trecording := &TestCertificateCounter{}","+","+\temptyMount := MountAttribution{","+\t\tMountAccessor: \"\", // intentionally blank","+\t\tMountPath:     \"pki/\",","+\t\tMountType:     \"pki\",","+\t}","+","+\tcert := makeCert(t, 730*time.Hour)","+\tinc := NewCertCountIncrementer(recording)","+","+\t// First call: WithMountInfo(empty) then Add — must not produce attribution.","+\tinc.WithMountInfo(emptyMount).AddIssuedCertificate(false, cert)","+\trequire.Equal(t, uint64(1), recording.Record.IssuedCerts)","+\trequire.Empty(t, recording.Record.PkiMountAttributions, \"blank accessor must not produce attribution entry\")","+","+\t// Reset recorder and call Add again on the same incrementer without WithMountInfo.","+\t// mountInfo should have been consumed (set to nil) by the first call.","+\trecording.Record = CertCount{}","+\tinc.AddIssuedCertificate(false, cert)","+\trequire.Equal(t, uint64(1), recording.Record.IssuedCerts)","+\trequire.Empty(t, recording.Record.PkiMountAttributions, \"stale mountInfo must not leak into a subsequent Add call\")","+}","+","+// TestWithMountInfo_NotCalledNoAttribution verifies that omitting WithMountInfo","+// produces no attribution maps, maintaining backward compatibility.","+func TestWithMountInfo_NotCalledNoAttribution(t *testing.T) {","+\trecording := &TestCertificateCounter{}","+","+\tcert := makeCert(t, 730*time.Hour)","+\tNewCertCountIncrementer(recording).AddIssuedCertificate(true, cert)","+","+\trequire.Equal(t, uint64(1), recording.Record.IssuedCerts)","+\trequire.Empty(t, recording.Record.PkiMountAttributions)","+\trequire.Empty(t, recording.Record.SshCertMountAttributions)","+\trequire.Empty(t, recording.Record.SshOtpMountAttributions)","+}","+","+// TestCertCount_Add_MergesAttributions verifies that CertCount.Add correctly","+// accumulates per-mount counts across multiple Add calls for all three metric types.","+func TestCertCount_Add_MergesAttributions(t *testing.T) {","+\ta := CertCount{","+\t\tPkiDurationAdjustedCerts: 1.0,","+\t\tSSHIssuedCerts:           0.5,","+\t\tSSHIssuedOTPs:            0.0014,","+\t\tPkiMountAttributions: map[string]MountAttribution{","+\t\t\t\"pki_aaa\": {MountAccessor: \"pki_aaa\", Count: 1.0},","+\t\t},","+\t\tSshCertMountAttributions: map[string]MountAttribution{","+\t\t\t\"ssh_aaa\": {MountAccessor: \"ssh_aaa\", Count: 0.5},","+\t\t},","+\t\tSshOtpMountAttributions: map[string]MountAttribution{","+\t\t\t\"otp_aaa\": {MountAccessor: \"otp_aaa\", Count: 0.0014},","+\t\t},","+\t}","+\tb := CertCount{","+\t\tPkiDurationAdjustedCerts: 2.0,","+\t\tSSHIssuedCerts:           1.0,","+\t\tSSHIssuedOTPs:            0.0014,","+\t\tPkiMountAttri