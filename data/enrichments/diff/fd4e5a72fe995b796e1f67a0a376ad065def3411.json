uxbar-slide-in 250ms ease-out;","+}","+","+@keyframes editor-slide-up {","+\tfrom {","+\t\ttransform: translateY(30%);","+\t\topacity: 0.5;","+\t}","+","+\tto {","+\t\ttransform: translateY(0);","+\t\topacity: 1;","+\t}","+}","+","+@keyframes panel-slide-up {","+\tfrom {","+\t\ttransform: translateY(100%);","+\t\topacity: 0.5;","+\t}","+","+\tto {","+\t\ttransform: translateY(0);","+\t\topacity: 1;","+\t}","+}","+","+@keyframes auxbar-slide-in {","+\tfrom {","+\t\ttransform: translateX(100%);","+\t\topacity: 0;","+\t}","+","+\tto {","+\t\ttransform: translateX(0);","+\t\topacity: 1;","+\t}","+}"],"additions":209,"deletions":0,"truncated":false},{"path":"src/vs/sessions/browser/media/style.css","lines":["@@ -3,14 +3,6 @@","  *  Licensed under the MIT License. See License.txt in the project root for license information.","  *--------------------------------------------------------------------------------------------*/"," ","-/* The model picker hover (shared with the main workbench chat) masks its dotted cost-table","- * leader with an opaque surface color, defaulting to the menu background. In the agents window","- * the hover sits on the panel surface, so scope the surface color to the panel background here.","- * The hover is portaled but mounts inside this workbench root, so it inherits this value. */","-.agent-sessions-workbench {","-\t--model-hover-surface-background: var(--vscode-agentsPanel-background);","-}","-"," /* ---- Action Bar Items ---- */"," "," /* Default rounded hover/active background for all action bar items in the","@@ -28,313 +20,6 @@"," \tborder-radius: var(--vscode-cornerRadius-small);"," }"," ","-/* ---- Sidebar & Auxiliary Bar Card Appearance ---- */","-","-.agent-sessions-workbench .part.sidebar {","-\tbackground: var(--vscode-agents-background);","-}","-","-.agent-sessions-workbench > .monaco-grid-view {","-\tbackground-color: var(--vscode-agents-background);","-}","-","-.agent-sessions-workbench.shell-gradient-background {","-\tposition: 