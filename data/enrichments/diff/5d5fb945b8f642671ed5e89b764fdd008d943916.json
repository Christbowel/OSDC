no conflict with non-imported ones","+\tif models.Provenance(provenance) != models.ProvenanceConvertedPrometheus && len(name) > util.MaxUIDLength {","+\t\treturn nil, fmt.Errorf(\"inhibition rule name is too long (exceeds %d characters)\", util.MaxUIDLength)","+\t}","+","+\treturn &InhibitionRule{","+\t\tName:        name,","+\t\tInhibitRule: rule,","+\t\tProvenance:  provenance,","+\t}, nil","+}","+","+// PostableMimirReceiverToPostableGrafanaReceiver converts all legacy models to PostableGrafanaReceiver.","+// If receiver does not have any legacy receivers, returns the original receiver.","+// Otherwise, returns a copy that contains converted integrations (and shallow copy of existing Grafana integrations).","+func PostableMimirReceiverToPostableGrafanaReceiver(r *PostableApiReceiver) (*PostableApiReceiver, error) {","+\tif !r.HasMimirIntegrations() {","+\t\treturn r, nil","+\t}","+\tv0, err := alertingNotify.ConfigReceiverToMimirIntegrations(r.Receiver)","+\tif err != nil {","+\t\treturn nil, fmt.Errorf(\"failed to convert v0 receiver to integrations: %w\", err)","+\t}","+\tresult := &PostableApiReceiver{","+\t\tReceiver: definition.Receiver{","+\t\t\tName: r.Name,","+\t\t},","+\t\tPostableGrafanaReceivers: PostableGrafanaReceivers{","+\t\t\tGrafanaManagedReceivers: make([]*PostableGrafanaReceiver, 0, len(v0)+len(r.GrafanaManagedReceivers)),","+\t\t},","+\t}","+\tresult.GrafanaManagedReceivers = append(result.GrafanaManagedReceivers, r.GrafanaManagedReceivers...)","+\ttypeCount := make(map[string]int)","+\tfor _, cfg := range v0 {","+\t\tintegrationType := string(cfg.Schema.Type())","+\t\tidx := typeCount[integrationType]","+\t\ttypeCount[integrationType]++","+\t\tintegration, err := MimirIntegrationConfigToPostableGrafanaReceiver(cfg, r.Name, idx)","+\t\tif err != nil {","+\t\t\treturn nil, fmt.Errorf(\"failed to convert Mimir integration config to PostableGrafanaReceiver: %w\", err)","+\t\t}","+\t\tresult.GrafanaManagedReceivers = append(result.GrafanaManagedReceivers, integration)","+\t}","+\treturn result, nil","+}","+","+// MimirIntegrationConfigToPostableGrafanaReceiver converts a Mimir integration configuration to a PostableGrafanaReceiver. All settings are unencrypted. Needs to be encrypted later.","+func MimirIntegrationConfigToPostableGrafanaReceiver(cfg alertingNotify.MimirIntegrationConfig, receiverName string, idx int) (*PostableGrafanaReceiver, error) {","+\traw, err := cfg.ConfigJSON()","+\tif err != nil {","+\t\treturn nil, err","+\t}","+","+\treturn &PostableGrafanaReceiver{","+\t\t// mimirIntegrationUID generates a stable, fixed-length UID for a converted Mimir integration that passes ValidateUID, 40-char limit for long names in particular","+\t\tUID:                   mimirIntegrationUID(receiverName, string(cfg.Schema.Type()), idx),","+\t\tName:                  receiverName,","+\t\tType:                  string(cfg.Schema.Type()),","+\t\tVersion:               string(cfg.Schema.Version),","+\t\tDisableResolveMessage: false, // V0 ignores this flag as they have their own SendResolved one.","+\t\tSettings:              raw,","+\t\tSecureSettings:        nil,","+\t}, nil","+}","+","+func mimirIntegrationUID(receiverName string, integrationType string, idx int) string {","+\th := fnv.New64a()","+\t_, _ = fmt.Fprintf(h, \"%s-%s-%d\", receiverName, integrationType, idx)","+\treturn fmt.Sprintf(\"%016x\", h.Sum64())","+}"],"additions":91,"deletions":0,"truncated":false},{"path":"pkg/services/ngalert/notifier/legacy_storage/v1/compat_test.go","lines":["@@ -2,13 +2,21 @@ package v1"," "," import ("," \t\"encoding/json\"","+\t\"errors\""," \t\"testing\""," "," \t\"github.com/google/go-cmp/cmp\""," \t\"github.com/google/go-cmp/cmp/cmpopts\""," \t\"github.com/grafana/alerting/definition\"","+\talertingNotify \"github.com/grafana/alerting/notify\"","+\temailV0 \"github.com/grafana/alerting/receivers/email/v0mimir1\"","+\twebhookV0 \"github.com/grafana/alerting/receivers/webhook/v0mimir1\"","+\t\"github.com/prometheu