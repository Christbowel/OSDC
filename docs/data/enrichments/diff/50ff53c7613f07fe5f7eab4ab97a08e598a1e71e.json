{"id":"50ff53c7613f07fe5f7eab4ab97a08e598a1e71e","axis":"silent","repo":"wandb/wandb","sha":"50ff53c7613f07fe5f7eab4ab97a08e598a1e71e","parsed":{"files":[{"path":"core/go.mod","lines":["@@ -30,6 +30,7 @@ require ("," \tgithub.com/prometheus/common v0.70.1"," \tgithub.com/prometheus/procfs v0.21.1"," \tgithub.com/radovskyb/watcher v1.0.7","+\tgithub.com/rogpeppe/go-internal v1.14.1"," \tgithub.com/shirou/gopsutil/v4 v4.26.6"," \tgithub.com/spf13/afero v1.15.0"," \tgithub.com/stretchr/testify v1.11.1"],"additions":1,"deletions":0,"truncated":false},{"path":"core/internal/runsync/runsyncer.go","lines":["@@ -12,6 +12,7 @@ import ("," "," \t\"github.com/wandb/wandb/core/internal/observability\""," \t\"github.com/wandb/wandb/core/internal/runhandle\"","+\t\"github.com/wandb/wandb/core/internal/runsyncstate\""," \t\"github.com/wandb/wandb/core/internal/runwork\""," \t\"github.com/wandb/wandb/core/internal/settings\""," \t\"github.com/wandb/wandb/core/internal/stream\"","@@ -72,7 +73,12 @@ func (f *RunSyncerFactory) New("," \t\trunWork,"," \t\t/*fileReadDelay=*/ 5*time.Second,"," \t)","-\trecordParser := f.RecordParserFactory.New(runWork.BeforeEndCtx(), tbHandler)","+\tsyncStateStore := runsyncstate.File(path)","+\trecordParser := f.RecordParserFactory.New(","+\t\trunWork.BeforeEndCtx(),","+\t\ttbHandler,","+\t\tsyncStateStore,","+\t)"," \trunReader := f.RunReaderFactory.New("," \t\tpath,"," \t\tdisplayPath,"],"additions":7,"deletions":1,"truncated":false},{"path":"core/internal/runsyncstate/syncstate.go","lines":["@@ -0,0 +1,88 @@","+package runsyncstate","+","+import (","+\t\"encoding/json\"","+\t\"fmt\"","+","+\t\"github.com/rogpeppe/go-internal/lockedfile\"","+)","+","+// syncStateSuffix is appended to a .wandb file's path to get the path of","+// its sync state file.","+const syncStateSuffix = \".syncstate\"","+","+// syncState is a run's saved upload state.","+//","+// It is stored in a file alongside the `.wandb` file, and may be updated","+// when run data is uploaded to the server, either during `wandb sync` or","+// during an online run's automatic upload.","+type syncState struct {","+\t// StartingStep is the initial step number for the run.","+\t//","+\t// For new runs this is zero.","+\t// For forked runs this is specified by the user when they create the run.","+\t// For resumed runs, this is determined during the first upload.","+\tStartingStep *int64 `json:\"starting_step,omitempty\"`","+}","+","+// GetOrInitStartingStep returns the starting step previously initialized, if any.","+//","+// Otherwise, it persists startingStep so that future calls (including from","+// other processes) return the same value.","+//","+// The read-check-write is performed under an exclusive file lock so that","+// concurrent syncs of the same file can't race.","+type Store interface {","+\tGetOrInitStartingStep(startingStep int64) (int64, error)","+}","+","+// SyncStateStore reads and updates the sync state file for a","+// single run.","+type fileStore struct {","+\t// path is the path to the sync state file.","+\tpath string","+}","+","+type noopStore struct{}","+","+func Noop() Store {","+\treturn &noopStore{}","+}","+","+func (s *noopStore) GetOrInitStartingStep(startingStep int64) (int64, error) {","+\treturn startingStep, nil","+}","+","+// File returns a store for a run's sync state file.","+func File(transactionLogPath string) Store {","+\treturn &fileStore{path: transactionLogPath + syncStateSuffix}","+}","+","+// GetOrInitStartingStep implements Store.GetOrInitStartingStep.","+func (s *fileStore) GetOrInitStartingStep(","+\tstartingStep int64,","+) (int64, error) {","+\tvar state syncState","+","+\terr := lockedfile.Transform(s.path, func(data []byte) ([]byte, error) {","+\t\tif len(data) > 0 {","+\t\t\tif err := json.Unmarshal(data, &state); err != nil {","+\t\t\t\treturn nil, fmt.Errorf(\"runsync: failed to parse sync state file: %v\", err)","+\t\t\t}","+\t\t\tif state.StartingStep != nil {","+\t\t\t\treturn data, nil","+\t\t\t}","+\t\t}","+","+\t\tstate.StartingStep = &startingStep","+\t\tupdated, err := json.Marshal(state)","+\t\tif err != nil {","+\t\t\treturn nil, fmt.Errorf(\"runsync: failed to encode sync state file: %v\", err)","+\t\t}","+\t\treturn updated, nil","+\t})","+\tif err != nil {","+\t\treturn 0, fmt.Errorf(\"runsync: failed to update sync state file: %v\", err)","+\t}","+\treturn *state.StartingStep, nil","+}"],"additions":88,"deletions":0,"truncated":false},{"path":"core/internal/runsyncstate/syncstate_test.go","lines":["@@ -0,0 +1,58 @@","+package runsyncstate_test","+","+import (","+\t\"os\"","+\t\"path/filepath\"","+\t\"testing\"","+","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+","+\t\"github.com/wandb/wandb/core/internal/runsyncstate\"","+)","+","+func TestSyncStateStore_GetOrInitStartingStep_PersistsFirstValue(t *testing.T) {","+\twandbFile := filepath.Join(t.TempDir(), \"run-xyz.wandb\")","+\tstore := runsyncstate.File(wandbFile)","+","+\tstep, err := store.GetOrInitStartingStep(5)","+\trequire.NoError(t, err)","+\tassert.EqualValues(t, 5, step)","+","+\t// A second call should reuse the initialized value, regardless of the","+\t// passed-in value.","+\tstep, err = store.GetOrInitStartingStep(999)","+\trequire.NoError(t, err)","+\tassert.EqualValues(t, 5, step)","+}","+","+func TestSyncStateStore_GetOrInitStartingStep_PersistsAcrossStores(t *testing.T) {","+\twandbFile := filepath.Join(t.TempDir(), \"run-xyz.wandb\")","+","+\t_, err := runsyncstate.File(wandbFile).GetOrInitStartingStep(7)","+\trequire.NoError(t, err)","+","+\t// A fresh store instance should read the previously initialized value.","+\tstep, err := runsyncstate.File(wandbFile).GetOrInitStartingStep(42)","+\trequire.NoError(t, err)","+\tassert.EqualValues(t, 7, step)","+}","+","+func TestSyncStateStore_GetOrInitStartingStep_HandlesMissingStartingStep(t *testing.T) {","+\twandbFile := filepath.Join(t.TempDir(), \"run-xyz.wandb\")","+","+\t// Simulate a pre-existing sync state file that's valid JSON but","+\t// doesn't set starting_step. This should behave like an uninitialized","+\t// file.","+\trequire.NoError(t,","+\t\tos.WriteFile(wandbFile+\".syncstate\", []byte(\"{}\"), 0o666))","+","+\tstep, err := runsyncstate.File(wandbFile).GetOrInitStartingStep(5)","+\trequire.NoError(t, err)","+\tassert.EqualValues(t, 5, step)","+","+\t// The value should now be persisted for subsequent calls.","+\tstep, err = runsyncstate.File(wandbFile).GetOrInitStartingStep(999)","+\trequire.NoError(t, err)","+\tassert.EqualValues(t, 5, step)","+}"],"additions":58,"deletions":0,"truncated":false},{"path":"core/internal/runupserter/runupdatework.go","lines":["@@ -11,6 +11,7 @@ import ("," "," \t\"github.com/wandb/wandb/core/internal/featurechecker\""," \t\"github.com/wandb/wandb/core/internal/observability\"","+\t\"github.com/wandb/wandb/core/internal/runsyncstate\""," \t\"github.com/wandb/wandb/core/internal/runwork\""," \t\"github.com/wandb/wandb/core/internal/settings\""," \t\"github.com/wandb/wandb/core/internal/wboperation\"","@@ -53,6 +54,7 @@ type RunUpdateWork struct {"," \tFeatureProvider    *featurechecker.FeatureProvider"," \tGraphqlClientOrNil graphql.Client"," \tLogger             *observability.CoreLogger","+\tSyncStateStore     runsyncstate.Store"," }"," "," // Accept implements WorkImpl.Accept.","@@ -98,6 +100,7 @@ func (w *RunUpdateWork) initRun(request *runwork.Request) {"," \t\tFeatureProvider:    w.FeatureProvider,"," \t\tGraphqlClientOrNil: w.GraphqlClientOrNil,"," \t\tLogger:             w.Logger,","+\t\tSyncStateStore:     w.SyncStateStore,"," \t})"," "," \tif err != nil {"],"additions":3,"deletions":0,"truncated":false},{"path":"core/internal/runupserter/runupserter.go","lines":["@@ -23,6 +23,7 @@ import ("," \t\"github.com/wandb/wandb/core/internal/runconfig\""," \t\"github.com/wandb/wandb/core/internal/runenvironment\""," \t\"github.com/wandb/wandb/core/internal/runmetric\"","+\t\"github.com/wandb/wandb/core/