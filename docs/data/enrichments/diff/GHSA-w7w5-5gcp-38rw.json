{"id":"GHSA-w7w5-5gcp-38rw","axis":"advisories","repo":"forgekeep/nebula-mesh","sha":"b45fda5476c41ffcff1ca23058aef0fb851359c1","parsed":{"files":[{"path":"internal/cli/security_headers.go","lines":["@@ -0,0 +1,32 @@","+package cli","+","+import \"net/http\"","+","+// securityHeaders wraps next with HTTP response security headers per advisory","+// GHSA-w7w5-5gcp-38rw: clickjacking, MIME sniffing, referrer leakage, and","+// (on TLS) protocol downgrade defenses.","+//","+// CSP keeps 'unsafe-inline' on script-src and style-src for compatibility","+// with existing inline <script>, <style>, onclick=, and style=\"...\" usage","+// in templates. Tightening that requires extracting inline blocks and","+// rewiring inline event handlers, tracked separately.","+func securityHeaders(next http.Handler) http.Handler {","+\tconst csp = \"default-src 'self'; \" +","+\t\t\"script-src 'self' 'unsafe-inline'; \" +","+\t\t\"style-src 'self' 'unsafe-inline'; \" +","+\t\t\"img-src 'self' data:; \" +","+\t\t\"frame-ancestors 'none'; \" +","+\t\t\"base-uri 'none'; \" +","+\t\t\"form-action 'self'\"","+\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\th := w.Header()","+\t\th.Set(\"Content-Security-Policy\", csp)","+\t\th.Set(\"X-Content-Type-Options\", \"nosniff\")","+\t\th.Set(\"Referrer-Policy\", \"same-origin\")","+\t\th.Set(\"X-Frame-Options\", \"DENY\")","+\t\tif r.TLS != nil {","+\t\t\th.Set(\"Strict-Transport-Security\", \"max-age=31536000; includeSubDomains\")","+\t\t}","+\t\tnext.ServeHTTP(w, r)","+\t})","+}"],"additions":32,"deletions":0,"truncated":false},{"path":"internal/cli/security_headers_test.go","lines":["@@ -0,0 +1,111 @@","+package cli","+","+import (","+\t\"crypto/tls\"","+\t\"net/http\"","+\t\"net/http/httptest\"","+\t\"strings\"","+\t\"testing\"","+)","+","+func TestSecurityHeaders_PlainHTTP(t *testing.T) {","+\tinner := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\tw.WriteHeader(http.StatusOK)","+\t})","+\th := securityHeaders(inner)","+","+\trec := httptest.NewRecorder()","+\treq := httptest.NewRequest(http.MethodGet, \"/anything\", nil)","+\th.ServeHTTP(rec, req)","+","+\tgot := rec.Result().Header","+","+\twantPrefix := map[string]string{","+\t\t\"Content-Security-Policy\": \"default-src 'self';\",","+\t\t\"X-Content-Type-Options\":  \"nosniff\",","+\t\t\"Referrer-Policy\":         \"same-origin\",","+\t\t\"X-Frame-Options\":         \"DENY\",","+\t}","+\tfor k, prefix := range wantPrefix {","+\t\tv := got.Get(k)","+\t\tif v == \"\" {","+\t\t\tt.Errorf(\"%s missing\", k)","+\t\t\tcontinue","+\t\t}","+\t\tif !strings.HasPrefix(v, prefix) {","+\t\t\tt.Errorf(\"%s = %q, want prefix %q\", k, v, prefix)","+\t\t}","+\t}","+","+\t// HSTS must NOT be set on plain HTTP — sending it from a plain","+\t// listener would invite the client to upgrade to a non-listening","+\t// HTTPS endpoint.","+\tif v := got.Get(\"Strict-Transport-Security\"); v != \"\" {","+\t\tt.Errorf(\"HSTS set on plain HTTP: %q\", v)","+\t}","+}","+","+func TestSecurityHeaders_TLS_SetsHSTS(t *testing.T) {","+\tinner := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\tw.WriteHeader(http.StatusOK)","+\t})","+\th := securityHeaders(inner)","+","+\trec := httptest.NewRecorder()","+\treq := httptest.NewRequest(http.MethodGet, \"/anything\", nil)","+\treq.TLS = &tls.ConnectionState{}","+\th.ServeHTTP(rec, req)","+","+\thsts := rec.Result().Header.Get(\"Strict-Transport-Security\")","+\tif hsts == \"\" {","+\t\tt.Fatal(\"HSTS missing on TLS request\")","+\t}","+\tif !strings.Contains(hsts, \"max-age=\") {","+\t\tt.Errorf(\"HSTS without max-age: %q\", hsts)","+\t}","+\tif !strings.Contains(hsts, \"includeSubDomains\") {","+\t\tt.Errorf(\"HSTS without includeSubDomains: %q\", hsts)","+\t}","+}","+","+func TestSecurityHeaders_CSPDirectives(t *testing.T) {","+\tinner := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\tw.WriteHeader(http.StatusOK)","+\t})","+\th := securityHeaders(inner)","+","+\trec := httptest.NewRecorder()","+\treq := httptest.NewRequest(http.MethodGet, \"/\", nil)","+\th.ServeHTTP(rec, req)","+","+\tcsp := rec.Result().Header.Get(\"Content-Security-Policy\")","+\twant := []string{","+\t\t\"default-src 'self'\",","+\t\t\"frame-ancestors 'none'\",","+\t\t\"base-uri 'none'\",","+\t\t\"form-action 'self'\",","+\t}","+\tfor _, d := range want {","+\t\tif !strings.Contains(csp, d) {","+\t\t\tt.Errorf(\"CSP missing %q; got %q\", d, csp)","+\t\t}","+\t}","+}","+","+func TestSecurityHeaders_AppliedOnErrorResponse(t *testing.T) {","+\tinner := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\thttp.Error(w, \"boom\", http.StatusInternalServerError)","+\t})","+\th := securityHeaders(inner)","+","+\trec := httptest.NewRecorder()","+\treq := httptest.NewRequest(http.MethodGet, \"/\", nil)","+\th.ServeHTTP(rec, req)","+","+\tif rec.Code != http.StatusInternalServerError {","+\t\tt.Fatalf(\"status = %d, want 500\", rec.Code)","+\t}","+\tif rec.Result().Header.Get(\"X-Frame-Options\") != \"DENY\" {","+\t\tt.Error(\"security headers stripped on error response\")","+\t}","+}"],"additions":111,"deletions":0,"truncated":false},{"path":"internal/cli/serve.go","lines":["@@ -227,7 +227,7 @@ func Serve(configPath string) error {"," "," \thttpServer := &http.Server{"," \t\tAddr:         cfg.Listen,","-\t\tHandler:      mux,","+\t\tHandler:      securityHeaders(mux),"," \t\tReadTimeout:  10 * time.Second,"," \t\tWriteTimeout: 10 * time.Second,"," \t}",""],"additions":1,"deletions":1,"truncated":false}],"additions":144,"deletions":1,"truncated":false,"file_count":3},"error":null,"fetched_at":"2026-06-09T10:50:06.754510+00:00"}