ose') {","+          process.nextTick(() => handler(0))","+        }","+      },","+      unref: () => {}","+    }","+  }","+","+  const fsExport = loadFsForPlatform('darwin')","+  await fsExport.openFile('/tmp/poc\";touch /tmp/pwn;#.txt')","+","+  assert.equal(spawnCall.command, 'open')","+  assert.deepEqual(spawnCall.args, ['/tmp/poc\";touch /tmp/pwn;#.txt'])","+  assert.equal(spawnCall.options.detached, false)","+})",""],"additions":87,"deletions":0,"truncated":false}],"additions":144,"deletions":14,"truncated":false,"file_count":4},"error":null,"fetched_at":"2026-05-20T17:33:23.810387+00:00"}