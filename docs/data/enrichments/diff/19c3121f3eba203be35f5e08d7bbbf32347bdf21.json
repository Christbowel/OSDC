? 'no-store' : undefined,","+\t\t\t});","+\t\t\tconst stream = response.body","+\t\t\t\t? responseBodyToStream(response.body, cancellation, cancellationListener)","+\t\t\t\t: emptyResponseStream(cancellationListener);","+\t\t\treturn {","+\t\t\t\tres: {","+\t\t\t\t\tstatusCode: response.status,","+\t\t\t\t\theaders: getResponseHeaders(response),","+\t\t\t\t},","+\t\t\t\tstream,","+\t\t\t};","+\t\t} catch (error) {","+\t\t\tcancellationListener.dispose();","+\t\t\tif (error instanceof Error && error.name === 'AbortError') {","+\t\t\t\tthrow new CancellationError();","+\t\t\t}","+\t\t\tif (error instanceof Error && error.name === 'TimeoutError') {","+\t\t\t\tthrow new Error(`Fetch timeout: ${options.timeout}ms`);","+\t\t\t}","+\t\t\tthrow error;","+\t\t}","+\t}","+}","+","+function getRequestHeaders(options: IRequestOptions): Headers | undefined {","+\tif (!options.headers && !options.user && !options.password && !options.proxyAuthorization) {","+\t\treturn undefined;","+\t}","+\tconst headers = new Headers();","+\tfor (const key in options.headers) {","+\t\tconst value = options.headers[key];","+\t\tif (typeof value === 'string') {","+\t\t\theaders.set(key, value);","+\t\t} else if (Array.isArray(value)) {","+\t\t\tfor (const item of value) {","+\t\t\t\theaders.append(key, item);","+\t\t\t}","+\t\t}","+\t}","+\tif (options.user || options.password) {","+\t\theaders.set('Authorization', `Basic ${btoa(`${options.user || ''}:${options.password || ''}`)}`);","+\t}","+\tif (options.proxyAuthorization) {","+\t\theaders.set('Proxy-Authorization', options.proxyAuthorization);","+\t}","+\treturn headers;","+}","+","+function getResponseHeaders(response: Response): IHeaders {","+\tconst headers: IHeaders = Object.create(null);","+\tresponse.headers.forEach((value, key) => {","+\t\theaders[key] = value;","+\t});","+\treturn headers;","+}","+","+function emptyResponseStream(cancellationListener: IDisposable): VSBufferWriteableStream {","+\tconst stream = newWriteableBufferStream