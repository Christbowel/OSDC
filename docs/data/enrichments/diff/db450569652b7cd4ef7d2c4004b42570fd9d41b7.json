{"id":"db450569652b7cd4ef7d2c4004b42570fd9d41b7","axis":"silent","repo":"duckdb/duckdb","sha":"db450569652b7cd4ef7d2c4004b42570fd9d41b7","parsed":{"files":[{"path":"src/common/enum_util.cpp","lines":["@@ -29,6 +29,7 @@"," #include \"duckdb/common/enums/cte_materialize.hpp\""," #include \"duckdb/common/enums/date_part_specifier.hpp\""," #include \"duckdb/common/enums/debug_initialize.hpp\"","+#include \"duckdb/common/enums/debug_order_verification.hpp\""," #include \"duckdb/common/enums/debug_statement_verification.hpp\""," #include \"duckdb/common/enums/debug_vector_verification.hpp\""," #include \"duckdb/common/enums/debug_verification_mode.hpp\"","@@ -1593,6 +1594,25 @@ DebugInitialize EnumUtil::FromString<DebugInitialize>(const char *value) {"," \treturn static_cast<DebugInitialize>(StringUtil::StringToEnum(GetDebugInitializeValues(), 3, \"DebugInitialize\", value));"," }"," ","+const StringUtil::EnumStringLiteral *GetDebugOrderVerificationValues() {","+\tstatic constexpr StringUtil::EnumStringLiteral values[] {","+\t\t{ static_cast<uint32_t>(DebugOrderVerification::NONE), \"NONE\" },","+\t\t{ static_cast<uint32_t>(DebugOrderVerification::CREATE_SORT_KEY), \"CREATE_SORT_KEY\" },","+\t\t{ static_cast<uint32_t>(DebugOrderVerification::VARIANT), \"VARIANT\" }","+\t};","+\treturn values;","+}","+","+template<>","+const char* EnumUtil::ToChars<DebugOrderVerification>(DebugOrderVerification value) {","+\treturn StringUtil::EnumToString(GetDebugOrderVerificationValues(), 3, \"DebugOrderVerification\", static_cast<uint32_t>(value));","+}","+","+template<>","+DebugOrderVerification EnumUtil::FromString<DebugOrderVerification>(const char *value) {","+\treturn static_cast<DebugOrderVerification>(StringUtil::StringToEnum(GetDebugOrderVerificationValues(), 3, \"DebugOrderVerification\", value));","+}","+"," const StringUtil::EnumStringLiteral *GetDebugStatementVerificationValues() {"," \tstatic constexpr StringUtil::EnumStringLiteral values[] {"," \t\t{ static_cast<uint32_t>(