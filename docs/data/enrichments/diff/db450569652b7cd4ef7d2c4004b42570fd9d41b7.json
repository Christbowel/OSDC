BJECTS:duckdb_func_variant_main>","     PARENT_SCOPE)"],"additions":2,"deletions":1,"truncated":false},{"path":"src/function/scalar/variant/functions.json","lines":["@@ -142,6 +142,16 @@"," \t\t],"," \t\t\"type\": \"scalar_function\""," \t},","+\t{","+\t\t\"name\": \"variant_comparator\",","+\t\t\"parameters\": \"input_variant\",","+\t\t\"description\": \"Returns a binary sort key that orders `input_variant` according to the logical ordering of VARIANT values (used internally for comparison and ordering).\",","+\t\t\"example\": \"variant_comparator({'a': 1, 'b': 2}::VARIANT)\",","+\t\t\"categories\": [","+\t\t\t\"variant\"","+\t\t],","+\t\t\"type\": \"scalar_function\"","+\t},"," \t{"," \t\t\"name\": \"variant_typeof\","," \t\t\"parameters\": \"input_variant\","],"additions":10,"deletions":0,"truncated":false},{"path":"src/function/scalar/variant/variant_comparator.cpp","lines":["@@ -0,0 +1,573 @@","+#include \"duckdb/function/scalar/variant_functions.hpp\"","+#include \"duckdb/function/create_sort_key.hpp\"","+#include \"duckdb/common/enums/order_type.hpp\"","+#include \"duckdb/common/radix.hpp\"","+#include \"duckdb/common/helper.hpp\"","+#include \"duckdb/common/types/datetime.hpp\"","+#include \"duckdb/common/types/interval.hpp\"","+#include \"duckdb/common/types/uhugeint.hpp\"","+#include \"duckdb/common/types/bignum.hpp\"","+#include \"duckdb/common/types/bit.hpp\"","+#include \"duckdb/common/types/variant.hpp\"","+#include \"duckdb/common/enum_util.hpp\"","+#include \"duckdb/common/vector/flat_vector.hpp\"","+#include \"duckdb/common/vector/string_vector.hpp\"","+#include \"duckdb/function/scalar/variant_utils.hpp\"","+","+#include <algorithm>","+","+namespace duckdb {","+","+namespace {","+","+//===--------------------------------------------------------------------===//","+// Variant Comparator Encoding","+//===--------------------------------------------------------------------===//","+// VARIANT is physically a STRUCT (keys/children/values/data), but ordering it by that physical","+// representation does not match the logical ordering of the values it stores. Instead we traverse","+// the variant and emit a sort key per value as [type-rank][value]. Sorting is performed by type","+// first and value second. Object keys are processed in string-sorted order so that objects that","+// only differ in key order (e.g. {'b': 10, 'a': 1} and {'a': 1, 'b': 10}) compare equal.","+//","+// Types are grouped into \"ranks\" the way a semi-structured system (e.g. Snowflake) groups them:","+// all integers, decimals and bignums fold into a single NUMBER rank (compared by numeric value) and","+// FLOAT/DOUBLE fold into a single REAL rank. Everything else keeps its own rank.","+//","+// The produced key is byte-comparable and self-contained - it is only ever compared against other","+// variant_comparator outputs, so the byte constants below only need to be internally consistent","+// (they mirror the conventions used by create_sort_key).","+","+//! byte constants for the comparator encoding","+constexpr data_t NULL_FIRST_BYTE = 1;","+constexpr data_t NULL_LAST_BYTE = 2;","+constexpr data_t STRING_DELIMITER = 0;","+constexpr data_t LIST_DELIMITER = 0;","+constexpr data_t BLOB_ESCAPE_CHARACTER = 1;","+","+//! BIT/BITSTRING sort-key bytes (mirrors CreateBitStringSortKey in the core_functions bitstring code):","+//! each bit is expanded to one byte, kept above the STRING_DELIMITER (0) so a shorter bitstring (a","+//! prefix) sorts first, while preserving 0 < 1","+constexpr data_t BIT_SORT_KEY_ZERO = 2;","+constexpr data_t BIT_SORT_KEY_ONE = 3;","+","+//! nanoseconds-per-unit scale factors used to fold the DATE / TIME / TIMESTAMP precisions into a","+//! common unit (nanoseconds) so that values of different precision compare by their actual instant","+constexpr int64_t NANOS_PER_MICRO = 1000;","+constexpr int64_t NANOS_PER_MILLI = 1000000;","+constexpr int64_t NANOS_PER_SEC = 1000000000;","+constexpr int64_t NANOS_PER_DAY = 86400LL * NANOS_PER_SEC;","+","+//! The sort-key rank of a variant value - determines the cross-type ordering (type-first).","+//! Ranks start at 1 so that every rank is strictly greater than the LIST/STRING delimiter (0); this","+//! guarantees a shorter list/object sorts before a longer one (the delimiter is smaller than any","+//! following element's rank byte) and that an element can never be confused with an end-of-list marker.","+enum class VariantSortRank : data_t {","+\tBOOLEAN = 1,","+\tNUMBER,","+\tREAL,","+\tVARCHAR,","+\tBLOB,","+\tUUID,","+\tTIMESTAMP,    // DATE and all non-tz TIMESTAMP precisions, compared as nanoseconds since the epoch","+\tTIMESTAMP_TZ, // TIMESTAMP WITH TIME ZONE (all precisions), compared as nanoseconds since the epoch (UTC)","+\tTIME,         // TIME (all precisions), compared as nanoseconds since midnight","+\tTIME_TZ,      // TIME WITH TIME ZONE","+\tINTERVAL,","+\tGEOMETRY,","+\tBITSTRING,","+\tARRAY,","+\tOBJECT,","+\t//! VARIANT_NULL ranks last so a nested NULL element orders after all non-null values, matching the","+\t//! native \"NULLS LAST\" ordering of nested NULLs under ASC. For DESC the ORDER BY operator reverses","+\t//! the (always-ascending) comparator key, which then places nested NULLs first - exactly as native","+\t//! nested ordering does (where the null position within nested types follows ASC/DESC).","+\tNULL_VALUE","+};","+","+data_t GetVariantTypeRank(VariantLogicalType type_id) {","+\tswitch (type_id) {","+\tcase VariantLogicalType::VARIANT_NULL:","+\t\treturn static_cast<data_t>(VariantSortRank::NULL_VALUE);","+\tcase VariantLogicalType::BOOL_TRUE:","+\tcase VariantLogicalType::BOOL_FALSE:","+\t\treturn static_cast<data_t>(VariantSortRank::BOOLEAN);","+\t// all integers, decimals and bignums fold into a single NUMBER rank (compared by numeric value)","+\tcase VariantLogicalType::INT8:","+\tcase VariantLogicalType::INT16:","+\tcase VariantLogicalType::INT32:","+\tcase VariantLogicalType::INT64:","+\tcase VariantLogicalType::INT128:","+\tcase VariantLogicalType::UINT8:","+\tcase VariantLogicalType::UINT16:","+\tcase VariantLogicalType::UINT32:","+\tcase VariantLogicalType::UINT64:","+\tcase VariantLogicalType::UINT128:","+\tcase VariantLogicalType::DECIMAL:","+\tcase VariantLogicalType::BIGNUM:","+\t\treturn static_cast<data_t>(VariantSortRank::NUMBER);","+\t// FLOAT and DOUBLE fold into a single REAL rank","+\tcase VariantLogicalType::FLOAT:","+\tcase VariantLogicalType::DOUBLE:","+\t\treturn static_cast<data_t>(VariantSortRank::REAL);","+\tcase VariantLogicalType::VARCHAR:","+\t\treturn static_cast<data_t>(VariantSortRank::VARCHAR);","+\tcase VariantLogicalType::BLOB:","+\t\treturn static_cast<data_t>(VariantSortRank::BLOB);","+\tcase VariantLogicalType::UUID:","+\t\treturn static_cast<data_t>(VariantSortRank::UUID);","+\t// DATE folds into the TIMESTAMP rank (a date compares as midnight of that day), together with all","+\t// non-tz TIMESTAMP precisions (SEC / MILIS / MICROS / NANOS)","+\tcase VariantLogicalType::DATE:","+\tcase VariantLogicalType::TIMESTAMP_SEC:","+\tcase VariantLogicalType::TIMESTAMP_MILIS:","+\tcase VariantLogicalType::TIMESTAMP_MICROS:","+\tcase VariantLogicalType::TIMESTAMP_NANOS:","+\t\treturn static_cast<data_t>(VariantSortRank::TIMESTAMP);","+\t// TIMESTAMP WITH TIME ZONE precisions fold into a single TIMESTAMP_TZ rank","+\tcase VariantLogicalType::TIMESTAMP_MICROS_TZ:","+\tcase VariantLogicalType::TIMESTAMP_NANOS_TZ:","+\t\treturn static_cast<data_t>(VariantSortRank::TIMESTAMP_TZ);","+\t// TIME precisions fold into a single TIME rank","+\tcase VariantLogicalType::TIME_MICROS:","+\tcase VariantLogicalType::TIME_NANOS:","+\t\treturn static_cast<data_t>(VariantSortRank::TIME);","+\tcase VariantLogicalType::TIME_MICROS_TZ:","+\t\treturn static_cast<data_t>(VariantSortRank::TIME_TZ);","+\tcase VariantLogicalType::INTERVAL:","+\t\treturn static_cast<data_t>(VariantSortRank::INTERVAL);","+\tcase VariantLogicalType::GEOMETRY:","+\t\treturn static_cast<data_t>(VariantSortRank::GEOMETRY);","+\tcase VariantLogicalType::BITSTRING:","+\t\treturn static_cast<data_t>(VariantSortRank::BITSTRING);","+\tcase VariantLogicalType::ARRAY:","+\t\treturn static_cast<data_t>(VariantSortRank::ARRAY);","+\tcase VariantLogicalType::OBJECT:","+\t\treturn static_cast<data_t>(VariantSortRank::OBJECT);","+\tdefault:","+\t\tthrow NotImplementedException(\"Variant type %s is not supported in variant_comparator\",","+\t\t                              EnumUtil::ToString(type_id));","+\t}","+}","+","+//===--------------------------------------------------------------------===//","+// NUMBER rank encoding","+//===--------------------------------------------------------------------===//","+// All integers, decimals and bignums fold into a single NUMBER rank and are compared by numeric","+// value. To make values of different scales/widths comparable (and equal when numerically equal),","+// each value is reduced to an order-preserving \"decimal-scientific\" form:","+//","+//     value = sign * 0.d1 d2 ... dk * 10^adjexp     (d1 != 0, trailing zeros stripped)","+//","+// and encoded as [class][adjexp][digits][terminator], where everything after the class byte is","+// complemented for negatives. This makes e.g. 1::TINYINT, 1::BIGINT, 1.00::DECIMAL and 1::BIGNUM all","+// encode identically, and orders them numerically (so -100.5 < 0 < 1.5 < 15 < ...).","+struct VariantNumberKey {","+\t//! 0 = negative, 1 = zero, 2 = positive (so negatives sort before zero before positives)","+\tdata_t number_class;","+\tint64_t adjusted_exponent;","+\t//! significant decimal digits ('0'..'9'), leading digit non-zero, trailing zeros stripped","+\tstring digits;","+};","+","+//! Build a number key from a sign, the decimal digits of the magnitude (no leading zeros, as e.g.","+//! produced by Uhugeint::ToString) and a base-10 scale (value = magnitude / 10^scale)","+VariantNumberKey BuildNumberKey(bool negative, const string &magnitude_digits, int64_t scale) {","+\tVariantNumberKey key;","+\t// find the first non-zero digit (magnitude strings have no leading zeros, but be defensive)","+\tidx_t first = 0;","+\twhile (first < magnitude_digits.size() && magnitude_digits[first] == '0') {","+\t\tfirst++;","+\t}","+\tif (first == magnitude_digits.size()) {","+\t\t// the value is zero","+\t\tkey.number_class = 1;","+\t\tkey.adjusted_exponent = 0;","+\t\treturn key;","+\t}","+\tkey.number_class = negative ? 0 : 2;","+\t// position of the leading digit: (#digits after leading zeros - 1) - scale","+\tkey.adjusted_exponent = static_cast<int64_t>(magnitude_digits.size() - first) - 1 - scale;","+\t// strip trailing zeros (keep at least the leading digit)","+\tidx_t last = magnitude_digits.size();","+\twhile (last > first + 1 && magnitude_digits[last - 1] == '0') {","+\t\tlast--;","+\t}","+\tkey.digits = magnitude_digits.substr(first, last - first);","+\treturn key;","+}","+","+template <class SINK>","+void VariantEncodeNumber(SINK &sink, const VariantNumberKey &key) {","+\t// the class byte is the primary discriminator and is never complemented","+\tsink.Write(key.number_class);","+\tif (key.number_class == 1) {","+\t\t// zero - the class fully describes the value","+\t\treturn;","+\t}","+\tconst bool negative = key.number_class == 0;","+\t// for negatives we complement every payload byte so that larger magnitudes sort earlier","+\tauto emit = [&](data_t b) {","+\t\tsink.Write(negative ? static_cast<data_t>(~b) : b);","+\t};","+","+\t// adjusted exponent (order-preserving signed encoding) orders magnitude","+\tdata_t exp_buffer[sizeof(int64_t)];","+\tRadix::EncodeData<int64_t>(exp_buffer, key.adjusted_exponent);","+\tfor (idx_t i = 0; i < sizeof(int64_t); i++) {","+\t\temit(exp_buffer[i]);","+\t}","+\t// significant digits (1..10 so the 0x00 terminator is smaller than any digit -> prefix sorts first)","+\tfor (auto c : key.digits) {","+\t\temit(static_cast<data_t>((c - '0') + 1));","+\t}","+\temit(0); // terminator","+}","+","+//! Decompose a 128-bit signed value (hugeint) into (sign, magnitude)","+uhugeint_t HugeintMagnitude(hugeint_t value, bool &negative) {","+\tnegative = value.upper < 0;","+\tuint64_t hi = static_cast<uint64_t>(value.upper);","+\tuint64_t lo = value.lower;","+\tif (negative) {","+\t\t// two's complement negate to get the magnitude","+\t\thi = ~hi;","+\t\tlo = ~lo;","+\t\tif (++lo == 0) {","+\t\t\t++hi;","+\t\t}","+\t}","+\treturn uhugeint_t(hi, lo);","+}","+","+//! Decompose a variant integer value into (sign, 128-bit magnitude)","+uhugeint_t VariantIntegralMagnitude(VariantLogicalType type_id, const_data_ptr_t ptr, bool &negative) {","+\tnegative = false;","+\tswitch (type_id) {","+\tcase VariantLogicalType::INT8:","+\t\treturn HugeintMagnitude(hugeint_t(Load<int8_t>(ptr)), negative);","+\tcase VariantLogicalType::INT16:","+\t\treturn HugeintMagnitude(hugeint_t(Load<int16_t>(ptr)), negative);","+\tcase VariantLogicalType::INT32:","+\t\treturn HugeintMagnitude(hugeint_t(Load<int32_t>(ptr)), negative);","+\tcase VariantLogicalType::INT64:","+\t\treturn HugeintMagnitude(hugeint_t(Load<int64_t>(ptr)), negative);","+\tcase VariantLogicalType::INT128:","+\t\treturn HugeintMagnitude(Load<hugeint_t>(ptr), negative);","+\tcase VariantLogicalType::UINT8:","+\t\treturn uhugeint_t(0, Load<uint8_t>(ptr));","+\tcase VariantLogicalType::UINT16:","+\t\treturn uhugeint_t(0, Load<uint16_t>(ptr));","+\tcase VariantLogicalType::UINT32:","+\t\treturn uhugeint_t(0, Load<uint32_t>(ptr));","+\tcase VariantLogicalType::UINT64:","+\t\treturn uhugeint_t(0, Load<uint64_t>(ptr));","+\tcase VariantLogicalType::UINT128:","+\t\treturn Load<uhugeint_t>(ptr);","+\tdefault:","+\t\tthrow InternalException(\"VariantIntegralMagnitude called on non-integer type\");","+\t}","+}","+","+//! Compute the number key for any value in the NUMBER rank (integer, decimal or bignum)","+VariantNumberKey VariantGetNumberKey(VariantLogicalType type_id, const UnifiedVariantVectorData &variant, idx_t row,","+                                     uint32_t values_idx, const_data_ptr_t value_ptr) {","+\tswitch (type_id) {","+\tcase VariantLogicalType::DECIMAL: {","+\t\tauto decimal_data = VariantUtils::DecodeDecimalData(variant, row, values_idx);","+\t\thugeint_t unscaled;","+\t\tswitch (decimal_data.GetPhysicalType()) {","+\t\tcase PhysicalType::INT16:","+\t\t\tunscaled = hugeint_t(Load<int16_t>(decimal_data.value_ptr));","+\t\t\tbreak;","+\t\tcase PhysicalType::INT32:","+\t\t\tunscaled = hugeint_t(Load<int32_t>(decimal_data.value_ptr));","+\t\t\tbreak;","+\t\tcase PhysicalType::INT64:","+\t\t\tunscaled = hugeint_t(Load<int64_t>(decimal_data.value_ptr));","+\t\t\tbreak;","+\t\tdefault:","+\t\t\tunscaled = Load<hugeint_t>(decimal_data.value_ptr);","+\t\t\tbreak;","+\t\t}","+\t\tbool negative;","+\t\tauto magnitude = HugeintMagnitude(unscaled, negative);","+\t\treturn BuildNumberKey(negative, Uhugeint::ToString(magnitude), decimal_data.scale);","+\t}","+\tcase VariantLogicalType::BIGNUM: {","+\t\tauto bignum_blob = VariantUtils::DecodeStringData(variant, row, values_idx);","+\t\tauto decimal_string = Bignum::BignumToVarchar(bignum_t(bignum_blob));","+\t\tbool negative = !decimal_string.empty() && decimal_string[0] == '-';","+\t\tidx_t offset = negative ? 1 : 0;","+\t\treturn BuildNumberKey(negative, decimal_string.substr(offset), 0);","+\t}","+\tdefault: {","+\t\t// integer types","+\t\tbool negative;","+\t\tauto magnitude = VariantIntegralMagnitude(type_id, value_ptr, negative);","+\t\treturn BuildNumberKey(negative, Uhugeint::ToString(magnitude), 0);","+\t}","+\t}","+}","+","+//! Sink that only computes the encoded length of a variant value","+struct VariantComparatorLengthSink {","+\tidx_t length = 0;","+","+\tinline void Write(data_t) {","+\t\tlength++;","+\t}","+\tinline void WriteBytes(const_data_ptr_t, idx_t count) {","+\t\tlength += count;","+\t}","+};","+","+//! Sink that writes the encoded bytes of a variant value (flipping bytes for DESCENDING order)","+struct VariantComparatorWriteSink {","+\tVariantComparatorWriteSink(data_ptr_t result_ptr, idx_t offset, bool flip_bytes)","+\t    : result_ptr(result_ptr), offset(offset), flip_bytes(flip_bytes) {","+\t}","+","+\tdata_ptr_t result_ptr;","+\tidx_t offset;","+\tbool flip_bytes;","+","+\tinline void Write(data_t b) {","+\t\tresult_ptr[offset++] = flip_bytes ? static_cast<data_t>(~b) : b;","+\t}","+\tinline void WriteBytes(const_data_ptr_t src, idx_t count) {","+\t\tfor (idx_t i = 0; i < count; i++) {","+\t\t\tWrite(src[i]);","+\t\t}","+\t}","+};","+","+template <class T, class SINK>","+void VariantEncodeFixed(SINK &sink, T value) {","+\tdata_t buffer[sizeof(T)];","+\tRadix::EncodeData<T>(buffer, value);","+\tsink.WriteBytes(buffer, sizeof(T));","+}","+","+template <class SINK>","+void VariantEncodeString(SINK &sink, const string_t &str, bool is_varchar) {","+\tauto input_data = const_data_ptr_cast(str.GetData());","+\tauto input_size = str.GetSize();","+\tif (is_varchar) {","+\t\t// VARCHAR is valid UTF-8 (never contains 0xFF) so we use the +1 / null-delimiter scheme","+\t\tfor (idx_t i = 0; i < input_size; i++) {","+\t\t\tsink.Write(static_cast<data_t>(input_data[i] + 1));","+\t\t}","+\t} else {","+\t\t// arbitrary bytes - escape \\x00 and \\x01 so they cannot collide with the delimiter","+\t\tfor (idx_t i = 0; i < input_size; i++) {","+\t\t\tif (input_data[i] <= 1) {","+\t\t\t\tsink.Write(BLOB_ESCAPE_CHARACTER);","+\t\t\t}","+\t\t\tsink.Write(input_data[i]);","+\t\t}","+\t}","+\tsink.Write(STRING_DELIMITER);","+}","+","+template <class SINK>","+void EncodeVariantValue(const UnifiedVariantVectorData &variant, idx_t row, uint32_t values_idx, SINK &sink) {","+\tauto type_id = variant.GetTypeId(row, values_idx);","+\t// write the type rank - this guarantees values are ordered by type first","+\tsink.Write(GetVariantTypeRank(type_id));","+","+\tauto blob_ptr = const_data_ptr_cast(variant.GetData(row).GetData());","+\tauto value_ptr = blob_ptr + variant.GetByteOffset(row, values_idx);","+\tswitch (type_id) {","+\tcase VariantLogicalType::VARIANT_NULL:","+\t\t// no payload - the rank fully describes the value","+\t\tbreak;","+\tcase VariantLogicalType::BOOL_TRUE:","+\t\tsink.Write(1);","+\t\tbreak;","+\tcase VariantLogicalType::BOOL_FALSE:","+\t\tsink.Write(0);","+\t\tbreak;","+\t// all integers, decimals and bignums fold into the NUMBER rank and compare by numeric value","+\tcase VariantLogicalType::INT8:","+\tcase VariantLogicalType::INT16:","+\tcase VariantLogicalType::INT32:","+\tcase VariantLogicalType::INT64:","+\tcase VariantLogicalType::INT128:","+\tcase VariantLogicalType::UINT8:","+\tcase VariantLogicalType::UINT16:","+\tcase VariantLogicalType::UINT32:","+\tcase VariantLogicalType::UINT64:","+\tcase VariantLogicalType::UINT128:","+\tcase VariantLogicalType::DECIMAL:","+\tcase VariantLogicalType::BIGNUM:","+\t\tVariantEncodeNumber(sink, VariantGetNumberKey(type_id, variant, row, values_idx, value_ptr));","+\t\tbreak;","+\tcase VariantLogicalType::FLOAT:","+\t\t// fold FLOAT into the REAL rank by widening to double (lossless)","+\t\tVariantEncodeFixed<double>(sink, static_cast<double>(Load<float>(value_ptr)));","+\t\tbreak;","+\tcase VariantLogicalType::DOUBLE:","+\t\tVariantEncodeFixed<double>(sink, Load<double>(value_ptr));","+\t\tbreak;","+\tcase VariantLogicalType::UUID:","+\t\tVariantEncodeFixed<hugeint_t>(sink, Load<hugeint_t>(value_ptr));","+\t\tbreak;","+\t// DATE and all (non-tz) TIMESTAMP precisions fold into the TIMESTAMP rank and compare as the number","+\t// of nanoseconds since the epoch (DATE compares as midnight of that day, TIMESTAMP WITH TIME ZONE","+\t// as its UTC instant). int128 is used so that the conversion to nanoseconds is lossless across the","+\t// full range of each type. The type rank already separates the tz / non-tz groups.","+\tcase VariantLogicalType::DATE:","+\t\tVariantEncodeFixed<hugeint_t>(sink, hugeint_t(Load<int32_t>(value_ptr)) * hugeint_t(NANOS_PER_DAY));","+\t\tbreak;","+\tcase VariantLogicalType::TIMESTAMP_SEC:","+\t\tVariantEncodeFixed<hugeint_t>(sink, hugeint_t(Load<int64_t>(value_ptr)) * hugeint_t(NANOS_PER_SEC));","+\t\tbreak;","+\tcase VariantLogicalType::TIMESTAMP_MILIS:","+\t\tVariantEncodeFixed<hugeint_t>(sink, hugeint_t(Load<int64_t>(value_ptr)) * hugeint_t(NANOS_PER_MILLI));","+\t\tbreak;","+\tcase VariantLogicalType::TIMESTAMP_MICROS:","+\tcase VariantLogicalType::TIMESTAMP_MICROS_TZ:","+\t\tVariantEncodeFixed<hugeint_t>(sink, hugeint_t(Load<int64_t>(value_ptr)) * hugeint_t(NANOS_PER_MICRO));","+\t\tbreak;","+\tcase VariantLogicalType::TIMESTAMP_NANOS:","+\tcase VariantLogicalType::TIMESTAMP_NANOS_TZ:","+\t\tVariantEncodeFixed<hugeint_t>(sink, hugeint_t(Load<int64_t>(value_ptr)));","+\t\tbreak;","+\t// TIME precisions fold into the TIME rank and compare as nanoseconds since midnight (fits in int64)","+\tcase VariantLogicalType::TIME_MICROS:","+\t\tVariantEncodeFixed<int64_t>(sink, Load<int64_t>(value_ptr) * NANOS_PER_MICRO);","+\t\tbreak;","+\tcase VariantLogicalType::TIME_NANOS:","+\t\tVariantEncodeFixed<int64_t>(sink, Load<int64_t>(value_ptr));","+\t\tbreak;","+\tcase VariantLogicalType::TIME_MICROS_TZ:","+\t\t// TIME WITH TIME ZONE requires a dedicated byte-comparable transform","+\t\tVariantEncodeFixed<uint64_t>(sink, Load<dtime_tz_t>(value_ptr).sort_key());","+\t\tbreak;","+\tcase VariantLogicalType::INTERVAL:","+\t\t// normalize the interval so that equal intervals encode identically","+\t\tVariantEncodeFixed<interval_t>(sink, Load<interval_t>(value_ptr).Normalize());","+\t\tbreak;","+\tcase VariantLogicalType::VARCHAR:","+\t\tVariantEncodeString(sink, VariantUtils::DecodeStringData(variant, row, values_idx), true);","+\t\tbreak;","+\tcase VariantLogicalType::BLOB:","+\tcase VariantLogicalType::GEOMETRY:","+\t\tVariantEncodeString(sink, VariantUtils::DecodeStringData(variant, row, values_idx), false);","+\t\tbreak;","+\tcase VariantLogicalType::BITSTRING: {","+\t\t// BIT is ordered by its logical bit sequence, not by its raw bytes - expand each bit to a sort","+\t\t// key byte (matching the bitstring_byte_comparable collation), terminated so a shorter bitstring","+\t\t// (a prefix) sorts before a longer one","+\t\tauto bitstring = VariantUtils::DecodeStringData(variant, row, values_idx);","+\t\tauto bit_length = Bit::BitLength(bitstring);","+\t\tfor (idx_t bit_idx = 0; bit_idx < bit_length; bit_idx++) {","+\t\t\tsink.Write(Bit::GetBit(bitstring, bit_idx) ? BIT_SORT_KEY_ONE : BIT_SORT_KEY_ZERO);","+\t\t}","+\t\tsink.Write(STRING_DELIMITER);","+\t\tbreak;","+\t}","+\tcase VariantLogicalType::ARRAY: {","+\t\tauto nested_data = VariantUtils::DecodeNestedData(variant, row, values_idx);","+\t\tfor (idx_t i = 0; i < nested_data.child_count; i++) {","+\t\t\tauto child_values_idx = variant.GetValuesIndex(row, nested_data.children_idx + i);","+\t\t\tEncodeVariantValue(variant, row, child_values_idx, sink);","+\t\t}","+\t\tsink.Write(LIST_DELIMITER);","+\t\tbreak;","+\t}","+\tcase VariantLogicalType::OBJECT: {","+\t\tauto nested_data = VariantUtils::DecodeNestedData(variant, row, values_idx);","+\t\t// gather (key, value) pairs and process them in string-sorted key order so that objects","+\t\t// that only differ in key order compare equal","+\t\tvector<std::pair<string_t, uint32_t>> entries;","+\t\tentries.reserve(nested_data.child_count);","+\t\tfor (idx_t i = 0; i < nested_data.child_count; i++) {","+\t\t\tauto key_idx = variant.GetKeysIndex(row, nested_data.children_idx + i);","+\t\t\tauto child_values_idx = variant.GetValuesIndex(row, nested_data.children_idx + i);","+\t\t\tentries.emplace_back(variant.GetKey(row, key_idx), child_values_idx);","+\t\t}","+\t\tstd::sort(entries.begin(), entries.end(),","+\t\t          [](const std::pair<string_t, uint32_t> &a, const std::pair<string_t, uint32_t> &b) {","+\t\t\t          return a.first < b.first;","+\t\t          });","+\t\tfor (auto &entry : entries) {","+\t\t\tVariantEncodeString(sink, entry.first, true);","+\t\t\tEncodeVariantValue(variant, row, entry.second, sink);","+\t\t}","+\t\tsink.Write(LIST_DELIMITER);","+\t\tbreak;","+\t}","+\tdefault:","+\t\tthrow NotImplementedException(\"Variant type %s is not supported in variant_comparator\",","+\t\t                              EnumUtil::ToString(type_id));","+\t}","+}","+","+//! Encodes the *logical* value of a VARIANT into a byte-comparable sort key. VARIANT is physically a","+//! STRUCT, but the generic create_sort_key encodes that physical representation (which is reversible,","+//! so it can be used by aggregates to store/decode values). For comparison / ordering we instead","+//! encode the *logical* value of the variant - this encoding is intentionally not reversible (e.g.","+//! all integer widths fold together). NULLs are propagated into the result validity.","+void CreateVariantComparator(const Vector &input, idx_t count, OrderModifiers modifiers, Vector &result) {","+\tRecursiveUnifiedVectorFormat variant_format;","+\tVector::RecursiveToUnifiedFormat(input, variant_format);","+\tUnifiedVariantVectorData variant(variant_format);","+","+\tdata_t null_byte = NULL_FIRST_BYTE;","+\tdata_t valid_byte = NULL_LAST_BYTE;","+\tif (modifiers.null_type == OrderByNullType::NULLS_LAST) {","+\t\tstd::swap(null_byte, valid_byte);","+\t}","+\tconst bool flip_bytes = modifiers.order_type == OrderType::DESCENDING;","+","+\tresult.SetVectorType(VectorType::FLAT_VECTOR);","+\tauto result_data = FlatVector::GetDataMutable<string_t>(result);","+\tauto &result_validity = FlatVector::ValidityMutable(result);","+","+\tfor (idx_t r = 0; r < count; r++) {","+\t\tconst bool valid = variant.RowIsValid(r);","+\t\t// phase 1 - compute the encoded length","+\t\tidx_t length = 1; // validity byte","+\t\tif (valid) {","+\t\t\tVariantComparatorLengthSink length_sink;","+\t\t\tEncodeVariantValue(variant, r, 0, length_sink);","+\t\t\tlength += length_sink.length;","+\t\t}","+\t\t// phase 2 - allocate and construct","+\t\tresult_data[r] = StringVector::EmptyString(result, length);","+\t\tauto ptr = data_ptr_cast(result_data[r].GetDataWriteable());","+\t\tif (!valid) {","+\t\t\tptr[0] = null_byte;","+\t\t\tresult_data[r].Finalize();","+\t\t\t// propagate NULL so that NULL = NULL stays NULL and ORDER BY ... NULLS FIRST/LAST is honored","+\t\t\tresult_validity.SetInvalid(r);","+\t\t\tcontinue;","+\t\t}","+\t\tptr[0] = valid_byte;","+\t\tVariantComparatorWriteSink write_sink(ptr, 1, flip_bytes);","+\t\tEncodeVariantValue(variant, r, 0, write_sink);","+\t\tresult_data[r].Finalize();","+\t}","+}","+","+// variant_comparator produces a binary, byte-comparable sort key for a VARIANT value.","+// It is used as a collation for VARIANT so that comparison / ordering / grouping all operate on the","+// logical ordering of variant values (see EncodeVariantValue above).","+// Unlike the create_sort_key scalar (which uses SPECIAL_HANDLING and encodes NULLs into the key), this","+// function propagates NULL - this is required so that NULL = NULL stays NULL and ORDER BY ... NULLS","+// FIRST/LAST is handled by the surrounding operator instead of being baked into the key.","+void VariantComparatorFunction(DataChunk &input, ExpressionState &state, Vector &result) {","+\tD_ASSERT(input.ColumnCount() == 1);","+\tOrderModifiers modifiers(OrderType::ASCENDING, OrderByNullType::NULLS_LAST);","+\tCreateVariantComparator(input.data[0], input.size(), modifiers, result);","+}","+","+} // namespace","+","+ScalarFunction VariantComparatorFun::GetFunction() {","+\tauto variant_type = LogicalType::VARIANT();","+\treturn ScalarFunction(\"variant_comparator\", {variant_type}, LogicalType::BLOB, VariantComparatorFunction);","+}","+","+} // namespace duckdb"],"additions":573,"deletions":0,"truncated":false},{"path":"src/include/duckdb/common/enum_util.hpp","lines":["@@ -166,6 +166,8 @@ enum class DatePartSpecifier : uint8_t;"," "," enum class DebugInitialize : uint8_t;"," ","+enum class DebugOrderVerification : uint8_t;","+"," enum class DebugStatementVerification : uint8_t;"," "," enum class DebugVectorVerification : uin