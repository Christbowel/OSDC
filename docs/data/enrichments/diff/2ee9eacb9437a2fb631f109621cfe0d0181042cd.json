0,0 +1,85 @@","+// Copyright (c) Tailscale Inc & contributors","+// SPDX-License-Identifier: BSD-3-Clause","+","+package routecheck","+","+import (","+\t\"net/http\"","+\t\"strconv\"","+\t\"time\"","+","+\tjsonv2 \"github.com/go-json-experiment/json\"","+\tjsonv1 \"github.com/go-json-experiment/json/v1\"","+","+\t\"tailscale.com/ipn/localapi\"","+\t\"tailscale.com/net/routecheck\"","+\t\"tailscale.com/util/httpm\"","+)","+","+func init() {","+\tlocalapi.Register(\"routecheck\", serveRouteCheck)","+}","+","+// ServeRouteCheck handles the API endpoint that serves the routecheck Report.","+// If the probe form field is true, then this handler will refresh the Report","+// before serving it.","+// If the timeout form field is a valid duration, the probe will consider a node","+// to be unreachable if it doesn’t respond before the timeout expires.","+func serveRouteCheck(h *localapi.Handler, w http.ResponseWriter, r *http.Request) {","+\trc := ClientFor(h.LocalBackend())","+\tif rc == nil {","+\t\thttp.Error(w, \"routecheck is not enabled\", http.StatusServiceUnavailable)","+\t\treturn","+\t}","+","+\tif r.Method != httpm.POST {","+\t\thttp.Error(w, \"want POST\", http.StatusMethodNotAllowed)","+\t\treturn","+\t}","+","+\tvar err error","+\tvar report *routecheck.Report","+\tif defBool(r.FormValue(\"probe\"), false) {","+\t\ttimeout := defDuration(r.FormValue(\"timeout\"), routecheck.DefaultTimeout)","+\t\ttimeout = min(max(0, timeout), 60*time.Second) // clamp to [0s, 60s]","+\t\treport, err = rc.Refresh(r.Context(), timeout)","+\t} else {","+\t\treport = rc.Report()","+\t}","+\tif err != nil {","+\t\tlocalapi.WriteErrorJSON(w, err)","+\t\treturn","+\t}","+","+\tw.Header().Set(\"Content-Type\", \"application/json\")","+\tif report == nil {","+\t\tw.WriteHeader(http.StatusNoContent)","+\t\treturn","+\t}","+","+\t// TODO(sfllaw): Since ipn/localapi is still using encoding/json","+\t// with its default options, marshal with DefaultOptionsV1.","+\tjsonv2.MarshalWrite(w, report, jsonv1.DefaultOptionsV1())","+}","+","+func defBool(a string, def bool) bool {","+\tif a == \"\" {","+\t\treturn def","+\t}","+\tv, err := strconv.ParseBool(a)","+\tif err != nil {","+\t\treturn def","+\t}","+\treturn v","+}","+","+func defDuration(a string, def time.Duration) time.Duration {","+\tif a == \"\" {","+\t\treturn def","+\t}","+\tv, err := time.ParseDuration(a)","+\tif err != nil {","+\t\treturn def","+\t}","+\treturn v","+}"],"additions":85,"deletions":0,"truncated":false},{"path":"net/routecheck/probe.go","lines":["@@ -50,6 +50,12 @@ func (c *Client) probe(ctx context.Context, nodes iter.Seq[probed], limit int, t"," \tvar mu syncs.Mutex"," \tr := &Report{}"," ","+\ttimestampProbe := func(n probed) {","+\t\tmu.Lock()","+\t\tdefer mu.Unlock()","+\t\tmak.Set(&r.LastProbed, n.ID(), time.Now())","+\t}","+"," \tmarkReachable := func(n probed) {"," \t\tmu.Lock()"," \t\tdefer mu.Unlock()","@@ -81,12 +87,22 @@ func (c *Client) probe(ctx context.Context, nodes iter.Seq[probed], limit int, t"," \t\t// TODO(sfllaw): Add a mechanism to mark a node as unreachable"," \t\t// because it fails of establish a new WireGuard connection."," \t\tif n.IsWireGuardOnly() {","+\t\t\ttimestampProbe(n)"," \t\t\tmarkReachable(n)"," \t\t\tcontinue"," \t\t}"," "," \t\tg.Go(func() error {"," \t\t\tmetricPing.Add(1)","+","+\t\t\t// We record the timestamp of each node’s latest probe","+\t\t\t// so we can probe in incremental batches","+\t\t\t// and to limit the rate that any given node is pinged.","+\t\t\t//","+\t\t\t// TODO(sfllaw): We currently record the timestamp","+\t\t\t// but haven’t implemented batching or rate-limiting yet.","+\t\t\tdefer timestampProbe(n)","+"," \t\t\t// TODO(sfllaw): Why did we choose Disco ping instead of TSMP ping?"," \t\t\t// After all, a TSMP ping proves that the peer Tailscale node is there"," \t\t\t// and that both nodes know each other’s WireGuard keys,"],"additions":16,"deletions":0,"truncated":false},{"path":"net/routecheck/report.go","lines":["@@ -4,10 +4,16 @@"," package routecheck"," "," import (","+\t\"cmp\""," \t\"context\"","+\t\"maps\""," \t\"net/netip\"","+\t\"slices\""," \t\"time\""," ","+\tjsonv2 \"github.com/go-json-experiment/json\"","+\t\"github.com/go-json-experiment/json/jsontext\"","+"," \t\"tailscale.com/tailcfg\""," \t\"tailscale.com/util/clientmetric\""," )","@@ -26,9 +32,9 @@ func (c *Client) Report() *Report {"," \t}"," "," \t// TODO(sfllaw): Return the latest snapshot produced by background probing.","-\tr, err := c.ProbeAllHARouters(context.TODO(), 5, DefaultTimeout)","+\tr, err := c.Refresh(context.TODO(), DefaultTimeout)"," \tif err != nil {","-\t\tc.logf(\"reachability report error: %v\", err)","+\t\tc.logf(\"%v\", err)"," \t}"," \treturn r"," }","@@ -36,26 +42,61 @@ func (c *Client) Report() *Report {"," // Report contains the result of a single routecheck."," type Report struct {"," \t// Done is the time when the report was finished.","-\tDone time.Time","+\tDone time.Time `json:\"done\"`"," "," \t// Reachable is the set of nodes that were reachable from the current host"," \t// when this report was compiled. Missing nodes may or may not be reachable.","-\tReachable map[tailcfg.NodeID]Node","+\tReachable NodeSet `json:\"reachable\"`","+","+\t// LastProbed tracks the last time a given node was probed.","+\t// This is used to rate-limit reachability probing, so an entry’s","+\t// presence doesn’t imply that it is reachable.","+\tLastProbed map[tailcfg.NodeID]time.Time `json:\"-\"` // not marshaled"," }"," "," // Node represents a node in the reachability report."," type Node struct {","-\tID tailcfg.NodeID","+\tID tailcfg.NodeID `json:\"id\"`"," "," \t// Name is the FQDN of the node."," \t// It is also the MagicDNS name for the node."," \t// It has a trailing dot."," \t// e.g. \"host.tail-scale.ts.net.\"","-\tName string","+\tName string `json:\"name\"`"," "," \t// Addr is the IP address that was probed.","-\tAddr netip.Addr","+\tAddr netip.Addr `json:\"addr\"`"," "," \t// Routes are the subnets that the node will route.","-\tRoutes []netip.Prefix","+\tRoutes []netip.Prefix `json:\"routes\"`","+}","+","+// NodeSet is a set of nodes keyed by node ID, so duplicates are easily detected.","+// To prevent stuttering, it marshals itself as a JSON array, sorted by node ID.","+type NodeSet map[tailcfg.NodeID]Node","+","+var _ jsonv2.MarshalerTo = &NodeSet{}","+var _ jsonv2.UnmarshalerFrom = &NodeSet{}","+","+// MarshalJSONTo implements [jsonv2.MarshalerTo].","+func (ns NodeSet) MarshalJSONTo(enc *jsontext.Encoder) error {","+\tnodes := slices.SortedFunc(maps.Values(ns), func(a, b Node) int {","+\t\treturn cmp.Compare(a.ID, b.ID)","+\t})","+\treturn jsonv2.MarshalEncode(enc, nodes)","+}","+","+// UnmarshalJSONFrom implements [jsonv2.UnmarshalerFrom].","+func (ns *NodeSet) UnmarshalJSONFrom(dec *jsontext.Decoder) error {","+\tvar nodes []Node","+\tif err := jsonv2.UnmarshalDecode(dec, &nodes); err != nil {","+\t\treturn err","+\t}","+\tif *ns == nil {","+\t\t*ns = make(NodeSet, len(nodes))","+\t}","+\tfor _, n := range nodes {","+\t\t(*ns)[n.ID] = n","+\t}","+\treturn nil"," }"],"additions":49,"deletions":8,"truncated":false},{"path":"net/routecheck/routecheck.go","lines":["@@ -7,13 +7,20 @@ package routecheck"," import ("," \t\"context\""," \t\"errors\"","+\t\"fmt\""," \t\"net/netip\""," \t\"sync/atomic\"","+\t\"time\""," "," \t\"tailscale.com/ipn/ipnstate\""," \t\"tailscale.com/tailcfg\""," \t\"tailscale.com/types/logger\""," \t\"tailscale.com/types/netmap\"","+\t\"tailscale.com/util/clientmetric\"","+)","+","+var (","+\tmetricRefresh = clientmetric.NewCounter(\"routecheck_refresh\")"," )"," "," // Client generates Reports describing the result of both passive and active","@@ -150,6 +157,17 @@ func (c *Client) waitForNetMap(ctx context.Context) (*netmap.NetworkMap, error)"," \t}"," }"," ","+// Refresh generates a new reachability report and returns it.","+// A peer is considered unreachable if it doesn’t respond within the timeout.","+func (c *Clie