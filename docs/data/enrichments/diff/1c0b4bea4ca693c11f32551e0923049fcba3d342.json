tion getCopilotTgrepExcludeFilter(platform: string, arch: string): st","  * Returns a glob filter that strips @github/copilot platform packages","  * for architectures other than the build target.","  *","- * For platforms the copilot SDK doesn't natively support (e.g. alpine, armhf),","- * ALL platform packages are stripped - that's fine because the copilot CLI SDK","- * resolves `node-pty` from the embedder (VS Code) first via `hostRequire`,","- * falling back to its bundled copy only if the embedder can't provide it.","+ * Alpine uses the linuxmusl-* packages. Other platform package names follow","+ * Node's `${process.platform}-${process.arch}` naming. If Copilot does not","+ * ship the computed platform package (for example linux-arm for armhf builds),","+ * this strips every known @github/copilot-* platform package.","  */"," export function getCopilotExcludeFilter(platform: string, arch: string): string[] {","-\tconst { nodePlatform, nodeArch } = toNodePlatformArch(platform, arch);","-\tconst targetPlatformArch = `${nodePlatform}-${nodeArch}`;","+\tconst targetPlatformArch = toCopilotPackagePlatformArch(platform, arch);"," \tconst nonTargetPlatforms = copilotPlatforms.filter(p => p !== targetPlatformArch);"," "," \t// Strip wrong-architecture @github/copilot-{platform} packages.","@@ -119,55 +155,121 @@ export function getCopilotExcludeFilter(platform: string, arch: string): string["," }"," "," /**","- * Returns the public @github/copilot-sdk runtime native addon files that must","- * survive app/remote packaging for the target platform.","+ * Returns the public @github/copilot package files that must survive","+ * app/remote packaging for the target platform.","  *","- * .moduleignore strips @github/copilot/prebuilds/** globally because the","- * internal extension SDK uses a copied sdk/prebuilds layout. Agent Host uses","- * the public SDK, whose runtime addon loader expects runtime.node in the root","- * prebuilds layout. The SDK's built-in shell tool additionally spawns commands","- * through node-pty, whose native binaries live in the same root prebuilds","- * layout, so those must be preserved too (otherwise the sandboxed shell fails","- * with `Cannot find module './prebuilds/<platform>/pty.node'` — or conpty.node","- * on Windows).","+ * .moduleignore strips all @github/copilot-* platform packages globally.","+ * Re-add the selected runtime package so Agent Host can launch its index.js","+ * entrypoint and load runtime prebuilds. Keep the standalone SEA executable","+ * and optional native payload trees out of the product build.","  */"," export function getCopilotRuntimePrebuildFiles(platform: string, arch: string, nodeModulesRoot = 'node_modules'): string[] {","-\tconst { nodePlatform, nodeArch } = toNodePlatformArch(platform, arch);","-\tconst targetPlatformArch = `${nodePlatform}-${nodeArch}`;","-\tconst prebuildDir = path.posix.join(nodeModulesRoot, '@github', 'copilot', 'prebuilds', targetPlatformArch);","+\tconst copilotPackagePlatformArch = toCopilotPackagePlatformArch(platform, arch);","+\tconst copilotPlatformPackageDir = path.posix.join(nodeModulesRoot, '@github', `copilot-${copilotPackagePlatformArch}`);"," ","-\tconst files = [","-\t\tpath.posix.join(prebuildDir, 'runtime.node'),","+\treturn [","+\t\tpath.posix.join(copilotPlatformPackageDir, '**'),","+\t\t`!${path.posix.join(copilotPlatformPackageDir, 'copilot')}`,","+\t\t`!${path.posix.join(copilotPlatformPackageDir, 'copilot.exe')}`,","+\t\t...copilotOptionalNativePayloadDirs.map(dir => `!${path.posix.join(copilotPlatformPackageDir, dir, '**')}`),","+\t\t...getCopilotOptionalNativePayloadFiles(platform).map(file => `!${path.posix.join(copilotPlatformPackageDir, file)}`),"," \t];","+}"," ","-\t// node-pty native binaries for the SDK's built-in shell tool. Windows uses","-\t// ConPTY (conpty.node plus the conpty/ helpers); darwin/linux use pty.node,","-\t// and darwin additionally ships the spawn-helper executable.","-\tif (nodePlatform === 'win32') {","-\t\tfiles.push(","-\t\t\tpath.posix.join(prebuildDir, 'conpty.node'),","-\t\t\tpath.posix.join(prebuildDir, 'conpty_console_list.node'),","-\t\t\tpath.posix.join(prebuildDir, 'conpty', 'OpenConsole.exe'),","-\t\t\tpath.posix.join(prebuildDir, 'conpty', 'conpty.dll'),","-\t\t);","-\t} else {","-\t\tfiles.push(path.posix.join(prebuildDir, 'pty.node'));","-\t\tif (nodePlatform === 'darwin') {","-\t\t\tfiles.push(path.posix.join(prebuildDir, 'spawn-helper'));","-\t\t}","+interface NpmPackageLock {","+\tpackages?: Record<string, {","+\t\tversion?: string;","+\t\tintegrity?: string;","+\t}>;","+}","+","+interface EnsureCopilotPlatformPackageOptions {","+\tpackPackage?: (packageName: string, version: string, tempDir: string) => string;","+}","+","+/**","+ * Ensures the selected @github/copilot-{platform} package is present before","+ * packaging. npm only installs the host-compatible optional dependency, but","+ * VS Code packaging can cross-build targets such as darwin-x64 on arm64 hosts.","+ */","+export function ensureCopilotPlatformPackage(platform: string, arch: string, nodeModulesRoot = 'node_modules', options: EnsureCopilotPlatformPackageOptions = {}): void {","+\tconst copilotPackagePlatformArch = toCopilotPackagePlatformArch(platform, arch);","+\tif (!copilotPlatforms.includes(copilotPackagePlatformArch)) {","+\t\treturn;"," \t}"," ","-\treturn files;","+\tconst packageName = `@github/copilot-${copilotPackagePlatformArch}`;","+\tconst packageDir = path.join(nodeModulesRoot, '@github', `copilot-${copilotPackagePlatformArch}`);","+\tif (fs.existsSync(packageDir)) {","+\t\treturn;","+\t}","+","+\tconst lockFilePath = path.join(path.dirname(nodeModulesRoot), 'package-lock.json');","+\tconst lockPackageKey = path.posix.join('node_modules', '@github', `copilot-${copilotPackagePlatformArch}`);","+\tconst lockPackage = readNpmPackageLock(lockFilePath).packages?.[lockPackageKey];","+\tif (!lockPackage?.version) {","+\t\tthrow new Error(`[ensureCopilotPlatformPackage] Missing ${lockPackageKey} in ${lockFilePath}. Run npm install to refresh the lockfile.`);","+\t}","+","+\tconst tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'vscode-copilot-platform-'));","+\ttry {","+\t\tconst tarballPath = (options.packPackage ?? packCopilotPlatformPackage)(packageName, lockPackage.version, tempDir);","+\t\tverifyNpmIntegrity(tarballPath, lockPackage.integrity);","+","+\t\tfs.mkdirSync(packageDir, { recursive: true });","+\t\textract({ file: tarballPath, cwd: packageDir, strip: 1, sync: true });","+\t\tconsole.log(`[ensureCopilotPlatformPackage] Materialized ${packageName}@${lockPackage.version} in ${packageDir}`);","+\t} catch (err) {","+\t\tfs.rmSync(packageDir, { recursive: true, force: true });","+\t\tthrow new Error(`[ensureCopilotPlatformPackage] Failed to materialize ${packageName}@${lockPackage.version}: ${err instanceof Error ? err.message : String(err)}`);","+\t} finally {","+\t\tfs.rmSync(tempDir, { recursive: true, force: true });","+\t}","+}","+","+function packCopilotPlatformPackage(packageName: string, version: string, tempDir: string): string {","+\texecFileSync(process.platform === 'win32' ? 'npm.cmd' : 'npm', ['pack', `${packageName}@${version}`, '--pack-destination', tempDir, '--silent'], { stdio: 'pipe', shell: process.platform === 'win32' });","+","+\tconst tarball = fs.readdirSync(tempDir).find(name => name.endsWith('.tgz'));","+\tif (!tarball) {","+\t\tthrow new Error(`npm pack did not produce a tarball in ${tempDir}`);","+\t}","+","+\treturn path.join(tempDir, tarball);","+}","+","+function readNpmPackageLock(lockFilePath: string): NpmPackageLock {","+\ttry {","+\t\treturn JSON.parse(fs.readFileSync(lockFilePath, 'utf8'));","+\t} catch (err) {","+\t\tthrow new Error(`[ensureCopilotPlatformPackage] Failed to read ${lockFilePath}: ${err instanceof Error ? err.message : String(err)}`);","+\t}","+}","+","+function verifyNpmIntegrity(tarballPath: string, integrity: string | undefined): void {","+\tif (!integrity) {","+\t\treturn;","+\t}","+","+\tconst sha512Integrity = integrity.split(/\\s+/).find(entry => entry.startsWith('sha512-'));","+\tif (!sha512Integrity) {","+\t\treturn;","+\t}","+","+\tconst expected = sha512Integrity.slice('sha512-'.length);","+\tconst actual = createHash('sha512').update(fs.readFileSync(tarballPath)).digest('base64');","+\tif (actual !== expected) {","+\t\tthrow new Error(`integrity mismatch for ${tarballPath}`);","+\t}"," }"," "," /**","- * Materializes the copilot CLI ripgrep shim directly inside the built-in copilot extension.","+ * Materializes target-platform Copilot CLI SDK files directly inside the built-in copilot extension.","  *","  * This is used when copilot is shipped as a built-in extension so startup does","- * not need to create the shim at runtime. The destination layout matches the","- * runtime shim logic in the copilot extension:","- * - ripgrep:  node_modules/@github/copilot/sdk/ripgrep/bin/{platform-arch}","- * - marker:   node_modules/@github/copilot/shims.txt","+ * not need to create the shim at runtime. The Copilot VSIX is built once on the","+ * Linux x64 host, so product packaging also restores target-platform SDK","+ * natives from the selected @github/copilot-{platform} package.","  *","  * Note: `node-pty` is no longer shimmed. The copilot CLI SDK resolves","  * `node-pty` from the embedder (VS Code) via `hostRequire` and falls back to","@@ -179,6 +281,7 @@ export function getCopilotRuntimePrebuildFiles(platform: string, arch: string, n"," export function prepareBuiltInCopilotRipgrepShim(platform: string, arch: string, builtInCopilotExtensionDir: string, appNodeModulesDir: string): void {"," \tconst { nodePlatform, nodeArch } = toNodePlatformArch(platform, arch);"," \tconst platformArch = `${nodePlatform}-${nodeArch}`;","+\tconst copilotPackagePlatformArch = toCopilotPackagePlatformArch(platform, arch);"," \tconst tgrepPlatformArch = toCopilotTgrepPlatformArch(platform, arch);"," "," \tconst extensionNodeModules = path.join(builtInCopilotExtensionDir, 'node_modules');","@@ -187,7 +290,8 @@ export function prepareBuiltInCopilotRipgrepShim(platform: string, arch: string,"," \tif (!fs.existsSync(copilotSdkBase)) {"," \t\tthrow new Error(`[prepareBuiltInCopilotRipgrepShim] Copilot SDK directory not found at ${copilotSdkBase}`);"," \t}","-\tpruneNonTargetCopilotSdkPrebuilds(platformArch, path.join(copilotSdkBase, 'prebuilds'), copilotPlatforms);","+\tmaterializeBuiltInCopilotSdkPlatformFiles(copilotPackagePlatformArch, tgrepPlatformArch, copilotBase, appNodeModulesDir);","+\tpruneNonTargetCopilotSdkPrebuilds(copilotPackagePlatformArch, path.join(copilotSdkBase, 'prebuilds'), copilotPlatforms);"," \tpruneNonTargetCopilotSdkPrebuilds(tgrepPlatformArch, path.join(copilotSdkBase, path.join('tgrep', 'bin')), copilotTgrepPlatforms);"," \tpruneNonTargetCopilotSdkPrebuilds(tgrepPlatformArch, path.join(copilotBase, path.join('tgrep', 'bin')), copilotTgrepPlatforms);"," ","@@ -219,6 +323,49 @@ export function prepareBuiltInCopilotRipgrepShim(platform: string, arch: string,"," \t}"," }"," ","+function materializeBuiltInCopilotSdkPlatformFiles(copilotPackagePlatformArch: string, tgrepPlatformArch: string, copilotBase: string, appNodeModulesDir: string): void {","+\tif (!copilotPlatforms.includes(copilotPackagePlatformArch)) {","+\t\treturn;","+\t}","+","+\tconst platformPackageDir = path.join(appNodeModulesDir, '@github', `copilot-${copilotPackagePlatformArch}`);","+\tif (!fs.existsSync(platformPackageDir)) {","+\t\tthrow new Error(`[prepareBuiltInCopilotRipgrepShim] Copilot platform package not found at ${platformPackageDir}`);","+\t}","+","+\tcopyRequiredDirectory(","+\t\tpath.join(platformPackageDir, 'prebuilds', copilotPackagePlatformArch),","+\t\tpath.join(copilotBase, 'sdk', 'prebuilds', copilotPackagePlatformArch),","+\t\t`Copilot SDK native prebuilds for ${copilotPackagePlatformArch}`","+\t);","+","+\tif (!copilotTgrepPlatforms.includes(tgrepPlatformArch)) {","+\t\treturn;","+\t}","+","+\tconst tg