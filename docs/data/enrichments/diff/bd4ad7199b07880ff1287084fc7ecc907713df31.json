->getOpObserver()->onDelete(","-            opCtx, *autoColl, kUninitializedStmtId, doc, getDocumentKey(*autoColl, doc), args);","-    }","-","-    // The armed UUID must survive the rollback (the redo reads it on the retry), but the","-    // per-attempt flag must be cleared so the retry re-persists the sentinel.","-    ASSERT_TRUE(redoState.armedCollectionUUID().has_value());","-    EXPECT_EQ(*redoState.armedCollectionUUID(), collectionUUID);","-    EXPECT_FALSE(redoState.flagPersisted());","-}","-"," // Verifies that a WriteUnitOfWork with groupOplogEntries=kGroupForTransaction consisting of an"," // insert, an update and a delete replicates as a single applyOps."," TEST_F(BatchedWriteOutputsTest, TestApplyOpsInsertDeleteUpdate) {",""],"additions":0,"deletions":61,"truncated":false}],"additions":0,"deletions":343,"truncated":false,"file_count":16},"error":null,"fetched_at":"2026-07-18T09:25:07.369752+00:00"}