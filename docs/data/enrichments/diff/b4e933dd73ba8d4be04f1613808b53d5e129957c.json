{"id":"b4e933dd73ba8d4be04f1613808b53d5e129957c","axis":"silent","repo":"hashicorp/terraform","sha":"b4e933dd73ba8d4be04f1613808b53d5e129957c","parsed":{"files":[{"path":"internal/command/plan_race_test.go","lines":["@@ -0,0 +1,118 @@","+// Copyright IBM Corp. 2014, 2026","+// SPDX-License-Identifier: BUSL-1.1","+","+package command","+","+import (","+\t\"context\"","+\t\"path/filepath\"","+\t\"regexp\"","+\t\"sync\"","+\t\"testing\"","+","+\t\"github.com/hashicorp/terraform/internal/configs/configload\"","+\t\"github.com/hashicorp/terraform/internal/initwd\"","+\t\"github.com/hashicorp/terraform/internal/registry\"","+\t\"github.com/spf13/afero\"","+)","+","+// moduleDir matches a descendant module's directory in the \"plan-modules-race\" fixture (e.g. \".../mod0\")","+var moduleDir = regexp.MustCompile(`(^|/)mod\\d+$`)","+","+type mockFS struct {","+\tafero.Fs","+\tloadingStarted chan struct{}","+\tproceed        chan struct{}","+\tonce           sync.Once","+}","+","+func (g *mockFS) Open(name string) (afero.File, error) {","+\tif moduleDir.MatchString(filepath.ToSlash(name)) {","+\t\t// Indicate the loading of modules has started, so we can trigger the shutdown channel","+\t\tg.once.Do(func() { close(g.loadingStarted) })","+\t\t<-g.proceed","+\t}","+\treturn g.Fs.Open(name)","+}","+","+// TestPlan_configLoaderRace is a regression test for a data race in the","+// configuration loader's shared parser: https://github.com/hashicorp/terraform/issues/38725","+//","+// A plan loads descendant modules by walking the init graph, which parses each","+// module into the loader's shared *configs.Parser (the write side). When the","+// run is interrupted via the shutdown channel, (*Meta).RunOperation stops waiting for the","+// operation and the command renders the resulting diagnostics, which reads the","+// same parser's source cache via Loader.Sources (the read side).","+func TestPlan_configLoaderRace(t *testing.T) {","+\ttd := t.TempDir()","+\ttestCopyDir(t, testFixturePath(\"plan-modules-race\"), td)","+\tt.Chdir(td)","+","+\tmodulesDir := t.TempDir()","+","+\t// Install the local modules with a fresh loader so the module manifest","+\t// exists on disk before the plan runs.","+\tinstallLoader, err := configload.NewLoader(&configload.Config{","+\t\tModulesDir: modulesDir,","+\t})","+\tif err != nil {","+\t\tt.Fatalf(\"failed to create install loader: %s\", err)","+\t}","+\tinst := initwd.NewModuleInstaller(modulesDir, installLoader, registry.NewClient(nil, nil), nil)","+\tif _, instDiags := inst.InstallModules(context.Background(), \".\", \"tests\", true, false); instDiags.HasErrors() {","+\t\tt.Fatalf(\"failed to install modules: %s\", instDiags.Err())","+\t}","+","+\tmockFS := &mockFS{","+\t\tFs:             afero.NewOsFs(),","+\t\tloadingStarted: make(chan struct{}),","+\t\tproceed:        make(chan struct{}),","+\t}","+\ttestLoader, err := configload.NewLoader(&configload.Config{","+\t\tModulesDir: modulesDir,","+\t\tOverrideFS: mockFS,","+\t})","+\tif err != nil {","+\t\tt.Fatalf(\"failed to create test loader: %s\", err)","+\t}","+\tif err := testLoader.RefreshModules(); err != nil {","+\t\tt.Fatalf(\"failed to refresh modules: %s\", err)","+\t}","+","+\tview, done := testView(t)","+\tdefer done(t)","+\t// Wire the diagnostics renderer to read this loader's sources,","+\t// mirroring what Meta.initConfigLoader does for a non-injected loader.","+\tview.SetConfigSources(testLoader.Sources)","+","+\tshutdownCh := make(chan struct{})","+\tc := &PlanCommand{","+\t\tMeta: Meta{","+\t\t\ttestingOverrides: metaOverridesForProvider(planFixtureProvider()),","+\t\t\tView:             view,","+\t\t\tconfigLoader:     testLoader,","+\t\t\tShutdownCh:       shutdownCh,","+\t\t},","+\t}","+","+\tgo func() {","+\t\t// Wait until the modules begin loading","+\t\t<-mockFS.loadingStarted","+","+\t\t// Cancel the operation, which after 5 seconds will trigger the read side of","+\t\t// the race condition (via the diagnostic renderer).","+\t\tclose(shutdownCh)","+","+\t\t// Allow one module load to proceed, which will trigger the write side of","+\t\t// the race condition (via the module being stored in the shared parser).","+\t\t//","+\t\t// The next module load will block until the shutdown has completed/timed","+\t\t// out (which is where the race condition would occur).","+\t\tmockFS.proceed <- struct{}{}","+\t}()","+","+\tc.Run([]string{})","+","+\t// Now that the run command has timed out, allow the remaining modules to proceed","+\tclose(mockFS.proceed)","+}"],"additions":118,"deletions":0,"truncated":false},{"path":"internal/command/testdata/plan-modules-race/main.tf","lines":["@@ -0,0 +1,7 @@","+module \"mod0\" {","+  source = \"./mod0\"","+}","+","+module \"mod1\" {","+  source = \"./mod1\"","+}"],"additions":7,"deletions":0,"truncated":false},{"path":"internal/command/testdata/plan-modules-race/mod0/main.tf","lines":["@@ -0,0 +1,3 @@","+resource \"test_instance\" \"this\" {","+  ami = \"mod0\"","+}"],"additions":3,"deletions":0,"truncated":false},{"path":"internal/command/testdata/plan-modules-race/mod1/main.tf","lines":["@@ -0,0 +1,3 @@","+resource \"test_instance\" \"this\" {","+  ami = \"mod1\"","+}"],"additions":3,"deletions":0,"truncated":false},{"path":"internal/configs/configload/loader.go","lines":["@@ -53,6 +53,10 @@ type Config struct {"," \t// IncludeStateMigrateFiles is set to true if state migration files should"," \t// be parsed when running state migrate commands."," \tIncludeStateMigrateFiles bool","+","+\t// OverrideFS is used to override the filesystem that the loader","+\t// reads configuration and module files from.","+\tOverrideFS afero.Fs"," }"," "," // NewLoader creates and returns a loader that reads configuration from the","@@ -63,6 +67,11 @@ type Config struct {"," // manifest cannot be read then an error will be returned."," func NewLoader(config *Config) (*Loader, error) {"," \tfs := afero.NewOsFs()","+","+\tif config.OverrideFS != nil {","+\t\tfs = config.OverrideFS"