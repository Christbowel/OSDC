{"id":"01c7cc4855bc75d33190ff7b14668a2d26015f43","axis":"silent","repo":"dotnet/aspnetcore","sha":"01c7cc4855bc75d33190ff7b14668a2d26015f43","parsed":{"files":[{"path":".azure/pipelines/fuzzing/deploy-to-onefuzz.yml","lines":["@@ -0,0 +1,111 @@","+# Builds the ASP.NET Core fuzzing targets and deploys them to OneFuzz.","+# See src/Fuzzing/README.md for details on the fuzzing infrastructure.","+","+# No CI trigger — runs on schedule only (or manual dispatch).","+trigger: none","+pr: none","+","+schedules:","+- cron: \"0 11 * * *\" # 11 AM UTC daily","+  displayName: OneFuzz deployment nightly run","+  branches:","+    include:","+    - main","+  always: true","+","+variables:","+  - template: /eng/common/templates-official/variables/pool-providers.yml@self","+  - name: fuzzerProject","+    value: $(Build.SourcesDirectory)/src/Fuzzing/AspNetCoreFuzzing","+  - name: _TeamName","+    value: AspNetCore","+","+resources:","+  repositories:","+  # Repo: 1ESPipelineTemplates/1ESPipelineTemplates","+  - repository: 1esPipelines","+    type: git","+    name: 1ESPipelineTemplates/1ESPipelineTemplates","+    ref: refs/tags/release","+","+extends:","+  template: v1/1ES.Unofficial.PipelineTemplate.yml@1esPipelines","+  parameters:","+    sdl:","+      sourceAnalysisPool:","+        name: NetCore1ESPool-Svc-Internal","+        image: 1es-windows-2022","+        os: windows","+      codeql:","+        compiled:","+          enabled: false","+          justificationForDisabling: 'This is a fuzzing-only pipeline. The same product code is already scanned in the main pipeline (aspnetcore-ci)'","+    featureFlags:","+      autoEnablePREfastWithNewRuleset: false","+","+    stages:","+    - stage: Build","+      jobs:","+      - job: DeployToOneFuzz","+        displayName: Build & Deploy to OneFuzz","+        timeoutInMinutes: 120","+        pool:","+          name: $(DncEngInternalBuildPool)","+          demands: ImageOverride -equals windows.vs2026.amd64","+","+        steps:","+        - checkout: self","+          clean: true","+          fetchDepth: 1","+          fetchTags: false","+","+        # The SharpFuzz CLI currently targets .NET 9.0 and won't run under","+        # the repo-local .NET SDK. Install a system-wide .NET 9.0 SDK.","+        - powershell: |","+            winget install -e --id Microsoft.DotNet.SDK.9 --accept-package-agreements --accept-source-agreements","+          displayName: Install .NET 9.0 (for SharpFuzz CLI)","+","+        # Restore and build the fuzzing project using the repo-local SDK.","+        - powershell: |","+            . $(Build.SourcesDirectory)/activate.ps1","+            cd $(fuzzerProject)","+            dotnet build-server shutdown","+            dotnet build -c Release","+          displayName: Build Fuzzing targets","+","+        # Install SharpFuzz.CommandLine as a local tool for instrumenting assemblies.","+        - powershell: |","+            cd $(fuzzerProject)","+            dotnet tool install --tool-path . SharpFuzz.CommandLine","+          displayName: Install SharpFuzz.CommandLine","+","+        # Run the prepare-onefuzz command to create per-fuzzer deployment directories","+        # with instrumented assemblies, libfuzzer-dotnet.exe, and OneFuzzConfig.json.","+        - powershell: |","+            cd $(fuzzerProject)","+            ./run.bat","+          displayName: Prepare OneFuzz deployment","+","+        # OneFuzz can't currently handle a single deployment where multiple jobs","+        # share similar assemblies/pdbs. As a workaround, we emit a task for every","+        # fuzzing target individually.","+        # https://fuzzfest.visualstudio.com/Onefuzz/_workitems/edit/191504/","+        #","+        # When the above issue is fixed, replace these individual tasks with:","+        #   - task: onefuzz-task@0","+        #     inputs:","+        #       onefuzzOSes: 'Windows'","+        #     env:","+        #       onefuzzDropDirectory: $(fuzzerProject)/deployment","+        #       SYSTEM_ACCESSTOKEN: $(System.AccessToken)","+        #     displayName: Send all fuzzers to OneFuzz","+","+# ONEFUZZ_TASK_WORKAROUND_START","+        - task: onefuzz-task@0","+          inputs:","+            onefuzzOSes: 'Windows'","+          env:","+            onefuzzDropDirectory: $(fuzzerProject)/deployment/MultipartReaderFuzzer","+            SYSTEM_ACCESSTOKEN: $(System.AccessToken)","+          displayName: Send MultipartReaderFuzzer to OneFuzz","+# ONEFUZZ_TASK_WORKAROUND_END"],"additions":111,"deletions":0,"truncated":false},{"path":"Directory.Build.props","lines":["@@ -28,6 +28,7 @@","         $(RepoRelativeProjectDir.Contains('perf')) OR","         $(RepoRelativeProjectDir.Contains('benchmarkapps')) \">true</IsBenchmarkProject>","     <IsMicrobenchmarksProject Condition=\" $(MSBuildProjectName.EndsWith('.Microbenchmarks')) \">true</IsMicrobenchmarksProject>","+    <IsFuzzingProject Condition=\" $(RepoRelativeProjectDir.Contains('Fuzzing')) AND $(MSBuildProjectName.EndsWith('Fuzzing')) \">true</IsFuzzingProject>","     <IsSpecificationTestProject Condition=\"$(MSBuildProjectName.EndsWith('.Specification.Tests'))\">true</IsSpecificationTestProject>","     <IsUnitTestProject Condition=\" '$(IsUnitTestProject)' == '' AND","         '$(IsSpecificationTestProject)' != 'true' AND","@@ -47,6 +48,7 @@","     <IsShipping Condition=\" '$(IsSampleProject)' == 'true' OR","         '$(IsTestAssetProject)' == 'true' OR","         '$(IsBenchmarkProject)' == 'true' OR","+        '$(IsFuzzingProject)' == 'true' OR","         '$(IsPublishedAppTestProject)' == 'true' OR","         $(IsUnitTestProject) \">false</IsShipping>","   </PropertyGroup>"],"additions":2,"deletions":0,"truncated":false},{"path":"THIRD-PARTY-NOTICES.txt","lines":["@@ -1108,3 +1108,35 @@ AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER"," LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,"," OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DE