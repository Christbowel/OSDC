rface {","-\tGetMulti(ctx context.Context, keys []string, opts ...cache.Option) map[string][]byte","-\tSetAsync(key string, value []byte, ttl time.Duration)","+\tGetMulti(ctx context.Context, keys []string, opts ...cache.Option) (map[string][]byte, error)","+\tSetAsync(ctx context.Context, key string, value []byte, ttl time.Duration) error"," }"," "," // HashCacheKey returns a hashed version of key that is small enough to fit within the Memcached key limit"],"additions":2,"deletions":2,"truncated":false},{"path":"pkg/streamingpromql/caching/in_memory.go","lines":["@@ -0,0 +1,63 @@","+// SPDX-License-Identifier: AGPL-3.0-only","+","+package caching","+","+import (","+\t\"context\"","+\t\"slices\"","+\t\"time\"","+","+\t\"github.com/grafana/dskit/cache\"","+)","+","+type InMemoryCache struct {","+\tEntries map[string]InMemoryCacheEntry","+","+\tGetCount int","+\tHitCount int","+\tSetCount int","+}","+","+// NewInMemoryCache creates a new in-memory cache.","+// This is intended for testing purposes only.","+func NewInMemoryCache() *InMemoryCache {","+\treturn &InMemoryCache{","+\t\tEntries: make(map[string]InMemoryCacheEntry),","+\t}","+}","+","+type InMemoryCacheEntry struct {","+\tValue []byte","+\tTTL   time.Duration","+}","+","+func (c *InMemoryCache) GetMulti(ctx context.Context, keys []string, opts ...cache.Option) (map[string][]byte, error) {","+\tc.GetCount++","+\tresults := make(map[string][]byte, len(keys))","+","+\tfor _, key := range keys {","+\t\tentry, ok := c.Entries[key]","+","+\t\tif ok && len(entry.Value) > 0 {","+\t\t\t// Clone bytes to simulate network serialization","+\t\t\tresults[key] = slices.Clone(entry.Value)","+\t\t\tc.HitCount++","+\t\t}","+\t}","+","+\treturn results, nil","+}","+","+func (c *InMemoryCache) SetAsync(ctx context.Context, key string, value []byte, ttl time.Duration) error {","+\tc.SetCount++","+\tc.Entries[key] = InMemoryCacheEntry{Value: value, TTL: ttl}","+","+\treturn nil","+}","+","+func (c *InMemoryCache) Reset() {","+\tc.Entries = make(map[string]InMemoryCacheEntry)","+\tc.SetCount = 0","+\tc.GetCount = 0","+\tc.HitCount = 0","+}"],"additions":63,"deletions":0,"truncated":false},{"path":"pkg/streamingpromql/caching/prefix.go","lines":["@@ -0,0 +1,66 @@","+// SPDX-License-Identifier: AGPL-3.0-only","+","+package caching","+","+import (","+\t\"context\"","+\t\"fmt\"","+\t\"time\"","+","+\t\"github.com/grafana/dskit/cache\"","+\t\"github.com/grafana/dskit/tenant\"","+)","+","+type PrefixGenerator func(ctx context.Context) (string, error)","+","+type PrefixingCache struct {","+\tinner           Backend","+\tprefixGenerator PrefixGenerator","+}","+","+func NewPrefixingCache(inner Backend, prefixGenerator func(ctx context.Context) (string, error)) *PrefixingCache {","+\treturn &PrefixingCache{inner: inner, prefixGenerator: prefixGenerator}","+}","+","+func (p *PrefixingCache) SetAsync(ctx context.Context, key string, value []byte, ttl time.Duration) error {","+\tprefix, err := p.prefixGenerator(ctx)","+\tif err != nil {","+\t\treturn err","+\t}","+","+\treturn p.inner.SetAsync(ctx, prefix+key, value, ttl)","+}","+","+func (p *PrefixingCache) GetMulti(ctx context.Context, keys []string, opts ...cache.Option) (map[string][]byte, error) {","+\tprefix, err := p.prefixGenerator(ctx)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+","+\tprefixedKeys := make([]string, len(keys))","+","+\tfor i, key := range keys {","+\t\tprefixedKeys[i] = prefix + key","+\t}","+","+\tprefixedResults, err := p.inner.GetMulti(ctx, prefixedKeys, opts...)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+","+\tresults := make(map[string][]byte, len(prefixedResults))","+\tfor key, value := range prefixedResults {","+\t\tresults[key[len(prefix):]] = value","+\t}","+","+\treturn results, nil","+}","+","+func TenantPrefixGenerator(ctx context.Context) (string, error) {","+\ttenantIDs, err := tenant.TenantIDs(ctx)","+\tif err != nil {","+\t\treturn \"\", err","+\t}","+","+\treturn fmt.Sprintf(\"%s:\", tenant.