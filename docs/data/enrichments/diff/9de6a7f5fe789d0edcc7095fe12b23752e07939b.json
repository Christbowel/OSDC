"-","-\t\tif ( rest_is_field_included( 'status', $fields ) ) {","-\t\t\t$data['status'] = $post->post_status;","-\t\t}","-","-\t\tif ( rest_is_field_included( 'guideline_categories', $fields ) ) {","-\t\t\t$guideline_categories = Gutenberg_Knowledge_Post_Type::get_guideline_categories_from_meta( $post->ID );","-","-\t\t\t// Handle ?block filter.","-\t\t\t$block_filter = $request->get_param( 'block' );","-\t\t\tif ( $block_filter && ! empty( $guideline_categories ) ) {","-\t\t\t\tif ( isset( $guideline_categories['blocks'][ $block_filter ] ) ) {","-\t\t\t\t\t$guideline_categories = array(","-\t\t\t\t\t\t'blocks' => array(","-\t\t\t\t\t\t\t$block_filter => $guideline_categories['blocks'][ $block_filter ],","-\t\t\t\t\t\t),","-\t\t\t\t\t);","-\t\t\t\t} else {","-\t\t\t\t\t$guideline_categories = new stdClass();","-\t\t\t\t}","-\t\t\t} elseif ( $request->get_param( 'category' ) ) {","-\t\t\t\t// Handle ?category filter.","-\t\t\t\t$category_filter = $request->get_param( 'category' );","-\t\t\t\tif ( isset( $guideline_categories[ $category_filter ] ) ) {","-\t\t\t\t\t$guideline_categories = array(","-\t\t\t\t\t\t$category_filter => $guideline_categories[ $category_filter ],","-\t\t\t\t\t);","-\t\t\t\t} else {","-\t\t\t\t\t$guideline_categories = new stdClass();","-\t\t\t\t}","-\t\t\t}","-","-\t\t\tif ( empty( $guideline_categories ) ) {","-\t\t\t\t$guideline_categories = new stdClass();","-\t\t\t}","-","-\t\t\t$data['guideline_categories'] = $guideline_categories;","-\t\t}","-","-\t\tif ( rest_is_field_included( 'date', $fields ) ) {","-\t\t\t$data['date'] = $this->prepare_date_response( $post->post_date_gmt, $post->post_date );","-\t\t}","-","-\t\tif ( rest_is_field_included( 'date_gmt', $fields ) ) {","-\t\t\t$data['date_gmt'] = $this->prepare_date_response( $post->post_date_gmt );","-\t\t}","-","-\t\tif ( rest_is_field_included( 'modified', $fields ) ) {","-\t\t\t$data['modified'] = $this->prepare_date_response( $post->post_modified_gmt, $post->post_modified );","-\t\t}","-","-\t\tif ( rest_is_field_included( 'modified_gmt', $fields ) ) {","-\t\t\t$data['modified_gmt'] = $this->prepare_date_response( $post->post_modified_gmt );","-\t\t}","-","-\t\tif ( rest_is_field_included( 'author', $fields ) ) {","-\t\t\t$data['author'] = (int) $post->post_author;","-\t\t}","-","-\t\t$context = ! empty( $request['context'] ) ? $request['context'] : 'view';","-\t\t$data    = $this->add_additional_fields_to_object( $data, $request );","-\t\t$data    = $this->filter_response_by_context( $data, $context );","-","-\t\t$response = rest_ensure_response( $data );","-","-\t\tif ( rest_is_field_included( '_links', $fields ) || rest_is_field_included( '_embedded', $fields ) ) {","-\t\t\t$response->add_links( $this->prepare_links( $post->ID ) );","-\t\t}","-","-\t\treturn $response;","-\t}","-","-\t/**","-\t * Prepares links for the request.","-\t *","-\t * Includes self, about, and version-history links.","-\t *","-\t * @param int $id Post ID.","-\t * @return array Links for the given post.","-\t */","-\tprotected function prepare_links( $id ) {","-\t\t$base = sprintf( '%s/%s', $this->namespace, $this->rest_base );","-","-\t\t$links = array(","-\t\t\t'self'  => array(","-\t\t\t\t'href' => rest_url( trailingslashit( $base ) . $id ),","-\t\t\t),","-\t\t\t'about' => array(","-\t\t\t\t'href' => rest_url( 'wp/v2/types/' . $this->post_type ),","-\t\t\t),","-\t\t);","-","-\t\tif ( post_type_supports( $this->post_type, 'revisions' ) ) {","-\t\t\t$revisions       = wp_get_latest_revision_id_and_total_count( $id );","-\t\t\t$revisions_count = ! is_wp_error( $revisions ) ? $revisions['count'] : 0;","-\t\t\t$revisions_base  = sprintf( '/%s/%d/revisions', $base, $id );","-","-\t\t\t$links['version-history'] = array(","-\t\t\t\t'href'  => rest_url( $revisions_base ),","-\t\t\t\t'count' => $revisions_count,","-\t\t\t);","-\t\t}","-","-\t\treturn $links;","-\t}","-","-\t/**","-\t * Saves guideline categories to post meta.","-\t *","-\t * @param int   $post_id    Post 