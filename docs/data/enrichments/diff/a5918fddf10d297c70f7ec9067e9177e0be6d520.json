{"id":"a5918fddf10d297c70f7ec9067e9177e0be6d520","axis":"silent","repo":"postgres/postgres","sha":"a5918fddf10d297c70f7ec9067e9177e0be6d520","parsed":{"files":[{"path":"doc/src/sgml/ddl.sgml","lines":["@@ -3759,6 +3759,26 @@ REVOKE CREATE ON SCHEMA public FROM PUBLIC;","    </para>","   </sect2>"," ","+  <sect2 id=\"ddl-schemas-conflict\">","+   <title>The Conflict Schema</title>","+","+   <indexterm zone=\"ddl-schemas-conflict\">","+    <primary>conflict</primary>","+    <secondary>schema</secondary>","+   </indexterm>","+","+   <para>","+    The <literal>pg_conflict</literal> schema (sometimes referred to as the","+    <emphasis>conflict schema</emphasis>) contains system-managed conflict","+    log tables used for logical replication conflict tracking.","+    These tables are created and maintained by the system and are not intended for","+    direct user manipulation. Unlike <literal>pg_catalog</literal>, the","+    <literal>pg_conflict</literal> schema is not implicitly included in the","+    search path, so objects within it must be referenced explicitly or by","+    adjusting the search path.","+   </para>","+  </sect2>","+","   <sect2 id=\"ddl-schemas-patterns\">","    <title>Usage Patterns</title>"," "],"additions":20,"deletions":0,"truncated":false},{"path":"doc/src/sgml/glossary.sgml","lines":["@@ -506,6 +506,18 @@","    </glossdef>","   </glossentry>"," ","+  <glossentry id=\"glossary-conflict-schema\">","+   <glossterm>Conflict schema</glossterm>","+   <glossdef>","+    <para>","+     The <literal>pg_conflict</literal> schema that contains system-managed","+     conflict log tables for logical replication. These tables are created","+     and maintained automatically by the system and are not intended for","+     direct user manipulation. See <xref linkend=\"ddl-schemas-conflict\"/>.","+    </para>","+   </glossdef>","+  </glossentry>","+","   <glossentry id=\"glossary-connection\">","    <glossterm>Connection</glossterm>","    <glossdef>"],"additions":12,"deletions":0,"truncated":false},{"path":"doc/src/sgml/logical-replication.sgml","lines":["@@ -293,6 +293,21 @@","    option of <command>CREATE SUBSCRIPTION</command> for details.","   </para>"," ","+  <para>","+   <link linkend=\"logical-replication-conflicts\">Conflicts</link> that occur","+   during replication are, by default, logged as plain text in the server log,","+   which can make automated monitoring and analysis difficult. The","+   <command>CREATE SUBSCRIPTION</command> command provides the","+   <link linkend=\"sql-createsubscription-params-with-conflict-log-destination\">","+   <literal>conflict_log_destination</literal></link> option to record detailed","+   conflict information in a structured, queryable format. When this parameter","+   is set to <literal>table</literal> or <literal>all</literal>, the system","+   automatically manages a dedicated <firstterm>conflict log table</firstterm>,","+   which is created and dropped along with the subscription. This significantly","+   improves post-mortem analysis and operational visibility of the replication","+   setup.","+  </para>","+","   <sect2 id=\"logical-replication-subscription-slot\">","    <title>Logical Replication Slot Management</title>"," "],"additions":15,"deletions":0,"truncated":false},{"path":"doc/src/sgml/ref/alter_subscription.sgml","lines":["@@ -293,8 +293,9 @@ ALTER SUBSCRIPTION <replaceable class=\"parameter\">name</replaceable> RENAME TO <","       <link linkend=\"sql-createsubscription-params-with-failover\"><literal>failover</literal></link>,","       <link linkend=\"sql-createsubscription-params-with-two-phase\"><literal>two_phase</literal></link>,","       <link linkend=\"sql-createsubscription-params-with-retain-dead-tuples\"><literal>retain_dead_tuples</literal></link>,","-      <link linkend=\"sql-createsubscription-params-with-max-retention-duration\"><literal>max_retention_duration</literal></link>, and","-      <link linkend=\"sql-createsubscription-params-with-wal-receiver-timeout\"><literal>wal_receiver_timeout</literal></link>.","+      <link linkend=\"sql-createsubscription-params-with-max-retention-duration\"><literal>max_retention_duration</literal></link>,","+      <link linkend=\"sql-createsubscription-params-with-wal-receiver-timeout\"><literal>wal_receiver_timeout</literal></link>, and","+      <link linkend=\"sql-createsubscription-params-with-conflict-log-destination\"><literal>conflict_log_destination</literal></link>.","       Only a superuser can set <literal>password_required = false</literal>.","      </para>"," ","@@ -352,6 +353,13 @@ ALTER SUBSCRIPTION <replaceable class=\"parameter\">name</replaceable> RENAME TO <","       <quote><literal>pg_conflict_detection</literal></quote>, created to retain","       dead tuples for conflict detection, will be dropped.","      </para>","+","+     <para>","+      When the <link linkend=\"sql-createsubscription-params-with-conflict-log-destination\"><literal>conflict_log_destination</literal></link>","+      parameter is set to <literal>table</literal> or <literal>all</literal>, the system","+      automatically creates the conflict log table. Conversely, if the destination is changed to","+      <literal>log</literal>, the conflict log table is automatically dropped.","+     </para>","     </listitem>","    </varlistentry>"," "],"additions":10,"deletions":2,"truncated":false},{"path":"doc/src/sgml/ref/create_subscription.sgml","lines":["@@ -261,6 +261,55 @@ CREATE SUBSCRIPTION <replaceable class=\"parameter\">subscription_name</replaceabl","         </listitem>","        </varlistentry>"," ","+       <varlistentry id=\"sql-createsubscription-params-with-conflict-log-destination\">","+        <term><literal>conflict_log_destination</literal> (<type>enum</type>)</term>","+        <listitem>","+         <para>","+          Specifies the destination for recording logical replication conflicts.","+          The available values are:","+          <variablelist>","+           <varlistentry>","+            <term><literal>log</literal></term>","+            <listitem>","+             <para>","+              Conflict details are recorded in the server log.","+              This is the default behavior.","+             </para>","+            </listitem>","+           </varlistentry>","+           <varlistentry>","+            <term><literal>table</literal></term>","+            <listitem>","+             <para>","+              The system automatically creates a structured table named","+              <literal>pg_conflict_log_&lt;subid&gt;</literal> in the","+              <literal>pg_conflict</literal> schema. This allows for easy","+              querying and analysis of conflicts.","+             </para>","+             <caution>","+              <para>","+               The conflict log table is strictly tied to the lifecycle of the","+               subscription or the <literal>conflict_log_destination</literal> setting. If","+               the subscription is dropped, or if the destination is changed to","+               <literal>log</literal>, the table is <emphasis>dropped</emphasis>.","+              </para>","+             </caution>","+            </listitem>","+           </varlistentry>","+           <varlistentry>","+            <term><literal>all</literal></term>","+            <listitem>","+             <para>","+              This is equivalent to configuring both destinations <literal>log</literal>","+              and <literal>table</literal> together.","+             </para>","+            </listitem>","+           </varlistentry>","+          </variablelist>","+         </para>","+        </listitem>","+       </varlistentry>","+","        <varlistentry id=\"sql-createsubscription-params-with-copy-data\">","         <term><literal>copy_data</literal> (<type>boolean</type>)</term>","         <listitem>"],"additions":49,"deletions":0,"truncated":false},{"path":"doc/src/sgml/ref/drop_subscription.sgml","lines":["@@ -114,6 +114,14 @@ DROP SUBSCRIPTION [ IF EXISTS ] <replaceable class=\"parameter\">name</replaceable","    If a subscription is associated with a replication slot, then <command>DROP","    SUBSCRIPTION</command> cannot be executed inside a transaction block.","   </para>","+","+  <para>","+   If a conflict log table exists for the subscription (that is, when","+   <link linkend=\"sql-createsubscription-params-with-conflict-log-destination\">","+   <literal>conflict_log_destination</literal></link> is set to <literal>table</literal>","+   or <literal>all</literal>), <command>DROP SUBSCRIPTION</command> automatically drops","+   the associated conflict log table.","+  </para>","  </refsect1>"," ","  <refsect1>"],"additions":8,"deletions":0,"truncated":false},{"path":"src/backend/catalog/aclchk.c","lines":["@@ -3337,25 +3337,39 @@ pg_class_aclmask_ext(Oid table_oid, Oid roleid, AclMode mask,"," "," \tclassForm = (Form_pg_class) GETSTRUCT(tuple);"," ","-\t/*","-\t * Deny anyone permission to update a system catalog unless","-\t * pg_authid.rolsuper is set.","-\t *","-\t * As of 7.4 we have some updatable system views; those shouldn't be","-\t * protected in this way.  Assume the view rules can take care of","-\t * themselves.  ACL_USAGE is if we ever have system sequences.","-\t */","-\tif ((mask & (ACL_INSERT | ACL_UPDATE | ACL_DELETE | ACL_TRUNCATE | ACL_USAGE)) &&","-\t\tIsSystemClass(table_oid, classForm) &&","-\t\tclassForm->relkind != RELKIND_VIEW &&","-\t\t!superuser_arg(roleid))","-\t\tmask &= ~(ACL_INSERT | ACL_UPDATE | ACL_DELETE | ACL_TRUNCATE | ACL_USAGE);","-","-\t/*","-\t * Otherwise, superusers bypass all permission-checking.","-\t */","-\tif (superuser_arg(roleid))","+\tif (!superuser_arg(roleid))"," \t{","+\t\tif (mask & (ACL_INSERT | ACL_UPDATE | ACL_DELETE | ACL_TRUNCATE | ACL_USAGE))","+\t\t{","+\t\t\tif (IsConflictLogTableClass(classForm))","+\t\t\t{","+\t\t\t\t/*","+\t\t\t\t * For conflict log tables, allow non-superusers to perform","+\t\t\t\t * DELETE and TRUNCATE for cleanup and maintenance, while","+\t\t\t\t * still restricting INSERT, UPDATE, and USAGE.","+\t\t\t\t */","+\t\t\t\tmask &= ~(ACL_INSERT | ACL_UPDATE | ACL_USAGE);","+\t\t\t}","+\t\t\telse if (IsSystemClass(table_oid, classForm) &&","+\t\t\t\t\t classForm->relkind != RELKIND_VIEW)","+\t\t\t{","+\t\t\t\t/*","+\t\t\t\t * Deny anyone permission to update a system catalog unless","+\t\t\t\t * pg_authid.rolsuper is set.","+\t\t\t\t *","+\t\t\t\t * As of 7.4 we have some updatable system views; those","+\t\t\t\t * shouldn't be protected in this way.  Assume the view rules","+\t\t\t\t * can take care of themselves.  ACL_USAGE is if we ever have","+\t\t\t\t * system sequences.","+\t\t\t\t */","+\t\t\t\tmask &= ~(ACL_INSERT | ACL_UPDATE | ACL_DELETE | ACL_TRUNCATE |","+\t\t\t\t\t\t  ACL_USAGE);","+\t\t\t}","+\t\t}","+\t}","+\telse","+\t{","+\t\t/* Superusers bypass all permission-checking. */"," \t\tReleaseSysCache(tuple);"," \t\treturn mask;"," \t}","@@ -3660,6 +3674,14 @@ pg_namespace_aclmask_ext(Oid nsp_oid, Oid roleid,"," \tAcl\t\t   *acl;"," \tOid\t\t\townerId;"," ","+\t/*","+\t * Disallow creation in the conflict schema for everyone, including","+\t * superusers, unless in binary-upgrade mode.","+\t */","+\tif (!IsBinaryUpgrade && (mask & ACL_CREATE) &&","+\t\tIsConflictLogTableNamespace(nsp_oid))","+\t\tmask &= ~ACL_CREATE;","+"," \t/* Superusers bypass all permission checking. */"," \tif (superuser_arg(roleid))"," \t\treturn mask;"],"additions":40,"deletions":18,"truncated":false},{"path":"src/backend/catalog/catalog.c","lines":["@@ -86,7 +86,9 @@ bool"," IsSystemClass(Oid relid, Form_pg_class reltuple)"," {"," \t/* IsCatalogRelationOid is a bit faster, so test that first */","-\treturn (IsCatalogRelationOid(relid) || IsToastClass(reltuple));","+\treturn (IsCatalogRelationOid(relid) ||","+\t\t\tIsToastClass(reltuple) ||","+\t\t\tIsConflictLogTableClass(reltuple));"," }"," "," /*","@@ -230,6 +232,20 @@ IsToastClass(Form_pg_class reltuple)"," \treturn IsToastNamespace(relnamespace);"," }"," ","+/*","+ * IsConflictLogTableClass","+ *\t\tTrue iff pg_class tuple represents a Conflict Log Table.","+ *","+ *\t\tDoes not perform any catalog accesses.","+ */","+bool","+IsConflictLogTableClass(Form_pg_class reltuple)","+{","+\tOid\t\t\trelnamespace = reltuple->relnamespace;","+","+\treturn IsConflictLogTableNamespace(relnamespace);","+}","+"," /*","  * IsCatalogNamespace","  *\t\tTrue iff namespace is pg_catalog.","@@ -264,6 +280,17 @@ IsToastNamespace(Oid namespaceId)"," \t\tisTempToastNamespace(namespaceId);"," }"," ","+/*","+ * IsConflictLogTableNamespace","+ *\t\tTrue iff namespace is pg_conflict.","+ *","+ *\t\tDoes not perform any catalog accesses.","+ */","+bool","+IsConflictLogTableNamespace(Oid namespaceId)","+{","+\treturn namespaceId == PG_CONFLICT_NAMESPACE;","+}"," "," /*","  * IsReservedName"],"additions":28,"deletions":1,"truncated":false},{"path":"src/backend/catalog/pg_publication.c","lines":["@@ -92,6 +92,13 @@ check_publication_add_relation(PublicationRelInfo *pri)"," \t\t\t\t errmsg(errormsg, relname),"," \t\t\t\t errdetail(\"This operation is not supported for system tables.\")));"," ","+\t/* Can't be conflict log table */","+\tif (IsConflictLogTableNamespace(RelationGetNamespace(targetrel)))","+\t\tereport(ERROR,","+\t\t\t\t(errcode(ERRCODE_INVALID_PARAMETER_VALUE),","+\t\t\t\t errmsg(errormsg, relname),","+\t\t\t\t errdetail(\"This operation is not supported for conflict log tables.\")));","+"," \t/* UNLOGGED and TEMP relations cannot be part of publication. */"," \tif (targetrel->rd_rel->relpersistence == RELPERSISTENCE_TEMP)"," \t\tereport(ERROR,","@@ -113,7 +120,8 @@ static void"," check_publication_add_schema(Oid schemaid)"," {"," \t/* Can't be system namespace */","-\tif (IsCatalogNamespace(schemaid) || IsToastNamespace(schemaid))","+\tif (IsCatalogNamespace(schemaid) || IsToastNamespace(schemaid) ||","+\t\tIsConflictLogTableNamespace(schemaid))"," \t\tereport(ERROR,"," \t\t\t\t(errcode(ERRCODE_INVALID_PARAMETER_VALUE),"," \t\t\t\t errmsg(\"cannot add schema \\\"%s\\\" to publication\",","@@ -148,7 +156,8 @@ check_publication_add_schema(Oid schemaid)","  * is really inadequate for that, since the information_schema could be","  * dropped and reloaded and then it'll be considered publishable.  The best","  * long-term solution may be to add a \"relispublishable\" bool to pg_class,","- * and depend on that instead of OID checks.","+ * and depend on that instead of OID checks.  IsConflictLogTableClass()","+ * excludes tables in conflict schema.","  */"," static bool"," is_publishable_class(Oid relid, Form_pg_class reltuple)","@@ -157,6 +166,7 @@ is_publishable_class(Oid relid, Form_pg_class reltuple)"," \t\t\treltuple->relkind == RELKIND_PARTITIONED_TABLE ||"," \t\t\treltuple->relkind == RELKIND_SEQUENCE) &&"," \t\t!IsCatalogRelationOid(relid) &&","+\t\t!IsConflictLogTableClass(reltuple) &&"," \t\treltuple->relpersistence == RELPERSISTENCE_PERMANENT &&"," \t\trelid >= FirstNormalObjectId;"," }"],"additions":12,"deletions":2,"truncated":false},{"path":"src/backend/catalog/pg_subscription.c","lines":["@@ -132,6 +132,7 @@ GetSubscription(Oid subid, bool missing_ok, bool conninfo_needed,"," \tsub->retaindeadtuples = subform->subretaindeadtuples;"," \tsub->maxretention = subform->submaxretention;"," \tsub->retentionactive = subform->subretentionactive;","+\tsub->conflictlogrelid = subform->subconflictlogrelid;"," "," \tif (conninfo_needed)"," \t{","@@ -203,6 +204,12 @@ GetSubscription(Oid subid, bool missing_ok, bool conninfo_needed,"," \t\t\t\t\t\t\t\t   Anum_pg_subscription_suborigin);"," \tsub->origin = TextDatumGetCString(datum);"," ","+\t/* Get conflict log destination */","+\tdatum = SysCacheGetAttrNotNull(SUBSCRIPTIONOID,","+\t\t\t\t\t\t\t\t   tup,","+\t\t\t\t\t\t\t\t   Anum_pg_subscription_subconflictlogdest);","+\tsub->conflictlogdest = TextDatumGetCString(datum);","+"," \t/* Is the subscription owner a superuser? */"," \tsub->ownersuperuser = superuser_arg(sub->owner);"," "],"additions":7,"deletions":0,"truncated":false},{"path":"src/backend/catalog/system_views.sql","lines":["@@ -1538,8 +1538,8 @@ GRANT SELECT (oid, subdbid, subskiplsn, subname, subowner, subenabled,","               subbinary, substream, subtwophasestate, subdisableonerr,"," \t\t\t  subpasswordrequired, subrunasowner, subfailover,","               subretaindeadtuples, submaxretention, subretentionactive,","-              subserver, subslotname, subsynccommit, subwalrcvtimeout,","-              subpublications, suborigin)","+              subserver, subconflictlogrelid, subconflictlogdest, subslotname,","+              subsynccommit, subwalrcvtimeout, subpublications, suborigin)","     ON pg_subscription TO public;"," "," CREATE VIEW pg_stat_subscription_stats AS"],"additions":2,"deletions":2,"truncated":false},{"path":"src/backend/commands/lockcmds.c","lines":["@@ -83,7 +83,19 @@ RangeVarCallbackForLockTable(const RangeVar *rv, Oid relid, Oid oldrelid,"," \t\treturn;\t\t\t\t\t/* woops, concurrently dropped; no permissions"," \t\t\t\t\t\t\t\t * check */"," ","-\t/* Currently, we only allow plain tables or views to be locked */","+\t/*","+\t * Note: Conflict log tables are deliberately NOT blocked here, even","+\t * though other direct DDL on them is rejected elsewhere. pg_dump relies","+\t * on being able to take an ACCESS SHARE lock on these tables to safely","+\t * dump their definitions during a binary upgrade, so we permit LOCK","+\t * commands on them and treat them like ordinary tables here. It's true","+\t * that a strong lock (ShareLock or above) on such a table would conflict","+\t * with the RowExclusiveLock taken by the apply worker's inserts and could","+\t * stall conflict logging as well as the apply worker for as long as it is","+\t * held. But locking a system-managed conflict log table is an unusual","+\t * thing to do, and it doesn't seem worth the trouble of filtering by lock","+\t * mode here.","+\t */"," \tif (relkind != RELKIND_RELATION && relkind != RELKIND_PARTITIONED_TABLE &&"," \t\trelkind != RELKIND_VIEW)"," \t\tereport(ERROR,","@@ -198,6 +210,16 @@ LockViewRecurse_walker(Node *node, LockViewRecurse_context *context)"," \t\t\t\trelkind != RELKIND_VIEW)"," \t\t\t\tcontinue;"," ","+\t\t\t/*","+\t\t\t * Conflict log tables only support SELECT, DELETE, and TRUNCATE.","+\t\t\t * A direct LOCK on them is permitted solely so that pg_dump can","+\t\t\t * lock them during a binary upgrade; locking one indirectly by","+\t\t\t * locking a view over it is not needed for that, so skip it here","+\t\t\t * rather than locking it.","+\t\t\t */","+\t\t\tif (IsConflictLogTableNamespace(get_rel_namespace(relid)))","+\t\t\t\tcontinue;","+"," \t\t\t/*"," \t\t\t * We might be dealing with a self-referential view.  If so, we"," \t\t\t * can just stop recursing, since we already locked it."],"additions":23,"deletions":1,"truncated":false},{"path":"src/backend/commands/policy.c","lines":["@@ -79,6 +79,18 @@ RangeVarCallbackForPolicy(const RangeVar *rv, Oid relid, Oid oldrelid,"," \tif (!object_ownercheck(RelationRelationId, relid, GetUserId()))"," \t\taclcheck_error(ACLCHECK_NOT_OWNER, get_relkind_objtype(get_rel_relkind(relid)), rv->relname);"," ","+\t/*","+\t * Conflict log tables are used internally for logical replication","+\t * conflict logging and should not be modified directly, as it could","+\t * disrupt conflict logging.","+\t */","+\tif (IsConflictLogTableClass(classform))","+\t\tereport(ERROR,","+\t\t\t\t(errcode(ERRCODE_WRONG_OBJECT_TYPE),","+\t\t\t\t errmsg(\"cannot create policy on conflict log table \\\"%s\\\"\",","+\t\t\t\t\t\trv->relname),","+\t\t\t\t errdetail(\"Conflict log tables are system-managed tables for logical replication conflicts.\")));","+"," \t/* No system table modifications unless explicitly allowed. */"," \tif (!allowSystemTableMods && IsSystemClass(relid, classform))"," \t\tereport(ERROR,"],"additions":12,"deletions":0,"truncated":false},{"path":"src/backend/commands/sta