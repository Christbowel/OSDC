ar sockets = new List<Socket>();","+\t\tvar endpoints = new (IPEndPoint intTcp, IPEndPoint extTcp, IPEndPoint http)[3];","+\t\ttry {","+\t\t\tfor (int i = 0; i < 3; i++)","+\t\t\t\tendpoints[i] = AllocateEndpoints(sockets);","+\t\t} finally {","+\t\t\tforeach (var s in sockets) s.Dispose();","+\t\t}","+","+\t\tvar allPorts = endpoints.SelectMany(e => new[] { e.intTcp.Port, e.extTcp.Port, e.http.Port }).ToList();","+\t\tAssert.AreEqual(allPorts.Count, allPorts.Distinct().Count(), \"Allocated duplicate ports\");","+","+\t\tvar clusterSecret = Guid.NewGuid().ToString(\"N\");","+","+\t\tfor (int i = 0; i < 3; i++) {","+\t\t\tvar peers = new EndPoint[] {","+\t\t\t\tendpoints[(i + 1) % 3].http,","+\t\t\t\tendpoints[(i + 2) % 3].http,","+\t\t\t};","+\t\t\t_nodes[i] = new MiniClusterNode<TLogFormat, TStreamId>(","+\t\t\t\tPathName, i,","+\t\t\t\tendpoints[i].intTcp, endpoints[i].extTcp, endpoints[i].http,","+\t\t\t\tgossipSeeds: peers,","+\t\t\t\tinMemDb: false,","+\t\t\t\tdisableTls: true,","+\t\t\t\tclusterSecret: clusterSecret);","+\t\t}","+","+\t\tawait Task.WhenAll(_nodes.Select(n => n.Start()));","+\t}","+","+\t[OneTimeTearDown]","+\tpublic override async Task TestFixtureTearDown() {","+\t\tawait Task.WhenAll(_nodes.Select(n => n.Shutdown()));","+\t\tMiniNodeLogging.Clear();","+\t\tawait base.TestFixtureTearDown();","+\t}","+","+\t[Test]","+\tpublic void cluster_elects_a_leader_and_followers() {","+\t\t// With --disable-tls, nodes must still be able to authenticate to each","+\t\t// other for gossip and elections — otherwise inter-node calls are","+\t\t// rejected as unauthenticated and the cluster never converges.","+\t\tAssertEx.IsOrBecomesTrue(","+\t\t\t() => _nodes.Any(n => n.NodeState == VNodeState.Leader),","+\t\t\ttimeout: TimeSpan.FromSeconds(30),","+\t\t\tmsg: \"No leader elected. Node states: \" +","+\t\t\t\tstring.Join(\", \", _nodes.Select(n => n.NodeState)));","+","+\t\tAssertEx.IsOrBecomesTrue(","+\t\t\t() => _nodes.Any(n => n.NodeState == VNodeState.Follower),","+\t\t\ttimeout: TimeSpan.FromSeconds(30),","+\t\t\tmsg: \"No follower joined. Node states: \" +","+\t\t\t\tstring.Join(\", \", _nodes.Select(n => n.NodeState)));","+\t}","+","+\tprivate static (IPEndPoint intTcp, IPEndPoint extTcp, IPEndPoint http) AllocateEndpoints(List<Socket> sockets) {","+\t\tvar loopback = new IPEndPoint(IPAddress.Loopback, 0);","+\t\tvar intTcp = new Socket(AddressFamily.InterNetwork, SocketType.Stream, ProtocolType.Tcp);","+\t\tvar extTcp = new Socket(AddressFamily.InterNetwork, SocketType.Stream, ProtocolType.Tcp);","+\t\tvar http = new Socket(AddressFamily.InterNetwork, SocketType.Stream, ProtocolType.Tcp);","+\t\tintTcp.Bind(loopback); sockets.Add(intTcp);","+\t\textTcp.Bind(loopback); sockets.Add(extTcp);","+\t\thttp.Bind(loopback); sockets.Add(http);","+\t\treturn (","+\t\t\tnew IPEndPoint(IPAddress.Loopback, ((IPEndPoint)intTcp.LocalEndPoint!).Port),","+\t\t\tnew IPEndPoint(IPAddress.Loopback, ((IPEndPoint)extTcp.LocalEndPoint!).Port),","+\t\t\tnew IPEndPoint(IPAddress.Loopback, ((IPEndPoint)http.LocalEndPoint!).Port));","+\t}","+}"],"additions":97,"deletions":0,"truncated":false},{"path":"src/KurrentDB.Core.Tests/Integration/disable_tls_with_auth.cs","lines":["@@ -0,0 +1,131 @@","+// Copyright (c) Kurrent, Inc and/or licensed to Kurrent, Inc under one or more agreements.","+// Kurrent, Inc licenses this file to you under the Kurrent License v1 (see LICENSE.md).","+","+using System;","+using System.Net;","+using System.Net.Http;","+using System.Net.Http.Headers;","+using System.Text;","+using System.Threading.Tasks;","+using EventStore.Client;","+using EventStore.Client.Streams;","+using EventStore.ClientAPI;","+using EventStore.ClientAPI.Internal;","+using EventStore.ClientAPI.SystemData;","+using Google.Protobuf;","+using Grpc.Core;","+using Grpc.Net.Client;","+using KurrentDB.Core.Services.Transport.Grpc;","+using KurrentDB.Core.Tests.Helpers;","+using NUnit.Framework;","+using GrpcConstants = KurrentDB.Core.Services.Transp