,"+ * It is deliberately **presentational only** and has no `@wordpress/rich-text`","+ * dependency: the editable behavior (value, formatting, keyboard shortcuts)","+ * and any focus/selection tracking are owned by the consumer, which wires them","+ * through the forwarded ref and native event props (see the richtext DataForm","+ * control in `@wordpress/dataviews` for the canonical assembly).","+ *","+ * ```jsx","+ * // The rich-text \"assembly\" lives in the consumer.","+ * <ContentEditableControl","+ *     label=\"Caption\"","+ *     ref={ mergedRef }","+ *     onFocus={ onEditableFocus }","+ *     onBlur={ onEditableBlur }","+ * />","+ * ```","+ */","+export const ContentEditableControl = forwardRef(","+\tUnforwardedContentEditableControl","+);","+","+export default ContentEditableControl;"],"additions":91,"deletions":0,"truncated":false},{"path":"packages/components/src/content-editable-control/stories/index.story.tsx","lines":["@@ -0,0 +1,32 @@","+/**","+ * External dependencies","+ */","+import type { Meta, StoryObj } from '@storybook/react-vite';","+","+/**","+ * Internal dependencies","+ */","+import ContentEditableControl from '..';","+","+const meta: Meta< typeof ContentEditableControl > = {","+\tid: 'components-contenteditablecontrol',","+\ttitle: 'Components/Selection & Input/Common/ContentEditableControl',","+\tcomponent: ContentEditableControl,","+\ttags: [ 'status-private' ],","+\tparameters: {","+\t\tcontrols: { expanded: true },","+\t\tdocs: {","+\t\t\tcanvas: { sourceState: 'shown' },","+\t\t},","+\t},","+};","+export default meta;","+","+type Story = StoryObj< typeof ContentEditableControl >;","+","+export const Default: Story = {","+\targs: {","+\t\tlabel: 'Title',","+\t\tplaceholder: 'Add a title…',","+\t},","+};"],"additions":32,"deletions":0,"truncated":false},{"path":"packages/components/src/content-editable-control/style.module.scss","lines":["@@ -0,0 +1,34 @@","+@use \"@wordpress/base-styles/mixins\" as *;","+@use \"@wordpress/base-styles/variables\" as *;","+@use \"../utils/theme-variables\" as *;","+","+.editable {","+\twidth: 100%;","+\tbackground: $components-color-background;","+\tcolor: $components-color-foreground;","+\t@include input-control( $components-color-accent );","+\tborder-color: $components-color-border;","+","+\t// `::placeholder` only applies to native form fields, so draw the text","+\t// from the `aria-placeholder` attribute while the element has no content.","+\t&[aria-placeholder]:empty::before {","+\t\tcontent: attr(aria-placeholder);","+\t\tcolor: $components-color-dark-gray-placeholder;","+\t}","+","+\tmin-height: $grid-unit-50;","+","+\t// Subtract 1px to account for the border, which isn't included on the element","+\t// on newer components like InputControl, SelectControl, etc.","+\t// These values should be shared with the `controlPaddingX` in ./utils/config-values.js","+\tpadding: $grid-unit-15;","+","+\t// Match the disabled treatment of native form controls (see the","+\t// `&:disabled` rules in the textarea/input control styles).","+\t&[aria-disabled=\"true\"] {","+\t\tbackground: $components-color-gray-100;","+\t\tborder-color: $components-color-gray-300;","+\t\tcolor: $components-color-gray-700;","+\t\tcursor: default;","+\t}","+}"],"additions":34,"deletions":0,"truncated":false},{"path":"packages/components/src/content-editable-control/test/index.tsx","lines":["@@ -0,0 +1,164 @@","+/**","+ * External dependencies","+ */","+import { render, screen, fireEvent } from '@testing-library/react';","+","+/**","+ * Internal dependencies","+ */","+import ContentEditableControl from '..';","+","+// The presentational shell is deliberately decoupled from `@wordpress/rich-text`:","+// the editable behavior and any focus/selection tracking are owned by the","+// consumer, wired through the forwarded ref and native event props. These","+// tests exercise only the chrome the shell owns -- the label and the","+// `contentEditable` element -- with no rich-text wiring at all.","+describe( 'ContentEditableControl', () => {","+\tit( 'renders a labeled contenteditable textbox', () => {","+\t\trender( <ContentEditableControl label=\"Description\" /> );","+","+\t\tconst textbox = screen.getByRole( 'textbox' );","+\t\tconst label = screen.getByText( 'Description' );","+","+\t\texpect( textbox ).toHaveAttribute( 'contenteditable', 'true' );","+\t\t// `BaseControl` wires the label's `for` to the control's `id`.","+\t\texpect( label ).toHaveAttribute( 'for', textbox.id );","+\t\t// `<label for>` does not contribute an accessible name to a non-form","+\t\t// element (a `<div role=\"textbox\">`), so the label is also mirrored","+\t\t// onto `aria-label` for assistive tech and test locators.","+\t\texpect( textbox ).toHaveAttribute( 'aria-label', 'Description' );","+\t} );","+","+\tit( 'visually hides the label when `hideLabelFromVision` is set', () => {","+\t\trender( <ContentEditableControl label=\"Note\" hideLabelFromVision /> );","+","+\t\tconst label = screen.getByText( 'Note' );","+\t\texpect( label ).toHaveClass( 'components-visually-hidden' );","+\t} );","+","+\tit( 'is multiline by default and accepts an `aria-multiline` override', () => {","+\t\tconst { rerender } = render(","+\t\t\t<ContentEditableControl label=\"Single line\" />","+\t\t);","+\t\texpect( screen.getByRole( 'textbox' ) ).toHaveAttribute(","+\t\t\t'aria-multiline',","+\t\t\t'true'","+\t\t);","+","+\t\trerender(","+\t\t\t<ContentEditableControl","+\t\t\t\tlabel=\"Single line\"","+\t\t\t\taria-multiline={ false }","+\t\t\t/>","+\t\t);","+\t\texpect( screen.getByRole( 'textbox' ) ).toHaveAttribute(","+\t\t\t'aria-multiline',","+\t\t\t'false'","+\t\t);","+\t} );","+","+\tit( 'exposes `disabled` as a non-editable, aria-disabled textbox', () => {","+\t\trender( <ContentEditableControl label=\"Note\" disabled /> );","+","+\t\tconst textbox = screen.getByRole( 'textbox' );","+\t\texpect( textbox ).toHaveAttribute( 'aria-disabled', 'true' );","+\t\texpect( textbox ).toHaveAttribute( 'contenteditable', 'false' );","+\t} );","+","+\tit( 'exposes `required` via aria-required', () => {","+\t\trender( <ContentEditableControl label=\"Note\" required /> );","+","+\t\texpect( screen.getByRole( 'textbox' ) ).toBeRequired();","+\t} );","+","+\tit( 'exposes `placeholder` via aria-placeholder', () => {","+\t\trender(","+\t\t\t<ContentEditableControl label=\"Note\" placeholder=\"Add a note…\" />","+\t\t);","+","+\t\texpect( screen.getByRole( 'textbox' ) ).toHaveAttribute(","+\t\t\t'aria-placeholder',","+\t\t\t'Add a note…'","+\t\t);","+\t} );","+","+\tit( 'uses a consumer-supplied `id` for the textbox and label', () => {","+\t\trender(","+\t\t\t<ContentEditableControl","+\t\t\t\tlabel=\"Custom id\"","+\t\t\t\t// eslint-disable-next-line no-restricted-syntax","+\t\t\t\tid=\"my-custom-id\"","+\t\t\t/>","+\t\t);","+","+\t\texpect( screen.getByRole( 'textbox' ) ).toHaveAttribute(","+\t\t\t'id',","+\t\t\t'my-custom-id'","+\t\t);","+\t\texpect( screen.getByText( 'Custom id' ) ).toHaveAttribute(","+\t\t\t'for',","+\t\t\t'my-custom-id'","+\t\t);","+\t} );","+","+\tit( 'applies a consumer-supplied className to the outermost wrapper', () => {","+\t\tconst { container } = render(","+\t\t\t<ContentEditableControl","+\t\t\t\tlabel=\"Styled\"","+\t\t\t\tclassName=\"my-custom-class\"","+\t\t\t/>","+\t\t);","+","+\t\t// The package convention is to put the consumer's `className` on the","+\t\t// outermost wrapper (the `BaseControl` root), not the editable.","+\t\texpect(","+\t\t\t// eslint-disable-next-line testing-library/no-container, testing-library/no-node-access","+\t\t\tcontainer.querySelector( '.components-base-control' )","+\t\t).toHaveClass( 'my-custom-class' );","+\t\texpect( screen.getByRole( 'textbox' ) ).not.toHaveClass(","+\t\t\t'my-custom-class'","+\t\t);","+\t} );","+","+\tit( 'forwards additional native props to the textbox', () => {","+\t\trender(","+\t\t\t<ContentEditableControl","+\t\t\t\tlabel=\"Note\"","+\t\t\t\tdir=\"rtl\"","+\t\t\t\tdata-testid=\"my-textbox\"","+\t\t\t/>","+\t\t);","+","+\t\tconst textbox = screen.getByRole( 'textbox' );","+\t\texpect( textbox ).toHaveAttribute( 'dir', 'rtl' );","+\t\texpect( textbox ).toHaveAttribute( 'data-testid', 'my-textbox' );","+\t} );","+","+\tit( 'forwards its ref to the contenteditable element', () => {","+\t\t// The rich-text wiring (the `useRichText` ref, event-listener refs,","+\t\t// an anchor ref, …) is injected through this forwarded ref.","+\t\tconst ref = jest.fn();","+\t\trender( <ContentEditableControl label=\"Note\" ref={ ref } /> );","+","+\t\texpect( ref ).toHaveBeenCalledWith( screen.getByRole( 'textbox' ) );","+\t} );","+","+\tit( 'calls consumer-supplied focus and blur handlers', () => {","+\t\tconst onFocus = jest.fn();","+\t\tconst onBlur = jest.fn();","+\t\trender(","+\t\t\t<ContentEditableControl","+\t\t\t\tlabel=\"Field\"","+\t\t\t\tonFocus={ onFocus }","+\t\t\t\tonBlur={ onBlur }","+\t\t\t/>","+\t\t);","+\t\tconst textbox = screen.getByRole( 'textbox' );","+","+\t\tfireEvent.focus( textbox );","+\t\texpect( onFocus ).toHaveBeenCalledTimes( 1 );","+","+\t\tfireEvent.blur( textbox );","+\t\texpect( onBlur ).toHaveBeenCalledTimes( 1 );","+\t} );","+} );"],"additions":164,"deletions":0,"truncated":false},{"path":"packages/components/src/content-editable-control/types.ts","lines":["@@ -0,0 +1,35 @@","+/**","+ * Internal dependencies","+ */","+import type { BaseControlProps } from '../base-control/types';","+","+export type ContentEditableControlProps = Pick<","+\tBaseControlProps,","+\t'className' | 'hideLabelFromVision' | 'help'","+> & {","+\t/**","+\t * Label text for the control.","+\t */","+\tlabel: string;","+\t/**","+\t * Whether the field is non-editable. A disabled field is not","+\t * `contentEditable` (so it is neither focusable nor editable) and exposes","+\t * `aria-disabled` to assistive technology.","+\t *","+\t * @default false","+\t */","+\tdisabled?: boolean;","+\t/**","+\t * Whether the field is required. Exposed to assistive technology via","+\t * `aria-required`.","+\t *","+\t * @default false","+\t */","+\trequired?: boolean;","+\t/**","+\t * Placeholder text shown while the element has no content. Exposed to","+\t * assistive technology via `aria-placeholder` and drawn by the stylesheet","+\t * when the element is empty.","+\t */","+\tplaceholder?: string;","+};"],"additions":35,"deletions":0,"truncated":false},{"path":"packages/components/src/private-apis.ts","lines":["@@ -24,15 +24,18 @@ import {"," \tValidatedNumberControl,"," \tValidatedSelectControl,"," \tValidatedRadioControl,","+\tValidatedContentEditableControl,"," \tValidatedTextControl,"," \tValidatedTextareaControl,"," \tValidatedToggleControl,"," \tValidatedToggleGroupControl,"," } from './validated-form-controls';"," import { ValidatedFormTokenField } from './validated-form-controls/components/form-token-field';","+import ContentEditableControl from './content-editable-control';"," "," export const privateApis = {};"," lock( privateApis, {","+\tContentEditableControl,"," \t__experimentalPopoverLegacyPositionToPlacement,"," \tComponentsContext,"," \tTabs,","@@ -52,6 +55,7 @@ lock( privateApis, {"," \tValidatedNumberControl,"," \tValidatedSelectControl,"," \tValidatedRadioControl,","+\tValidatedContentEditableControl,"," \tValidatedTextControl,"," \tValidatedTextareaControl,"," \tValidatedToggleControl,"],"additions":4,"deletions":0,"truncated":false},{"path":"packages/components/src/validated-form-controls/components/content-editable-control.tsx","lines":["@@ -0,0 +1,88 @@","+/**","+ * External dependencies","+ */","+import clsx from 'clsx';","+","+/**","+ * WordPress dependencies","+ */","+import { forwardRef, useRef } from '@wordpress/element';","+","+/**","+ * Internal dependencies","+ */","+import { ControlWithError } from '../control-with-error';","+import type { ValidatedControlProps } from './types';","+import ContentEditableControl from '../../content-editable-control';","+","+/**","+ * A `contentEditable` field does not par