ient, prefix)"," \tif err != nil {"," \t\treturn nil, err"," \t}","@@ -339,22 +339,53 @@ func (m *Meta) JobByPrefix(client *api.Client, prefix string, filter string) (*a"," \treturn job, nil"," }"," ","+// JobByPrefixFilterFunc filters jobs during a client-side prefix match. It is","+// the fallback for servers that cannot evaluate the server-side filter expression.","+type JobByPrefixFilterFunc func(*api.JobListStub) bool","+"," // JobIDByPrefix provides best effort match for the given job prefix."," // Returns the prefix itself if job prefix search is not allowed and an error"," // if there are no matches or if there are more than one exact match across"," // namespaces.","-func (m *Meta) JobIDByPrefix(client *api.Client, prefix string, filter string) (string, string, error) {","+func (m *Meta) JobIDByPrefix(client *api.Client, prefix string) (string, string, error) {","+\treturn m.jobIDByPrefix(client, prefix, \"\", nil)","+}","+","+// jobIDByPrefix backs JobIDByPrefix. When clientFilter is set and the server is","+// too old to parse the filter expression (the \"is not nil\" operator landed in","+// 1.11.3), it retries without the server-side filter and applies clientFilter","+// to the results instead.","+func (m *Meta) jobIDByPrefix(client *api.Client, prefix, filter string, clientFilter JobByPrefixFilterFunc) (string, string, error) {"," \tmaxResults := 20 // reduce load for large sets"," \tjobs, _, err := client.Jobs().ListOptions(nil, &api.QueryOptions{"," \t\tPrefix:  prefix,"," \t\tFilter:  filter,"," \t\tPerPage: int32(maxResults),"," \t})","+\ttruncated := len(jobs) >= maxResults"," \tif err != nil {"," \t\tif strings.Contains(err.Error(), api.PermissionDeniedErrorContent) {"," \t\t\treturn prefix, \"\", nil"," \t\t}","-\t\treturn \"\", \"\", fmt.Errorf(\"Error querying job prefix %q: %s\", prefix, err)","+\t\t// Servers older than 1.11.3 reject the \"is not nil\" filter operator","+\t\t// while building the result paginator. Retry without the server-side","+\t\t// filter and narrow the results on the client.","+\t\t// COMPAT(2.0): remove this fallback once 1.10LTS is out of support","+\t\tif clientFilter == nil || !strings.Contains(err.Error(), api.ResultPaginatorErrorContent) {","+\t\t\treturn \"\", \"\", fmt.Errorf(\"Error querying job prefix %q: %s\", prefix, err)","+\t\t}","+\t\tjobs, _, err = client.Jobs().PrefixList(prefix)","+\t\tif err != nil {","+\t\t\treturn \"\", \"\", fmt.Errorf(\"Error querying job prefix %q: %s\", prefix, err)","+\t\t}","+\t\tvar filtered []*api.JobListStub","+\t\tfor _, j := range jobs {","+\t\t\tif clientFilter(j) {","+\t\t\t\tfiltered = append(filtered, j)","+\t\t\t}","+\t\t}","+\t\tjobs = filtered","+\t\ttruncated = false // the unfiltered prefix list is complete"," \t}"," "," \tif len(jobs) == 0 {","@@ -364,7 +395,7 @@ func (m *Meta) JobIDByPrefix(client *api.Client, prefix string, filter string) ("," \t\texactMatch := prefix == jobs[0].ID"," \t\tmatchInMultipleNamespaces := m.allNamespaces() && jobs[0].ID == jobs[1].ID"," \t\ttruncatedMsg := \"\"","-\t\tif len(jobs) >= maxResults {","+\t\tif truncated {"," \t\t\ttruncatedMsg = \"\\n(results may be truncated)\""," \t\t}"," \t\tif !exactMatch || matchInMultipleNamespaces {"],"additions":36,"deletions":5,"truncated":false},{"path":"command/meta_test.go","lines":["@@ -4,8 +4,11 @@"," package command"," "," import (","+\t\"encoding/json\""," \t\"flag\""," \t\"fmt\"","+\t\"net/http\"","+\t\"net/http/httptest\""," \t\"os\""," \t\"reflect\""," \t\"sort\"","@@ -201,7 +204,6 @@ func TestMeta_JobByPrefix(t *testing.T) {"," \ttestCases := []struct {"," \t\tname          string"," \t\tprefix        string","-\t\tfilter        string"," \t\texpectedError string"," \t}{"," \t\t{","@@ -212,12 +214,6 @@ func TestMeta_JobByPrefix(t *testing.T) {"," \t\t\tname:   \"partial match\","," \t\t\tprefix: \"exam\","," \t\t},","-\t\t{","-\t\t\tname:   \"match with filter\",","-\t\t\tprefix: \"job-\",","-\t\t\t// Filter out jobs so that only \"job-2\" ma