+\t\t\treturn \"\", err","+\t\t}","+","+\t\treplacement := expressions.EscapeStringValue(result.Text, marker.quote)","+\t\tresolved = resolved[:marker.start] + replacement + resolved[marker.end:]","+\t}","+","+\treturn resolved, nil","+}","+","+func findDSLStringMarkers(expression string, data map[string]interface{}, stringSpans []stringLiteralSpan) ([]dslStringMarker, error) {","+\tvar markers []dslStringMarker","+\tvar occupiedSpans []textSpan","+","+\tseenComplex := make(map[string]struct{})","+","+\tfor _, expr := range expressions.FindExpressions(expression, \"{{\", \"}}\", data) {","+\t\tif _, ok := seenComplex[expr]; ok {","+\t\t\tcontinue","+\t\t}","+\t\tseenComplex[expr] = struct{}{}","+","+\t\tmarker := \"{{\" + expr + \"}}\"","+\t\tfor start := 0; ; {","+\t\t\tindex := strings.Index(expression[start:], marker)","+\t\t\tif index < 0 {","+\t\t\t\tbreak","+\t\t\t}","+","+\t\t\tindex += start","+\t\t\tend := index + len(marker)","+","+\t\t\tstringSpan, ok := stringLiteralForSpan(stringSpans, index, end)","+\t\t\tif !ok {","+\t\t\t\treturn nil, fmt.Errorf(\"unresolved DSL placeholder %q is not inside a string literal\", expr)","+\t\t\t}","+","+\t\t\tgot := dslStringMarker{start: index, end: end, expr: expr, quote: stringSpan.quote}","+\t\t\tmarkers = append(markers, got)","+\t\t\toccupiedSpans = append(occupiedSpans, textSpan{start: index, end: end})","+\t\t\tstart = end","+\t\t}","+\t}","+","+\tfor _, match := range dslStringMarkerRegex.FindAllStringSubmatchIndex(expression, -1) {","+\t\tif len(match) < 4 || markerWithinSpans(match[0], match[1], occupiedSpans) {","+\t\t\tcontinue","+\t\t}","+","+\t\tstringSpan, ok := stringLiteralForSpan(stringSpans, match[0], match[1])","+\t\tif !ok {","+\t\t\treturn nil, fmt.Errorf(\"unresolved DSL placeholder %q is not inside a string literal\", expression[match[2]:match[3]])","+\t\t}","+","+\t\tmarkers = append(markers, dslStringMarker{","+\t\t\tstart: match[0],","+\t\t\tend:   match[1],","+\t\t\texpr:  expression[match[2]:match[3]],","+\t\t\tquote: stringSpan.quote,","+\t\t})","+\t}","+","+\treturn markers, nil","+}","+","+func markerWithinSpans(start, end int, spans []textSpan) bool {","+\tfor _, span := range spans {","+\t\tif start >= span.start && end <= span.end {","+\t\t\treturn true","+\t\t}","+\t}","+","+\treturn false","+}","+","+func findStringLiteralSpans(expression string) []stringLiteralSpan {","+\tvar spans []stringLiteralSpan","+\tvar quote byte","+\tstart := 0","+\tescaped := false","+","+\tfor i := 0; i < len(expression); i++ {","+\t\tchar := expression[i]","+\t\tif escaped {","+\t\t\tescaped = false","+\t\t\tcontinue","+\t\t}","+","+\t\tif char == '\\\\' {","+\t\t\tescaped = true","+\t\t\tcontinue","+\t\t}","+","+\t\tif quote != 0 {","+\t\t\tif char == quote {","+\t\t\t\tspans = append(spans, stringLiteralSpan{start: start, end: i, quote: quote})","+\t\t\t\tquote = 0","+\t\t\t}","+\t\t\tcontinue","+\t\t}","+","+\t\tif char == '\\'' || char == '\"' {","+\t\t\tquote = char","+\t\t\tstart = i + 1","+\t\t}","+\t}","+","+\tif quote != 0 {","+\t\tspans = append(spans, stringLiteralSpan{start: start, end: len(expression), quote: quote})","+\t}","+","+\treturn spans","+}","+","+func stringLiteralForSpan(spans []stringLiteralSpan, start, end int) (stringLiteralSpan, bool) {","+\tfor _, span := range spans {","+\t\tif start >= span.start && end <= span.end {","+\t\t\treturn span, true","+\t\t}","+\t}","+","+\treturn stringLiteralSpan{}, false","+}"],"additions":181,"deletions":0,"truncated":false},{"path":"pkg/operators/matchers/match.go","lines":["@@ -11,6 +11,7 @@ import ("," \t\"github.com/projectdiscovery/gologger\""," \t\"github.com/projectdiscovery/nuclei/v3/pkg/operators/common/dsl\""," \t\"github.com/projectdiscovery/nuclei/v3/pkg/protocols/common/expressions\"","+\t\"github.com/projectdiscovery/nuclei/v3/pkg/protocols/common/render\""," \tstringsutil \"github.com/projectdiscovery/utils/strings\""," )"," ","@@ -64,13 +65,14 @@ func (matcher *Matcher) MatchWords(corp