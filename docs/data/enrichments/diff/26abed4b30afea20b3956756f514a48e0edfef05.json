{"id":"26abed4b30afea20b3956756f514a48e0edfef05","axis":"silent","repo":"WordPress/gutenberg","sha":"26abed4b30afea20b3956756f514a48e0edfef05","parsed":{"files":[{"path":"packages/edit-post/src/components/layout/index.js","lines":["@@ -73,7 +73,8 @@ import { useMetaBoxInitialization } from '../meta-boxes/use-meta-box-initializat"," const { useCommandContext } = unlock( commandsPrivateApis );"," /** @type {{} & {useDrag: import('@use-gesture/react').useDrag}} */"," const { useDrag } = unlock( componentsPrivateApis );","-const { Editor, FullscreenMode } = unlock( editorPrivateApis );","+const { Editor, FullscreenMode, UploadProgressSnackbar } =","+\tunlock( editorPrivateApis );"," const { BlockKeyboardShortcuts } = unlock( blockLibraryPrivateApis );"," const DESIGN_POST_TYPES = ["," \t'wp_template',","@@ -623,6 +624,7 @@ function Layout( {"," \t\t\t\t\t\t\t<PostEditorMoreMenu />"," \t\t\t\t\t\t\t{ backButton }"," \t\t\t\t\t\t\t<SnackbarNotices className=\"edit-post-layout__snackbar\" />","+\t\t\t\t\t\t\t<UploadProgressSnackbar />"," \t\t\t\t\t\t</Editor>"," \t\t\t\t\t</div>"," \t\t\t\t</ErrorBoundary>"],"additions":3,"deletions":1,"truncated":false},{"path":"packages/edit-site/src/components/layout/index.js","lines":["@@ -48,7 +48,7 @@ import SaveHub from '../save-hub';"," import SavePanel from '../save-panel';"," "," const { useLocation } = unlock( routerPrivateApis );","-const { useStyle } = unlock( editorPrivateApis );","+const { useStyle, UploadProgressSnackbar } = unlock( editorPrivateApis );"," "," const ANIMATION_DURATION = 0.3;"," ","@@ -164,6 +164,7 @@ function Layout() {"," \t\t\t\t\t) }"," "," \t\t\t\t\t<SnackbarNotices className=\"edit-site-layout__snackbar\" />","+\t\t\t\t\t<UploadProgressSnackbar />"," "," \t\t\t\t\t{ isMobileViewport && areas.mobile && ("," \t\t\t\t\t\t<div className=\"edit-site-layout__mobile\">"],"additions":2,"deletions":1,"truncated":false},{"path":"packages/editor/CHANGELOG.md","lines":["@@ -2,6 +2,10 @@"," "," ## Unreleased"," ","+### New Features","+","+-   Added `UploadProgressSnackbar` component that shows a persistent snackbar with upload progress while media uploads are in progress. The snackbar shows a spinner during uploads and a checkmark briefly when all uploads complete.","+"," ### Code Quality"," "," -   Add missing `@types/react` dependency. [#78882](https://github.com/WordPress/gutenberg/pull/78882)."],"additions":4,"deletions":0,"truncated":false},{"path":"packages/editor/src/components/upload-progress-snackbar/README.md","lines":["@@ -0,0 +1,26 @@","+# UploadProgressSnackbar","+","+`UploadProgressSnackbar` manages a snackbar notice that shows media upload progress. It creates and updates a notice via the notices store, so the snackbar positions and stacks with every other snackbar in the editor.","+","+The component reads from two sources so it works for both upload paths:","+","+-   **`@wordpress/upload-media`** — the client-side media processing (CSM) path. Only counts original user-uploaded files, ignoring generated subsizes and thumbnails (items with a `parentId`).","+-   **Editor-local tracker** — populated by the editor's `mediaUpload` wrapper for the traditional (non-CSM) upload path (e.g. Safari, or when a filter disables CSM).","+","+While uploads are in progress the snackbar shows a spinner to the left of the text. When the last upload finishes, the spinner is replaced with a green checkmark for a brief moment before the snackbar dismisses.","+","+The component renders nothing itself — it is a controller that manages a notice.","+","+## Usage","+","+```jsx","+import { UploadProgressSnackbar } from '@wordpress/editor';","+","+// Mount anywhere in the editor — it doesn't render DOM, just manages a notice.","+<UploadProgressSnackbar />","+```","+","+## Accessibility","+","+-   The component calls `wp.a11y.speak()` once when uploads start and once when they complete, avoiding per-tick chatter.","+-   The snackbar is created with `speak: false` to prevent the notices store from re-announcing on every text update."],"additions":26,"deletions":0,"truncated":false},{"path":"packages/editor/src/components/upload-progress-snackbar/index.js","lines":["@@ -0,0 +1,216 @@","+/**","+ * WordPress dependencies","+ */","+import { useSelect, useDispatch } from '@wordpress/data';","+import { useEffect, useMemo, useRef, useState } from '@wordpress/element';","+import { __, sprintf } from '@wordpress/i18n';","+import { speak } from '@wordpress/a11y';","+import { store as uploadStore } from '@wordpress/upload-media';","+import { store as noticesStore } from '@wordpress/notices';","+import { Icon as WCIcon, Spinner } from '@wordpress/components';","+import { check } from '@wordpress/icons';","+","+/**","+ * Internal dependencies","+ */","+import { useTracker } from './tracker';","+","+const NOTICE_ID = 'upload-progress';","+","+// How long the completion checkmark is shown before the snackbar dismisses.","+const COMPLETION_DISPLAY_MS = 3000;","+","+// Longest filename shown before it is middle-truncated. Long names (e.g. the","+// UUID-style names some sources produce) would otherwise stretch the snackbar.","+const MAX_FILENAME_LENGTH = 40;","+","+/**","+ * Middle-truncates a filename that exceeds `MAX_FILENAME_LENGTH`, keeping the","+ * start and the end (so the file extension stays visible).","+ *","+ * @param {string} filename The filename to truncate.","+ * @return {string} The original or middle-truncated filename.","+ */","+function truncateFilename( filename ) {","+\tif ( filename.length <= MAX_FILENAME_LENGTH ) {","+\t\treturn filename;","+\t}","+\tconst ellipsis = '…';","+\tconst visible = MAX_FILENAME_LENGTH - ellipsis.length;","+\tconst front = Math.ceil( visible / 2 );","+\tconst back = Math.floor( visible / 2 );","+\treturn (","+\t\tfilename.slice( 0, front ) +","+\t\tellipsis +","+\t\tfilename.slice( filename.length - back )","+\t);","+}","+","+// Exported so the Storybook story can render the exact icon markup the notice","+// uses, keeping the visual review faithful to what ships.","+export const UPLOAD_SPINNER = (","+\t<span","+\t\tclassName=\"editor-upload-progress-snackbar__spinner\"","+\t\taria-hidden=\"true\"","+\t>","+\t\t<Spinner />","+\t</span>","+);","+","+export const UPLOAD_DONE = (","+\t<span className=\"editor-upload-progress-snackbar__check\" aria-hidden=\"true\">","+\t\t<WCIcon icon={ check } />","+\t</span>","+);","+","+/**","+ * Manages a snackbar notice that shows media upload progress while uploads are","+ * in progress. It creates/updates a notice via the notices store so that it","+ * positions and stacks with every other snackbar in the editor.","+ *","+ * Reads from two sources to cover both upload paths:","+ *  - `@wordpress/upload-media` store (client-side media processing path).","+ *  - An editor-local tracker populated by the traditional `mediaUpload`","+ *    wrapper (non-CSM path — e.g. Safari, or when a filter disables CSM).","+ *","+ * Only counts original user-uploaded files (items without a `parentId`),","+ * ignoring generated subsizes/thumbnails.","+ *","+ * @return {null} This component renders nothing — it only manages a notice.","+ */","+export default function UploadProgressSnackbar() {","+\tconst items = useSelect(","+\t\t( select ) => select( uploadStore ).getItems(),","+\t\t[]","+\t);","+\tconst tracker = useTracker();","+","+\t// CSM path: originals in the upload-media queue (subsizes excluded). Memoized","+\t// so its reference is stable across renders where `items` is unchanged, since","+\t// it's a dependency of the effect below.","+\tconst csmOriginals = useMemo(","+\t\t() => items.filter( ( item ) => ! item.parentId ),","+\t\t[ items ]","+\t);","+\tconst csmRemaining = csmOriginals.length;","+","+\t// Non-CSM path: files tracked by the editor's mediaUpload wrapper.","+\tconst trackedRemaining = tracker ? tracker.total - tracker.completed : 0;","+","+\tconst remaining = csmRemaining + trackedRemaining;","+","+\t// Track peak total across sources during a session. The CSM queue removes","+\t// items on completion, and the tracker tops out at its recorded total, so","+\t// `total` has to be tracked as the high-water mark.","+\tconst [ peak, setPeak ] = useState( 0 );","+\tconst sessionTotal = csmRemaining + ( tracker ? tracker.total : 0 );","+\tif ( sessionTotal > peak ) {","+\t\tsetPeak( sessionTotal );","+\t}","+","+\tconst { createNotice, removeNotice } = useDispatch( noticesStore );","+","+\t// Track whether the user has dismissed the notice. If so, don't re-create","+\t// it until the current batch finishes and a new one starts.","+\tconst dismissedRef = useRef( false );","+\tconst wasUploadingRef = useRef( false );","+","+\t// Timeout that removes the completion-state (checkmark) notice after a","+\t// brief display. Held so a new upload can cancel it.","+\tconst completionTimeoutRef = useRef( null );","+\tuseEffect( () => {","+\t\treturn () => {","+\t\t\tif ( completionTimeoutRef.current ) {","+\t\t\t\tclearTimeout( completionTimeoutRef.current );","+\t\t\t}","+\t\t};","+\t}, [] );","+","+\tuseEffect( () => {","+\t\tconst isUploading = remaining > 0;","+","+\t\tif ( isUploading && ! wasUploadingRef.current ) {","+\t\t\tdismissedRef.current = false;","+\t\t\tspeak( __( 'Media upload started' ), 'polite' );","+\t\t\t// A new batch started during the completion display: cancel the","+\t\t\t// pending dismissal so the snackbar transitions straight back","+\t\t\t// into the uploading state, and reset the peak so the new batch","+\t\t\t// counts from `1 of N` rather than resuming the previous total.","+\t\t\tif ( completionTimeoutRef.current ) {","+\t\t\t\tclearTimeout( completionTimeoutRef.current );","+\t\t\t\tcompletionTimeoutRef.current = null;","+\t\t\t\tsetPeak( 0 );","+\t\t\t}","+\t\t} else if ( ! isUploading && wasUploadingRef.current ) {","+\t\t\tspeak( __( 'Media upload complete' ), 'polite' );","+","+\t\t\tif ( ! dismissedRef.current ) {","+\t\t\t\tcreateNotice( 'info', __( 'Upload complete' ), {","+\t\t\t\t\tid: NOTICE_ID,","+\t\t\t\t\ttype: 'snackbar',","+\t\t\t\t\tisDismissible: false,","+\t\t\t\t\texplicitDismiss: false,","+\t\t\t\t\tspeak: false,","+\t\t\t\t\ticon: UPLOAD_DONE,","+\t\t\t\t\tonDismiss: () => {","+\t\t\t\t\t\tdismissedRef.current = true;","+\t\t\t\t\t},","+\t\t\t\t} );","+","+\t\t\t\tcompletionTimeoutRef.current = setTimeout( () => {","+\t\t\t\t\tremoveNotice( NOTICE_ID );","+\t\t\t\t\tcompletionTimeoutRef.current = null;","+\t\t\t\t\tsetPeak( 0 );","+\t\t\t\t}, COMPLETION_DISPLAY_MS );","+\t\t\t} else {","+\t\t\t\tsetPeak( 0 );","+\t\t\t}","+\t\t}","+","+\t\twasUploadingRef.current = isUploading;","+","+\t\tif ( ! isUploading || dismissedRef.current ) {","+\t\t\treturn;","+\t\t}","+","+\t\tconst total = peak;","+\t\tconst current = total - remaining + 1;","+","+\t\t// Prefer the CSM queue's first original filename, then fall back to","+\t\t// the tracker's first pending filename.","+\t\tconst filename = truncateFilename(","+\t\t\tcsmOriginals[ 0 ]?.sourceFile?.name ||","+\t\t\t\ttracker?.pending[ 0 ] ||","+\t\t\t\t__( 'Uploading' )","+\t\t);","+","+\t\tconst content =","+\t\t\ttotal === 1","+\t\t\t\t? sprintf(","+\t\t\t\t\t\t/* translators: %s: filename. */","+\t\t\t\t\t\t__( 'Uploading — %s' ),","+\t\t\t\t\t\tfilename","+\t\t\t\t  )","+\t\t\t\t: sprintf(","+\t\t\t\t\t\t/* translators: 1: current upload number, 2: total uploads, 3: filename. */","+\t\t\t\t\t\t__( 'Uploading %1$d of %2$d — %3$s' ),","+\t\t\t\t\t\tcurrent,","+\t\t\t\t\t\ttotal,","+\t\t\t\t\t\tfilename","+\t\t\t\t  );","+","+\t\tcreateNotice( 'info', content, {","+\t\t\tid: NOTICE_ID,","+\t\t\ttype: 'snackbar',","+\t\t\tisDismissible: false,","+\t\t\texplicitDismiss: true,","+\t\t\tspeak: false,","+\t\t\ticon: UPLOAD_SPINNER,","+\t\t\tonDismiss: () => {","+\t\t\t\tdismissedRef.current = true;","+\t\t\t},","+\t\t} );","+\t}, [ remaining, peak, csmOriginals, tracker, createNotice, removeNotice ] );","+","+\treturn null;","+}"],"additions":216,"deletions":0,"truncated":false},{"path":"packages/editor/src/components/upload-progress-snackbar/stories/index.story.tsx","lines":["@@ -0,0 +1,85 @@","+/**","+ * External dependencies","+ */","+import type { Meta, StoryObj } from '@storybook/react-vite';","+","+/**","+ * WordPress dependencies","+ */","+import { Snackbar } from '@wordpress/components';","+","+/**","+ * Internal dependencies","+ */","+import { UPLOAD_DONE, UPLOAD_SPINNER } from '../index';","+","+/**","+ * The `UploadProgressSnackbar` component itself renders no UI: it manages a","+ * snackbar notice via the notices store while media uploads are in progress.","+ *","+ * These stories render the `Snackbar` with the same icon markup and text the","+ * notice produces, so the in-progress and completed states can be reviewed","+ * visually without running an actual upload.","+ */","+const meta: Meta< typeof Snackbar > = {","+\ttitle: 'Editor/UploadProgressSnackbar',","+\tcomponent: Snackbar,","+\tparameters: {","+\t\tdocs: { canvas: { sourceState: 'shown' } },","+\t},","+\targTypes: {","+\t\ticon: { control: false },","+\t\tchildren: { control: false },","+\t},","+};","+export default meta;","+","+type Story = StoryObj< typeof Snackbar >;","+","+export const Uploading: Story = {","+\targs: {","+\t\ticon: UPLOAD_SPINNER,","+\t\tchildren: 'Uploading — sunset-over-the-bay.jpg',","+\t\texplicitDismiss: true,","+\t},","+};","+","+export const UploadingMultiple: Story = {","+\targs: {","+\t\ticon: UPLOAD_SPINNER,","+\t\tchildren: 'Uploading 1 of 3 — sunset-over-the-bay.jpg',","+\t\texplicitDismiss: true,","+\t},","+};","+","+export const Complete: Story = {","+\targs: {","+\t\ticon: UPLOAD_DONE,","+\t\tchildren: 'Upload complete',","+\t},","+};","+","+/**","+ * All states shown together for quick comparison of the icon alignment and","+ * sizing between the spinner and the completion checkmark.","+ */","+export const AllStates: Story = {","+\trender: () => (","+\t\t<div","+\t\t\tstyle={ {","+\t\t\t\tdisplay: 'flex',","+\t\t\t\tflexDirection: 'column',","+\t\t\t\talignItems: 'flex-start',","+\t\t\t\tgap: '12px',","+\t\t\t} }","+\t\t>","+\t\t\t<Snackbar icon={ UPLOAD_SPINNER } explicitDismiss>","+\t\t\t\tUploading — sunset-over-the-bay.jpg","+\t\t\t</Snackbar>","+\t\t\t<Snackbar icon={ UPLOAD_SPINNER } explicitDismiss>","+\t\t\t\tUploading 1 of 3 — sunset-over-the-bay.jpg","+\t\t\t</Snackbar>","+\t\t\t<Snackbar icon={ UPLOAD_DONE }>Upload complete</Snackbar>","+\t\t</div>","+\t),","+};"],"additions":85,"deletions":0,"truncated":false},{"path":"packages/editor/src/components/upload-progress-snackbar/style.scss","lines":["@@ -0,0 +1,30 @@","+@use \"@wordpress/base-styles/variables\" as *;","+","+.editor-upload-progress-snackbar__spinner,","+.editor-upload-progress-snackbar__check {","+\tdisplay: inline-flex;","+\talign-items: center;","+\tjustify-content: center;","+\t// Size the slot to $icon-size to match the icon dimensions the Snackbar's","+\t// absolute positioning is tuned for, so the spinner and checkmark sit","+\t// vertically centered against the notice text.","+\twidth: $icon-size;","+\theight: $icon-size;","+}","+","+.editor-upload-progress-snackbar__spinner .components-spinner {","+\t// The Spinner ships with an asymmetric default margin (top, not bottom),","+\t// which offsets it within the centered icon slot. Reset it so the flex","+\t// centering above keeps the spinner vertically centered against the text.","+\tmargin: 0;","+}","+","+.editor-upload-progress-snackbar__check svg {","+\t// Render at the full icon size: the check glyph only occupies the center of","+\t// its viewBox, so a smaller size makes the mark look faint next to the text.","+\twidth: $icon-size;","+\theight: $icon-size;","+\t// The icon ships without a fill, which renders black and disappears against","+\t// the dark snackbar. Inherit the snackbar's white text color instead.","+\tfill: currentColor;","+}"],"additions":30,"deletions":0,"truncated":false},{"path":"packages/editor/src/components/upload-progress-snackbar/test/index.js","lines":["@@ -0,0 +1,199 @@","+/**","+ * External dependencies","+ */","+import { render, act } from '@testing-library/react';","+","+/**","+ * WordPress dependencies","+ */","+import { useSelect } from '@wordpress/data';","+","+/**","+ * Internal dependencies","+ */","+import UploadProgressSnackbar from '../';","+import { addFiles, advance, reset } from '../tracker';","+","+jest.mock( '@wordpress/data/src/components/use-select', () => {","+\tconst mock = jest.fn();","+\treturn mock;","+} );","+","+const mockCreateNotice = jest.fn();","+const mockRemoveNotice = jest.fn();","+","+jest.mock( '@wordpress/data/src/components/use-dispatch', () => {","+\treturn {","+\t\tuseDispatch: jest.fn( () => ( {","+\t\t\tcreateNotice: mockCreateNotice,","+\t\t\tremoveNotice: mockRemoveNotice,","+\t\t} ) ),","+\t\tuseDispatchWithMap: jest.fn(),","+\t};","+} );","+","+jest.mock( '@wordpress/a11y', () => ( {","+\tspeak: jest.fn(),","+} ) );","+","+function mockQueue( items ) {","+\tuseSelect.mockImplementation( ( mapSelect ) =>","+\t\tmapSelect( () => ( {","+\t\t\tgetItems: () => items,","+\t\t\tisUploading: () => items.length > 0,","+\t\t} ) )","+\t);","+}","+","+function makeItem( id, name, { parentId } = {} ) {","+\treturn {","+\t\tid,","+\t\tsourceFile: { name },","+\t\tstatus: 'PROCESSING',","+\t\tparentId,","+\t};","+}","+","+describe( 'UploadProgressSnackbar', () => {","+\tbeforeEach( () => {","+\t\tjest.clearAllMocks();","+\t\treset();","+\t} );","+","+\tit( 'does not create a notice when both sources are empty', () => {","+\t\tmockQueue( [] );","+\t\trender( <UploadProgressSnackbar /> );","+\t\texpect( mockCreateNotice ).not.toHaveBeenCalled();","+\t} );","+","+\tit( 'creates a notice with the filename when a single CSM upload is in progress', () => {","+\t\tmockQueue( [ makeItem( '1', 'photo.jpg' ) ] );","+\t\trender( <UploadProgressSnackbar /> );","+\t\texpect( mockCreateNotice ).toHaveBeenCalledWith(","+\t\t\t'info',","+\t\t\texpect.stringContaining( 'photo.jpg' ),","+\t\t\texpect.objectContaining( {","+\t\t\t\tid: 'upload-progress',","+\t\t\t\ttype: 'snackbar',","+\t\t\t} )","+\t\t);","+\t\texpect( mockCreateNotice.mock.calls[ 0 ][ 1 ] ).toBe(","+\t\t\t'Uploading — photo.jpg'","+\t\t);","+\t} );","+","+\tit( 'shows batch count for CSM uploads', () => {","+\t\tmockQueue( [","+\t\t\tmakeItem( '1', 'a.jpg' ),","+\t\t\tmakeItem( '2', 'b.jpg' ),","+\t\t\tmakeItem( '3', 'c.jpg' ),","+\t\t] );","+\t\trender( <UploadProgressSnackbar /> );","+\t\texpect( mockCreateNotice.mock.calls[ 0 ][ 1 ] ).toMatch( /1 of 3/ );","+\t} );","+","+\tit( 'excludes subsizes from the CSM count', () => {","+\t\tmockQueue( [","+\t\t\tmakeItem( '1', 'photo.jpg' ),","+\t\t\tmakeItem( '1-thumb', 'photo-150x150.jpg', { parentId: '1' } ),","+\t\t\tmakeItem( '1-medium', 'photo-300x300.jpg', { parentId: '1' } ),","+\t\t] );","+\t\trender( <UploadProgressSnackbar /> );","+\t\texpect( mockCreateNotice.mock.calls[ 0 ][ 1 ] ).toBe(","+\t\t\t'Uploading — photo.jpg'","+\t\t);","+\t} );","+","+\tit( 'shows non-CSM uploads tracked by the editor mediaUpload wrapper', () => {","+\t\tmockQueue( [] );","+\t\tact( () => {","+\t\t\taddFiles( [ 'traditional.jpg' ] );","+\t\t} );","+\t\trender( <UploadProgressSnackbar /> );","+\t\texpect( mockCreateNotice.mock.calls[ 0 ][ 1 ] ).toBe(","+\t\t\t'Uploading — traditional.jpg'","+\t\t);","+\t} );","+","+\tit( 'shows batch count for non-CSM uploads', () => {","+\t\tmockQueue( [] );","+\t\tact( () => {","+\t\t\taddFiles( [ 'a.jpg', 'b.jpg', 'c.jpg' ] );","+\t\t} );","+\t\trender( <UploadProgressSnackbar /> );","+\t\texpect( mockCreateNotice.mock.calls[ 0 ][ 1 ] ).toMatch( /1 of 3/ );","+\t\texpect( mockCreateNotice.mock.calls[ 0 ][ 1 ] ).toMatch( /a\\.jpg/ );","+\t} );","+","+\tit( 'shows a completion notice and then removes it when uploads finish', () => {","+\t\tjest.useFakeTimers();","+\t\ttry {","+\t\t\tmockQueue( [] );","+\t\t\tact( () => {","+\t\t\t\taddFiles( [ 'a.jpg' ] );","+\t\t\t} );","+\t\t\trender( <UploadProgressSnackbar /> );","+\t\t\texpect( mockCreateNotice ).toHaveBeenCalled();","+\t\t\tmockCreateNotice.mockClear();","+","+\t\t\tact( () => {","+\t\t\t\tadvance( 1 );","+\t\t\t} );","+","+\t\t\t// Completion notice replaces the progress notice (same ID).","+\t\t\texpect( mockCreateNotice ).toHaveBeenCalledWith(","+\t\t\t\t'info',","+\t\t\t\t'Upload complete',","+\t\t\t\texpect.objectContaining( {","+\t\t\t\t\tid: 'upload-progress',","+\t\t\t\t\ttype: 'snackbar',","+\t\t\t\t\ticon: expect.anything(),","+\t\t\t\t} )","+\t\t\t);","+\t\t\texpect( mockRemoveNotice ).not.toHaveBeenCalled();","+","+\t\t\tact( () => {","+\t\t\t\tjest.runAllTimers();","+\t\t\t} );","+","+\t\t\texpect( mockRemoveNotice ).toHaveBeenCalledWith(","+\t\t\t\t'upload-progress'","+\t\t\t);","+\t\t} finally {","+\t\t\tjest.useRealTimers();","+\t\t}","+\t} );","+","+\tit( 'middle-truncates a long filename while keeping the extension', () => {","+\t\tconst longName =","+\t\t\t'a-really-long-uuid-like-filename-1234567890-abcdefghij.jpg';","+\t\tmockQueue( [ makeItem( '1', longName ) ] );","+\t\trender( <UploadProgressSnackbar /> );","+\t\tconst content = mockCreateNotice.mock.calls[ 0 ][ 1 ];","+\t\t// Truncated: shorter than the original, marked with an ellipsis, and the","+\t\t// extension is still visible.","+\t\texpect( content ).toContain( '…' );","+\t\texpect( content ).not.toContain( longName );","+\t\texpect( content ).toMatch( /\\.jpg$/ );","+\t} );","+","+\tit( 'does not truncate a short filename', () => {","+\t\tmockQueue( [ makeItem( '1', 'photo.jpg' ) ] );","+\t\trender( <UploadProgressSnackbar /> );","+\t\texpect( mockCreateNotice.mock.calls[ 0 ][ 1 ] ).toBe(","+\t\t\t'Uploading — photo.jpg'","+\t\t);","+\t} );","+","+\tit( 'includes a spinner icon on the in-progress notice', () => {","+\t\tmockQueue( [ makeItem( '1', 'photo.jpg' ) ] );","+\t\trender( <UploadProgressSnackbar /> );","+\t\texpect( mockCreateNotice ).toHaveBeenCalledWith(","+\t\t\t'info',","+\t\t\texpect.any( String ),","+\t\t\texpect.objectContaining( {","+\t\t\t\ticon: expect.anything(),","+\t\t\t} )","+\t\t);","+\t} );","+} );"],"additions":199,"deletions":0,"truncated":false},{"path":"packages/editor/src/components/upload-progress-snackbar/tracker.js","lines":["@@ -0,0 +1,105 @@","+/**","+ * WordPress dependencies","+ */","+import { useSyncExternalStore } from '@wordpress/element';","+","+/**","+ * A minimal in-memory tracker for in-flight media uploads that happen outside","+ * the `@wordpress/upload-media` store (i.e. the traditional / non-CSM upload","+ * path). The editor's `mediaUpload` wrapper writes to it; the","+ * `UploadProgressSnackbar` reads from it.","+ *","+ * State shape: { total, completed, pending: string[] }","+ * - `total`: total files registered in the current session.","+ * - `completed`: files that have finished (succeeded OR errored).","+ * - `pending`: remaining filenames in submission order.","+ *","+ * The tracker holds at most one \"session\" at a time — if a new batch starts","+ * while one is in progress, its files are appended to the existing session.","+ */","+","+let state = null;","+const listeners = new Set();","+","+function notify() {","+\tlisteners.forEach( ( listener ) => listener() );","+}","+","+/**","+ * Registers a new batch of files that have started uploading.","+ *","+ * @param {string[]} filenames Filenames in submission order.","+ */","+export function addFiles( filenames ) {","+\tif ( ! filenames.length ) {","+\t\treturn;","+\t}","+\tif ( ! state ) {","+\t\tstate = { total: 0, completed: 0, pending: [] };","+\t}","+\tstate = {","+\t\ttotal: state.total + filenames.length,","+\t\tcompleted: state.completed,","+\t\tpending: [ ...state.pending, ...filenames ],","+\t};","+\tnotify();","+}","+","+/**","+ * Advances the tracker by a number of finished files (success or error).","+ *","+ * @param {number} count Number of files that finished since the last call.","+ */","+export function advance( count ) {","+\tif ( ! state || count <= 0 ) {","+\t\treturn;","+\t}","+\tconst completed = Math.min( state.total, state.completed + count );","+\tconst pending = state.pending.slice( count );","+\tif ( completed >= state.total ) {","+\t\tstate = null;","+\t} else {","+\t\tstate = { total: state.total, completed, pending };","+\t}","+\tnotify();","+}","+","+/**","+ * Resets the tracker to its empty state.","+ *","+ * Test-only helper: `state` is a module-level singleton, so tests call this in","+ * `beforeEach` to isolate cases from one another. Not used in production -","+ * `advance` clears the state on its own once every file in a batch finishes.","+ */","+export function reset() {","+\tif ( state === null ) {","+\t\treturn;","+\t}","+\tstate = null;","+\tnotify();","+}","+","+/**","+ * Returns the current tracker state, or `null` when idle.","+ *","+ * @return {?{total: number, completed: number, pending: string[]}} Tracker state.","+ */","+export function getState() {","+\treturn state;","+}","+","+function subscribe( listener ) {","+\tlisteners.add( listener );","+\treturn () => {","+\t\tlisteners.delete( listener );","+\t};","+}","+","+/**","+ * React hook that subscribes to the tracker.","+ *","+ * @return {?{total: number, completed: number, pending: string[]}} Tracker state.","+ */","+export function useTracker() {","+\treturn useSyncExternalStore( subscribe, getState, getState );","+}"],"additions":105,"deletions":0,"truncated":false},{"path":"packages/editor/src/private-apis.js","lines":["@@ -29,6 +29,7 @@ import GlobalStylesUIWrapper from './components/global-styles';"," import { StyleBookPreview } from './components/style-book';"," import { useGlobalStyles, useStyle } from './components/global-styles/hooks';"," import { GlobalStylesActionMenu } from './components/global-styles/menu';","+import UploadProgressSnackbar from './components/upload-progress-snackbar';"," "," const { store: interfaceStore, ...remainingInterfaceApis } = interfaceApis;"," ","@@ -48,6 +49,7 @@ lock( privateApis, {"," \tToolsMoreMenuGroup,","