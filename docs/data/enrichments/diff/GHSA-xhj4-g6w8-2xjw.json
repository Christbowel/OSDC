{"id":"GHSA-xhj4-g6w8-2xjw","axis":"advisories","repo":"woven-by-toyota/go-zserio","sha":"39ef1decde7e9766207794d396018776b33c6e45","parsed":{"files":[{"path":"README.md","lines":["@@ -31,6 +31,22 @@ definitions are stored. Supported file extensions are `.zs` and `.zserio`."," `rootpackage` specifies the root package name of the generated Go files."," `output_directory` specifies the path where the Go files will be generated."," ","+## Memory allocation","+","+When reading arrays, strings and bytes (blobs) zserio defaults to not allocate","+more memory than a configurable maximum. This is a safety measure to prevent ","+allocating all memory and entering an out-of-memory state if the input has ","+invalid sizes data. This could happen when dealing with untrusted or corrupted input.","+This behavior can be controlled using environment variables.","+","+| Environment variable | Default | Description |","+| -- | -- | -- |","+| `ZSERIO_MAX_INITIAL_ARRAY_SIZE` | 1000 | Maximum initial capacity for arrays |","+| `ZSERIO_MAX_INITIAL_BLOB_SIZE`  | 102400 (100kB) |  Maximum initial capacity of bytes and strings |","+","+Setting an environment variable to `0` removes the maximum, which can result in","+a small performance gain. This should only be done when the input is trusted.","+"," ## Limitations"," "," - Implicit length arrays are deprecated, and are not supported."],"additions":16,"deletions":0,"truncated":false},{"path":"ztype/array_decode.go","lines":["@@ -1,9 +1,14 @@"," package ztype"," "," import (","+\t\"os\"","+\t\"strconv\"","+"," \tzserio \"github.com/woven-planet/go-zserio\""," )"," ","+var maxInitialArrayCapacityInt = 1000","+"," // UnmarshalZserio reads an array from a bit reader, in either packed or unpacked configuration."," func (array *Array[T, Y]) UnmarshalZserio(reader zserio.Reader) error {"," \tarraySize := array.FixedSize","@@ -16,7 +21,13 @@ func (array *Array[T, Y]) UnmarshalZserio(reader zserio.Reader) error {"," \t\tarraySize = int(u64ReadSize)"," \t}"," ","-\tarray.RawArray = make([]T, 0, arraySize)","+\t// Limit the initial capacity to a reasonable number to avoid excessive memory allocation.","+\t// This is needed in case the input is untrusted could have an overly large value.","+\tif maxInitialArrayCapacityInt == 0 {","+\t\tarray.RawArray = make([]T, 0, arraySize)","+\t} else {","+\t\tarray.RawArray = make([]T, 0, min(arraySize, maxInitialArrayCapacityInt))","+\t}"," "," \tif arraySize > 0 {"," \t\tvar err error","@@ -99,3 +110,14 @@ type checkOffsetMethod[T any, Y IArrayTraits[T]] OffsetMethod"," func (fn checkOffsetMethod[T, Y]) apply(array *Array[T, Y]) {"," \tarray.checkOffsetMethod = OffsetMethod(fn)"," }","+","+func init() {","+\tmaxLengthStr := os.Getenv(\"ZSERIO_MAX_INITIAL_ARRAY_SIZE\")","+\tif maxLengthStr != \"\" {","+\t\tn, err := strconv.ParseUint(maxLengthStr, 10, 32)","+\t\tif err != nil {","+\t\t\tpanic(err)","+\t\t}","+\t\tmaxInitialArrayCapacityInt = int(n)","+\t}","+}"],"additions":23,"deletions":1,"truncated":false},{"path":"ztype/array_decode_test.go","lines":["@@ -2,6 +2,7 @@ package ztype_test"," "," import ("," \t\"bytes\"","+\t\"runtime\""," \t\"testing\""," "," \t\"github.com/google/go-cmp/cmp\"","@@ -9,6 +10,30 @@ import ("," \t\"github.com/woven-planet/go-zserio/ztype\""," )"," ","+func TestArrayDecodeMemoryUsage(t *testing.T) {","+\t// Prepare a buffer with a 4-byte varsize encoding of 100_000_000.","+\tvar buf bytes.Buffer","+\tw := zstream.NewWriter(&buf)","+\tztype.WriteVarsize(w, 100_000_000) // 4 bytes","+\tw.Close()","+","+\t// We now try to read this as an array. This must trigger an error","+\t// because the array size does not match the available data.","+\tvar before, after runtime.MemStats","+\truntime.ReadMemStats(&before)","+\treader := zstream.NewReader(bytes.NewReader(buf.Bytes()))","+\tarray := ztype.Array[uint64, *ztype.VarSizeArrayTraits]{","+\t\tArrayTraits: &ztype.VarSizeArrayTraits{}, IsAuto: true,","+\t}","+\tif err := array.UnmarshalZserio(reader); err == nil {","+\t\tt.Fatalf(\"No EOF error was raised when reading an array with an invalid size\")","+\t}","+\truntime.ReadMemStats(&after)","+\tif after.Alloc > before.Alloc+10_000_000 {","+\t\tt.Errorf(\"unexpectedly high memory usage: before=%d, after=%d\", before.Alloc, after.Alloc)","+\t}","+}","+"," func TestVarintArrayDecoding(t *testing.T) {"," \ttests := map[string]struct {"," \t\tinput     []byte"],"additions":25,"deletions":0,"truncated":false},{"path":"ztype/bytes_decode.go","lines":["@@ -1,28 +1,77 @@"," package ztype"," "," import (","-\t\"errors\"","+\t\"bytes\""," \t\"io\"","+\t\"os\"","+\t\"strconv\""," "," \tzserio \"github.com/woven-planet/go-zserio\""," )"," ","+var maxInitialBytesCapacityInt uint64 = 1024 * 100 // 100KB","+"," // ReadBytes reads an zserio bytes type (variable size byte buffer) from a reader."," func ReadBytes(r zserio.Reader) (*BytesType, error) {","-\tvar err error","-\tb := &BytesType{}","-\tb.ByteSize, err = ReadVarsize(r)","+\tbyteSize, data, err := safeReadBytes(r)"," \tif err != nil {"," \t\treturn nil, err"," \t}"," ","-\tb.Buffer = make([]byte, b.ByteSize)","-\tn, err := io.ReadFull(r, b.Buffer)","+\treturn &BytesType{","+\t\tByteSize: byteSize,","+\t\tBuffer:   data,","+\t}, nil","+}","+","+func safeReadBytes(r zserio.Reader) (uint64, []byte, error) {","+\tbyteSize, err := ReadVarsize(r)"," \tif err != nil {","-\t\treturn nil, err","+\t\treturn 0, nil, err"," \t}","-\tif n != int(b.ByteSize) {","-\t\treturn nil, errors.New(\"read number of bytes didn't match\")","+","+\t// For small blobs that fit under our capacity limit we can directly read into","+\t// a buffer and return the result.","+\tif maxInitialBytesCapacityInt == 0 || byteSize <= maxInitialBytesCapacityInt {","+\t\tbuf := make([]byte, byteSize)","+\t\tif _, err = io.ReadFull(r, buf); err != nil {","+\t\t\treturn 0, nil, err","+\t\t}","+\t\treturn byteSize, buf, nil","+\t}","+","+\t// For larger blobs where we do not know for sure the claimed size is correct we","+\t// read data in chunks of maxInitialBytesCapacityInt until we have read all data","+\t// or hit an error.","+\tblobSize := int64(byteSize)","+\treader := io.LimitReader(r, blobSize)","+","+\toutput := bytes.NewBuffer(make([]byte, 0, min(byteSize, maxInitialBytesCapacityInt)))","+\tbuf := make([]byte, maxInitialBytesCapacityInt)","+","+\tremaining := blobSize","+\tvar written int64","+\tfor remaining > 0 && err == nil {","+\t\twritten, err = io.CopyBuffer(output, reader, buf)","+\t\tif err != nil {","+\t\t\treturn 0, nil, err","+\t\t}","+\t\tif written == 0 {","+\t\t\treturn 0, nil, io.ErrUnexpectedEOF","+\t\t}","+\t\tremaining -= written","+\t}","+","+\treturn byteSize, output.Bytes(), nil","+}","+","+func init() {","+\tmaxLengthStr := os.Getenv(\"ZSERIO_MAX_INITIAL_BLOB_SIZE\")","+\tif maxLengthStr != \"\" {","+\t\tn, err := strconv.ParseUint(maxLengthStr, 10, 64)","+\t\tif err != nil {","+\t\t\tpanic(err)","+\t\t}","+\t\tmaxInitialBytesCapacityInt = n"," \t}","-\treturn b, nil"," }"],"additions":59,"deletions":10,"truncated":false},{"path":"ztype/bytes_decode_test.go","lines":["@@ -0,0 +1,33 @@","+package ztype_test","+","+import (","+\t\"bytes\"","+\t\"io\"","+\t\"runtime\"","+\t\"testing\"","+","+\t\"github.com/woven-planet/go-zserio/zstream\"","+\t\"github.com/woven-planet/go-zserio/ztype\"","+)","+","+func TestReadBytesMemoryUsage(t *testing.T) {","+\t// Prepare a buffer with a 4-byte varsize encoding of 100_000_000.","+\tvar buf bytes.Buffer","+\tw := zstream.NewWriter(&buf)","+\tztype.WriteVarsize(w, 100_000_000) // 4 bytes","+\tztype.WriteBool(w, true)","+\tw.Close()","+","+\t// We now try to read this as a bytes type. This must trigger an error","+\t// because the array size does not match the available data.","+\tvar before, after runtime.MemStats","+\truntime.ReadMemStats(&before)","+\treader := zstream.NewReader(bytes.NewReader(buf.Bytes()))","+\tif _, err := ztype.ReadBytes(reader); err != io.ErrUnexpectedEOF {","+\t\tt.Fatalf(\"No EOF error was raised when reading a bytes type with an invalid size: %v\", err)","+\t}","+\truntime.ReadMemStats(&after)","+\tif after.Alloc > before.Alloc+10_000_000 {","+\t\tt.Errorf(\"unexpectedly high memory usage: before=%d, after=%d\", before.Alloc, after.Alloc)","+\t}","+}"],"additions":33,"deletions":0,"truncated":false},{"path":"ztype/string_decode.go","lines":["@@ -1,20 +1,13 @@"," package ztype"," "," import (","-\t\"io\"","-"," \tzserio \"github.com/woven-planet/go-zserio\""," )"," ","+var maxInitialStringCapacityInt uint64 = 4096","+"," // ReadString reads a string from the bitstream."," func ReadString(r zserio.Reader) (string, error) {","-\tsize, err := ReadVarsize(r)","-\tif err != nil {","-\t\treturn \"\", err","-\t}","-\tbuf := make([]byte, size)","-\tif _, err = io.ReadFull(r, buf); err != nil {","-\t\treturn \"\", err","-\t}","-\treturn string(buf), nil","+\t_, data, err := safeReadBytes(r)","+\treturn string(data), err"," }"],"additions":4,"deletions":11,"truncated":false},{"path":"ztype/string_decode_test.go","lines":["@@ -2,6 +2,8 @@ package ztype_test"," "," import ("," \t\"bytes\"","+\t\"io\"","+\t\"runtime\""," \t\"testing\""," "," \t\"github.com/google/go-cmp/cmp\"","@@ -9,6 +11,28 @@ import ("," \t\"github.com/woven-planet/go-zserio/ztype\""," )"," ","+func TestReadStringMemoryUsage(t *testing.T) {","+\t// Prepare a buffer with a 4-byte varsize encoding of 100_000_000.","+\tvar buf bytes.Buffer","+\tw := zstream.NewWriter(&buf)","+\tztype.WriteVarsize(w, 100_000_000) // 4 bytes","+\tztype.WriteBool(w, true)","+\tw.Close()","+","+\t// We now try to read this as a string. This must trigger an error","+\t// because the array size does not match the available data.","+\tvar before, after runtime.MemStats","+\truntime.ReadMemStats(&before)","+\treader := zstream.NewReader(bytes.NewReader(buf.Bytes()))","+\tif _, err := ztype.ReadString(reader); err != io.ErrUnexpectedEOF {","+\t\tt.Fatalf(\"No EOF error was raised when reading a string with an invalid siz