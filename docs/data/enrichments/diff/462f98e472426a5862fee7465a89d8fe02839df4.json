","+            it('custom uploaded favicon.ico', function (done) {","+                storage.getStorage().storagePath = path.join(__dirname, '../../../../utils/fixtures/images/');","+                localSettingsCache.icon = '/content/images/favicon.ico';","+","+                request(blogApp)","+                    .get('/favicon.ico')","+                    .expect(302)","+                    .expect('Location', '/content/images/favicon.ico')","+                    .end(done);","+            });","+","+            it('to favicon.ico when favicon.png is requested', function (done) {","+                configUtils.set('paths:publicFilePath', path.join(__dirname, '../../../../test/utils/fixtures/'));","+                localSettingsCache.icon = null;","+","+                request(blogApp)","+                    .get('/favicon.png')","+                    .expect(302)","+                    .expect('Location', '/favicon.ico')","+                    .end(done);","+            });","+        });","+    });","+});",""],"additions":94,"deletions":0,"truncated":false}],"additions":152,"deletions":221,"truncated":false,"file_count":6},"error":null,"fetched_at":"2026-05-21T04:46:48.022813+00:00"}