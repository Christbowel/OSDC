lt;","+\tresult.type = \"transaction_secret_type\";","+\tresult.provider = \"config\";","+\tresult.name = Identifier(name);","+\tresult.scope = {scope};","+\tresult.on_conflict = on_conflict;","+\tresult.persist_type = SecretPersistType::TRANSACTION;","+\treturn result;","+}","+","+TEST_CASE(\"Transaction secrets are isolated and cleaned up\", \"[secret]\") {","+\tDuckDB db(nullptr);","+\tConnection owner(db);","+\tConnection other(db);","+\tDemoSecretType::RegisterDemoSecret(*db.instance, \"transaction_secret_type\");","+","+\tREQUIRE_NO_FAIL(owner.Query(\"CREATE SECRET global_secret (TYPE transaction_secret_type, SCOPE 's3://bucket')\"));","+\tauto &secret_manager = SecretManager::Get(*db.instance);","+","+\tREQUIRE_NO_FAIL(owner.Query(\"BEGIN TRANSACTION READ ONLY\"));","+\tauto input = TransactionSecretInput(\"transaction_secret\", \"s3://bucket\");","+\tauto created_secret = secret_manager.CreateSecret(*owner.context, input);","+\tREQUIRE(created_secret);","+\tREQUIRE(created_secret->persist_type == SecretPersistType::TRANSACTION);","+\tREQUIRE(created_secret->storage_mode == SecretManager::TRANSACTION_STORAGE_NAME);","+","+\tauto owner_transaction = CatalogTransaction::GetSystemCatalogTransaction(*owner.context);","+\tauto owner_match =","+\t    secret_manager.LookupSecret(owner_transaction, \"s3://bucket/data.parquet\", \"transaction_secret_type\");","+\tREQUIRE(owner_match.HasMatch());","+\tREQUIRE(owner_match.GetSecret().GetName() == \"transaction_secret\");","+\tREQUIRE(secret_manager.GetSecretByName(owner_transaction, \"transaction_secret\"));","+","+\tauto all_secrets = secret_manager.AllSecrets(owner_transaction);","+\tREQUIRE(std::any_of(all_secrets.begin(), all_secrets.end(),","+\t                    [](const SecretEntry &entry) { return entry.secret->GetName() == \"transaction_secret\"; }));","+","+\tother.BeginTransaction();","+\tauto other_transaction = CatalogTransaction::GetSystemCatalogTransaction(*other.context);","+\tREQUIRE(!secret_manager.GetSecretByName(other_transaction, \"transaction_secret\"));","+\tauto other_match =","+\t    secret_manager.LookupSecret(other_transaction, \"s3://bucket/data.parquet\", \"transaction_secret_type\");","+\tREQUIRE(other_match.HasMatch());","+\tREQUIRE(other_match.GetSecret().GetName() == \"global_secret\");","+\tother.Rollback();","+","+\towner.Commit();","+\towner.BeginTransaction();","+\towner_transaction = CatalogTransaction::GetSystemCatalogTransaction(*owner.context);","+\tREQUIRE(!secret_manager.GetSecretByName(owner_transaction, \"transaction_secret\"));","+\towner_match = secret_manager.LookupSecret(owner_transaction, \"s3://bucket/data.parquet\", \"transaction_secret_type\");","+\tREQUIRE(owner_match.HasMatch());","+\tREQUIRE(owner_match.GetSecret().GetName() == \"global_secret\");","+","+\tauto rollback_input = TransactionSecretInput(\"rollback_secret\", \"s3://rollback\");","+\tREQUIRE(secret_manager.CreateSecret(*owner.context, rollback_input));","+\towner.Rollback();","+\towner.BeginTransaction();","+\towner_transaction = CatalogTransaction::GetSystemCatalogTransaction(*owner.context);","+\tREQUIRE(!secret_manager.GetSecretByName(owner_transaction, \"rollback_secret\"));","+\towner.Rollback();","+}","+","+TEST_CASE(\"Transaction secret validation and conflicts\", \"[secret]\") {","+\tDuckDB db(nullptr);","+\tConnection con(db);","+\tDemoSecretType::RegisterDemoSecret(*db.instance, \"transaction_secret_type\");","+\tauto &secret_manager = SecretManager::Get(*db.instance);","+","+\tcon.BeginTransaction();","+\tauto input = TransactionSecretInput(\"conflicting_secret\", \"s3://original\");","+\tauto transaction = CatalogTransaction::GetSystemCatalogTransaction(*con.context);","+\tREQUIRE_THROWS(secret_manager.BindCreateSecret(transaction, input));","+\tREQUIRE(secret_manager.CreateSecret(*con.context, input));","+\tREQUIRE_THROWS(secret_manager.CreateSecret(*con.context, input));","+","+\tinput.on_conflict = OnCreateConflict::IGNORE_ON_CONFLICT;","+\tREQUIRE(!secret_manager.CreateSecret(*con.context, input));","+","+\tinput.on_conflict = OnCreateConflict::REPLACE_ON_CONFLICT;","+\tinput.scope = {\"s3://replacement\"};","+\tREQUIRE(secret_manager.CreateSecret(*con.context, input));","+\tauto stored_secret = secret_manager.GetSecretByName(transaction, \"conflicting_secret\");","+\tREQUIRE(stored_secret);","+\tREQUIRE(stored_secret->secret->GetScope()[0] == \"s3://replacement\");","+","+\tsecret_manager.DropSecretByName(transaction, \"conflicting_secret\", OnEntryNotFound::THROW_EXCEPTION,","+\t                                SecretPersistType::TRANSACTION);","+\tREQUIRE(!secret_manager.GetSecretByName(transaction, \"conflicting_secret\"));","+","+\tinput.name = \"explicit_storage\";","+\tinput.storage_type = SecretManager::TEMPORARY_STORAGE_NAME;","+\tREQUIRE_THROWS(secret_manager.CreateSecret(*con.context, input));","+\tcon.Rollback();","+","+\tinput.storage_type = \"\";","+\tauto secret = DemoSecretType::CreateDemoSecret(*con.context, input);","+\tauto system_transaction = CatalogTransaction::GetSystemTransaction(*db.instance);","+\tREQUIRE_THROWS(secret_manager.RegisterSecret(system_transaction, std::move(secret),","+\t                                             OnCreateConflict::ERROR_ON_CONFLICT, SecretPersistType::TRANSACTION));","+}"],"additions":105,"deletions":0,"truncated":false},{"path":"test/sql/secrets/create_transaction_secret.test","lines":["@@ -0,0 +1,13 @@","+# name: test/sql/secrets/create_transaction_secret.test","+# description: Ensure transaction-scoped secrets cannot be created through SQL","+# group: [secrets]","+","+statement error","+CREATE TRANSACTION SECRET transaction_secret (TYPE HTTP);","+----","+<REGEX>:.*Parser Error.*syntax error.*","+","+statement error","+CREATE SECRET transaction_secret IN transaction (TYPE HTTP);","+----","+Binder Error: Transaction-scoped secrets cannot be created through SQL",""],"additions":13,"deletions":0,"truncated":false}],"additions":316,"deletions":10,"trunc