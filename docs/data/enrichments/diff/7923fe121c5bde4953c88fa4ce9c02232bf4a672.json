+\t\t{","+\t\t\tname:        \"auth enabled ignores no_auth_tenant\",","+\t\t\tauthEnabled: true,","+\t\t\ttenant:      \"\",","+\t\t\twantErr:     false,","+\t\t},","+\t}","+","+\tfor _, tt := range tests {","+\t\tt.Run(tt.name, func(t *testing.T) {","+\t\t\tcfg := Config{}","+\t\t\tf := flag.NewFlagSet(\"test\", flag.PanicOnError)","+\t\t\tcfg.RegisterFlags(f)","+\t\t\tcfg.AuthEnabled = tt.authEnabled","+\t\t\tcfg.NoAuthTenant = tt.tenant","+","+\t\t\terr := cfg.validateNoAuthTenant()","+\t\t\tif tt.wantErr {","+\t\t\t\trequire.Error(t, err)","+\t\t\t\trequire.Contains(t, err.Error(), \"no_auth_tenant\")","+\t\t\t} else {","+\t\t\t\trequire.NoError(t, err)","+\t\t\t}","+\t\t})","+\t}","+}"],"additions":66,"deletions":0,"truncated":false},{"path":"pkg/loki/modules.go","lines":["@@ -211,7 +211,7 @@ func (t *Loki) initServer() (services.Service, error) {"," \th := func(next http.Handler) http.Handler {"," \t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {"," \t\t\tif !t.Cfg.AuthEnabled {","-\t\t\t\tnext.ServeHTTP(w, r.WithContext(user.InjectOrgID(r.Context(), \"fake\")))","+\t\t\t\tnext.ServeHTTP(w, r.WithContext(user.InjectOrgID(r.Context(), t.Cfg.NoAuthTenant)))"," \t\t\t\treturn"," \t\t\t}"," "],"additions":1,"deletions":1,"truncated":false},{"path":"pkg/querytee/goldfish/manager.go","lines":["@@ -522,7 +522,7 @@ func CaptureResponse(resp *http.Response, duration time.Duration, traceID, spanI"," func extractTenant(r *http.Request) string {"," \ttenant := r.Header.Get(\"X-Scope-OrgID\")"," \tif tenant == \"\" {","-\t\treturn \"fake\"","+\t\treturn unknown"," \t}"," \treturn tenant"," }"],"additions":1,"deletions":1,"truncated":false},{"path":"pkg/util/fakeauth/fake_auth.go","lines":["@@ -1,5 +1,5 @@","-// Package fakeauth provides middlewares thats injects a fake userID, so the rest of the code","-// can continue to be multitenant.","+// Package fakeauth provides middlewares that inject a tenant ID so the rest of","+// the code can continue to be multi-tenant even when auth is disabled."," package fakeauth"," "," import (","@@ -12,8 +12,10 @@ import ("," \t\"google.golang.org/grpc\""," )"," ","-// SetupAuthMiddleware for the given server config.","-func SetupAuthMiddleware(config *server.Config, enabled bool, noGRPCAuthOn []string) middleware.Interface {","+// SetupAuthMiddleware configures auth middleware for the given server config.","+// When enabled is false, noAuthTenant is injected as the org ID into every","+// request so downstream code can assume a tenant is always present.","+func SetupAuthMiddleware(config *server.Config, enabled bool, noGRPCAuthOn []string, noAuthTenant string) middleware.Interface {"," \tif enabled {"," \t\tignoredMethods := map[string]bool{}"," \t\tfor _, m := range noGRPCAuthOn {","@@ -40,31 +42,25 @@ func SetupAuthMiddleware(config *server.Config, enabled bool, noGRPCAuthOn []str"," \t}"," "," \tconfig.GRPCMiddleware = append(config.GRPCMiddleware,","-\t\tfakeGRPCAuthUniaryMiddleware,","+\t\tfunc(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {","+\t\t\tctx = user.InjectOrgID(ctx, noAuthTenant)","+\t\t\treturn handler(ctx, req)","+\t\t},"," \t)"," \tconfig.GRPCStreamMiddleware = append(config.GRPCStreamMiddleware,","-\t\tfakeGRPCAuthStreamMiddleware,","+\t\tfunc(srv interface{}, ss grpc.ServerStream, _ *grpc.StreamServerInfo, handler grpc.StreamHandler) error {","+\t\t\tctx := user.InjectOrgID(ss.Context(), noAuthTenant)","+\t\t\treturn handler(srv, serverStream{","+\t\t\t\tctx:          ctx,","+\t\t\t\tServerStream: ss,","+\t\t\t})","+\t\t},"," \t)","-\treturn fakeHTTPAuthMiddleware","-}","-","-var fakeHTTPAuthMiddleware = middleware.Func(func(next http.Handler) http.Handler {","-\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","-\t\tctx := user.InjectOrgID(r.Context(), \"fake\")","-\t\tnext.ServeHTTP(w, r.WithContext(ctx))","-\t})","-})","-","-var fakeGRPCAuthUniaryMiddleware = func(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {","-\tctx = user.InjectOrgID(ctx, \"fake\")","-\treturn handler(ctx, req)","-}","-","-var fakeGRPCAuthStreamMiddleware = func(srv interface{}, ss grpc.ServerStream, _ *grpc.StreamServerInfo, handler grpc.StreamHandler) error {","-\tctx := user.InjectOrgID(ss.Context(), \"fake\")","-\treturn handler(srv, serverStream{","-\t\tctx:          ctx,","-\t\tServerStream: ss,","+\treturn middleware.Func(func(next http.Handler) http.Handler {","+\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\t\tctx := user.InjectOrgID(r.Context(), noAuthTenant)","+\t\t\tnext.ServeHTTP(w, r.WithContext(ctx))","+\t\t})"," \t})"," }"," "],"additions":22,"deletions":26,"truncated":false},{"path":"pkg/util/fakeauth/fake_auth_test.go","lines":["@@ -0,0 +1,65 @@","+package fakeauth","+","+import (","+\t\"context\"","+\t\"net/http\"","+\t\"net/http/httptest\"","+\t\"testing\"","+","+\t\"github.com/grafana/dskit/server\"","+\t\"github.com/grafana/dskit/user\"","+\t\"github.com/stretchr/testify/require\"","+\t\"google.golang.org/grpc\"","+)","+","+func TestSetupAuthMiddlewareDisabled(t *testing.T) {","+\ttenants := []string{\"fake\", \"anonymous\", \"my-org\"}","+","+\tfor _, tenant := range tenants {","+\t\tt.Run(tenant, func(t *testing.T) {","+\t\t\tcfg := &server.Config{}","+\t\t\tvar got string","+","+\t\t\tnext := http.HandlerFunc(func(_ http.ResponseWriter, r *http.Request) {","+\t\t\t\tid, err := user.ExtractOrgID(r.Context())","+\t\t\t\trequire.NoError(t, err)","+\t\t\t\tgot = id","+\t\t\t})","+","+\t\t\tmw := SetupAuthMiddleware(cfg, false, nil, tenant)","+\t\t\treq := httptest.NewRequest(http.MethodGet, \"/\", nil)","+\t\t\tmw.Wrap(next).ServeHTTP(httptest.NewRecorder(), req)","+","+\t\t\trequire.Equal(t, tenant, got)","+\t\t})","+\t}","+}","+","+func TestSetupAuthMiddlewareEnabled(t *testing.T) {","+\tcfg := &server.Config{}","+","+\t// When auth is enabled the returned middleware is middleware.AuthenticateUser.","+\t// We just verify the gRPC interceptor slots were populated correctly.","+\tmw := SetupAuthMiddleware(cfg, true, []string{\"/some.Service/Method\"}, \"unused\")","+\trequire.NotNil(t, mw)","+\trequire.Len(t, cfg.GRPCMiddleware, 1)","+\trequire.Len(t, cfg.GRPCStreamMiddleware, 1)","+}","+","+func TestSetupAuthMiddlewareGRPCUnary(t *testing.T) {","+\tcfg := &server.Config{}","+\tSetupAuthMiddleware(cfg, false, nil, \"my-tenant\")","+\trequire.Len(t, cfg.GRPCMiddleware, 1)","+","+\tvar gotTenant string","+\thandler := func(ctx context.Context, _ interface{}) (interface{}, error) {","+\t\tid, err := user.ExtractOrgID(ctx)","+\t\trequire.NoError(t, err)","+\t\tgotTenant = id","+\t\treturn nil, nil","+\t}","+","+\t_, err := cfg.GRPCMiddleware[0](context.Background(), nil, &grpc.UnaryServerInfo{}, handler)","+\trequire.NoError(t, err)","+\trequire.Equal(t, \"my-tenant\", gotTenant)","+}",""],"additions":65,"deletions":0,"truncated":false}],"additions":197,"deletions":34,"truncated":false,"file_count":9},"error":null,"fetched_at":"2026-07-14T09:32:14.940098+00:00"}