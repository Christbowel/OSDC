e as ballast in order to"," # optimize garbage collection. Larger ballasts result in fewer garbage"," # collection passes, reducing CPU overhead at the cost of heap size. The ballast"],"additions":8,"deletions":1,"truncated":false},{"path":"pkg/distributor/ratestore.go","lines":["@@ -30,6 +30,11 @@ const ("," \t// A larger factor weights recent samples more heavily while a smaller"," \t// factor weights historic samples more heavily."," \tsmoothingFactor = .4","+","+\t// defaultLimitsTenant is a sentinel used to probe global/default limits when","+\t// AllByUserID returns nil (no per-tenant overrides are configured). The value","+\t// has no storage impact; any string would return the same result.","+\tdefaultLimitsTenant = \"fake\""," )"," "," type RateStoreConfig struct {","@@ -220,8 +225,8 @@ func (s *rateStore) wasUpdated(tenantID string, streamID uint64, lastUpdated map"," func (s *rateStore) anyShardingEnabled() bool {"," \tlimits := s.limits.AllByUserID()"," \tif len(limits) == 0 {","-\t\t// There aren't any tenant limits, check the default","-\t\treturn s.limits.ShardStreams(\"fake\").Enabled","+\t\t// No per-tenant overrides; check the global default.","+\t\treturn s.limits.ShardStreams(defaultLimitsTenant).Enabled"," \t}"," "," \tfor user := range limits {"],"additions":7,"deletions":2,"truncated":false},{"path":"pkg/loki/loki.go","lines":["@@ -9,6 +9,7 @@ import ("," \t\"net/http\""," \t\"os\""," \trt \"runtime\"","+\t\"strings\""," \t\"time\""," "," \t\"github.com/fatih/color\"","@@ -89,6 +90,7 @@ type Config struct {"," \tTarget       flagext.StringSliceCSV `yaml:\"target,omitempty\"`"," \tAuthEnabled  bool                   `yaml:\"auth_enabled,omitempty\"`"," \tLBAC         labelaccess.Config     `yaml:\"lbac,omitempty\" category:\"experimental\"`","+\tNoAuthTenant string                 `yaml:\"no_auth_tenant,omitempty\"`"," \tHTTPPrefix   string                 `yaml:\"http_prefix\" doc:\"hidden\"`"," \tBallastBytes int                    `yaml:\"ba