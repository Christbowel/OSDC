{"id":"7422e06ada979320fbd4551013b9924f3f2a0f25","axis":"silent","repo":"microsoft/vscode","sha":"7422e06ada979320fbd4551013b9924f3f2a0f25","parsed":{"files":[{"path":"extensions/copilot/package.json","lines":["@@ -151,6 +151,21 @@","     \"toolInvocationApproveCombination\",","     \"chatSessionCustomizationProvider\"","   ],","+  \"capabilities\": {","+    \"untrustedWorkspaces\": {","+      \"supported\": \"limited\",","+      \"description\": \"%workspaceTrust%\",","+      \"restrictedConfigurations\": [","+        \"github.copilot.chat.otel.enabled\",","+        \"github.copilot.chat.otel.exporterType\",","+        \"github.copilot.chat.otel.otlpEndpoint\",","+        \"github.copilot.chat.otel.captureContent\",","+        \"github.copilot.chat.otel.maxAttributeSizeChars\",","+        \"github.copilot.chat.otel.outfile\",","+        \"github.copilot.chat.otel.dbSpanExporter.enabled\"","+      ]","+    }","+  },","   \"contributes\": {","     \"languageModelTools\": [","       {","@@ -2854,6 +2869,18 @@","         \"category\": \"Chat\",","         \"enablement\": \"config.github.copilot.chat.otel.dbSpanExporter.enabled\"","       },","+      {","+        \"command\": \"github.copilot.chat.otel.statusActive\",","+        \"title\": \"OpenTelemetry\",","+        \"category\": \"Chat\",","+        \"icon\": \"$(broadcast)\"","+      },","+      {","+        \"command\": \"github.copilot.chat.otel.statusCapturing\",","+        \"title\": \"OpenTelemetry\",","+        \"category\": \"Chat\",","+        \"icon\": \"$(eye)\"","+      },","       {","         \"command\": \"github.copilot.sessionSync.deleteSessions\",","         \"title\": \"%github.copilot.command.sessionSync.deleteSessions%\",","@@ -5546,7 +5573,27 @@","           \"group\": \"inline@2\"","         }","       ],","+      \"chat/input/status\": [","+        {","+          \"command\": \"github.copilot.chat.otel.statusActive\",","+          \"when\": \"github.copilot.otel.state == 'active'\",","+      