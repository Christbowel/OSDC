als via","+\t * `environmentVariableCollection`, so terminals opened before the SDK","+\t * boots still see user-controlled values.","+\t */","+\tprivate _configureTerminalEnv(): void {","+\t\tconst collection = this._extensionContext.environmentVariableCollection;","+\t\tconst otelKeys = [","+\t\t\t'COPILOT_OTEL_ENABLED',","+\t\t\t'OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT',","+\t\t\t'OTEL_EXPORTER_OTLP_ENDPOINT',","+\t\t\t'COPILOT_OTEL_ENDPOINT',","+\t\t\t'COPILOT_OTEL_EXPORTER_TYPE',","+\t\t\t'COPILOT_OTEL_FILE_EXPORTER_PATH',","+\t\t];","+\t\t// Clear prior overrides before re-applying.","+\t\tfor (const key of otelKeys) {","+\t\t\tcollection.delete(key);","+\t\t}","+","+\t\tconst config = this._otelService.config;","+\t\tif (!config.enabledExplicitly) {","+\t\t\treturn;","+\t\t}","+","+\t\tcollection.replace('COPILOT_OTEL_ENABLED', 'true');","+\t\tif (config.otlpEndpoint) {","+\t\t\tcollection.replace('OTEL_EXPORTER_OTLP_ENDPOINT', config.otlpEndpoint);","+\t\t}","+\t\tcollection.replace('OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT', String(config.captureContent));","+\t}","+","+\tprivate _registerOpenSettingsCommand(): void {","+\t\tthis._register(vscode.commands.registerCommand(OPEN_OTEL_SETTINGS_COMMAND, async () => {","+\t\t\tawait this._openOTelSettingsAtEffectiveScope();","+\t\t}));","+\t}","+","+\t/**","+\t * Open Settings at the deepest scope where any OTel setting is configured","+\t * (folder → workspace → user). Writing at the wrong scope would not","+\t * override a value pinned in workspace settings.","+\t */","+\tprivate async _openOTelSettingsAtEffectiveScope(): Promise<void> {","+\t\tconst query = 'github.copilot.chat.otel';","+\t\t// Probe across multiple OTel settings, not just captureContent: any of","+\t\t// them may pin scope while captureContent stays at default.","+\t\tconst probeSettings = [","+\t\t\tConfigKey.Advanced.OTelCaptureContent.fullyQualifiedId,","+\t\t\tConfigKey.Advanced.OTelEnabled.fullyQualifiedId,","+\t\t\t