{"id":"7bd1b318b9dfb8664ad260ade020a1cee53c1838","axis":"silent","repo":"directus/directus","sha":"7bd1b318b9dfb8664ad260ade020a1cee53c1838","parsed":{"files":[{"path":".changeset/fix-license-modal-dismiss.md","lines":["@@ -0,0 +1,5 @@","+---","+'@directus/app': patch","+---","+","+Fixed license modals being impossible to dismiss when shown above a route drawer (e.g. field detail pages) by keeping dialog focus traps stacked in visual order, and scoped license dismissal cookies to the whole app so dismissals persist across navigation"],"additions":5,"deletions":0,"truncated":false},{"path":"app/src/auth.ts","lines":["@@ -73,8 +73,8 @@ export async function login({ credentials, provider, share }: LoginParams): Prom"," \t}"," "," \tappStore.accessTokenExpiry = Date.now() + (response.expires ?? 0);","-\tcookies.remove('license-banner-dismissed');","-\tcookies.remove('license-login-modal-dismissed');","+\tcookies.remove('license-banner-dismissed', { path: '/' });","+\tcookies.remove('license-login-modal-dismissed', { path: '/' });"," \tappStore.authenticated = true;"," "," \t// Reload server store to get authenticated data"],"additions":2,"deletions":2,"truncated":false},{"path":"app/src/components/v-dialog.vue","lines":["@@ -1,11 +1,16 @@"," <script setup lang=\"ts\">"," import { useShortcut } from '@directus/composables';"," import { useFocusTrap } from '@vueuse/integrations/useFocusTrap';","-import { computed, nextTick, ref, useTemplateRef, watch } from 'vue';","+import { computed, nextTick, onScopeDispose, ref, useTemplateRef, watch } from 'vue';"," import TransitionDialog from '@/components/transition/dialog.vue';"," import VOverlay from '@/components/v-overlay.vue';"," import { useDialogRouteLeave } from '@/composables/use-dialog-route';","-import { useFocusTrapManager } from '@/composables/use-focus-trap-manager';","+import {","+\ttype DialogTrapHandle,","+\tregisterDialogTrap,","+\tunregisterDialogTrap,","+\tuseFocusTrapManager,","+} from '@/composables/use-focus-trap-manager';"," "," export type ApplyShortcut = 'meta+enter' | 'meta+s';"," ","@@ -95,6 +100,22 @@ function useOverlayFocusTrap() {"," "," \taddFocusTrap(focusTrap);"," ","+\tconst trapHandle: DialogTrapHandle = {","+\t\t// mirrors the z-index stacking of the dialog placements in the styles below","+\t\tget zRank() {","+\t\t\tif (props.placement === 'center') return props.keepBehind ? 500 : 600;","+\t\t\treturn props.keepBehind ? 490 : 500;","+\t\t},","+\t\treassert() {","+\t\t\tconst focused = document.activeElement;","+","+\t\t\tfocusTrap.deactivate({ returnFocus: false });","+\t\t\tfocusTrap.activate();","+","+\t\t\tif (focused instanceof HTMLElement && overlayEl.value?.contains(focused)) focused.focus();","+\t\t},","+\t};","+"," \twatch("," \t\tinternalActive,"," \t\t(newActive) => {","@@ -110,11 +131,18 @@ function useOverlayFocusTrap() {"," \t\tasync (newActive) => {"," \t\t\tawait nextTick();"," ","-\t\t\tif (newActive) focusTrap.activate();","-\t\t\telse focusTrap.deactivate();","+\t\t\tif (newActive) {","+\t\t\t\tfocusTrap.activate();","+\t\t\t\tregisterDialogTrap(trapHandle);","+\t\t\t} else {","+\t\t\t\tunregisterDialogTrap(trapHandle);","+\t\t\t\tfocusTrap.deactivate();","+\t\t\t}"," \t\t},"," \t\t{ immediate: true },"," \t);","+","+\tonScopeDispose(() => unregisterDialogTrap(trapHandle));"," }"," </script>"," "],"additions":32,"deletions":4,"truncated":false},{"path":"app/src/composables/use-focus-trap-manager.test.ts","lines":["@@ -0,0 +1,95 @@","+import { describe, expect, it, vi } from 'vitest';","+import { type DialogTrapHandle, registerDialogTrap, unregisterDialogTrap } from './use-focus-trap-manager';","+","+function makeHandle(zRank: number): DialogTrapHandle & { reassert: ReturnType<typeof vi.fn> } {","+\treturn { zRank, reassert: vi.fn() };","+}","+","+describe('registerDialogTrap', () => {","+\tit('does not reassert when the new trap has the highest rank', () => {","+\t\tconst drawer = makeHandle(500);","+\t\tconst modal = makeHandle(600);","+","+\t\tregisterDialogTrap(drawer);","+\t\tregisterDialogTrap(modal);","+","+\t\texpect(drawer.reassert).not.toHaveBeenCalled();","+\t\texpect(modal.reassert).not.toHaveBeenCalled();","+","+\t\tunregisterDialogTrap(drawer);","+\t\tunregisterDialogTrap(modal);","+\t});","+","+\tit('reasserts an active center modal when a drawer activates after it', () => {","+\t\t// customer scenario: license modal already open, route drawer (field detail) mounts after","+\t\tconst modal = makeHandle(600);","+\t\tconst drawer = makeHandle(500);","+","+\t\tregisterDialogTrap(modal);","+\t\tregisterDialogTrap(drawer);","+","+\t\texpect(modal.reassert).toHaveBeenCalledOnce();","+\t\texpect(drawer.reassert).not.toHaveBeenCalled();","+","+\t\tunregisterDialogTrap(modal);","+\t\tunregisterDialogTrap(drawer);","+\t});","+","+\tit('lets the most recently activated trap win ties', () => {","+\t\tconst drawerOne = makeHandle(500);","+\t\tconst drawerTwo = makeHandle(500);","+","+\t\tregisterDialogTrap(drawerOne);","+\t\tregisterDialogTrap(drawerTwo);","+","+\t\texpect(drawerOne.reassert).not.toHaveBeenCalled();","+\t\texpect(drawerTwo.reassert).not.toHaveBeenCalled();","+","+\t\tunregisterDialogTrap(drawerOne);","+\t\tunregisterDialogTrap(drawerTwo);","+\t});","+","+\tit('reasserts the most recently activated of multiple higher-ranked traps', () => {","+\t\tconst modalOne = makeHandle(600);","+\t\tconst modalTwo = makeHandle(600);","+\t\tconst drawer = makeHandle(500);","+","+\t\tregisterDialogTrap(modalOne);","+\t\tregisterDialogTrap(modalTwo);","+\t\tregisterDialogTrap(drawer);","+","+\t\texpect(modalOne.reassert).not.toHaveBeenCalled();","+\t\texpect(modalTwo.reassert).toHaveBeenCalledOnce();","+","+\t\tunregisterDialogTrap(modalOne);","+\t\tunregisterDialogTrap(modalTwo);","+\t\tunregisterDialogTrap(drawer);","+\t});","+","+\tit('keeps keep-behind center dialogs below regular drawers', () => {","+\t\tconst keepBehindModal = makeHandle(500);","+\t\tconst drawer = makeHandle(500);","+","+\t\tregisterDialogTrap(keepBehindModal);","+\t\tregisterDialogTrap(drawer);","+","+\t\t// equal rank: drawer activated later, stays on top","+\t\texpect(keepBehindModal.reassert).not.toHaveBeenCalled();","+","+\t\tunregisterDialogTrap(keepBehindModal);","+\t\tunregisterDialogTrap(drawer);","+\t});","+","+\tit('does not reassert unregistered traps', () => {","+\t\tconst modal = makeHandle(600);","+\t\tconst drawer = makeHandle(500);","+","+\t\tregisterDialogTrap(modal);","+\t\tunregisterDialogTrap(modal);","+\t\tregisterDialogTrap(drawer);","+","+\t\texpect(modal.reassert).not.toHaveBeenCalled();","+","+\t\tunregisterDialogTrap(drawer);","+\t});","+});"],"additions":95,"deletions":0,"truncated":false},{"path":"app/src/composables/use-focus-trap-manager.ts","lines":["@@ -29,3 +29,35 @@ export function useInjectFocusTrapManager() {"," \t\tunpauseFocusTrap: () => {},"," \t});"," }","+","+export interface DialogTrapHandle {","+\t/** Mirrors the visual z-index stacking of the dialog placements */","+\treadonly zRank: number;","+\treassert: () => void;","+}","+","+const activeDialogTraps: DialogTrapHandle[] = [];","+","+/**","+ * Dialog focus traps activate in mount order, which may not match their visual stacking:","+ * a route drawer mounting after an already-open center modal would put its trap on top of","+ * the focus-trap stack and block all interaction with the modal rendered above it.","+ * Whenever a dialog trap activates, re-assert the highest-ranked active dialog trap","+ * (most recently activated wins ties) so the trap order matches the visual order.","+ */","+export function registerDialogTrap(handle: DialogTrapHandle) {","+\tactiveDialogTraps.push(handle);","+","+\tlet top = handle;","+","+\tfor (const trap of activeDialogTraps) {","+\t\tif (trap.zRank >= top.zRank) top = trap;","+\t}","+","+\tif (top !== handle) top.reassert();","+}","+","+export function unregisterDialogTrap(handle: DialogTrapHandle) {","+\tconst index = activeDialogTraps.indexOf(handle);","+\tif (index !== -1) activeDialogTraps.splice(index, 1);","+}"],"additions":32,"deletions":0,"truncated":false},{"path":"app/src/views/private/components/license-banner.vue","lines":["@@ -49,7 +49,11 @@ async function setOwner() {"," "," function remindLater() {"," \t// 30 days, will be deleted on logout / session end","-\tcookies.set('license-banner-dismissed', 'true', { expires: new Date(Date.now() + 1000 * 60 * 60 * 24 * 30) });","+\tcookies.set('license-banner-dismissed', 'true', {","+\t\tpath: '/',","+\t\texpires: new Date(Date.now() + 1000 * 60 * 60 * 24 * 30),","+\t});","+"," \tnotify({ title: t('license_banner.remind_next_login'), type: 'info' });"," \tmodel.value = false;"," }"],"additions":5,"deletions":1,"truncated":false},{"path":"app/src/views/private/components/license-onboarding.vue","lines":["@@ -93,6 +93,7 @@ async function save() {"," "," function dismiss() {"," \tcookies.set('license-onboarding-dismissed', 'true', {","+\t\tpath: '/',"," \t\texpires: new Date(Date.now() + 1000 * 60 * 60 * 24 * 365 * 10),"," \t});"," "],"additions":1,"deletions":0,"truncated":false},{"path":"app/src/views/private/components/license/license-login-modal.vue","lines":["@@ -52,6 +52,7 @@ async function save() {"," "," function dismiss() {"," \tcookies.set('license-login-modal-dismissed', 'true', {","+\t\tpath: '/',"," \t\texpires: new Date(Date.now() + 1000 * 60 * 60 * 24 * 30),"," \t});"," ",""],"additions":1,"deletions":0,"truncated":false}],"additions":173,"deletions":7,"truncated":false,"file_count":8},"error":null,"fetched_at":"2026-06-12T11:44:44.200923+00:00"}