BTreeMap`), so `==` reproduces","+    // the order-insensitive `equals`; absent on either side normalizes","+    // to an empty map. A changed patch file changes its hash here, so","+    // this is what invalidates a lockfile whose `(patch_hash=...)` depPath","+    // suffixes would otherwise go stale.","+    let empty_patches: BTreeMap<String, String> = BTreeMap::new();","+    let lockfile_patches = lockfile.patched_dependencies.as_ref().unwrap_or(&empty_patches);","+    let config_patches = patched_dependencies.unwrap_or(&empty_patches);","+    if lockfile_patches != config_patches {","+        return Err(StalenessReason::PatchedDependenciesChanged {","+            lockfile: lockfile_patches.clone(),","+            config: config_patches.clone(),","+        });","+    }","+","     // `Boolean(lockfile.settings?.injectWorkspacePackages) !==","     // Boolean(injectWorkspacePackages)` at upstream's","     // [`getOutdatedLockfileSetting.ts:80-82`](https://github.com/pnpm/pnpm/blob/39101f5e37/lockfile/settings-checker/src/getOutdatedLockfileSetting.ts#L80-L82)."],"additions":43,"deletions":4,"truncated":false},{"path":"pacquet/crates/lockfile/src/freshness/tests.rs","lines":["@@ -599,6 +599,7 @@ fn check_settings_passes_when_both_sides_empty() {","             None,","             None,","             None,","+            None,","             false,","             crate::DEFAULT_PEERS_SUFFIX_MAX_LENGTH","         )","@@ -610,6 +611,7 @@ fn check_settings_passes_when_both_sides_empty() {","             None,","             None,","             Some(&[]),","+            None,","             false,","             crate::DEFAULT_PEERS_SUFFIX_MAX_LENGTH","         )","@@ -636,6 +638,7 @@ fn check_settings_passes_when_sets_match_regardless_of_order() {","             None,","             None,","             Some(&config_set),","+            None,","             false,","             crate::DEFAULT_PEERS_SUFFIX_MAX_LENGTH,","         )","@@ -658,6 +661,7 @@ fn check_settin