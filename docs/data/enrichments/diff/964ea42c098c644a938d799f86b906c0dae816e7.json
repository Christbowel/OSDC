{"id":"964ea42c098c644a938d799f86b906c0dae816e7","axis":"silent","repo":"ollama/ollama","sha":"964ea42c098c644a938d799f86b906c0dae816e7","parsed":{"files":[{"path":"x/create/blockfp8.go","lines":["@@ -0,0 +1,173 @@","+package create","+","+import (","+\t\"fmt\"","+\t\"slices\"","+\t\"sort\"","+\t\"strings\"","+)","+","+// planBlockFP8 plans an HF block-FP8 source. MLX has no FP8 tensor type, so","+// every FP8 weight is decoded to BF16 using its block scale and then quantized","+// to the target (mxfp8); a weight the policy declines is still decoded and kept","+// at BF16 (it is never stored as FP8). Everything else passes through at source","+// precision.","+func planBlockFP8(inv Inventory, target string, policy quantizePolicy) ([]BlobSpec, error) {","+\t// The scale companion of each FP8 weight is folded into that weight's","+\t// blob, so it is not emitted on its own.","+\tconsumed := make(map[string]bool)","+\tfor _, name := range sortedTensorNames(inv) {","+\t\tif isFP8Weight(inv, name) {","+\t\t\tif scale, ok := fp8ScaleFor(inv, name); ok {","+\t\t\t\tconsumed[scale] = true","+\t\t\t}","+\t\t}","+\t}","+","+\tgroups := make(map[string][]SourceTensor)","+\tfp8Groups := make(map[string][]SourceTensor)","+\tspecs := make([]BlobSpec, 0, len(inv.Tensors))","+\tfor _, name := range sortedTensorNames(inv) {","+\t\tif consumed[name] {","+\t\t\tcontinue","+\t\t}","+\t\tt := inv.Tensors[name]","+","+\t\tif isFP8Weight(inv, name) {","+\t\t\t// Disjoint per-expert FP8 weights are stacked, decoded, and","+\t\t\t// quantized together by planFP8ExpertGroup; an already-stacked (3D)","+\t\t\t// FP8 expert tensor falls through to the single-tensor decode below.","+\t\t\tif gp, perExpert := perExpertGroup(name); perExpert {","+\t\t\t\tfp8Groups[gp] = append(fp8Groups[gp], t)","+\t\t\t\tcontinue","+\t\t\t}","+\t\t\tscaleName, ok := fp8ScaleFor(inv, name)","+\t\t\tif !ok {","+\t\t\t\treturn nil, fmt.Errorf(\"fp8 weight %q has no scale companion\", name)","+\t\t\t}","+\t\t\tspecs = append(specs, BlobSpec{","+\t\t\t\tName: name,","+\t\t\t\tTensors: []TensorSpec{{","+\t\t\t\t\tName:      name,","+\t\t\t\t\tSources:   []SourceTensor{t, inv.Tensors[scaleName]},","+\t\t\t\t\tTransform: TransformDecodeFP8,","+\t\t\t\t\tQuantize:  policy.quantizationType(name, t.Shape, target),","+\t\t\t\t\tOutDtype:  \"BF16\",","+\t\t\t\t\tOutShape:  t.Shape,","+\t\t\t\t}},","+\t\t\t})","+\t\t\tcontinue","+\t\t}","+","+\t\tif gp, ok := perExpertGroup(name); ok {","+\t\t\tgroups[gp] = append(groups[gp], t)","+\t\t\tcontinue","+\t\t}","+","+\t\tspecs = append(specs, BlobSpec{","+\t\t\tName:    name,","+\t\t\tTensors: []TensorSpec{{Name: name, Sources: []SourceTensor{t}}},","+\t\t})","+\t}","+","+\tfor _, gp := range sortedKeys(groups) {","+\t\tspec, err := planExpertGroup(gp, groups[gp], \"\", policy)","+\t\tif err != nil {","+\t\t\treturn nil, err","+\t\t}","+\t\tspecs = append(specs, spec)","+\t}","+\tfor _, gp := range sortedKeys(fp8Groups) {","+\t\tspec, err := planFP8ExpertGroup(gp, fp8Groups[gp], inv, target, policy)","+\t\tif err != nil {","+\t\t\treturn nil, err","+\t\t}","+\t\tspecs = append(specs, spec)","+\t}","+\treturn specs, nil","+}","+","+// planFP8ExpertGroup packs a layer's disjoint per-expert block-FP8 weights into","+// one blob: the experts of each projection are stacked into [experts, out, in],","+// dequantized from FP8 with their block scales, and quantized per the policy.","+// The stacking, decode, and quantize all run on the MLX writer thread; the","+// planner only groups and orders the source weights and their scale companions.","+func planFP8ExpertGroup(groupPrefix string, tensors []SourceTensor, inv Inventory, target string, policy quantizePolicy) (BlobSpec, error) {","+\ttype expert struct {","+\t\tidx    int","+\t\tweight SourceTensor","+\t\tscale  SourceTensor","+\t}","+\tbyProj := make(map[string][]expert)","+\tfor _, t := range tensors {","+\t\tidx, proj, err := parseExpertTensor(groupPrefix, t.Name)","+\t\tif err != nil {","+\t\t\treturn BlobSpec{}, err","+\t\t}","+\t\tscaleName, ok := fp8ScaleFor(inv, t.Name)","+\t\tif !ok {","+\t\t\treturn BlobSpec{}, fmt.Errorf(\"fp8 expert weight %q has no scale companion\", t.Name)","+\t\t}","+\t\tbyProj[proj] = append(byProj[proj], expert{idx: idx, weight: t, scale: inv.Tensors[scaleName]})","+\t}","+","+\tspec := BlobSpec{Name: groupPrefix}","+\tfor _, proj := range sortedKeys(byProj) {","+\t\texperts := byProj[proj]","+\t\tsort.Slice(experts, func(i, j int) bool { return experts[i].idx < experts[j].idx })","+","+\t\tbase := experts[0].weight","+\t\tbaseScale := experts[0].scale","+\t\t// Sources are the N weights followed by the N scales, in expert order,","+\t\t// matching what TransformDecodeStackFP8 expects.","+\t\tsources := make([]SourceTensor, 0, 2*len(experts))","+\t\tscales := make([]SourceTensor, 0, len(experts))","+\t\tfor _, e := range experts {","+\t\t\tif e.weight.Dtype != base.Dtype || !slices.Equal(e.weight.Shape, base.Shape) {","+\t\t\t\treturn BlobSpec{}, fmt.Errorf(\"fp8 expert group %s projection %s has mismatched weight layout (%s %v vs %s %v)\",","+\t\t\t\t\tgroupPrefix, proj, base.Dtype, base.Shape, e.weight.Dtype, e.weight.Shape)","+\t\t\t}","+\t\t\tif e.scale.Dtype != baseScale.Dtype || !slices.Equal(e.scale.Shape, baseScale.Shape) {","+\t\t\t\treturn BlobSpec{}, fmt.Errorf(\"fp8 expert group %s projection %s has mismatched scale layout (%s %v vs %s %v)\",","+\t\t\t\t\tgroupPrefix, proj, baseScale.Dtype, baseScale.Shape, e.scale.Dtype, e.scale.Shape)","+\t\t\t}","+\t\t\tsources = append(sources, e.weight)","+\t\t\tscales = append(scales, e.scale)","+\t\t}","+\t\tsources = append(sources, scales...)","+","+\t\tstackedName := groupPrefix + \".\" + proj + \".weight\"","+\t\tstackedShape := append([]int32{int32(len(experts))}, base.Shape...)","+\t\tspec.Tensors = append(spec.Tensors, TensorSpec{","+\t\t\tName:      stackedName,","+\t\t\tSources:   sources,","+\t\t\tTransform: TransformDecodeStackFP8,","+\t\t\tQuantize:  policy.quantizationType(stackedName, stackedShape, target),","+\t\t\tOutDtype:  base.Dtype,","+\t\t\tOutShape:  stackedShape,","+\t\t})","+\t}","+\treturn spec, nil","+}","+","+// isFP8Weight reports whether name is an F8_E4M3 weight with a block-scale","+// companion (the form that must be decoded before use).","+func isFP8Weight(inv Inventory, name string) bool {","+\tt, ok := inv.Tensors[name]","+\tif !ok || !strings.HasSuffix(name, \".weight\") || !isE4M3Dtype(t.Dtype) {","+\t\treturn false","+\t}","+\t_, ok = fp8ScaleFor(inv, name)","+\treturn ok","+}","+","+// fp8ScaleFor returns the block-scale companion name for an FP8 weight,","+// preferring \"_scale_inv\" over \"_scale\" (matching the source conventions).","+func fp8ScaleFor(inv Inventory, weightName string) (string, bool) {","+\tfor _, suffix := range []string{\"_scale_inv\", \"_scale\"} {","+\t\tif s := weightName + suffix; inv.Has(s) {","+\t\t\treturn s, true","+\t\t}","+\t}","+\treturn \"\", false","+}"],"additions":173,"deletions":0,"truncated":false},{"path":"x/create/blockfp8_test.go","lines":["@@ -0,0 +1,132 @@","+package create","+","+import (","+\t\"slices\"","+\t\"testing\"","+)","+","+func blockFP8(tensors map[string]string) Inventory {","+\t// Block-fp8 sources are routed to planBlockFP8 by kind; the config is not","+\t// needed once classified, so build the inventory directly with realistic","+\t// shapes for the quantize policy.","+\tm := make(map[string]SourceTensor)","+\tfor name, dtype := range tensors {","+\t\tshape := []int32{256, 256}","+\t\tif dtype != \"F8_E4M3\" && dtype != \"BF16\" {","+\t\t\tshape = []int32{1} // scale companions are small","+\t\t}","+\t\tm[name] = SourceTensor{Name: name, Dtype: dtype, Shape: shape}","+\t}","+\treturn Inventory{Dir: \"test\", Tensors: m}","+}","+","+func TestPlanBlockFP8(t *testing.T) {","+\tinv := blockFP8(map[string]string{","+\t\t\"model.layers.0.self_attn.q_proj.weight\":           \"F8_E4M3\",","+\t\t\"model.layers.0.self_attn.q_proj.weight_scale_inv\": \"F32\",","+\t\t\"model.layers.0.mlp.down_proj.weight\":              \"F8_E4M3\",","+\t\t\"model.layers.0.mlp.down_proj.weight_scale_inv\":    \"F32\",","+\t\t\"model.layers.0.input_layernorm.weight\":            \"F32\", // norm stays as-is","+\t\t\"model.embed_tokens.weight\":                        \"BF16\",","+\t\t\"lm_head.weight\":                                   \"BF16\",","+\t})","+","+\tspecs, err := Plan(inv, Classification{Kind: SourceBlockFP8, Quantize: \"mxfp8\"}, defaultQuantPolicy{})","+\tif err != nil {","+\t\tt.Fatalf(\"Plan() error = %v\", err)","+\t}","+","+\t// FP8 weight: decode + quantize to mxfp8, scale folded in (not its own blob).","+\tq, ok := specByName(specs, \"model.layers.0.self_attn.q_proj.weight\")","+\tif !ok {","+\t\tt.Fatal(\"missing q_proj blob\")","+\t}","+\tts := q.Tensors[0]","+\tif ts.Transform != TransformDecodeFP8 || ts.Quantize != \"mxfp8\" || ts.OutDtype != \"BF16\" {","+\t\tt.Errorf(\"q_proj = %+v, want decode_fp8 + mxfp8 + BF16\", ts)","+\t}","+\tif len(ts.Sources) != 2 || ts.Sources[0].Name != \"model.layers.0.self_attn.q_proj.weight\" ||","+\t\tts.Sources[1].Name != \"model.layers.0.self_attn.q_proj.weight_scale_inv\" {","+\t\tt.Errorf(\"q_proj sources = %v, want [weight, scale_inv]\", ts.Sources)","+\t}","+\tif _, leaked := specByName(specs, \"model.layers.0.self_attn.q_proj.weight_scale_inv\"); leaked {","+\t\tt.Error(\"scale companion must not be its own blob\")","+\t}","+","+\t// Norm stays at source precision (F32), not quantized, not cast.","+\tnorm, _ := specByName(specs, \"model.layers.0.input_layernorm.weight\")","+\tif norm.Tensors[0].Quantize != \"\" || norm.Tensors[0].Transform != TransformNone || norm.Tensors[0].OutDtype != \"\" {","+\t\tt.Errorf(\"norm = %+v, want kept at source precision\", norm.Tensors[0])","+\t}","+","+\t// BF16 weights pass through untouched.","+\tlmHead, _ := specByName(specs, \"lm_head.weight\")","+\tif lmHead.Tensors[0].Quantize != \"\" || lmHead.Tensors[0].Transform != TransformNone {","+\t\tt.Errorf(\"lm_head = %+v, want kept at source precision\", lmHead.Tensors[0])","+\t}","+}","+","+func TestPlanBlockFP8PrestackedExperts(t *testing.T) {","+\t// A pre-stacked fp8 expert tensor (one [E, out, in] tensor + one scale)","+\t// decodes + quantizes as an ordinary tensor — no per-expert stacking.","+\tinv := Inventory{Dir: \"test\", Tensors: map[string]SourceTensor{","+\t\t\"model.layers.0.mlp.experts.gate_up_proj.weight\":           {Name: \"model.layers.0.mlp.experts.gate_up_proj.weight\", Dtype: \"F8_E4M3\", Shape: []int32{8, 512, 256}},","+\t\t\"model.layers.0.mlp.experts.gate_up_proj.weight_scale_inv\": {Name: \"model.layers.0.mlp.experts.gate_up_proj.weight_scale_inv\", Dtype: \"F32\", Shape: []int32{8, 4, 2}},","+\t}}","+\tspecs, err := Plan(inv, Classification{Kind: SourceBlockFP8, Quantize: \"mxfp8\"}, defaultQuantPolicy{})","+\tif err != nil {","+\t\tt.Fatalf(\"Plan() error = %v\", err)","+\t}","+\tw, ok := specByName(specs, \"model.layers.0.mlp.experts.gate_up_proj.weight\")","+\tif !ok || len(specs) != 1 {","+\t\tt.Fatalf(\"want single decode blob; got %v\", specNames(specs))","+\t}","+\tts := w.Tensors[0]","+\tif ts.Transform != TransformDecodeFP8 || ts.Quantize != \"mxfp8\" || !slices.Equal(ts.OutShape, []int32{8, 512, 256}) {","+\t\tt.Errorf(\"pre-stacked fp8 expert = %+v, want decode_fp8 + mxfp8 + 3D shape\", ts)","+\t}","+}","+","+func TestPlanBlockFP8PerExpertStacked(t *testing.T) {","+\t// Disjoint per-expert fp8 weights are grouped by projection, stacked into one","+\t// [experts, out, in] tensor, and decoded+quantized together. Sources are the","+\t// N weights followed by the N scales, in expert-index order.","+\tinv := Inventory{Dir: \"test\", Tensors: map[string]SourceTensor{","+\t\t\"model.layers.0.mlp.experts.0.gate_proj.weight\":       {Name: \"model.layers.0.mlp.experts.0.gate_proj.weight\", Dtype: \"F8_E4M3\", Shape: []int32{256, 256}},","+\t\t\"model.layers.0.mlp.experts.0.gate_proj.weight_scale\": {Name: \"model.layers.0.mlp.experts.0.gate_proj.weight_scale\", Dtype: \"BF16\", Shape: []int32{2, 2}},","+\t\t\"model.layers.0.mlp.experts.1.gate_proj.weight\":       {Name: \"model.layers.0.mlp.experts.1.gate_proj.weight\", Dtype: \"F8_E4M3\", Shape: []int32{256, 256}},","+\t\t\"model.layers.0.mlp.experts.1.gate_proj.weight_scale\": {Name: \"model.layers.0.mlp.experts.1.gate_proj.weight_scale\", Dtype: \"BF16\", Shape: []int32{2, 2}},","+\t}}","+\tspecs, err := Plan(inv, Classification{Kind: SourceBlockFP8, Quantize: \"mxfp8\"}, defaultQuantPolicy{})","+\tif err != nil {","+\t\tt.Fatalf(\"Plan() error = %v\", err)","+\t}","+\tif len(specs) != 1 {","+\t\tt.Fatalf(\"want single stacked blob; got %v\", specNames(specs))","+\t}","+\tspec, ok := specByName(specs, \"model.layers.0.mlp.experts\")","+\tif !ok || len(spec.Tensors) != 1 {","+\t\tt.Fatalf(\"want one stacked expert group; got %v\", specNames(specs))","+\t}","+\tts := spec.Tensors[0]","+\tif ts.Name != \"model.layers.0.mlp.experts.gate_proj.weight\" {","+\t\tt.Errorf(\"stacked name = %q, want model.layers.0.mlp.experts.gate_proj.weight\", ts.Name)","+\t}","+\tif ts.Transform != TransformDecodeStackFP8 || ts.Quantize != \"mxfp8\" || ts.OutDtype != \"F8_E4M3\" || !slices.Equal(ts.OutShape, []int32{2, 256, 256}) {","+\t\tt.Errorf(\"stacked fp8 expert = %+v, want decode_stack_fp8 + mxfp8 + F8_E4M3 + [2 256 256]\", ts)","+\t}","+\twantSources := []string{","+\t\t\"model.layers.0.mlp.experts.0.gate_proj.weight\",","+\t\t\"model.layers.0.mlp.experts.1.gate_proj.weight\",","+\t\t\"model.layers.0.mlp.experts.0.gate_proj.weight_scale\",","+\t\t\"model.layers.0.mlp.experts.1.gate_proj.weight_scale\",","+\t}","+\tif len(ts.Sources) != len(wantSources) {","+\t\tt.Fatalf(\"sources = %d, want %d (N weights then N scales)\", len(ts.Sources), len(wantSources))","+\t}","+\tfor i, want := range wantSources {","+\t\tif ts.Sources[i].Name != want {","+\t\t\tt.Errorf(\"source[%d] = %q, want %q\", i, ts.Sources[i].Name, want)","+\t\t}","+\t}","+}"],"additions":132,"deletions":0,"truncated":false},{"path":"x/create/classify.go","lines":["@@ -0,0 +1,166 @@","+package create","+","+import (","+\t\"fmt\"","+\t\"strings\"","+","+\t\"github.com/ollama/ollama/x/quant\"","+)","+","+// SourceKind is the overarching dtype for a given safetensors model","+type SourceKind int","+","+const (","+\tSourceFloat        SourceKind = iota // bf16/fp16/fp32 — quantizable on request","+\tSourceBlockFP8                       // HF block-FP8 — auto-converted to mxfp8","+\tSourcePrequantized                   // already quantized — copied through","+)","+","+func (k SourceKind) String() string {","+\tswitch k {","+\tcase SourceFloat:","+\t\treturn \"float\"","+\tcase SourceBlockFP8:","+\t\treturn \"block-fp8\"","+\tcase SourcePrequantized:","+\t\treturn \"prequantized\"","+\tdefault:","+\t\treturn \"unknown\"","+\t}","+}","+","+// Classification is the decision about a source model: its kind and the","+// quantization that will actually be applied. An empty Quantize means the","+// tensors are stored at source precision (no quantization).","+type Classification struct {","+\tKind     SourceKind","+\tQuantize string","+}","+","+// Classify decides a source model's kind and resolves the effective","+// quantization from the user's requested type, rejecting requests that are not","+// allowed for the kind.","+func Classify(inv Inventory, requested string) (Classification, error) {","+\trequested, err := normalizeRequested(requested)","+\tif err != nil {","+\t\treturn Classification{}, err","+\t}","+","+\tif name, ok := firstUnsupportedFP8(inv); ok {","+\t\treturn Classification{}, fmt.Errorf(\"unsupported fp8 source: tensor %s is F8_E5M2; only F8_E4M3 block-FP8 sources are supported\", name)","+\t}","+","+\tswitch detectKind(inv) {","+\tcase SourceFloat:","+\t\treturn Classification{Kind: SourceFloat, Quantize: requested}, nil","+","+\tcase SourcePrequantized:","+\t\tif requested != \"\" {","+\t\t\treturn Classification{}, fmt.Errorf(\"cannot requantize an already-quantized source model (requested %q): only bf16/fp16/fp32 sources can be quantized\", requested)","+\t\t}","+\t\treturn Classification{Kind: SourcePrequantized}, nil","+","+\tcase SourceBlockFP8:","+\t\trows, cols, ok := inv.Config.HFFP8WeightBlockSize()","+\t\tif !ok {","+\t\t\treturn Classification{}, fmt.Errorf(\"fp8 source model is missing weight_block_size metadata\")","+\t\t}","+\t\tif rows != 128 || cols != 128 {","+\t\t\treturn Classification{}, fmt.Errorf(\"unsupported fp8 source block size %dx%d (only 128x128 is supported)\", rows, cols)","+\t\t}","+\t\tif requested != \"\" {","+\t\t\treturn Classification{}, fmt.Errorf(\"cannot quantize an fp8 source model (requested %q): fp8 sources are converted to mxfp8 automatically; only bf16/fp16/fp32 sources can be quantized\", requested)","+\t\t}","+\t\treturn Classification{Kind: SourceBlockFP8, Quantize: \"mxfp8\"}, nil","+\t}","+","+\treturn Classification{}, fmt.Errorf(\"could not classify source model in %s\", inv.Dir)","+}","+","+// normalizeRequested validates the user's quantize value and returns its","+// canonical form (\"\" for no quantization).","+func normalizeRequested(requested string) (string, error) {","+\tif strings.TrimSpace(requested) == \"\" {","+\t\treturn \"\", nil","+\t}","+\tc := quant.Canonical(requested)","+\tif c == \"\" {","+\t\treturn \"\", fmt.Errorf(\"unsupported quantize type %q: supported types are int4, int8, nvfp4, mxfp4, mxfp8\", requested)","+\t}","+\treturn c, nil","+}","+","+// detectKind sorts a source into Float, BlockFP8, or Prequantized using only","+// the inventory's tensor names, dtypes, and config. Prequantized is detected","+// from the tensors themselves, so a model whose quantization config sidecar is","+// missing (e.g. a ModelOpt checkpoint without hf_quant_config.json) is still","+// recognized as already-quantized and not mistaken for a float model.","+func detectKind(inv Inventory) SourceKind {","+\tvar hasMLXScales, hasPacked, hasNVFP4Scale, hasFP8Weight bool","+\tfor name, t := range inv.Tensors {","+\t\tswitch {","+\t\tcase strings.HasSuffix(name, \".scales\"):","+\t\t\thasMLXScales = true","+\t\tcase strings.HasSuffix(name, \".weight_packed\"):","+\t\t\thasPacked = true","+\t\tcase strings.HasSuffix(name, \".weight_scale\"):","+\t\t\t// An NVFP4 per-block scale sits on a packed (U8) weight. A","+\t\t\t// block-FP8 source also has a scale companion, but its weight is","+\t\t\t// F8_E4M3 — so the base weight's dtype disambiguates the two.","+\t\t\tif bt, ok := inv.Tensors[strings.TrimSuffix(name, \"_scale\")]; ok && isPackedDtype(bt.Dtype) {","+\t\t\t\thasNVFP4Scale = true","+\t\t\t}","+\t\t}","+\t\tif strings.HasSuffix(name, \".weight\") && isE4M3Dtype(t.Dtype) {","+\t\t\thasFP8Weight = true","+\t\t}","+\t}","+","+\tswitch {","+\tcase hasMLXScales || hasPacked || hasNVFP4Scale:","+\t\treturn SourcePrequantized","+\tcase hasFP8Weight:","+\t\treturn SourceBlockFP8","+\tdefault:","+\t\treturn SourceFloat","+\t}","+}","+","+// firstUnsupportedFP8 returns the name of the first F8_E5M2 weight in the","+// source, if any. We decode only E4M3, so an E5M2 source must be rejected","+// explicitly rather than silently mishandled.","+func firstUnsupportedFP8(inv Inventory) (string, bool) {","+\tfor name, t := range inv.Tensors {","+\t\tif strings.HasSuffix(name, \".weight\") && isE5M2Dtype(t.Dtype) {","+\t\t\treturn name, true","+\t\t}","+\t}","+\treturn \"\", false","+}","+","+func isPackedDtype(dtype string) bool {","+\tswitch strings.ToUpper(dtype) {","+\tcase \"U8\", \"U32\": // current .weight_scale producers ship U8; U32 covers a future word-packed source","+\t\treturn true","+\tdefault:","+\t\treturn false","+\t}","+}","+","+func isE4M3Dtype(dtype string) bool {","+\tswitch strings.ToUpper(dtype) {","+\tcase \"F8_E4M3\", \"F8_E4M3FN\":","+\t\treturn true","+\tdefault:","+\t\treturn false","+\t}","+}","+","+func isE5M2Dtype(dtype string) bool {","+\tswitch strings.ToUpper(dtype) {","+\tcase \"F8_E5M2\", \"F8_E5M2FNUZ\":","+\t\treturn true","+\tdefault:","+\t\treturn false","+\t}","+}"],"additions":166,"deletions":0,"truncated":false},{"path":"x/create/classify_test.go","lines":["@@ -0,0 +1,149 @@","+package create","+","+import (","+\t\"strings\"","+\t\"testing\"","+)","+","+func newInventory(cfg sourceModelConfig, tensors map[string]string) Inventory {","+\tm := make(map[string]SourceTensor)","+\tfor name, dtype := range tensors {","+\t\tm[name] = SourceTensor{Name: name, Dtype: dtype, Shape: []int32{128, 128}, File: \"model.safetensors\"}","+\t}","+\treturn Inventory{Dir: \"test\", Config: cfg, Tensors: m}","+}","+","+func fp8BlockConfig(rows, cols int32) sourceModelConfig {","+\treturn sourceModelConfig{","+\t\tQuantizationConfig: sourceQuantization{QuantMethod: \"fp8\", WeightBlockSize: []int32{rows, cols}},","+\t}","+}","+","+func TestClassify(t *testing.T) {","+\ttests := []struct {","+\t\tname      string","+\t\tcfg       sourceModelConfig","+\t\ttensors   map[string]string","+\t\trequested string","+\t\twantKind  SourceKind","+\t\twantQuant string","+\t}{","+\t\t{","+\t\t\tname:     \"float, no quantize\",","+\t\t\ttensors:  map[string]string{\"model.embed.weight\": \"BF16\", \"model.layers.0.weight\": \"BF16\"},","+\t\t\twantKind: SourceFloat,","+\t\t},","+\t\t{","+\t\t\tname:      \"float, quantize int4\",","+\t\t\ttensors:   map[string]string{\"model.layers.0.weight\": \"BF16\"},","+\t\t\trequested: \"int4\",","+\t\t\twantKind:  SourceFloat,","+\t\t\twantQuant: \"int4\",","+\t\t},","+\t\t{","+\t\t\tname:      \"float, quantize alias fp8 resolves to int8\",","+\t\t\ttensors:   map[string]string{\"model.layers.0.weight\": \"F32\"},","+\t\t\trequested: \"fp8\",","+\t\t\twantKind:  SourceFloat,","+\t\t\twantQuant: \"int8\",","+\t\t},","+\t\t{","+\t\t\tname:     \"mlx prequantized (.scales)\",","+\t\t\ttensors:  map[string]string{\"model.layers.0.weight\": \"U32\", \"model.layers.0.scales\": \"BF16\"},","+\t\t\twantKind: SourcePrequantized,"