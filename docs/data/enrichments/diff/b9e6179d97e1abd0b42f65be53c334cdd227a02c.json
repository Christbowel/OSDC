er family pairs its MT-Settings adapter directly in","+\t\t\t// front of its legacy strategy; first match wins, so the order is","+\t\t\t// the design.","+\t\t\tstrategyTypes := make([]string, 0, len(env.service.fbStrategies))","+\t\t\tfor _, strategy := range env.service.fbStrategies {","+\t\t\t\tstrategyTypes = append(strategyTypes, fmt.Sprintf(\"%T\", strategy))","+\t\t\t}","+\t\t\trequire.Equal(t, tc.expectedStrategies, strategyTypes)"," \t\t})"," \t}"," }"],"additions":24,"deletions":4,"truncated":false},{"path":"pkg/services/ssosettings/ssosettingstests/fallback_strategy_fake.go","lines":["@@ -13,7 +13,7 @@ func NewFakeFallbackStrategy() *FakeFallbackStrategy {"," \treturn &FakeFallbackStrategy{}"," }"," ","-func (f *FakeFallbackStrategy) IsMatch(provider string) bool {","+func (f *FakeFallbackStrategy) IsMatch(_ context.Context, provider string) bool {"," \treturn f.ExpectedIsMatch"," }"," "],"additions":1,"deletions":1,"truncated":false},{"path":"pkg/services/ssosettings/strategies/ldap_strategy.go","lines":["@@ -23,7 +23,7 @@ func NewLDAPStrategy(cfg *setting.Cfg) *LDAPStrategy {"," \t}"," }"," ","-func (s *LDAPStrategy) IsMatch(provider string) bool {","+func (s *LDAPStrategy) IsMatch(_ context.Context, provider string) bool {"," \treturn provider == social.LDAPProviderName"," }"," "],"additions":1,"deletions":1,"truncated":false},{"path":"pkg/services/ssosettings/strategies/mtsettings_strategy.go","lines":["@@ -0,0 +1,73 @@","+package strategies","+","+import (","+\t\"context\"","+\t\"slices\"","+","+\t\"github.com/open-feature/go-sdk/openfeature\"","+","+\t\"github.com/grafana/grafana/pkg/login/social\"","+\t\"github.com/grafana/grafana/pkg/services/featuremgmt\"","+\t\"github.com/grafana/grafana/pkg/services/ssosettings\"","+)","+","+// The MT-Settings strategies resolve provider settings from the MT-Settings","+// service. Each provider family has its own adapter, registered directly in","+// front of the family's legacy strategy: while the grafana.ssoSettingsToMTSettings","+// feature toggle is enabled the adapter wins the match and fails loudly","+// instead of silently falling back to the legacy mechanism.","+type mtSettingsStrategy struct {","+\tmatches func(provider string) bool","+}","+","+func (s *mtSettingsStrategy) IsMatch(ctx context.Context, provider string) bool {","+\tenabled := openfeature.NewDefaultClient().Boolean(ctx,","+\t\tfeaturemgmt.FlagGrafanaSsoSettingsToMTSettings, false, openfeature.TransactionContext(ctx))","+\treturn enabled && s.matches(provider)","+}","+","+func (s *mtSettingsStrategy) GetProviderConfig(_ context.Context, _ string) (map[string]any, error) {","+\treturn nil, ssosettings.ErrMTSettingsNotImplemented","+}","+","+type MTSettingsOAuthStrategy struct {","+\tmtSettingsStrategy","+}","+","+var _ ssosettings.FallbackStrategy = (*MTSettingsOAuthStrategy)(nil)","+","+func NewMTSettingsOAuthStrategy() *MTSettingsOAuthStrategy {","+\treturn &MTSettingsOAuthStrategy{mtSettingsStrategy{","+\t\tmatches: func(provider string) bool {","+\t\t\treturn slices.Contains(ssosettings.AllOAuthProviders, provider)","+\t\t},","+\t}}","+}","+","+type MTSettingsLDAPStrategy struct {","+\tmtSettingsStrategy","+}","+","+var _ ssosettings.FallbackStrategy = (*MTSettingsLDAPStrategy)(nil)","+","+func NewMTSettingsLDAPStrategy() *MTSettingsLDAPStrategy {","+\treturn &MTSettingsLDAPStrategy{mtSettingsStrategy{","+\t\tmatches: func(provider string) bool {","+\t\t\treturn provider == social.LDAPProviderName","+\t\t},","+\t}}","+}","+","+type MTSettingsSAMLStrategy struct {","+\tmtSettingsStrategy","+}","+","+var _ ssosettings.FallbackStrategy = (*MTSettingsSAMLStrategy)(nil)","+","+func NewMTSettingsSAMLStrategy() *MTSettingsSAMLStrategy {","+\treturn &MTSettingsSAMLStrategy{mtSettingsStrategy{","+\t\tmatches: func(provider string) bool {","+\t\t\treturn provider == social.SAMLProviderName","+\t\t},","+\t}}","+}"],"additions":73,"deletions":0,"truncated":false},{"path":"pkg/services/ssosettings/strategies/mtsettings_strategy_test.go","lines":["@@ -0,0 +1,94 @@","+package strategies","+","+import (","+\t\"context\"","+\t\"testing\"","+","+\t\"github.com/open-feature/go-sdk/openfeature\"","+\t\"github.com/open-feature/go-sdk/openfeature/memprovider\"","+\toftesting \"github.com/open-feature/go-sdk/openfeature/testing\"","+\t\"github.com/stretchr/testify/require\"","+","+\t\"github.com/grafana/grafana/pkg/login/social\"","+\t\"github.com/grafana/grafana/pkg/services/featuremgmt\"","+\t\"github.com/grafana/grafana/pkg/services/ssosettings\"","+\t\"github.com/grafana/grafana/pkg/setting\"","+)","+","+var provider = oftesting.NewTestProvider()","+","+func TestMain(m *testing.M) {","+\tif err := openfeature.SetProvider(provider); err != nil {","+\t\tpanic(err)","+\t}","+","+\tm.Run()","+}","+","+func toggleFlags(enabled bool) map[string]memprovider.InMemoryFlag {","+\treturn map[string]memprovider.InMemoryFlag{","+\t\tfeaturemgmt.FlagGrafanaSsoSettingsToMTSettings: setting.NewInMemoryFlag(featuremgmt.FlagGrafanaSsoSettingsToMTSettings, enabled),","+\t}","+}","+","+func TestMTSettingsStrategies_IsMatch(t *testing.T) {","+\tt.Run(\"no adapter matches any provider when the toggle is disabled\", func(t *testing.T) {","+\t\tprovider.UsingFlags(t, toggleFlags(false))","+","+\t\tadapters := []ssosettings.FallbackStrategy{","+\t\t\tNewMTSettingsOAuthStrategy(),","+\t\t\tNewMTSettingsLDAPStrategy(),","+\t\t\tNewMTSettingsSAMLStrategy(),","+\t\t}","+\t\tproviders := append([]string{}, ssosettings.AllOAuthProviders...)","+\t\tproviders = append(providers, social.LDAPProviderName, social.SAMLProviderName)","+","+\t\tfor _, adapter := range adapters {","+\t\t\tfor _, p := range providers {","+\t\t\t\trequire.False(t, adapter.IsMatch(t.Context(), p))","+\t\t\t}","+\t\t}","+\t})","+","+\tt.Run(\"each adapter matches exactly its own family when the toggle is enabled\", func(t *testing.T) {","+\t\tprovider.UsingFlags(t, toggleFlags(true))","+","+\t\toauth := NewMTSettingsOAuthStrategy()","+\t\tldap := NewMTSettingsLDAPStrategy()","+\t\tsaml := NewMTSettingsSAMLStrategy()","+","+\t\tfor _, p := range ssosettings.AllOAuthProviders {","+\t\t\trequire.True(t, oauth.IsMatch(t.Context(), p))","+\t\t\trequire.False(t, ldap.IsMatch(t.Context(), p))","+\t\t\trequire.False(t, saml.IsMatch(t.Context(), p))","+\t\t}","+","+\t\trequire.True(t, ldap.IsMatch(t.Context(), social.LDAPProviderName))","+\t\trequire.False(t, oauth.IsMatch(t.Context(), social.LDAPProviderName))","+\t\trequire.False(t, saml.IsMatch(t.Context(), social.LDAPProviderName))","+","+\t\trequire.True(t, saml.IsMatch(t.Context(), social.SAMLProviderName))","+\t\trequire.False(t, oauth.IsMatch(t.Context(), social.SAMLProviderName))","+\t\trequire.False(t, ldap.IsMatch(t.Context(), social.SAMLProviderName))","+\t})","+}","+","+func TestMTSettingsStrategies_GetProviderConfig(t *testing.T) {","+\tprovider.UsingFlags(t, toggleFlags(true))","+","+\ttestCases := []struct {","+\t\tadapter  ssosettings.FallbackStrategy","+\t\tprovider string","+\t}{","+\t\t{NewMTSettingsOAuthStrategy(), social.GenericOAuthProviderName},","+\t\t{NewMTSettingsLDAPStrategy(), social.LDAPProviderName},","+\t\t{NewMTSettingsSAMLStrategy(), social.SAMLProviderName},","+\t}","+","+\tfor _, tc := range testCases {","+\t\tconfig, err := tc.adapter.GetProviderConfig(context.Background(), tc.provider)","+","+\t\trequire.Nil(t, config)","+\t\trequire.ErrorIs(t, err, ssosettings.ErrMTSettingsNotImplemented)","+\t}","+}"],"additions":94,"deletions":0,"truncated":false},{"path":"pkg/services/ssosettings/strategies/oauth_strategy.go","lines":["@@ -36,7 +36,7 @@ func NewOAuthStrategy(cfg *setting.Cfg) *OAuthStrategy {"," \treturn oauthStrategy"," }"," ","-func (s *OAuthStrategy) IsMatch(provider string) bool {","+func (s *OAuthStrategy) IsMatch(_ context.Context, provider string) bool {"," \t_, ok := s.settingsByProvider[provider]"," \treturn ok"," }"],"additions":1,"deletions":1,"truncated":false},{"path":"pkg/services/ssosettings/strategies/saml_strategy.go","lines":["@@ -21,7 +21,7 @@ func NewSAMLStrategy(settingsProvider setting.Provider) *SAMLStrategy {"," \t}"," }"," ","-func (s *SAMLStrategy) IsMatch(provider string) bool {","+func (s *SAMLStrategy) IsMatch(_ context.Context, provider string) bool {"," \treturn provider == social.SAMLProviderName"," }"," "],"additions":1,"deletions":1,"truncated":false},{"path":"pkg/services/ssosettings/strategies/saml_strategy_test.go","lines":["@@ -98,8 +98,8 @@ var ("," func TestSAMLIsMatch(t *testing.T) {"," \tcfg := setting.NewCfg()"," \tstrategy := NewSAMLStrategy(&setting.OSSImpl{Cfg: cfg})","-\trequire.True(t, strategy.IsMatch(\"saml\"))","-\trequire.False(t, strategy.IsMatch(\"oauth\"))","+\trequire.True(t, strategy.IsMatch(t.Context(), \"saml\"))","+\trequire.False(t, strategy.IsMatch(t.Context(), \"oauth\"))"," }"," "," func TestSAMLGetProviderConfig(t *testing.T) {",""],"additions":2,"deletions":2,"truncated":false}],"additions":212,"deletions":15,"truncated":false,"file_count":11},"error":null,"fetched_at":"2026-07-15T09:40:02.612015+00:00"}