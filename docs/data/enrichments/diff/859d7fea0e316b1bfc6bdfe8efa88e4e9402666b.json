{"id":"859d7fea0e316b1bfc6bdfe8efa88e4e9402666b","axis":"silent","repo":"WordPress/wordpress-develop","sha":"859d7fea0e316b1bfc6bdfe8efa88e4e9402666b","parsed":{"files":[{"path":"src/wp-includes/json-schema.php","lines":["@@ -0,0 +1,72 @@","+<?php","+/**","+ * JSON Schema API: shared functions for working with JSON Schema.","+ *","+ * @package WordPress","+ * @subpackage JSON_Schema","+ * @since 7.1.0","+ */","+","+/**","+ * Gets the JSON Schema keywords allowed for a given schema profile.","+ *","+ * Use the returned list to decide which keywords to keep when a schema is","+ * output as JSON. Both profiles describe JSON Schema draft-04 output, also","+ * called JSON Schema Version 4. They differ only in how much of the keyword","+ * vocabulary stays in the result.","+ *","+ * - 'rest-api' returns the subset of draft-04 that the WordPress REST API","+ *   uses for route output. This is the default.","+ * - 'draft-04' returns the larger draft-04 set used when publishing a schema","+ *   as a standalone document to clients, such as the Abilities API. It keeps","+ *   documentation and passthrough keywords like '$ref', 'definitions',","+ *   'allOf', 'not', 'dependencies', and 'additionalItems'.","+ *","+ * The keywords are allowed to stay in the schema output. This does not mean","+ * WordPress validates or sanitizes values against them.","+ *","+ * @since 7.1.0","+ *","+ * @param string $schema_profile Optional. Name of the schema profile to get keywords for.","+ *                               Accepts 'rest-api' or 'draft-04'. Any other value falls","+ *                               back to the 'rest-api' profile. Default 'rest-api'.","+ * @return string[] Allowed JSON Schema keywords.","+ */","+function wp_get_json_schema_allowed_keywords( string $schema_profile = 'rest-api' ): array {","+\t$rest_keywords = rest_get_allowed_schema_keywords();","+","+\t$keywords_by_profile = array(","+\t\t'rest-api' => $rest_keywords,","+\t\t'draft-04' => array_merge(","+\t\t\tarray(","+\t\t\t\t'$schema',","+\t\t\t\t'id',","+\t\t\t\t'$ref',","+\t\t\t),","+\t\t\t$rest_keywords,","+\t\t\tarray(","+\t\t\t\t'required',","+\t\t\t\t'allOf',","+\t\t\t\t'not',","+\t\t\t\t'definitions',","+\t\t\t\t'dependencies',","+\t\t\t\t'additionalItems',","+\t\t\t)","+\t\t),","+\t);","+","+\t$allowed_keywords = $keywords_by_profile[ $schema_profile ] ?? $rest_keywords;","+","+\t/**","+\t * Filters the JSON Schema keywords allowed for a given schema profile.","+\t *","+\t * Adding a keyword lets it stay in the schema output for that profile.","+\t * It does not make WordPress validate or sanitize values against the keyword.","+\t *","+\t * @since 7.1.0","+\t *","+\t * @param string[] $allowed_keywords Allowed JSON Schema keywords.","+\t * @param string   $schema_profile   The schema profile the keywords are for.","+\t */","+\treturn apply_filters( 'wp_json_schema_allowed_keywords', $allowed_keywords, $schema_profile );","+}"],"additions":72,"deletions":0,"truncated":false},{"path":"src/wp-includes/rest-api/class-wp-rest-server.php","lines":["@@ -1649,7 +1649,7 @@ public function get_data_for_route( $route, $callbacks, $context = 'view' ) {"," \t\t\t}"," \t\t}"," ","-\t\t$allowed_schema_keywords = array_flip( rest_get_allowed_schema_keywords() );","+\t\t$allowed_schema_keywords = array_flip( wp_get_json_schema_allowed_keywords( 'rest-api' ) );"," "," \t\t$route = preg_replace( '#\\(\\?P<(\\w+?)>.*?\\)#', '{$1}', $route );"," "],"additions":1,"deletions":1,"truncated":false},{"path":"src/wp-includes/rest-api/endpoints/class-wp-rest-abilities-v1-list-controller.php","lines":["@@ -34,6 +34,18 @@ class WP_REST_Abilities_V1_List_Controller extends WP_REST_Controller {"," \t */"," \tprotected $rest_base = 'abilities';"," ","+\t/**","+\t * Lookup map of allowed schema keywords for preparing ability schemas in REST responses.","+\t *","+\t * Keyword names are stored as keys so they can be matched with","+\t * array_intersect_key(). Computed lazily on first use and reused while","+\t * preparing nested schemas.","+\t *","+\t * @since 7.1.0","+\t * @var array<string, true>","+\t */","+\tprivate array $allowed_schema_keyword_lookup;","+"," \t/**"," \t * Registers the routes for abilities."," \t *","@@ -193,26 +205,6 @@ public function get_item_permissions_check( $request ) {"," \t\treturn current_user_can( 'read' );"," \t}"," ","-\t/**","-\t * Additional schema keywords to preserve in REST responses.","-\t *","-\t * Ability schemas are exposed to clients as JSON Schema. Preserve additional","-\t * draft-04 keywords so clients can validate richer schemas, even when some","-\t * of those keywords are not enforced by the server-side REST schema validator.","-\t *","-\t * @since 7.1.0","-\t * @var string[]","-\t */","-\tprivate const ADDITIONAL_ALLOWED_SCHEMA_KEYWORDS = array(","-\t\t'required',","-\t\t'allOf',","-\t\t'not',","-\t\t'$ref',","-\t\t'definitions',","-\t\t'dependencies',","-\t\t'additionalItems',","-\t);","-"," \t/**"," \t * Determines whether the value is an associative array."," \t *","@@ -227,6 +219,26 @@ private function is_associative_array( $value ): bool {"," \t\treturn is_array( $value ) && ! wp_is_numeric_array( $value );"," \t}"," ","+\t/**","+\t * Gets the allowed schema keywords for preparing ability schemas in REST responses.","+\t *","+\t * Uses the fuller draft-04 keyword set, not the smaller REST API subset.","+\t * The published schema is consumed by clients that re-validate values","+\t * against standard draft-04, so it keeps the keywords those validators","+\t * expect.","+\t *","+\t * @since 7.1.0","+\t *","+\t * @return array<string, true> Allowed schema keywords.","+\t */","+\tprivate function get_allowed_schema_keywords_for_response(): array {","+\t\tif ( ! isset( $this->allowed_schema_keyword_lookup ) ) {","+\t\t\t$this->allowed_schema_keyword_lookup = array_fill_keys( wp_get_json_schema_allowed_keywords( 'draft-04' ), true );","+\t\t}","+","+\t\treturn $this->allowed_schema_keyword_lookup;","+\t}","+"," \t/**"," \t * Transforms an ability schema for REST response output."," \t *","@@ -258,17 +270,7 @@ private function prepare_schema_for_response( array $schema ): array {"," \t\t\t}"," \t\t}"," ","-\t\t// Computed once and reused across the recursive calls for every schema node.","-\t\tstatic $allowed_keywords = null;","-\t\t$allowed_keywords      ??= array_fill_keys(","-\t\t\tarray_merge(","-\t\t\t\trest_get_allowed_schema_keywords(),","-\t\t\t\tself::ADDITIONAL_ALLOWED_SCHEMA_KEYWORDS","-\t\t\t),","-\t\t\ttrue","-\t\t);","-","-\t\t$schema = array_intersect_key( $schema, $allowed_keywords );","+\t\t$schema = array_intersect_key( $schema, $this->get_allowed_schema_keywords_for_response() );"," "," \t\t// Collect draft-03 per-property `required: true` flags into a draft-04"," \t\t// `required` array of property names on the parent object schema."],"additions":33,"deletions":31,"truncated":false},{"path":"src/wp-settings.php","lines":["@@ -313,6 +313,7 @@"," require ABSPATH . WPINC . '/abilities-api.php';"," require ABSPATH . WPINC . '/abilities.php';"," require ABSPATH . WPINC . '/rest-api.php';","+require ABSPATH . WPINC . '/json-schema.php';"," require ABSPATH . WPINC . '/rest-api/class-wp-rest-server.php';"," require ABSPATH . WPINC . '/rest-api/class-wp-rest-response.php';"," require ABSPATH . WPINC . '/rest-api/class-wp-rest-request.php';"],"additions":1,"deletions":0,"truncated":false},{"path":"tests/phpunit/tests/abilities-api/wpRegisterCoreAbilities.php","lines":["@@ -385,9 +385,7 @@ public function test_core_get_environment_info_rejects_invalid_fields(): void {"," \t * @ticket 64384"," \t */"," \tpublic function test_core_abilities_schemas_use_only_valid_keywords(): void {","-\t\t$allowed_keywords = rest_get_allowed_schema_keywords();","-\t\t// Add 'required' which is valid at the property level for draft-04.","-\t\t$allowed_keywords[] = 'required';","+\t\t$allowed_keywords = wp_get_json_schema_allowed_keywords( 'draft-04' );"," "," \t\t$abilities = wp_get_abilities();"," "],"additions":1,"deletions":3,"truncated":false},{"path":"tests/phpunit/tests/json-schema.php","lines":["@@ -0,0 +1,57 @@","+<?php","+/**","+ * JSON Schema functions.","+ *","+ * @package WordPress","+ * @subpackage JSON_Schema","+ */","+","+/**","+ * @group json-schema","+ */","+class Tests_JSON_Schema extends WP_UnitTestCase {","+","+\t/**","+\t * @ticket 64955","+\t */","+\tpublic function test_wp_get_json_schema_allowed_keywords_uses_rest_keywords_by_default() {","+\t\t$this->assertSame( rest_get_allowed_schema_keywords(), wp_get_json_schema_allowed_keywords() );","+\t\t$this->assertSame( rest_get_allowed_schema_keywords(), wp_get_json_schema_allowed_keywords( 'rest-api' ) );","+\t\t$this->assertSame( rest_get_allowed_schema_keywords(), wp_get_json_schema_allowed_keywords( 'unknown-context' ) );","+\t}","+","+\t/**","+\t * @ticket 64955","+\t */","+\tpublic function test_wp_get_json_schema_allowed_keywords_includes_draft_04_keywords() {","+\t\t$keywords = wp_get_json_schema_allowed_keywords( 'draft-04' );","+","+\t\t// Keywords the draft-04 profile adds on top of the REST keyword set.","+\t\tforeach ( array( '$schema', 'id', '$ref', 'required', 'allOf', 'not', 'definitions', 'dependencies', 'additionalItems' ) as $keyword ) {","+\t\t\t$this->assertContains( $keyword, $keywords );","+\t\t}","+","+\t\t// 'type' is a base REST keyword, not a draft-04 addition. Checking it","+\t\t// confirms the draft-04 profile is a superset that keeps the REST keywords.","+\t\t$this->assertContains( 'type', $keywords );","+\t}","+","+\t/**","+\t * @ticket 64955","+\t */","+\tpublic function test_wp_get_json_schema_allowed_keywords_filter_receives_schema_profile() {","+\t\t$schema_profiles = array();","+\t\t$filter          = static function ( $keywords, $schema_profile ) use ( &$schema_profiles ) {","+\t\t\t$schema_profiles[] = $schema_profile;","+\t\t\t$keywords[]        = 'xCustomKeyword';","+","+\t\t\treturn $keywords;","+\t\t};","+","+\t\tadd_filter( 'wp_json_schema_allowed_keywords', $filter, 10, 2 );","+\t\t$keywords = wp_get_json_schema_allowed_keywords( 'draft-04' );","+","+\t\t$this->assertContains( 'xCustomKeyword', $keywords );","+\t\t$this->assertSame( array( 'draft-04' ), $schema_profiles );","+\t}","+}"],"additions":57,"deletions":0,"truncated":false},{"path":"tests/phpunit/tests/rest-api/rest-server.php","lines":["@@ -2519,6 +2519,47 @@ public function test_get_data_for_route_includes_permitted_schema_keywords() {"," \t\t$this->assertSameSetsWithIndex( $expected, $args['param'] );"," \t}"," ","+\t/**","+\t * @ticket 64955","+\t */","+\tpublic function test_get_data_for_route_includes_filtered_json_schema_keywords() {","+\t\t$filter = static function ( $keywords, $schema_profile ) {","+\t\t\tif ( 'rest-api' === $schema_profile ) {","+\t\t\t\t$keywords[] = 'xRestApiKeyword';","+\t\t\t}","+","+\t\t\treturn $keywords;","+\t\t};","+","+\t\tadd_filter( 'wp_json_schema_allowed_keywords', $filter, 10, 2 );","+","+\t\tregister_rest_route(","+\t\t\t'test-ns/v1',","+\t\t\t'/test',","+\t\t\tarray(","+\t\t\t\t'methods'             => 'POST',","+\t\t\t\t'callback'            => static function () {","+\t\t\t\t\treturn new WP_REST_Response( 'test' );","+\t\t\t\t},","+\t\t\t\t'permission_callback' => '__return_true',","+\t\t\t\t'args'                => array(","+\t\t\t\t\t'param' => array(","+\t\t\t\t\t\t'type'            => 'string',","+\t\t\t\t\t\t'xRestApiKeyword' => true,","+\t\t\t\t\t\t'invalid'         => true,","+\t\t\t\t\t),","+\t\t\t\t),","+\t\t\t)","+\t\t);","+","+\t\t$response = rest_do_request( new WP_REST_Request( 'OPTIONS', '/test-ns/v1/test' ) );","+","+\t\t$args = $response->get_data()['endpoints'][0]['args'];","+","+\t\t$this->assertArrayHasKey( 'xRestApiKeyword', $args['param'] );","+\t\t$this->assertArrayNotHasKey( 'invalid', $args['param'] );","+\t}","+"," \t/**"," \t * @ticket 53056"," \t */",""],"additions":41,"deletions":0,"truncated":false}],"additions":206,"deletions":35,"truncated":false,"file_count":7},"error":null,"fetched_at":"2026-06-24T10:41:58.572066+00:00"}