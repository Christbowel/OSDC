"matchers\"`","+}","+","+type FingerprintMatcher struct {","+\tPos   string `json:\"pos\"`","+\tValue string `json:\"value\"`","+}","+","+type FingerprintVersionInfo struct {","+\tMethod string `json:\"method\"`","+\tPath   string `json:\"path\"`","+\tPart   string `json:\"part\"`","+\tRegex  string `json:\"regex\"`","+}","+","+type Fingerprint struct {","+\tName        string `json:\"name\"`","+\tDescription string `json:\"description\"`","+\tSeverity    string `json:\"severity\"`","+\tProduct     string `json:\"product\"`","+\tVendor      string `json:\"vendor\"`","+","+\tHttpInfo    FingerprintHttpInfo    `json:\"httpInfo\"`","+\tVersionInfo FingerprintVersionInfo `json:\"versionInfo\"`","+}","+","+type SecurityScanProvider struct {","+\tType  string `json:\"type\"`","+\tOwner string `json:\"owner\"`","+","+\tOnlineList string `json:\"onlineList\"`","+\tTargetURL  string `json:\"targetUrl\"`","+}","+","+type SecurityScanFinding struct {","+\tName      string `json:\"name\"`","+\tProduct   string `json:\"product\"`","+\tVendor    string `json:\"vendor\"`","+\tVersion   string `json:\"version\"`","+\tSeverity  string `json:\"severity\"`","+\tTargetURL string `json:\"targetUrl\"`","+\tCVEs      []CVE  `json:\"cves\"`","+}","+","+type securityScanTarget struct {","+\tName    string","+\tBaseURL string","+}","+","+type onlineScanLists struct {","+\tCVEList         []CVE         `json:\"cveList\"`","+\tFingerprintList []Fingerprint `json:\"fingerprintList\"`","+}","+","+func NewScanProviderFromProvider(provider *object.Provider) SecurityScanProvider {","+\treturn SecurityScanProvider{Type: provider.SubType, Owner: provider.Owner, OnlineList: provider.Endpoint, TargetURL: provider.Content}","+}","+","+func (v SecurityScanProvider) Scan(target string, command string) (string, error) {","+\t_ = command","+","+\tif !strings.EqualFold(v.Type, \"Site\") && !strings.EqualFold(v.Type, \"Url\") {","+\t\treturn \"\", fmt.Errorf(\"scan provider sub type: %s is not supported\", v.Type)","+\t}","+","+\tcves, fingerprints, err := getOnlineScanLists(dataSourceUrl)","+\tif err != nil {","+\t\treturn \"\", err","+\t}","+","+\truntimeCVEList := buildCVEMap(cves)","+\truntimeFingerprintList := buildFingerprintList(fingerprints)","+","+\tif strings.TrimSpace(v.OnlineList) != \"\" {","+\t\tonlineCVEList, onlineFingerprintList, err := getOnlineScanLists(v.OnlineList)","+\t\tif err != nil {","+\t\t\tlogs.Warning(\"scan: failed to load online scan lists, onlineList = %s, err = %v\", v.OnlineList, err)","+\t\t} else {","+\t\t\tmergeOnlineCVEs(runtimeCVEList, onlineCVEList)","+\t\t\truntimeFingerprintList = mergeOnlineFingerprints(runtimeFingerprintList, onlineFingerprintList)","+\t\t}","+\t}","+","+\tscanTargets, err := v.getScanTargets(strings.TrimSpace(target))","+\tif err != nil {","+\t\treturn \"\", err","+\t}","+","+\tclient := &http.Client{","+\t\tTimeout: 5 * time.Second,","+\t\tTransport: &http.Transport{","+\t\t\tTLSClientConfig: &tls.Config{InsecureSkipVerify: true}, //nolint:gosec","+\t\t},","+\t\tCheckRedirect: func(_ *http.Request, _ []*http.Request) error {","+\t\t\treturn http.ErrUseLastResponse","+\t\t},","+\t}","+","+\tfindings := make([]SecurityScanFinding, 0)","+\tfindingMap := map[string]int{}","+","+\tfor _, scanTarget := range scanTargets {","+\t\thasFindingForTarget := false","+\t\tfor _, fingerprint := range runtimeFingerprintList {","+\t\t\tmatched, err := isFingerprintMatched(client, scanTarget.BaseURL, fingerprint)","+\t\t\tif err != nil {","+\t\t\t\tlogs.Warning(\"scan: fingerprint probe failed, target = %s, fingerprint = %s, err = %v\", scanTarget.Name, fingerprint.Name, err)","+\t\t\t\tcontinue","+\t\t\t}","+","+\t\t\tif !matched {","+\t\t\t\tcontinue","+\t\t\t}","+","+\t\t\thasFindingForTarget = true","+","+\t\t\tversion, err := getFingerprintVersion(client, scanTarget.BaseURL, fingerprint)","+\t\t\tif err != nil {","+\t\t\t\tlogs.Warning(\"scan: version probe failed, target = %s, fingerprint = %s, err = %v\", scanTarget.Name, fingerprint.Name, err)","+\t\t\t}","+","+\t\t\tcves := filterMatchedCVEs(runtimeCVEList[fingerprint.Name], version)","+\t\t\tfinding := SecurityScanFinding{","+\t\t\t\tName:      scanTarget.Name,","+\t\t\t\tProduct:   fingerprint.Product,","+\t\t\t\tVendor:    fingerprint.Vendor,","+\t\t\t\tVersion:   version,","+\t\t\t\tSeverity:  fingerprint.Severity,","+\t\t\t\tTargetURL: scanTarget.BaseURL,","+\t\t\t\tCVEs:      cves,","+\t\t\t}","+\t\t\tfinding = normalizeUnknownFinding(finding)","+","+\t\t\tfindingKey := fmt.Sprintf(\"%s|%s\", finding.Name, finding.TargetURL)","+\t\t\tif idx, ok := findingMap[findingKey]; ok {","+\t\t\t\tfindings[idx] = mergeFinding(findings[idx], finding)","+\t\t\t\tcontinue","+\t\t\t}","+","+\t\t\tfindingMap[findingKey] = len(findings)","+\t\t\tfindings = append(findings, finding)","+\t\t}","+","+\t\tif !hasFindingForTarget {","+\t\t\tunknownFinding := normalizeUnknownFinding(SecurityScanFinding{","+\t\t\t\tName:      scanTarget.Name,","+\t\t\t\tTargetURL: scanTarget.BaseURL,","+\t\t\t\tCVEs:      []CVE{},","+\t\t\t})","+\t\t\tfindingMapKey := fmt.Sprintf(\"%s|%s\", unknownFinding.Name, unknownFinding.TargetURL)","+\t\t\tif idx, ok := findingMap[findingMapKey]; ok {","+\t\t\t\tfindings[idx] = mergeFinding(findings[idx], unknownFinding)","+\t\t\t} else {","+\t\t\t\tfindingMap[findingMapKey] = len(findings)","+\t\t\t\tfindings = append(findings, unknownFinding)","+\t\t\t}","+\t\t}","+\t}","+","+\tsort.Slice(findings, func(i, j int) bool {","+\t\tif findings[i].TargetURL == findings[j].TargetURL {","+\t\t\treturn findings[i].Name < findings[j].Name","+\t\t}","+\t\treturn findings[i].TargetURL < findings[j].TargetURL","+\t})","+","+\tresultBytes, err := json.Marshal(findings)","+\tif err != nil {","+\t\treturn \"\", err","+\t}","+","+\treturn string(resultBytes), nil","+}","+","+func (v SecurityScanProvider) ParseResult(rawResult string) (string, error) {","+\tvar findings []SecurityScanFinding","+\tif err := json.Unmarshal([]byte(rawResult), &findings); err != nil {","+\t\treturn \"\", err","+\t}","+","+\tresultBytes, err := json.Marshal(findings)","+\tif err != nil {","+\t\treturn \"\", err","+\t}","+","+\treturn string(resultBytes), nil","+}","+","+func (v SecurityScanProvider) GetResultSummary(result string) string {","+\tvar findings []SecurityScanFinding","+\tif err := json.Unmarshal([]byte(result), &findings); err != nil {","+\t\treturn fmt.Sprintf(\"invalid result: %v\", err)","+\t}","+","+\ttargetSet := map[string]struct{}{}","+\tcveCount := 0","+\tfor _, finding := range findings {","+\t\ttargetSet[finding.TargetURL] = struct{}{}","+\t\tcveCount += len(finding.CVEs)","+\t}","+","+\treturn fmt.Sprintf(\"targets=%d findings=%d cves=%d\", len(targetSet), len(findings), cveCount)","+}","+","+func (v SecurityScanProvider) getScanTargets(target string) ([]securityScanTarget, error) {","+\tif strings.EqualFold(v.Type, \"Site\") {","+\t\tsites, err := object.GetSites(v.Owner)","+\t\tif err != nil {","+\t\t\treturn nil, err","+\t\t}","+","+\t\tres := make([]securityScanTarget, 0)","+\t\tfor _, site := range sites {","+\t\t\tif site == nil {","+\t\t\t\tcontinue","+\t\t\t}","+","+\t\t\tfor _, baseURL := range getSiteBaseURLs(site) {","+\t\t\t\tif target != \"\" && !strings.Contains(baseURL, target) {","+\t\t\t\t\tcontinue","+\t\t\t\t}","+\t\t\t\tres = append(res, securityScanTarget{Name: site.Name, BaseURL: baseURL})","+\t\t\t}","+\t\t}","+\t\treturn res, nil","+\t}","+","+\ttargetURL := strings.TrimSpace(target)","+\tif targetURL == \"\" {","+\t\ttargetURL = strings.TrimSpace(v.TargetURL)","+\t}","+\tif targetURL == \"\" {","+\t\treturn nil, fmt.Errorf(\"target URL is required for Url scan\")","+\t}","+","+\ttargetURLs := splitScanTargets(targetURL)","+\tif len(targetURLs) == 0 {","+\t\treturn nil, fmt.Errorf(\"target URL is required for Url scan\")","+\t}","+","+\tres := make([]securityScanTarget, 0, len(targetURLs))","+\tfor _, currentTargetURL := range targetURLs {","+\t\ttargetName, baseURL, err := normalizeScanBaseURL(currentTargetURL)","+\t\tif err != nil {","+\t\t\treturn nil, err","+\t\t}","+","+\t\tres = append(res, securityScanTarget{Name: targetName, BaseURL: baseURL})","+\t}","+","+\treturn res, nil","+}"],"additions":297,"deletions":0,"truncated":false},{"path":"scan/util.go","lines":["@@ -0,0 +1,694 @@","+package scan","+","+import (","+\t\"encoding/json\"","+\t\"fmt\"","+\t\"io\"","+\t\"net/http\"","+\t\"net/url\"","+\t\"regexp\"","+\t\"strconv\"","+\t\"strings\"","+\t\"time\"","+","+\t\"github.com/beego/beego/v2/core/logs\"","+\t\"github.com/casdoor/casdoor/object\"","+)","+","+func getSiteBaseURLs(site *object.Site) []string {","+\tres := []string{}","+\tseen := map[string]struct{}{}","+","+\tschemes := []string{\"http\"}","+\tlowerSslMode := strings.ToLower(strings.TrimSpace(site.SslMode))","+\tif strings.Contains(lowerSslMode, \"https\") || strings.Contains(lowerSslMode, \"enable\") {","+\t\tschemes = []string{\"https\"}","+\t} else if lowerSslMode == \"\" || strings.Contains(lowerSslMode, \"auto\") {","+\t\tschemes = []string{\"https\", \"http\"}","+\t}","+","+\tappendCandidate := func(raw string) {","+\t\traw = strings.TrimSpace(raw)","+\t\tif raw == \"\" {","+\t\t\treturn","+\t\t}","+","+\t\tif strings.HasPrefix(raw, \"http://\") || strings.HasPrefix(raw, \"https://\") {","+\t\t\tu, err := url.Parse(raw)","+\t\t\tif err != nil || u.Host == \"\" {","+\t\t\t\treturn","+\t\t\t}","+\t\t\tbaseURL := fmt.Sprintf(\"%s://%s\", u.Scheme, u.Host)","+\t\t\tif _, ok := seen[baseURL]; !ok {","+\t\t\t\tseen[baseURL] = struct{}{}","+\t\t\t\tres = append(res, baseURL)","+\t\t\t}","+\t\t\treturn","+\t\t}","+","+\t\traw = strings.TrimPrefix(raw, \"//\")","+\t\tfor _, scheme := range schemes {","+\t\t\tbaseURL := fmt.Sprintf(\"%s://%s\", scheme, raw)","+\t\t\tu, err := url.Parse(baseURL)","+\t\t\tif err != nil || u.Host == \"\" {","+\t\t\t\tcontinue","+\t\t\t}","+\t\t\tif _, ok := seen[baseURL]; ok {","+\t\t\t\tcontinue","+\t\t\t}","+\t\t\tseen[baseURL] = stru