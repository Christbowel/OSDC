extcloud/e2e-test-server/docker'","+import { LoginPage } from '../../support/sections/LoginPage.ts'","+","+test.describe('Login: Redirect', () => {","+\tlet user: User","+","+\ttest.beforeAll(async () => {","+\t\tuser = await createRandomUser()","+\t})","+","+\ttest.afterAll(async () => {","+\t\tawait runOcc(['user:delete', user.userId])","+\t})","+","+\ttest('redirects to login with redirect_url when session expires', async ({ page, context }) => {","+\t\tawait login(context.request, user)","+\t\tawait page.goto('/settings/user#profile')","+","+\t\t// Wait for the profile settings checkbox to confirm the page has loaded","+\t\tawait expect(page.getByRole('checkbox', { name: /Enable profile/i })).toBeVisible()","+","+\t\t// Simulate session expiry by clearing all cookies","+\t\tawait context.clearCookies()","+","+\t\t// Clicking the checkbox triggers an authenticated request that returns 302 to login","+\t\tawait page.getByRole('checkbox', { name: /Enable profile/i }).click({ force: true })","+","+\t\tawait expect(page).toHaveURL(/\\/login/i)","+\t\tawait expect(page).toHaveURL(/redirect_url=/)","+\t})","+","+\ttest('redirect_url parameter redirects to the original page after login', async ({ page }) => {","+\t\tconst redirectTarget = 'settings/user#profile'","+\t\tawait page.goto(redirectTarget)","+\t\tawait expect(page).toHaveURL(new RegExp(`/login\\\\?redirect_url=(\\/index.php\\/)?${redirectTarget}`))","+","+\t\tconst loginPage = new LoginPage(page)","+\t\tawait expect(loginPage.usernameInput()).toBeVisible()","+\t\tawait loginPage.login(user.userId, user.password)","+","+\t\tawait expect(page).toHaveURL(/\\/settings\\/user/)","+\t\tawait expect(page.getByRole('checkbox', { name: /Enable profile/i })).toBeVisible()","+\t})","+})"],"additions":52,"deletions":0,"truncated":false},{"path":"tests/playwright/e2e/login/login.spec.ts","lines":["@@ -0,0 +1,87 @@","+/*","+ * SPDX-FileCopyrightText: 2026 Nextcloud GmbH and Nextcloud contributors","+ * SPDX-License-Identifier: AGPL-3.0-or-later","+ */","+","+import { expect, test as baseTest } from '@playwright/test'","+import { User } from '@nextcloud/e2e-test-server'","+import { createRandomUser, login } from '@nextcloud/e2e-test-server/playwright'","+import { runOcc } from '@nextcloud/e2e-test-server/docker'","+import { AccountMenuPage } from '../../support/sections/AccountMenuPage.ts'","+import { LoginPage } from '../../support/sections/LoginPage.ts'","+","+const test = baseTest.extend<{","+\tuser: User","+\tdisabledUser: User","+}>({","+\tuser: async ({}, use) => {","+\t\tconst user = await createRandomUser()","+\t\tawait use(user)","+\t\tawait runOcc(['user:delete', user.userId])","+\t},","+\tdisabledUser: async ({}, use) => {","+\t\tconst user = await createRandomUser()","+\t\tawait runOcc(['user:disable', user.userId])","+\t\tawait use(user)","+\t\tawait runOcc(['user:delete', user.userId])","+\t},","+})","+","+test.describe('Login', () => {","+\ttest.beforeAll(async () => {","+\t\tawait runOcc(['config:system:set', 'auth.bruteforce.protection.enabled', '--value', 'false', '--type', 'bool'])","+\t})","+","+\ttest.afterAll(async () => {","+\t\tawait runOcc(['config:system:delete', 'auth.bruteforce.protection.enabled'])","+\t})","+","+\ttest('successful login lands on the dashboard', async ({ page, user }) => {","+\t\tconst loginPage = new LoginPage(page)","+\t\tawait loginPage.goto()","+\t\tawait loginPage.login(user.userId, user.password)","+","+\t\tawait expect(page).toHaveURL(/apps\\/dashboard(\\/|$)/)","+\t})","+","+\ttest('wrong password shows error and marks password field invalid', async ({ page, user }) => {","+\t\tconst loginPage = new LoginPage(page)","+\t\tawait loginPage.goto()","+\t\tawait loginPage.login(user.userId, `${user.password}--wrong`)","+","+\t\tawait expect(page).toHaveURL(/\\/login/)","+\t\tawait expect(page.getByText(/Wrong login or password/i)).toBeVisible()","+\t\tawait expect(loginPage.passwordInput().and(page.locator(':invalid'))).toHaveCount(1)",