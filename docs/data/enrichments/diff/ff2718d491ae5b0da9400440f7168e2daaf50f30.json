biner()","+\tresp := &fakePipelineResponse{}","+","+\tmc.Combine(&tempopb.SearchMetrics{","+\t\tInspectedBytes:    100,","+\t\tBackendReads:      2,","+\t\tBackendBytes:      4096,","+\t\tAdditionalMetrics: map[string]int64{tempopb.AdditionalMetricCacheHits: 5},","+\t}, resp)","+\tmc.Combine(&tempopb.SearchMetrics{","+\t\tInspectedBytes:    200,","+\t\tBackendReads:      3,","+\t\tBackendBytes:      8192,","+\t\tAdditionalMetrics: map[string]int64{tempopb.AdditionalMetricCacheHits: 7, tempopb.AdditionalMetricCacheMisses: 1},","+\t}, resp)","+","+\tassert.Equal(t, uint64(300), mc.Metrics.InspectedBytes)","+\tassert.Equal(t, uint64(5), mc.Metrics.BackendReads)","+\tassert.Equal(t, uint64(12288), mc.Metrics.BackendBytes)","+\tassert.Equal(t, int64(12), mc.Metrics.AdditionalMetrics[tempopb.AdditionalMetricCacheHits])","+\tassert.Equal(t, int64(1), mc.Metrics.AdditionalMetrics[tempopb.AdditionalMetricCacheMisses])","+}","+","+func TestSearchMetricsCombiner_CacheHitSuppressesNewFields(t *testing.T) {","+\tmc := NewSearchMetricsCombiner()","+\tcacheHit := &fakePipelineResponse{cacheHit: true}","+\tmc.Combine(&tempopb.SearchMetrics{","+\t\tInspectedBytes:    100,","+\t\tBackendReads:      2,","+\t\tBackendBytes:      4096,","+\t\tAdditionalMetrics: map[string]int64{tempopb.AdditionalMetricCacheHits: 5},","+\t}, cacheHit)","+\t// CompletedJobs still increments on cache hit (matches existing semantics).","+\tassert.Equal(t, uint32(1), mc.Metrics.CompletedJobs)","+\tassert.Equal(t, uint64(0), mc.Metrics.InspectedBytes)","+\tassert.Equal(t, uint64(0), mc.Metrics.BackendReads)","+\tassert.Equal(t, uint64(0), mc.Metrics.BackendBytes)","+\tassert.Empty(t, mc.Metrics.AdditionalMetrics)","+}","+","+func TestSearchMetricsCombiner_CombineMetadataDoesNotPullNewFields(t *testing.T) {","+\t// Regression guard: CombineMetadata is for sharder-emitted totals; it must","+\t// not accumulate the new backend/cache fields.","+\tmc := NewSearchMetricsCombiner()","+\tmc.CombineMetadata(&tempopb.SearchMetrics{","+\t\tTotalBlocks:       10,","+\t\tTotalJobs:         5,","+\t\tTotalBlockBytes:   1024,","+\t\tBackendReads:      99,","+\t\tBackendBytes:      99999,","+\t\tAdditionalMetrics: map[string]int64{tempopb.AdditionalMetricCacheHits: 99},","+\t}, nil)","+\tassert.Equal(t, uint32(10), mc.Metrics.TotalBlocks)","+\tassert.Equal(t, uint64(0), mc.Metrics.BackendReads)","+\tassert.Equal(t, uint64(0), mc.Metrics.BackendBytes)","+\tassert.Empty(t, mc.Metrics.AdditionalMetrics)","+}","+","+func TestSearchMetricsCombiner_NilInputIsNoOp(t *testing.T) {","+\tmc := NewSearchMetricsCombiner()","+\tmc.Combine(nil, &fakePipelineResponse{})","+\tassert.Equal(t, uint32(0), mc.Metrics.CompletedJobs)","+}","+","+func TestTraceByIDMetricsCombiner_SumsNewFields(t *testing.T) {","+\tmc := NewTraceByIDMetricsCombiner()","+\tresp := &fakePipelineResponse{}","+\tmc.Combine(&tempopb.TraceByIDMetrics{","+\t\tInspectedBytes:    50,","+\t\tBackendReads:      1,","+\t\tBackendBytes:      2048,","+\t\tAdditionalMetrics: map[string]int64{tempopb.AdditionalMetricCacheHits: 3},","+\t}, resp)","+\tmc.Combine(&tempopb.TraceByIDMetrics{","+\t\tBackendReads:      2,","+\t\tBackendBytes:      1024,","+\t\tAdditionalMetrics: map[string]int64{tempopb.AdditionalMetricCacheHits: 4},","+\t}, resp)","+\tassert.Equal(t, uint64(50), mc.Metrics.InspectedBytes)","+\tassert.Equal(t, uint64(3), mc.Metrics.BackendReads)","+\tassert.Equal(t, uint64(3072), mc.Metrics.BackendBytes)","+\tassert.Equal(t, int64(7), mc.Metrics.AdditionalMetrics[tempopb.AdditionalMetricCacheHits])","+}","+","+func TestMetadataMetricsCombiner_SumsNewFields(t *testing.T) {","+\tmc := NewMetadataMetricsCombiner()","+\tresp := &fakePipelineResponse{}","+\tmc.Combine(&tempopb.MetadataMetrics{","+\t\tInspectedBytes:    100,","+\t\tBackendReads:      4,","+\t\tBackendBytes:      4096,","+\t\tAdditionalMetrics: map[string]int64{tempopb.AdditionalMetricCacheHits: 8},","+\t}, resp)","+\tassert.Equal(t, uint64(100), mc.Metrics.InspectedBytes)","+\tassert.Equal(t, uint64(4), mc.Metrics.BackendReads)","+\tassert.Equal(t, uint64(4096), mc.Metrics.BackendBytes)","+\tassert.Equal(t, int64(8), mc.Metrics.AdditionalMetrics[tempopb.AdditionalMetricCacheHits])","+}","+","+func TestQueryRangeMetricsCombiner_SumsNewFields(t *testing.T) {","+\tmc := NewQueryRangeMetricsCombiner()","+\tresp := &fakePipelineResponse{}","+\t// Job response (non-metadata).","+\tmc.Combine(&tempopb.SearchMetrics{","+\t\tInspectedBytes:    200,","+\t\tBackendReads:      5,","+\t\tBackendBytes:      8192,","+\t\tAdditionalMetrics: map[string]int64{tempopb.AdditionalMetricCacheHits: 9},","+\t}, resp)","+\tassert.Equal(t, uint64(200), mc.Metrics.InspectedBytes)","+\tassert.Equal(t, uint64(5), mc.Metrics.BackendReads)","+\tassert.Equal(t, uint64(8192), mc.Metrics.BackendBytes)","+\tassert.Equal(t, int64(9), mc.Metrics.AdditionalMetrics[tempopb.AdditionalMetricCacheHits])","+}","+","+func TestMergeAdditionalMetrics(t *testing.T) {","+\t// nil/empty source is no-op.","+\tassert.Nil(t, mergeAdditionalMetrics(nil, nil))","+\tassert.Nil(t, mergeAdditionalMetrics(nil, map[string]int64{}))","+","+\t// Allocates dst lazily and copies entries.","+\tdst := mergeAdditionalMetrics(nil, map[string]int64{\"a\": 1, \"b\": 2})","+\tassert.Equal(t, int64(1), dst[\"a\"])","+\tassert.Equal(t, int64(2), dst[\"b\"])","+","+\t// Sums into existing dst keys.","+\tdst = mergeAdditionalMetrics(dst, map[string]int64{\"a\": 5, \"c\": 7})","+\tassert.Equal(t, int64(6), dst[\"a\"])","+\tassert.Equal(t, int64(2), dst[\"b\"])","+\tassert.Equal(t, int64(7), dst[\"c\"])","+}"],"additions":159,"deletions":0,"truncated":false},{"path":"modules/frontend/handler.go","lines":["@@ -11,6 +11,7 @@ import ("," "," \t\"github.com/grafana/dskit/flagext\""," \t\"github.com/grafana/dskit/grpcutil\"","+\t\"github.com/grafana/tempo/modules/frontend/pipeline\""," \t\"github.com/grafana/tempo/pkg/util\""," \t\"go.opentelemetry.io/otel/attribute\""," \t\"go.opentelemetry.io/otel/trace\"","@