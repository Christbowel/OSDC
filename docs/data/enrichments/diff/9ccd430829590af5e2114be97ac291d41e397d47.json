 "," func TestVectorSearch_AuthzDenyAllReturnsEmpty(t *testing.T) {","-\t// When BatchCheck denies every row, the handler returns an empty result set.","-\taccess := &fakeAccessClient{","-\t\tallow: func(string, string) bool { return false },","-\t}","+\t// When BatchCheck denies every row, the handler should return an empty","+\t// result set (not an error).","+\taccess := &fakeAccessClient{allow: func(string, string) bool { return false }}"," \tbackend := &fakeVectorBackend{"," \t\tresults: []vector.VectorSearchResult{{UID: \"u1\", Title: \"T1\", Score: 0.1}},"," \t}","@@ -389,7 +403,7 @@ func TestVectorSearch_NoUserInContextReturnsUnauthenticated(t *testing.T) {"," \tassert.Equal(t, codes.Unauthenticated, status.Code(err))"," }"," ","-func TestVectorSearch_AuthzBatchCheckErrorReturnsInternal(t *testing.T) {","+func TestVectorSearch_AuthzCompileErrorReturnsInternal(t *testing.T) {"," \taccess := &erroringAccessClient{err: errors.New(\"authz service is down\")}"," \tbackend := &fakeVectorBackend{"," \t\tresults: []vector.VectorSearchResult{{UID: \"u1\", Score: 0.1}},"],"additions":20,"deletions":6,"truncated":false},{"path":"pkg/storage/unified/search/embed/backfill/backfill_test.go","lines":["@@ -0,0 +1,343 @@","+package backfill","+","+import (","+\t\"context\"","+\t\"encoding/json\"","+\t\"testing\"","+","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+","+\t\"github.com/grafana/grafana/pkg/storage/unified/search/embed\"","+\t\"github.com/grafana/grafana/pkg/storage/unified/search/embed/dashboard\"","+\t\"github.com/grafana/grafana/pkg/storage/unified/search/embed/embedder\"","+\t\"github.com/grafana/grafana/pkg/storage/unified/search/vector\"","+)","+","+// minimalDashboardJSON returns a small dashboard payload the dashboard","+// extractor will turn into a single panel item.","+func minimalDashboardJSON(uid, title string) []byte {","+\tbody, _ := json.Marshal(map[string]any{","+\t\t\"uid\":   uid,","+\t\t\"title\": title,","+\t\t\"panels\": []any{","+\t\t\tmap[string]any{","+\t\t\t\t\"id\":          1,","+\t\t\t\t\"title\":       \"CPU\",","+\t\t\t\t\"description\": \"CPU usage\",","+\t\t\t},","+\t\t},","+\t})","+\treturn body","+}","+","+// makeListItem packages a minimal dashboard JSON into a listItem with the","+// given namespace, name, and RV.","+func makeListItem(ns, name string, rv int64) listItem {","+\treturn listItem{","+\t\tNamespace: ns,","+\t\tName:      name,","+\t\tRV:        rv,","+\t\tValue:     minimalDashboardJSON(name, name+\"-title\"),","+\t}","+}","+","+func newBackfiller(t *testing.T, storage *fakeStorage, vec *fakeVector) *VectorBackfiller {","+\tt.Helper()","+\temb := newFakeEmbedder(&fakeText{dim: 4})","+\tb, err := NewVectorBackfiller(Options{","+\t\tStorage:       storage,","+\t\tVectorBackend: vec,","+\t\tEmbedder:      emb,","+\t\tBatchEmbedder: embedder.NewBatchEmbedder(*emb),","+\t\tBuilders:      []embed.Builder{dashboard.New()},","+\t})","+\trequire.NoError(t, err)","+\treturn b","+}","+","+func TestRunBackfill_NoIncompleteJobs_NoOp(t *testing.T) {","+\tvec := newFakeVector()","+\to := newBackfiller(t, newFakeStorage(), vec)","+\to.runBackfill(context.Background())","+\tassert.Empty(t, vec.checkpoints)","+\tassert.Empty(t, vec.completedJobIDs)","+}","+","+func TestRun_LockUnavailable_SkipsAllWork(t *testing.T) {","+\tstorage := newFakeStorage()","+\tstorage.listItems = []listItem{makeListItem(\"ns\", \"a\", 1)}","+","+\tvec := newFakeVector()","+\tvec.lockUnavailable = true","+\tvec.jobs = []vector.BackfillJob{{","+\t\tID: 1, Model: \"test-model\", StoppingRV: 100,","+\t}}","+","+\to := newBackfiller(t, storage, vec)","+\trequire.NoError(t, o.Run(context.Background()))","+","+\tassert.Equal(t, 1, vec.lockAttempts, \"should attempt to acquire the lock\")","+\tassert.Equal(t, 0, vec.lockReleases, \"should not release a lock it didn't acquire\")","+\tassert.Empty(t, vec.checkpoints, \"no work should happen without the lock\")","+\tassert.Empty(t, vec.upserts)","+\tassert.Empty(t, vec.completedJobIDs)","+}","+","+func TestRun_LockAcquired_ReleasedOnReturn(t *testing.T) {","+\tvec := newFakeVector()","+\to := newBackfiller(t, newFakeStorage(), vec)","+\trequire.NoError(t, o.Run(context.Background()))","+","+\tassert.Equal(t, 1, vec.lockAttempts)","+\tassert.Equal(t, 1, vec.lockReleases, \"lock must be released when Run returns\")","+}","+","+func TestRunBackfillJob_HappyPath_EmbedsAndCompletes(t *testing.T) {","+\tstorage := newFakeStorage()","+\tstorage.listItems = []listItem{","+\t\tmakeListItem(\"ns-1\", \"dash-a\", 50),","+\t\tmakeListItem(\"ns-1\", \"dash-b\", 60),","+\t\tmakeListItem(\"ns-2\", \"dash-c\", 70),","+\t}","+","+\tvec := newFakeVector()","+\tvec.jobs = []vector.BackfillJob{{","+\t\tID: 42, Model: \"test-model\", StoppingRV: 100,","+\t}}","+","+\to := newBackfiller(t, storage, vec)","+\to.runBackfill(context.Background())","+","+\trequire.Len(t, vec.upserts, 3, \"one upsert per dashboard\")","+\trequire.Len(t, vec.completedJobIDs, 1)","+\tassert.Equal(t, int64(42), vec.completedJobIDs[0])","+","+\t// Checkpoint is deferred by one item: each item's continue token is","+\t// only persisted after the next Next()==true confirms its peek was","+\t// valid. The final item's token is never confirmed (iterator is","+\t// exhausted), so we get N-1 checkpoints for N items.","+\trequire.Len(t, vec.checkpoints, 2)","+\tfor _, c := range vec.checkpoints {","+\t\tassert.Empty(t, c.LastError, \"happy path leaves last_error empty\")","+\t}","+}","+","+func TestRunBackfillJob_SkipsExistingEmbeddings(t *testing.T) {","+\tstorage := newFakeStorage()","+\tstorage.listItems = []listItem{","+\t\tmakeListItem(\"ns-1\", \"dash-a\", 50),","+\t\tmakeListItem(\"ns-1\", \"dash-b\", 60),","+\t}","+","+\tvec := newFakeVector()","+\tvec.jobs = []vector.BackfillJob{{","+\t\tID: 1, Model: \"test-model\", StoppingRV: 100,","+\t}}","+\t// dash-a already has an embedding — backfill should skip it.","+\tvec.markExists(\"ns-1\", \"test-model\", \"dashboards\", \"dash-a\")","+","+\to := newBackfiller(t, storage, vec)","+\to.runBackfill(context.Background())","+","+\trequire.Len(t, vec.upserts, 1, \"only the missing dashboard is embedded\")","+\tv := vec.upserts[0][0]","+\tassert.Equal(t, \"dash-b\", v.UID)","+}","+","+func TestRunBackfillJob_SkipsItemsAboveStoppingRV(t *testing.T) {","+\tstorage := newFakeStorage()","+\tstorage.listItems = []listItem{","+\t\tmakeListItem(\"ns\", \"old\", 50),","+\t\tmakeListItem(\"ns\", \"new\", 999), // RV > stopping_rv","+\t}","+","+\tvec := newFakeVector()","+\tvec.jobs = []vector.BackfillJob{{","+\t\tID: 1, Model: \"test-model\", StoppingRV: 100,","+\t}}","+","+\to := newBackfiller(t, storage, vec)","+\to.runBackfill(context.Background())","+","+\trequire.Len(t, vec.upserts, 1, \"items past stopping_rv belong to the live worker\")","+\tassert.Equal(t, \"old\", vec.upserts[0][0].UID)","+}","+","+func TestRunBackfillJob_ResumesFromLastSeenKey(t *testing.T) {","+\tstorage := newFakeStorage()","+\tstorage.listItems = []listItem{","+\t\tmakeListItem(\"ns\", \"a\", 1),","+\t\tmakeListItem(\"ns\", \"b\", 2),","+\t\tmakeListItem(\"ns\", \"c\", 3),","+\t}","+","+\tvec := newFakeVector()","+\t// Pretend a previous run already processed items 0 + 1 (\"a\" and \"b\") and","+\t// checkpointed at \"tok-2\" (start at the third item) for the dashboards","+\t// builder.","+\tvec.jobs = []vector.BackfillJob{{","+\t\tID: 1, Model: \"test-model\", StoppingRV: 100,","+\t\tLastSeenKey: encodeCursor(\"dashboards\", \"tok-2\"),","+\t}}","+","+\to := newBackfiller(t, storage, vec)","+\to.runBackfill(context.Background())","+","+\trequire.Len(t, vec.upserts, 1, \"resume should only embed the remaining item\")","+\tassert.Equal(t, \"c\", vec.upserts[0][0].UID)","+\trequire.Len(t, vec.completedJobIDs, 1)","+}","+","+func TestRunBackfillJob_CursorForUnknownResource_StartsFromScratch(t *testing.T) {","+\tstorage := newFakeStorage()","+\tstorage.listItems = []listItem{","+\t\tmakeListItem(\"ns\", \"a\", 1),","+\t\tmakeListItem(\"ns\", \"b\", 2),","+\t}","+","+\tvec := newFakeVector()","+\t// Cursor refers to a Builder that's no longer registered. The","+\t// backfiller should ignore the cursor (not blindly trust the token","+\t// against the wrong keyspace) and run every registered Builder","+\t// from the beginning.","+\tvec.jobs = []vector.BackfillJob{{","+\t\tID: 1, Model: \"test-model\", StoppingRV: 100,","+\t\tLastSeenKey: encodeCursor(\"removed-resource\", \"tok-9999\"),","+\t}}","+","+\to := newBackfiller(t, storage, vec)","+\to.runBackfill(context.Background())","+","+\trequire.Len(t, vec.upserts, 2, \"every dashboard should be embedded after cursor is ignored\")","+\trequire.Len(t, vec.completedJobIDs, 1)","+}","+","+// A job pinned to a resource this instance doesn't know about almost","+// certainly belongs to another instance configured with a different set of","+// Builders. Leaving it untouched (no upserts, no complete, no error stamp)","+// lets the right instance drain it.","+func TestRunBackfillJob_TargetedUnknownResource_LeftUntouched(t *testing.T) {","+\tstorage := newFakeStorage()","+\tstorage.listItems = []listItem{makeListItem(\"ns\", \"a\", 1)}","+","+\tvec := newFakeVector()","+\tvec.jobs = []vector.BackfillJob{{","+\t\tID: 1, Model: \"test-model\", Resource: \"folders\", StoppingRV: 100,","+\t}}","+","+\to := newBackfiller(t, storage, vec)","+\to.runBackfill(context.Background())","+","+\tassert.Empty(t, vec.upserts, \"no builder for the targeted resource → no embeddings\")","+\tassert.Empty(t, vec.completedJobIDs, \"another instance may own this resource; do not complete it\")","+\tassert.Empty(t, vec.errorMarks, \"no error path on a deliberate skip\")","+\tassert.Empty(t, vec.checkpoints)","+}","+","+func TestRunBackfillJob_MalformedCursor_StartsFromScratch(t *testing.T) {","+\tstorage := newFakeStorage()","+\tstorage.listItems = []listItem{makeListItem(\"ns\", \"a\", 1)}","+","+\tvec := newFakeVector()","+\tvec.jobs = []vector.BackfillJob{{","+\t\tID: 1, Model: \"test-model\", StoppingRV: 100,","+\t\tLastSeenKey: \"not-json-at-all\",","+\t}}","+","+\to := newBackfiller(t, storage, vec)","+\to.runBackfill(context.Background())","+","+\trequire.Len(t, vec.upserts, 1, \"malformed cursor → start fresh, embed everything\")","+\trequire.Len(t, vec.completedJobIDs, 1)","+}","+","+// Jobs targeting a different model belong to another instance; the SQL","+// list query filters them server-side so this backfiller never sees them.","+// The fake mirrors that behavior — we assert nothing happens, in particular","+// that last_error is not stamped on a row another instance owns.","+func TestRunBackfillJob_DifferentModel_IgnoredCompletely(t *testing.T) {","+\tstorage := newFakeStorage()","+\tstorage.listItems = []listItem{makeListItem(\"ns\", \"a\", 1)}","+","+\tvec := newFakeVector()","+\tvec.jobs = []vector.BackfillJob{{","+\t\tID: 1, Model: \"some-other-instances-model\", StoppingRV: 100,","+\t}}","+","+\to := newBackfiller(t, storage, vec)","+\to.runBackfill(context.Background())","+","+\tassert.Empty(t, vec.upserts)","+\tassert.Empty(t, vec.completedJobIDs, \"another instance owns this job; do not complete it\")","+\tassert.Empty(t, vec.checkpoints)","+\tassert.Empty(t, vec.errorMarks, \"model mismatch must not pollute another instance's last_error\")","+}","+","+func TestRunBackfillJob_PaginatedAcrossPages(t *testing.T) {","+\t// Build a result set one page + 5 items long so the backfiller must","+\t// fetch exactly two pages.","+\tconst total = backfillPageSize + 5","+","+\tstorage := newFakeStorage()","+\tstorage.listItems = make([]listItem, total)","+\tfor i := range storage.listItems {","+\t\tstorage.listItems[i] = makeListItem(\"ns\", uniqName(i), int64(i+1))","+\t}","+","+\tvec := newFakeVector()","+\tvec.jobs = []vector.BackfillJob{{","+\t\tID: 7, Model: \"test-model\", StoppingRV: int64(total + 100),","+\t}}","+","+\to := newBackfiller(t, storage, vec)","+\to.runBackfill(context.Background())","+","+\tassert.Len(t, vec.upserts, total, \"every item across all pages is embedded\")","+\trequire.Len(t, vec.completedJobIDs, 1)","+\t// assert pagination","+\trequire.Len(t, storage.listCalls, 2, \"backfiller must request two pages\")","+\tassert.Empty(t, storage.listCalls[0], \"first page starts with an empty token\")","+\tassert.NotEmpty(t, storage.listCalls[1], \"second page must resume from a continue token\")","+}","+","+// TestRunBackfillJob_ExactPageMultiple exercises the boundary where total","+// item count is exactly N * backfillPageSize. A naive implementation would","+// emit a continue token built from the post-last-item peek (Name=\"\") and","+// re-feed it through ListIterator on the next page call, which the kv","+// backend rejects with \"name is required\". The fix defers the per-item","+// checkpoint by one Next()==true so the last item of a page is only","+// persisted after a confirming peek.","+func TestRunBackfillJob_ExactPageMultiple(t *testing.T) {","+\tconst total = backfillPageSize","+","+\tstorage := newFakeStorage()","+\tstorage.listItems = make([]listItem, total)","+\tfor i := range storage.listItems {","+\t\tstorage.listItems[i] = makeListItem(\"ns\", uniqName(i), int64(i+1))","+\t}","+","+\tvec := newFakeVector()","+\tvec.jobs = []vector.BackfillJob{{","+\t\tID: 9, Model: \"test-model\", StoppingRV: int64(total + 100),","+\t}}","+","+\to := newBackfiller(t, storage, vec)","+\to.runBackfill(context.Background())","+","+\tassert.Len(t, vec.upserts, total, \"every item is embedded\")","+\trequire.Len(t, vec.completedJobIDs, 1, \"job completes despite hitting the page boundary\")","+\tassert.Empty(t, vec.errorMarks, \"no error path on a clean exact-page run\")","+\t// Final item's continue token is never confirmed by a follow-up","+\t// Next()==true, so we persist N-1 checkpoints, never the broken one.","+\trequire.Len(t, vec.checkpoints, total-1)","+}","+","+func uniqName(i int) string {","+\tconst letters = \"abcdefghijklmnopqrstuvwxyz\"","+\tout := []byte{letters[i%26], letters[(i/26)%26]}","+\tif i >= 26*26 {","+\t\tout = append(out, letters[(i/(26*26))%26])","+\t}","+\treturn string(out)","+}"],"additions":343,"deletions":0,"truncated":false},{"path":"pkg/storage/unified/search/embed/backfill/backfiller.go","lines":["@@ -0,0 +1,308 @@","+package backfill","+","+import (","+\t\"context\"","+\t\"fmt\"","+\t\"sort\""],"additions":6,"deletions":0,"truncated":false}],"additions":448,"deletions":56,"truncated":true,"file_count":9},"error":null,"fetched_at":"2026-05-20T17:49:26.963626+00:00"}