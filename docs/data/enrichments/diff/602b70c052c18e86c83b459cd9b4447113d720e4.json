(t, actions, datasources.ActionQuery)","+\t})","+","+\tt.Run(\"flag on: emits only action set token\", func(t *testing.T) {","+\t\topenfeatureTestMutex.Lock()","+\t\tdefer func() {","+\t\t\t_ = openfeature.SetProviderAndWait(openfeature.NoopProvider{})","+\t\t\topenfeatureTestMutex.Unlock()","+\t\t}()","+","+\t\tprovider, err := featuremgmt.CreateStaticProviderWithStandardFlags(map[string]memprovider.InMemoryFlag{","+\t\t\tfeaturemgmt.FlagIamOnlyStoreDatasourceActionSets: setting.NewInMemoryFlag(featuremgmt.FlagIamOnlyStoreDatasourceActionSets, true),","+\t\t})","+\t\trequire.NoError(t, err)","+\t\trequire.NoError(t, openfeature.SetProviderAndWait(provider))","+","+\t\tsvc := &Service{options: dsOpts}","+\t\tactions, err := svc.mapPermission(\"Edit\")","+\t\trequire.NoError(t, err)","+\t\trequire.Len(t, actions, 1)","+\t\tassert.Equal(t, dsOpts.GetActionSetName(\"Edit\"), actions[0])","+\t})","+}","+","+func TestIsActionSetEnabledResource_Datasource(t *testing.T) {","+\tassert.True(t, isActionSetEnabledResource(datasources.ScopeRoot+\":query\"))","+\tassert.True(t, isActionSetEnabledResource(datasources.ScopeRoot+\":edit\"))","+\tassert.True(t, isActionSetEnabledResource(datasources.ScopeRoot+\":admin\"))","+}"],"additions":57,"deletions":0,"truncated":false},{"path":"pkg/services/featuremgmt/registry.go","lines":["@@ -2279,6 +2279,15 @@ var ("," \t\t\tOwner:        identityAccessTeam,"," \t\t\tExpression:   \"false\","," \t\t},","+\t\t{","+\t\t\tName:         \"iam.onlyStoreDatasourceActionSets\",","+\t\t\tDescription:  \"When storing datasource resource permissions, only store action sets and not the full list of underlying permissions\",","+\t\t\tStage:        FeatureStageExperimental,","+\t\t\tGenerate:     Generate{LegacyGo: true},","+\t\t\tHideFromDocs: true,","+\t\t\tOwner:        identityAccessTeam,","+\t\t\tExpression:   \"false\",","+\t\t},"," \t\t{"," \t\t\tName:         \"excludeRedundantManagedPermissions\","," \t\t\tDescription:  \"Exclude redundant in