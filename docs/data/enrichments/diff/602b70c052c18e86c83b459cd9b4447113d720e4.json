{"id":"602b70c052c18e86c83b459cd9b4447113d720e4","axis":"silent","repo":"grafana/grafana","sha":"602b70c052c18e86c83b459cd9b4447113d720e4","parsed":{"files":[{"path":"pkg/services/accesscontrol/resourcepermissions/service.go","lines":["@@ -461,6 +461,17 @@ func (s *Service) mapPermission(permission string) ([]string, error) {"," \t\t}"," \t}"," ","+\t// Write action set token for datasources. Granular actions are also written until","+\t// FlagIamOnlyStoreDatasourceActionSets is enabled (after the backfill migration has run).","+\tif s.options.Resource == datasources.ScopeRoot {","+\t\tactions = append(actions, s.options.GetActionSetName(permission))","+","+\t\tonlyActionSets, _ := openfeature.NewDefaultClient().BooleanValue(context.Background(), featuremgmt.FlagIamOnlyStoreDatasourceActionSets, false, openfeature.EvaluationContext{})","+\t\tif onlyActionSets {","+\t\t\treturn actions, nil","+\t\t}","+\t}","+"," \t// New resources with no legacy granular data go straight to action-set-only."," \tif s.options.Resource == accesscontrol.AlertingRoutesResource {"," \t\treturn []string{s.options.GetActionSetName(permission)}, nil","@@ -709,7 +720,8 @@ func isActionSetEnabledResource(action string) bool {"," \treturn strings.HasPrefix(action, dashboards.ScopeDashboardsRoot) ||"," \t\tstrings.HasPrefix(action, folder.ScopeFoldersRoot) ||"," \t\tstrings.HasPrefix(action, accesscontrol.AlertingRoutesKind) ||","-\t\tstrings.HasPrefix(action, serviceaccounts.ScopeServiceAccountRoot)","+\t\tstrings.HasPrefix(action, serviceaccounts.ScopeServiceAccountRoot) ||","+\t\tstrings.HasPrefix(action, datasources.ScopeRoot)"," }"," "," // scopeResource returns the resource prefix used for Resource fields in commands/queries."],"additions":13,"deletions":1,"truncated":false},{"path":"pkg/services/accesscontrol/resourcepermissions/service_test.go","lines":["@@ -17,6 +17,7 @@ import ("," \t\"github.com/grafana/grafana/pkg/services/accesscontrol\""," \t\"github.com/grafana/grafana/pkg/servic