} = payload;","+    if (!filePath?.trim()) return { error: 'File path is required', success: false };","+    if (path.isAbsolute(filePath) || filePath.split(/[/\\\\]/).includes('..')) {","+      return { error: `Invalid file path: ${filePath}`, success: false };","+    }","+","+    const execFileAsync = promisify(execFile);","+","+    // Probe HEAD via cat-file -e — exit 0 means the blob exists at HEAD.","+    let existsAtHead: boolean;","+    try {","+      await execFileAsync('git', ['cat-file', '-e', `HEAD:${filePath}`], {","+        cwd: dirPath,","+        timeout: 5000,","+      });","+      existsAtHead = true;","+    } catch {","+      existsAtHead = false;","+    }","+","+    try {","+      if (existsAtHead) {","+        await execFileAsync('git', ['checkout', 'HEAD', '--', filePath], {","+          cwd: dirPath,","+          timeout: 15_000,","+        });","+      } else {","+        // Unstage if the file is in the index (staged-add). `git rm --cached`","+        // exits non-zero on untracked paths, which is fine — swallow it.","+        try {","+          await execFileAsync('git', ['rm', '--cached', '--quiet', '--', filePath], {","+            cwd: dirPath,","+            timeout: 5000,","+          });","+        } catch {","+          // not staged — fall through to the disk-delete","+        }","+        await rm(path.resolve(dirPath, filePath), { force: true, recursive: false });","+      }","+      return { success: true };","+    } catch (error: any) {","+      const stderr: string = (error?.stderr ?? error?.message ?? '').toString().trim();","+      logger.debug('[revertGitFile] failed', { filePath, stderr });","+      return { error: stderr || 'git revert failed', success: false };","+    }","+  }"," }"],"additions":68,"deletions":1,"truncated":false},{"path":"locales/en-US/chat.json","lines":["@@ -891,6 +891,13 @@","   \"workingPanel.review.mode.unstaged\": \"Unstaged\",","   \"workingPanel.review.more\": \"More options\",","   \"workingPanel