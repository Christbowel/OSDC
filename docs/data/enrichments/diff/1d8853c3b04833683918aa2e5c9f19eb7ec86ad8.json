{"id":"1d8853c3b04833683918aa2e5c9f19eb7ec86ad8","axis":"silent","repo":"argoproj/argo-workflows","sha":"1d8853c3b04833683918aa2e5c9f19eb7ec86ad8","parsed":{"files":[{"path":".features/pending/13437-client-tls-server-mode.md","lines":["@@ -0,0 +1,15 @@","+Description: Extend client TLS certificate support in server mode","+Authors: [Miltiadis Alexis](https://github.com/miltalex)","+Component: CLI","+Issues: 13437","+","+Use `--client-certificate` and `--client-key` when an Argo Server or its proxy requires mutual TLS authentication.","+Both flags must be provided together.","+Use `--certificate-authority` to trust the certificate authority that signed the server certificate.","+The certificates are used by the gRPC and HTTP/1 clients, including artifact downloads with `argo cp`.","+","+For example, run `argo --argo-server argo.example.com:443 --secure --certificate-authority ca.crt --client-certificate client.crt --client-key client.key list`.","+","+In server mode, client certificates and certificate authorities embedded in a kubeconfig context are not used automatically.","+Pass the three flags explicitly when connecting through Argo Server.","+The flags do not have `ARGO_*` environment variable equivalents."],"additions":15,"deletions":0,"truncated":false},{"path":"cmd/argo/commands/client/conn.go","lines":["@@ -2,6 +2,7 @@ package client"," "," import ("," \t\"context\"","+\t\"errors\""," \t\"fmt\""," \t\"net/http\""," \t\"net/url\"","@@ -57,6 +58,14 @@ func AddAPIClientFlagsToCmd(cmd *cobra.Command) {"," }"," "," func NewAPIClient(ctx context.Context) (context.Context, apiclient.Client, error) {","+\t// Reuse the explicit kubectl client certificate flags in server mode.","+\tArgoServerOpts.ClientCert = overrides.AuthInfo.ClientCertificate","+\tArgoServerOpts.ClientKey = overrides.AuthInfo.ClientKey","+\tArgoServerOpts.CACert = overrides.ClusterInfo.CertificateAuthority","+\tif (ArgoServerOpts.ClientCert == \"\") != (ArgoServerOpts.ClientKey == \"\") {","+\t\treturn nil, nil, errors.New(\"--client-certificate and --client-key must be provided together\")","+\t}","+"," \tvar proxy func(*http.Request) (*url.URL, error)"," \tif overrides.ClusterInfo.ProxyURL != \"\" {"," \t\tproxyURL, err := url.Parse(overrides.ClusterInfo.ProxyURL)"],"additions":9,"deletions":0,"truncated":false},{"path":"cmd/argo/commands/client/conn_test.go","lines":["@@ -42,3 +42,63 @@ func TestCreateOfflineClient(t *testing.T) {"," \t\tassert.Error(t, err)"," \t})"," }","+","+func TestNewAPIClientRequiresClientCertificateAndKey(t *testing.T) {","+\toriginalOverrides := overrides","+\toriginalArgoServerOpts := ArgoServerOpts","+\tt.Cleanup(func() {","+\t\toverrides = originalOverrides","+\t\tArgoServerOpts = originalArgoServerOpts","+\t})","+","+\ttests := []struct {","+\t\tname       string","+\t\tclientCert string","+\t\tclientKey  string","+\t}{","+\t\t{","+\t\t\tname:       \"certificate without key\",","+\t\t\tclientCert: \"client.crt\",","+\t\t},","+\t\t{","+\t\t\tname:      \"key without certificate\",","+\t\t\tclientKey: \"client.key\",","+\t\t},","+\t}","+","+\tfor _, tt := range tests {","+\t\tt.Run(tt.name, func(t *testing.T) {","+\t\t\toverrides.AuthInfo.ClientCertificate = tt.clientCert","+\t\t\toverrides.AuthInfo.ClientKey = tt.clientKey","+","+\t\t\t_, _, err := NewAPIClient(logging.TestContext(t.Context()))","+","+\t\t\trequire.EqualError(t, err, \"--client-certificate and --client-key must be provided together\")","+\t\t})","+\t}","+}","+","+func TestNewAPIClientUsesExplicitCertificateAuthority(t *testing.T) {","+\toriginalOverrides := overrides","+\toriginalArgoServerOpts := ArgoServerOpts","+\toriginalOffline := Offline","+\toriginalOfflineFiles := OfflineFiles","+\tt.Cleanup(func() {","+\t\toverrides = originalOverrides","+\t\tArgoServerOpts = originalArgoServerOpts","+\t\tOffline = originalOffline","+\t\tOfflineFiles = originalOfflineFiles","+\t})","+","+\toverrides.AuthInfo.ClientCertificate = \"\"","+\toverrides.AuthInfo.ClientKey = \"\"","+\toverrides.ClusterInfo.CertificateAuthority = \"ca.crt\"","+\toverrides.ClusterInfo.ProxyURL = \"\"","+\tOffline = true","+\tOfflineFiles = nil","+","+\t_, _, err := NewAPIClient(logging.TestContext(t.Context()))","+","+\trequire.NoError(t, err)","+\tassert.Equal(t, \"ca.crt\", ArgoServerOpts.CACert)","+}"],"additions":60,"deletions":0,"truncated":false},{"path":"cmd/argo/commands/cp.go","lines":["@@ -2,7 +2,6 @@ package commands"," "," import ("," \t\"context\"","-\t\"crypto/tls\""," \t\"fmt\""," \t\"io\""," \t\"log\"","@@ -18,6 +17,7 @@ import ("," \t\"github.com/argoproj/argo-workflows/v4/pkg/apiclient\""," \tworkflowpkg \"github.com/argoproj/argo-workflows/v4/pkg/apiclient/workflow\""," \t\"github.com/argoproj/argo-workflows/v4/pkg/apis/workflow/v1alpha1\"","+\ttlsutil \"github.com/argoproj/argo-workflows/v4/util/tls\""," \twfutil \"github.com/argoproj/argo-workflows/v4/workflow/util\""," )"," ","@@ -74,12 +74,9 @@ func NewCpCommand() *cobra.Command {"," \t\t\t}"," \t\t\tartifactSearchResults := workflow.SearchArtifacts(&artifactSearchQuery)"," ","-\t\t\tc := &http.Client{","-\t\t\t\tTransport: &http.Transport{","-\t\t\t\t\tTLSClientConfig: &tls.Config{","-\t\t\t\t\t\tInsecureSkipVerify: client.ArgoServerOpts.InsecureSkipVerify,","-\t\t\t\t\t},","-\t\t\t\t},","+\t\t\tc, err := newArtifactHTTPClient(client.ArgoServerOpts)","+\t\t\tif err != nil {","+\t\t\t\treturn err"," \t\t\t}"," "," \t\t\tfor _, artifact := range artifactSearchResults {","@@ -117,6 +114,14 @@ func NewCpCommand() *cobra.Command {"," \treturn command"," }"," ","+func newArtifactHTTPClient(opts apiclient.ArgoServerOpts) (*http.Client, error) {","+\ttlsConfig, err := tlsutil.GetClientTLSConfig(opts.ClientCert, opts.ClientKey, opts.CACert, opts.InsecureSkipVerify)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\treturn &http.Client{Transport: &http.Transport{TLSClientConfig: tlsConfig}}, nil","+}","+"," func getAndStoreArtifactData(ctx context.Context, namespace string, workflowNam