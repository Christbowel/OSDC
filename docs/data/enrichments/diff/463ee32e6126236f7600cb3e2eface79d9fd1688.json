n an in-JS registry that dispatches events along the DOM ancestry","+ * of `event.target`.","+ *","+ * The model mirrors React's synthetic event system: a single root","+ * listener handles every event of a given type, and callbacks bound to","+ * an `Element` only fire when that element is on the target's path.","+ * Callbacks bound to a `Document` always fire (document is the root of","+ * every event in that document); callbacks bound to a `Window` always","+ * fire as a flat fan-out, since `window` isn't on the DOM tree.","+ *","+ * @param target    `Element`, `Document`, or `Window` to bind the","+ *                  callback to. For `Element`, the callback only fires","+ *                  when the event happens on the element or a","+ *                  descendant.","+ * @param eventType DOM event name.","+ * @param callback  Listener to be invoked with the event.","+ * @param capture   Use the capture phase. Required when ancestor","+ *                  listeners gate on `event.defaultPrevented`, since a","+ *                  bubble-phase root listener fires after them. Defaults","+ *                  to `false`.","+ * @return Unsubscribe function.","+ */","+// root -> eventTypeKey -> subscribedTarget -> Set<callback>","+//","+// Inner registry is a `WeakMap`: element subscribers are held weakly so","+// an iframe removal lets the iframe's Elements (and through them, its","+// `ownerDocument`) be garbage-collected. The native listener is","+// attached to the document itself, so it goes when the document goes.","+const registries = new WeakMap<","+\tEventTarget,","+\tMap< string, WeakMap< EventTarget, Set< EventListener > > >","+>();","+","+function getRoot( target: EventTarget ): EventTarget {","+\t// Detect Document / Window via duck typing (works across realms —","+\t// the iframe's `Document` constructor is distinct from the parent","+\t// window's, so `instanceof` is unreliable).","+\tif ( ( target as Document ).nodeType === 9 /* DOCUMENT_NODE */ ) {","+\t\treturn target;","+\t}","+\tif ( ( target as Window ).window === target ) {","+\t\treturn target;","+\t}","+\t// Assume Element/Node.","+\treturn ( target as Node ).ownerDocument as Document;","+}","+","+export default function subscribeDelegatedListener(","+\ttarget: EventTarget,","+\teventType: string,","+\tcallback: EventListener,","+\tcapture: boolean = false","+): () => void {","+\tconst root = getRoot( target );","+\t// Duck-type detection (cross-realm safe).","+\tconst isWindow = ( root as Window ).window === root;","+","+\tlet perRoot = registries.get( root );","+\tif ( ! perRoot ) {","+\t\tperRoot = new Map();","+\t\tregistries.set( root, perRoot );","+\t}","+\tconst key = capture ? `${ eventType }:capture` : eventType;","+\tlet perEvent = perRoot.get( key );","+\tif ( ! perEvent ) {","+\t\tperEvent = new WeakMap< EventTarget, Set< EventListener > >();","+\t\tperRoot.set( key, perEvent );","+\t\tconst subscribers = perEvent;","+\t\troot.addEventListener(","+\t\t\teventType,","+\t\t\t( event ) => {","+\t\t\t\tif ( isWindow ) {","+\t\t\t\t\t// Window has no DOM ancestry — all subscribers share","+\t\t\t\t\t// the window key; fetch its set and fan out.","+\t\t\t\t\tconst set = subscribers.get( root );","+\t\t\t\t\tif ( set ) {","+\t\t\t\t\t\tfor ( const cb of set ) {","+\t\t\t\t\t\t\tcb( event );","+\t\t\t\t\t\t}","+\t\t\t\t\t}","+\t\t\t\t\treturn;","+\t\t\t\t}","+\t\t\t\t// Walk the target → root ancestry, dispatching callbacks","+\t\t\t\t// for any node in the path. Bubble order matches the walk","+\t\t\t\t// direction, so dispatch inline (no path array). Capture","+\t\t\t\t// has to materialise the path to iterate in reverse.","+\t\t\t\tif ( capture ) {","+\t\t\t\t\tconst path: Array< Node | Document > = [];","+\t\t\t\t\tlet current: Node | null = event.target as Node | null;","+\t\t\t\t\twhile ( current ) {","+\t\t\t\t\t\tpath.push( current );","+\t\t\t\t\t\tif ( current === root ) {","+\t\t\t\t\t\t\tbreak;","+\t\t\t\t\t\t}","+\t\t\t\t\t\tcurrent = current.parentNode;","+\t\t\t\t\t}","+\t\t\t\t\tfor ( let i = path.length - 1; i >= 0; i-- ) {","+\t\t\t\t\t\tconst set = subscribers.get( path[ i ] );","+\t\t\t\t\t\tif ( set ) {","+\t\t\t\t\t\t\tfor ( const cb of set ) {","+\t\t\t\t\t\t\t\tcb( event );","+\t\t\t\t\t\t\t}","+\t\t\t\t\t\t}","+\t\t\t\t\t}","+\t\t\t\t} else {","+\t\t\t\t\tlet current: Node | null = event.target as Node | null;","+\t\t\t\t\twhile ( current ) {","+\t\t\t\t\t\tconst set = subscribers.get( current );","+\t\t\t\t\t\tif ( set ) {","+\t\t\t\t\t\t\tfor ( const cb of set ) {","+\t\t\t\t\t\t\t\tcb( event );","+\t\t\t\t\t\t\t}","+\t\t\t\t\t\t}","+\t\t\t\t\t\tif ( current === root ) {","+\t\t\t\t\t\t\tbreak;","+\t\t\t\t\t\t}","+\t\t\t\t\t\tcurrent = current.parentNode;","+\t\t\t\t\t}","+\t\t\t\t}","+\t\t\t},","+\t\t\tcapture","+\t\t);","+\t}","+\tlet set = perEvent.get( target );","+\tif ( ! set ) {","+\t\tset = new Set();","+\t\tperEvent.set( target, set );","+\t}","+\tset.add( callback );","+\treturn () => {","+\t\tset.delete( callback );","+\t};","+}"],"additions":136,"deletions":0,"truncated":false},{"path":"packages/compose/src/utils/subscribe-delegated-listener/test/index.js","lines":["@@ -0,0 +1,170 @@","+/**","+ * Internal dependencies","+ */","+import subscribeDelegatedListener from '..';","+","+describe( 'subscribeDelegatedListener', () => {","+\tlet root;","+\tlet target;","+","+\tbeforeEach( () => {","+\t\t// Build a nested DOM:","+\t\t//   document.body > #outer > #inner > #leaf","+\t\troot = document.createElement( 'div' );","+\t\troot.id = 'outer';","+\t\tconst inner = document.createElement( 'div' );","+\t\tinner.id = 'inner';","+\t\ttarget = document.createElement( 'span' );","+\t\ttarget.id = 'leaf';","+\t\tinner.appendChild( target );","+\t\troot.appendChild( inner );","+\t\tdocument.body.appendChild( root );","+\t} );","+","+\tafterEach( () => {","+\t\tdocument.body.removeChild( root );","+\t} );","+","+\tfunction fire( element, type = 'click', init = { bubbles: true } ) {","+\t