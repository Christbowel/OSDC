ault_verify_undo_logs/scripts/smoke-verify-undo-logs.sh","lines":["@@ -1,35 +0,0 @@","-#!/usr/bin/env bash","-# Copyright IBM Corp. 2016, 2025","-# SPDX-License-Identifier: BUSL-1.1","-","-function fail() {","-  echo \"$1\" 1>&2","-  exit 1","-}","-","-[[ -z \"$EXPECTED_STATE\" ]] && fail \"EXPECTED_STAE env variable has not been set\"","-[[ -z \"$RETRY_INTERVAL\" ]] && fail \"RETRY_INTERVAL env variable has not been set\"","-[[ -z \"$TIMEOUT_SECONDS\" ]] && fail \"TIMEOUT_SECONDS env variable has not been set\"","-[[ -z \"$VAULT_ADDR\" ]] && fail \"VAULT_ADDR env variable has not been set\"","-[[ -z \"$VAULT_INSTALL_DIR\" ]] && fail \"VAULT_INSTALL_DIR env variable has not been set\"","-[[ -z \"$VAULT_TOKEN\" ]] && fail \"VAULT_TOKEN env variable has not been set\"","-","-binpath=${VAULT_INSTALL_DIR}/vault","-test -x \"$binpath\" || fail \"unable to locate vault binary at $binpath\"","-","-begin_time=$(date +%s)","-end_time=$((begin_time + TIMEOUT_SECONDS))","-while [ \"$(date +%s)\" -lt \"$end_time\" ]; do","-  state=$($binpath read sys/metrics -format=json | jq -r '.data.Gauges[] | select(.Name == \"vault.core.replication.write_undo_logs\")')","-  target_undo_logs_status=\"$(jq -r '.Value' <<< \"$state\")\"","-","-  if [ \"$target_undo_logs_status\" == \"$EXPECTED_STATE\" ]; then","-    echo \"vault.core.replication.write_undo_logs has expected Value: \\\"${EXPECTED_STATE}\\\"\"","-    exit 0","-  fi","-","-  echo \"Waiting for vault.core.replication.write_undo_logs to have Value: \\\"${EXPECTED_STATE}\\\"\"","-  sleep \"$RETRY_INTERVAL\"","-done","-","-fail \"Timed out waiting for vault.core.replication.write_undo_logs to have Value: \\\"${EXPECTED_STATE}\\\"\""],"additions":0,"deletions":35,"truncated":false},{"path":"sdk/helper/testcluster/blackbox/session.go","lines":["@@ -10,6 +10,7 @@ import ("," \t\"os\""," \t\"path\""," \t\"slices\"","+\t\"strings\""," \t\"testing\""," \t\"time\""," ","@@ -58,11 +59,63 @@ func New(t *testing.T, opts ...SessionOpts) *Session {"," \trequire.NoError(t, err)"," \tprivClient.SetToken(token)"," ","-\tnsName := fmt.Sprintf(\"bbsdk-%s\", randomString(8))","+\t// Auto-detect protocol: if we get HTTP/HTTPS mismatch, retry with correct protocol","+\tif strings.HasPrefix(addr, \"http://\") {","+\t\t// Try HTTP first, but be ready to switch to HTTPS","+\t\ttestResp, testErr := privClient.Sys().Health()","+\t\tif testErr != nil && (strings.Contains(testErr.Error(), \"Client sent an HTTP request to an HTTPS server\") ||","+\t\t\tstrings.Contains(testErr.Error(), \"server gave HTTP response to HTTPS client\")) {","+\t\t\t// Server is using HTTPS, create completely fresh config","+\t\t\thttpsAddr := strings.Replace(addr, \"http://\", \"https://\", 1)","+","+\t\t\thttpsConfig := api.DefaultConfig()","+\t\t\thttpsConfig.Address = httpsAddr","+\t\t\thttpsConfig.Timeout = 120 * time.Second","+","+\t\t\t// Disable TLS verification for test environments","+\t\t\ttlsConfig := &api.TLSConfig{","+\t\t\t\tInsecure: true,","+\t\t\t}","+\t\t\tif err := httpsConfig.ConfigureTLS(tlsConfig); err != nil {","+\t\t\t\trequire.NoError(t, err, \"Failed to configure TLS\")","+\t\t\t}","+","+\t\t\tprivClient, err = api.NewClient(httpsConfig)","+\t\t\trequire.NoError(t, err)","+\t\t\tprivClient.SetToken(token)","+\t\t\tt.Logf(\"Auto-detected HTTPS protocol, switched from %s to %s (TLS verification disabled)\", addr, httpsAddr)","+\t\t} else if testErr != nil && testResp == nil {","+\t\t\t// Some other error, fail normally","+\t\t\trequire.NoError(t, testErr, \"Failed to connect to Vault at %s\", addr)","+\t\t}","+\t}","+","+\t// Use timestamp to ensure uniqueness across test retries","+\tnsName := fmt.Sprintf(\"bbsdk-%d-%s\", time.Now().UnixNano(), randomString(8))"," \tnsURLPath := fmt.Sprintf(\"sys/namespaces/%s\", nsName)"," ","+\t// Try to create the namespace, but if it already exists (from a previous failed run),","+\t// delete it first and retry"," \t_, err = privClient.Logical().Write(nsURLPath, nil)","-\trequire.NoError(t, err)","+\tif err != nil {","+\t\t// Check if namespace already exists","+\t\tif resp, readErr := privClient.Logical().Read(nsURLPath); readErr == nil && resp != nil {","+\t\t\tt.Logf(\"RETRY DETECTED: Namespace %s already exists from previous failed test run, cleaning up and retrying\", nsName)","+\t\t\t_, delErr := privClient.Logical().Delete(nsURLPath)","+\t\t\tif delErr != nil {","+\t\t\t\tt.Fatalf(\"RETRY CLEANUP FAILED: Could not delete existing namespace %s: %v (original creation error: %v)\", nsName, delErr, err)","+\t\t\t}","+\t\t\t// Retry creation after deletion","+\t\t\t_, err = privClient.Logical().Write(nsURLPath, nil)","+\t\t\tif err != nil {","+\t\t\t\tt.Fatalf(\"RETRY FAILED: Could not create namespace %s after cleanup: %v\", nsName, err)","+\t\t\t}","+\t\t\tt.Logf(\"RETRY SUCCESS: Namespace %s created after cleanup\", nsName)","+\t\t} else {","+\t\t\t// This is the initial failure, not a retry","+\t\t\trequire.NoError(t, err, \"INITIAL TEST FAILURE: Failed to create namespace %s. If you see this error followed by a retry with a different error, the cluster state was not properly reset.\", nsName)","+\t\t}","+\t}"," "," \t// session client should get the full namespace of parent + test"," \tfullNSPath := nsName"],"additions":55,"deletions":2,"truncated":false},{"path":"sdk/helper/testcluster/blackbox/session_metrics.go","lines":["@@ -0,0 +1,100 @@","+// Copyright IBM Corp. 2025, 2026","+// SPDX-License-Identifier: BUSL-1.1","+","+package blackbox","+","+import (","+\t\"encoding/json\"","+\t\"fmt\"","+\t\"time\"","+","+\t\"github.com/hashicorp/vault/api\"","+)","+","+// MetricsResponse represents the response from sys/metrics endpoint","+type MetricsResponse struct {","+\tData struct {","+\t\tGauges []struct {","+\t\t\tName   string            `json:\"Name\"`","+\t\t\tValue  float64           `json:\"Value\"`","+\t\t\tLabels map[string]string `json:\"Labels\"`","+\t\t} `json:\"Gauges\"`","+\t\tCounters []struct {","+\t\t\tName   string            `json:\"Name\"`","+\t\t\tCount  int               `json:\"Count\"`","+\t\t\tSum    float64           `json:\"Sum\"`","+\t\t\tLabels map[string]string `json:\"Labels\"`","+\t\t} `json:\"Counters\"`","+\t\tSamples []struct {","+\t\t\tName   string            `json:\"Name\"`","+\t\t\tCount  int               `json:\"Count\"`","+\t\t\tSum    float64           `json:\"Sum\"`","+\t\t\tLabels map[string]string `json:\"Labels\"`","+\t\t} `json:\"Samples\"`","+\t} `json:\"data\"`","+}","+","+// AssertMetricGaugeValue verifies that a specific gauge metric has the expected value","+// This method includes retry logic with configurable timeout","+// Note: retryInterval parameter is ignored as the SDK uses a fixed 200ms interval","+func (s *Session) AssertMetricGaugeValue(gaugeName string, expectedValue float64, timeout time.Duration, retryInterval time.Duration) {","+\ts.t.Helper()","+","+\ts.EventuallyWithTimeout(func() error {","+\t\tvar secret *api.Secret","+\t\tvar err error","+","+\t\t// sys/metrics is only available at root namespace, use Req() to avoid race conditions","+\t\terr = s.Req(func(c *api.Client) error {","+\t\t\tsecret, err = c.Logical().Read(\"sys/metrics\")","+\t\t\treturn err","+\t\t}, WithClientRootNamespace())","+\t\tif err != nil {","+\t\t\treturn fmt.Errorf(\"failed to read sys/metrics: %w\", err)","+\t\t}","+","+\t\tif secret == nil || secret.Data == nil {","+\t\t\treturn fmt.Errorf(\"sys/metrics returned nil data\")","+\t\t}","+","+\t\t// Marshal and unmarshal to get proper structure","+\t\tdataBytes, err := json.Marshal(secret.Data)","+\t\tif err != nil {","+\t\t\treturn fmt.Errorf(\"failed to marshal metrics data: %w\", err)","+\t\t}","+","+\t\tvar metricsData struct {","+\t\t\tGauges []struct {","+\t\t\t\tName   string            `json:\"Name\"`","+\t\t\t\tValue  float64           `json:\"Value\"`","+\t\t\t\tLabels map[string]string `json:\"Labels\"`","+\t\t\t} `json:\"Gauges\"`","+\t\t}","+","+\t\tif err := json.Unmarshal(dataBytes, &metricsData); err != nil {","+\t\t\treturn fmt.Errorf(\"failed to unmarshal metrics data: %w\", err)","+\t\t}","+","+\t\t// Find the gauge by name","+\t\tvar found bool","+\t\tvar actualValue float64","+\t\tfor _, gauge := range metricsData.Gauges {","+\t\t\tif gauge.Name == gaugeName {","+\t\t\t\tfound = true","+\t\t\t\tactualValue = gauge.Value","+\t\t\t\tbreak","+\t\t\t}","+\t\t}","+","+\t\tif !found {","+\t\t\treturn fmt.Errorf(\"gauge metric %q not found in sys/metrics response\", gaugeName)","+\t\t}","+","+\t\tif actualValue != expectedValue {","+\t\t\treturn fmt.Errorf(\"gauge %q has value %.0f, expected %.0f\", gaugeName, actualValue, expectedValue)","+\t\t}","+","+\t\ts.t.Logf(\"Gauge metric %q has expected value: %.0f\", gaugeName, expectedValue)","+\t\treturn nil","+\t}, timeout)","+}"],"additions":100,"deletions":0,"truncated":false},{"path":"vault/external_tests/blackbox/verify/undo_logs_test.go","lines":["@@ -0,0 +1,63 @@","+// Copyright IBM Corp. 2025, 2026","+// SPDX-License-Identifier: BUSL-1.1","+","+package verify","+","+import (","+\t\"os\"","+\t\"strconv\"","+\t\"testing\"","+\t\"time\"","+","+\t\"github.com/hashicorp/vault/sdk/helper/testcluster/blackbox\"","+)","+","+// TestVaultUndoLogsMetric verifies the vault.core.replication.write_undo_logs gauge metric","+// This test runs from CI/GitHub runners and connects to the Vault cluster via API","+func TestVaultUndoLogsMetric(t *testing.T) {","+\tt.Parallel()","+","+\t// Read required environment variables","+\texpectedStateStr := os.Getenv(\"EXPECTED_STATE\")","+\tif expectedStateStr == \"\" {","+\t\tt.Fatal(\"EXPECTED_STATE environment variable is required\")","+\t}","+","+\texpectedState, err := strconv.ParseFloat(expectedStateStr, 64)","+\tif err != nil {","+\t\tt.Fatalf(\"Failed to parse EXPECTED_STATE: %v\", err)","+\t}","+","+\t// Validate expected state is 0 or 1","+\tif expectedState != 0 && expectedState != 1 {","+\t\tt.Fatalf(\"EXPECTED_STATE must be 0 or 1, got: %.0f\", expectedState)","+\t}","+","+\ttimeoutStr := os.Getenv(\"TIMEOUT_SECONDS\")","+\tif timeoutStr == \"\" {","+\t\tt.Fatal(\"TIMEOUT_SECONDS environment variable is required\")","+\t}","+","+\ttimeoutSeconds, err := strconv.Atoi(timeoutStr)","+\tif err != nil {","+\t\tt.Fatalf(\"Failed to parse TIMEOUT_SECONDS: %v\", err)","+\t}","+","+\tretryIntervalStr := os.Getenv(\"RETRY_INTERVAL\")","+\tif retryIntervalStr == \"\" {","+\t\tt.Fatal(\"RETRY_INTERVAL environment variable is required\")","+\t}","+","+\tretryIntervalSeconds, err := strconv.Atoi(retryIntervalStr)","+\tif err != nil {","+\t\tt.Fatalf(\"Failed to parse RETRY_INTERVAL: %v\", err)","+\t}","+","+\ttimeout := time.Duration(timeoutSeconds) * time.Second","+\tretryInterval := time.Duration(retryIntervalSeconds) * time.Second","+","+\tv := blackbox.New(t)","+","+\t// Verify the undo logs metric has the expected value","+\tv.AssertMetricGaugeValue(\"vault.core.replication.write_undo_logs\", expectedState, timeout, retryInterval)","+}",""],"additions":63,"deletions":0,"truncated":false}],"additions":264,"deletions":136,"truncated":false,"file_count":9},"error":null,"fetched_at":"2026-06-03T12:51:55.801099+00:00"}