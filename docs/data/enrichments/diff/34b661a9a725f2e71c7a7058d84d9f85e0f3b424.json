se entries for paymentService discovery chain.","+\t//","+\t// Discovery chain is required in case of API Gateway with peering,","+\t// because we need service resolver to redirect request to peer.","+\t// If paymentServiceSet is not provided, then api-gateway will work as simple api-gw","+\t// without knowledge of peering and service resolver (no redirection to peer)","+\tpaymentServiceSet := configentry.NewDiscoveryChainSet()","+\tpaymentServiceSet.AddEntries(","+\t\t&structs.ProxyConfigEntry{","+\t\t\tKind:   structs.ProxyDefaults,","+\t\t\tName:   structs.ProxyConfigGlobal,","+\t\t\tConfig: map[string]interface{}{\"protocol\": \"http\"},","+\t\t},","+\t\t&structs.ServiceResolverConfigEntry{","+\t\t\tKind: structs.ServiceResolver,","+\t\t\tName: paymentService.Name,","+\t\t\tRedirect: &structs.ServiceResolverRedirect{","+\t\t\t\tPeer: paymentServiceUID.Peer, // Redirect to peer","+\t\t\t},","+\t\t},","+\t)","+\tpaymentServiceChain := discoverychain.TestCompileConfigEntries(","+\t\tt,","+\t\tpaymentService.Name,","+\t\t\"default\",","+\t\t\"default\",","+\t\t\"dc1\",","+\t\tconnect.TestClusterID+\".consul\",","+\t\t// Below discovery chain (re)compile request is sent, so that","+\t\t// we could get the updated localGatewayEndpoint.","+\t\t//","+\t\t// API Gateway does not directly update WatchedLocalGWEndpoints.","+\t\t// It watches route config entries and upstream chains.","+\t\t// So, after every update, DC recompile happens for API GW.","+\t\t// Within recompile,it synthesize the listeners/routes, etc &","+\t\t// then we would be able to get localGatewayEndpoint.","+\t\t//","+\t\t// Also, since we are recompiling the discovery chain,","+\t\t// it prefix the clusterName with customizationHash","+\t\t// while generating the cluster configs.","+\t\t//","+\t\t// Please note that:","+\t\t// API Gateway, do not recomplile when \"OverrideMeshGateway\" changes.","+\t\t// It do not set \"OverrideMeshGateway\" in discoveryChainWatchOpts.","+\t\t// This is just to trigger the recompilation.","+\t\t//","+\t\t// MeshGateway mode is updated in TestConfigSnapshotAPIGateway,","+\t\t// which updates the NodeService, and once the NodeService is modified,","+\t\t// proxyCfg manager recreates the state (state config + serviceInstance).","+\t\tfunc(req *discoverychain.CompileRequest) {","+\t\t\treq.OverrideMeshGateway = structs.MeshGatewayConfig{Mode: structs.MeshGatewayModeLocal}","+\t\t},","+\t\tpaymentServiceSet,","+\t)","+","+\t// generateNodeServiceTargetAddress generates tagged addresses","+\t// for NodeService based on the upstream address type.","+\tgenerateNodeServiceTargetAddress := func(peerServiceName, upstreamAddr string, upstreamAddrIsHostname bool) map[string]structs.ServiceAddress {","+\t\tif upstreamAddrIsHostname {","+\t\t\treturn map[string]structs.ServiceAddress{","+\t\t\t\tstructs.TaggedAddressLAN: {","+\t\t\t\t\tAddress: upstreamAddr,","+\t\t\t\t\tPort:    8443,","+\t\t\t\t},","+\t\t\t\tstructs.TaggedAddressWAN: {","+\t\t\t\t\tAddress: peerServiceName + \".us-east-1.elb.notaws.com\",","+\t\t\t\t\tPort:    443,","+\t\t\t\t},","+\t\t\t}","+\t\t}","+\t\treturn nil","+\t}","+","+\tnewTestCase := func(name string, mgwMode structs.MeshGatewayMode, upstreamAddr string, upstreamAddrIsHostname bool) goldenTestCase {","+\t\ttc := goldenTestCase{","+\t\t\tname: name,","+\t\t\tcreate: func(t testinf.T) *proxycfg.ConfigSnapshot {","+\t\t\t\tproxyCfgUpdateEvents := []proxycfg.UpdateEvent{","+\t\t\t\t\t// Inject Discovery Chain Events","+\t\t\t\t\t// (because API Gateway uses serviceResolvers)","+\t\t\t\t\t{","+\t\t\t\t\t\tCorrelationID: \"discovery-chain:\" + paymentService.Name,","+\t\t\t\t\t\tResult: &structs.DiscoveryChainResponse{","+\t\t\t\t\t\t\tChain: paymentServiceChain,","+\t\t\t\t\t\t},","+\t\t\t\t\t},","+\t\t\t\t\t// Trust Bundles & Endpoints","+\t\t\t\t\t{","+\t\t\t\t\t\tCorrelationID: \"peer-trust-bundle:\" + paymentServiceUID.Peer,","+\t\t\t\t\t\tResult: &pbpeering.TrustBundleReadResponse{","+\t\t\t\t\t\t\tBundle: &pbpeering.PeeringTrustBundle{","+\t\t\t\t\t\t\t\tPeerName:          paymentServiceUID.Peer,","+\t\t\t\t\t\t\t\tTrustDomain:       peerTrustDomain,","+\t\t\t\t\t\t\t\tExportedPartition: \"default\",","+\t\t\t\t\t\t\t\tRootPEMs:          []string{paymentServiceUID.Peer + \"-root\"},","+\t\t\t\t\t\t\t},","+\t\t\t\t\t\t},","+\t\t\t\t\t},","+\t\t\t\t\t// Upstream nodes for the payment service in peer cluster.","+\t\t\t\t\t{","+\t\t\t\t\t\tCorrelationID: \"upstream-peer:\" + paymentServiceUID.String(),","+\t\t\t\t\t\tResult: &structs.IndexedCheckServiceNodes{","+\t\t\t\t\t\t\tNodes: structs.CheckServiceNodes{","+\t\t\t\t\t\t\t\t{","+\t\t\t\t\t\t\t\t\tNode: &structs.Node{","+\t\t\t\t\t\t\t\t\t\tID:         \"test1\",","+\t\t\t\t\t\t\t\t\t\tNode:       \"test1\",","+\t\t\t\t\t\t\t\t\t\tAddress:    upstreamAddr,","+\t\t\t\t\t\t\t\t\t\tDatacenter: paymentServiceDC,","+\t\t\t\t\t\t\t\t\t},","+\t\t\t\t\t\t\t\t\tService: &structs.NodeService{","+\t\t\t\t\t\t\t\t\t\tKind:            structs.ServiceKindAPIGateway,","+\t\t\t\t\t\t\t\t\t\tService:         \"gateway\",","+\t\t\t\t\t\t\t\t\t\tPort:            8443,","+\t\t\t\t\t\t\t\t\t\tTaggedAddresses: generateNodeServiceTargetAddress(paymentService.Name, upstreamAddr, upstreamAddrIsHostname),","+\t\t\t\t\t\t\t\t\t\tConnect: structs.ServiceConnect{","+\t\t\t\t\t\t\t\t\t\t\tPeerMeta: &structs.PeeringServiceMeta{","+\t\t\t\t\t\t\t\t\t\t\t\tSNI: []string{","+\t\t\t\t\t\t\t\t\t\t\t\t\tfmt.Sprintf(\"%s.%s.%s.%s.external.%s\",","+\t\t\t\t\t\t\t\t\t\t\t\t\t\tpaymentService.Name, paymentServiceNamespace, paymentServicePartition, paymentServiceUID.Peer, peerTrustDomain),","+\t\t\t\t\t\t\t\t\t\t\t\t},","+\t\t\t\t\t\t\t\t\t\t\t\tSpiffeID: []string{","+\t\t\t\t\t\t\t\t\t\t\t\t\tfmt.Sprintf(\"spiffe://%s/ns/default/dc/%s/svc/%s\", peerTrustDomain, paymentServiceDC, paymentService.Name),","+\t\t\t\t\t\t\t\t\t\t\t\t},","+\t\t\t\t\t\t\t\t\t\t\t\tProtocol: \"tcp\","],"additions":143,"deletions":0,"truncated":false}],"additions":484,"deletions":35,"trunc