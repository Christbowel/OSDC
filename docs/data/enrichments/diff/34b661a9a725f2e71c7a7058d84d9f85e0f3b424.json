ocol that was configured on the listener in order"," \t\t\t\t\t\t// to force that protocol on the Envoy listener."," \t\t\t\t\t\tConfig: upstreamCfg,","+","+\t\t\t\t\t\t// Propogate the meshGatewayConfig in api gateway upstreams","+\t\t\t\t\t\t// so that meshGatewayMode can be used in XDS for","+\t\t\t\t\t\t// endpoints and cluster config generation.","+\t\t\t\t\t\tMeshGateway: meshGatewayConfig,"," \t\t\t\t\t}"," "," \t\t\t\t\tlistenerKey := APIGatewayListenerKeyFromListener(listener)","@@ -425,6 +443,7 @@ func (h *handlerAPIGateway) handleRouteConfigUpdate(ctx context.Context, u Updat"," "," \t\tfor _, service := range route.Services {"," \t\t\teffectiveLimits := apiGatewayEffectiveUpstreamLimits(defaultLimits, service.Limits)","+\t\t\tmeshGatewayConfig := h.proxyCfg.MeshGateway"," \t\t\tupstreamID := NewUpstreamIDFromServiceName(service.ServiceName())"," \t\t\tseenUpstreamIDs.add(upstreamID)"," ","@@ -454,7 +473,8 @@ func (h *handlerAPIGateway) handleRouteConfigUpdate(ctx context.Context, u Updat"," \t\t\t\t\tLocalBindPort:        listener.Port,"," \t\t\t\t\t// Pass the protocol that was configured on the ingress listener in order"," \t\t\t\t\t// to force that protocol on the Envoy listener.","-\t\t\t\t\tConfig: upstreamCfg,","+\t\t\t\t\tConfig:      upstreamCfg,","+\t\t\t\t\tMeshGateway: meshGatewayConfig,"," \t\t\t\t}"," "," \t\t\t\tlistenerKey := APIGatewayListenerKeyFromListener(listener)"],"additions":21,"deletions":1,"truncated":false},{"path":"agent/proxycfg/state.go","lines":["@@ -226,6 +226,7 @@ func newKindHandler(config stateConfig, s serviceInstance, ch chan UpdateEvent)"," \tcase structs.ServiceKindIngressGateway:"," \t\thandler = &handlerIngressGateway{handlerState: h}"," \tcase structs.ServiceKindAPIGateway:","+\t\th.logger = config.logger.Named(logging.APIGateway)"," \t\thandler = &handlerAPIGateway{handlerState: h}"," \tdefault:"," \t\treturn nil, errors.New(\"not a connect-proxy, terminating-gateway, mesh-gateway, or ingress-gateway\")"],"additi