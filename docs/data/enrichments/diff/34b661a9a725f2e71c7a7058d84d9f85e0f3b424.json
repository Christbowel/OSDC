eturn &ns, token","+\t\t\t},","+\t\t\twant: true,","+\t\t},","+\t\t{","+\t\t\tname:  \"different mesh gateway mode (local)\",","+\t\t\tns:    structs.TestNodeServiceAPIGateway(t),","+\t\t\ttoken: \"foo\",","+\t\t\tmutate: func(ns structs.NodeService, token string) (*structs.NodeService, string) {","+\t\t\t\tns.Proxy.MeshGateway.Mode = structs.MeshGatewayModeLocal","+\t\t\t\treturn &ns, token","+\t\t\t},","+\t\t\twant: true,","+\t\t},","+\t\t{","+\t\t\tname:  \"different mesh gateway mode (remote)\",","+\t\t\tns:    structs.TestNodeServiceAPIGateway(t),","+\t\t\ttoken: \"foo\",","+\t\t\tmutate: func(ns structs.NodeService, token string) (*structs.NodeService, string) {","+\t\t\t\tns.Proxy.MeshGateway.Mode = structs.MeshGatewayModeRemote","+\t\t\t\treturn &ns, token","+\t\t\t},","+\t\t\twant: true,","+\t\t},"," \t}"," "," \tfor _, tt := range tests {"],"additions":126,"deletions":1,"truncated":false},{"path":"agent/structs/testing_catalog.go","lines":["@@ -176,10 +176,35 @@ func TestNodeServiceMeshGateway(t testing.T) *NodeService {"," }"," "," func TestNodeServiceAPIGateway(t testing.T) *NodeService {","+\tentMeta := DefaultEnterpriseMetaInPartition(\"\")"," \treturn &NodeService{"," \t\tKind:    ServiceKindAPIGateway,"," \t\tService: \"api-gateway\","," \t\tAddress: \"1.1.1.1\",","+","+\t\t// ---------------------------------------","+\t\t// Adding TestConnectProxyConfig to the proxy field here within TestNodeServiceAPIGateway","+\t\t// to test whether APIGateway is able to handle state changes within ConnectProxyConfig (TestStateChangedAPIGateway).","+\t\t// Please note:","+\t\t// The naming may suggest that ConnectProxyConfig should only be used for ConnectProxy,","+\t\t// but \"APIGateway state\" uses serviceInstance, which embeds ConnectProxyConfig as part of its state,","+\t\t// so any changes to ConnectProxyConfig will also impact APIGateway, such as change in \"mesh gateway mode\".","+\t\t//","+\t\t// For example, let's say a user updates the mesh gateway mode of an API gateway,","+\t\t// First NodeService.Proxy will be updated and then proxyCfg manager detects change in config","+\t\t// and it recreates the state for api_gateway which would copy the","+\t\t// NodeService.Proxy.MeshGateway to serviceInstance.proxyCfg.MeshGateway in `newServiceInstanceFromNodeService` (serviceInstance is part of state)","+\t\t// and then proxyCfg manager calls the api_gateway handleUpdates method which would","+\t\t// update the api_gateway upstreams with new meshGateway config.","+\t\t//","+\t\t// Now, this serviceInstance.proxyCfg and NodeService.Proxy","+\t\t// refers to same proxy configuration, which is of type ConnectProxyConfig.","+","+\t\t// So, we need to test it as well.","+\t\t// ---------------------------------------","+","+\t\tProxy:          TestConnectProxyConfig(t),","+\t\tEnterpriseMeta: *entMeta,"," \t}"," }"," "],"additions":25,"deletions":0,"truncated":false},{"path":"agent/xds/clusters.go","lines":["@@ -1656,25 +1656,47 @@ func (s *ResourceGenerator) makeUpstreamClustersForDiscoveryChain("," \t\tfor _, groupedTarget := range targetGroups {"," \t\t\ts.Logger.Debug(\"generating cluster for\", \"cluster\", groupedTarget.ClusterName)"," ","+\t\t\t// Now this makeUpstreamClusterForDiscoveryChain, is a generic method","+\t\t\t// and used by connect proxy, ingress gateway and api gateway.","+\t\t\t//","+\t\t\t// Issue: This method always make cluster (without endpoints).","+\t\t\t// `ClusterDiscoveryType: &envoy_cluster_v3.Cluster_Type{Type: envoy_cluster_v3.Cluster_EDS},`","+\t\t\t//","+\t\t\t// Envoy Exception:","+\t\t\t// As we know that any service whose upstream endpoint is of type hostname,","+\t\t\t// envoy cannot resolve hostname as EDS.","+\t\t\t// So, we need to use CDS to send endpoints as well along with cluster configs.","+\t\t\t//","+\t\t\t// Context:","+\t\t\t// When we have 2 consul DC peered with mesh gw ON AWS and","+\t\t\t// we have API gw on DC1 which need to access a service X which exist on DC2.","+\t