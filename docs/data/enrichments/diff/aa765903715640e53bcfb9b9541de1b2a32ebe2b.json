{"id":"aa765903715640e53bcfb9b9541de1b2a32ebe2b","axis":"silent","repo":"rails/rails","sha":"aa765903715640e53bcfb9b9541de1b2a32ebe2b","parsed":{"files":[{"path":"activerecord/CHANGELOG.md","lines":["@@ -1,3 +1,24 @@","+*   Add `#default_order` query method and association option which can be used to order records when no other order is specified.","+","+    This extends the functionality offered by `#implicit_order_column` to scopes and associations.","+","+    Usage:","+","+    ```ruby","+    class Post < ApplicationRecord","+      has_many :comments, default_order: :likes","+      # .. or ..","+      has_many :comments, -> { default_order(:likes) }","+    end","+","+    post = Post.first","+","+    post.comments # comments ordered by `likes`","+    post.comments.order(:created_at) # comments ordered by `created_at`","+    ```","+","+    *Dan Ungureanu*","+"," *   Raise `ActiveRecord::MultiparameterAssignmentErrors` instead of `NoMethodError`","     when assigning a malformed multiparameter attribute name."," "],"additions":21,"deletions":0,"truncated":false},{"path":"activerecord/lib/active_record/associations/association_scope.rb","lines":["@@ -152,6 +152,7 @@ def add_constraints(scope, owner, chain)","               scope.unscope!(*item.table_name_qualified_unscope_values)","               scope.where_clause += item.where_clause","               scope.order_values = item.order_values | scope.order_values","+              scope.default_order_values = item.default_order_values | scope.default_order_values","             end","           end"," "],"additions":1,"deletions":0,"truncated":false},{"path":"activerecord/lib/active_record/associations/builder/has_many.rb","lines":["@@ -7,7 +7,7 @@ def self.macro","     end"," ","     def self.valid_options(options)","-      valid = super + [:counter_cache, :join_table, :index_errors, :as, :through]","+      valid = super + [:counter_cache, :join_table, :index_errors, :default_order, :as, :through]","       valid += [:fo