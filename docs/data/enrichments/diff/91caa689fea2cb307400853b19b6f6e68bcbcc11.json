t\",","+\t\ttime.Now().Add(2*time.Hour),","+\t\ttypes.ProvisionTokenSpecV2{","+\t\t\tJoinMethod: types.JoinMethodBoundKeypair,","+\t\t\tRoles:      []types.SystemRole{types.RoleInstance, types.RoleApp},","+\t\t\tBoundKeypair: &types.ProvisionTokenSpecV2BoundKeypair{","+\t\t\t\tOnboarding: &types.ProvisionTokenSpecV2BoundKeypair_OnboardingSpec{","+\t\t\t\t\tInitialPublicKey: correctPublicKey,","+\t\t\t\t},","+\t\t\t\tRecovery: &types.ProvisionTokenSpecV2BoundKeypair_RecoverySpec{","+\t\t\t\t\tLimit: 3,","+\t\t\t\t},","+\t\t\t},","+\t\t},","+\t\t&types.ProvisionTokenStatusV2{},","+\t)","+\trequire.NoError(t, err)","+\trequire.NoError(t, authServer.CreateBoundKeypairToken(ctx, token))","+","+\t// Make an unauthenticated auth client that will be used for joining.","+\tnopClient, err := srv.NewClient(authtest.TestNop())","+\trequire.NoError(t, err)","+\tdefer nopClient.Close()","+","+\tclientState := makeMockBoundKeypairState(signers,","+\t\twithSingleSigningKey(correctPublicKey),","+\t\twithNoRotation(),","+\t)","+","+\toriginalJoinResult, err := joinclient.Join(t.Context(), joinclient.JoinParams{","+\t\tToken: token.GetName(),","+\t\tID: state.IdentityID{","+\t\t\tRole: types.RoleInstance,","+\t\t},","+\t\tAuthClient:        nopClient,","+\t\tBoundKeypairState: clientState,","+\t})","+\trequire.NoError(t, err)","+","+\t// Perform a recovery, this time with a join state.","+\trecoverResult, err := joinclient.Join(t.Context(), joinclient.JoinParams{","+\t\tToken: token.GetName(),","+\t\tID: state.IdentityID{","+\t\t\tRole: types.RoleInstance,","+\t\t},","+\t\tAuthClient: nopClient,","+\t\t// Note: the client state manages prev join state internally in","+\t\t// UpdateFromRegisterResult().","+\t\tBoundKeypairState: clientState,","+\t})","+\trequire.NoError(t, err)","+","+\trecoveredClient, err := clientFromJoinResult(srv, recoverResult)","+\trequire.NoError(t, err)","+\tdefer recoveredClient.Close()","+","+\t// Try an API call with these certs.","+\t_, err = recoveredClient.Ping(ctx)","+\trequire.NoError(t, err)","+","+\t// Subscribe to events from the LockWatcher","+\tlockSub, err := srv.AuthServer.LockWatcher.Subscribe(ctx, types.LockTarget{","+\t\tJoinToken: \"bound-keypair-test\",","+\t})","+\trequire.NoError(t, err)","+\tdefer lockSub.Close()","+","+\t// Try to recover again, but with the original join state.","+\toutdatedClientState := makeMockBoundKeypairState(signers,","+\t\twithSingleSigningKey(correctPublicKey),","+\t\twithPreviousJoinState(originalJoinResult.BoundKeypair.JoinState),","+\t\twithNoRotation(),","+\t)","+\t_, err = joinclient.Join(ctx, joinclient.JoinParams{","+\t\tToken: token.GetName(),","+\t\tID: state.IdentityID{","+\t\t\tRole: types.RoleInstance,","+\t\t},","+\t\tAuthClient:        nopClient,","+\t\tBoundKeypairState: outdatedClientState,","+\t})","+\trequire.Error(t, err)","+","+\t// The token should now be locked - but only once.","+\tlocks, err := srv.Auth().GetLocks(ctx, true, types.LockTarget{","+\t\tJoinToken: \"bound-keypair-test\",","+\t})","+\trequire.NoError(t, err)","+\trequire.Len(t, locks, 1, \"only one lock should be generated\")","+\trequire.Contains(t, locks[0].Message(), \"failed to verify its join state\")","+","+\t// Wait for the LockWatcher to notify us about the new lock. Since this","+\t// otherwise happens async, we need to wait explicitly, otherwise the lock","+\t// may exist in the backend without being enforced.","+\tselect {","+\tcase event := <-lockSub.Events():","+\t\trequire.Equal(t, types.OpPut, event.Type)","+\tcase <-lockSub.Done():","+\t\tt.Fatal(\"lock subscription closed unexpectedly\")","+\tcase <-ctx.Done():","+\t\tt.Fatal(\"timed out waiting for lock event\")","+\t}","+","+\t// The previously working client should be locked.","+\t_, err = recoveredClient.Ping(ctx)","+\trequire.Error(t, err)","+\trequire.ErrorContains(t, err, \"access denied\")","+","+\t// Try joining again with the same parameters to try to generate another","+\t// lock - they should not be duplicat