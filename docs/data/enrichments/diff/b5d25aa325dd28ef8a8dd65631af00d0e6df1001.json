 '@directus/errors';","+import { beforeEach, describe, expect, test, vi } from 'vitest';","+import { assertValidStoragePath } from './assert-valid-storage-path.js';","+","+const state = vi.hoisted(() => ({ env: {} as Record<string, unknown> }));","+","+vi.mock('@directus/env', () => ({ useEnv: () => state.env }));","+","+const baseEnv = (): Record<string, unknown> => ({","+\tSTORAGE_LOCATIONS: 'local',","+\tSTORAGE_LOCAL_DRIVER: 'local',","+\tSTORAGE_LOCAL_ROOT: './uploads',","+\tEXTENSIONS_PATH: './extensions',","+\tTEMP_PATH: './node_modules/.directus',","+});","+","+describe('assertValidStoragePath', () => {","+\tbeforeEach(() => {","+\t\tstate.env = baseEnv();","+\t});","+","+\ttest('allows a normal file under the storage root', () => {","+\t\texpect(() => assertValidStoragePath('1234.jpg', 'local')).not.toThrow();","+\t});","+","+\ttest('allows a folder literally named \"extensions\" inside the storage root', () => {","+\t\texpect(() => assertValidStoragePath('extensions/x.jpg', 'local')).not.toThrow();","+\t});","+","+\ttest('defaults to the first STORAGE_LOCATIONS when storage is omitted', () => {","+\t\texpect(() => assertValidStoragePath('1234.jpg')).not.toThrow();","+\t});","+","+\ttest('blocks writing into the extensions dir when the storage root is cwd', () => {","+\t\tstate.env['STORAGE_LOCAL_ROOT'] = '.';","+\t\texpect(() => assertValidStoragePath('extensions/evil.js', 'local')).toThrow(ForbiddenError);","+\t});","+","+\ttest('blocks writing into the temp dir when the storage root is the cwd', () => {","+\t\tstate.env['STORAGE_LOCAL_ROOT'] = '.';","+\t\texpect(() => assertValidStoragePath('node_modules/.directus/evil.js', 'local')).toThrow(ForbiddenError);","+\t});","+","+\ttest('blocks when EXTENSIONS_PATH is explicitly nested under the storage root', () => {","+\t\tstate.env['STORAGE_LOCAL_ROOT'] = './data';","+\t\tstate.env['EXTENSIONS_PATH'] = './data/extensions';","+\t\texpect(() => assertValidStoragePath('extensions/evil.js', 'local')).toThrow(ForbiddenError);","+\t});","+","+\ttest('does not over-block a sibling folder that shares the extensions prefix', () => {","+\t\tstate.env['STORAGE_LOCAL_ROOT'] = '.';","+\t\texpect(() => assertValidStoragePath('extensions-backup/x.jpg', 'local')).not.toThrow();","+\t});","+","+\tdescribe('remote extension sync source', () => {","+\t\tbeforeEach(() => {","+\t\t\tObject.assign(state.env, {","+\t\t\t\tSTORAGE_LOCATIONS: 'local,s3',","+\t\t\t\tSTORAGE_S3_DRIVER: 's3',","+\t\t\t\tEXTENSIONS_LOCATION: 's3',","+\t\t\t});","+\t\t});","+","+\t\ttest('blocks keys under the EXTENSIONS_PATH prefix on the sync-source bucket', () => {","+\t\t\texpect(() => assertValidStoragePath('extensions/evil/index.js', 's3')).toThrow(ForbiddenError);","+\t\t});","+","+\t\ttest('blocks irrespective of STORAGE_S3_ROOT prefix', () => {","+\t\t\tstate.env['STORAGE_S3_ROOT'] = 'some-prefix';","+\t\t\texpect(() => assertValidStoragePath('extensions/evil/index.js', 's3')).toThrow(ForbiddenError);","+\t\t});","+","+\t\ttest('allows extension-prefixed keys on a remote location that is not extension storage driver', () => {","+\t\t\tstate.env['EXTENSIONS_LOCATION'] = 'other';","+\t\t\texpect(() => assertValidStoragePath('extensions/x.js', 's3')).not.toThrow();","+\t\t});","+\t});","+});"],"additions":78,"deletions":0,"truncated":false},{"path":"api/src/services/files/lib/assert-valid-storage-path.ts","lines":["@@ -0,0 +1,49 @@","+import path from 'node:path';","+import { useEnv } from '@directus/env';","+import { ForbiddenError } from '@directus/errors';","+import { toArray } from '@directus/utils';","+import { sanitizeFilepath } from './sanitize-filepath.js';","+","+/**","+ * Reject storage filepaths that write to \"forbidden\" locations","+ *","+ * @throws ForbiddenError","+ *","+ */","+export function assertValidStoragePath(filepath: string, storage?: string): void {","+\tconst env = useEnv();","+\tconst location = storage || toArray(env['STORAGE_LOCATIONS'] as string[])[0]!;","+\tconst storageDriver