{"id":"f61955d76acb05cd92d8a1704d1d6a35ff5eb2f4","axis":"silent","repo":"WordPress/gutenberg","sha":"f61955d76acb05cd92d8a1704d1d6a35ff5eb2f4","parsed":{"files":[{"path":"backport-changelog/7.1/12264.md","lines":["@@ -0,0 +1,3 @@","+https://github.com/WordPress/wordpress-develop/pull/12264","+","+* https://github.com/WordPress/gutenberg/pull/79403"],"additions":3,"deletions":0,"truncated":false},{"path":"lib/compat/wordpress-7.0/class-wp-connector-registry.php","lines":["@@ -21,7 +21,7 @@"," \t *     logo_url?: non-empty-string,"," \t *     type: non-empty-string,"," \t *     authentication: array{","-\t *         method: 'api_key'|'none',","+\t *         method: 'api_key'|'application_password'|'none',"," \t *         credentials_url?: non-empty-string,"," \t *         setting_name?: non-empty-string,"," \t *         constant_name?: non-empty-string,","@@ -57,12 +57,11 @@ final class WP_Connector_Registry {"," \t\t * Registers a new connector."," \t\t *"," \t\t * Validates the provided arguments and stores the connector in the registry.","-\t\t * For connectors with `api_key` authentication, a `setting_name` can be provided","-\t\t * explicitly. If omitted, one is automatically generated using the pattern","-\t\t * `connectors_{$type}_{$id}_api_key`, with hyphens in the type and ID normalized","-\t\t * to underscores (e.g., connector type `spam_filtering` with ID `akismet` produces","-\t\t * `connectors_spam_filtering_akismet_api_key`). This setting name is used for the","-\t\t * Settings API registration and REST API exposure.","+\t\t * For connectors with `api_key` or `application_password` authentication, a","+\t\t * `setting_name` can be provided explicitly. When omitted, setting names are","+\t\t * automatically generated using the pattern `connectors_{$type}_{$id}_{$method}`,","+\t\t * with hyphens in the type and ID normalized to underscores. These setting","+\t\t * names are used for Settings API registration and REST API exposure."," \t\t *"," \t\t * Registering a connector with an ID that is already registered will trigger a"," \t\t * `_doing_it_wrong()` notice and return `null`. To override an existing connector,","@@ -84,16 +83,24 @@ final class WP_Connector_Registry {"," \t\t *     @type array  $authentication {"," \t\t *         Required. Authentication configuration."," \t\t *","-\t\t *         @type string $method          Required. The authentication method: 'api_key' or 'none'.","+\t\t *         @type string $method          Required. The authentication method: 'api_key',","+\t\t *                                       'application_password', or 'none'."," \t\t *         @type string $credentials_url Optional. URL where users can obtain API credentials.","-\t\t *         @type string $setting_name    Optional. The setting name for the API key.","-\t\t *                                       When omitted, auto-generated as","-\t\t *                                       `connectors_{$type}_{$id}_api_key`.","+\t\t *         @type string $setting_name    Optional. The setting name for the API key","+\t\t *                                       or application-password credentials. When","+\t\t *                                       omitted, auto-generated as","+\t\t *                                       `connectors_{$type}_{$id}_api_key` for API","+\t\t *                                       keys and `connectors_{$type}_{$id}_application_password`","+\t\t *                                       for application passwords."," \t\t *                                       Must be a non-empty string when provided."," \t\t *         @type string $constant_name   Optional. PHP constant name for the API key","-\t\t *                                       (e.g. 'ANTHROPIC_API_KEY'). Only checked when provided.","+\t\t *                                       (e.g. 'ANTHROPIC_API_KEY') or for application-password","+\t\t *                                       credentials in `username:password` format. Only checked","+\t\t *                                       when provided."," \t\t *         @type string $env_var_name    Optional. Environment variable name for the API key","-\t\t *                                       (e.g. 'ANTHROPIC_API_KEY'). Only checked when provided.","+\t\t *                                       (e.g. 'ANTHROPIC_API_KEY') or for application-password","+\t\t *                                       credentials in `username:password` format. Only checked","+\t\t *                                       when provided."," \t\t *     }"," \t\t *     @type array  $plugin         {"," \t\t *         Optional. Plugin data for install/activate UI.","@@ -114,7 +121,7 @@ final class WP_Connector_Registry {"," \t\t *     logo_url?: non-empty-string,"," \t\t *     type: non-empty-string,"," \t\t *     authentication: array{","-\t\t *         method: 'api_key'|'none',","+\t\t *         method: 'api_key'|'application_password'|'none',"," \t\t *         credentials_url?: non-empty-string,"," \t\t *         setting_name?: non-empty-string,"," \t\t *         constant_name?: non-empty-string,","@@ -180,11 +187,11 @@ public function register( string $id, array $args ): ?array {"," \t\t\t\treturn null;"," \t\t\t}"," ","-\t\t\tif ( empty( $args['authentication']['method'] ) || ! in_array( $args['authentication']['method'], array( 'api_key', 'none' ), true ) ) {","+\t\t\tif ( empty( $args['authentication']['method'] ) || ! in_array( $args['authentication']['method'], array( 'api_key', 'application_password', 'none' ), true ) ) {"," \t\t\t\t_doing_it_wrong("," \t\t\t\t\t__METHOD__,"," \t\t\t\t\t/* translators: %s: Connector ID. */","-\t\t\t\t\tsprintf( __( 'Connector \"%s\" authentication method must be \"api_key\" or \"none\".' ), esc_html( $id ) ),","+\t\t\t\t\tsprintf( __( 'Connector \"%s\" authentication method must be \"api_key\", \"application_password\", or \"none\".' ), esc_html( $id ) ),"," \t\t\t\t\t'7.0.0'"," \t\t\t\t);"," \t\t\t\treturn null;","@@ -208,10 +215,13 @@ public function register( string $id, array $args ): ?array {"," \t\t\t\t$connector['logo_url'] = $args['logo_url'];"," \t\t\t}"," ","-\t\t\tif ( 'api_key' === $args['authentication']['method'] ) {","+\t\t\t$requires_credentials = in_array( $args['authentication']['method'], array( 'api_key', 'application_password' ), true );","+","+\t\t\tif ( $requires_credentials ) {"," \t\t\t\tif ( ! empty( $args['authentication']['credentials_url'] ) && is_string( $args['authentication']['credentials_url'] ) ) {"," \t\t\t\t\t$connector['authentication']['credentials_url'] = $args['authentication']['credentials_url'];"," \t\t\t\t}","+"," \t\t\t\tif ( isset( $args['authentication']['setting_name'] ) ) {"," \t\t\t\t\tif ( ! is_string( $args['authentication']['setting_name'] ) || '' === $args['authentication']['setting_name'] ) {"," \t\t\t\t\t\t_doing_it_wrong(","@@ -224,8 +234,9 @@ public function register( string $id, array $args ): ?array {"," \t\t\t\t\t}"," \t\t\t\t\t$connector['authentication']['setting_name'] = $args['authentication']['setting_name'];"," \t\t\t\t} else {","-\t\t\t\t\t$connector['authentication']['setting_name'] = str_replace( '-', '_', \"connectors_{$connector['type']}_{$id}_api_key\" );","+\t\t\t\t\t$connector['authentication']['setting_name'] = str_replace( '-', '_', \"connectors_{$connector['type']}_{$id}_{$args['authentication']['method']}\" );"," \t\t\t\t}","+"," \t\t\t\tif ( isset( $args['authentication']['constant_name'] ) ) {"," \t\t\t\t\tif ( ! is_string( $args['authentication']['constant_name'] ) || '' === $args['authentication']['constant_name'] ) {"," \t\t\t\t\t\t_doing_it_wrong("],"additions":29,"deletions":18,"truncated":false},{"path":"lib/compat/wordpress-7.0/connectors.php","lines":["@@ -44,15 +44,17 @@ function wp_is_connector_registered( string $id ): bool {"," \t *     @type string $logo_url       Optional. URL to the connector's logo image."," \t *     @type string $type           The connector type, e.g. 'ai_provider' or 'spam_filtering'."," \t *     @type array  $authentication {","-\t *         Authentication configuration. When method is 'api_key', includes","-\t *         credentials_url, setting_name, and optionally constant_name and","-\t *         env_var_name. When 'none', only method is present.","+\t *         Authentication configuration. When method is 'api_key' or","+\t *         'application_password', includes credentials_url, setting_name, and","+\t *         optionally constant_name and env_var_name. When 'none', only method","+\t *         is present."," \t *","-\t *         @type string $method          The authentication method: 'api_key' or 'none'.","+\t *         @type string $method          The authentication method: 'api_key',","+\t *                                       'application_password', or 'none'."," \t *         @type string $credentials_url Optional. URL where users can obtain API credentials.","-\t *         @type string $setting_name    Optional. The setting name for the API key.","-\t *         @type string $constant_name   Optional. PHP constant name for the API key.","-\t *         @type string $env_var_name    Optional. Environment variable name for the API key.","+\t *         @type string $setting_name    Optional. The setting name for the API key or application-password credentials.","+\t *         @type string $constant_name   Optional. PHP constant name for the API key or application-password credentials.","+\t *         @type string $env_var_name    Optional. Environment variable name for the API key or application-password credentials."," \t *     }"," \t *     @type array  $plugin         {"," \t *         Optional. Plugin data for install/activate UI.","@@ -69,7 +71,7 @@ function wp_is_connector_registered( string $id ): bool {"," \t *     logo_url?: non-empty-string,"," \t *     type: non-empty-string,"," \t *     authentication: array{","-\t *         method: 'api_key'|'none',","+\t *         method: 'api_key'|'application_password'|'none',"," \t *         credentials_url?: non-empty-string,"," \t *         setting_name?: non-empty-string,"," \t *         constant_name?: non-empty-string,","@@ -110,15 +112,17 @@ function wp_get_connector( string $id ): ?array {"," \t *         @type string      $logo_url       Optional. URL to the connector's logo image."," \t *         @type string      $type           The connector type, e.g. 'ai_provider' or 'spam_filtering'."," \t *         @type array       $authentication {","-\t *             Authentication configuration. When method is 'api_key', includes","-\t *             credentials_url, setting_name, and optionally constant_name and","-\t *             env_var_name. When 'none', only method is present.","+\t *             Authentication configuration. When method is 'api_key' or","+\t *             'application_password', includes credentials_url, setting_name,","+\t *             and optionally constant_name and env_var_name. When 'none', only","+\t *             method is present."," \t *","-\t *             @type string $method          The authentication method: 'api_key' or 'none'.","+\t *             @type string $method          The authentication method: 'api_key',","+\t *                                           'application_password', or 'none'."," \t *             @type string $credentials_url Optional. URL where users can obtain API credentials.","-\t *             @type string $setting_name    Optional. The setting name for the API key.","-\t *             @type string $constant_name   Optional. PHP constant name for the API key.","-\t *             @type string $env_var_name    Optional. Environment variable name for the API key.","+\t *             @type string $setting_name    Optional. The setting name for the API key or application-password credentials.","+\t *             @type string $constant_name   Optional. PHP constant name for the API key or application-password credentials.","+\t *             @type string $env_var_name    Optional. Environment variable name for the API key or application-password credentials."," \t *         }"," \t *         @type array       $plugin         {"," \t *             Optional. Plugin data for install/activate UI.","@@ -136,7 +140,7 @@ function wp_get_connector( string $id ): ?array {"," \t *     logo_url?: non-empty-string,"," \t *     type: non-empty-string,"," \t *     authentication: array{","-\t *         method: 'api_key'|'none',","+\t *         method: 'api_key'|'application_password'|'none',"," \t *         credentials_url?: non-empty-string,"," \t *         setting_name?: non-empty-string,"," \t *         constant_name?: non-empty-string,"],"additions":20,"deletions":16,"truncated":false},{"path":"lib/compat/wordpress-7.0/default-connectors.php","lines":["@@ -252,6 +252,115 @@ function _gutenberg_get_api_key_source( string $setting_name, string $env_var_na"," \treturn 'none';"," }"," ","+/**","+ * Parses a `username:password` credentials string.","+ *","+ * Splits on the first colon, matching the HTTP Basic authentication","+ * userinfo format, so passwords may contain colons.","+ *","+ * @access private","+ *","+ * @param string $value The raw credentials string.","+ * @return array{username: string, password: string} Parsed credentials. Both values","+ *                                                   are empty when the string is malformed.","+ */","+function _gutenberg_parse_application_password_credentials( string $value ): array {","+\t$separator = strpos( $value, ':' );","+\t// Trim so surrounding whitespace or a trailing newline (common when the","+\t// value comes from a file or `.env`) does not become part of the credentials.","+\t$username = false === $separator ? '' : trim( substr( $value, 0, $separator ) );","+\t$password = false === $separator ? '' : trim( substr( $value, $separator + 1 ) );","+","+\tif ( '' === $username || '' === $password ) {","+\t\treturn array(","+\t\t\t'username' => '',","+\t\t\t'password' => '',","+\t\t);","+\t}","+","+\treturn array(","+\t\t'username' => $username,","+\t\t'password' => $password,","+\t);","+}","+","+/**","+ * Resolves application-password credentials for a connector.","+ *","+ * Checks in order: environment variable, PHP constant, database. The","+ * environment variable and constant are only checked when their respective","+ * names are provided, and must contain the credentials as a single","+ * `username:password` string. A non-empty environment variable or constant","+ * that cannot be parsed as `username:password` is reported with","+ * `_doing_it_wrong()` and ignored, so resolution falls through to the next","+ * source.","+ *","+ * @access private","+ *","+ * @param array $auth The connector's authentication configuration.","+ * @return array{username: string, password: string, source: string} Resolved credentials and","+ *                                                                   their source: 'env', 'constant',","+ *                                                                   'database', or 'none'.","+ */","+function _gutenberg_get_application_password_credentials( array $auth ): array {","+\t// Check environment variable (only if explicitly configured).","+\t$env_var_name = $auth['env_var_name'] ?? '';","+\tif ( '' !== $env_var_name ) {","+\t\t$env_value = getenv( $env_var_name );","+\t\tif ( false !== $env_value && '' !== $env_value ) {","+\t\t\t$credentials = _gutenberg_parse_application_password_credentials( $env_value );","+\t\t\tif ( '' !== $credentials['username'] && '' !== $credentials['password'] ) {","+\t\t\t\t$credentials['source'] = 'env';","+\t\t\t\treturn $credentials;","+\t\t\t}","+","+\t\t\t_doing_it_wrong(","+\t\t\t\t__FUNCTION__,","+\t\t\t\tsprintf(","+\t\t\t\t\t/* translators: %s: Environment variable name. */","+\t\t\t\t\t__( 'The %s environment variable must contain application password credentials in \"username:password\" format.', 'gutenberg' ),","+\t\t\t\t\tesc_html( $env_var_name )","+\t\t\t\t),","+\t\t\t\t'7.0.0'","+\t\t\t);","+\t\t}","+\t}","+","+\t// Check PHP constant (only if explicitly configured).","+\t$constant_name = $auth['constant_name'] ?? '';","+\tif ( '' !== $constant_name && defined( $constant_name ) ) {","+\t\t$const_value = constant( $constant_name );","+\t\tif ( is_string( $const_value ) && '' !== $const_value ) {","+\t\t\t$credentials = _gutenberg_parse_application_password_credentials( $const_value );","+\t\t\tif ( '' !== $credentials['username'] && '' !== $credentials['password'] ) {","+\t\t\t\t$credentials['source'] = 'constant';","+\t\t\t\treturn $credentials;","+\t\t\t}","+","+\t\t\t_doing_it_wrong(","+\t\t\t\t__FUNCTION__,","+\t\t\t\tsprintf(","+\t\t\t\t\t/* translators: %s: PHP constant name. */","+\t\t\t\t\t__( 'The %s constant must contain application password credentials in \"username:password\" format.', 'gutenberg' ),","+\t\t\t\t\tesc_html( $constant_name )","+\t\t\t\t),","+\t\t\t\t'7.0.0'","+\t\t\t);","+\t\t}","+\t}","+","+\t// Check database.","+\t$stored   = get_option( $auth['setting_name'] ?? '', array() );","+\t$username = is_array( $stored ) && isset( $stored['username'] ) && is_string( $stored['username'] ) ? $stored['username'] : '';","+\t$password = is_array( $stored ) && isset( $stored['password'] ) && is_string( $stored['password'] ) ? $stored['password'] : '';","+","+\treturn array(","+\t\t'username' => $username,","+\t\t'password' => $password,","+\t\t'source'   => '' !== $username && '' !== $password ? 'database' : 'none',","+\t);","+}","+"," /**","  * Masks an API key, showing only the last 4 characters.","  *","@@ -307,13 +416,72 @@ function _gutenberg_is_ai_api_key_valid( string $key, string $provider_id ): ?bo"," }"," "," /**","- * Masks and validates connector API keys in REST responses.","+ * Sanitizes stored application-password credentials for a connector.","+ *","+ * Credential fields that are missing or not strings keep their currently","+ * stored values, so partial updates cannot silently clear a stored secret.","+ * A password matching the mask that `_gutenberg_connectors_rest_settings_dispatch()`","+ * places in REST responses also keeps the stored password, so a masked","+ * settings response can be submitted back to the endpoint unchanged.","+ * Pass an empty string to clear a field.","+ * If the sanitized username is empty, both fields are discarded so partial","+ * credentials cannot leave an orphaned secret.","+ *","+ * @access private","+ *","+ * @param mixed  $value  The submitted setting value.","+ * @param string $option The option name being sanitized. Passed explicitly by the","+ *                       registered sanitize callback; falls back to the current","+ *                       `sanitize_option_{$option}` filter name when omitted.","+ * @return array{username: string, password: string} Sanitized credentials.","+ */","+function _gutenberg_sanitize_application_password_credentials( $value, string $option = '' ): array {","+\tif ( ! is_array( $value ) ) {","+\t\t$value = array();","+\t}","+","+\tif ( '' === $option ) {","+\t\t$option = str_replace( 'sanitize_option_', '', (string) current_filter() );","+\t}","+","+\t$stored = get_option( $option );","+\tif ( ! is_array( $stored ) ) {","+\t\t$stored = array();","+\t}","+","+\t$credentials = array();","+\tforeach ( array( 'username', 'password' ) as $field ) {","+\t\tif ( isset( $value[ $field ] ) && is_string( $value[ $field ] ) ) {","+\t\t\t$credentials[ $field ] = sanitize_text_field( $value[ $field ] );","+\t\t} else {","+\t\t\t$credentials[ $field ] = isset( $stored[ $field ] ) && is_string( $stored[ $field ] ) ? $stored[ $field ] : '';","+\t\t}","+\t}","+","+\t// A masked password means a client resubmitted a masked REST response.","+\tif ( str_repeat( \"\\u{2022}\", 16 ) === $credentials['password'] ) {","+\t\t$credentials['password'] = isset( $stored['password'] ) && is_string( $stored['password'] ) ? $stored['password'] : '';","+\t}","+","+\tif ( '' === $credentials['username'] ) {","+\t\treturn array("