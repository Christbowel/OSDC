ration. All rights reserved.","+ *  Licensed under the MIT License. See License.txt in the project root for license information.","+ *--------------------------------------------------------------------------------------------*/","+","+import * as vscode from 'vscode';","+import { IAuthenticationService } from '../../../platform/authentication/common/authentication';","+import { IConfigurationService } from '../../../platform/configuration/common/configurationService';","+import { ILogService } from '../../../platform/log/common/logService';","+import { Disposable } from '../../../util/vs/base/common/lifecycle';","+","+const NOTIFICATION_ID = 'copilot.byokUtilityModelHint';","+const UTILITY_MODEL_SETTING = 'chat.utilityModel';","+const UTILITY_SMALL_MODEL_SETTING = 'chat.utilitySmallModel';","+","+/**","+ * Shows a chat input notification in air-gapped BYOK scenarios (no GitHub","+ * session) when at least one BYOK model is available but the utility model","+ * settings are still defaults. The default utility models require GitHub","+ * Copilot access, so without it the utility slots silently fall back and","+ * degrade the experience until the user points them at a BYOK model.","+ *","+ * The notification hides automatically once the user signs in, BYOK models","+ * disappear, or both utility settings are configured.","+ */","+export class ByokUtilityModelNotificationContribution extends Disposable {","+","+\tprivate _notification: vscode.ChatInputNotification | undefined;","+\tprivate _hasByokModels = false;","+\tprivate _refreshing = false;","+","+\tconstructor(","+\t\t@IAuthenticationService private readonly _authService: IAuthenticationService,","+\t\t@IConfigurationService private readonly _configService: IConfigurationService,","+\t\t@ILogService private readonly _logService: ILogService,","+\t) {","+\t\tsuper();","+","+\t\tthis._register(this._authService.onDidAuthenticationChange(() => this._update()));","+\t\tthis._register(vscode.lm.onDidChangeChatModels(() => this._update()));","+\t\tthis._register(this._configService.onDidChangeConfiguration(e => {","+\t\t\tif (e.affectsConfiguration(UTILITY_MODEL_SETTING) || e.affectsConfiguration(UTILITY_SMALL_MODEL_SETTING)) {","+\t\t\t\tthis._update();","+\t\t\t}","+\t\t}));","+","+\t\tthis._update();","+\t}","+","+\tprivate async _refreshHasByokModels(): Promise<void> {","+\t\tif (this._refreshing) {","+\t\t\treturn;","+\t\t}","+\t\tthis._refreshing = true;","+\t\ttry {","+\t\t\tconst models = await vscode.lm.selectChatModels({});","+\t\t\tthis._hasByokModels = models.some(m => m.vendor !== 'copilot');","+\t\t} catch (err) {","+\t\t\tthis._logService.warn(`[ByokUtilityModelNotification] Failed to query language models: ${err}`);","+\t\t} finally {","+\t\t\tthis._refreshing = false;","+\t\t}","+\t}","+","+\tprivate async _update(): Promise<void> {","+\t\tawait this._refreshHasByokModels();","+","+\t\tconst signedOut = !this._authService.anyGitHubSession;","+\t\tconst utilityUnset = !this._isUtilityOverrideSet(UTILITY_MODEL_SETTING);","+\t\tconst utilitySmallUnset = !this._isUtilityOverrideSet(UTILITY_SMALL_MODEL_SETTING);","+","+\t\tif (!signedOut || !this._hasByokModels || (!utilityUnset && !utilitySmallUnset)) {","+\t\t\tthis._hideNotification();","+\t\t\treturn;","+\t\t}","+","+\t\tthis._showNotification(utilityUnset, utilitySmallUnset);","+\t}","+","+\tprivate _isUtilityOverrideSet(configKey: string): boolean {","+\t\tconst raw = this._configService.getNonExtensionConfig<unknown>(configKey);","+\t\treturn typeof raw === 'string' && raw.length > 0;","+\t}","+","+\tprivate _showNotification(utilityUnset: boolean, utilitySmallUnset: boolean): void {","+\t\tconst notification = this._ensureNotification();","+\t\tnotification.severity = vscode.ChatInputNotificationSeverity.Info;","+\t\tnotification.dismissible = true;","+\t\tnotification.autoDismissOnMessage = false;","+","+\t\tif (utilityUnset && utilitySmallUnset) {","+\t\t\tnotification.message = vscode.l10n.t('Set BYOK utility models');","+\t\t\tnotification.description = vscode.l10n.t('Unlocks full AI features.');","+\t\t\tnotification.actions = [","+\t\t\t\t{ label: vscode.l10n.t('Configure'), commandId: 'workbench.action.openSettings', commandArgs: ['chat.utility'] },","+\t\t\t];","+\t\t} else if (utilityUnset) {","+\t\t\tnotification.message = vscode.l10n.t('Set BYOK utility model');","+\t\t\tnotification.description = vscode.l10n.t('Unlocks full AI features.');","+\t\t\tnotification.actions = [","+\t\t\t\t{ label: vscode.l10n.t('Configure'), commandId: 'workbench.action.openSettings', commandArgs: [UTILITY_MODEL_SETTING] },","+\t\t\t];","+\t\t} else {","+\t\t\tnotification.message = vscode.l10n.t('Set BYOK small utility model');","+\t\t\tnotification.description = vscode.l10n.t('Unlocks full AI features.');","+\t\t\tnotification.actions = [","+\t\t\t\t{ label: vscode.l10n.t('Configure'), commandId: 'workbench.action.openSettings', commandArgs: [UTILITY_SMALL_MODEL_SETTING] },","+\t\t\t];","+\t\t}","+","+\t\tnotification.show();","+\t}","+","+\tprivate _ensureNotification(): vscode.ChatInputNotification {","+\t\tif (!this._notification) {","+\t\t\tthis._notification = vscode.chat.createInputNotification(NOTIFICATION_ID);","+\t\t\tthis._register({ dispose: () => this._notification?.dispose() });","+\t\t}","+\t\treturn this._notification;","+\t}","+","+\tprivate _hideNotification(): void {","+\t\tthis._notification?.hide();","+\t}","+}"],"additions":125,"deletions":0,"truncated":false},{"path":"extensions/copilot/src/extension/chatInputNotification/vscode-node/test/byokUtilityModel.contribution.spec.ts","lines":["@@ -0,0 +1,199 @@","+/*---------------------------------------------------------------------------------------------","+ *  Copyright (c) Microsoft Corporation. All rights reserved.","+ *  Licensed under the MIT License. See License.txt in the project root for license information.","+ *--------------------------------------------------------------------------------------------*/","+","+import { afterEach, beforeEach, describe, expect, test, vi } from 'vitest';","+import { IAuthenticationService } from '../../../../platform/authentication/common/authentication';","+import { IConfigurationService } from '../../../../platform/configuration/common/configurationService';","+import { ILogService } from '../../../../platform/log/common/logService';","+import { Emitter } from '../../../../util/vs/base/common/event';","+","+// ---- vscode mock -----------------------------------------------------------","+","+const mockNotification = {","+\tseverity: 0,","+\tdismissible: false,","+\tautoDismissOnMessage: false,","+\tmessage: '',","+\tdescription: '',","+\tactions: [] as { label: string; commandId: string; commandArgs?: unknown[] }[],","+\tshow: vi.fn(),","+\thide: vi.fn(),","+\tdispose: vi.fn(),","+};","+","+const onDidChangeChatModelsEmitter = new Emitter<void>();","+const selectChatModelsMock = vi.fn();","+","+vi.mock('vscode', () => ({","+\tChatInputNotificationSeverity: { Info: 1 },","+\tchat: {","+\t\tcreateInputNotification: vi.fn(() => mockNotification),","+\t},","+\tlm: {","+\t\tget onDidChangeChatModels() { return onDidChangeChatModelsEmitter.event; },","+\t\tselectChatModels: (...args: unknown[]) => selectChatModelsMock(...args),","+\t},","+\tl10n: { t: (str: string, ...args: unknown[]) => str.replace(/\\{(\\d+)\\}/g, (_, i) => String(args[Number(i)])) },","+}));","+","+import { ByokUtilityModelNotificationContribution } from '../byokUtilityModel.contribution';","+","+// ---- helpers ---------------------------------------------------------------","+","+function createAuthService(opts?: { anyGitHubSession?: unknown }) {","+\tconst emitter = new Emitter<void>();","+\tconst hasSession = opts && 'anyGitHubSession' in opts;","+\tconst authService = {","+\t\t_serviceBrand: undefined,","+\t\tanyGitHubSession: hasSession ? opts!.anyGitHubSession : undefined,","+\t\tonDidAuthenticationChange: emitter.event,","+\t} as unknown as IAuthenticationService;","+\treturn { authService, emitter };","+}","+","+function createConfigService(values: Record<string, unknown> = {}) {","+\tconst emitter = new Emitter<{ affectsConfiguration: (key: string) => boolean }>();","+\tconst store = new Map<string, unknown>(Object.entries(values));","+\tconst configService = {","+\t\t_serviceBrand: undefined,","+\t\tgetNonExtensionConfig: <T,>(key: string) => store.get(key) as T | undefined,","+\t\tonDidChangeConfiguration: emitter.event,","+\t} as unknown as IConfigurationService;","+\tconst set = (key: string, value: unknown) => {","+\t\tif (value === undefined) {","+\t\t\tstore.delete(key);","+\t\t} else {","+\t\t\tstore.set(key, value);","+\t\t}","+\t\temitter.fire({ affectsConfiguration: (k: string) => k === key });","+\t};","+\treturn { configService, set };","+}","+","+const noopLog = {","+\t_serviceBrand: undefined,","+\ttrace: vi.fn(), debug: vi.fn(), info: vi.fn(), warn: vi.fn(), error: vi.fn(), show: vi.fn(),","+} as unknown as ILogService;","+","+async function flushAsync() {","+\t// Drain microtasks so async _update() observers complete.","+\tawait Promise.resolve();","+\tawait Promise.resolve();","+\tawait Promise.resolve();","+}","+","+// ---- tests -----------------------------------------------------------------","+","+describe('ByokUtilityModelNotificationContribution', () => {","+\tlet contribution: ByokUtilityModelNotificationContribution | undefined;","+","+\tbeforeEach(() => {","+\t\tvi.clearAllMocks();","+\t\tmockNotification.show.mockClear();","+\t\tmockNotification.hide.mockClear();","+\t\tmockNotification.message = '';","+\t\tmockNotification.description = '';","+\t\tmockNotification.actions = [];","+\t\tselectChatModelsMock.mockResolvedValue([{ vendor: 'ollama', id: 'llama3' }]);","+\t});","+","+\tafterEach(() => {","+\t\tcontribution?.dispose();","+\t\tcontribution = undefined;","+\t});","+","+\ttest('shows notification when signed out + BYOK + both utility settings unset', async () => {","+\t\tconst { authService } = createAuthService({ anyGitHubSession: undefined });","+\t\tconst { configService } = createConfigService();","+\t\tcontribution = new ByokUtilityModelNotificationContribution(authService, configService, noopLog);","+","+\t\tawait flushAsync();","+","+\t\texpect(mockNotification.show).toHaveBeenCalled();","+\t\texpect(mockNotification.message).toBe('Set BYOK utility models');","+\t\texpect(mockNotification.actions).toHaveLength(1);","+\t\texpect(mockNotification.actions[0].commandId).toBe('workbench.action.openSettings');","+\t\texpect(mockNotification.actions[0].commandArgs).toEqual(['chat.utility']);","+\t});","+","+\ttest('shows notification with single action when only chat.utilityModel is unset', async () => {","+\t\tconst { authService } = createAuthService({ anyGitHubSession: undefined });","+\t\tconst { configService } = createConfigService({ 'chat.utilitySmallModel': 'ollama/llama3' });","+\t\tcontribution = new ByokUtilityModelNotificationContribution(authService, configService, noopLog);","+","+\t\tawait flushAsync();","+","+\t\texpect(mockNotification.show).toHaveBeenCalled();","+\t\texpect(mockNotification.message).toBe('Set BYOK utility model');","+\t\texpect(mockNotification.actions).toHaveLength(1);","+\t\texpect(mockNotification.actions[0].commandArgs).toEqual(['chat.utilityModel']);","+\t});","+","+\ttest('does not show notification when signed in', async () => {","+\t\tconst { authService } = createAuthService({ anyGitHubSession: { accessToken: 'tok' } });","+\t\tconst { configService } = createConfigService();","+\t\tcontribution = new ByokUtilityModelNotificationContribution(authService, configService, noopLog);","+","+\t\tawait flushAsync();","+","+\t\texpect(mockNotification.show).not.toHaveBeenCalled();","+\t});","+","+\ttest('does not show notification when no BYOK models are registered', async () => {","+\t\tselectChatModelsMock.mockResolvedValue([{ vendor: 'copilot', id: 'gpt-4' }]);","+\t\tconst { authService } = createAuthService({ anyGitHubSession: undefined });","+\t\tconst { configService } = createConfigService();","+\t\tcontribution = new ByokUtilityModelNotificationContribution(authService, configService, noopLog);","+","+\t\tawait flushAsync();","+","+\t\texpect(mockNotification.show).not.toHaveBeenCalled();","+\t});","+","+\ttest('does not show notification when both utility settings are configured', async () => {","+\t\tconst { authService } = createAuthService({ anyGitHubSession: undefined });","+\t\tconst { configService } = createConfigService({","+\t\t\t'chat.utilityModel': 'ollama/llama3',","+\t\t\t'chat.utilitySmallModel': 'ollama/llama3',","+\t\t});","+\t\tcontribution = new ByokUtilityModelNotificationContribution(authService, configService, noopLog);","+","+\t\tawait flushAsync();","+","+\t\texpect(mockNotification.show).not.toHaveBeenCalled();","+\t});","+","+\ttest('hides notification once both utility settings are configured', async () => {","+\t\tconst { authService } = createAuthService({ anyGitHubSession: undefined });","+\t\tconst { configService, set } = createConfigService();","+\t\tcontribution = new ByokUtilityModelNotificationContribution(authService, configService, noopLog);","+","+\t\tawait flushAsync();","+\t\texpect(mockNotification.show).toHaveBeenCalled();","+","+\t\tset('chat.utilityModel', 'ollama/llama3');","+\t\tawait flushAsync();","+\t\texpect(mockNotification.hide).not.toHaveBeenCalled(); // small model still unset → still showing","+","+\t\tset('chat.utilitySmallModel', 'ollama/llama3');","+\t\tawait flushAsync();","+\t\texpect(mockNotification.hide).toHaveBeenCalled();","+\t});","+","+\ttest('hides notification when user signs in', async () => {","+\t\tconst { authService, emitter } = createAuthService({ anyGitHubSession: undefined });","+\t\tconst { configService } = createConfigService();","+\t\tcontribution = new ByokUtilityModelNotificationContribution(authService, configService, noopLog);","+","+\t\tawait flushAsync();","+\t\texpect(mockNotification.show).toHaveBeenCalled();","+","+\t\t(authService as unknown as { anyGitHubSession: unknown }).anyGitHubSession = { accessToken: 'tok' };","+\t\temitter.fire();","+\t\tawait flushAsync();","+","+\t\texpect(mockNotification.hide).toHaveBeenCalled();","+\t});","+});"],"additions":199,"deletions":0,"truncated":false},{"path":"extensions/copilot/src/extension/chatSessions/copilotcli/node/copilotCli.ts","lines":["@@ -96,6 +96,10 @@ export class CopilotCLIModels extends Disposable implements ICopilotCLIModels {"," \t}"," "," \tprivate _fetchAndCacheModels(): void {","+\t\tif (!this._authenticationService.anyGitHubSession) {","+\t\t\tthis.logService.info('[CopilotCLIModels] Skipping model fetch since there is no GitHub session');","+\t\t\treturn;","+\t\t}"," \t\tconst availableModels = this._availableModels = this._getAvailableModels();"," \t\tavailableModels.then(models => {"," \t\t\t// Bail out if a newer fetch has superseded this one (e.g. auth changed mid-flight)."],"additions":4,"deletions":0,"truncated":false},{"path":"extensions/copilot/src/extension/completions/vscode-node/completionsCoreContribution.ts","lines":["@@ -31,9 +31,14 @@ export class CompletionsCoreContribution extends Disposable {"," \t\t\tconst unificationStateValue = unificationState.read(reader);"," \t\t\tconst configEnabled = configurationService.getExperimentBasedConfigObservable<boolean>(ConfigKey.TeamInternal.InlineEditsEnableGhCompletionsProvider, experimentationService).read(reader);"," \t\t\tconst extensionUnification = unificationStateValue?.extensionUnification ?? false;","+\t\t\tconst copilotToken = this._copilotToken.read(reader);"," "," \t\t\tlet hasInstantiatedProvider = false;","-\t\t\tif (unificationStateValue?.codeUnification || extensionUnification || configEnabled || this._copilotToken.read(reader)?.isNoAuthUser) {","+\t\t\t// Completions require a Copilot token to call the completions endpoint, so don't","+\t\t\t// register the provider in air-gapped / signed-out