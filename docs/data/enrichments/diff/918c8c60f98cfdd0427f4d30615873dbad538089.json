{"id":"918c8c60f98cfdd0427f4d30615873dbad538089","axis":"silent","repo":"WordPress/gutenberg","sha":"918c8c60f98cfdd0427f4d30615873dbad538089","parsed":{"files":[{"path":"docs/explanations/architecture/dashboard-widgets.md","lines":["@@ -25,14 +25,15 @@ widgets/hello-world/"," ├── widget.json        static metadata (name, title, description, help, actions, keywords, category, presentation, textdomain)"," ├── widget.ts          metadata module: default-exports icon, attributes, example"," ├── render.tsx         render module: default-exports the React component","-└── style.module.css   optional, injected at runtime by the build","+├── style.module.css   optional, injected at runtime by the build","+└── report.csv         optional static asset linked from an action `href`"," ```"," "," The split between `widget.json` and `widget.ts` is deliberate. `widget.json` is build-time input: plain JSON the pipeline can read without executing code, including the translatable strings (`title`, `description`, `help`, `keywords`) the server localizes through `textdomain`."," "," Unlike the other translatable strings, `help` is an object: `content` plus optional `links`, meant for compact surfaces such as tooltips."," ","-`actions` is a list of the declarative actions a widget exposes: each carries `id`, `label`, `href`, and optional `download` / `openInNewTab`, with the label translated. A host renders them as links and decides where; the dashboard surfaces them in a \"More\" menu. Because navigation and download are the browser's, the widget declares an intent and a target without knowing its surface.","+`actions`: declarative links (`id`, `label`, `href`, optional `download` / `openInNewTab`). Hosts place them; the dashboard uses a \"More\" menu. A relative `href` that exists under `widgets/{name}/` becomes a plugin URL at registration; missing relative non-admin files are dropped. `data:` and `javascript:` hrefs are rejected. Prefer absolute URLs for assets that must work in the plugin zip (which does not ship `widgets/`)."," "," `widget.ts` is the live half of the metadata: values that only exist in JavaScript, such as the icon element or the `attributes` field schema (including optional `relevance` hints) that hosts feed into `DataForm`."," "],"additions":3,"deletions":2,"truncated":false},{"path":"lib/experimental/dashboard-widgets/widget-types.php","lines":["@@ -111,14 +111,73 @@ function gutenberg_sanitize_widget_help( $help ) {"," }"," "," /**","- * Constrains a widget's actions to their allowed shape: each entry keeps","- * `id`, `label`, and `href`; entries missing any of those are dropped.","- * Optional `download` and `openInNewTab` are copied when present.","+ * Resolves a widget-local file href to a plugin URL.","  *","- * @param array|null $actions Actions from the build manifest.","- * @return array|null Sanitized actions, or null when there are none.","+ * Leaves absolute, scheme-relative, root-relative, and single-segment admin","+ * `.php` hrefs unchanged. Returns '' for local path traversal and for","+ * relative hrefs that are not a file under `widgets/{dir}/` (so","+ * `esc_url_raw()` cannot invent `http://filename`). Query strings on local","+ * filenames are not stripped: `report.csv?v=2` will not resolve as a file.","+ *","+ * @param string $href     Action href.","+ * @param string $dir_name Widget directory name.","+ * @return string Plugin URL, original href, or ''.","+ */","+function gutenberg_resolve_widget_action_href( $href, $dir_name ) {","+\tif ( ! is_string( $href ) || '' === $href ) {","+\t\treturn '';","+\t}","+","+\t// Absolute, scheme-relative, or schemed — including URLs with `..` in the path.","+\tif ( preg_match( '#^([a-z][a-z0-9+.-]*:)?//#i', $href ) || str_contains( $href, ':' ) ) {","+\t\treturn $href;","+\t}","+","+\t// Root-relative paths (e.g. /wp-admin/…, /report.csv).","+\tif ( str_starts_with( $href, '/' ) ) {","+\t\treturn $href;","+\t}","+","+\tif ( str_contains( $href, '..' ) ) {","+\t\treturn '';","+\t}","+","+\t$path_only = preg_split( '/[?#]/', $href, 2 )[0];","+\tif ( str_ends_with( strtolower( $path_only ), '.php' ) ) {","+\t\t// Single-segment admin entry points stay as-is. Deeper relative","+\t\t// paths would come out of `esc_url_raw()` as `http://` URLs, and","+\t\t// PHP files never resolve as local widget assets.","+\t\treturn str_contains( $path_only, '/' ) ? '' : $href;","+\t}","+","+\tif ( ! is_string( $dir_name ) || '' === $dir_name ) {","+\t\treturn '';","+\t}","+","+\t$candidate = 'widgets/' . $dir_name . '/' . $href;","+","+\tif ( is_file( gutenberg_dir_path() . $candidate ) ) {","+\t\treturn gutenberg_url( $candidate );","+\t}","+","+\treturn '';","+}","+","+/**","+ * Sanitizes widget actions to `id` / `label` / `href` (via `esc_url_raw()`),","+ * plus optional `download` / `openInNewTab`. Drops incomplete or unsafe","+ * entries; dropped hrefs are reported through `_doing_it_wrong()`. With","+ * `$dir_name`, resolves widget-local file hrefs first.","+ *","+ * This is the registration gate for manifest-sourced widget types. Definitions","+ * registered only on the client do not pass through it; any future CPT/API","+ * source should reuse this helper at that boundary.","+ *","+ * @param array|null $actions  Actions from the build manifest.","+ * @param string     $dir_name Optional widget directory for local asset hrefs.","+ * @return array|null Sanitized actions, or null.","  */","-function gutenberg_sanitize_widget_actions( $actions ) {","+function gutenberg_sanitize_widget_actions( $actions, $dir_name = '' ) {"," \tif ( ! is_array( $actions ) ) {"," \t\treturn null;"," \t}","@@ -127,23 +186,48 @@ function gutenberg_sanitize_widget_actions( $actions ) {"," \tforeach ( $actions as $action ) {"," \t\tif ("," \t\t\t! is_array( $action ) ||","-\t\t\tempty( $action['id'] ) ||","-\t\t\tempty( $action['label'] ) ||","-\t\t\tempty( $action['href'] )","+\t\t\t! isset( $action['id'], $action['label'], $action['href'] ) ||","+\t\t\t! is_string( $action['id'] ) ||","+\t\t\t! is_string( $action['label'] ) ||","+\t\t\t! is_string( $action['href'] ) ||","+\t\t\t'' === $action['id'] ||","+\t\t\t'' === $action['label'] ||","+\t\t\t'' === $action['href']"," \t\t) {"," \t\t\tcontinue;"," \t\t}"," ","+\t\t$href = gutenberg_resolve_widget_action_href( $action['href'], $dir_name );","+\t\t$href = esc_url_raw( $href );","+\t\tif ( ! $href ) {","+\t\t\t_doing_it_wrong(","+\t\t\t\t__FUNCTION__,","+\t\t\t\tsprintf(","+\t\t\t\t\t/* translators: 1: Widget action id. 2: Declared action href. */","+\t\t\t\t\t__( 'Dropped widget action \"%1$s\": href \"%2$s\" is neither an allowed URL nor an existing widget file.', 'gutenberg' ),","+\t\t\t\t\t$action['id'],","+\t\t\t\t\t$action['href']","+\t\t\t\t),","+\t\t\t\t'23.7.0'","+\t\t\t);","+\t\t\tcontinue;","+\t\t}","+"," \t\t$entry = array("," \t\t\t'id'    => $action['id'],"," \t\t\t'label' => $action['label'],","-\t\t\t'href'  => $action['href'],","+\t\t\t'href'  => $href,"," \t\t);"," "," \t\tif ( isset( $action['download'] ) ) {","-\t\t\t$entry['download'] = is_bool( $action['download'] )","-\t\t\t\t? $action['download']","-\t\t\t\t: (string) $action['download'];","+\t\t\tif ( is_bool( $action['download'] ) ) {","+\t\t\t\t$entry['download'] = $action['download'];","+\t\t\t} else {","+\t\t\t\t$filename = sanitize_file_name( (string) $action['download'] );","+\t\t\t\tif ( $filename ) {","+\t\t\t\t\t$entry['download'] = $filename;","+\t\t\t\t}","+\t\t\t}"," \t\t}"," "," \t\tif ( isset( $action['openInNewTab'] ) ) {","@@ -189,7 +273,10 @@ function gutenberg_register_widget_types() {"," \t\t\t\t'title'         => $widget['title'] ?? null,"," \t\t\t\t'description'   => $widget['description'] ?? null,"," \t\t\t\t'help'          => gutenberg_sanitize_widget_help( $widget['help'] ?? null ),","-\t\t\t\t'actions'       => gutenberg_sanitize_widget_actions( $widget['actions'] ?? null ),","+\t\t\t\t'actions'       => gutenberg_sanitize_widget_actions(","+\t\t\t\t\t$widget['actions'] 