ivate String string;","+","+\t@DateTimeFormat(pattern = \"dd-MM-yyyy\")","+\tprivate CharSequence charSequence;","+","+\t@DateTimeFormat(pattern = \"dd-MM-yyyy\")","+\tprivate Integer integer;","+}"],"additions":21,"deletions":0,"truncated":false},{"path":"documentation/src/main/asciidoc/reference/_ch02.adoc","lines":["@@ -694,6 +694,10 @@ The default is `ANY`, which means both IPv4 and IPv6 addresses are considered va"," \tSupported data types::: `CharSequence`"," \tHibernate metadata impact::: None"," ","+`@DateTimeFormat`:: Checks that the annotated character sequence is valid for the date and/or time format. The `pattern` parameter specifies the date/time format pattern (e.g., \"yyyy-MM-dd\", \"dd/MM/yyyy HH:mm:ss\") following `java.time.format.DateTimeFormatter` conventions. The `locale` parameter accepts one or more locale strings (e.g., `\"en-US\"`, `{\"en-US\", \"fr-FR\"}`), validation succeeds if the value parses with any of them; defaults to `\"ROOT\"` which works for numeric patterns but not text-based ones like month names. The `lenient` parameter determines date validation behaviour: when `false` (default), invalid dates like February 31st are rejected; when `true`, invalid dates are accepted and rolled over to subsequent months (e.g., February 30th becomes March 2nd). `null` values are always considered valid.","+\tSupported data types::: `CharSequence`","+\tHibernate metadata impact::: None","+"," `@Length(min=, max=)`:: Validates that the annotated character sequence is between `min` and `max` included"," \tSupported data types::: `CharSequence`"," \tHibernate metadata impact::: Column length will be set to max"],"additions":4,"deletions":0,"truncated":false},{"path":"engine/src/main/java/org/hibernate/validator/cfg/defs/DateTimeFormatDef.java","lines":["@@ -0,0 +1,48 @@","+/*","+ * SPDX-License-Identifier: Apache-2.0","+ * Copyright Red Hat Inc. and Hibernate Authors","+ */","+package org.hibernate.validator.cfg.defs;","+","+","+import java.util.Locale;","+","+import org.hibernate.validator.cfg.ConstraintDef;","+import org.hibernate.validator.constraints.DateTimeFormat;","+","+/**","+ * An {@link org.hibernate.validator.constraints.DateTimeFormat} constraint definition.","+ * @author Sean Okafor","+ * @since 9.2","+ */","+public class DateTimeFormatDef extends ConstraintDef<DateTimeFormatDef, DateTimeFormat> {","+","+\tpublic DateTimeFormatDef() {","+\t\tsuper( DateTimeFormat.class );","+\t}","+","+\tpublic DateTimeFormatDef pattern(String pattern) {","+\t\taddParameter( \"pattern\", pattern );","+\t\treturn this;","+\t}","+","+\tpublic DateTimeFormatDef locale(String... locale) {","+\t\taddParameter( \"locale\", locale );","+\t\treturn this;","+\t}","+","+\tpublic DateTimeFormatDef locale(Locale... locale) {","+\t\tfinal String[] locales = new String[locale.length];","+\t\tfor ( int i = 0; i < locales.length; i++ ) {","+\t\t\tlocales[i] = locale[i].toLanguageTag();","+\t\t}","+\t\taddParameter( \"locale\", locales );","+\t\treturn this;","+\t}","+","+\tpublic DateTimeFormatDef lenient(boolean lenient) {","+\t\taddParameter( \"lenient\", lenient );","+\t\treturn this;","+\t}","+","+}"],"additions":48,"deletions":0,"truncated":false},{"path":"engine/src/main/java/org/hibernate/validator/constraints/DateTimeFormat.java","lines":["@@ -0,0 +1,92 @@","+/*","+ * SPDX-License-Identifier: Apache-2.0","+ * Copyright Red Hat Inc. and Hibernate Authors","+ */","+package org.hibernate.validator.constraints;","+","+import static java.lang.annotation.ElementType.ANNOTATION_TYPE;","+import static java.lang.annotation.ElementType.CONSTRUCTOR;","+import static java.lang.annotation.ElementType.FIELD;","+import static java.lang.annotation.ElementType.METHOD;","+import static java.lang.annotation.ElementType.PARAMETER;","+import static java.lang.annotation.ElementType.TYPE_USE;","+import static java.lang.annotation.RetentionPolicy.RUNTIME;","+","+import java.lang.annotation.Documented;","+import java.lang.annotation.Repeatable;","+import java.lang.annotation.Retention;","+import java.lang.annotation.Target;","+","+import jakarta.validation.Constraint;","+import jakarta.validation.Payload;","+","+import org.hibernate.validator.Incubating;","+","+/**","+ * Validates that the annotated character sequence represents a valid date and/or time","+ * according to the specified {@link #pattern() format}.","+ * <p>","+ * The format pattern follows the same syntax as {@link java.time.format.DateTimeFormatter}.","+ * For example, {@code \"yyyy-MM-dd\"} for dates like {@code \"2026-07-06\"},","+ * or {@code \"yyyy-MM-dd'T'HH:mm:ss\"} for date-times like {@code \"2026-07-06T11:00:00\"}.","+ * <p>","+ * The supported type is {@code CharSequence}. {@code null} is considered valid.","+ *","+ * @author Sean Okafor","+ * @since 9.2","+ *","+ * @see java.time.format.DateTimeFormatter","+ */","+@Documented","+@Constraint(validatedBy = { })","+@Target({ METHOD, FIELD, ANNOTATION_TYPE, CONSTRUCTOR, PARAMETER, TYPE_USE })","+@Retention(RUNTIME)","+@Repeatable(DateTimeFormat.List.class)","+@Incubating","+public @interface DateTimeFormat {","+","+\tString message() default \"{org.hibernate.validator.constraints.DateTimeFormat.message}\";","+","+\tClass<?>[] groups() default { };","+","+\tClass<? extends Payload>[] payload() default { };","+","+\t/**","+\t * Must be a valid pattern for {@link java.time.format.DateTimeFormatter}.","+\t */","+\tString pattern();","+","+\t/**","+\t * @return the locale(s) to use for parsing text-based date/time elements (e.g., month names, day names).","+\t * When multiple locales are specified, validation succeeds if parsing succeeds with any of them (OR logic).","+\t * Defaults to {@code \"ROOT\"}, which works for numeric patterns but not for text-based patterns","+\t * like {@code \"dd MMMM yyyy\"}.","+\t * <p>","+\t * Examples:","+\t * <ul>","+\t *   <li>{@code locale = \"en-US\"} - Accept only English month/day names</li>","+\t *   <li>{@code locale = {\"en-US\", \"fr-FR\", \"de-DE\"}} - Accept English, French, or German</li>","+\t * </ul>","+\t */","+\tString[] locale() default { \"ROOT\" };","+","+\t/**","+\t * @return whether to be lenient when parsing dates.","+\t * When false (default), invalid dates like February 31st are rejected","+\t * using {@link java.time.format.ResolverStyle#STRICT}.","+\t * When true, invalid dates are accepted and rolled over to subsequent months","+\t * (e.g., February 30th becomes March 2nd) using {@link java.time.format.ResolverStyle#LENIENT}.","+\t */","+\tboolean lenient() default false;","+","+\t/**","+\t * Defines several {@code @DateTimeFormat} annotations on the same element.","+\t */","+\t@Target({ METHOD, FIELD, ANNOTATION_TYPE, CONSTRUCTOR, PARAMETER, TYPE_USE })","+\t@Retention(RUNTIME)","+\t@Documented","+\t@interface List {","+\t\tDateTimeFormat[] value();","+\t}","+","+}"],"additions":92,"deletions":0,"truncated":false},{"path":"engine/src/main/java/org/hibernate/validator/internal/constraintvalidators/hv/DateTimeFormatValidator.java","lines":["@@ -0,0 +1,113 @@","+/*","+ * SPDX-License-Identifier: Apache-2.0","+ * Copyright Red Hat Inc. and Hibernate Authors","+ */","+package org.hibernate.validator.internal.constraintvalidators.hv;","+","+import java.time.format.DateTimeFormatter;","+import java.time.format.DateTimeParseException;","+import java.time.format.ResolverStyle;","+import java.util.Locale;","+import java.util.Map;","+import java.util.concurrent.ConcurrentHashMap;","+","+import jakarta.validation.ConstraintValidatorContext;","+import jakarta.validation.metadata.ConstraintDescriptor;","+","+import org.hibernate.validator.constraints.DateTimeFormat;","+import org.hibernate.validator.constraintvalidation.HibernateConstraintValidator;","+import org.hibernate.validator.constraintvalidation.HibernateConstraintValidatorInitializationContext;","+","+/**","+ * Checks that a given character sequence (e.g. string) is a valid date and/or time","+ * according to the specified pattern and locale(s).","+ * <p>","+ * This validator implements {@link HibernateConstraintValidator} to leverage shared data caching.","+ * Instead of creating new {@link DateTimeFormatter} instances for every validator instance,","+ * formatters are cached globally and reused across all validators with the same configuration.","+ * This significantly reduces memory usage in applications with many date validation fields.","+ *","+ * @author Sean Okafor","+ */","+public class DateTimeFormatValidator implements HibernateConstraintValidator<DateTimeFormat, CharSequence> {","+","+\tprivate DateTimeFormatter[] formatters;","+","+\t@Override","+\tpublic void initialize(ConstraintDescriptor<DateTimeFormat> constraintDescriptor,","+\t\t\tHibernateConstraintValidatorInitializationContext initializationContext) {","+\t\tDateTimeFormat annotation = constraintDescriptor.getAnnotation();","+\t\tString pattern = annotation.pattern();","+\t\tboolean lenient = annotation.lenient();","+\t\tString[] localeStrings = annotation.locale();","+","+\t\t// Get the cache instance","+\t\tDateTimeFormatConstraintInitializer cache = initializationContext","+\t\t\t\t.getSharedData( DateTimeFormatConstraintInitializer.class, DateTimeFormatConstraintInitializer::getInstance );","+","+\t\t// Build array of formatters by getting each one from the cache individually","+\t\t// This allows formatters to be shared across constraints with overlapping locales","+\t\tthis.formatters = new DateTimeFormatter[localeStrings.length];","+\t\tfor ( int i = 0; i < localeStrings.length; i++ ) {","+\t\t\tLocale locale = parseLocale( localeStrings[i] );","+\t\t\tthis.formatters[i] = cache.of( pattern, lenient, locale );","+\t\t}","+\t}","+","+\tprivate Locale parseLocale(String localeString) {","+\t\tif ( \"ROOT\".equals( localeString ) ) {","+\t\t\treturn Locale.ROOT;","+\t\t}","+\t\tString languageTag = localeString.replace( '_', '-' );","+\t\treturn Locale.forLanguageTag( languageTag );","+\t}","+","+\t@Override","+\tpublic boolean isValid(CharSequence value, ConstraintValidatorContext context) {","+\t\tif ( value == null ) {","+\t\t\treturn true;","+\t\t}","+\t\tif ( value.isEmpty() ) {","+\t\t\treturn false;","+\t\t}","+","+\t\tfor ( DateTimeFormatter formatter : formatters ) {","+\t\t\ttry {","+\t\t\t\tformatter.parse( value.toString() );","+\t\t\t\treturn true;","+\t\t\t}","+\t\t\tcatch (DateTimeParseException e) {","+","+\t\t\t}","+\t\t}","+\t\treturn false;","+\t}","+","+\tprivate static final class DateTimeFormatConstraintInitializer {","+","+\t\tprivate final Map<FormatterKey, DateTimeFormatter> cache;","+","+\t\tpublic static DateTimeFormatConstraintInitializer getInstance() {","+\t\t\treturn new DateTimeFormatConstraintInitializer();","+\t\t}","+","+\t\tprivate DateTimeFormatConstraintInitializer() {","+\t\t\tthis.cache = new ConcurrentHashMap<>();","+\t\t}","+","+\t\tpublic DateTimeFormatter of(String pattern, boolean lenient, Locale locale) {","+\t\t\treturn cache.computeIfAbsent(","+\t\t\t\t\tnew FormatterKey( pattern, lenient, locale ),","+\t\t\t\t\tkey -> {","+\t\t\t\t\t\tResolverStyle resolverStyle = lenient ? ResolverStyle.LENIENT : ResolverStyle.STRICT;","+\t\t\t\t\t\treturn DateTimeFormatter","+\t\t\t\t\t\t\t\t.ofPattern( pattern, locale )","+\t\t\t\t\t\t\t\t.withResolverStyle( resolverStyle );","+\t\t\t\t\t}","+\t\t\t);","+\t\t}","+","+\t\tprivate record FormatterKey(String pattern, boolean lenient, Locale locale) {","+\t\t}","+\t}","+}"],"additions":113,"deletions":0,"truncated":false},{"path":"engine/src/main/java/org/hibernate/validator/internal/metadata/core/BuiltinConstraint.java","lines":["@@ -53,6 +53,7 @@ enum BuiltinConstraint {"," \t// Hibernate Validator specific constraints"," \tORG_HIBERNATE_VALIDATOR_CONSTRAINTS_CODE_POINT_LENGTH( \"org.hibernate.validator.constraints.CodePointLength\" ),"," \tORG_HIBERNATE_VALIDATOR_CONSTRAINTS_CURRENCY( \"org.hibernate.validator.constraints.Currency\" ),","+\tORG_HIBERNATE_VALIDATOR_CONSTRAINTS_DATE_TIME_FORMAT( \"org.hiberna