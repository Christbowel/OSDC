ce.\";","+    }","+","+    class Invocation final : public InvocationBase {","+    public:","+        using InvocationBase::InvocationBase;","+","+        void typedRun(OperationContext* opCtx) {","+            uassert(","+                ErrorCodes::IllegalOperation,","+                \"_configsvrConvertShardRefsInNamespaceMetadata can only be run on config servers\",","+                serverGlobalParams.clusterRole.has(ClusterRole::ConfigServer));","+","+            // Set the operation context read concern level to local for reads into the config","+            // database.","+            repl::ReadConcernArgs::get(opCtx) =","+                repl::ReadConcernArgs(repl::ReadConcernLevel::kLocalReadConcern);","+","+            CommandHelpers::uassertCommandRunWithMajority(Request::kCommandName,","+                                                          opCtx->getWriteConcern());","+","+            const auto nss = NamespaceStringUtil::deserialize(","+                boost::none, request().getCommandParameter(), SerializationContext::stateDefault());","+","+            ShardingCatalogManager::get(opCtx)->convertShardRefsInNamespaceMetadata(opCtx, nss);","+        }","+","+    private:","+        NamespaceString ns() const override {","+            return {};","+        }","+","+        bool supportsWriteConcern() const override {","+            return true;","+        }","+","+        void doCheckAuthorization(OperationContext* opCtx) const override {","+            uassert(ErrorCodes::Unauthorized,","+                    \"Unauthorized\",","+                    AuthorizationSession::get(opCtx->getClient())","+                        ->isAuthorizedForActionsOnResource(","+                            ResourcePattern::forClusterResource(request().getDbName().tenantId()),","+                            ActionType::internal));","+        }","+    };","+};","+MONGO_REGISTER_COMMAND(ConfigSvrConvertShardRefsInNamespaceMetadataCommand).forShard();","+","+}  // namespa