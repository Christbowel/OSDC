vrChunksNamespace, updateRequest);","+        uassertStatusOK(getStatusFromWriteCommandReply(updateResponse));","+","+        BatchedCommandResponse batchedResponse;","+        std::string unusedErrmsg;","+        batchedResponse.parseBSON(updateResponse, &unusedErrmsg);","+        if (batchedResponse.getNModified() == 0) {","+            // Write a no-op to ensure an oplog entry is produced so callers can wait for majority","+            // write concern.","+            sharding_ddl_util::performNoopMajorityWriteLocally(opCtx);","+        }","+    };","+","+    if (nss.isDbOnly()) {","+        LOGV2(12888601,","+              \"Converting shardRef field in config.databases document\",","+              \"dbName\"_attr = nss);","+","+        const auto dbNameStr =","+            DatabaseNameUtil::serialize(nss.dbName(), SerializationContext::stateDefault());","+","+        // Retrieve the config.databases document by _id.","+        const auto dbBSON =","+            findOneConfigDocument(opCtx,","+                                  NamespaceString::kConfigDatabasesNamespace,","+                                  BSON(DatabaseType::kDbNameFieldName << dbNameStr));","+","+        if (dbBSON.isEmpty()) {","+            LOGV2_WARNING(12888602,","+                          \"Database not found in config.databases, skipping shardRef conversion\","],"additions":44,"deletions":0,"truncated":false}],"additions":390,"deletions":4,"truncated":true,"file_count":19},"error":null,"fetched_at":"2026-06-24T10:42:18.937578+00:00"}