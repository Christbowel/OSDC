\t\tarray(","+\t\t\t\t\t'methods'             => WP_REST_Server::READABLE,","+\t\t\t\t\t'callback'            => array( $this, 'get_item' ),","+\t\t\t\t\t'permission_callback' => array( $this, 'get_item_permissions_check' ),","+\t\t\t\t\t'args'                => array(","+\t\t\t\t\t\t'context' => $this->get_context_param( array( 'default' => 'view' ) ),","+\t\t\t\t\t),","+\t\t\t\t),","+\t\t\t\t'schema' => array( $this, 'get_public_item_schema' ),","+\t\t\t)","+\t\t);","+\t}","+","+\t/**","+\t * Checks whether a given request has permission to read icon collections.","+\t *","+\t * @since 7.1.0","+\t *","+\t * @param WP_REST_Request $request Full details about the request.","+\t * @return true|WP_Error True if the request has read access, WP_Error object otherwise.","+\t */","+\tpublic function get_items_permissions_check(","+\t\t// phpcs:ignore VariableAnalysis.CodeAnalysis.VariableAnalysis.UnusedVariable","+\t\t$request","+\t) {","+\t\tif ( current_user_can( 'edit_posts' ) ) {","+\t\t\treturn true;","+\t\t}","+","+\t\tforeach ( get_post_types( array( 'show_in_rest' => true ), 'objects' ) as $post_type ) {","+\t\t\tif ( current_user_can( $post_type->cap->edit_posts ) ) {","+\t\t\t\treturn true;","+\t\t\t}","+\t\t}","+","+\t\treturn new WP_Error(","+\t\t\t'rest_cannot_view',","+\t\t\t__( 'Sorry, you are not allowed to view the registered icon collections.' ),","+\t\t\tarray( 'status' => rest_authorization_required_code() )","+\t\t);","+\t}","+","+\t/**","+\t * Checks if a given request has access to read a specific icon collection.","+\t *","+\t * @since 7.1.0","+\t *","+\t * @param WP_REST_Request $request Full details about the request.","+\t * @return true|WP_Error True if the request has read access for the item, WP_Error object otherwise.","+\t */","+\tpublic function get_item_permissions_check( $request ) {","+\t\t$check = $this->get_items_permissions_check( $request );","+\t\tif ( is_wp_error( $check ) ) {","+\t\t\treturn $check;","+\t\t}","+","+\t\treturn true;","+\t}","+","+\t/**","+\t * Retrieves all icon collections.","+\t *","+\t * @since 7.1.0","+\t *","+\t * @param WP_REST_Request $request Full details about the request.","+\t * @return WP_REST_Response|WP_Error Response object on success, or WP_Error object on failure.","+\t */","+\tpublic function get_items( $request ) {","+\t\t$response    = array();","+\t\t$collections = WP_Icon_Collections_Registry::get_instance()->get_all_registered();","+\t\tforeach ( $collections as $collection ) {","+\t\t\t$prepared_collection = $this->prepare_item_for_response( $collection, $request );","+\t\t\t$response[]          = $this->prepare_response_for_collection( $prepared_collection );","+\t\t}","+\t\treturn rest_ensure_response( $response );","+\t}","+","+\t/**","+\t * Retrieves a specific icon collection.","+\t *","+\t * @since 7.1.0","+\t *","+\t * @param WP_REST_Request $request Full details about the request.","+\t * @return WP_REST_Response|WP_Error Response object on success, or WP_Error object on failure.","+\t */","+\tpublic function get_item( $request ) {","+\t\t$collection = $this->get_icon_collection( $request['slug'] );","+\t\tif ( is_wp_error( $collection ) ) {","+\t\t\treturn $collection;","+\t\t}","+","+\t\t$data = $this->prepare_item_for_response( $collection, $request );","+\t\treturn rest_ensure_response( $data );","+\t}","+","+\t/**","+\t * Retrieves a specific icon collection from the registry.","+\t *","+\t * @since 7.1.0","+\t *","+\t * @param string $slug Icon collection slug.","+\t * @return array|WP_Error Icon collection data on success, or WP_Error object on failure.","+\t */","+\tpublic function get_icon_collection( $slug ) {","+\t\t$registry   = WP_Icon_Collections_Registry::get_instance();","+\t\t$collection = $registry->get_registered( $slug );","+","+\t\tif ( null === $collection ) {","+\t\t\treturn new WP_Error(","+\t\t\t\t'rest_icon_collection_not_found',","+\t\t\t\tsprintf(","+\t\t\t\t\t/* translators: %s: Icon collection slug. */","+\t\t\t\t\t__( 'Icon collection not found: \"%s\".' ),","+\t\t\t\t\t$slug","+\t\t\t\t),","+\t\t\t\tarray( 'status' => 404 )","+\t\t\t);","+\t\t}","+","+\t\treturn $collection;","+\t}","+","+\t/**","+\t * Prepares a raw icon collection before it gets output in a REST API response.","+\t *","+\t * @since 7.1.0","+\t *","+\t * @param array           $item    Raw icon collection as registered, before any changes.","+\t * @param WP_REST_Request $request Request object.","+\t * @return WP_REST_Response|WP_Error Response object on success, or WP_Error object on failure.","+\t */","+\tpublic function prepare_item_for_response( $item, $request ) {","+\t\t$fields = $this->get_fields_for_response( $request );","+\t\t$keys   = array(","+\t\t\t'slug'        => 'slug',","+\t\t\t'label'       => 'label',","+\t\t\t'description' => 'description',","+\t\t);","+\t\t$data   = array();","+\t\tforeach ( $keys as $item_key => $rest_key ) {","+\t\t\tif ( isset( $item[ $item_key ] ) && rest_is_field_included( $rest_key, $fields ) ) {","+\t\t\t\t$data[ $rest_key ] = $item[ $item_key ];","+\t\t\t}","+\t\t}","+","+\t\t$context = ! empty( $request['context'] ) ? $request['context'] : 'view';","+\t\t$data    = $this->add_additional_fields_to_object( $data, $request );","+\t\t$data    = $this->filter_response_by_context( $data, $context );","+\t\treturn rest_ensure_response( $data );","+\t}","+","+\t/**","+\t * Retrieves the icon collection schema, conforming to JSON Schema.","+\t *","+\t * @since 7.1.0","+\t *","+\t * @return array Item schema data.","+\t */","+\tpublic function get_item_schema() {","+\t\tif ( $this->schema ) {","+\t\t\treturn $this->add_additional_fields_schema( $this->schema );","+\t\t}","+","+\t\t$schema = array(","+\t\t\t'$schema'    => 'http://json-schema.org/draft-04/schema#',","+\t\t\t'title'      => 'icon-collection',","+\t\t\t'type'       => 'object',","+\t\t\t'properties' => array(","+\t\t\t\t'slug'        => array(","+\t\t\t\t\t'description' => __( 'The icon collection slug.' 