","+\tprivate IConfig $config;","+\t/** @var bool|null */","+\tprivate $canCreateNewLocalStorage = null;","+\t/** @var bool|null */","+\tprivate $allowUserMounting = null;","+\t/** @var array|null */","+\tprivate $userMountingBackends = null;","+","+\t/**","+\t * @param IConfig $config","+\t */","+\tpublic function __construct(IConfig $config) {","+\t\t$this->config = $config;","+\t}","+","+\t/**","+\t * Checks if the regular users are allowed to mount external storages","+\t * @return bool","+\t */","+\tpublic function isUserMountingAllowed(): bool {","+\t\tif ($this->allowUserMounting === null) {","+\t\t\t$this->allowUserMounting = $this->config->getAppValue('files_external', 'allow_user_mounting', 'no') === 'yes';","+\t\t\t// if no backend is in the list an empty string is in the array and user mounting is disabled","+\t\t\tif ($this->allowedBackendsForUsers() === ['']) {","+\t\t\t\t$this->allowUserMounting = false;","+\t\t\t}","+\t\t}","+\t\treturn $this->allowUserMounting;","+\t}","+","+\tprivate function allowedBackendsForUsers() {","+\t\tif ($this->userMountingBackends === null) {","+\t\t\t$user_mounting_backends = $this->config->getAppValue('files_external', 'user_mounting_backends', '');","+\t\t\t$this->userMountingBackends = \\explode(","+\t\t\t\t',',","+\t\t\t\t$user_mounting_backends","+\t\t\t);","+\t\t}","+\t\treturn $this->userMountingBackends;","+\t}","+","+\t/**","+\t * Checks if the regular users are allowed to mount the specified backend.","+\t * Note that the admin might still mount the backend.","+\t * @param Backend $backend","+\t * @return bool","+\t */","+\tpublic function isAllowedUserBackend(Backend $backend): bool {","+\t\t// Allowing users to mount local storage is a security risk, so it's","+\t\t// blacklisted regardless of admin's decision. The admin can still","+\t\t// setup a local mount for everyone (or chosen users) if he wants.","+\t\t$blacklistedBackendsForUsers = ['\\OC\\Files\\Storage\\Local'];","+\t\tif (\\in_array($backend->get