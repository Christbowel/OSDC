"+\t\t\t}","+\t\tcase enum.MergeMethodSquash:","+\t\t\ttitle = fmt.Sprintf(\"%s (#%d)\", pr.Title, pr.Number)","+\t\tcase enum.MergeMethodRebase, enum.MergeMethodFastForward:","+\t\t\t// Not used.","+\t\t}","+\t}","+"," \treturn PullReqGitInput{"," \t\tAuthor:        author,"," \t\tCommitter:     committer,","-\t\tRefUpdates:    refUpdates,","+\t\tRefUpdates:    nil,"," \t\tCommitMessage: git.CommitMessage(title, message),","-\t\tSourceSHA:     sourceBranchSHA,","-\t}, nil","+\t\tSourceSHA:     sha.None,","+\t}"," }"],"additions":58,"deletions":42,"truncated":false},{"path":"app/services/mergequeue/handlers_checks.go","lines":["@@ -0,0 +1,161 @@","+// Copyright 2023 Harness, Inc.","+//","+// Licensed under the Apache License, Version 2.0 (the \"License\");","+// you may not use this file except in compliance with the License.","+// You may obtain a copy of the License at","+//","+//     http://www.apache.org/licenses/LICENSE-2.0","+//","+// Unless required by applicable law or agreed to in writing, software","+// distributed under the License is distributed on an \"AS IS\" BASIS,","+// WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.","+// See the License for the specific language governing permissions and","+// limitations under the License.","+","+package mergequeue","+","+import (","+\t\"context\"","+\t\"fmt\"","+\t\"slices\"","+","+\tcheckevents \"github.com/harness/gitness/app/events/check\"","+\t\"github.com/harness/gitness/app/services/protection\"","+\t\"github.com/harness/gitness/errors\"","+\t\"github.com/harness/gitness/events\"","+\t\"github.com/harness/gitness/git/sha\"","+\t\"github.com/harness/gitness/store\"","+\t\"github.com/harness/gitness/types\"","+\t\"github.com/harness/gitness/types/enum\"","+","+\t\"github.com/rs/zerolog/log\"","+)","+","+// handlerCheckFinished is invoked whenever a status check is reported for any commit.","+// It looks up any merge queue entries whose ChecksCommitSHA matches the reported SHA and","+// acts on the result: successful checks advance the entry toward being merged;","+// failed checks remove the entry from the queue.","+func (s *Service) handlerCheckFinished(","+\tctx context.Context,","+\tevent *events.Event[*checkevents.ReportedPayload],","+) error {","+\tstatus := event.Payload.Status","+","+\tif status != enum.CheckStatusSuccess && status != enum.CheckStatusFailure {","+\t\treturn nil","+\t}","+","+\trepoID := event.Payload.RepoID","+\tcommitSHA, err := sha.New(event.Payload.SHA)","+\tif err != nil {","+\t\terr = fmt.Errorf(\"invalid commit SHA format: %q: %w\", event.Payload.SHA, err)","+\t\treturn events.NewDiscardEventError(err)","+\t}","+","+\trepo, err := s.repoFinder.FindByID(ctx, repoID)","+\tif err != nil {","+\t\treturn fmt.Errorf(\"failed to find repo: %w\", err)","+\t}","+","+\t// Find merge queue entry by merge commit in the DB. This is column has a unique index,","+\t// because every entry's merge commit must be unique.","+\tentry, err := s.mergeQueueEntryStore.FindByMergeCommit(ctx, commitSHA)","+\tif errors.Is(err, store.ErrResourceNotFound) {","+\t\treturn nil // This check is not a merge queue check. We're done.","+\t}","+\tif err != nil {","+\t\treturn fmt.Errorf(\"failed to list merge queue entries by checks commit SHA: %w\", err)","+\t}","+","+\tq, err := s.mergeQueueStore.Find(ctx, entry.MergeQueueID)","+\tif err != nil {","+\t\treturn fmt.Errorf(\"failed to find merge queue from entry's ID: %w\", err)","+\t}","+","+\tbranchProtection, err := s.protectionManager.ListRepoBranchRules(ctx, repoID)","+\tif err != nil {","+\t\treturn fmt.Errorf(\"failed to list repo branch rules: %w\", err)","+\t}","+","+\tmergeQueueSetup, err := branchProtection.GetMergeQueueSetup(protection.MergeQueueSetupInput{","+\t\tRepo:         repo,","+\t\tTargetBranch: q.Branch,","+\t})","+\tif err != nil {","+\t\treturn fmt.Errorf(\"failed to get merge queue setup: %w\", err)","+\t}","+","+\tif !mergeQueueSetup.IsActive() {","+\t\terr = s.removeAll(ctx, repo, q)","+\t\tif err != nil {","+\t\t\treturn fmt.Errorf(\"failed to clear merge queue: %w\", err)","+\t\t}","+","+\t\treturn nil","+\t}","+","+\t// One failure is enough to remove the PR from the merge queue.","+\tif status == enum.CheckStatusFailure {","+\t\terr = s.remove(ctx, entry.PullReqID, enum.MergeQueueRemovalReasonCheckFail)","+\t\tif errors.Is(err, ErrNotInQueue) {","+\t\t\t// Perhaps a check was running after the PR has already been taken from the merge queue.","+\t\t\treturn nil","+\t\t}","+\t\tif err != nil {","+\t\t\tlog.Ctx(ctx).Warn().Err(err).","+\t\t\t\tInt64(\"repo_id\", repoID).","+\t\t\t\tInt64(\"pullreq_id\", entry.PullReqID).","+\t\t\t\tMsg(\"failed to remove merge queue entry from merge queue\")","+\t\t\treturn err","+\t\t}","+","+\t\terr = s.reprocess(ctx, repo, q, mergeQueueSetup)","+\t\tif err != nil {","+\t\t\treturn fmt.Errorf(\"failed to process merge queue after removing entry because failed check: %w\", err)","+\t\t}","+","+\t\treturn nil","+\t}","+","+\t// Only act on success checks for entries that are the checks leader.","+\tif entry.State != enum.MergeQueueEntryStateChecksInProgress {","+\t\treturn nil","+\t}","+","+\tchecks, err := s.checkStore.List(ctx, repoID, commitSHA.String(), types.CheckListOptions{","+\t\tListQueryFilter: types.ListQueryFilter{","+\t\t\tPagination: types.Pagination{Page: 0, Size: MaximumQueueSize},","+\t\t},","+\t})","+\tif err != nil {","+\t\treturn fmt.Errorf(\"failed to list merge queue entries by checks commit SHA: %w\", err)","+\t}","+","+\tcompletedChecks := make([]string, 0, len(checks))","+\tfor _, check := range checks {","+\t\tif check.Status == enum.CheckStatusSuccess {","+\t\t\tcompletedChecks = append(completedChecks, check.Identifier)","+\t\t}","+\t}","+","+\trequiredChecks := mergeQueueSetup.RequiredChecks","+","+\tfor _, check := range requiredChecks {","+\t\tif !slices.Contains(completedChecks, check) {","+\t\t\t// Not all required checks have finished successfully. Waiting for more checks to finish...","+\t\t\treturn nil","+\t\t}","+\t}","+","+\terr = s.fastForward(ctx, q, entry)","+\tif err != nil {","+\t\treturn fmt.Errorf(\"failed to fast forward target branch to the merge commit: %w\", err)","+\t}","+","+\terr = s.reprocess(ctx, repo, q, mergeQueueSetup)","+\tif err != nil {","+\t\treturn fmt.Errorf(\"failed to process merge queue after fast forwarding: %w\", err)","+\t}","+","+\treturn nil","+}"],"additions":161,"deletions":0,"truncated":false},{"path":"app/services/mergequeue/handlers_updated.go","lines":["@@ -0,0 +1,79 @@","+// Copyright 2023 Harness, Inc.","+//","+// Licensed under the Apache License, Version 2.0 (the \"License\");","+// you may not use this file except in compliance with the License.","+// You may obtain a copy of the License at","+//","+//     http://www.apache.org/licenses/LICENSE-2.0","+//","+// Unless required by applicable law or agreed to in writing, software","+// distributed under the License is distributed on an \"AS IS\" BASIS,","+// WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.","+// See the License for the specific language governing permissions and"],"additions":12,"deletions":0,"truncated":false}],"additions":730,"deletions":42,"truncated":true,"file_count":16},"error":null,"fetched_at":"2026-05-20T17:42:08.065220+00:00"}