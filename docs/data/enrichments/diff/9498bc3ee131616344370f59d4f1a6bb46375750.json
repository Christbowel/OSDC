                                      ","+        var_dump($namedNotation !== $iteratedNotation);","+    }","+}","+?>","+--EXPECT--","+=== GIF ===","+string(3) \"GIF\"","+NULL","+NULL","+bool(true)","+bool(true)","+bool(true)","+NULL","+string(3) \"GIF\"","+NULL","+NULL","+bool(true)","+bool(true)","+bool(true)","+NULL","+bool(true)","+=== JPEG ===","+string(4) \"JPEG\"","+NULL","+NULL","+bool(true)","+bool(true)","+bool(true)","+NULL","+string(4) \"JPEG\"","+NULL","+NULL","+bool(true)","+bool(true)","+bool(true)","+NULL","+bool(true)","+=== HTML ===","+string(4) \"HTML\"","+NULL","+NULL","+bool(true)","+bool(true)","+bool(true)","+NULL","+string(4) \"HTML\"","+NULL","+NULL","+bool(true)","+bool(true)","+bool(true)","+NULL","+bool(true)",""],"additions":101,"deletions":0,"truncated":false}],"additions":139,"deletions":11,"truncated":false,"file_count":7},"error":null,"fetched_at":"2026-05-20T17:42:23.911603+00:00"}