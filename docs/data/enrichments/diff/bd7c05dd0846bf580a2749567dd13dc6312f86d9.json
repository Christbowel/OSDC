q *logproto.PushRe"," \t}"," "," \tvar ingestionBlockedError error","-\tvar totalEntriesSize, totalLineCount int","+","+\t// Ingestion rate limiting is bucketed by the effective rate-limit target: streams whose","+\t// resolved policy has a per-policy ingestion rate override are metered against their own","+\t// per-(tenant,policy) bucket, replacing the tenant-wide limit; all other streams share the","+\t// tenant-wide bucket (keyed by \"\").","+\trlBuckets := map[string]*rateLimitBucket{}"," "," \terr = func() error {"," \t\tsp := trace.SpanFromContext(ctx)","@@ -774,9 +780,7 @@ func (d *Distributor) PushWithResolver(ctx context.Context, req *logproto.PushRe"," "," \t\t\t\tn++"," \t\t\t\tentrySize := util.EntryTotalSize(&entry)","-\t\t\t\ttotalEntriesSize += entrySize"," \t\t\t\tstreamEntriesSize += entrySize","-\t\t\t\ttotalLineCount++"," \t\t\t}"," \t\t\tstream.Entries = stream.Entries[:n]"," \t\t\tif len(stream.Entries) == 0 {","@@ -784,6 +788,20 @@ func (d *Distributor) PushWithResolver(ctx context.Context, req *logproto.PushRe"," \t\t\t\tcontinue"," \t\t\t}"," ","+\t\t\t// Attribute this stream's bytes/lines to its rate-limit bucket.","+\t\t\t_, hasRateOverride := d.validator.PolicyIngestionRateBytes(tenantID, policy)","+\t\t\tbucketKey := \"\"","+\t\t\tif hasRateOverride {","+\t\t\t\tbucketKey = policy","+\t\t\t}","+\t\t\tb := rlBuckets[bucketKey]","+\t\t\tif b == nil {","+\t\t\t\tb = &rateLimitBucket{policy: policy, hasOverride: hasRateOverride}","+\t\t\t\trlBuckets[bucketKey] = b","+\t\t\t}","+\t\t\tb.bytes += streamEntriesSize","+\t\t\tb.lines += n","+"," \t\t\tmaybeShardStreams(stream, lbs, streamEntriesSize, policy)"," \t\t}"," \t\treturn nil","@@ -805,13 +823,8 @@ func (d *Distributor) PushWithResolver(ctx context.Context, req *logproto.PushRe"," \t\treturn &logproto.PushResponse{}, validationErr"," \t}"," ","-\tif !d.ingestionRateLimiter.AllowN(now, tenantID, totalEntriesSize) {","-\t\td.trackDiscardedData(ctx, req.Streams, validationContext, tenantID, validation.RateLimited, streamResolver, format)","-","-\t\terr = fmt.Errorf(validation.RateLimitedErrorMsg, tenantID, int(d.ingestionRateLimiter.Limit(now, tenantID)), totalLineCount, totalEntriesSize)","-\t\td.writeFailuresManager.Log(tenantID, err)","-\t\t// Return a 429 to indicate to the client they are being rate limited","-\t\treturn nil, httpgrpc.Errorf(http.StatusTooManyRequests, \"%s\", err.Error())","+\tif err := d.enforceIngestionRateLimits(ctx, now, tenantID, rlBuckets, req.Streams, validationContext, streamResolver, format); err != nil {","+\t\treturn nil, err"," \t}"," "," \t// These limits are checked after the ingestion rate limit as this","@@ -824,7 +837,7 @@ func (d *Distributor) PushWithResolver(ctx context.Context, req *logproto.PushRe"," \t\t\t\tfor _, stream := range rejected {"," \t\t\t\t\tdiscardedStreams = append(discardedStreams, stream.Stream)"," \t\t\t\t}","-\t\t\t\td.trackDiscardedData(ctx, discardedStreams, validationContext, tenantID, validation.StreamLimit, streamResolver, format)","+\t\t\t\td.trackDiscardedData(ctx, discardedStreams, validationContext, tenantID, validation.StreamLimit, streamResolver, format, nil)"," "," \t\t\t\t// While many streams may have failed we only log the error for one stream in the insight logs and in the error message."," \t\t\t\t// It's generally not useful to know the stream labels for a stream that is hitting the stream limit as it could be any","@@ -988,6 +1001,124 @@ func (d *Distributor) missingEnforcedLabels(lbs labels.Labels, tenantID string,"," \treturn len(missingLbs) > 0, missingLbs"," }"," ","+// rateLimitBucket accumulates the bytes and line count of the streams metered against a","+// single ingestion rate-limit bucket (either the tenant-wide bucket or a per-policy bucket).","+type rateLimitBucket struct {","+\tpolicy      string","+\thasOverride bool","+\tbytes       int","+\tlines       int","+}","+","+// rateLimitError builds the client-facing 429 error for the rate-limit buckets a request","+// exceeded. A single exceeded bucket uses the existing per-tenant or per-policy message; two","+// or more are enumerated deterministically (the caller sorts them). All limits are looked up","+// at the same \"now\" used for the reservation decision.","+func (d *Distributor) rateLimitError(now time.Time, tenantID string, exceeded []*rateLimitBucket) error {","+\tlimitOf := func(b *rateLimitBucket) int {","+\t\tkey := tenantID","+\t\tif b.hasOverride {","+\t\t\tkey = encodeRateLimitKey(tenantID, b.policy)","+\t\t}","+\t\treturn int(d.ingestionRateLimiter.Limit(now, key))","+\t}","+","+\tif len(exceeded) == 1 {","+\t\tb := exceeded[0]","+\t\tif b.hasOverride {","+\t\t\treturn fmt.Errorf(validation.RateLimitedPolicyErrorMsg, tenantID, b.policy, limitOf(b), b.lines, b.bytes)","+\t\t}","+\t\treturn fmt.Errorf(validation.RateLimitedErrorMsg, tenantID, limitOf(b), b.lines, b.bytes)","+\t}","+","+\tclauses := make([]string, 0, len(exceeded))","+\tfor _, b := range exceeded {","+\t\tif b.hasOverride {","+\t\t\tclauses = append(clauses, fmt.Sprintf(\"policy %q (limit: %d bytes/sec) ingesting %d lines totaling %d bytes\", b.policy, limitOf(b), b.lines, b.bytes))","+\t\t} else {","+\t\t\tclauses = append(clauses, fmt.Sprintf(\"the tenant default (limit: %d bytes/sec) ingesting %d lines totaling %d bytes\", limitOf(b), b.lines, b.bytes))","+\t\t}","+\t}","+\treturn fmt.Errorf(validation.RateLimitedMultiErrorMsg, tenantID, strings.Join(clauses, \"; \"))","+}","+","+// enforceIngestionRateLimits applies the per-bucket ingestion rate limit as an all-or-nothing","+// decision. A bucket with a per-policy override is metered independently from the tenant-wide","+// bucket. We tentatively reserve each bucket's bytes and, if any bucket can't accept them","+// immediately, cancel every reservation (returning the tokens) and reject the whole request.","+// Using reservations rather than AllowN keeps the buckets independent: a request rejected","+// because one bucket is over its limit does not consume tokens from the others, so an","+// over-limit policy can't drain the budgets of unrelated policies across client retries.","+//","+// It returns a non-nil 429 error if any bucket is over its limit (all reservations are rolled","+// back); nil means the request was admitted (the reservations are kept and the tokens consumed).","+func (d *Distributor) enforceIngestionRateLimits(","+\tctx context.Context,","+\tnow time.Time,","+\ttenantID string,","+\trlBuckets map[string]*rateLimitBucket,","+\tstreams []logproto.Stream,","+\tvalidationContext validationContext,","+\tstreamResolver push.StreamResolver,","+\tformat string,","+) error {","+\ttype bucketReservation struct {","+\t\tbucket      *rateLimitBucket","+\t\treservation *rate.Reservation","+\t}","+\treservations := make([]bucketReservation, 0, len(rlBuckets))","+\tvar exceeded []*rateLimitBucket","+\tfor _, b := range rlBuckets {","+\t\tlimiterKey := tenantID","+\t\tif b.hasOverride {","+\t\t\tlimiterKey = encodeRateLimitKey(tenantID, b.policy)","+\t\t}","+\t\tr := d.ingestionRateLimiter.ReserveN(now, limiterKey, b.bytes)","+\t\treservations = append(reservations, bucketReservation{bucket: b, reservation: r})","+\t\t// A reservation that isn't OK (bytes exceed the burst) or that requires a wait is not","+\t\t// immediately allowed, which is equivalent to AllowN returning false. We evaluate every","+\t\t// bucket (rather than stopping at the first failure) so the rejection error can","+\t\t// deterministically report all exceeded buckets.","+\t\tif !r.OK() || r.DelayFrom(now) > 0 {","+\t\t\texceeded = append(exceeded, b)","+\t\t}","+\t}","+","+\tif len(exceeded) == 0 {","+\t\treturn nil","+\t}","+","+\t// Roll back every reservation so no tokens are consumed for a rejected request.","+\tfor _, br := range reservations {","+\t\tbr.reservation.CancelAt(now)","+\t}","+","+\t// The whole request is dropped, so attribute every stream as discarded (each under its","+\t// own policy label, handled by