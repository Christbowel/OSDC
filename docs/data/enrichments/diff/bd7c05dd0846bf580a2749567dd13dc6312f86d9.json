0), not the generous tenant limit.","+\tresp, err := distributors[0].Push(ctx, makeWriteRequestWithLabels(1, 60, []string{`{foo=\"bar\"}`}, false, false, false))","+\tassert.Nil(t, resp)","+\tassert.Equal(t, httpgrpc.Errorf(http.StatusTooManyRequests, validation.RateLimitedPolicyErrorMsg, \"test\", \"finance\", 50, 1, 60), err)","+","+\t// A push with labels not matched to any policy uses the tenant-wide bucket and is allowed.","+\tresp, err = distributors[0].Push(ctx, makeWriteRequestWithLabels(1, 60, []string{`{other=\"x\"}`}, false, false, false))","+\tassert.NoError(t, err)","+\tassert.Equal(t, success, resp)","+}","+","+// TestDistributor_PushIngestionRateLimitPolicyAllOrNothing verifies that when a request mixes","+// streams from two policies and only one is over its limit, rejecting the request does NOT","+// consume tokens from the under-limit policy's bucket (the reservations are cancelled).","+func TestDistributor_PushIngestionRateLimitPolicyAllOrNothing(t *testing.T) {","+\tlimits := &validation.Limits{}","+\tflagext.DefaultValues(limits)","+\tlimits.IngestionRateStrategy = validation.LocalIngestionRateStrategy","+\tlimits.IngestionRateMB = datasize.ByteSize(1000).MBytes()","+\tlimits.IngestionBurstSizeMB = datasize.ByteSize(1000).MBytes()","+\tlimits.PolicyStreamMapping = validation.PolicyStreamMapping{","+\t\t\"finance\": []*validation.PriorityStream{{Selector: `{app=\"finance\"}`, Priority: 1}},","+\t\t\"ops\":     []*validation.PriorityStream{{Selector: `{app=\"ops\"}`, Priority: 1}},","+\t}","+\t// Both policies get a 50-byte budget.","+\tlimits.PolicyOverrideLimits = map[string]validation.PolicyOverridableLimits{","+\t\t\"finance\": {IngestionRateMB: datasize.ByteSize(50).MBytes(), IngestionBurstSizeMB: datasize.ByteSize(50).MBytes()},","+\t\t\"ops\":     {IngestionRateMB: datasize.ByteSize(50).MBytes(), IngestionBurstSizeMB: datasize.ByteSize(50).MBytes()},","+\t}","+\trequire.NoError(t, limits.Validate())","+","+\tdistributors, _ := prepare(t, 1, 5, limits, nil)","+","+\t// Request mixes a finance stream that is over its 50-byte budget (60 bytes) with an ops","+\t// stream that is under its budget (40 bytes). The whole request must be rejected because","+\t// finance is over limit.","+\treq := makeWriteRequestWithLabels(1, 60, []string{`{app=\"finance\"}`}, false, false, false)","+\topsStreams := makeWriteRequestWithLabels(1, 40, []string{`{app=\"ops\"}`}, false, false, false)","+\treq.Streams = append(req.Streams, opsStreams.Streams...)","+","+\tresp, err := distributors[0].Push(ctx, req)","+\tassert.Nil(t, resp)","+\tassert.Equal(t, httpgrpc.Errorf(http.StatusTooManyRequests, validation.RateLimitedPolicyErrorMsg, \"test\", \"finance\", 50, 1, 60), err)","+","+\t// The ops bucket must NOT have been drained by the rejected request: a fresh ops push that","+\t// fills its entire 50-byte budget still succeeds. (Without reservation cancellation, the","+\t// earlier 40 bytes would have been consumed and this 50-byte push would be rate limited.)","+\tresp, err = distributors[0].Push(ctx, makeWriteRequestWithLabels(1, 50, []string{`{app=\"ops\"}`}, false, false, false))","+\tassert.NoError(t, err)","+\tassert.Equal(t, success, resp)","+}","+","+// TestDistributor_PushIngestionRateLimitMultiplePolicies verifies that when several policy","+// buckets are over their limit in the same request, the 429 error deterministically enumerates","+// all exceeded policies (sorted), regardless of map iteration order.","+func TestDistributor_PushIngestionRateLimitMultiplePolicies(t *testing.T) {","+\tlimits := &validation.Limits{}","+\tflagext.DefaultValues(limits)","+\tlimits.IngestionRateStrategy = validation.LocalIngestionRateStrategy","+\tlimits.IngestionRateMB = datasize.ByteSize(1000).MBytes()","+\tlimits.IngestionBurstSizeMB = datasize.ByteSize(1000).MBytes()","+\tlimits.PolicyStreamMapping = validation.PolicyStreamMapping{","+\t\t\"finance\": []*validation.PriorityStream{{Selector: `{app=\"finance\"}`, Priority: 1}},","