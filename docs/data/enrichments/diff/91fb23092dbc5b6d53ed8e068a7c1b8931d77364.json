{"id":"91fb23092dbc5b6d53ed8e068a7c1b8931d77364","axis":"silent","repo":"grafana/mimir","sha":"91fb23092dbc5b6d53ed8e068a7c1b8931d77364","parsed":{"files":[{"path":"CHANGELOG.md","lines":["@@ -4,6 +4,7 @@"," "," ### Grafana Mimir"," ","+* [CHANGE] Query-frontend: `-query-frontend.log-query-request-headers` now rejects headers that carry credentials or session material (e.g. `Authorization`, `Cookie`, `X-Api-Key`) at startup, and any such headers that reach the slow-query/query-stats log paths are redacted as defense in depth. Operators that previously allow-listed such headers must remove them from the flag. #15487"," * [CHANGE] Alertmanager: Upgraded the embedded `prometheus/alertmanager` library to v0.32.0. The per-tenant alertmanager web UI and the `/-/healthy`, `/-/ready`, `/-/reload`, `/script.js`, and `/favicon.ico` endpoints under the alertmanager prefix are no longer served because upstream removed the embeddable UI package. The v2 API endpoints and request/response shapes are unchanged, but a few error message strings from the upstream parser have been reformatted (for example, matcher-validation errors now include `in set N`). #15144"," * [CHANGE] Alertmanager: The `cortex_alertmanager_dispatcher_aggregation_group_limit_reached_total` counter is now best-effort under concurrent alert ingest. The upstream alertmanager v0.32.0 ingests alerts via worker goroutines and the group-limit check is a racy check-then-act, so the configured limit can be exceeded under burst load. #15144"," * [FEATURE] API: Add alertmanager limits (alertmanager_notification_rate_limit, alertmanager_max_dispatcher_aggregation_groups, alertmanager_max_templates_count) to the user limits API response. #15308"],"additions":1,"deletions":0,"truncated":false},{"path":"pkg/frontend/config.go","lines":["@@ -49,6 +49,9 @@ func (cfg *CombinedFrontendConfig) RegisterFlags(f *flag.FlagSet, logger log.Log"," }"," "," func (cfg *CombinedFrontendConfig) Validate() error {","+\tif err := cfg.Handler.Validate(); err != nil {","+\t\treturn err","+\t}"," \tif err := cfg.FrontendV2.Validate(); err != nil {"," \t\treturn err"," \t}"],"additions":3,"deletions":0,"truncated":false},{"path":"pkg/frontend/transport/handler.go","lines":["@@ -41,7 +41,7 @@ const ("," \t// StatusClientClosedRequest is the status code for when a client request cancellation of an http request"," \tStatusClientClosedRequest    = 499"," \tServiceTimingHeaderName      = \"Server-Timing\"","-\tcacheControlLogField         = \"header_cache_control\"","+\tcacheControlSafeHeader       = safeHeader(requestoptions.CacheControlHeader)"," \tresponseQueryStatsHeaderName = \"X-Mimir-Response-Query-Stats\""," \tencodeTimeSeconds            = \"encode_time_seconds\""," \testimatedSeriesCount         = \"estimated_series_count\"","@@ -64,6 +64,28 @@ var ("," \terrCanceled              = httpgrpc.Error(StatusClientClosedRequest, context.Canceled.Error())"," \terrDeadlineExceeded      = httpgrpc.Error(http.StatusGatewayTimeout, context.DeadlineExceeded.Error())"," \terrRequestEntityTooLarge = httpgrpc.Errorf(http.StatusRequestEntityTooLarge, \"http: request body too large\")","+","+\t// sensitiveHeaderNames is the deny list of HTTP header names whose values","+\t// carry credentials or session material and must never appear in logs.","+\tsensitiveHeaderNames = []string{","+\t\t\"authorization\",","+\t\t\"proxy-authorization\",","+\t\t\"cookie\",","+\t\t\"set-cookie\",","+\t\t\"x-api-key\",","+\t\t\"x-auth-token\",","+\t\t\"x-amz-security-token\",","+\t\t\"authentication-info\",","+\t\t\"www-authenticate\",","+\t\t\"proxy-authenticate\",","+\t\t\"x-csrf-token\",","+\t\t\"x-xsrf-token\",","+\t\t\"x-access-token\",","+\t\t\"x-session-token\",","+\t\t\"x-forwarded-authorization\",","+\t\t\"x-auth-request-access-token\",","+\t\t\"x-id-token\",","+\t}"," )"," "," // HandlerConfig is a config for the handler.","@@ -83,13 +105,27 @@ func (cfg *HandlerConfig) RegisterFlags(f *flag.FlagSet) {"," \tf.DurationVar(&cfg.ActiveSeriesWriteTimeout, \"query-frontend.active-series-write-timeout\", 5*time.Minute, \"Timeout for writing active series responses. 0 means the value from `-server.http-write-timeout` is used.\")"," }"," ","+// Validate the HandlerConfig.","+func (cfg *HandlerConfig) Validate() error {","+\tvar rejected []string","+\tfor _, h := range cfg.LogQueryRequestHeaders {","+\t\tif isSensitiveHeaderName(h) {","+\t\t\trejected = append(rejected, h)","+\t\t}","+\t}","+\tif len(rejected) > 0 {","+\t\treturn fmt.Errorf(\"-query-frontend.log-query-request-headers must not contain headers that carry credentials or session material: %s\", strings.Join(rejected, \", \"))","+\t}","+\treturn nil","+}","+"," // Handler accepts queries and forwards them to RoundTripper. It can wait on in-flight requests and log slow queries,"," // all other logic is inside the RoundTripper."," type Handler struct {","-\tcfg          HandlerConfig","-\theadersToLog []string","-\tlog          log.Logger","-\troundTripper http.RoundTripper","+\tcfg              HandlerConfig","+\tsafeHeadersToLog []safeHeader","+\tlog              log.Logger","+\troundTripper     http.RoundTripper"," "," \t// Metrics."," \tquerySeconds               *prometheus.CounterVec","@@ -111,10 +147,10 @@ type Handler struct {"," // NewHandler creates a new frontend handler."," func NewHandler(cfg HandlerConfig, roundTripper http.RoundTripper, log log.Logger, reg prometheus.Registerer) *Handler {"," \th := &Handler{","-\t\tcfg:          cfg,","-\t\theadersToLog: filterHeadersToLog(cfg.LogQueryRequestHeaders),","-\t\tlog:          log,","-\t\troundTripper: roundTripper,","+\t\tcfg:              cfg,","+\t\tsafeHeadersToLog: safeHeadersToLog(cfg.LogQueryRequestHeaders),","+\t\tlog:              log,","+\t\troundTripper:     roundTripper,"," \t}"," \th.cond = sync.NewCond(&h.mtx)"," ","@@ -305,7 +341,7 @@ func (f *Handler) reportSlowQuery(r *http.Request, queryString url.Values, query"," \t\t\"time_taken\", queryResponseTime.String(),"," \t}"," ","-\tlogMessage = append(logMessage, formatRequestHeaders(&r.Header, f.headersToLog)...)","+\tlogMessage = append(logMessage, f.formatRequestHeaders(&r.Header)...)"," "," \t// Append query string params last so that, if the log line is truncated downstream,"," \t// the long param_query value is what gets cut rather than other fields.","@@ -412,7 +448,7 @@ func (f *Handler) reportQueryStats("," \t\tlogMessage = append(logMessage, \"read_consistency_max_delay\", delay)"," \t}"," ","-\tlogMessage = append(logMessage, formatRequestHeaders(&r.Header, f.headersToLog)...)","+\tlogMessage = append(logMessage, f.formatRequestHeaders(&r.Header)...)"," "," \tif queryErr == nil && queryResponseStatusCode/100 != 2 {"," \t\t// If downstream replied with non-2xx, log this as a failure.","@@ -483,21 +519,75 @@ func paramValueFromDetails(details *querymiddleware.QueryDetails, paramName stri"," \treturn \"\""," }"," ","-func filterHeadersToLog(headersToLog []string) (filtered []string) {","+// safeHeader is the name of an HTTP request header that has been validated as","+// safe to log: it is not in the sensitive-header deny list. Values must be","+// constructed via newSafeHeader so the deny-list check cannot be bypassed by","+// callers outside the package.","+type safeHeader string","+","+// newSafeHeader returns a safeHeader wrapping name and true, or the zero value","+// and false if name is in the sensitive-header deny list.","+func newSafeHeader(name string) (safeHeader, bool) {","+\tif isSensitiveHeaderName(name) {","+\t\treturn \"\", false","+\t}","+\treturn safeHeader(name), true","+}","+","+func (s safeHeader) String() string {","+\treturn string(s)","+}","+","+func (s safeHeader) log() string {","+\treturn fmt.Sprintf(\"header_%s\", strings.ReplaceAll(strings.ToLower(string(s)), \"-\", \"_\"))","+}","+","+// isSensitiveHeaderName reports whether the named header carries credentials","+// or session material whose value must never be logged, regardless of operator","+// allow-list configuration.","+func isSensitiveHeaderName(name string) bool {","+\tlower := strings.ToLower(name)","+\tfor _, h := range sensitiveHeaderNames {","+\t\tif h == lower {","+\t\t\treturn true","+\t\t}","+\t}","+\treturn false","+}","+","+func safeHeadersToLog(headersToLog []string) (safeHeaders []safeHeader) {"," \tfor _, h := range headersToLog {"," \t\tif strings.EqualFold(h, requestoptions.CacheControlHeader) {"," \t\t\tcontinue"," \t\t}","-\t\tfiltered = append(filtered, h)","+\t\tif s, ok := newSafeHeader(h); ok {","+\t\t\tsafeHeaders = append(safeHeaders, s)","+\t\t}"," \t}","-\treturn filtered","+\treturn safeHeaders","+}","+","+// sanitizeHeaderValue reads headerName from header and returns its sanitized","+// value. The ok flag is true when the sanitized value is non-empty or","+// acceptEmpty is set.","+func sanitizeHeaderValue(header *http.Header, headerName safeHeader, acceptEmpty bool) (string, bool) {","+\tvalue := header.Get(headerName.String())","+\tvalue = strings.TrimSpace(value)","+","+\treturn value, acceptEmpty || value != \"\""," }"," ","-func formatRequestHeaders(h *http.Header, headersToLog []string) (fields []any) {","-\tfields = append(fields, cacheControlLogField, h.Get(requestoptions.CacheControlHeader))","-\tfor _, s := range headersToLog {","-\t\tif v := h.Get(s); v != \"\" {","-\t\t\tfields = append(fields, fmt.Sprintf(\"header_%s\", strings.ReplaceAll(strings.ToLower(s), \"-\", \"_\")), v)","+// formatRequestHeaders returns the log fields for the Cache-Control header and","+// for every operator-allow-listed header present in the request. All such","+// headers are of type safeHeader.","+func (f *Handler) formatRequestHeaders(header *http.Header) (fields []any) {","+\tif v, ok := sanitizeHeaderValue(header, cacheControlSafeHeader, true); ok {","+\t\tfields = append(fields, cacheControlSafeHeader.log(), v)","+\t}","+","+\tfor _, s := range f.safeHeadersToLog {","+\t\tif v, ok := sanitizeHeaderValue(header, s, false); ok {","+\t\t\tfields = append(fields, s.log(), v)"," \t\t}"," \t}"," \treturn fields"],"additions":109,"deletions":19,"truncated":false},{"path":"pkg/frontend/transport/handler_test.go","lines":["@@ -26,6 +26,7 @@ import ("," \t\"github.com/gogo/protobuf/proto\""," \t\"github.com/golang/snappy\""," \t\"github.com/grafana/dskit/concurrency\"","+\t\"github.com/grafana/dskit/flagext\""," \t\"github.com/grafana/dskit/httpgrpc\""," \t\"github.com/grafana/dskit/middleware\""," \t\"github.com/grafana/dskit/test\"","@@ -1133,13 +1134,25 @@ func TestHandler_QueryStringLoggedLast(t *testing.T) {"," \trequire.True(t, sawQueryStats)"," }"," ","-func TestFormatRequestHeaders(t *testing.T) {","+func TestHandler_FormatRequestHeaders(t *testing.T) {"," \th := http.Header{}"," \th.Add(\"X-Header-To-Log\", \"i should be logged!\")"," \th.Add(\"X-Header-To-Not-Log\", \"i shouldn't be logged!\")","+\th.Add(\"Authorization\", \"Bearer super-secret-token\")","+\th.Add(\"X-Api-Key\", \"secret-api-key\")"," ","-\tfields := formatRequestHeaders(&h, []string{\"X-Header-To-Log\", \"X-Header-Not-Present\"})","+\troundTripper := roundTripperFunc(func(*http.Request) (*http.Response, error) {","+\t\treturn &http.Response{StatusCode: http.StatusOK}, nil","+\t})","+","+\treg := prometheus.NewPedanticRegistry()","+\tcfg := HandlerConfig{LogQueryRequestHeaders: []string{\"X-Header-To-Log\", \"X-Header-Not-Present\", \"Authorization\", \"X-Api-Key\"}}","+\tlogger := &testLogger{}","+\thandler := NewHandler(cfg, roundTripper, logger, reg)"," ","+\tfields := handler.formatRequestHeaders(&h)","+","+\t// We don't expect to see \"Authorization\" nor \"X-Api-Key\"."," \texpected := []interface{}{"," \t\t\"header_cache_control\","," \t\t\"\",","@@ -1149,3 +1162,133 @@ func TestFormatRequestHeaders(t *testing.T) {"," "," \tassert.Equal(t, expected, fields)"," }","+","+func TestSafeHeadersToLog(t *testing.T) {","+\tt.Run(\"remove Cache-Control if it is present\", func(t *testing.T) {","+\t\tgot := safeHeadersToLog([]string{","+\t\t\t\"X-Header-To-Log\",","+\t\t\t\"Cache-Control\",","+\t\t\t\"Authorization\",","+\t\t\t\"X-Api-Key\",","+\t\t\t\"X-Trace-Id\",","+\t\t})","+\t\tassert.Equal(t, []safeHeader{\"X-Header-To-Log\", \"X-Trace-Id\"}, got)","+\t})","+","+\tt.Run(\"don't add Cache-Control if it is not present\", func(t *testing.T) {","+\t\tgot := safeHeadersToLog([]string{","+\t\t\t\"X-Header-To-Log\",","+\t\t\t\"Authorization\",","+\t\t\t\"X-Api-Key\",","+\t\t\t\"X-Trace-Id\",","+\t\t})","+\t\tassert.Equal(t, []safeHeader{\"X-Header-To-Log\", \"X-Trace-Id\"}, got)","+\t})","+}","+","+func TestNewSafeHeader(t *testing.T) {","+\tt.Run(\"for non-sensitive headers should return a new safeHeader\", func(t *testing.T) {","+\t\tsH, ok := newSafeHeader(\"X-Custom-Header\")","+\t\tassert.True(t, ok)","+\t\tassert.Equal(t, \"X-Custom-Header\", sH.String())","+\t\tassert.Equal(t, \"header_x_custom_header\", sH.log())","+\t})","+","+\tt.Run(\"for sensitive headers should not return a new safeHeader\", func(t *testing.T) {","+\t\tfor _, name := range sensitiveHeaderNames {","+\t\t\t_, ok := newSafeHeader(name)","+\t\t\tassert.False(t, ok)","+\t\t}","+\t})","+}","+","+func TestSanitizeHeaderValue(t *testing.T) {","+\ttype testCase struct {","+\t\theaderName     string","+\t\tvalue          string","+\t\tacceptEmpty    bool","+\t\texpectedValue  string","+\t\texpectedStatus bool","+\t}","+","+\ttestCases := map[string]testCase{","+\t\t\"non-sensitive header passes through\": {","+\t\t\theaderName:     \"X-Custom-Header\",","+\t\t\tvalue:          \"some-value\",","+\t\t\texpectedValue:  \"some-value\",","+\t\t\texpectedStatus: true,","+\t\t},","+\t\t\"empty value returns empty if accepted\": {","+\t\t\theaderName:     \"X-Custom-Header\",","+\t\t\tvalue:          \"\",","+\t\t\tacceptEmpty:    true,","+\t\t\texpectedValue:  \"\",","+\t\t\texpectedStatus: true,","+\t\t},","+\t\t\"empty value rejected if not accepted\": {","+\t\t\theaderName:     \"X-Custom-Header\",","+\t\t\tvalue:          \"\",","+\t\t\tacceptEmpty:    false,","+\t\t\texpectedValue:  \"\",","+\t\t\texpectedStatus: false,","+\t\t},","+\t}","+","+\tfor name, tc := range testCases {","+\t\tt.Run(name, func(t *testing.T) {","+\t\t\theader := &http.Header{tc.headerName: {tc.value}}","+\t\t\tsH, ok := newSafeHeader(tc.headerName)","+\t\t\tassert.True(t, ok)","+\t\t\tval, ok := sanitizeHeaderValue(header, sH, tc.acceptEmpty)","+\t\t\tassert.Equal(t, tc.expectedStatus, ok)","+\t\t\tassert.Equal(t, tc.expectedValue, val)","+\t\t})","+\t}","+}","+","+func TestHandlerConfig_Validate(t *testing.T) {","+\ttestCases := map[string]struct {","+\t\theaders       []string","+\t\texpectErr     bool","+\t\texpectErrSubs []string","+\t}{","+\t\t\"empty allow-list is valid\": {","+\t\t\theaders:   nil,","+\t\t\texpectErr: false,","+\t\t},","+\t\t\"benign headers are valid\": {","+\t\t\theaders:   []string{\"User-Agent\", \"X-Trace-Id\", \"X-Custom-Tenant\"},","+\t\t\texpectErr: false,","+\t\t},","+\t\t\"single sensitive header is rejected\": {","+\t\t\theaders:       []string{\"Authorization\"},","+\t\t\texpectErr:     true,","+\t\t\texpectErrSubs: []string{\"Authorization\"},","+\t\t},","+\t\t\"multiple sensitive headers are reported together\": {","+\t\t\theaders:       []string{\"User-Agent\", \"Authorization\", \"X-Api-Key\", \"X-Trace-Id\"},","+\t\t\texpectErr:     true,","+\t\t\texpectErrSubs: []string{\"Authorization\", \"X-Api-Key\"},","+\t\t},","+\t\t\"matching is case-insensitive\": {","+\t\t\theaders:       []string{\"AUTHORIZATION\"},","+\t\t\texpectErr:     true,","+\t\t\texpectErrSubs: []string{\"AUTHORIZATION\"},","+\t\t},","+\t}","+","+\tfor name, tc := range testCases {","+\t\tt.Run(name, func(t *testing.T) {","+\t\t\tcfg := HandlerConfig{LogQueryRequestHeaders: flagext.StringSliceCSV(tc.headers)}","+\t\t\terr := cfg.Validate()","+\t\t\tif !tc.expectErr {","+\t\t\t\trequire.NoError(t, err)","+\t\t\t\treturn","+\t\t\t}","+\t\t\trequire.Error(t, err)","+\t\t\tfor _, sub := range tc.expectErrSubs {","+\t\t\t\tassert.Contains(t, err.Error(), sub)","+\t\t\t}","+\t\t})","+\t}","+}",""],"additions":145,"deletions":2,"truncated":false}],"additions":258,"deletions":21,"truncated":false,"file_count":4},"error":null,"fetched_at":"2026-05-30T09:34:59.724600+00:00"}