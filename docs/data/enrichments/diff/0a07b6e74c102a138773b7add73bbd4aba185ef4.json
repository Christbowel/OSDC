{"id":"0a07b6e74c102a138773b7add73bbd4aba185ef4","axis":"silent","repo":"rack/rack","sha":"0a07b6e74c102a138773b7add73bbd4aba185ef4","parsed":{"files":[{"path":"lib/rack/conditional_get.rb","lines":["@@ -6,7 +6,7 @@"," "," module Rack"," ","-  # Middleware that enables conditional GET using if-none-match and","+  # Middleware that enables conditional GET and QUERY using if-none-match and","   # if-modified-since. The application should set either or both of the","   # last-modified or etag response headers according to RFC 2616. When","   # either of the conditions is met, the response body is set to be zero","@@ -27,7 +27,7 @@ def initialize(app)","     # modified since the last request.","     def call(env)","       case env[REQUEST_METHOD]","-      when \"GET\", \"HEAD\"","+      when \"GET\", \"HEAD\", \"QUERY\"","         status, headers, body = response = @app.call(env)"," ","         if status == 200 && fresh?(env, headers)"],"additions":2,"deletions":2,"truncated":false},{"path":"lib/rack/constants.rb","lines":["@@ -36,6 +36,7 @@ module Rack","   LINK    = 'LINK'","   UNLINK  = 'UNLINK'","   TRACE   = 'TRACE'","+  QUERY   = 'QUERY'"," ","   # Rack environment variables","   RACK_VERSION                        = 'rack.version'"],"additions":1,"deletions":0,"truncated":false},{"path":"lib/rack/method_override.rb","lines":["@@ -6,7 +6,7 @@"," "," module Rack","   class MethodOverride","-    HTTP_METHODS = %w[GET HEAD PUT POST DELETE OPTIONS PATCH LINK UNLINK]","+    HTTP_METHODS = %w[GET HEAD PUT POST DELETE OPTIONS PATCH LINK UNLINK QUERY]"," ","     PRIV_HTTP_METHODS = HTTP_METHODS","     private_constant :PRIV_HTTP_METHODS"],"additions":1,"deletions":1,"truncated":false},{"path":"lib/rack/mock_request.rb","lines":["@@ -10,12 +10,12 @@ module Rack","   # Rack::MockRequest helps testing your Rack application without","   # actually using HTTP.","   #","-  # After performing a request on a URL with get/post/put/patch/delete, it","+  # After performing a request