 align=\"start\" gap=\"sm\">","+\t\t\t\t\t\t\t{ links.map( ( link ) => (","+\t\t\t\t\t\t\t\t<Link","+\t\t\t\t\t\t\t\t\tkey={ link.href }","+\t\t\t\t\t\t\t\t\thref={ link.href }","+\t\t\t\t\t\t\t\t\tclassName={ styles.link }","+\t\t\t\t\t\t\t\t>","+\t\t\t\t\t\t\t\t\t{ link.label }","+\t\t\t\t\t\t\t\t</Link>","+\t\t\t\t\t\t\t) ) }","+\t\t\t\t\t\t</Stack>","+\t\t\t\t\t) }","+\t\t\t\t</Stack>","+\t\t\t</Popover.Popup>","+\t\t</Popover.Root>","+\t);","+}"],"additions":82,"deletions":0,"truncated":false},{"path":"packages/widget-dashboard/src/components/widget-header/widget-header.module.css","lines":["@@ -29,6 +29,31 @@"," \tcolor: var(--wpds-color-foreground-content-neutral);"," }"," ","+.popoverPopup {","+\tmax-width: 300px;","+}","+","+/**","+ * Infotip trigger: a bare icon button beside the title.","+ */","+.help {","+\tdisplay: inline-flex;","+\talign-items: center;","+\tpadding: 0;","+\tborder: 0;","+\tbackground: none;","+\tcolor: var(--wpds-color-foreground-content-neutral-weak);","+\tcursor: var(--wpds-cursor-control);","+}","+","+/**","+ * Divide adjacent links in the infotip.","+ */","+.link + .link {","+\tborder-inline-start: var(--wpds-border-width-xs) solid var(--wpds-color-stroke-surface-neutral);","+\tpadding-inline-start: var(--wpds-dimension-gap-sm);","+}","+"," .toolbar {"," \tmargin-inline-start: auto;"," }"],"additions":25,"deletions":0,"truncated":false},{"path":"packages/widget-dashboard/src/components/widget-header/widget-header.tsx","lines":["@@ -13,11 +13,13 @@ import type { WidgetType } from '@wordpress/widget-primitives';"," /**","  * Internal dependencies","  */","+import { WidgetInfotip } from './widget-header-infotip';"," import styles from './widget-header.module.css';"," "," export interface WidgetHeaderProps {"," \t/**","-\t * Widget type, source of the icon and title shown as identity.","+\t * Widget type, source of the icon, title, and help note shown as","+\t * identity."," \t */"," \twidgetType?: WidgetType;"," ","@@ -83,8 +85,16 @@ 