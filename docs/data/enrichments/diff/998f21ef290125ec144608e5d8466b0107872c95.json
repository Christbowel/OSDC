,"-\t\tip, err := netip.ParseAddr(address)","-\t\tif err != nil {","-\t\t\tslog.DebugContext(ctx, \"Skipping invalid IP\", \"ip\", address, \"error\", err)","-\t\t\tcontinue","-\t\t}","-","-\t\tnameservers = append(nameservers, AddrWithDNSPort(ip))","-\t}","-","-\tslog.DebugContext(ctx, \"Loaded host upstream nameservers.\", \"nameservers\", nameservers, \"config_file\", confFilePath)","-\treturn nameservers, nil","-}","+var platformUpstreamNameserverSource = ResolvConfUpstreamNameserverSource"],"additions":1,"deletions":53,"truncated":false},{"path":"lib/vnet/dns/osnameservers_linux.go","lines":["@@ -28,48 +28,53 @@ import ("," \t\"github.com/gravitational/teleport/lib/vnet/systemdresolved\""," )"," ","-// platformLoadUpstreamNameservers returns the list of DNS upstreams configured in systemd-resolved.","-func platformLoadUpstreamNameservers(ctx context.Context, slog *slog.Logger) ([]string, error) {","-\tconn, err := dbus.ConnectSystemBus()","-\tif err != nil {","-\t\treturn nil, trace.NotFound(\"system D-Bus is unavailable: %v\", err)","-\t}","-\tdefer conn.Close()","-\tif err := systemdresolved.CheckAvailability(ctx, conn); err != nil {","-\t\treturn nil, err","-\t}","+var platformUpstreamNameserverSource = SystemDUpstreamNameserverSource"," ","-\tdns, err := systemdresolved.LoadConfiguredDNSServers(ctx, conn)","-\tif err != nil {","-\t\treturn nil, err","-\t}","-","-\tnameservers := make([]string, 0, len(dns))","-\tfor _, entry := range dns {","-\t\taddr, ok := netip.AddrFromSlice(entry.Address)","-\t\tif !ok {","-\t\t\tslog.DebugContext(ctx, \"Skipping invalid DNS server address\", \"address_bytes\", entry.Address)","-\t\t\tcontinue","+// SystemDUpstreamNameserverSource returns the list of DNS upstreams configured","+// in systemd-resolved.","+func SystemDUpstreamNameserverSource(log *slog.Logger) UpstreamNameserverSource {","+\treturn upstreamNameserverSourceFn(func(ctx context.Context) ([]string, error) {","+\t\tconn, err := dbus.ConnectSystemBus()","+\t\tif err != nil {","+\t\t\treturn nil, trace.NotFound(\"system D-Bus is unavailable: %v\", err)","+\t\t}","+\t\tdefer conn.Close()","+\t\tif err := systemdresolved.CheckAvailability(ctx, conn); err != nil {","+\t\t\treturn nil, err"," \t\t}","-\t\tif addr.IsUnspecified() || addr.IsLoopback() {","-\t\t\tcontinue","+","+\t\tdns, err := systemdresolved.LoadConfiguredDNSServers(ctx, conn)","+\t\tif err != nil {","+\t\t\treturn nil, err"," \t\t}","-\t\t// Link-local IPv6 addresses require a scope to be routable.","-\t\tif addr.Is6() && addr.IsLinkLocalUnicast() {","-\t\t\tif entry.InterfaceIndex == 0 {","-\t\t\t\tslog.DebugContext(ctx, \"Skipping link-local DNS server without interface index\", \"address\", addr.String())","+","+\t\tnameservers := make([]string, 0, len(dns))","+\t\tfor _, entry := range dns {","+\t\t\taddr, ok := netip.AddrFromSlice(entry.Address)","+\t\t\tif !ok {","+\t\t\t\tlog.DebugContext(ctx, \"Skipping invalid DNS server address\", \"address_bytes\", entry.Address)"," \t\t\t\tcontinue"," \t\t\t}","-\t\t\tiface, err := net.InterfaceByIndex(int(entry.InterfaceIndex))","-\t\t\tif err != nil {","-\t\t\t\tslog.DebugContext(ctx, \"Skipping link-local DNS server with unknown interface\", \"address\", addr.String(), \"interface_index\", entry.InterfaceIndex, \"error\", err)","+\t\t\tif addr.IsUnspecified() || addr.IsLoopback() {"," \t\t\t\tcontinue"," \t\t\t}","-\t\t\taddr = addr.WithZone(iface.Name)","+\t\t\t// Link-local IPv6 addresses require a scope to be routable.","+\t\t\tif addr.Is6() && addr.IsLinkLocalUnicast() {","+\t\t\t\tif entry.InterfaceIndex == 0 {","+\t\t\t\t\tlog.DebugContext(ctx, \"Skipping link-local DNS server without interface index\", \"address\", addr.String())","+\t\t\t\t\tcontinue","+\t\t\t\t}","+\t\t\t\tiface, err := net.InterfaceByIndex(int(entry.InterfaceIndex))","+\t\t\t\tif err != nil {","+\t\t\t\t\tlog.DebugContext(ctx, \"Skipping link-local DNS server with unknown interface\", \"address\", addr.String(), \"interface_index\", entry.InterfaceIndex, \"error\", err)","+\t\t\t\t\tcontinue","+\t\t\t\t}","+\t\t\t\taddr = addr.WithZone(iface.Name)","+\t\t\t}","+\t\t\tnameservers = append(nameservers, AddrWithDNSPort(addr))"," \t\t}","-\t\tnameservers = append(nameservers, AddrWithDNSPort(addr))","-\t}"," ","-\tslog.DebugContext(ctx, \"Loaded host upstream nameservers\", \"nameservers\", nameservers)","-\treturn nameservers, nil","+\t\tlog.DebugContext(ctx, \"Loaded host upstream nameservers\", \"nameservers\", nameservers)","+\t\treturn nameservers, nil","+\t})"," }"],"additions":40,"deletions":35,"truncated":false},{"path":"lib/vnet/dns/osnameservers_other.go","lines":["@@ -31,6 +31,8 @@ var ("," \tvnetNotImplemented = &trace.NotImplementedError{Message: \"VNet is not implemented on \" + runtime.GOOS}"," )"," ","-func platformLoadUpstreamNameservers(ctx context.Context, slog *slog.Logger) ([]string, error) {","-\treturn nil, trace.Wrap(vnetNotImplemented)","+func platformUpstreamNameserverSource(*slog.Logger) UpstreamNameserverSource {","+\treturn upstreamNameserverSourceFn(func(context.Context) ([]string, error) {","+\t\treturn nil, trace.Wrap(vnetNotImplemented)","+\t})"," }"],"additions":4,"deletions":2,"truncated":false},{"path":"lib/vnet/dns/osnameservers_windows.go","lines":["@@ -1,3 +1,5 @@","+//go:build windows","+"," // Teleport"," // Copyright (C) 2025 Gravitational, Inc."," //","@@ -27,32 +29,36 @@ import ("," \t\"golang.zx2c4.com/wireguard/windows/tunnel/winipcfg\""," )"," ","-// platformLoadUpstreamNameservers attempts to find the default DNS nameservers","+var platformUpstreamNameserverSource = WindowsUpstreamNameserverSource","+","+// WindowsUpstreamNameserverSource attempts to find the default DNS nameservers"," // that VNet should forward unmatched queries to. To do this, it finds the"," // nameservers configured for each interface and sorts by the interface metric.","-func platformLoadUpstreamNameservers(ctx context.Context, slog *slog.Logger) ([]string, error) {","-\tinterfaces, err := winipcfg.GetIPInterfaceTable(windows.AF_INET)","-\tif err != nil {","-\t\treturn nil, trace.Wrap(err, \"looking up local network interfaces\")","-\t}","-\tsort.Slice(interfaces, func(i, j int) bool {","-\t\treturn interfaces[i].Metric < interfaces[j].Metric","-\t})","-\tvar nameservers []string","-\tfor _, iface := range interfaces {","-\t\tifaceNameservers, err := iface.InterfaceLUID.DNS()","+func WindowsUpstreamNameserverSource(slog *slog.Logger) UpstreamNameserverSource {","+\treturn upstreamNameserverSourceFn(func(ctx context.Context) ([]string, error) {","+\t\tinterfaces, err := winipcfg.GetIPInterfaceTable(windows.AF_INET)"," \t\tif err != nil {","-\t\t\treturn nil, trace.Wrap(err, \"looking up DNS nameservers for interface\")","+\t\t\treturn nil, trace.Wrap(err, \"looking up local network interfaces\")"," \t\t}","-\t\tfor _, ifaceNameserver := range ifaceNameservers {","-\t\t\tif ignoreUpstreamNameserver(ifaceNameserver) {","-\t\t\t\tcontinue","+\t\tsort.Slice(interfaces, func(i, j int) bool {","+\t\t\treturn interfaces[i].Metric < interfaces[j].Metric","+\t\t})","+\t\tvar nameservers []string","+\t\tfor _, iface := range interfaces {","+\t\t\tifaceNameservers, err := iface.InterfaceLUID.DNS()","+\t\t\tif err != nil {","+\t\t\t\treturn nil, trace.Wrap(err, \"looking up DNS nameservers for interface\")","+\t\t\t}","+\t\t\tfor _, ifaceNameserver := range ifaceNameservers {","+\t\t\t\tif ignoreUpstreamNameserver(ifaceNameserver) {","+\t\t\t\t\tcontinue","+\t\t\t\t}","+\t\t\t\tnameservers = append(nameservers, AddrWithDNSPort(ifaceNameserver))"," \t\t\t}","-\t\t\tnameservers = append(nameservers, AddrWithDNSPort(ifaceNameserver))"," \t\t}","-\t}","-\tslog.DebugContext(ctx, \"Loaded host upstream nameservers\", \"nameservers\", nameservers)","-\treturn nameservers, nil","+\t\tslog.DebugContext(ctx, \"Loaded host upstream nameservers\", \"nameservers\", nameservers)","+\t\treturn nameservers, nil","+\t})"," }"," "," var ("],"additions":26,"deletions":20,"truncated":false},{"path":"lib/vnet/dns/resolvconf.go","lines":["@@ -0,0 +1,79 @@","+//go:build linux || darwin","+","+// Teleport","+// Copyright (C) 2026 Gravitational, Inc.","+//","+// This program is free software: you can redistribute it and/or modify","+// it under the terms of the GNU Affero General Public License as published by","+// the Free Software Foundation, either version 3 of the License, or","+// (at your option) any later version.","+//","+// This program is distributed in the hope that it will be useful,","+// but WITHOUT ANY WARRANTY; without even the implied warranty of","+// MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the","+// GNU Affero General Public License for more details.","+//","+// You should have received a copy of the GNU Affero General Public License","+// along with this program.  If not, see <http://www.gnu.org/licenses/>.","+","+package dns","+","+import (","+\t\"bufio\"","+\t\"context\"","+\t\"log/slog\"","+\t\"net/netip\"","+\t\"os\"","+\t\"strings\"","+","+\t\"github.com/gravitational/trace\"","+)","+","+const (","+\tconfFilePath = \"/etc/resolv.conf\"","+)","+","+// ResolvConfUpstreamNameserverSource reads the OS DNS nameservers found in the","+// /etc/resolv.conf file on unix-like systems.","+//","+// https://man7.org/linux/man-pages/man5/resolver.5.html","+//","+// On macOS, the comments in the file make it clear it is not actually consulted","+// for DNS hostname resolution, but it seems to be be kept up-to-date with the","+// current default nameservers as configured for the OS, and it is the easiest","+// place to read them. Eventually, we should probably use a better method, but","+// for now this works.","+func ResolvConfUpstreamNameserverSource(slog *slog.Logger) UpstreamNameserverSource {","+\treturn upstreamNameserverSourceFn(func(ctx context.Context) ([]string, error) {","+\t\tf, err := os.Open(confFilePath)","+\t\tif err != nil {","+\t\t\treturn nil, trace.Wrap(err, \"opening %s\", confFilePath)","+\t\t}","+\t\tdefer f.Close()","+","+\t\tvar nameservers []string","+\t\tscanner := bufio.NewScanner(f)","+\t\tfor scanner.Scan() {","+\t\t\tline := scanner.Text()","+\t\t\tif !strings.HasPrefix(line, \"nameserver \") {","+\t\t\t\tcontinue","+\t\t\t}","+\t\t\tfields := strings.Fields(line)","+\t\t\tif len(fields) < 2 {","+\t\t\t\tcontinue","+\t\t\t}","+\t\t\taddress := fields[1]","+","+\t\t\tip, err := netip.ParseAddr(address)","+\t\t\tif err != nil {","+\t\t\t\tslog.DebugContext(ctx, \"Skipping invalid IP\", \"ip\", address, \"error\", err)","+\t\t\t\tcontinue","+\t\t\t}","+","+\t\t\tnameservers = append(nameservers, AddrWithDNSPort(ip))","+\t\t}","+","+\t\tslog.DebugContext(ctx, \"Loaded host upstream nameservers.\", \"nameservers\", nameservers, \"config_file\", confFilePath)","+\t\treturn nameservers, nil","+\t})","+}"],"additions":79,"deletions":0,"truncated":false},{"path":"lib/vnet/embedded.go","lines":["@@ -0,0 +1,306 @@","+// Teleport","+// Copyright (C) 2026 Gravitational, Inc.","+//","+// This program is free software: you can redistribute it and/or modify","+// it under the terms of the GNU Affero General Public License as published by","+// the Free Software Foundation, either version 3 of the License, or","+// (at your option) any later version.","+//","+// This program is distributed in the hope that it will be useful,","+// but WITHOUT ANY WARRANTY; without even the implied warranty of","+// MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the","+// GNU Affero General Public License for more details.","+//","+// You should have received a copy of the GNU Affero General Public License","+// along with this program.  If not, see <http://www.gnu.org/licenses/>.","+","+package vnet","+","+import (","+\t\"bytes\"","+\t\"context\"","+\t\"crypto\"","+\t\"crypto/tls\"","+\t\"errors\"","+\t\"io\"","+","+\t\"github.com/gravitational/trace\"","+\t\"golang.org/x/crypto/ssh\"","+\t\"golang.org/x/sync/errgroup\"","+\t\"google.golang.org/grpc\"","+","+\tvnetv1 \"github.com/gravitational/teleport/gen/proto/go/teleport/lib/vnet/v1\"","+\t\"github.com/gravitational/teleport/lib/cryptosuites\"","+\t\"github.com/gravitational/teleport/lib/vnet/dns\"","+)","+","+// EmbeddedVNetConfig is the configuration for an embedded/single-process","+// application of VNet.","+type EmbeddedVNetConfig struct {","+\t// Device is the TUN device VNet will bind to.","+\tDevice TUNDevice","+","+\t// ApplicationService is used to provide configuration, resolve DNS queries,","+\t// and generate client certificates.","+\tApplicationService EmbeddedApplicationService","+","+\t// ConfigureHost is called to update the host's routing table and DNS","+\t// resolver configuration. It will be called multiple times, so must be","+\t// idempotent. cfg will be nil when VNet it shutting down and any host","+\t// configuration should be torn down.","+\tConfigureHost EmbeddedConfigureHostFunc","+","+\t// UpstreamNameserverSource overrides the default platform source of upstream","+\t// nameservers (e.g. allowing you to swap systemd-resolved for /etc/resolv.conf","+\t// on Linux).","+\tUpstreamNameserverSource dns.UpstreamNameserverSource","+}","+","+// EmbeddedConfigureHostFunc is called to update the host's routing table and","+// DNS resolver configuration.","+type EmbeddedConfigureHostFunc func(ctx context.Context, cfg *EmbeddedVNetHostConfig) error","+","+// EmbeddedApplicationService is a subset of vnetv1.ClientApplicationServiceClient","+// required for embedded/single-process applications of VNet.","+type EmbeddedApplicationService interface {","+\t// ResolveFQDN is called during DNS resolution to resolve a fully-qualified","+\t// domain name to a target.","+\tResolveFQDN(ctx context.Context, fqdn string) (*vnetv1.ResolveFQDNResponse, error)","+","+\t// GetTargetOSConfiguration gets the target OS configuration.","+\tGetTargetOSConfiguration(ctx context.Context) (*vnetv1.TargetOSConfiguration, error)","+","+\t// GetAppCert issues a TLS certificate for the given application.","+\tGetAppCert(ctx context.Context, key *vnetv1.AppInfo, port uint16) (*tls.Certificate, error)","+","+\t// GetAppSigner returns the private key for the given application's TLS certificate.","+\tGetAppSigner(ctx context.Context, key *vnetv1.AppKey, port uint16) (crypto.Signer, error)","+}","+","+// EmbeddedVNetHostConfig is passed to EmbeddedVNetConfig.ConfigureHost to","+// reconfigure the host's routing table and DNS resolver.","+type EmbeddedVNetHostConfig struct {","+\t// DeviceIPv4 is the desired IPv4 address of the TUN device.","+\tDeviceIPv4 string","+","+\t// DeviceIPv6 is the desired IPv6 address of the TUN device.","+\tDeviceIPv6 string","+","+\t// CIDRRanges are the desired IPv4 and IPv6 CIDR ranges that should be","+\t// routed to the TUN device.","+\tCIDRRanges []string","+","+\t// DNSAddrs are the IPv4 and IPv6 addresses for the VNet's nameserver.","+\tDNSAddrs []string","+","+\t// DNSZones are the zones for which the host's DNS resolver should send","+\t// queries to the VNet's nameserver.","+\tDNSZones []string","+}","+","+// EmbeddedVNet is an embedded/single-process application of VNet. It does not","+// currently support VNet SSH.","+type EmbeddedVNet struct {","+\tdevice              TUNDevice","+\tclient              *clientApplicationServiceClient","+\tconfigureHost       EmbeddedConfigureHostFunc","+\tupstreamNameservers dns.UpstreamNameserverSource","+}","+","+// NewEmbeddedVNet creates an embedded VNet with the given configuration.","+//","+// It is the caller's responsibility to configure the host by creating the TUN","+// device, updating the OS routing table, and configuring the DNS resolver.","+func NewEmbeddedVNet(cfg EmbeddedVNetConfig) (*EmbeddedVNet, error) {","+\tif cfg.Device == nil {","+\t\treturn nil, trace.BadParameter(\"Device is required\")","+\t}","+\tif cfg.ApplicationService == nil {","+\t\treturn nil, trace.BadParameter(\"ApplicationService is required\")","+\t}","+\tif cfg.ConfigureHost == nil {","+\t\treturn nil, trace.BadParameter(\"ConfigureHost is required\")","+\t}","+\treturn &EmbeddedVNet{","+\t\tdevice: cfg.Device,","+\t\tclient: &clientApplicationServiceClient{","+\t\t\tclt: &embeddedApplicationServiceClient{","+\t\t\t\tservice: cfg.ApplicationService,","+\t\t\t},","+\t\t\tcloser: io.NopCloser(bytes.NewReader([]byte{})),","+\t\t},","+\t\tconfigureHost:       cfg.ConfigureHost,","+\t\tupstreamNameservers: cfg.UpstreamNameserverSource,","+\t}, nil","+}","+","+// Run the VNet until the given context is canceled.","+func (vnet *EmbeddedVNet) Run(ctx context.Context) error {","+\tstackConfig, err := newNetworkStackConfig(ctx, vnet.device, vnet.client)","+\tif err != nil {","+\t\treturn trace.Wrap(err, \"creating network stack config\")","+\t}","+\tif vnet.upstreamNameservers != nil {","+\t\tstackConfig.upstreamNameserverSource = vnet.upstreamNameservers","+\t}","+","+\tstack, err := newNetworkStack(stackConfig)","+\tif err != nil {","+\t\treturn trace.Wrap(err, \"creating network stack\")","+\t}","+","+\ttunName, err := vnet.device.Name()","+\tif err != nil {","+\t\treturn trace.Wrap(err, \"getting TUN device name\")","+\t}","+","+\tosConfigProvider, err := newOSConfigProvider(osConfigProviderConfig{","+\t\tclt:           vnet.client,","+\t\ttunName:       tunName,","+\t\tipv6Prefix:    stackConfig.ipv6Prefix.String(),","+\t\tdnsIPv6:       stackConfig.dnsIPv6.String(),","+\t\taddDNSAddress: stack.addDNSAddress,","+\t})","+\tif err != nil {","+\t\treturn trace.Wrap(err, \"creating OS config provider\")","+\t}","+","+\tosConfigurator := newOSConfigurator(osConfigProvider,","+\t\tfunc(ctx context.Context, oc *osConfig, _ *osConfigState) error {","+\t\t\tif oc.tunName == \"\" {","+\t\t\t\treturn vnet.configureHost(ctx, nil)","+\t\t\t}","+\t\t\treturn vnet.configureHost(ctx, &EmbeddedVNetHostConfig{","+\t\t\t\tDeviceIPv4: oc.tunIPv4,","+\t\t\t\tDeviceIPv6: oc.tunIPv6,","+\t\t\t\tCIDRRanges: append(oc.cidrRanges, oc.tunIPv6+\"/64\"),","+\t\t\t\tDNSAddrs:   oc.dnsAddrs,","+\t\t\t\tDNSZones:   oc.dnsZones,","+\t\t\t})","+\t\t},","+\t)","+","+\tg, ctx := errgroup.WithContext(ctx)","+\tg.Go(func() error {","+\t\tdefer log.InfoContext(ctx, \"Network stack terminated.\")","+\t\tif err := stack.run(ctx); err != nil {","+\t\t\treturn trace.Wrap(err, \"running network stack\")","+\t\t}","+\t\treturn errors.New(\"network stack terminated\")","+\t})","+\tg.Go(func() error {","+\t\tdefer log.InfoContext(ctx, \"OS configuration loop exited.\")","+\t\tif err := osConfigurator.runOSConfigurationLoop(ctx); err != nil {","+\t\t\treturn trace.Wrap(err, \"running OS configuration loop\")","+\t\t}","+\t\treturn errors.New(\"OS configuration loop terminated\")","+\t})","+","+\terr = g.Wait()","+\tif errors.Is(err, context.Canceled) {","+\t\treturn nil","+\t}","+\treturn err","+}","+","+type embeddedApplicationServiceClient struct{ service EmbeddedApplicationService }","+","+func (e *embeddedApplicationServiceClient) AuthenticateProcess(_ context.Context, req *vnetv1.AuthenticateProcessRequest, _ ...grpc.CallOption) (*vnetv1.AuthenticateProcessResponse, error) {","+\treturn &vnetv1.AuthenticateProcessResponse{Version: req.GetVersion()}, nil","+}","+","+func (e *embeddedApplicationServiceClient) ReportNetworkStackInfo(context.Context, *vnetv1.ReportNetworkStackInfoRequest, ...grpc.CallOption) (*vnetv1.ReportNetworkStackInfoResponse, error) {","+\treturn &vnetv1.ReportNetworkStackInfoResponse{}, nil","+}","+","+func (e *embeddedApplicationServiceClient) Ping(context.Context, *vnetv1.PingRequest, ...grpc.CallOption) (*vnetv1.PingResponse, error) {","+\treturn &vnetv1.PingResponse{}, nil","+}","+","+func (e *embeddedApplicationServiceClient) ResolveFQDN(ctx context.Context, req *vnetv1.ResolveFQDNRequest, _ ...grpc.CallOption) (*vnetv1.ResolveFQDNResponse, error) {","+\treturn e.service.ResolveFQDN(ctx, req.GetFqdn())","+}","+","+func (e *embeddedApplicationServiceClient) ReissueAppCert(ctx context.Context, req *vnetv1.ReissueAppCertRequest, _ ...grpc.CallOption) (*vnetv1.ReissueAppCertResponse, error) {","+\tcert, err := e.service.GetAppCert(ctx, req.GetAppInfo(), uint16(req.GetTargetPort()))","+\tif err != nil {","+\t\treturn nil, trace.Wrap(err)","+\t}","+\treturn &vnetv1.ReissueAppCertResponse{Cert: cert.Certificate[0]}, nil","+}","+","+func (e *embeddedApplicationServiceClient) SignForApp(ctx context.Context, req *vnetv1.SignForAppRequest, _ ...grpc.CallOption) (*vnetv1.SignForAppResponse, error) {","+\tsigner, err := e.service.GetAppSigner(ctx, req.GetAppKey(), uint16(req.GetTargetPort()))","+\tif err != nil {","+\t\treturn nil, trace.Wrap(err)","+\t}","+\tsig, err := sign(signer, req.GetSign())","+\tif err != nil {","+\t\treturn nil, trace.Wrap(err, \"signing for app %v\", req.GetAppKey())","+\t}","+\treturn &vnetv1.SignForAppResponse{","+\t\tSignature: sig,","+\t}, nil","+}","+","+func (*embeddedApplicationServiceClient) OnNewAppConnection(context.Context, *vnetv1.OnNewAppConnectionRequest, ...grpc.CallOption) (*vnetv1.OnNewAppConnectionResponse, error) {","+\treturn &vnetv1.OnNewAppConnectionResponse{}, nil","+}","+","+func (*embeddedApplicationServiceClient) OnInvalidLocalPort(context.Context, *vnetv1.OnInvalidLocalPortRequest, ...grpc.CallOption) (*vnetv1.OnInvalidLocalPortResponse, error) {","+\treturn &vnetv1.OnInvalidLocalPortResponse{}, nil","+}","+","+func (e *embeddedApplicationServiceClient) GetTargetOSConfiguration(ctx context.Context, _ *vnetv1.GetTargetOSConfigurationRequest, _ ...grpc.CallOption) (*vnetv1.GetTargetOSConfigurationResponse, error) {","+\tcfg, err := e.service.GetTargetOSConfiguration(ctx)","+\tif err != nil {","+\t\treturn nil, trace.Wrap(err)","+\t}","+\treturn &vnetv1.GetTargetOSConfigurationResponse{TargetOsConfiguration: cfg}, nil","+}","+","+func (e *embeddedApplicationServiceClient) UserTLSCert(ctx context.Context, req *vnetv1.UserTLSCertRequest, _ ...grpc.CallOption) (*vnetv1.UserTLSCertResponse, error) {","+\treturn nil, trace.NotImplemented(\"SSH not supported in embedded VNet\")","+}","+","+func (e *embeddedApplicationServiceClient) SignForUserTLS(context.Context, *vnetv1.SignForUserTLSRequest, ...grpc.CallOption) (*vnetv1.SignForUserTLSResponse, error) {","+\treturn nil, trace.NotImplemented(\"SSH not supported in embedded VNet\")","+}","+","+func (*embeddedApplicationServiceClient) SessionSSHConfig(context.Context, *vnetv1.SessionSSHConfigRequest, ...grpc.CallOption) (*vnetv1.SessionSSHConfigResponse, error) {","+\treturn nil, trace.NotImplemented(\"SSH not supported in embedded VNet\")","+}","+","+func (*embeddedApplicationServiceClient) SignForSSHSession(context.Context, *vnetv1.SignForSSHSessionRequest, ...grpc.CallOption) (*vnetv1.SignForSSHSessionResponse, error) {","+\treturn nil, trace.NotImplemented(\"SSH not supported in embedded VNet\")","+}","+","+func (*embeddedApplicationServiceClient) ReissueDBCert(ctx context.Context, in *vnetv1.ReissueDBCertRequest, opts ...grpc.CallOption) (*vnetv1.ReissueDBCertResponse, error) {","+\treturn nil, trace.NotImplemented(\"databases not supported in embedded VNet\")","+}","+","+func (*embeddedApplicationServiceClient) SignForDB(context.Context, *vnetv1.SignForDBRequest, ...grpc.CallOption) (*vnetv1.SignForDBResponse, error) {","+\treturn nil, trace.NotImplemented(\"databases not supported in embedded VNet\")","+}","+","+func (*embeddedApplicationServiceClient) OnNewDBConnection(context.Context, *vnetv1.OnNewDBConnectionRequest, ...grpc.CallOption) (*vnetv1.OnNewDBConnectionResponse, error) {","+\treturn nil, trace.NotImplemented(\"databases not supported in embedded VNet\")","+}","+","+func (*embeddedApplicationServiceClient) ExchangeSSHKeys(context.Context, *vnetv1.ExchangeSSHKeysRequest, ...grpc.CallOption) (*vnetv1.ExchangeSSHKeysResponse, error) {","+\t// EmbeddedVNet does not yet support SSH, but we must return a valid public","+\t// key so that the SSH setup code doesn't return an error.","+\tkey, err := cryptosuites.GenerateKeyWithAlgorithm(cryptosuites.Ed25519)","+\tif err != nil {","+\t\treturn nil, trace.Wrap(err)","+\t}","+\tsigner, err := ssh.NewSignerFromSigner(key)","+\tif err != nil {","+\t\treturn nil, trace.Wrap(err)","+\t}","+\treturn &vnetv1.ExchangeSSHKeysResponse{","+\t\tUserPublicKey: signer.PublicKey().Marshal(),","+\t}, nil","+}","+","+var _ vnetv1.ClientApplicationServiceClient = (*embeddedApplicationServiceClient)(nil)"],"additions":306,"deletions":0,"truncated":false},{"path":"lib/vnet/embedded_test.go","lines":["@@ -0,0 +1,148 @@","+// Teleport","+// Copyright (C) 2026 Gravitational, Inc.","+//","+// This program is free software: you can redistribute it and/or modify","+// it under the terms of the GNU Affero General Public License as published by","+// the Free Software Foundation, either version 3 of the License, or","+// (at your option) any later version.","+//","+// This program is distributed in the hope that it will be useful,","+// but WITHOUT ANY WARRANTY; without even the implied warranty of"],"additions":10,"deletions":0,"truncated":false}],"additions":503,"deletions":155,"truncated":true,"file_count":14},"error":null,"fetched_at":"2026-05-20T17:48:12.808328+00:00"}