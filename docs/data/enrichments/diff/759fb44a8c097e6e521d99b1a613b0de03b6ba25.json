h complex namespace\",","+\t\t\tpath:     \"/k8s/clusters/c-m-abc123/api/v1/namespaces/cattle-system/pods/rancher-xyz/exec\",","+\t\t\texpected: true,","+\t\t},","+","+\t\t{","+\t\t\tname:     \"remote cluster pod exec with steve version\",","+\t\t\tpath:     \"/k8s/clusters/c-m-abc123/v1/api/v1/namespaces/default/pods/nginx/exec\",","+\t\t\texpected: true,","+\t\t},","+\t\t{","+\t\t\tname:     \"remote cluster pod exec with steve version and complex namespace\",","+\t\t\tpath:     \"/k8s/clusters/c-m-abc123/v1/api/v1/namespaces/cattle-system/pods/rancher-xyz/exec\",","+\t\t\texpected: true,","+\t\t},","+","+\t\t// Invalid requests - different subresources","+\t\t{","+\t\t\tname:     \"pod logs request\",","+\t\t\tpath:     \"/api/v1/namespaces/default/pods/nginx/log\",","+\t\t\texpected: false,","+\t\t},","+\t\t{","+\t\t\tname:     \"pod attach request\",","+\t\t\tpath:     \"/api/v1/namespaces/default/pods/nginx/attach\",","+\t\t\texpected: false,","+\t\t},","+\t\t{","+\t\t\tname:     \"pod portforward request\",","+\t\t\tpath:     \"/api/v1/namespaces/default/pods/nginx/portforward\",","+\t\t\texpected: false,","+\t\t},","+\t\t{","+\t\t\tname:     \"get pod request\",","+\t\t\tpath:     \"/api/v1/namespaces/default/pods/nginx\",","+\t\t\texpected: false,","+\t\t},","+\t\t{","+\t\t\tname:     \"list pods request\",","+\t\t\tpath:     \"/api/v1/namespaces/default/pods\",","+\t\t\texpected: false,","+\t\t},","+","+\t\t// Edge cases that expose over-zealous matching","+\t\t{","+\t\t\tname:     \"wrong order - pods before namespaces\",","+\t\t\tpath:     \"/api/v1/pods/nginx/namespaces/default/exec\",","+\t\t\texpected: false, // Should be false - segment order does not match the pod exec pattern","+\t\t},","+\t\t{","+\t\t\tname:     \"exec in middle of path, not at end\",","+\t\t\tpath:     \"/api/v1/namespaces/default/exec/pods/nginx/status\",","+\t\t\texpected: false, // Should be false since exec is not the suffix","+\t\t},","+\t\t{","+\t\t\tname:     \"exec as part of pod name\",","+\t\t\tpath:     \"/api/v1/namespaces/default/pods/my-executor-pod\",","+\t\t\texpected: false, // Should be false - exec is in pod name, not subresource","+\t\t},","+\t\t{","+\t\t\tname:     \"exec as part of namespace name\",","+\t\t\tpath:     \"/api/v1/namespaces/exec-namespace/pods/nginx/logs\",","+\t\t\texpected: false, // Should be false - exec in namespace name","+\t\t},","+\t\t{","+\t\t\tname:     \"namespaces and pods in query string or fragment\",","+\t\t\tpath:     \"/some/other/path/exec?namespaces=foo&pods=bar\",","+\t\t\texpected: false, // Should be false - keywords in query params","+\t\t},","+\t\t{","+\t\t\tname:     \"deployment exec (not a real k8s API)\",","+\t\t\tpath:     \"/api/v1/namespaces/default/deployments/nginx/exec\",","+\t\t\texpected: false, // Should be false - not a pod resource","+\t\t},","+\t\t{","+\t\t\tname:     \"exec endpoint but missing namespaces\",","+\t\t\tpath:     \"/api/v1/pods/nginx/exec\",","+\t\t\texpected: false,","+\t\t},","+\t\t{","+\t\t\tname:     \"exec endpoint but missing pods\",","+\t\t\tpath:     \"/api/v1/namespaces/default/exec\",","+\t\t\texpected: false,","+\t\t},","+","+\t\t// Malicious/crafted paths that might bypass checks","+\t\t{","+\t\t\tname:     \"path with embedded keywords in unrelated context\",","+\t\t\tpath:     \"/custom/namespaces/api/something/pods/data/exec\",","+\t\t\texpected: false, // Not a valid k8s API path","+\t\t},","+\t\t{","+\t\t\tname:     \"double slashes\",","+\t\t\tpath:     \"/api/v1/namespaces//default//pods//nginx//exec\",","+\t\t\texpected: false,","+\t\t\t// stdlib http.Mux will automatically normalize paths, so double slashes are not a concern","+\t\t\t// Test case left here for completeness of unit-testing the func","+\t\t},","+","+\t\t// Empty and nil cases","+\t\t{","+\t\t\tname:     \"empty path\",","+\t\t\tpath:     \"\",","+\t\t\texpected: false,","+\t\t},","+\t\t{","+\t\t\tname:     \"root path\",","+\t\t\tpath:     \"/\",","+\t\t\texpected