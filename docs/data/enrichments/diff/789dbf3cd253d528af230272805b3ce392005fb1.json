equest request, HttpServletResponse response)\r","+        throws IOException {\r","+        String logicalPath = name.substring(WEBJARS_REQUEST_PREFIX.length());\r","+        Optional<String> resource = webJarUrlProvider.resolveResourcePath(logicalPath);\r","+        if (resource.isEmpty()) {\r","+            return false;\r","+        }\r","+        URL resourceUrl = findResource(resource.get());\r","+        if (resourceUrl == null) {\r","+            return false;\r","+        }\r","+        process(resourceUrl.openStream(), path, request, response);\r","+        return true;\r","+    }\r","+\r","+    protected void sendNotFound(HttpServletResponse response) {\r","         try {\r","             response.sendError(HttpServletResponse.SC_NOT_FOUND);\r","         } catch (IOException e1) {\r","@@ -321,32 +367,43 @@ protected String buildPath(String name, String packagePrefix) throws Unsupported","     }\r"," \r"," \r","+    /**\r","+     * Maps a lower-case file extension to its content type. Not using the code provided by\r","+     * activation.jar to avoid adding yet another dependency; this covers the files we serve up\r","+     * (Struts' own static assets plus WebJar assets).\r","+     */\r","+    private static final Map<String, String> CONTENT_TYPES = Map.ofEntries(\r","+        Map.entry(\"js\", \"text/javascript\"),\r","+        Map.entry(\"mjs\", \"text/javascript\"),\r","+        Map.entry(\"css\", \"text/css\"),\r","+        Map.entry(\"html\", \"text/html\"),\r","+        Map.entry(\"txt\", \"text/plain\"),\r","+        Map.entry(\"gif\", \"image/gif\"),\r","+        Map.entry(\"jpg\", \"image/jpeg\"),\r","+        Map.entry(\"jpeg\", \"image/jpeg\"),\r","+        Map.entry(\"png\", \"image/png\"),\r","+        Map.entry(\"svg\", \"image/svg+xml\"),\r","+        Map.entry(\"ico\", \"image/x-icon\"),\r","+        Map.entry(\"woff2\", \"font/woff2\"),\r","+        Map.entry(\"woff\", \"font/woff\"),\r","+        Map.entry(\"ttf\", \"font/ttf\"),\r","+        Map.entry(\"otf\", \"font/otf\"),\r","+        Map.entry(\"eot\", \"application/vnd.ms-fontobject\"),\r","+        Map.entry(\"json\", \"application/json\"),\r","+        Map.entry(\"map\", \"application/json\"));\r","+\r","     /**\r","      * Determine the content type for the resource name.\r","      *\r","      * @param name The resource name\r","-     * @return The mime type\r","+     * @return The mime type, or {@code null} if the extension is unknown\r","      */\r","     protected String getContentType(String name) {\r","-        // NOT using the code provided activation.jar to avoid adding yet another dependency\r","-        // this is generally OK, since these are the main files we server up\r","-        if (name.endsWith(\".js\")) {\r","-            return \"text/javascript\";\r","-        } else if (name.endsWith(\".css\")) {\r","-            return \"text/css\";\r","-        } else if (name.endsWith(\".html\")) {\r","-            return \"text/html\";\r","-        } else if (name.endsWith(\".txt\")) {\r","-            return \"text/plain\";\r","-        } else if (name.endsWith(\".gif\")) {\r","-            return \"image/gif\";\r","-        } else if (name.endsWith(\".jpg\") || name.endsWith(\".jpeg\")) {\r","-            return \"image/jpeg\";\r","-        } else if (name.endsWith(\".png\")) {\r","-            return \"image/png\";\r","-        } else {\r","+        int dot = name.lastIndexOf('.');\r","+        if (dot < 0) {\r","             return null;\r","         }\r","+        return CONTENT_TYPES.get(name.substring(dot + 1));\r","     }\r"," \r","     /**\r"],"additions":75,"deletions":18,"truncated":false},{"path":"core/src/main/java/org/apache/struts2/views/freemarker/tags/StrutsModels.java","lines":["@@ -53,6 +53,7 @@ public class StrutsModels {","     protected RadioModel radio;","     protected SelectModel select;","     protected SetModel set;","+    protected WebJarModel webjar;","     protected SubmitModel submit;","     protected