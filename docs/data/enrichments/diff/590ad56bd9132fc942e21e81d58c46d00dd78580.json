+\tdelete(s, item)","+}","+","+// Has returns true if the set contains the item.","+func (s Set[T]) Has(item T) bool {","+\t_, exists := s[item]","+\treturn exists","+}","+","+// List returns the items in the set as a slice.","+// The order of the items is not guaranteed to be stable.","+func (s Set[T]) List() []T {","+\tkeys := make([]T, 0, len(s))","+\tfor k := range s {","+\t\tkeys = append(keys, k)","+\t}","+\treturn keys","+}","+","+// Sorted returns the items in the set as a sorted slice.","+func Sorted[T cmp.Ordered](s Set[T]) []T {","+\tl := s.List()","+\tslices.Sort(l)","+\treturn l","+}"],"additions":80,"deletions":0,"truncated":false},{"path":"internal/sets/set_test.go","lines":["@@ -0,0 +1,379 @@","+/*","+Copyright 2026 The Kubernetes Authors.","+","+Licensed under the Apache License, Version 2.0 (the \"License\");","+you may not use this file except in compliance with the License.","+You may obtain a copy of the License at","+","+\thttp://www.apache.org/licenses/LICENSE-2.0","+","+Unless required by applicable law or agreed to in writing, software","+distributed under the License is distributed on an \"AS IS\" BASIS,","+WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.","+See the License for the specific language governing permissions and","+limitations under the License.","+*/","+","+package sets_test","+","+import (","+\t\"testing\"","+","+\t\"github.com/stretchr/testify/assert\"","+","+\t\"sigs.k8s.io/external-dns/internal/sets\"","+)","+","+func TestNew(t *testing.T) {","+\ttests := []struct {","+\t\tname  string","+\t\titems []int","+\t\twant  sets.Set[int]","+\t}{","+\t\t{","+\t\t\tname:  \"empty\",","+\t\t\titems: []int{},","+\t\t\twant:  sets.New[int](),","+\t\t},","+\t\t{","+\t\t\tname:  \"single item\",","+\t\t\titems: []int{1},","+\t\t\twant:  sets.New(1),","+\t\t},","+\t\t{","+\t\t\tname:  \"multiple items with duplicates\",","+\t\t\titems: []int{1, 2, 3, 2, 1},","+\t\t\twant:  sets.New(1, 2, 3),","+\t\t},","+\t}","+\t