e]","+\tpublic function getDisplayName(IFactory $l10nFactory): string {","+\t\treturn $l10nFactory->get(Application::APP_ID)->t('Show files in grid view');","+\t}","+","+\t#[\\Override]","+\tpublic function getHint(IFactory $l10nFactory): ?string {","+\t\treturn null;","+\t}","+","+\t#[\\Override]","+\tpublic function getPriority(): int {","+\t\treturn 30;","+\t}","+","+\t#[\\Override]","+\tpublic function isAdvanced(): bool {","+\t\treturn true;","+\t}","+","+\t#[\\Override]","+\tpublic function isRequired(): bool {","+\t\treturn false;","+\t}","+","+\t#[\\Override]","+\tpublic function getDefaultValue(): string {","+\t\treturn 'false';","+\t}","+}"],"additions":46,"deletions":0,"truncated":false},{"path":"apps/files/lib/Sharing/Source/NodeShareSourceType.php","lines":["@@ -0,0 +1,101 @@","+<?php","+","+/**","+ * SPDX-FileCopyrightText: 2025 Nextcloud GmbH and Nextcloud contributors","+ * SPDX-License-Identifier: AGPL-3.0-or-later","+ */","+","+declare(strict_types=1);","+","+namespace OCA\\Files\\Sharing\\Source;","+","+use Exception;","+use OCA\\Files\\AppInfo\\Application;","+use OCA\\Files_Trashbin\\Events\\MoveToTrashEvent;","+use OCP\\EventDispatcher\\Event;","+use OCP\\EventDispatcher\\IEventDispatcher;","+use OCP\\EventDispatcher\\IEventListener;","+use OCP\\Files\\Events\\Node\\NodeDeletedEvent;","+use OCP\\Files\\IRootFolder;","+use OCP\\Files\\Node;","+use OCP\\IDBConnection;","+use OCP\\Interaction\\InteractionResource;","+use OCP\\Interaction\\Resources\\NodeResource;","+use OCP\\IURLGenerator;","+use OCP\\L10N\\IFactory;","+use OCP\\Server;","+use OCP\\Sharing\\Icon\\ShareIconURL;","+use OCP\\Sharing\\ISharingManager;","+use OCP\\Sharing\\ShareAccessContext;","+use OCP\\Sharing\\Source\\IShareSourceType;","+use OCP\\Sharing\\Source\\ShareSource;","+","+/**","+ * @template-implements IEventListener<NodeDeletedEvent|MoveToTrashEvent>","+ */","+final class NodeShareSourceType implements IShareSourceType, IEventListener {","+\tprivate ?IRootFolder $rootFolder = null;","+","+\tprivate ?IURLGenerator $urlGenerator = null;","+","+\tpublic function __construct(","+\t\tIEventDispatcher $eventDispatcher,","+\t\tprivate readonly IDBConnection $dbConnection,","+\t\tprivate readonly ISharingManager $manager,","+\t) {","+\t\t$eventDispatcher->addServiceListener(NodeDeletedEvent::class, self::class);","+\t\t$eventDispatcher->addServiceListener(MoveToTrashEvent::class, self::class);","+\t}","+","+\tprivate function getRootFolder(): IRootFolder {","+\t\treturn $this->rootFolder ??= Server::get(IRootFolder::class);","+\t}","+","+\tprivate function getUrlGenerator(): IURLGenerator {","+\t\treturn $this->urlGenerator ??= Server::get(IURLGenerator::class);","+\t}","+","+\t#[\\Override]","+\tpublic function getDisplayName(IFactory $l10nFactory): string {","+\t\treturn $l10nFactory->get(Application::APP_ID)->t('File');","+\t}","+","+\t#[\\Override]","+\tpublic function validateSource(string $source): bool {","+\t\treturn $this->getRootFolder()->getFirstNodeById((int)$source) instanceof Node;","+\t}","+","+\t#[\\Override]","+\tpublic function getSourceDisplayName(string $source): ?string {","+\t\t$displayName = $this->getRootFolder()->getFirstNodeById((int)$source)?->getName();","+\t\tif ($displayName === '') {","+\t\t\treturn null;","+\t\t}","+","+\t\treturn $displayName;","+\t}","+","+\t#[\\Override]","+\tpublic function getSourceIcon(string $source): ShareIconURL {","+\t\t$url = $this->getUrlGenerator()->linkToRouteAbsolute('core.Preview.getPreviewByFileId', ['fileId' => $source, 'x' => 64, 'y' => 64]);","+","+\t\treturn new ShareIconURL($url, $url);","+\t}","+","+\t#[\\Override]","+\tpublic function getSourceInteractionResource(string $userId, string $source): InteractionResource {","+\t\treturn new NodeResource((int)$source, $userId);","+\t}","+","+\t#[\\Override]","+\tpublic function handle(Event $event): void {","+\t\ttry {","+\t\t\t$this->dbConnection->beginTransaction();","+\t\t\t$this->manager->onSourceDeleted(new ShareAccess