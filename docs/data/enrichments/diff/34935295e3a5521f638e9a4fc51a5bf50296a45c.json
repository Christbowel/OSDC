ther the module path and the RelSubject to form","+\t\t// the absolute address of the config resource being removed.","+\t\tres := mi.ToResource","+\t\ttoAddr := addrs.ConfigResource{","+\t\t\tModule:   append(cfg.Path, res.Module...),","+\t\t\tResource: res.Resource,","+\t\t}","+","+\t\t// If we already have an import statement for this ConfigResource, it","+\t\t// must have come from a parent module, because duplicate import","+\t\t// blocks in the same module result in an error.","+\t\t// The import block in the parent module overrides the block in the","+\t\t// child module.","+\t\texistingResource, ok := into.GetOk(toAddr)","+\t\tif ok {","+\t\t\tif existingResource.AbsToResource.Equal(toAddr) {","+\t\t\t\tcontinue","+\t\t\t}","+\t\t}","+","+\t\tinto.Put(toAddr, ImportStatement{","+\t\t\tAbsToResource:    toAddr,","+\t\t\tContainingModule: cfg.Path,","+\t\t\tImport:           mi,","+\t\t})","+\t}","+","+\tfor _, childCfg := range cfg.Children {","+\t\tinto = findImportStatements(childCfg, into)","+\t}","+","+\treturn into","+}"],"additions":63,"deletions":0,"truncated":false},{"path":"internal/terraform/context_apply_import_test.go","lines":["@@ -0,0 +1,202 @@","+// Copyright IBM Corp. 2014, 2026","+// SPDX-License-Identifier: BUSL-1.1","+","+package terraform","+","+import (","+\t\"encoding/json\"","+\t\"testing\"","+","+\t\"github.com/zclconf/go-cty/cty\"","+","+\t\"github.com/hashicorp/terraform/internal/addrs\"","+\t\"github.com/hashicorp/terraform/internal/configs/configschema\"","+\t\"github.com/hashicorp/terraform/internal/plans\"","+\t\"github.com/hashicorp/terraform/internal/providers\"","+\t\"github.com/hashicorp/terraform/internal/states\"","+\t\"github.com/hashicorp/terraform/internal/tfdiags\"","+)","+","+// other import tests can be found in context_apply2_test.go","+func TestContextApply_import_in_module(t *testing.T) {","+\tm := testModule(t, \"import-block-in-module\")","+","+\tp := mockProviderWithResourceTypeSchema(\"test_object\", &configschema.Block{","+\t\tAttributes: map[string]*configschema.Attribute{","+\t\t\t\"id\":          {Type: cty.String, Computed: true},","+\t\t\t\"test_string\": {Type: cty.String, Optional: true},","+\t\t},","+\t})","+\tp.ImportResourceStateFn = func(req providers.ImportResourceStateRequest) providers.ImportResourceStateResponse {","+\t\treturn providers.ImportResourceStateResponse{","+\t\t\tImportedResources: []providers.ImportedResource{","+\t\t\t\t{","+\t\t\t\t\tTypeName: \"test_object\",","+\t\t\t\t\tState: cty.ObjectVal(map[string]cty.Value{","+\t\t\t\t\t\t\"test_string\": cty.StringVal(\"importable\"),","+\t\t\t\t\t\t\"id\":          cty.StringVal(req.ID),","+\t\t\t\t\t}),","+\t\t\t\t},","+\t\t\t},","+\t\t}","+\t}","+\tp.ReadResourceFn = func(r providers.ReadResourceRequest) providers.ReadResourceResponse {","+\t\tid := r.PriorState.GetAttr(\"id\")","+\t\treturn providers.ReadResourceResponse{","+\t\t\tNewState: cty.ObjectVal(map[string]cty.Value{","+\t\t\t\t\"test_string\": cty.StringVal(\"importable\"),","+\t\t\t\t\"id\":          id,","+\t\t\t}),","+\t\t}","+\t}","+","+\tctx := testContext2(t, &ContextOpts{","+\t\tProviders: map[addrs.Provider]providers.Factory{","+\t\t\taddrs.NewDefaultProvider(\"test\"): testProviderFuncFixed(p),","+\t\t},","+\t})","+","+\tdiags := ctx.Validate(m, nil)","+\ttfdiags.AssertNoErrors(t, diags)","+","+\tplan, diags := ctx.Plan(m, states.NewState(), &PlanOpts{","+\t\tMode: plans.NormalMode,","+\t})","+\ttfdiags.AssertNoErrors(t, diags)","+","+\tstate, diags := ctx.Apply(plan, m, nil)","+\ttfdiags.AssertNoErrors(t, diags)","+","+\tif !p.ImportResourceStateCalled {","+\t\tt.Fatal(\"resource not imported\")","+\t}","+","+\trs := state.ResourceInstance(mustResourceInstanceAddr(\"module.child.test_object.bar[\\\"first\\\"]\"))","+\tif rs == nil {","+\t\tt.Fatal(\"imported resource not found in module\")","+\t}","+\tvar attrs map[string]interface{}","+\terr := json.Unmarshal(rs.Current.AttrsJSON, &attrs)","+\tif err != nil {","+\t\tt.Fatal(err)","+\t}","+\tif got, want := attrs[\"id\"], \"testa\"; got != want {","+\t\tt.Fatalf(\"wrong id for \\\"first\\\" got:  %#v\\nwant: %#v\", got, want)","+\t}","+","+\trs = state.ResourceInstance(mustResourceInstanceAddr(\"module.child.test_object.bar[\\\"second\\\"]\"))","+\tif rs == nil {","+\t\tt.Fatal(\"imported resource not found in module\")","+\t}","+\terr = json.Unmarshal(rs.Current.AttrsJSON, &attrs)","+\tif err != nil {","+\t\tt.Fatal(err)","+\t}","+\tif got, want := attrs[\"id\"], \"testb\"; got != want {","+\t\tt.Fatalf(\"wrong id for \\\"second\\\" got:  %#v\\nwant: %#v\", got, want)","+\t}","+}","+","+func TestContextApply_import_in_nested_module(t *testing.T) { // more nested than the test above. nesteder.","+\tm := testModule(t, \"import-block-in-nested-module\")","+","+\tp := simpleMockProvider()","+\tp.ImportResourceStateResponse = &providers.ImportResourceStateResponse{","+\t\tImportedResources: []providers.ImportedResource{","+\t\t\t{","+\t\t\t\tTypeName: \"test_object\",","+\t\t\t\tState: cty.ObjectVal(map[string]cty.Value{","+\t\t\t\t\t\"test_string\": cty.StringVal(\"importable\"),","+\t\t\t\t}),","+\t\t\t},","+\t\t},","+\t}","+\tp.ReadResourceResponse = &providers.ReadResourceResponse{","+\t\tNewState: cty.ObjectVal(map[string]cty.Value{","+\t\t\t\"test_string\": cty.StringVal(\"importable\"),","+\t\t}),","+\t}","+","+\tctx := testContext2(t, &ContextOpts{","+\t\tProviders: map[addrs.Provider]providers.Factory{","+\t\t\taddrs.NewDefaultProvider(\"test\"): testProviderFuncFixed(p),","+\t\t},","+\t})","+","+\tdiags := ctx.Validate(m, nil)","+\ttfdiags.AssertNoErrors(t, diags)","+","+\tplan, diags := ctx.Plan(m, states.NewState(), &PlanOpts{","+\t\tMode: plans.NormalMode,","+\t})","+\ttfdiags.AssertNoErrors(t, diags)","+","+\tstate, diags := ctx.Apply(plan, m, nil)","+\ttfdiags.AssertNoErrors(t, diags)","+","+\trs := state.ResourceInstance(mustResourceInstanceAddr(\"module.child.module.kinder.test_object.bar\"))","+\tif rs == nil {","+\t\tt.Fatal(\"imported resource not found in module\")","+\t}","+","+\tif !p.ImportResourceStateCalled {","+\t\tt.Fatal(\"resources not imported\")","+\t}","+}","+","+func TestContextApply_import_in_expanded_module(t *testing.T) { // count AND for each!","+\tm := testModule(t, \"import-block-in-module-with-expansion\")","+","+\tp := simpleMockProvider()","+\tp.ImportResourceStateResponse = &providers.ImportResourceStateResponse{","+\t\tImportedResources: []providers.ImportedResource{","+\t\t\t{","+\t\t\t\tTypeName: \"test_object\",","+\t\t\t\tState: cty.ObjectVal(map[string]cty.Value{","+\t\t\t\t\t\"test_string\": cty.StringVal(\"importable\"),","+\t\t\t\t}),","+\t\t\t},","+\t\t},","+\t}","+\tp.ReadResourceResponse = &providers.ReadResourceResponse{","+\t\tNewState: cty.ObjectVal(map[string]cty.Value{","+\t\t\t\"test_string\": cty.StringVal(\"importable\"),","+\t\t}),","+\t}","+","+\tctx := testContext2(t, &ContextOpts{","+\t\tProviders: map[addrs.Provider]providers.Factory{","+\t\t\taddrs.NewDefaultProvider(\"test\"): testProviderFuncFixed(p),","+\t\t},","+\t})","+","+\tdiags := ctx.Validate(m, nil)","+\ttfdiags.AssertNoErrors(t, diags)","+","+\tplan, diags := ctx.Plan(m, states.NewState(), &PlanOpts{","+\t\tMode: plans.NormalMode,","+\t})","+\ttfdiags.AssertNoErrors(t, diags)","+","+\tstate, diags := ctx.Apply(plan, m, nil)","+\ttfdiags.AssertNoErrors(t, diags)","+","+\trs := state.ResourceInstance(mustResourceInstanceAddr(\"module.count_child[0].test_object.foo\"))","+\tif rs == nil {","+\t\tt.Fatal(\"imported resource not found in module\")","+\t}","+","+\trs = state.ResourceInstance(mustResourceInstanceAddr(\"module.count_child[1].test_object.foo\"))","+\tif rs == nil {","+\t\tt.Fatal(\"imported resource not found in module\")","+\t}","+","+\trs = state.ResourceInstance(mustResourceInstanceAddr(\"module.for_each_child[\\\"a\\\"].test_object.foo\"))","+\tif rs == nil {","+\t\tt.Fatal(\"imported resource not found in module\")","+\t}","+","+\tif !p.ImportResourceStateCal