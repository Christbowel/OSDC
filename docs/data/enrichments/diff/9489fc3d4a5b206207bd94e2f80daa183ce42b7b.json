ttp\"","+\t\"net/url\"","+\t\"strings\"","+\t\"time\"","+","+\t\"github.com/casdoor/casdoor/util\"","+\t\"github.com/golang-jwt/jwt/v5\"","+)","+","+// LogoutTokenClaims represents the claims in an OIDC Back-Channel Logout token.","+// See https://openid.net/specs/openid-connect-backchannel-1_0.html","+type LogoutTokenClaims struct {","+\tEvents map[string]interface{} `json:\"events\"`","+\tjwt.RegisteredClaims","+}","+","+func generateLogoutToken(application *Application, user *User, sessionId string, host string) (string, error) {","+\tnowTime := time.Now()","+\t_, originBackend := getOriginFromHost(host)","+","+\tevents := map[string]interface{}{","+\t\t\"http://schemas.openid.net/event/backchannel-logout\": map[string]interface{}{},","+\t}","+","+\tclaims := LogoutTokenClaims{","+\t\tEvents: events,","+\t\tRegisteredClaims: jwt.RegisteredClaims{","+\t\t\tIssuer:   originBackend,","+\t\t\tSubject:  user.Id,","+\t\t\tAudience: []string{application.ClientId},","+\t\t\tIssuedAt: jwt.NewNumericDate(nowTime),","+\t\t\tID:       util.GetId(application.Owner, util.GenerateId()),","+\t\t},","+\t}","+","+\tif sessionId != \"\" {","+\t\t// sid claim carries the session ID per the spec","+\t\tclaims.RegisteredClaims.ID = sessionId","+\t}","+","+\tcert, err := getCertByApplication(application)","+\tif err != nil {","+\t\treturn \"\", err","+\t}","+\tif cert == nil {","+\t\treturn \"\", fmt.Errorf(\"no cert found for application: %s\", application.GetId())","+\t}","+","+\tvar (","+\t\ttoken *jwt.Token","+\t\tkey   interface{}","+\t)","+","+\tsigningMethod := application.TokenSigningMethod","+\tif strings.Contains(signingMethod, \"ES\") {","+\t\ttoken = jwt.NewWithClaims(jwt.SigningMethodES256, claims)","+\t\tkey, err = jwt.ParseECPrivateKeyFromPEM([]byte(cert.PrivateKey))","+\t} else {","+\t\ttoken = jwt.NewWithClaims(jwt.SigningMethodRS256, claims)","+\t\tkey, err = jwt.ParseRSAPrivateKeyFromPEM([]byte(cert.PrivateKey))","+\t}","+\tif err != nil {","+\t\treturn \"\", err","+\t}","+","+\ttoken.Header[\"kid\"] = cert.Name","+\treturn token.SignedString(key)","+}","+","+// SendBackchannelLogout sends OIDC Back-Channel Logout tokens to all registered","+// backchannel_logout_uri endpoints for applications that have active tokens for the user.","+// See https://openid.net/specs/openid-connect-backchannel-1_0.html","+func SendBackchannelLogout(organization, username, sessionId, host string) {","+\ttokens, err := GetActiveTokensByUser(organization, username)","+\tif err != nil || len(tokens) == 0 {","+\t\treturn","+\t}","+","+\t// Deduplicate applications","+\tseen := map[string]bool{}","+\tfor _, token := range tokens {","+\t\tappId := util.GetId(token.Owner, token.Application)","+\t\tif seen[appId] {","+\t\t\tcontinue","+\t\t}","+\t\tseen[appId] = true","+","+\t\tapplication, err := GetApplication(appId)","+\t\tif err != nil || application == nil || application.BackchannelLogoutUri == \"\" {","+\t\t\tcontinue","+\t\t}","+","+\t\tuser, err := GetUser(util.GetId(organization, username))","+\t\tif err != nil || user == nil {","+\t\t\tcontinue","+\t\t}","+","+\t\tlogoutToken, err := generateLogoutToken(application, user, sessionId, host)","+\t\tif err != nil {","+\t\t\tcontinue","+\t\t}","+","+\t\tgo postBackchannelLogout(application.BackchannelLogoutUri, logoutToken)","+\t}","+}","+","+func postBackchannelLogout(logoutUri, logoutToken string) {","+\tbody := url.Values{\"logout_token\": {logoutToken}}","+\tresp, err := http.PostForm(logoutUri, body)","+\tif err != nil {","+\t\treturn","+\t}","+\tdefer resp.Body.Close()","+}"],"additions":132,"deletions":0,"truncated":false},{"path":"object/wellknown_oidc_discovery.go","lines":["@@ -47,6 +47,8 @@ type OidcDiscovery struct {"," \tRequestParameterSupported              bool     `json:\"request_parameter_supported\"`"," \tRequestObjectSigningAlgValuesSupported []string `json:\"request_object_signing_alg_values_supported\"`"," \tEndSessionEndpoint                     string   `json:\"end_session_end