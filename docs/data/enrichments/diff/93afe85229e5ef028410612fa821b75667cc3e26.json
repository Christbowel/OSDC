\treturn new Response(localize('browserSession.untrustedFile', 'Forbidden. File does not reside within a trusted folder.'), { status: 403 });","+\t\t\t}","+\t\t\treturn this.electronSession.fetch(request, { bypassCustomProtocolHandlers: true });","+\t\t});"," \t}"," "," \t/**"],"additions":25,"deletions":1,"truncated":false},{"path":"src/vs/platform/browserView/electron-main/browserViewMainService.ts","lines":["@@ -61,6 +61,12 @@ export class BrowserViewMainService extends Disposable implements IBrowserViewMa"," \t\t@IApplicationStorageMainService private readonly applicationStorageMainService: IApplicationStorageMainService"," \t) {"," \t\tsuper();","+","+\t\tthis._register(this.windowsMainService.onDidDestroyWindow(window => {","+\t\t\tif (this._perWindowTrustedRoots.delete(window.id)) {","+\t\t\t\tthis._recomputeTrustedFileRoots();","+\t\t\t}","+\t\t}));"," \t}"," "," \tasync getOrCreateBrowserView(id: string, options: IBrowserViewCreateOptions): Promise<IBrowserViewState> {","@@ -321,6 +327,22 @@ export class BrowserViewMainService extends Disposable implements IBrowserViewMa"," \t\t}"," \t}"," ","+\tasync updateTrustedFileRoots(windowId: number, roots: readonly string[]): Promise<void> {","+\t\tthis._perWindowTrustedRoots.set(windowId, roots);","+\t\tthis._recomputeTrustedFileRoots();","+\t}","+","+\tprivate readonly _perWindowTrustedRoots = new Map<number, readonly string[]>();","+\tprivate _recomputeTrustedFileRoots(): void {","+\t\tconst roots = new Set<string>();","+\t\tfor (const contribution of this._perWindowTrustedRoots.values()) {","+\t\t\tfor (const root of contribution) {","+\t\t\t\troots.add(root);","+\t\t\t}","+\t\t}","+\t\tBrowserSession.setTrustedFileRoots([...roots]);","+\t}","+"," \tasync updateKeybindings(keybindings: { [commandId: string]: string }): Promise<void> {"," \t\tthis._keybindings = keybindings;"," \t}"],"additions":22,"deletions":0,"truncated":false},{"path":"src/vs/workbench/contrib/browserView/electron-browser/browserViewWorkbenc