{"id":"93afe85229e5ef028410612fa821b75667cc3e26","axis":"silent","repo":"microsoft/vscode","sha":"93afe85229e5ef028410612fa821b75667cc3e26","parsed":{"files":[{"path":"extensions/vscode-api-tests/src/singlefolder-tests/browser.cdp.test.ts","lines":["@@ -177,7 +177,11 @@ const CAPTURED_DOMAINS = ['Browser', 'Target'];"," "," \t// #endregion"," ","-\ttest('CDP debugging golden scenario', async function () {","+\t// Loads `file:///<workspaceFolder>/index.html`. Skipped in remote","+\t// workspaces: the workspace folder is a `vscode-remote://` URI so it","+\t// isn't added to the local `file://` trust allowlist, and the harness","+\t// would be rejected with 403 before the worker is ever attached.","+\t(vscode.env.remoteName ? test.skip : test)('CDP debugging golden scenario', async function () {"," \t\tthis.timeout(30_000);"," "," \t\tconst workspaceRoot = workspace.rootPath!;"],"additions":5,"deletions":1,"truncated":false},{"path":"extensions/vscode-api-tests/src/singlefolder-tests/browser.test.ts","lines":["@@ -4,8 +4,11 @@","  *--------------------------------------------------------------------------------------------*/"," "," import * as assert from 'assert';","+import * as fs from 'fs';","+import * as os from 'os';","+import * as path from 'path';"," import * as vscode from 'vscode';","-import { window, commands, ViewColumn } from 'vscode';","+import { window, commands, ViewColumn, workspace } from 'vscode';"," import { assertNoRpc, closeAllEditors } from '../utils';"," "," (vscode.env.uiKind === vscode.UIKind.Web ? suite.skip : suite)('vscode API - browser', () => {","@@ -214,4 +217,107 @@ import { assertNoRpc, closeAllEditors } from '../utils';"," \t});"," "," \t// #endregion","+","+\t// #region trusted file:// loading","+\t//","+\t// Trust enforcement is exercised by writing a small harness HTML file","+\t// into the (trusted) workspace folder, opening it in a browser tab, and","+\t// letting it `fetch(?url=...)` whatever URL the test targets. The","+\t// harness writes `status:<code>` (or `error:<msg>`) to `document.title`,","+\t// which we observe via `tab.title`. The harness file itself is created","+\t// at test time so it doesn't pollute the shared test workspace.","+\t//","+\t// Skipped in remote workspaces: the test workspace lives on the remote","+\t// machine, so the locally-pushed trust list doesn't include its","+\t// folders and the harness page itself would be blocked.","+","+\t(vscode.env.remoteName ? suite.skip : suite)('trusted file:// loading', () => {","+\t\tconst HARNESS_NAME = 'trust-harness.html';","+\t\tconst HARNESS_CONTENT = `<!DOCTYPE html>","+<html>","+<head><title>idle</title></head>","+<body>","+<script>","+(async function () {","+\t// Use the URL fragment rather than the query string — Chromium's","+\t// built-in \\`file://\\` loader rejects URLs with a \\`?query\\`, but","+\t// fragments are stripped before the file is read.","+\tconst params = new URLSearchParams(location.hash.slice(1));","+\tconst target = params.get('url');","+\tif (!target) {","+\t\tdocument.title = 'no-url';","+\t\treturn;","+\t}","+\ttry {","+\t\tconst res = await fetch(target);","+\t\tdocument.title = 'status:' + res.status;","+\t} catch (err) {","+\t\tdocument.title = 'error:' + (err && err.message || err);","+\t}","+})();","+</script>","+</body>","+</html>`;","+","+\t\tlet harnessUri: vscode.Uri | undefined;","+","+\t\tsuiteSetup(async () => {","+\t\t\tconst folders = workspace.workspaceFolders;","+\t\t\tassert.ok(folders && folders.length > 0, 'expected at least one workspace folder');","+\t\t\tharnessUri = vscode.Uri.joinPath(folders[0].uri, HARNESS_NAME);","+\t\t\tawait fs.promises.writeFile(harnessUri.fsPath, HARNESS_CONTENT);","+\t\t});","+","+\t\tsuiteTeardown(async () => {","+\t\t\tif (harnessUri) {","+\t\t\t\tawait fs.promises.rm(harnessUri.fsPath, { force: true });","+\t\t\t\tharnessUri = undefined;","+\t\t\t}","+\t\t});","+","+\t\tasync function fetchFromTrustedHarness(target: string): Promise<string> {","+\t\t\tassert.ok(harnessUri, 'harness must be initialized');","+\t\t\tconst url = `${harnessUri.toString()}#url=${encodeURIComponent(target)}`;","+\t\t\tconst tab = await window.openBrowserTab(url);","+","+\t\t\t// Poll `tab.title` for the harness's contract (`status:<n>` or","+\t\t\t// `error:<msg>`). The browser tab decorates the title with the","+\t\t\t// page URL, so callers should check by prefix.","+\t\t\tconst deadline = Date.now() + 15_000;","+\t\t\twhile (Date.now() < deadline) {","+\t\t\t\tif (tab.title.startsWith('status:') || tab.title.startsWith('error:')) {","+\t\t\t\t\treturn tab.title;","+\t\t\t\t}","+\t\t\t\tawait new Promise(resolve => setTimeout(resolve, 100));","+\t\t\t}","+\t\t\tthrow new Error(`Timed out waiting for trust-harness title to update (target=${target}, last title=${tab.title})`);","+\t\t}","+","+\t\ttest('file:// inside a trusted workspace folder loads', async function () {","+\t\t\tthis.timeout(30_000);","+","+\t\t\tconst folders = workspace.workspaceFolders!;","+\t\t\tconst trustedTarget = vscode.Uri.joinPath(folders[0].uri, 'index.html').toString();","+","+\t\t\tconst title = await fetchFromTrustedHarness(trustedTarget);","+\t\t\tassert.ok(title.startsWith('status:200'), `Expected status 200 for trusted file, got: ${title}`);","+\t\t});","+","+\t\ttest('file:// outside any trusted root is blocked with 403', async function () {","+\t\t\tthis.timeout(30_000);","+","+\t\t\tconst tempDir = await fs.promises.mkdtemp(path.join(os.tmpdir(), 'vscode-browser-trust-'));","+\t\t\tconst untrustedFile = path.join(tempDir, 'untrusted.html');","+\t\t\tawait fs.promises.writeFile(untrustedFile, '<!doctype html><body>should not be reachable</body>');","+","+\t\t\ttry {","+\t\t\t\tconst title = await fetchFromTrustedHarness(vscode.Uri.file(untrustedFile).toString());","+\t\t\t\tassert.ok(title.startsWith('status:403'), `Expected status 403 for untrusted file, got: ${title}`);","+\t\t\t} finally {","+\t\t\t\tawait fs.promises.rm(tempDir, { recursive: true, force: true });","+\t\t\t}","+\t\t});","+\t});","+","+\t// #endregion"," });"],"additions":107,"deletions":1,"truncated":false},{"path":"extensions/vscode-api-tests/src/singlefolder-tests/browser.tools.test.ts","lines":["@@ -98,7 +98,10 @@ function extractTextContent(result: vscode.LanguageModelToolResult): string {"," \t\tassert.match(output, /Page ID:/, `Expected output to contain \"Page ID:\", got: ${output}`);"," \t});"," ","-\ttest('basic browser tool interactions', async function () {","+\t// Loads `file:///<workspaceFolder>/index.html`. Skipped in remote","+\t// workspaces: the workspace folder is a `vscode-remote://` URI so it","+\t// isn't added to the local `file://` trust allowlist.","+\t(vscode.env.remoteName ? test.skip : test)('basic browser tool interactions', async function () {"," \t\tthis.timeout(60000);"," "," \t\t// Build a file:// URL to the test workspace's index.html"],"additions":4,"deletions":1,"truncated":false},{"path":"src/vs/platform/browserView/common/browserView.ts","lines":["@@ -558,4 +558,17 @@ export interface IBrowserViewService {"," \t * @param config The configuration to apply"," \t */"," \tupdateConfiguration(config: IBrowserViewConfiguration): Promise<void>;","+","+\t/**","+\t * Replace the calling window's contribution to the `file://` allowlist","+\t * used by integrated browser sessions. Main unions every window's","+\t * contribution into a process-wide allowlist; entries are dropped when","+\t * the window is destroyed.","+\t *","+\t * @param windowId The calling window's `vscodeWindowId`.","+\t * @param roots Normalized filesystem paths the window deems trusted —","+\t * usually `getTrustedUris()` plus, when the workspace itself is trusted,","+\t * its workspace folder paths.","+\t */","+\tupdateTrustedFileRoots(windowId: number, roots: readonly string[]): Promise<void>;"," }"],"additions":13,"deletions":0,"truncated":false},{"path":"src/vs/platform/browserView/electron-main/browserSession.ts","lines":["@@ -4,12