{"id":"ce0129a1f77baa71ae5190ff44dba190ac954611","axis":"silent","repo":"WordPress/gutenberg","sha":"ce0129a1f77baa71ae5190ff44dba190ac954611","parsed":{"files":[{"path":"lib/experimental/knowledge/knowledge.php","lines":["@@ -9,13 +9,6 @@"," \texit;"," }"," ","-/**","- * Maximum length, in characters, of a guideline row's content.","- */","-if ( ! defined( 'GUTENBERG_GUIDELINE_MAX_LENGTH' ) ) {","-\tdefine( 'GUTENBERG_GUIDELINE_MAX_LENGTH', 5000 );","-}","-"," if ( ! function_exists( 'wp_knowledge_types' ) ) {"," \t/**"," \t * Returns the registered knowledge types keyed by slug.","@@ -76,6 +69,11 @@ function wp_knowledge_types(): array {"," \t * automatically. The registry carries identity and presentation only; rows"," \t * are created on first save."," \t *","+\t * The `blocks` scope is the one exception: it has no single `guideline-blocks`","+\t * row. Its section lists per-block guidelines stored as `guideline-block-*`","+\t * rows. Removing it from this registry (via the filter) hides that section on","+\t * the Settings page.","+\t *"," \t * @return array {"," \t *     Slug-keyed map of guideline scopes."," \t *","@@ -113,6 +111,11 @@ function wp_guideline_scopes(): array {"," \t\t\t\t\t'description' => __( 'Outline your style, dimensions, formats, mood and aesthetic preferences.', 'gutenberg' ),"," \t\t\t\t\t'order'       => 30,"," \t\t\t\t),","+\t\t\t\t'blocks'     => array(","+\t\t\t\t\t'title'       => __( 'Blocks', 'gutenberg' ),","+\t\t\t\t\t'description' => __( 'Create tailored guidelines for specific block types.', 'gutenberg' ),","+\t\t\t\t\t'order'       => 40,","+\t\t\t\t),"," \t\t\t\t'additional' => array("," \t\t\t\t\t'title'       => __( 'Additional', 'gutenberg' ),"," \t\t\t\t\t'description' => __( 'Add additional guidelines.', 'gutenberg' ),","@@ -123,6 +126,22 @@ function wp_guideline_scopes(): array {"," \t}"," }"," ","+if ( ! function_exists( 'wp_guideline_max_length' ) ) {","+\t/**","+\t * Returns the maximum length, in characters, of a guideline row's content.","+\t *","+\t * @return int Maximum number of characters allowed in guideline content.","+\t */","+\tfunction wp_guideline_max_length(): int {","+\t\t/**","+\t\t * Filters the maximum length, in characters, of a guideline row's content.","+\t\t *","+\t\t * @param int $max_length Maximum number of characters. Default 5000.","+\t\t */","+\t\treturn (int) apply_filters( 'wp_guideline_max_length', 5000 );","+\t}","+}","+"," if ( ! function_exists( 'wp_knowledge_get_or_create_type_term' ) ) {"," \t/**"," \t * Resolve a `wp_knowledge_type` term by slug, creating it lazily.","@@ -325,26 +344,43 @@ function wp_knowledge_maybe_map_term_label( array $data, string $taxonomy ): arr"," "," if ( ! function_exists( 'wp_guideline_scope_from_slug' ) ) {"," \t/**","-\t * Resolve a registry scope key from a guideline row slug.","+\t * Resolve the scope that owns a guideline row slug."," \t *","-\t * Returns the scope key for `guideline-{scope}` slugs that match a","-\t * registered scope, or null for block rows (`guideline-block-*`) and","-\t * unknown scopes.","+\t * Returns the scope key for a `guideline-{scope}` slug that matches a","+\t * registered scope. A registered scope key always wins, so a scope keyed","+\t * like `block-foo` resolves to itself rather than the blocks scope. Any","+\t * other `guideline-block-*` slug is a per-block row that belongs to the","+\t * `blocks` scope while it is registered. Returns null for the bare","+\t * `guideline-block-` slug and for any unknown scope."," \t *"," \t * @access private"," \t *"," \t * @param string $slug Post slug.","-\t * @return string|null Scope key, or null if not a registry scope.","+\t * @return string|null Scope key, or null if the slug is not a registered scope."," \t */"," \tfunction wp_guideline_scope_from_slug( string $slug ): ?string {","-\t\tif ( ! str_starts_with( $slug, 'guideline-' ) || str_starts_with( $slug, 'guideline-block-' ) ) {","+\t\tif ( ! str_starts_with( $slug, 'guideline-' ) ) {"," \t\t\treturn null;"," \t\t}"," ","-\t\t$scope  = substr( $slug, strlen( 'guideline-' ) );"," \t\t$scopes = wp_guideline_scopes();","+\t\t$scope  = substr( $slug, strlen( 'guideline-' ) );","+","+\t\t// A slug that matches a registered scope key is that scope. Checking this","+\t\t// first lets a scope keyed like `block-foo` win over the per-block","+\t\t// namespace below, instead of being swallowed by the blocks scope.","+\t\tif ( isset( $scopes[ $scope ] ) ) {","+\t\t\treturn $scope;","+\t\t}","+","+\t\t// Otherwise a `guideline-block-<name>` row is a per-block row that belongs","+\t\t// to the blocks scope while it is registered. A real block name never","+\t\t// equals a registered scope key, so the check above stays safe.","+\t\tif ( str_starts_with( $slug, 'guideline-block-' ) && strlen( $slug ) > strlen( 'guideline-block-' ) ) {","+\t\t\treturn isset( $scopes['blocks'] ) ? 'blocks' : null;","+\t\t}"," ","-\t\treturn isset( $scopes[ $scope ] ) ? $scope : null;","+\t\treturn null;"," \t}"," }"," ","@@ -353,10 +389,13 @@ function wp_guideline_scope_from_slug( string $slug ): ?string {"," \t * Hook callback for `rest_pre_insert_wp_knowledge` that sanitizes and"," \t * normalizes guideline rows on the REST insert path."," \t *","-\t * For rows whose slug begins with `guideline-`:","+\t * Only rows whose slug maps to a registered guideline scope are shaped (see","+\t * `wp_guideline_scope_from_slug()`); any other row is left untouched. For a","+\t * recognized guideline row this callback:"," \t * - Sanitizes `post_content` to plain text capped at the guideline length.","-\t * - Re-stamps the title of registry scopes from `wp_guideline_scopes()` in","-\t *   the site locale. Block rows keep the client-provided canonical block name.","+\t * - Re-stamps the title of single-row registry scopes from","+\t *   `wp_guideline_scopes()` in the site locale. Per-block rows (the multi-row","+\t *   `blocks` scope) keep the client-provided canonical block name."," \t *"," \t * Slug uniqueness is intentionally left to WordPress: the published row keeps"," \t * its exact slug because the first save has no conflict and later saves reuse","@@ -383,23 +422,26 @@ function wp_knowledge_guard_guideline_row( $prepared_post, $request ) { // phpcs"," \t\t\t}"," \t\t}"," ","-\t\tif ( ! str_starts_with( (string) $slug, 'guideline-' ) ) {","+\t\t// Only shape rows whose slug maps to a registered guideline scope.","+\t\t$scope = wp_guideline_scope_from_slug( (string) $slug );","+\t\tif ( null === $scope ) {"," \t\t\treturn $prepared_post;"," \t\t}"," "," \t\t// Sanitize content: plain text, capped at the guideline length."," \t\tif ( isset( $prepared_post->post_content ) ) {"," \t\t\t$content = sanitize_textarea_field( $prepared_post->post_content );","-\t\t\tif ( mb_strlen( $content, 'UTF-8' ) > GUTENBERG_GUIDELINE_MAX_LENGTH ) {","-\t\t\t\t$content = mb_substr( $content, 0, GUTENBERG_GUIDELINE_MAX_LENGTH, 'UTF-8' );","+\t\t\t$max     = wp_guideline_max_length();","+\t\t\tif ( mb_strlen( $content, 'UTF-8' ) > $max ) {","+\t\t\t\t$content = mb_substr( $content, 0, $max, 'UTF-8' );"," \t\t\t}"," \t\t\t$prepared_post->post_content = $content;"," \t\t}"," ","-\t\t// Re-stamp registry scope titles in the site locale. Block rows keep the","+\t\t// Re-stamp single-row registry scope titles in the site locale. The","+\t\t// blocks scope is multi-row, so its per-block rows keep the"," \t\t// client-provided canonical block name.","-\t\t$scope = wp_guideline_scope_from_slug( $slug );","-\t\tif ( null !== $scope ) {","+\t\tif ( 'blocks' !== $scope ) {"," \t\t\t$switched = switch_to_locale( get_locale() );"," \t\t\t$scopes   = wp_guideline_scopes();"," \t\t\tif ( $switched ) {"],"additions":66,"deletions":24,"truncated":false},{"path":"packages/e2e-tests/plugins/guidelines-scopes-filter.php","lines":["@@ -0,0 +1,29 @@","+<?php","+/**","+ * Plugin Name: Gutenberg Test Guidelines Scopes Filter","+ * Plugin URI: https://github.com/WordPress/gutenberg","+ * Author: Gutenberg Team","+ *","+ * @package gutenberg-test-guidelines-scopes-filter","+ */","+","+/**","+ * Exercises the `wp_guideline_scopes` filter for e2e tests: adds a custom","+ * scope and removes the built-in `blocks` scope. The Settings -> Guidelines","+ * page should grow the custom section and drop the Blocks section.","+ *","+ * @param array $scopes Slug-keyed map of guideline scopes.","+ * @return array Filtered scopes.","+ */","+function gutenberg_test_filter_guideline_scopes( $scopes ) {","+\tunset( $scopes['blocks'] );","+","+\t$scopes['e2e-custom'] = array(","+\t\t'title'       => 'E2E Custom',","+\t\t'description' => 'A custom guideline scope added by an e2e test plugin.',","+\t\t'order'       => 45,","+\t);","+","+\treturn $scopes;","+}","+add_filter( 'wp_guideline_scopes', 'gutenberg_test_filter_guideline_scopes' );"],"additions":29,"deletions":0,"truncated":false},{"path":"phpunit/experimental/knowledge/class-gutenberg-guideline-reservation-test.php","lines":["@@ -151,7 +151,7 @@ public function test_block_row_keeps_canonical_title() {"," "," \t\t$response = $this->create_row("," \t\t\tarray(","-\t\t\t\t'slug'    => 'guideline-block-core-paragraph',","+\t\t\t\t'slug'    => 'guideline-block-core_paragraph',"," \t\t\t\t'title'   => 'core/paragraph',"," \t\t\t\t'content' => 'Keep paragraphs short.',"," \t\t\t\t'status'  => 'publish',","@@ -184,4 +184,26 @@ public function test_content_sanitized_and_capped() {"," \t\t$this->assertStringNotContainsString( '<script', $content );"," \t\t$this->assertLessThanOrEqual( 5000, mb_strlen( $content, 'UTF-8' ) );"," \t}","+","+\t/**","+\t * A `guideline-` slug that is not a registered scope is left untouched by the","+\t * guard: its content is neither sanitized nor capped, so a long plain-text","+\t * body is stored in full rather than truncated to the guideline length.","+\t */","+\tpublic function test_unrecognized_slug_row_is_not_shaped() {","+\t\twp_set_current_user( self::$admin_id );","+","+\t\t$long = str_repeat( 'a', 6000 );","+","+\t\t$response = $this->create_row(","+\t\t\tarray(","+\t\t\t\t'slug'    => 'guideline-nope',","+\t\t\t\t'content' => $long,","+\t\t\t\t'status'  => 'publish',","+\t\t\t)","+\t\t);","+","+\t\t$this->assertSame( 201, $response->get_status() );","+\t\t$this->assertSame( 6000, mb_strlen( get_post( $response->get_data()['id'] )->post_content, 'UTF-8' ) );","+\t}"," }"],"additions":23,"deletions":1,"truncated":false},{"path":"phpunit/experimental/knowledge/class-gutenberg-guideline-scopes-controller-test.php","lines":["@@ -61,7 +61,7 @@ public function test_returns_default_scopes_for_admin() {"," "," \t\t$data  = $response->get_data();"," \t\t$slugs = wp_list_pluck( $data, 'slug' );","-\t\t$this->assertSame( array( 'site', 'copy', 'images', 'additional' ), $slugs );","+\t\t$this->assertSame( array( 'site', 'copy', 'images', 'blocks', 'additional' ), $slugs );"," "," \t\t$this->assertArrayHasKey( 'title', $data[0] );"," \t\t$this->assertArrayHasKey( 'description', $data[0] );","@@ -94,4 +94,25 @@ public function test_filter_adds_scope() {"," "," \t\t$this->assertContains( 'custom', $slugs );"," \t}","+","+\t/**","+\t * The `wp_guideline_scopes` filter can remove a default scope, so a plugin","+\t * can drop the Blocks section from the Settings page entirely.","+\t */","+\tpublic function test_filter_removes_scope() {","+\t\twp_set_current_user( self::$admin_id );","+","+\t\tadd_filter(","+\t\t\t'wp_guideline_scopes',","+\t\t\tstatic function ( $scopes ) {","+\t\t\t\tunset( $scopes['blocks'] );","+\t\t\t\treturn $scopes;","+\t\t\t}","+\t\t);","+","+\t\t$data  = rest_get_server()->dispatch( new WP_REST_Request( 'GET', '/wp/v2/knowledge/guideline-scopes' ) )->get_data();","+\t\t$slugs = wp_list_pluck( $data, 'slug' );","+","+\t\t$this->assertNotContains( 'blocks', $slugs );","+\t}"," }"],"additions":22,"deletions":1,"truncated":false},{"path":"phpunit/experimental/knowledge/class-gutenberg-guideline-scopes-test.php","lines":["@@ -0,0 +1,153 @@","+<?php","+/**","+ * Tests for the guideline scopes registry and the slug/length helpers.","+ *","+ * @package gutenberg","+ *","+ * @group knowledge","+ */","+class Gutenberg_Guideline_Scopes_Test extends WP_UnitTestCase {","+","+\t/**","+\t * The default scopes are registered in order, each with the expected shape.","+\t */","+\tpublic function test_default_scopes_are_registered() {","+\t\t$scopes = wp_guideline_scopes();","+","+\t\t$this->assertSame( array( 'site', 'copy', 'images', 'blocks', 'additional' ), array_keys( $scopes ) );","+","+\t\tforeach ( $scopes as $scope ) {","+\t\t\t$this->assertArrayHasKey( 'title', $scope );","+\t\t\t$this->assertArrayHasKey( 'description', $scope );","+\t\t\t$this->assertArrayHasKey( 'order', $scope );","+\t\t\t$this->assertIsInt( $scope['order'] );","+\t\t}","+","+\t\t$this->assertSame( 'Site', $scopes['site']['title'] );","+\t}","+","+\t/**","+\t * Plugins can register additional scopes through the filter.","+\t */","+\tpublic function test_scopes_are_filterable() {","+\t\tadd_filter(","+\t\t\t'wp_guideline_scopes',","+\t\t\tstatic function ( $scopes ) {","+\t\t\t\t$scopes['custom'] = array(","+\t\t\t\t\t'title'       => 'Custom',","+\t\t\t\t\t'description' => 'Custom scope.',","+\t\t\t\t\t'order'       => 99,","+\t\t\t\t);","+\t\t\t\treturn $scopes;","+\t\t\t}","+\t\t);","+","+\t\t$scopes = wp_guideline_scopes();","+","+\t\t$this->assertArrayHasKey( 'custom', $scopes );","+\t\t$this->assertSame( 'Custom', $scopes['custom']['title'] );","+\t}","+","+\t/**","+\t * The content length cap defaults to 5000 characters.","+\t */","+\tpublic function test_max_length_defaults_to_5000() {","+\t\t$this->assertSame( 5000, wp_guideline_max_length() );","+\t}","+","+\t/**","+\t * The content length cap is filterable.","+\t */","+\tpublic function test_max_length_is_filterable() {","+\t\tadd_filter(","+\t\t\t'wp_guideline_max_length',","+\t\t\tstatic function () {","+\t\t\t\treturn 10;","+\t\t\t}","+\t\t);","+","+\t\t$this->assertSame( 10, wp_guideline_max_length() );","+\t}","+","+\t/**","+\t * Data provider for scope resolution from a row slug.","+\t *","+\t * @return array<string, array{0: string, 1: string|null}>","+\t */","+\tpublic function data_scope_from_slug(): array {","+\t\treturn array(","+\t\t\t'registry scope'   => array( 'guideline-site', 'site' ),","+\t\t\t'another scope'    => array( 'guideline-images', 'images' ),","+\t\t\t'blocks scope'     => array( 'guideline-blocks', 'blocks' ),","+\t\t\t'block row'        => array( 'guideline-block-core_paragraph', 'blocks' ),","+\t\t\t'empty block name' => array( 'guideline-block-', null ),","+\t\t\t'unknown scope'    => array( 'guideline-nope', null ),","+\t\t\t'bare prefix'      => array( 'guideline-', null ),","+\t\t\t'not a guideline'  => array( 'note-site', null ),","+\t\t);","+\t}","+","+\t/**","+\t * A row slug resolves to the scope that owns it.","+\t *","+\t * @dataProvider data_scope_from_slug","+\t *","+\t * @param string      $slug     Post slug.","+\t * @param string|null $expected Expected scope key.","+\t */","+\tpublic function test_scope_from_slug( $slug, $expected ) {","+\t\t$this->assertSame( $expected, wp_guideline_scope_from_slug( $slug ) );","+\t}","+","+\t/**","+\t * Per-block rows resolve to the blocks scope only while it is registered.","+\t */","+\tpublic function test_block_row_scope_requires_blocks_scope() {","+\t\t$this->assertSame( 'blocks', wp_guideline_scope_from_slug( 'guideline-block-core_paragraph' ) );","+","+\t\tadd_filter(","+\t\t\t'wp_guideline_scopes',","+\t\t\tstatic function ( $scopes ) {","+\t\t\t\tunset( $scopes['blocks'] );","+\t\t\t\treturn $scopes;","+\t\t\t}","+\t\t);","+","+\t\t$this->assertNull( wp_guideline_scope_from_slug( 'guideline-block-core_paragraph' ) );","+\t}","+","+\t/**","+\t * A registered scope keyed under `block-` wins over the per-block namespace.","+\t *","+\t * Real per-block slugs always encode the block namespace separator as `_`","+\t * (`core/paragraph` becomes `guideline-block-core_paragraph`), so a scope key","+\t * made only of hyphens like `block-editor-media-instructions` never matches a","+\t * real block row. That is why the collision is very unlikely in practice.","+\t */","+\tpublic function test_registered_scope_wins_over_block_namespace() {","+\t\t$slug = 'guideline-block-editor-media-instructions';","+","+\t\t// Before the scope exists the slug looks like a per-block row, so it is","+\t\t// swallowed by the blocks scope.","+\t\t$this->assertSame( 'blocks', wp_guideline_scope_from_slug( $slug ) );","+","+\t\tadd_filter(","+\t\t\t'wp_guideline_scopes',","+\t\t\tstatic function ( $scopes ) {","+\t\t\t\t$scopes['block-editor-media-instructions'] = array(","+\t\t\t\t\t'title'       => 'Media instructions',","+\t\t\t\t\t'description' => '',","+\t\t\t\t\t'order'       => 60,","+\t\t\t\t);","+\t\t\t\treturn $scopes;","+\t\t\t}","+\t\t);","+","+\t\t// Once registered, the exact scope key wins and resolves to itself.","+\t\t$this->assertSame( 'block-editor-media-instructions', wp_guideline_scope_from_slug( $slug ) );","+","+\t\t// A real per-block row keeps the namespace separator as `_`, so it never","+\t\t// collides with such a scope key and still resolves to the blocks scope.","+\t\t$this->assertSame( 'blocks', wp_guideline_scope_from_slug( 'guideline-block-core_paragraph' ) );","+\t}","+}"],"additions":153,"deletions":0,"truncated":false},{"path":"routes/guidelines/data.ts","lines":["@@ -28,6 +28,13 @@ export const KNOWLEDGE_NAME = 'wp_knowledge';"," const SCOPE_PREFIX = 'guideline-';"," const BLOCK_PREFIX = 'guideline-block-';"," ","+// The registry scope that lists per-block guidelines. Unlike the other scopes","+// it has no single `guideline-blocks` row: its content lives in `guideline-block-*`","+// rows. It is rendered as the Blocks section and skipped by the single-row paths","+// (slug query, import/export). Removing it from the server registry removes the","+// Blocks section entirely.","+export const BLOCKS_SCOPE = 'b