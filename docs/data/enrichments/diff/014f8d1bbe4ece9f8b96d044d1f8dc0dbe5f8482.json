{"id":"014f8d1bbe4ece9f8b96d044d1f8dc0dbe5f8482","axis":"silent","repo":"hashicorp/packer","sha":"014f8d1bbe4ece9f8b96d044d1f8dc0dbe5f8482","parsed":{"files":[{"path":".go-version","lines":["@@ -1 +1 @@","-1.25.11","+1.26.3"],"additions":1,"deletions":1,"truncated":false},{"path":"command/execute.go","lines":["@@ -25,6 +25,7 @@ import ("," \tchecksumpostprocessor \"github.com/hashicorp/packer/post-processor/checksum\""," \tcompresspostprocessor \"github.com/hashicorp/packer/post-processor/compress\""," \tmanifestpostprocessor \"github.com/hashicorp/packer/post-processor/manifest\"","+\tprovenancepostprocessor \"github.com/hashicorp/packer/post-processor/provenance\""," \tshelllocalpostprocessor \"github.com/hashicorp/packer/post-processor/shell-local\""," \tbreakpointprovisioner \"github.com/hashicorp/packer/provisioner/breakpoint\""," \tfileprovisioner \"github.com/hashicorp/packer/provisioner/file\"","@@ -63,6 +64,7 @@ var PostProcessors = map[string]packersdk.PostProcessor{"," \t\"checksum\":    new(checksumpostprocessor.PostProcessor),"," \t\"compress\":    new(compresspostprocessor.PostProcessor),"," \t\"manifest\":    new(manifestpostprocessor.PostProcessor),","+\t\"provenance\":  new(provenancepostprocessor.PostProcessor),"," \t\"shell-local\": new(shelllocalpostprocessor.PostProcessor),"," }"," "],"additions":2,"deletions":0,"truncated":false},{"path":"command/verify_attestation.go","lines":["@@ -0,0 +1,155 @@","+// Copyright IBM Corp. 2024, 2025","+// SPDX-License-Identifier: BUSL-1.1","+","+package command","+","+import (","+\t\"context\"","+\t\"strings\"","+","+\tinternalattestation \"github.com/hashicorp/packer/internal/attestation\"","+\t\"github.com/posener/complete\"","+)","+","+type VerifyAttestationCommand struct {","+\tMeta","+}","+","+type VerifyAttestationArgs struct {","+\tAttestationPath          string","+\tSigningMode              string","+\tKey                      string","+\tVerifier                 string","+\tPredicateType            string","+\tBuilderID                string","+\tSourceURI                string","+\tArtifactPath             string","+\tTrustedRootPath          string","+\tKeylessIdentity          string","+\tKeylessOIDCIssuer        string","+\tSigstoreBundlePath       string","+\tRequireTransparencyLog   bool","+\tRequireObserverTimestamp bool","+}","+","+func (c *VerifyAttestationCommand) Run(args []string) int {","+\tctx, cleanup := handleTermInterrupt(c.Ui)","+\tdefer cleanup()","+","+\tcfg, ret := c.ParseArgs(args)","+\tif ret != 0 {","+\t\treturn ret","+\t}","+","+\treturn c.RunContext(ctx, cfg)","+}","+","+func (c *VerifyAttestationCommand) ParseArgs(args []string) (*VerifyAttestationArgs, int) {","+\tvar cfg VerifyAttestationArgs","+","+\tflags := c.FlagSet(\"verify-attestation\")","+\tflags.Usage = func() { c.Ui.Say(c.Help()) }","+\tflags.StringVar(&cfg.SigningMode, \"signing-mode\", \"\", \"Signing mode used for the attestation\")","+\tflags.StringVar(&cfg.Key, \"key\", \"\", \"PEM path or KMS/Vault URI\")","+\tflags.StringVar(&cfg.Verifier, \"verifier\", \"\", \"PEM verifier path\")","+\tflags.StringVar(&cfg.PredicateType, \"predicate-type\", \"\", \"Expected attestation predicate type\")","+\tflags.StringVar(&cfg.BuilderID, \"builder-id\", \"\", \"Expected SLSA builder ID\")","+\tflags.StringVar(&cfg.SourceURI, \"source-uri\", \"\", \"Expected resolved source URI\")","+\tflags.StringVar(&cfg.ArtifactPath, \"artifact\", \"\", \"Artifact path to match against attestation subjects\")","+\tflags.StringVar(&cfg.TrustedRootPath, \"trusted-root-path\", \"\", \"Optional Sigstore trusted-root JSON file\")","+\tflags.StringVar(&cfg.KeylessIdentity, \"keyless-identity\", \"\", \"Expected keyless signing identity\")","+\tflags.StringVar(&cfg.KeylessOIDCIssuer, \"keyless-oidc-issuer\", \"\", \"Expected keyless OIDC issuer\")","+\tflags.StringVar(&cfg.SigstoreBundlePath, \"bundle\", \"\", \"Optional Sigstore bundle JSON file for Rekor or timestamp verification\")","+\tflags.BoolVar(&cfg.RequireTransparencyLog, \"require-rekor\", false, \"Require Rekor transparency log verification using the Sigstore bundle\")","+\tflags.BoolVar(&cfg.RequireObserverTimestamp, \"require-timestamp\", false, \"Require a trusted observer timestamp from Rekor integrated time or RFC3161 timestamp evidence\")","+\tif err := flags.Parse(args); err != nil {","+\t\treturn &cfg, 1","+\t}","+","+\targs = flags.Args()","+\tif len(args) != 1 {","+\t\tflags.Usage()","+\t\treturn &cfg, 1","+\t}","+\tcfg.AttestationPath = args[0]","+\treturn &cfg, 0","+}","+","+func (c *VerifyAttestationCommand) RunContext(ctx context.Context, cfg *VerifyAttestationArgs) int {","+\t_, err := internalattestation.VerifyAttestationFile(ctx, cfg.AttestationPath, internalattestation.BackendConfig{","+\t\tMode:              cfg.SigningMode,","+\t\tSignerRef:         cfg.Key,","+\t\tVerifierRef:       cfg.Verifier,","+\t\tTrustedRootPath:   cfg.TrustedRootPath,","+\t\tKeylessIdentity:   cfg.KeylessIdentity,","+\t\tKeylessOIDCIssuer: cfg.KeylessOIDCIssuer,","+\t}, internalattestation.VerificationPolicy{","+\t\tPredicateType:            cfg.PredicateType,","+\t\tBuilderID:                cfg.BuilderID,","+\t\tSourceURI:                cfg.SourceURI,","+\t\tArtifactPath:             cfg.ArtifactPath,","+\t\tSigstoreBundlePath:       cfg.SigstoreBundlePath,","+\t\tRequireTransparencyLog:   cfg.RequireTransparencyLog,","+\t\tRequireObserverTimestamp: cfg.RequireObserverTimestamp,","+\t})","+\tif err != nil {","+\t\tc.Ui.Error(err.Error())","+\t\treturn 1","+\t}","+","+\tc.Ui.Say(\"Attestation verified.\")","+\treturn 0","+}","+","+func (*VerifyAttestationCommand) Help() string {","+\thelpText := `","+Usage: packer verify-attestation [options] ATTESTATION","+","+  Verifies a signed DSSE attestation and optionally enforces policy checks","+  such as predicate type, builder identity, source URI, and subject digest.","+","+Options:","+","+  -signing-mode=MODE            Signing mode: key, kms, keyless. Auto-detected when possible.","+  -key=PATH_OR_URI              PEM key path or KMS/Vault URI used for verification when no verifier is supplied.","+  -verifier=PATH                PEM verifier path.","+  -predicate-type=TYPE          Expected attestation predicate type.","+  -builder-id=ID                Expected SLSA builder ID.","+  -source-uri=URI               Expected resolved source URI.","+  -artifact=PATH                Artifact path to match against attestation subjects.","+  -trusted-root-path=PATH       Optional Sigstore trusted-root JSON for keyless verification.","+  -keyless-identity=IDENTITY    Expected keyless signing identity.","+  -keyless-oidc-issuer=ISSUER   Expected keyless OIDC issuer.","+  -bundle=PATH                  Optional Sigstore bundle JSON for Rekor or timestamp verification.","+  -require-rekor                Require Rekor transparency log verification from the bundle.","+  -require-timestamp            Require a trusted observer timestamp from Rekor integrated time or RFC3161 evidence.","+`","+","+\treturn strings.TrimSpace(helpText)","+}","+","+func (*VerifyAttestationCommand) Synopsis() string {","+\treturn \"verify a signed attestation against policy\"","+}","+","+func (*VerifyAttestationCommand) AutocompleteArgs() complete.Predictor {","+\treturn complete.PredictNothing","+}","+","+func (*VerifyAttestationCommand) AutocompleteFlags() complete.Flags {","+\treturn complete.Flags{","+\t\t\"-signing-mode\":        complete.PredictNothing,","+\t\t\"-key\":                 complete.PredictNothing,","+\t\t\"-verifier\":            complete.PredictNothing,","+\t\t\"-predicate-type\":      complete.PredictNothing,","+\t\t\"-builder-id\":          complete.PredictNothing,","+\t\t\"-source-uri\":          complete.PredictNothing,","+\t\t\"-artifact\":            complete.PredictNothing,","+\t\t\"-trusted-root-path\":   complete.PredictNothing,","+\t\t\"-keyless-identity\":    complete.PredictNothing,","+\t\t\"-keyless-oidc-issuer\": complete.PredictNothing,","+\t\t\"-bundle\":              complete.PredictNothing,","+\t\t\"-require-rekor\":       complete.PredictNothing,","+\t\t\"-require-timestamp\":   complete.PredictNothing,","+\t}","+}"],"additions":155,"deletions":0,"truncated":false},{"path":"command/verify_attestation_test.go","lines":["@@ -0,0 +1,244 @@","+// Copyright IBM Corp. 2024, 2025","+// SPDX-License-Identifier: BUSL-1.1","+","+package command","+","+import (","+\t\"bytes\"","+\t\"context\"","+\t\"crypto/ecdsa\"","+\t\"crypto/elliptic\"","+\t\"crypto/rand\"","+\t\"crypto/sha256\"","+\t\"crypto/x509\"","+\t\"encoding/base64\"","+\t\"encoding/hex\"","+\t\"encoding/json\"","+\t\"encoding/pem\"","+\t\"os\"","+\t\"path/filepath\"","+\t\"strings\"","+\t\"testing\"","+","+\tpackersdk \"github.com/hashicorp/packer-plugin-sdk/packer\"","+\tinternalattestation \"github.com/hashicorp/packer/internal/attestation\"","+\tinternalprovenance \"github.com/hashicorp/packer/internal/provenance\"","+)","+","+func TestVerifyAttestationCommandRun(t *testing.T) {","+\tartifactPath := filepath.Join(t.TempDir(), \"artifact.txt\")","+\tif err := os.WriteFile(artifactPath, []byte(\"hello verify\"), 0600); err != nil {","+\t\tt.Fatalf(\"write artifact: %v\", err)","+\t}","+","+\tprivateKeyPath, publicKeyPath := writeVerifierKeypair(t)","+\tattestationPath := writeSignedAttestation(t, privateKeyPath, artifactPath, \"https://example.com/builder\", \"git+https://github.com/hashicorp/packer@refs/heads/main\")","+","+\tmeta := testMeta(t)","+\tcommand := &VerifyAttestationCommand{Meta: meta}","+\tret := command.Run([]string{","+\t\t\"-verifier=\" + publicKeyPath,","+\t\t\"-predicate-type=\" + internalprovenance.SLSAProvenanceV1PredicateType,","+\t\t\"-builder-id=https://example.com/builder\",","+\t\t\"-source-uri=git+https://github.com/hashicorp/packer@refs/heads/main\",","+\t\t\"-artifact=\" + artifactPath,","+\t\tattestationPath,","+\t})","+\tif ret != 0 {","+\t\tfatalCommand(t, meta)","+\t}","+","+\tui := meta.Ui.(*packersdk.BasicUi)","+\tif got := ui.Writer.(*bytes.Buffer).String(); !strings.Contains(got, \"Attestation verified.\") {","+\t\tt.Fatalf(\"expected success output, got %q\", got)","+\t}","+}","+","+func TestVerifyAttestationCommandRejectsMismatchedBuilderID(t *testing.T) {","+\tartifactPath := filepath.Join(t.TempDir(), \"artifact.txt\")","+\tif err := os.WriteFile(artifactPath, []byte(\"hello verify\"), 0600); err != nil {","+\t\tt.Fatalf(\"write artifact: %v\", err)","+\t}","+","+\tprivateKeyPath, publicKeyPath := writeVerifierKeypair(t)","+\tattestationPath := writeSignedAttestation(t, privateKeyPath, artifactPath, \"https://example.com/builder\", \"git+https://github.com/hashicorp/packer@refs/heads/main\")","+","+\tmeta := testMeta(t)","+\tcommand := &VerifyAttestationCommand{Meta: meta}","+\tret := command.Run([]string{","+\t\t\"-verifier=\" + publicKeyPath,","+\t\t\"-builder-id=https://example.com/other-builder\",","+\t\tattestationPath,","+\t})","+\tif ret == 0 {","+\t\tt.Fatalf(\"expected builder mismatch to fail\")","+\t}","+}","+","+func TestVerifyAttestationCommandRequiresBundleForRekorChecks(t *testing.T) {","+\tartifactPath := filepath.Join(t.TempDir(), \"artifact.txt\")","+\tif err := os.WriteFile(artifactPath, []byte(\"hello verify\"), 0600); err != nil {","+\t\tt.Fatalf(\"write artifact: %v\", err)","+\t}","+","+\tprivateKeyPath, publicKeyPath := writeVerifierKeypair(t)","+\tattestationPath := writeSignedAttestation(t, privateKeyPath, artifactPath, \"https://example.com/builder\", \"git+https://github.com/hashicorp/packer@refs/heads/main\")","+","+\tmeta := testMeta(t)","+\tcommand := &VerifyAttestationCommand{Meta: meta}","+\tret := command.Run([]string{","+\t\t\"-verifier=\" + publicKeyPath,","+\t\t\"-require-rekor\",","+\t\tattestationPath,","+\t})","+\tif ret == 0 {","+\t\tt.Fatalf(\"expected missing bundle to fail\")","+\t}","+","+\tui := meta.Ui.(*packersdk.BasicUi)","+\tif got := ui.ErrorWriter.(*bytes.Buffer).String(); !strings.Contains(got, \"requires -bundle\") {","+\t\tt.Fatalf(\"expected missing bundle error, got %q\", got)","+\t}","+}","+","+func TestVerifyAttestationCommandRejectsTamperedPayload(t *testing.T) {","+\tartifactPath := filepath.Join(t.TempDir(), \"artifact.txt\")","+\tif err := os.WriteFile(artifactPath, []byte(\"hello verify\"), 0600); err != nil {","+\t\tt.Fatalf(\"write artifact: %v\", err)","+\t}","+","+\tprivateKeyPath, publicKeyPath := writeVerifierKeypair(t)","+\tattestationPath := writeSignedAttestation(t, privateKeyPath, artifactPath, \"https://example.com/builder\", \"git+https://github.com/hashicorp/packer@refs/heads/main\")","+","+\ttamperAttestationPayload(t, attestationPath)","+","+\tmeta := testMeta(t)","+\tcommand := &VerifyAttestationCommand{Meta: meta}","+\tret := command.Run([]string{","+\t\t\"-verifier=\" + publicKeyPath,","+\t\tattestationPath,","+\t})","+\tif ret == 0 {","+\t\tt.Fatalf(\"expected tampered payload to fail verification\")","+\t}","+}","+","+func tamperAttestationPayload(t *testing.T, attestationPath string) {","+\tt.Helper()","+","+\tcontents, err := os.ReadFile(attestationPath)","+\tif err != nil {","+\t\tt.Fatalf(\"read attestation: %v\", err)","+\t}","+","+\tvar envelope internalattestation.Envelope","+\tif err := json.Unmarshal(contents, &envelope); err != nil {","+\t\tt.Fatalf(\"unmarshal envelope: %v\", err)","+\t}","+","+\tpayload, err := internalattestation.DecodeEnvelopePayload(envelope)","+\tif err != nil {","+\t\tt.Fatalf(\"decode payload: %v\", err)","+\t}","+","+\ttampered := bytes.Replace(payload, []byte(\"https://example.com/builder\"), []byte(\"https://example.com/evilbuilder\"), 1)","+\tif bytes.Equal(tampered, payload) {","+\t\tt.Fatalf(\"expected payload to be modified\")","+\t}","+\tenvelope.Payload = base64.StdEncoding.EncodeToString(tampered)","+","+\ttamperedEnvelope, err := json.Marshal(envelope)","+\tif err != nil {","+\t\tt.Fatalf(\"marshal tampered envelope: %v\", err)","+\t}","+\tif err := os.WriteFile(attestationPath, tamperedEnvelope, 0600); err != nil {","+\t\tt.Fatalf(\"write tampered attestation: %v\", err)","+\t}","+}","+","+func writeSignedAttestation(t *testing.T, privateKeyPath, artifactPath, builderID, sourceURI string) string {","+\tt.Helper()","+","+\tartifactDigest := sha256.Sum256([]byte(readFileString(t, artifactPath)))","+\tstatement := internalprovenance.WrapInToto(","+\t\t[]internalprovenance.Subject{{","+\t\t\tName: filepath.Base(artifactPath),","+\t\t\tDigest: internalprovenance.DigestSet{","+\t\t\t\t\"sha256\": hex.EncodeToString(artifactDigest[:]),","+\t\t\t},","+\t\t}},","+\t\tinternalprovenance.SLSAProvenanceV1PredicateType,","+\t\tinternalprovenance.BuildSLSAPredicate(internalprovenance.PredicateInput{","+\t\t\tBuilderID:            builderID,","+\t\t\tResolvedDependencies: []internalprovenance.ResolvedDependency{{URI: sourceURI}},","+\t\t}),","+\t)","+\tpayload, err := internalattestation.MarshalPayload(statement)","+\tif err != nil {","+\t\tt.Fatalf(\"marshal statement: %v\", err)","+\t}","+","+\tsigner, err := internalattestation.NewSigner(context.Background(), internalattestation.BackendConfig{Mode: internalattestation.SigningModeKey, SignerRef: privateKeyPath})","+\tif err != nil {","+\t\tt.Fatalf(\"create signer: %v\", err)","+\t}","+","+\tsignature, err := signer.Sign(context.Background(), internalattestation.InTotoPayloadType, payload)","+\tif err != nil {","+\t\tt.Fatalf(\"sign statement: %v\", err)","+\t}","+","+\tattestationPath := filepath.Join(t.TempDir(), \"attestation.json\")","+\tenvelope, err := json.Marshal(internalattestation.NewEnvelope(internalattestation.InTotoPayloadType, payload, signature))","+\tif err != nil {","+\t\tt.Fatalf(\"marshal envelope: %v\", err)","+\t}","+\tif err := os.WriteFile(attestationPath, envelope, 0600); err != nil {","+\t\tt.Fatalf(\"write attestation: %v\", err)","+\t}","+","+\treturn attestationPath","+}","+","+func writeVerifierKeypair(t *testing.T) (string, string) {","+\tt.Helper()","+","+\tprivateKey, err := ecdsa.GenerateKey(elliptic.P256(), rand.Reader)","+\tif err != nil {","+\t\tt.Fatalf(\"generate private key: %v\", err)","+\t}","+","+\tprivateKeyDER, err := x509.MarshalECPrivateKey(privateKey)","+\tif err != nil {","+\t\tt.Fatalf(\"marshal private key: %v\", err)","+\t}","+","+\tpublicKeyDER, err := x509.MarshalPKIXPublicKey(privateKey.Public())","+\tif err != nil {","+\t\tt.Fatalf(\"marshal public key: %v\", err)","+\t}","+","+\tdir := t.TempDir()","+\tprivateKeyPath := filepath.Join(dir, \"signer.pem\")","+\tpublicKeyPath := filepath.Join(dir, \"verifier.pem\")","+","+\tif err := os.WriteFile(privateKeyPath, pem.EncodeToMemory(&pem.Block{Type: \"EC PRIVATE KEY\", Bytes: privateKeyDER}), 0600); err != nil {","+\t\tt.Fatalf(\"write private key: %v\", err)","+\t}","+\tif err := os.WriteFile(publicKeyPath, pem.EncodeToMemory(&pem.Block{Type: \"PUBLIC KEY\", Bytes: publicKeyDER}), 0600); err != nil {","+\t\tt.Fatalf(\"write public key: %v\", err)","+\t}","+","+\treturn privateKeyPath, publicKeyPath","+}","+","+func readFileString(t *testing.T, path string) string {","+\tt.Helper()","+","+\tcontents, err := os.ReadFile(path)","+\tif err != nil {","+\t\tt.Fatalf(\"read file %q: %v\", path, err)","+\t}","+","+\treturn string(contents)","+}"],"additions":244,"deletions":0,"truncated":false},{"path":"commands.go","lines":["@@ -112,6 +112,10 @@ func init() {"," \t\t\treturn &command.SBOMGenerateCommand{Meta: *CommandMeta}, nil"," \t\t},"," ","+\t\t\"verify-attestation\": func() (cli.Command, error) {","+\t\t\treturn &command.VerifyAttestationCommand{Meta: *CommandMeta}, nil","+\t\t},","+"," \t\t// plugin is essentially an alias to the plugins command"," \t\t//"," \t\t// It is not meant to be documented or used outside of simple"],"additions":4,"deletions":0,"truncated":false},{"path":"examples/ci/README.md","lines":["@@ -0,0 +1,34 @@","+# Provenance CI reference workflows","+","+These are copy-paste reference workflows for producing SLSA provenance with the","+Packer `provenance` post-processor. They are **not** wired into this","+repository's own CI — copy them into your project's `.github/workflows/`","+directory and adapt the template and artifact paths.","+","+## SLSA levels and Packer","+","+SLSA Build levels are mostly properties of the build **platform**, not the","+build **tool**. Packer is a tool, so its reach is:","+","+| SLSA Build level | Requirement | Packer's role | What Packer provides |","+|---|---|---|---|","+| **L1** | Provenance exists and is distributed | Fully in Packer | Provenance generation |","+| **L2** | Provenance signed by a hosted platform | Packer signs via CI OIDC identity | Keyless signing in CI |","+| **L3** | Hardened platform; build steps cannot reach the signing key | Platform property; Packer is compatible | Delegated-signing pattern |","+| **L4** | — | Not defined in SLSA v1.0 | — |","+","+Packer generates SLSA Provenance v1 and reaches Build L1, and L2 when run on a","+hosted CI with keyless signing. L3 is a property of the build platform: it","+requires the signing key to be unreachable by the build steps. Packer does not","+confer L3 on its own, but the delegated-signing pattern below is compatible with","+an L3 platform.","+","+## Workflows","+","+- [`github-actions-l2-keyless.yml`](github-actions-l2-keyless.yml) — L2: Packer","+  signs provenance keyless using the workflow's OIDC identity, uploads to Rekor,","+  and verifies the signed attestation with `packer verify-attestation`.","+- [`github-actions-l3-delegated.yml`](github-actions-l3-delegated.yml) —","+  L3-compatible: the build job only builds and publishes a digest; provenance","+  generation and signing are delegated to an isolated reusable workflow so the","+  build steps cannot reach the signing material."],"additions":34,"deletions":0,"truncated":false},{"path":"examples/ci/github-actions-l2-keyless.yml","lines":["@@ -0,0 +1,93 @@","+# Reference workflow — NOT wired into this repository's CI.","+#","+# Copy this into your own project's .github/workflows/ directory.","+#","+# SLSA Build L2 pattern: Packer signs the provenance attestation keyless, using","+# the GitHub Actions workflow's own OIDC identity (Fulcio) and records the","+# signature in the Rekor transparency log. This yields signed, transparently","+# logged provenance produced by a hosted platform.","+#","+# This does NOT confer SLSA L3 on its own: the build job can still reach the","+# (ephemeral) signing material. See github-actions-l3-delegated.yml for the","+# L3-compatible delegated-signing pattern.","+","+name: build-and-sign-provenance","+","+on:","+  push:","+    tags:","+      - \"v*\"","+","+permissions:","+  contents: read","+  # Required so Packer's keyless signing can request an OIDC token from GitHub","+  # and exchange it with Fulcio for a short-lived signing certificate.","+  id-token: write","+","+jobs:","+  build:","+    runs-on: ubuntu-latest","+    env:","+      # Must match the workflow's OIDC identity so verification can pin it.","+      KEYLESS_IDENTITY: \"https://github.com/${{ github.repository }}/.github/workflows/build-and-sign-provenance.yml@${{ github.ref }}\"","+      KEYLESS_OIDC_ISSUER: \"https://token.actions.githubusercontent.com\"","+    steps:","+      - name: Checkout","+        uses: actions/checkout@v4","+","+      - name: Install Packer","+        uses: hashicorp/setup-packer@main","+        with:","+          version: latest","+","+      - name: Initialize plugins","+        run: packer init .","+","+      # The template below is expected to declare two input variables and a","+      # keyless provenance post-processor. NOTE: Packer's `env()` function may","+      # only appear in a variable `default`, never inline in a block, so the","+      # workflow passes the values with `-var` instead.","+      #","+      #   variable \"keyless_identity\"    { type = string }","+      #   variable \"keyless_oidc_issuer\" { type = string }","+      #","+      #   post-processor \"provenance\" {","+      #     signing_mode        = \"keyless\"","+      #     upload_tlog         = true","+      #     keyless_identity    = var.keyless_identity","+      #     keyless_oidc_issuer = var.keyless_oidc_issuer","+      #   }","+      #","+      # Packer picks up the ambient GitHub OIDC token automatically from the","+      # ACTIONS_ID_TOKEN_REQUEST_URL / ACTIONS_ID_TOKEN_REQUEST_TOKEN variables","+      # that are available when `id-token: write` is granted above.","+      - name: Build and sign","+        run: |","+          packer build \\","+            -var \"keyless_identity=${KEYLESS_IDENTITY}\" \\","+            -var \"keyless_oidc_issuer=${KEYLESS_OIDC_ISSUER}\" \\","+            .","+","+      # Verify the signed attestation with Rekor-backed transparency evidence","+      # using the generated Sigstore bundle sidecar (*.sigstore.json).","+      - name: Verify attestation","+        run: |","+          for att in *.provenance.json; do","+            packer verify-attestation \\","+              -signing-mode=keyless \\","+              -bundle=\"${att%.json}.sigstore.json\" \\","+              -require-rekor \\","+              -require-timestamp \\","+              -keyless-identity=\"${KEYLESS_IDENTITY}\" \\","+              -keyless-oidc-issuer=\"${KEYLESS_OIDC_ISSUER}\" \\","+              -predicate-type=\"https://slsa.dev/provenance/v1\" \\","+              \"${att}\"","+          done","+","+      - name: Upload provenance artifacts","+        uses: actions/upload-artifact@v4","+        with:","+          name: provenance","+          path: |","+            *.provenance.json","+            *.sigstore.json"],"additions":93,"deletions":0,"truncated":false},{"path":"examples/ci/github-actions-l3-delegated.yml","lines":["@@ -0,0 +1,64 @@","+# Reference workflow — NOT wired into this repository's CI.","+#","+# Copy this into your own project's .github/workflows/ directory.","+#","+# SLSA Build L3-compatible pattern: the build job ONLY builds the artifact and","+# publishes its digest. Provenance generation and signing are delegated to an","+# isolated, reusable workflow (the SLSA GitHub generator) that runs in a","+# separate job the build steps cannot influence or reach. This keeps the","+# signing material unreachable from the build, which is what L3 requires.","+#","+# Packer itself does not confer L3. It participates by producing the artifact;","+# the platform (isolated signer) provides the L3 property.","+","+name: build-and-delegate-provenance","+","+on:","+  push:","+    tags:","+      - \"v*\"","+","+permissions:","+  contents: read","+","+jobs:","+  build:","+    runs-on: ubuntu-latest","+    outputs:","+      digest: ${{ steps.hash.outputs.digest }}","+    steps:","+      - name: Checkout","+        uses: actions/checkout@v4","+","+      - name: Install Packer","+        uses: hashicorp/setup-packer@main","+        with:","+          version: latest","+","+      - name: Initialize plugins","+        run: packer init .","+","+      # Build only. Do NOT sign here: signing in the build job would defeat the","+      # isolation that the delegated signer provides.","+      - name: Build artifact","+        run: packer build .","+","+      # Emit a base64-encoded subject digest for the delegated generator.","+      - name: Compute artifact digest","+        id: hash","+        run: |","+          # Adjust the artifact path to match your build output.","+          echo \"digest=$(sha256sum output/image.qcow2 | base64 -w0)\" >> \"${GITHUB_OUTPUT}\"","+","+  # Isolated, reusable workflow that generates and signs SLSA provenance in a","+  # job the build cannot reach. This is the component that provides the L3","+  # property; pin it to a released tag in real usage.","+  provenance:","+    needs: [build]","+    permissions:","+      actions: read","+      id-token: write","+      contents: write","+    uses: slsa-framework/slsa-github-generator/.github/workflows/generator_generic_slsa3.yml@v2.0.0","+    with:","+      base64-subjects: ${{ needs.build.outputs.digest }}"],"additions":64,"deletions":0,"truncated":false},{"path":"go.mod","lines":["@@ -7,7 +7,7 @@ require ("," \tgithub.com/chzyer/readline v1.5.1"," \tgithub.com/dsnet/compress v0.0.2-0.20230904184137-39efe44ab707"," \tgithub.com/go-git/go-git/v5 v5.19.1","-\tgithub.com/go-openapi/runtime v0.28.0","+\tgithub.com/go-openapi/runtime v0.32.3"," \tgithub.com/gobwas/glob v0.2.3"," \tgithub.com/gofrs/flock v0.8.1 // indirect"," \tgithub.com/golang/groupcache v0.0.0-20241129210726-2c02b8208cf8 // indirect","@@ -24,7 +24,7 @@ require ("," \tgithub.com/hashicorp/hcp-sdk-go v0.174.0"," \tgithub.com/hashicorp/packer-plugin-sdk v0.6.10"," \tgithub.com/jehiah/go-strftime v0.0.0-20171201141054-1d33003b3869","-\tgithub.com/klauspost/compress v1.18.5","+\tgithub.com/klauspost/compress v1.18.6"," \tgithub.com/klauspost/pgzip v1.2.6"," \tgithub.com/masterzen/winrm v0.0.0-20250927112105-5f8e6c707321"," \tgithub.com/mattn/go-runewidth v0.0.19 // indirect","@@ -57,37 +57,51 @@ require ("," \tgithub.com/CycloneDX/cyclonedx-go v0.11.0"," \tgithub.com/Masterminds/semver/v3 v3.4.0"," \tgithub.com/anchore/syft v1.42.3","-\tgithub.com/go-openapi/strfmt v0.23.0","+\tgithub.com/go-openapi/strfmt v0.26.3"," \tgithub.com/google/go-github/v75 v75.0.0"," \tgithub.com/oklog/ulid v1.3.1"," \tgithub.com/pierrec/lz4/v4 v4.1.22"," \tgithub.com/shirou/gopsutil/v3 v3.23.4","+\tgithub.com/sigstore/protobuf-specs v0.5.1","+\tgithub.com/sigstore/sigstore v1.10.8","+\tgithub.com/sigstore/sigstore-go v1.2.1","+\tgithub.com/sigstore/sigstore/pkg/signature/kms/aws v1.10.8","+\tgithub.com/sigstore/sigstore/pkg/signature/kms/azure v1.10.8","+\tgithub.com/sigstore/sigstore/pkg/signature/kms/gcp v1.10.8","+\tgithub.com/sigstore/sigstore/pkg/signature/kms/hashivault v1.10.8"," \tgithub.com/spdx/tools-golang v0.5.7","-\tgoogle.golang.org/grpc v1.79.3","+\tgoogle.golang.org/grpc v1.81.1"," \tmodernc.org/sqlite v1.46.1"," )"," "," require ("," \tcel.dev/expr v0.25.1 // in