rt/session/sftputils\"","+)","+","+func TestEnsureReqIsAllowed(t *testing.T) {","+\tt.Parallel()","+\tconst filePath = \"/foo/bar/baz.txt\"","+\tpassTests := []struct {","+\t\tname    string","+\t\tallowed *allowedOps","+\t\treq     *sftp.Request","+\t}{","+\t\t{","+\t\t\tname: \"no restrictions\",","+\t\t\treq: &sftp.Request{","+\t\t\t\tFilepath: filePath,","+\t\t\t\tMethod:   sftputils.MethodGet,","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:    \"read\",","+\t\t\tallowed: &allowedOps{path: filePath},","+\t\t\treq: &sftp.Request{","+\t\t\t\tFilepath: filePath,","+\t\t\t\tMethod:   sftputils.MethodGet,","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:    \"write\",","+\t\t\tallowed: &allowedOps{path: filePath, write: true},","+\t\t\treq: &sftp.Request{","+\t\t\t\tFilepath: filePath,","+\t\t\t\tMethod:   sftputils.MethodPut,","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:    \"chmod\",","+\t\t\tallowed: &allowedOps{path: filePath, write: true},","+\t\t\treq: &sftp.Request{","+\t\t\t\tFilepath: filePath,","+\t\t\t\tMethod:   sftputils.MethodSetStat,","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:    \"stat in read mode\",","+\t\t\tallowed: &allowedOps{path: filePath},","+\t\t\treq: &sftp.Request{","+\t\t\t\tFilepath: filePath,","+\t\t\t\tMethod:   sftputils.MethodStat,","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:    \"lstat in read mode\",","+\t\t\tallowed: &allowedOps{path: filePath},","+\t\t\treq: &sftp.Request{","+\t\t\t\tFilepath: filePath,","+\t\t\t\tMethod:   sftputils.MethodLstat,","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:    \"stat in write mode\",","+\t\t\tallowed: &allowedOps{path: filePath, write: true},","+\t\t\treq: &sftp.Request{","+\t\t\t\tFilepath: filePath,","+\t\t\t\tMethod:   sftputils.MethodStat,","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:    \"lstat in write mode\",","+\t\t\tallowed: &allowedOps{path: filePath, write: true},","+\t\t\treq: &sftp.Request{","+\t\t\t\tFilepath: filePath,","+\t\t\t\tMethod:   sftputils.MethodLstat,","+\t\t\t},","+\t\t},","+\t}","+\tfor _, tc := range passTests {","+\t\tt.Run(\"allow \"+tc.name, func(t *testing.T) {","+\t\t\ttc.req.Filepath = filePath","+\t\t\tif tc.allowed != nil {","+\t\t\t\ttc.allowed.path = filePath","+\t\t\t}","+\t\t\thandler := &sftpHandler{allowed: tc.allowed}","+\t\t\trequire.NoError(t, handler.ensureReqIsAllowed(tc.req))","+\t\t})","+\t}","+","+\tconst convolutedPath = \"/foo/bar/../bar/baz.txt\"","+\tfailTests := []struct {","+\t\tname    string","+\t\tallowed *allowedOps","+\t\treq     *sftp.Request","+\t}{","+\t\t{","+\t\t\tname:    \"uncleaned path\",","+\t\t\tallowed: &allowedOps{path: convolutedPath},","+\t\t\treq: &sftp.Request{","+\t\t\t\tFilepath: convolutedPath,","+\t\t\t\tMethod:   sftputils.MethodGet,","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:    \"get in write mode\",","+\t\t\tallowed: &allowedOps{path: filePath, write: true},","+\t\t\treq: &sftp.Request{","+\t\t\t\tFilepath: filePath,","+\t\t\t\tMethod:   sftputils.MethodGet,","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:    \"write in read mode\",","+\t\t\tallowed: &allowedOps{path: filePath},","+\t\t\treq: &sftp.Request{","+\t\t\t\tFilepath: filePath,","+\t\t\t\tMethod:   sftputils.MethodPut,","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:    \"chmod in read mode\",","+\t\t\tallowed: &allowedOps{path: filePath},","+\t\t\treq: &sftp.Request{","+\t\t\t\tFilepath: filePath,","+\t\t\t\tMethod:   sftputils.MethodSetStat,","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname:    \"unknown method\",","+\t\t\tallowed: &allowedOps{path: filePath},","+\t\t\treq: &sftp.Request{","+\t\t\t\tFilepath: filePath,","+\t\t\t\tMethod:   sftputils.MethodRename,","+\t\t\t},","+\t\t},","+\t}","+\tfor _, tc := range failTests {","+\t\tt.Run(\"deny \"+tc.name, func(t *testing.T) {","+\t\t\thandler := &sftpHandler{allowed: tc.allowed}","+\t\t\trequire.Error(t, handler.ensureReqIsAllowed(tc.req))","+\t\t})","+\t}","+}","+","+func newTempDir(t *testing.T) string {","+\ttempDir := t.TempDir()","+\ttempRoot, err := filepath.EvalSymlinks(tempDir)","+\trequire.NoError(t, err)","+\treturn tempRoot","+}","+","+func TestNoFollowFileOperations(t *testing.T) {","+\tt.Parallel()","+","+\tt.Run(\"successful on path with no symlinks\", func(t *testing.T) {","+\t\ttargetFile := filepath.Join(newTempDir(t), \"myfile.txt\")","+","+\t\tf, err := openFileNoFollow(targetFile, os.O_WRONLY|os.O_CREATE, 0o600)","+\t\trequire.NoError(t, err)","+\t\tconst fileData = \"foo bar baz\"","+\t\t_, err = f.WriteString(fileData)","+\t\trequire.NoError(t, err)","+\t\trequire.NoError(t, f.Close())","+","+\t\tinfo, err := os.Stat(targetFile)","+\t\trequire.NoError(t, err)","+\t\trequire.Equal(t, int64(len(fileData)), info.Size())","+\t\trequire.Equal(t, os.FileMode(0o600), info.Mode())","+","+\t\tf, err = openFileNoFollow(targetFile, os.O_RDONLY, 0)","+\t\trequire.NoError(t, err)","+\t\tdata, err := io.ReadAll(f)","+\t\trequire.NoError(t, err)","+\t\trequire.NoError(t, f.Close())","+\t\trequire.Equal(t, []byte(fileData), data)","+","+\t\tupdatedTime := info.ModTime().Add(time.Hour).Truncate(time.Second)","+\t\terr = setstatNoFollow(targetFile, sftp.FileAttrFlags{","+\t\t\tSize:        true,","+\t\t\tPermissions: true,","+\t\t\tAcmodtime:   true,","+\t\t}, &sftp.FileStat{","+\t\t\tSize:  uint64(len(fileData) / 2),","+\t\t\tMode:  0o604,","+\t\t\tAtime: uint32(updatedTime.Unix()),","+\t\t\tMtime: uint32(updatedTime.Unix()),","+\t\t})","+\t\trequire.NoError(t, err)","+\t\tnewInfo, err := os.Stat(targetFile)","+\t\trequire.NoError(t, err)","+\t\trequire.Equal(t, int64(len(fileData)/2), newInfo.Size())","+\t\trequire.Equal(t, os.FileMode(0o604), newInfo.Mode())","+\t\trequire.Equal(t, updatedTime, newInfo.ModTime())","+\t})","+","+\tt.Run(\"block symlink in parent dir\", func(t *testing.T) {","+\t\ttempDir := newTempDir(t)","+\t\ttargetFile := filepath.Join(tempDir, \"foo.txt\")","+\t\trequire.NoError(t, os.WriteFile(targetFile, []byte(\"foo\"), 0o644))","+\t\tlink := filepath.Join(tempDir, \"link\")","+\t\trequire.NoError(t, os.Symlink(tempDir, link))","+\t\tlinkTarget := filepath.Join(link, \"foo.txt\")","+","+\t\t_, err := openFileNoFollow(linkTarget, os.O_WRONLY|os.O_CREATE, 0o644)","+\t\trequire.ErrorIs(t, err, syscall.ENOTDIR)","+\t\terr = setstatNoFollow(linkTarget, sftp.FileAttrFlags{Permissions: true}, &sftp.FileStat{Mode: 0o600})","+\t\trequire.ErrorIs(t, err, syscall.ENOTDIR)","+\t})","+","+\tt.Run(\"block symlink at end of path\", func(t *testing.T) {","+\t\ttempDir := newTempDir(t)","+\t\ttargetFile := filepath.Join(tempDir, \"foo.txt\")","+\t\trequire.NoError(t, os.WriteFile(targetFile, []byte(\"foo\"), 0o644))","+\t\tlink := filepath.Join(tempDir, \"link\")","+\t\trequire.NoError(t, os.Symlink(targetFile, link))","+","+\t\t_, err := openFileNoFollow(link, os.O_WRONLY|os.O_CREATE, 0o644)","+\t\trequire.ErrorIs(t, err, syscall.ELOOP)","+\t\terr = setstatNoFollow(link, sftp.FileAttrFlags{Permissions: true}, &sftp.FileStat{Mode: 0o600})","+\t\trequire.ErrorIs(t, err, syscall.ELOOP)","+\t})","+}"],"additions":248,"deletions":0,"truncated":false},{"path":"session/sftputils/sftp.go","lines":["@@ -193,7 +193,6 @@ func (n *NonRecursiveDirectoryTransferError) Error() string {"," func setstat(req *sftp.Request, fs FileSystem) error {"," \tattrFlags := req.AttrFlags()"," \tattrs := req.Attributes()","-"," \tif attrFlags.Acmodtime {"," \t\tatime := time.Unix(int64(attrs.Atime), 0)"," \t\tmtime := time.Unix(int64(attrs.Mtime), 0)",""],"additions":0,"deletions":1,"truncated":false}],"additions":550,"deletions":113,"truncated":false,"file_count":8},"error":null,"fetched_at":"2026-05-20T17:52:50.136941+00:00"}