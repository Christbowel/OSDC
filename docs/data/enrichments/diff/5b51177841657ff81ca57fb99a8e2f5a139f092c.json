t) (retErr error) {"," \t\treturn err"," \t}"," ","+\tif s.allowed != nil && req.Method == sftputils.MethodSetStat {","+\t\t// Setstat can be called during moderated file transfers, don't follow","+\t\t// symlinks if that's the case.","+\t\treturn setstatNoFollow(req.Filepath, req.AttrFlags(), req.Attributes())","+\t}","+"," \treturn sftputils.HandleFilecmd(req, nil /* local filesystem */)"," }"," ","@@ -381,3 +391,131 @@ func openFD(fd uintptr, name string) (*os.File, error) {"," "," \treturn file, nil"," }","+","+// openAtAndClose opens a file under the parent directory without following","+// symlinks, then closes the parent file. The parent file will be","+// closed even if this function returns an error.","+func openAtAndClose(parent *os.File, name string, flags int, mode os.FileMode) (*os.File, error) {","+\tdefer parent.Close()","+\tsyscallConn, err := parent.SyscallConn()","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\tvar childFd int","+\tvar openAtErr error","+\tctrlErr := syscallConn.Control(func(fd uintptr) {","+\t\tfor {","+\t\t\tchildFd, openAtErr = unix.Openat(int(fd), name, flags|unix.O_NOFOLLOW|unix.O_CLOEXEC, uint32(mode))","+\t\t\tif !errors.Is(openAtErr, syscall.EINTR) {","+\t\t\t\treturn","+\t\t\t}","+\t\t}","+\t})","+\tif ctrlErr != nil {","+\t\treturn nil, ctrlErr","+\t} else if openAtErr != nil {","+\t\treturn nil, openAtErr","+\t}","+\treturn os.NewFile(uintptr(childFd), filepath.Join(parent.Name(), name)), nil","+}","+","+// openFileNoFollow opens a file without following symlinks in any part of the path.","+func openFileNoFollow(file string, flags int, mode os.FileMode) (*os.File, error) {","+\tif !filepath.IsAbs(file) {","+\t\treturn nil, trace.BadParameter(\"file path must be absolute\")","+\t}","+\tdir, filename := filepath.Split(file)","+\trelDir, err := filepath.Rel(string(os.PathSeparator), dir)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\tparent, err := os.OpenFile(string(os.PathSeparator), readOnlyPath, 0)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\t// Open each directory one at a time to ensure no symlinks are followed.","+\tfor relDir != \"\" {","+\t\tvar part string","+\t\tpart, relDir, _ = strings.Cut(relDir, string(os.PathSeparator))","+\t\tparent, err = openAtAndClose(parent, part, unix.O_DIRECTORY|readOnlyPath, 0)","+\t\tif err != nil {","+\t\t\treturn nil, err","+\t\t}","+\t}","+\t// Set nonblock so we don't hang in case file is a pipe.","+\tf, err := openAtAndClose(parent, filename, flags|unix.O_NONBLOCK, mode)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\tinfo, err := f.Stat()","+\tif err != nil {","+\t\t_ = f.Close()","+\t\treturn nil, err","+\t}","+\tif !info.Mode().IsRegular() {","+\t\t_ = f.Close()","+\t\treturn nil, trace.BadParameter(\"path does not point to a regular file\")","+\t}","+\treturn f, nil","+}","+","+func chtimes(file *os.File, atime, mtime time.Time) error {","+\tsyscallConn, err := file.SyscallConn()","+\tif err != nil {","+\t\treturn err","+\t}","+\tvar modifyErr error","+\tctrlErr := syscallConn.Control(func(fd uintptr) {","+\t\tfor {","+\t\t\tmodifyErr = unix.Futimes(int(fd), []unix.Timeval{","+\t\t\t\tunix.NsecToTimeval(atime.UnixNano()),","+\t\t\t\tunix.NsecToTimeval(mtime.UnixNano()),","+\t\t\t})","+\t\t\tif !errors.Is(modifyErr, syscall.EINTR) {","+\t\t\t\treturn","+\t\t\t}","+\t\t}","+\t})","+\tif ctrlErr != nil {","+\t\treturn ctrlErr","+\t}","+\treturn modifyErr","+}","+","+// setstatNoFollow sets file attributes on a file without following any symlinks.","+func setstatNoFollow(file string, attrFlags sftp.FileAttrFlags, attrs *sftp.FileStat) error {","+\tif !attrFlags.Acmodtime && !attrFlags.Permissions && !attrFlags.Size && !attrFlags.UidGid {","+\t\treturn nil","+\t}","+\tmode := os.O_RDONLY","+\tif attrFlags.Size {","+\t\t// Only open in write mode if needed to truncate.","+\t\tmode = os.O_WRONLY","+\t}","+\tf, err := openFileNoFollow(file, mode, 0)","+\tif err != nil {","+\t\treturn err","+\t}","+\tdefer f.C