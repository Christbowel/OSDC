v >>> 8) & 0xff,","+    v & 0xff,","+","+    // Parse ........-####-....-....-............","+    (v = parseInt(uuid.slice(9, 13), 16)) >>> 8,","+    v & 0xff,","+","+    // Parse ........-....-####-....-............","+    (v = parseInt(uuid.slice(14, 18), 16)) >>> 8,","+    v & 0xff,","+","+    // Parse ........-....-....-####-............","+    (v = parseInt(uuid.slice(19, 23), 16)) >>> 8,","+    v & 0xff,","+","+    // Parse ........-....-....-....-############","+    // (Use \"/\" to avoid 32-bit truncation when bit-shifting high-order bytes)","+    ((v = parseInt(uuid.slice(24, 36), 16)) / 0x10000000000) & 0xff,","+    (v / 0x100000000) & 0xff,","+    (v >>> 24) & 0xff,","+    (v >>> 16) & 0xff,","+    (v >>> 8) & 0xff,","+    v & 0xff","+  );","+}","+","+export default parse;"],"additions":39,"deletions":0,"truncated":false},{"path":"js/src/utils/uuid/src/regex.ts","lines":["@@ -0,0 +1 @@","+export default /^(?:[0-9a-f]{8}-[0-9a-f]{4}-[1-8][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$/i;"],"additions":1,"deletions":0,"truncated":false},{"path":"js/src/utils/uuid/src/rng.ts","lines":["@@ -0,0 +1,7 @@","+// RNG values for use in UUID generation. This *must* use a high-quality source","+// of entropy, such as `crypto.getRandomValues()`.  And we reuse an array for","+// performance.","+const rnds8 = new Uint8Array(16);","+export default function rng() {","+  return crypto.getRandomValues(rnds8);","+}"],"additions":7,"deletions":0,"truncated":false},{"path":"js/src/utils/uuid/src/sha1.ts","lines":["@@ -0,0 +1,110 @@","+// Adapted from Chris Veness' SHA1 code at","+// http://www.movable-type.co.uk/scripts/sha1.html","+function f(s: 0 | 1 | 2 | 3, x: number, y: number, z: number) {","+  switch (s) {","+    case 0:","+      return (x & y) ^ (~x & z);","+    case 1:","+      return x ^ y ^ z;","+    case 2:","+      return (x & y) ^ (x & z) ^ (y & z);","+    case 3:","+      return x ^ y ^ z;","