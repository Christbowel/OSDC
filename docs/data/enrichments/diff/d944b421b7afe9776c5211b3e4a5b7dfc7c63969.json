 verifiable address by its value and channel.","+// Used by the notify_previous_addresses hook to persist the set of","+// addresses that should receive a change notification.","+type AddressRef struct {","+\tValue string `json:\"value\"`","+\tVia   string `json:\"via\"`","+}","+","+// SendVerifiableAddressChangedNotifications queues a change notification to","+// each target via the appropriate courier channel. Errors from individual","+// targets are collected and returned as a joined error but do not","+// short-circuit the batch — a failure to notify one recipient should not","+// prevent others from receiving their notification.","+func (m *Manager) SendVerifiableAddressChangedNotifications(","+\tctx context.Context,","+\ttargets []AddressRef,","+\ti *Identity,","+) (err error) {","+\tctx, span := m.r.Tracer(ctx).Tracer().Start(ctx, \"identity.Manager.SendVerifiableAddressChangedNotifications\")","+\tdefer otelx.End(span, &err)","+","+\tif len(targets) == 0 {","+\t\treturn nil","+\t}","+","+\tc, err := m.r.Courier(ctx)","+\tif err != nil {","+\t\treturn err","+\t}","+","+\tmodel, err := x.StructToMap(i)","+\tif err != nil {","+\t\treturn errors.WithStack(err)","+\t}","+\tchangedAt := time.Now().UTC().Format(time.RFC3339)","+","+\tvar errs []error","+\tfor _, t := range targets {","+\t\tswitch t.Via {","+\t\tcase AddressTypeEmail:","+\t\t\ttpl := email.NewVerifiableAddressChanged(m.r, &email.VerifiableAddressChangedModel{","+\t\t\t\tTo:        t.Value,","+\t\t\t\tIdentity:  model,","+\t\t\t\tChangedAt: changedAt,","+\t\t\t})","+\t\t\tif _, qerr := c.QueueEmail(ctx, tpl); qerr != nil {","+\t\t\t\tm.r.Logger().WithError(qerr).","+\t\t\t\t\tWithField(\"via\", t.Via).","+\t\t\t\t\tWarn(\"Failed to queue verifiable-address-change email.\")","+\t\t\t\terrs = append(errs, qerr)","+\t\t\t}","+\t\tcase AddressTypeSMS:","+\t\t\ttpl := sms.NewVerifiableAddressChanged(m.r, &sms.VerifiableAddressChangedModel{","+\t\t\t\tTo:        t.Value,","+\t\t\t\tIdentity:  model,","+\t\