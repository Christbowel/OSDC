vate IP access).","                 if !ep.allowed_ips.is_empty() {","                     lines.push(Line::from(vec![","-                        Span::styled(\"      Allowed IPs: \", styles::MUTED),","-                        Span::styled(ep.allowed_ips.join(\", \"), styles::TEXT),","+                        Span::styled(\"      Allowed IPs: \", t.muted),","+                        Span::styled(ep.allowed_ips.join(\", \"), t.text),","                     ]));","                 }"," ","@@ -1110,8 +1128,8 @@ fn render_policy_lines(","                             \"*\"","                         };","                         lines.push(Line::from(vec![","-                            Span::styled(\"      Allow: \", styles::MUTED),","-                            Span::styled(format!(\"{:<6} {}\", method, target), styles::TEXT),","+                            Span::styled(\"      Allow: \", t.muted),","+                            Span::styled(format!(\"{:<6} {}\", method, target), t.text),","                         ]));","                     }","                 }","@@ -1119,8 +1137,8 @@ fn render_policy_lines(","                 // Access preset (if set instead of explicit rules).","                 if !ep.access.is_empty() && ep.rules.is_empty() {","                     lines.push(Line::from(vec![","-                        Span::styled(\"      Access: \", styles::MUTED),","-                        Span::styled(ep.access.clone(), styles::TEXT),","+                        Span::styled(\"      Access: \", t.muted),","+                        Span::styled(ep.access.clone(), t.text),","                     ]));","                 }","             }","@@ -1129,8 +1147,8 @@ fn render_policy_lines(","             let binary_paths: Vec<&str> = rule.binaries.iter().map(|b| b.path.as_str()).collect();","             if !binary_paths.is_empty() {","                 lines.push(Line::from(vec![","-                    Span::styled(\"    Binaries: \", styles::MUTED),","-         