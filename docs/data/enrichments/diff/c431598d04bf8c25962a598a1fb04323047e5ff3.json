   api: mockApi,","+                models: {Settings: mockSettingsModel},","+                settingsCache: mockSettingsCache","+            });","+            manager.configure({siteUrl: 'https://example.com'});","+","+            await assert.rejects(","+                () => manager.createOrUpdateConfiguration('bpc_existing'),","+                {message: 'Stripe API error'}","+            );","+        });","+    });","+","+    describe('getConfigurationOptions', function () {","+        it('returns full configuration options by default', function () {","+            mockSettingsCache.get.withArgs('title').returns('My Ghost Site');","+","+            const manager = new BillingPortalManager({","+                api: mockApi,","+                models: {Settings: mockSettingsModel},","+                settingsCache: mockSettingsCache","+            });","+            manager.configure({siteUrl: 'https://example.com'});","+","+            const options = manager.getConfigurationOptions();","+","+            assert.deepEqual(options, {","+                business_profile: {","+                    headline: 'Manage your My Ghost Site subscription'","+                },","+                features: {","+                    invoice_history: {enabled: true},","+                    payment_method_update: {enabled: true},","+                    subscription_cancel: {enabled: true}","+                },","+                default_return_url: 'https://example.com'","+            });","+        });","+","+        it('returns everything except the profile when updateOnly is true', function () {","+            mockSettingsCache.get.withArgs('title').returns('My Ghost Site');","+","+            const manager = new BillingPortalManager({","+                api: mockApi,","+                models: {Settings: mockSettingsModel},","+                settingsCache: mockSettingsCache","+            });","+            manager.configure({siteUrl: 'https://example.com'});","+","+      