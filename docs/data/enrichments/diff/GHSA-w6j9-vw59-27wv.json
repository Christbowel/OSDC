teAddr: \"\", want: false},","+\t}","+\tfor _, tc := range tests {","+\t\tt.Run(tc.name, func(t *testing.T) {","+\t\t\treq := &http.Request{RemoteAddr: tc.remoteAddr}","+\t\t\trequire.Equal(t, tc.want, isRequestFromTrustedProxy(req))","+\t\t})","+\t}","+}"],"additions":48,"deletions":0,"truncated":false},{"path":"templates/admin/config.tmpl","lines":["@@ -306,6 +306,8 @@"," \t\t\t\t\t\t<dd><i class=\"fa fa{{if .Auth.EnableReverseProxyAutoRegistration}}-check{{end}}-square-o\"></i></dd>"," \t\t\t\t\t\t<dt>{{.i18n.Tr \"admin.config.auth.reverse_proxy_authentication_header\"}}</dt>"," \t\t\t\t\t\t<dd><code>{{.Auth.ReverseProxyAuthenticationHeader}}</code></dd>","+\t\t\t\t\t\t<dt>{{.i18n.Tr \"admin.config.auth.trusted_proxy_ips\"}}</dt>","+\t\t\t\t\t\t<dd><code>{{Join .Auth.TrustedProxyIPs \", \"}}</code></dd>"," \t\t\t\t\t\t<dt>{{.i18n.Tr \"admin.config.auth_custom_logout_url\"}}</dt>"," \t\t\t\t\t\t<dd>"," \t\t\t\t\t\t\t{{if .Auth.CustomLogoutURL}}",""],"additions":2,"deletions":0,"truncated":false}],"additions":111,"deletions":2,"truncated":false,"file_count":9},"error":null,"fetched_at":"2026-06-23T10:51:51.893717+00:00"}