ry/x/httpx\""," ","+\t\"github.com/stretchr/testify/assert\""," \t\"github.com/stretchr/testify/require\""," )"," ","@@ -74,3 +79,92 @@ func TestSchemaValidator(t *testing.T) {"," \t\t})"," \t}"," }","+","+// TestSchemaValidator_FileRefExfiltration asserts that identity schemas","+// cannot exfiltrate server-side files via `$ref: \"file://...\"`. The jsonschema","+// `file` loader is registered process-wide so operator-configured top-level","+// `file://` schemas still work, but per-compiler $ref resolution must reject","+// the `file` scheme.","+func TestSchemaValidator_FileRefExfiltration(t *testing.T) {","+\tt.Parallel()","+","+\tdir := t.TempDir()","+\tsecretContents := `\"LEAKED_COOKIE_SECRET_VALUE\"`","+","+\tschemaWithRef := func(refURL string) string {","+\t\treturn fmt.Sprintf(`{","+\t\t\t\"$id\": \"https://test.example.com/probe.schema.json\",","+\t\t\t\"$schema\": \"http://json-schema.org/draft-07/schema#\",","+\t\t\t\"type\": \"object\",","+\t\t\t\"properties\": {","+\t\t\t\t\"traits\": {","+\t\t\t\t\t\"type\": \"object\",","+\t\t\t\t\t\"properties\": {","+\t\t\t\t\t\t\"email\": {","+\t\t\t\t\t\t\t\"type\": \"string\",","+\t\t\t\t\t\t\t\"format\": \"email\",","+\t\t\t\t\t\t\t\"ory.sh/kratos\": {","+\t\t\t\t\t\t\t\t\"credentials\": {","+\t\t\t\t\t\t\t\t\t\"password\": {\"identifier\": true}","+\t\t\t\t\t\t\t\t}","+\t\t\t\t\t\t\t}","+\t\t\t\t\t\t},","+\t\t\t\t\t\t\"field\": {\"$ref\": %q}","+\t\t\t\t\t},","+\t\t\t\t\t\"required\": [\"email\"]","+\t\t\t\t}","+\t\t\t}","+\t\t}`, refURL)","+\t}","+","+\tserveSchema := func(t *testing.T, body string) string {","+\t\tmux := http.NewServeMux()","+\t\tmux.HandleFunc(\"/schema\", func(w http.ResponseWriter, r *http.Request) {","+\t\t\tw.Header().Set(\"Content-Type\", \"application/json\")","+\t\t\t_, _ = w.Write([]byte(body))","+\t\t})","+\t\tts := httptest.NewServer(mux)","+\t\tt.Cleanup(ts.Close)","+\t\treturn ts.URL + \"/schema\"","+\t}","+","+\tctx := context.WithValue(context.Background(), httploader.ContextKey, httpx.NewResilientClient())","+","+\tt.Run(\"case=file ref is rejected before any file access\", func(t *testing.T) {","+\t\tt.Parallel()","+\t\t// Fragment that would pass validation if the file were read, and fail","+\t\t// if not. Its contents are a valid JSON-schema fragment.","+\t\tschemaFragment := fmt.Sprintf(`{\"type\": \"string\", \"const\": %s}`, secretContents)","+\t\tfragmentPath := filepath.Join(dir, \"fragment.json\")","+\t\trequire.NoError(t, os.WriteFile(fragmentPath, []byte(schemaFragment), 0o600))","+","+\t\tu := serveSchema(t, schemaWithRef(\"file://\"+fragmentPath))","+","+\t\tt.Run(\"with disallowRefs=true\", func(t *testing.T) {","+\t\t\terr := NewValidator().Validate(ctx, u,","+\t\t\t\tjson.RawMessage(`{\"traits\": {\"email\": \"a@b.c\", \"field\": \"wrong\"}}`),","+\t\t\t\tWithDisallowRefs(true))","+\t\t\trequire.Error(t, err)","+","+\t\t\t// The file scheme must be rejected, and the file contents must not","+\t\t\t// leak into the error.","+\t\t\tvar he *herodot.DefaultError","+\t\t\trequire.True(t, stderrors.As(err, &he))","+\t\t\tassert.Contains(t, he.Debug(), `\"file\"`, \"rejected scheme should appear in cause\")","+\t\t\tassert.NotContains(t, he.Error(), \"LEAKED_COOKIE_SECRET_VALUE\")","+\t\t\tassert.NotContains(t, he.Debug(), \"LEAKED_COOKIE_SECRET_VALUE\")","+\t\t})","+","+\t\tt.Run(\"with disallowRefs=false preserves legacy exfiltration\", func(t *testing.T) {","+\t\t\t// When the feature flag is off (default for existing deployments),","+\t\t\t// the legacy behavior must remain: the $ref is dereferenced and","+\t\t\t// the file contents flow into validation errors. This documents","+\t\t\t// the intentional opt-in nature of the mitigation.","+\t\t\terr := NewValidator().Validate(ctx, u,","+\t\t\t\tjson.RawMessage(`{\"traits\": {\"email\": \"a@b.c\", \"field\": \"wrong\"}}`))","+\t\t\trequire.Error(t, err)","+\t\t\tassert.Contains(t, err.Error(), \"LEAKED_COOKIE_SECRET_VALUE\",","+\t\t\t\t\"with the flag off, the file contents should still be reachable — this test documents the exploitable default\")","+\t\t})","+\t})","+}"],"additions":94,"deletions":0,"truncated":false},{"path":"selfservice/flow/login/extension_identifier_label.go","lines":["@@ -9,16 +9,18 @@ import ("," \t\"github.com/ory/kratos/text\""," \t\"github.com/ory/x/jsonschemax\""," ","-\t\"github.com/ory/jsonschema/v3\""," \t\"github.com/ory/kratos/schema\""," )"," ","-func GetIdentifierLabelFromSchema(ctx context.Context, schemaURL string) (*text.Message, error) {","+func GetIdentifierLabelFromSchema(ctx context.Context, schemaURL string, disallowRefs bool) (*text.Message, error) {"," \trunner, err := schema.NewExtensionRunner(ctx)"," \tif err != nil {"," \t\treturn nil, err"," \t}","-\tc := jsonschema.NewCompiler()","+\tc, err := schema.NewCompilerWithURL(ctx, schemaURL, disallowRefs)","+\tif err != nil {","+\t\treturn nil, err","+\t}"," \tc.ExtractAnnotations = true"," \trunner.Register(c)"," "],"additions":5,"deletions":3,"truncated":false},{"path":"selfservice/flow/login/extension_identifier_label_test.go","lines":["@@ -150,7 +150,7 @@ func TestGetIdentifierLabelFromSchema(t *testing.T) {"," \t\t},"," \t} {"," \t\tt.Run(tc.name, func(t *testing.T) {","-\t\t\tlabel, err := GetIdentifierLabelFromSchema(t.Context(), constructSchema(t, tc.emailConfig, tc.usernameConfig))","+\t\t\tlabel, err := GetIdentifierLabelFromSchema(t.Context(), constructSchema(t, tc.emailConfig, tc.usernameConfig), true)"," \t\t\trequire.NoError(t, err)"," \t\t\tassert.Equal(t, tc.expected, label)"," \t\t})"],"additions":1,"deletions":1,"truncated":false},{"path":"selfservice/strategy/code/strategy.go","lines":["@@ -302,7 +302,7 @@ func (s *Strategy) populateChooseMethodFlow(r *http.Request, f flow.Flow) error"," \t\t\t\t\tWithMetaLabel(text.NewInfoSelfServiceLoginAAL2CodeAddress(string(address.Via), address.To)))"," \t\t\t}"," \t\t} else {","-\t\t\tidentifierLabel, err := login.GetIdentifierLabelFromSchema(ctx, ds.String())","+\t\t\tidentifierLabel, 