{"id":"5bb332b7aaf952e28680b0ed3c7c0b559532eeb1","axis":"silent","repo":"owncloud/core","sha":"5bb332b7aaf952e28680b0ed3c7c0b559532eeb1","parsed":{"files":[{"path":"changelog/unreleased/41418","lines":["@@ -0,0 +1,14 @@","+Bugfix: Fix htaccess RewriteBase rules blocking API requests by file extension","+","+Files whose names end in extensions like .jpg, .png, .svg, .json and others","+could not be marked as favorites or have their tags updated via the files API","+when htaccess.RewriteBase was configured. The .htaccess rules generated by","+`occ maintenance:update:htaccess` used a URI extension check to skip routing","+through index.php, which inadvertently blocked API requests to paths like","+`/apps/files/api/v1/files/photo.jpg`, returning 405 Method Not Allowed.","+","+The fix replaces the extension-based condition with `RewriteCond","+%{REQUEST_FILENAME} !-f`, which correctly routes virtual API paths through","+index.php while still serving actual static files directly.","+","+https://github.com/owncloud/core/issues/41418"],"additions":14,"deletions":0,"truncated":false},{"path":"core/Command/Maintenance/UpdateHtaccess.php","lines":["@@ -32,7 +32,7 @@ protected function configure() {"," \t}"," "," \tprotected function execute(InputInterface $input, OutputInterface $output): int {","-\t\t\\OC\\Setup::updateHtaccess();","+\t\t\\OC\\Setup::updateHtaccess(\\OC::$server->getConfig());"," \t\t$output->writeln('.htaccess has been updated');"," \t\treturn 0;"," \t}"],"additions":1,"deletions":1,"truncated":false},{"path":"lib/private/Setup.php","lines":["@@ -390,7 +390,7 @@ public function install(array $options): array {"," \t\t\t\t&& \\is_writable(self::pathToHtaccess())"," \t\t\t) {"," \t\t\t\t// Update .htaccess files","-\t\t\t\tself::updateHtaccess();","+\t\t\t\tself::updateHtaccess($config);"," \t\t\t}"," \t\t\tself::protectDataDirectory();"," ","@@ -450,8 +450,7 @@ public static function pathToHtaccess(): string {"," \t/**"," \t * Append the correct ErrorDocument path for Apache hosts"," \t */","-\tpublic static function updateHtaccess(): void {","-\t\t$config = \\OC::$server->getConfig();","+\tpublic static function updateHtaccess(\\OCP\\IConfig $config): void {"," \t\t$il10n = \\OC::$server->getL10N('lib');"," "," \t\t// For CLI read the value from overwrite.cli.url","@@ -499,8 +498,7 @@ public static function updateHtaccess(): void {"," \t\t\t$content .= \"\\n  RewriteRule ^favicon.ico$ core/img/favicon.ico [L]\";"," \t\t\t$content .= \"\\n  RewriteRule ^core/js/oc.js$ index.php [PT,E=PATH_INFO:$1]\";"," \t\t\t$content .= \"\\n  RewriteRule ^core/preview.png$ index.php [PT,E=PATH_INFO:$1]\";","-\t\t\t$content .= \"\\n  RewriteCond %{REQUEST_URI} !\\\\.(css|js|svg|gif|png|html|ttf|woff|ico|jpg|jpeg|json|properties)$\";","-\t\t\t$content .= \"\\n  RewriteCond %{REQUEST_URI} !\\\\.(min|js|auto)\\\\.map$\";","+\t\t\t$content .= \"\\n  RewriteCond %{REQUEST_FILENAME} !-f\";"," \t\t\t$content .= \"\\n  RewriteCond %{REQUEST_URI} !^$rewriteBaseRe/core/img/favicon\\\\.ico$\";"," \t\t\t$content .= \"\\n  RewriteCond %{REQUEST_URI} !^$rewriteBaseRe/robots\\\\.txt$\";"," \t\t\t$content .= \"\\n  RewriteCond %{REQUEST_URI} !^$rewriteBaseRe/remote\\\\.php\";"],"additions":3,"deletions":5,"truncated":false},{"path":"lib/private/Updater.php","lines":["@@ -243,7 +243,7 @@ private function doUpgrade($currentVersion, $installedVersion) {"," \t\t\t\t&& \\is_writable(Setup::pathToHtaccess())"," \t\t\t) {"," \t\t\t\t// Update .htaccess files","-\t\t\t\tSetup::updateHtaccess();","+\t\t\t\tSetup::updateHtaccess($this->config);"," \t\t\t}"," \t\t\tSetup::protectDataDirectory();"," \t\t} catch (\\Exception $e) {"],"additions":1,"deletions":1,"truncated":false},{"path":"tests/lib/SetupTest.php","lines":["@@ -146,7 +146,7 @@ public function testCannotUpdateHtaccess(): void {"," \t\t\\chmod($htaccessFile, 0400);"," \t\t\\OC::$SERVERROOT = \\OC::$SERVERROOT . '/tests/data';"," \t\ttry {","-\t\t\t$this->setupClass->updateHtaccess();","+\t\t\t$this->setupClass->updateHtaccess($this->config);"," \t\t} catch (\\Exception $e) {"," \t\t\tthrow $e;"," \t\t} finally {","@@ -168,7 +168,7 @@ public function testHtaccessIsFolder(): void {"," \t\t"," \t\t\\OC::$SERVERROOT = \\OC::$SERVERROOT . '/tests/data';"," \t\ttry {","-\t\t\t$this->setupClass->updateHtaccess();","+\t\t\t$this->setupClass->updateHtaccess($this->config);"," \t\t} catch (\\Exception $e) {"," \t\t\tthrow $e;"," \t\t} finally {","@@ -184,7 +184,7 @@ public function testUpdateHtaccess(): void {"," \t\t\\chmod($htaccessFile, 0700);"," \t\t\\OC::$SERVERROOT = \\OC::$SERVERROOT . '/tests/data';"," \t\ttry {","-\t\t\t$this->setupClass->updateHtaccess();","+\t\t\t$this->setupClass->updateHtaccess($this->config);"," \t\t} catch (\\Exception $e) {"," \t\t\tthrow $e;"," \t\t} finally {","@@ -197,4 +197,44 @@ public function testUpdateHtaccess(): void {"," \t\t\t$content"," \t\t);"," \t}","+","+\tpublic function testUpdateHtaccessWithRewriteBaseUsesFileExistenceCheck(): void {","+\t\t$origServerRoot = \\OC::$SERVERROOT;","+\t\t$htaccessFile = \\OC::$SERVERROOT . '/tests/data/.htaccess';","+\t\t\\touch($htaccessFile);","+\t\t\\chmod($htaccessFile, 0700);","+\t\t\\OC::$SERVERROOT = \\OC::$SERVERROOT . '/tests/data';","+","+\t\t$this->config->method('getSystemValue')","+\t\t\t->willReturnCallback(function ($key, $default = null) {","+\t\t\t\tif ($key === 'htaccess.RewriteBase') {","+\t\t\t\t\treturn '/owncloud';","+\t\t\t\t}","+\t\t\t\tif ($key === 'overwrite.cli.url') {","+\t\t\t\t\treturn 'http://localhost/owncloud';","+\t\t\t\t}","+\t\t\t\treturn $default;","+\t\t\t});","+","+\t\ttry {","+\t\t\t$this->setupClass->updateHtaccess($this->config);","+\t\t} catch (\\Exception $e) {","+\t\t\tthrow $e;","+\t\t} finally {","+\t\t\t\\OC::$SERVERROOT = $origServerRoot;","+\t\t}","+\t\t$content = \\file_get_contents($htaccessFile);","+\t\t@\\unlink($htaccessFile);","+","+\t\t// Must use file-existence check, not extension pattern","+\t\t$this->assertStringContainsString(","+\