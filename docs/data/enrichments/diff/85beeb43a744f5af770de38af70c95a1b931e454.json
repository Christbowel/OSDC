_pruning_awareness: <bool> | default = false]","+","     # Compaction related overrides","     compaction:","       # Per-user block retention. If this value is set to 0 (default),"],"additions":7,"deletions":0,"truncated":false},{"path":"modules/livestore/instance_search.go","lines":["@@ -23,6 +23,7 @@ import ("," \t\"google.golang.org/grpc/status\""," "," \t\"github.com/go-kit/log/level\"","+\t\"github.com/grafana/tempo/modules/overrides\""," \t\"github.com/grafana/tempo/pkg/api\""," \t\"github.com/grafana/tempo/pkg/boundedwaitgroup\""," \t\"github.com/grafana/tempo/pkg/collector\"","@@ -249,6 +250,7 @@ func (i *instance) Search(ctx context.Context, req *tempopb.SearchRequest) (*tem"," \t\t\tfor _, name := range req.SkipASTTransformations {"," \t\t\t\tsearchOpts = append(searchOpts, traceql.WithSkipOptimization(name))"," \t\t\t}","+\t\t\tsearchOpts = append(searchOpts, overrides.SpanPruningAwarenessCompileOptions(i.overrides.SpanPruningAwareness(i.tenantID))...)"," \t\t\tresp, err = traceql.NewEngine().ExecuteSearch(ctx, req, f, searchOpts...)"," \t\t} else {"," \t\t\tresp, err = b.Search(ctx, req, opts)","@@ -740,6 +742,8 @@ func (i *instance) QueryRange(ctx context.Context, req *tempopb.QueryRangeReques"," \t\tcompileOpts = append(compileOpts, traceql.WithSpanOnlyFetch(*p))"," \t}"," ","+\tcompileOpts = append(compileOpts, overrides.SpanPruningAwarenessCompileOptions(i.overrides.SpanPruningAwareness(i.tenantID))...)","+"," \t// Compile the raw version of the query for head and wal blocks"," \t// These aren't cached and we put them all into the same evaluator"," \t// for efficiency."],"additions":4,"deletions":0,"truncated":false},{"path":"modules/overrides/config.go","lines":["@@ -179,6 +179,11 @@ type ReadOverrides struct {"," \t// MetricsSpanOnlyFetch, when set, enables or disables the new fetch layer by default for TraceQL metrics queries"," \t// for this tenant.  When not set, then the default behavior is used. Maybe be overridden by query hints."," \tMetric