 {","+\t\treturn []Span{","+\t\t\tnewMockSpan(nil).WithStartTime(uint64(1*time.Second)).WithSpanString(\"service\", \"baseline\"),","+\t\t\tnewMockSpan(nil).WithStartTime(uint64(2*time.Second)).WithSpanString(\"service\", \"selected\"),","+\t\t}","+\t}","+","+\trun := func(t *testing.T, query string, step uint64, makeSpans func() []Span, opts ...CompileOption) (MetricsEvaluator, map[string]int64) {","+\t\tt.Helper()","+\t\treq := &tempopb.QueryRangeRequest{","+\t\t\tStart: 1,","+\t\t\tEnd:   uint64(3 * time.Second),","+\t\t\tStep:  step,","+\t\t\tQuery: query,","+\t\t}","+\t\teval, err := NewEngine().CompileMetricsQueryRange(req, opts...)","+\t\trequire.NoError(t, err)","+\t\trequire.NoError(t, eval.Do(ctx, &fakeSpanFetcher{makeSpans}, 0, 0, 0))","+\t\treturn eval, eval.Metrics().AdditionalMetrics","+\t}","+","+\tt.Run(\"watcher installed and summary span present\", func(t *testing.T) {","+\t\t_, got := run(t, `{} | rate()`, uint64(time.Second), withSummary, summaryWatcher(t))","+\t\trequire.Equal(t, int64(1), got[summaryKey])","+\t})","+","+\tt.Run(\"watcher installed but no summary span\", func(t *testing.T) {","+\t\t_, got := run(t, `{} | rate()`, uint64(time.Second), withoutSummary, summaryWatcher(t))","+\t\t_, ok := got[summaryKey]","+\t\trequire.False(t, ok, \"no summary metric when no matched span carries the attribute\")","+\t})","+","+\tt.Run(\"no watcher installed\", func(t *testing.T) {","+\t\t_, got := run(t, `{} | rate()`, uint64(time.Second), withSummary)","+\t\t_, ok := got[summaryKey]","+\t\trequire.False(t, ok, \"no metric when no watcher is installed\")","+\t})","+","+\t// Metric math produces multiple sub-pipeline evaluators that share one","+\t// request-scoped watcher. Both operands here match the summary span, so the","+\t// old per-pipeline design would count it twice; it must be counted once.","+\t// Guards the batchMetricsEvaluator request-scoping fix.","+\tt.Run(\"math counts summary once across sub-pipelines\", func(t *testing.T) {","+\t\tquery := `({} | count_over_time()) / ({ .service=\"selected\" } | count_over_time())`","+\t\teval, got := run(t, query, uint64(2*time.Second), withSummary, summaryWatcher(t))","+","+\t\tbatch, ok := eval.(*batchMetricsEvaluator)","+\t\trequire.True(t, ok)","+\t\trequire.Greater(t, len(batch.evals), 1, \"metric math should produce multiple sub-pipelines\")","+\t\trequire.Equal(t, int64(1), got[summaryKey], \"counted once, not once per sub-pipeline\")","+\t})","+}","+"," func runTraceQLMetric(req *tempopb.QueryRangeRequest, inSpans ...[]Span) (SeriesSet, int, error) {"," \tres, err := processLayer1AndLayer2(req, inSpans...)"," \tif err != nil {"],"additions":96,"deletions":9,"truncated":false},{"path":"pkg/traceql/options.go","lines":["@@ -11,6 +11,8 @@ type compileOptions struct {"," \t// metrics query only"," \tspanOnlyFetch     *bool"," \ttimeOverlapCutoff float64","+","+\twatchers []SpanWatcher"," }"," "," func applyCompileOptions(opts ...CompileOption) compileOptions {","@@ -53,3 +55,12 @@ func WithTimeOverlapCutoff(v float64) CompileOption {"," \t\to.timeOverlapCutoff = v"," \t}"," }","+","+// WithWatchers installs span watchers on the query.","+// Watchers inspect matched spans to gather extra on-demand metrics.","+// They are typically installed from per-tenant overrides and shared across a request's sub-queries.","+func WithWatchers(watchers ...SpanWatcher) CompileOption {","+\treturn func(o *compileOptions) {","+\t\to.watchers = append(o.watchers, watchers...)","+\t}","+}"],"additions":11,"deletions":0,"truncated":false},{"path":"pkg/traceql/storage.go","lines":["@@ -15,8 +15,10 @@ type Condition struct {"," \tAttribute Attribute"," \tOp        Operator"," \tOperands  Operands","-\t// Callback is used in the parquetquery.CallbackPredicate to determine if the iterator should be stopped.","-\t// It's used to limit the overhead of fetching exemplars by stopping the iterator early.","+\t// CallBack is invoked by parquetquery.CallbackPredicate to gate whether the","+\t// column scan continues going. Returning","+\t// false ends the column scan early (e.g. once a watcher no longer needs the","+\t// attribute); it does not terminate the overall spanset fetch."," \tCallBack func() bool"," "," \t// Hints"],"additions":4,"deletions":2,"truncated":false},{"path":"pkg/traceql/watch.go","lines":["@@ -0,0 +1,178 @@","+package traceql","+","+import (","+\t\"sync\"","+\t\"sync/atomic\"","+)","+","+const SpanPruningAttribute = \"aggregation.is_summary\"","+","+// NewSpanPruningWatcher returns a watcher that reports whether any matched span is a span-pruning summary span.","+func NewSpanPruningWatcher() SpanWatcher {","+\treturn NewAttributePresenceWatcher(NewAttribute(SpanPruningAttribute), SpanPruningAttribute)","+}","+","+// SpanWatcher inspects spans as they flow through the TraceQL engine and records something about them.","+type SpanWatcher interface {","+\t// Conditions returns the fetch conditions the watcher needs so the attributes it cares about are loaded onto watched spans.","+\tConditions() []Condition","+\t// WatchSpan inspects a single span.","+\t// It returns true while the watcher is still interested in further spans.","+\tWatchSpan(Span) bool","+\t// Active reports whether the watcher still wants to see spans.","+\tActive() bool","+\t// Stats returns the metrics gathered so far, keyed by metric name.","+\tStats() map[string]int64","+}","+","+var _ SpanWatcher = (*attrPresenceWatcher)(nil)","+","+type attrPresenceWatcher struct {","+\tattr      Attribute","+\tmetricKey string","+\tactive    atomic.Bool","+}","+","+// NewAttributePresenceWatcher returns an watcher that records whether any watched span carries attr.","+// When the attribute is seen, Stats reports a count of 1 under metricKey.","+func NewAttributePresenceWatcher(attr Attribute, metricKey string) SpanWatcher {","+\to := &attrPresenceWatcher{attr: attr, metricKey: metricKey}","+\to.active.Store(true)","+\treturn o","+}","+","+func (a *attrPresenceWatcher) Conditions() []Condition {","+\treturn []Condition{{Attribute: a.attr, Op: OpNone, CallBack: a.active.Load}}","+}","+","+func (a *attrPresenceWatcher) WatchSpan(span Span) bool {","+\tif !a.active.Load() {","+\t\treturn false // already found; no longer interested","+\t}","+\tif _, ok := span.AttributeFor(a.attr); ok {","+\t\ta.active.Store(false)","+\t\treturn false // found it; done","+\t}","+\treturn true // keep looking","+}","+","+func (a *attrPresenceWatcher) Active() bool {","+\treturn a.active.Load()","+}","+","+func (a *attrPresenceWatcher) Stats() map[string]int64 {","+\tif a.active.Load() {","+\t\treturn nil","+\t}","+\treturn map[string]int64{a.metricKey: 1}","+}","+","+// spanWatchers keeps all watchers but partitions them:","+// (1) obs[:active] are still active","+// (2) obs[active:] have gone inactive.","+// Inactive watchers are never dropped, only moved past the boundary, so WatchSpans only walks the active prefix.","+type spanWatchers struct {","+\tmtx    sync.Mutex","+\tobs    []SpanWatcher","+\tactive int","+}","+","+func (s *spanWatchers) Add(watchers ...SpanWatcher) {","+\ts.mtx.Lock()","+\tdefer s.mtx.Unlock()","+","+\tfor _, o := range watchers {","+\t\ts.obs = append(s.obs, o)","+\t\tif o.Active() {","+\t\t\t// Swap the newly-added active watcher into the active boundary so the","+\t\t\t// obs[:active] partition holds regardless of add order or whether any","+\t\t\t// already-added watcher has gone inactive.","+\t\t\tlast := len(s.obs) - 1","+\t\t\ts.obs[s.active], s.obs[last] = s.obs[last], s.obs[s.active]","+\t\t\ts.active++","+\t\t}","+\t}","+}","+","+func (s *spanWatchers) Conditions() []Condition {","+\ts.mtx.Lock()","+\tdefer s.mtx.Unlock()","+","+\t// Only the active watchers need their attributes fetched.","+\tconds := make([]Condition, 0, s.active)","+\tfor _, watcher := range s.obs[:s.active] {","+\t\tconds = append(conds, watcher.Conditions()...)","+\t}","+\treturn conds","+}","+","+func (s *spanWatchers) WatchSpans(spans []*Spanset) {","+\ts.mtx.Lock()","+\tdefer s.mtx.Unlock()","+","+\tif s.active == 0 {","+\t\treturn // done, exit early","+\t}","+","+outer:","+\tfor _, ss := range spans {","+\t\tfor _, span := range ss.Spans {","+\t\t\ts.watch(span)","+\t\t\tif s.active == 0 {","+\t\t\t\tbreak outer","+\t\t\t}","+\t\t}","+\t}","+}","+","+// WatchSpan feeds a single span to the active watchers.","+// It's the per-span equivalent of WatchSpans,","+// used by hot paths that already iterate spans individually (e.g. the span-only metrics fetch) to avoid allocating a Spanset.","+// It returns whether any watchers remain active, so callers can stop","+// calling (and paying for the mutex) once all watchers are done.","+func (s *spanWatchers) WatchSpan(span Span) bool {","+\ts.mtx.Lock()","+\tdefer s.mtx.Unlock()","+","+\tif s.active == 0 {","+\t\treturn false // done, exit early","+\t}","+","+\ts.watch(span)","+\treturn s.active > 0","+}","+","+// watch walks the active prefix for a single span.","+// When a watcher goes inactive, swap it past the boundary so it's retained but skipped on future calls.","+// Caller must hold s.mtx.","+func (s *spanWatchers) watch(span Span) {","+\tfor i := 0; i < s.active; {","+\t\tif s.obs[i].WatchSpan(span) {","+\t\t\ti++","+\t\t\tcontinue","+\t\t}","+\t\ts.active--","+\t\ts.obs[i], s.obs[s.active] = s.obs[s.active], s.obs[i]","+\t\t// don't advance i: re-check the watcher swapped into position i","+\t}","+}","+","+func (s *spanWatchers) Active() bool {","+\ts.mtx.Lock()","+\tdefer s.mtx.Unlock()","+","+\treturn s.active > 0","+}","+","+func (s *spanWatchers) Stats() map[string]int64 {","+\ts.mtx.Lock()","+\tdefer s.mtx.Unlock()","+","+\tstats := make(map[string]int64)","+\tfor _, watcher := range s.obs {","+\t\tfor k, v := range watcher.Stats() {","+\t\t\tstats[k] += v","+\t\t}","+\t}","+\treturn stats","+}"],"additions":178,"deletions":0,"truncated":false},{"path":"pkg/traceql/watch_test.go","lines":["@@ -0,0 +1,248 @@","+package traceql","+","+import (","+\t\"context\"","+\t\"testing\"","+\t\"time\"","+","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+","+\t\"github.com/grafana/tempo/pkg/tempopb\"","+)","+","+func TestAttrPresenceWatcher(t *testing.T) {","+\tattr := NewAttribute(\"aggregation.is_summary\")","+\tconst metricKey = \"myMetric\"","+","+\tt.Run(\"attribute absent\", func(t *testing.T) {","+\t\to := NewAttributePresenceWatcher(attr, metricKey)","+","+\t\t// A span without the attribute keeps the watcher interested.","+\t\tkeepLooking := o.WatchSpan(newMockSpan([]byte{1}).WithSpanString(\"foo\", \"bar\"))","+\t\tassert.True(t, keepLooking, \"watcher should keep looking\")","+\t\tassert.True(t, o.Active())","+\t\tassert.Nil(t, o.Stats(), \"no stats until the attribute is seen\")","+\t})","+","+\tt.Run(\"attribute present\", func(t *testing.T) {","+\t\to := NewAttributePresenceWatcher(attr, metricKey)","+","+\t\tkeepLooking := o.WatchSpan(newMockSpan([]byte{1}).WithAttrBool(\"aggregation.is_summary\", true))"],"additions":31,"deletions":0,"truncated":false}],"additions":466,"deletions":34,"truncated":true,"file_count":18},"error":null,"fetched_at":"2026-07-14T09:32:16.634260+00:00"}