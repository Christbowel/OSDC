gs(want)","+\t\t\tif !reflect.DeepEqual(gotPkgs, want) {","+\t\t\t\tt.Errorf(\"PkgPaths = %v, want %v\", gotPkgs, want)","+\t\t\t}","+","+\t\t\tfor _, tgt := range result {","+\t\t\t\tgens := tgt.Generators(ctx)","+\t\t\t\tif len(gens) != 1 {","+\t\t\t\t\tt.Errorf(\"pkg %q: got %d generators, want 1\", tgt.Path(), len(gens))","+\t\t\t\t\tcontinue","+\t\t\t\t}","+\t\t\t\tgdc, ok := gens[0].(*genDeepCopy)","+\t\t\t\tif !ok {","+\t\t\t\t\tt.Errorf(\"pkg %q: generator type = %T, want *genDeepCopy\", tgt.Path(), gens[0])","+\t\t\t\t\tcontinue","+\t\t\t\t}","+\t\t\t\tif want, ok := tc.wantAllTypes[tgt.Path()]; ok && gdc.allTypes != want {","+\t\t\t\t\tt.Errorf(\"pkg %q: allTypes = %v, want %v\", tgt.Path(), gdc.allTypes, want)","+\t\t\t\t}","+\t\t\t\tif want, ok := tc.wantRegister[tgt.Path()]; ok && gdc.registerTypes != want {","+\t\t\t\t\tt.Errorf(\"pkg %q: registerTypes = %v, want %v\", tgt.Path(), gdc.registerTypes, want)","+\t\t\t\t}","+\t\t\t}","+\t\t})","+\t}","+}"],"additions":223,"deletions":0,"truncated":false},{"path":"staging/src/k8s.io/code-generator/cmd/defaulter-gen/args/args.go","lines":["@@ -21,6 +21,7 @@ import ("," "," \t\"github.com/spf13/pflag\""," ","+\t\"k8s.io/code-generator/pkg/apidefinitions\""," \t\"k8s.io/gengo/v2\""," )"," ","@@ -34,6 +35,8 @@ type Args struct {"," \t// groups of generators (external API that depends on Kube generations) should"," \t// keep tags distinct as well."," \tGeneratedBuildTag string","+","+\tapidefinitions.LintArgs"," }"," "," // New returns default arguments for the generator.","@@ -52,6 +55,7 @@ func (args *Args) AddFlags(fs *pflag.FlagSet) {"," \tfs.StringVar(&args.GoHeaderFile, \"go-header-file\", \"\","," \t\t\"the path to a file containing boilerplate header text; the string \\\"YEAR\\\" will be replaced with the current 4-digit year\")"," \tfs.StringVar(&args.GeneratedBuildTag, \"build-tag\", args.GeneratedBuildTag, \"A Go build tag to use to identify files generated by this command. Should be unique.\")","+\ta