y-gen/args\"","+\t\"k8s.io/gengo/v2/generator\"","+\t\"k8s.io/gengo/v2/types\"","+)","+","+// copyableStruct returns a struct type with a single primitive int32 field.","+// copyableType in deepcopy.go accepts a non-private struct kind.","+func copyableStruct(pkgPath, name string, comments []string) *types.Type {","+\treturn &types.Type{","+\t\tName:         types.Name{Package: pkgPath, Name: name},","+\t\tKind:         types.Struct,","+\t\tCommentLines: comments,","+\t\tMembers: []types.Member{","+\t\t\t{Name: \"X\", Type: types.Int32},","+\t\t},","+\t}","+}","+","+func TestGetTargets(t *testing.T) {","+\ttype pkgSpec struct {","+\t\tpath     string","+\t\tcomments []string","+\t\t// types maps type-name to its CommentLines (a copyable struct is","+\t\t// synthesized for each entry). nil means no types in the package.","+\t\ttypes map[string][]string","+\t}","+","+\tcases := []struct {","+\t\tname     string","+\t\tpkgs     []pkgSpec","+\t\twantPkgs []string","+\t\t// wantAllTypes maps PkgPath -> expected genDeepCopy.allTypes value.","+\t\twantAllTypes map[string]bool","+\t\t// wantRegister maps PkgPath -> expected genDeepCopy.registerTypes value.","+\t\twantRegister map[string]bool","+\t}{","+\t\t{","+\t\t\tname: \"package tag with copyable struct activates\",","+\t\t\tpkgs: []pkgSpec{","+\t\t\t\t{","+\t\t\t\t\tpath:     \"example.com/pkg/a\",","+\t\t\t\t\tcomments: []string{\"+k8s:deepcopy-gen=package\"},","+\t\t\t\t\ttypes:    map[string][]string{\"T\": nil},","+\t\t\t\t},","+\t\t\t},","+\t\t\twantPkgs:     []string{\"example.com/pkg/a\"},","+\t\t\twantAllTypes: map[string]bool{\"example.com/pkg/a\": true},","+\t\t\twantRegister: map[string]bool{\"example.com/pkg/a\": false},","+\t\t},","+\t\t{","+\t\t\tname: \"package tag with register=false activates with register=false\",","+\t\t\tpkgs: []pkgSpec{","+\t\t\t\t{","+\t\t\t\t\tpath:     \"example.com/pkg/b\",","+\t\t\t\t\tcomments: []string{\"+k8s:deepcopy-gen=package,register=false\"},","+\t\t\t\t\ttypes:    map[string][]string{\"T\": nil},","+\t\t\t\t},","+\t\t\t},","+\t\t\twantPkgs:     []string{\"example.com/pkg/b\"},","+\t\t\twantAllTypes: map[string]bool{\"example.com/pkg/b\": true},","+\t\t\twantRegister: map[string]bool{\"example.com/pkg/b\": false},","+\t\t},","+\t\t{","+\t\t\tname: \"package tag with register=true activates with register=true\",","+\t\t\tpkgs: []pkgSpec{","+\t\t\t\t{","+\t\t\t\t\tpath:     \"example.com/pkg/c\",","+\t\t\t\t\tcomments: []string{\"+k8s:deepcopy-gen=package,register=true\"},","+\t\t\t\t\ttypes:    map[string][]string{\"T\": nil},","+\t\t\t\t},","+\t\t\t},","+\t\t\twantPkgs:     []string{\"example.com/pkg/c\"},","+\t\t\twantAllTypes: map[string]bool{\"example.com/pkg/c\": true},","+\t\t\twantRegister: map[string]bool{\"example.com/pkg/c\": true},","+\t\t},","+\t\t{","+\t\t\tname: \"package opted out is skipped\",","+\t\t\tpkgs: []pkgSpec{","+\t\t\t\t{","+\t\t\t\t\tpath:     \"example.com/pkg/d\",","+\t\t\t\t\tcomments: []string{\"+k8s:deepcopy-gen=false\"},","+\t\t\t\t\ttypes:    map[string][]string{\"T\": nil},","+\t\t\t\t},","+\t\t\t},","+\t\t\twantPkgs: nil,","+\t\t},","+\t\t{","+\t\t\tname: \"no package tag but type opts in activates\",","+\t\t\tpkgs: []pkgSpec{","+\t\t\t\t{","+\t\t\t\t\tpath: \"example.com/pkg/e\",","+\t\t\t\t\ttypes: map[string][]string{","+\t\t\t\t\t\t\"T\": {\"+k8s:deepcopy-gen=true\"},","+\t\t\t\t\t},","+\t\t\t\t},","+\t\t\t},","+\t\t\twantPkgs:     []string{\"example.com/pkg/e\"},","+\t\t\twantAllTypes: map[string]bool{\"example.com/pkg/e\": false},","+\t\t\twantRegister: map[string]bool{\"example.com/pkg/e\": false},","+\t\t},","+\t\t{","+\t\t\tname: \"package tag but no copyable types is skipped\",","+\t\t\tpkgs: []pkgSpec{","+\t\t\t\t{","+\t\t\t\t\tpath:     \"example.com/pkg/f\",","+\t\t\t\t\tcomments: []string{\"+k8s:deepcopy-gen=package\"},","+\t\t\t\t\ttypes:    nil,","+\t\t\t\t},","+\t\t\t},","+\t\t\twantPkgs: nil,","+\t\t},","+\t\t{","+\t\t\tname: \"no tag and no opt-in types is skipped\",","+\t\t\t