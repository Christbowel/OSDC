en(cronClass.pendingAlertTriggerTasks) != 0 {","+\t\tt.Fatal(\"expired alert-trigger authorization must be pruned\")","+\t}","+}","+","+func TestAlertTriggerCronResultAuthorizationRevokeRemovesLatestDispatch(t *testing.T) {","+\texistingAuthorizationExpiresAt := time.Now().Add(time.Hour)","+\tcronClass := &CronClass{","+\t\tpendingAlertTriggerTasks: map[uint64]map[uint64][]time.Time{","+\t\t\t42: {7: {existingAuthorizationExpiresAt}},","+\t\t},","+\t}","+\tcronClass.reserveAlertTriggerCronResult(42, 7)","+","+\tcronClass.revokeAlertTriggerCronResult(42, 7)","+","+\tauthorizations := cronClass.pendingAlertTriggerTasks[42][7]","+\tif len(authorizations) != 1 {","+\t\tt.Fatalf(\"expected one previous alert-trigger authorization to remain, got %d\", len(authorizations))","+\t}","+\tif !authorizations[0].Equal(existingAuthorizationExpiresAt) {","+\t\tt.Fatal(\"send failure rollback must remove the newest reserved authorization\")","+\t}","+}","+","+func TestCronClassUpdatePrunesAlertTriggerCronResultAuthorization(t *testing.T) {","+\tcronClass := &CronClass{","+\t\tCron: cron.New(cron.WithSeconds()),","+\t\tclass: class[uint64, *model.Cron]{","+\t\t\tlist: map[uint64]*model.Cron{42: {Common: model.Common{ID: 42}}},","+\t\t},","+\t\tpendingAlertTriggerTasks: map[uint64]map[uint64][]time.Time{","+\t\t\t42: {7: {time.Now().Add(time.Hour)}},","+\t\t},","+\t}","+","+\tcronClass.Update(&model.Cron{Common: model.Common{ID: 42}})","+","+\tif len(cronClass.pendingAlertTriggerTasks) != 0 {","+\t\tt.Fatal(\"cron update must prune old alert-trigger result authorizations\")","+\t}","+}","+","+func TestCronClassDeletePrunesAlertTriggerCronResultAuthorization(t *testing.T) {","+\tcronClass := &CronClass{","+\t\tCron: cron.New(cron.WithSeconds()),","+\t\tclass: class[uint64, *model.Cron]{","+\t\t\tlist: map[uint64]*model.Cron{42: {Common: model.Common{ID: 42}}},","+\t\t},","+\t\tpendingAlertTriggerTasks: map[uint64]map[uint64][]time.Time{","+\t\t\t42: {7: {time.Now().Add(time.Hour)}},",