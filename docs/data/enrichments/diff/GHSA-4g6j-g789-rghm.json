sed on a","+// dispatch that never actually reached the wire.","+type failingTaskStream struct {","+\tcapturedTaskStream","+\tsendErr error","+}","+","+func newFailingTaskStream(err error) *failingTaskStream {","+\treturn &failingTaskStream{","+\t\tcapturedTaskStream: capturedTaskStream{tasks: make(chan *pb.Task, 4)},","+\t\tsendErr:            err,","+\t}","+}","+","+func (s *failingTaskStream) Send(task *pb.Task) error {","+\ts.tasks <- task","+\treturn s.sendErr","+}","+","+func TestCronTriggerRevokesAlertTriggerAuthorizationOnSendFailure(t *testing.T) {","+\tfailing := newFailingTaskStream(context.Canceled)","+\treplaceServerSharedForSecurityTest(t,","+\t\t&model.Server{Common: model.Common{ID: 7, UserID: 100}, Name: \"broken-server\", TaskStream: failing},","+\t)","+\treplaceUserInfoMapForSecurityTest(t, map[uint64]model.UserInfo{","+\t\t100: {Role: model.RoleMember},","+\t})","+","+\toriginalCronShared := CronShared","+\tt.Cleanup(func() { CronShared = originalCronShared })","+\tCronShared = &CronClass{","+\t\tclass:                    class[uint64, *model.Cron]{list: map[uint64]*model.Cron{}},","+\t\tpendingAlertTriggerTasks: map[uint64]map[uint64][]time.Time{},","+\t}","+","+\tcr := &model.Cron{","+\t\tCommon: model.Common{ID: 42, UserID: 100},","+\t\tCover:  model.CronCoverAlertTrigger,","+\t}","+","+\tCronTrigger(cr, 7)()","+","+\t// drain the dispatched task — Send error is what we care about, not the payload","+\tselect {","+\tcase <-failing.tasks:","+\tcase <-time.After(time.Second):","+\t\tt.Fatal(\"expected CronTrigger to call Send before reacting to the error\")","+\t}","+","+\tif CronShared.consumeAlertTriggerCronResult(42, 7) {","+\t\tt.Fatal(\"Send failure must revoke the reserved alert-trigger authorization; otherwise a foreign agent could later report a result for a dispatch that never reached the wire\")","+\t}","+\tif len(CronShared.pendingAlertTriggerTasks) != 0 {","+\t\tt.Fatalf(\"expected pendingAlertTriggerTasks to be empty after revoke, g