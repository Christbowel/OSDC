ons":1,"deletions":1,"truncated":false},{"path":"services/auth/go/providers/azuread.go","lines":["@@ -41,11 +41,9 @@ func NewAzureadProvider("," }"," "," type azureUser struct {","-\tOID    string `json:\"oid\"`","-\tEmail  string `json:\"email\"`","-\tName   string `json:\"name\"`","-\tUPN    string `json:\"upn\"`","-\tPrefer string `json:\"preferred_username\"`","+\tOID   string `json:\"oid\"`","+\tEmail string `json:\"email\"`","+\tName  string `json:\"name\"`"," }"," "," func (a *AzureAD) GetProfile(","@@ -64,19 +62,20 @@ func (a *AzureAD) GetProfile("," \t\treturn oidc.Profile{}, fmt.Errorf(\"AzureAD API error: %w\", err)"," \t}"," ","-\temail := userProfile.Email","-\tif email == \"\" {","-\t\temail = userProfile.Prefer","-\t}","-","-\tif email == \"\" {","-\t\temail = userProfile.UPN","-\t}","-","+\t// Only the `email` claim represents a real external email Azure AD has","+\t// associated with the account. `preferred_username` and `upn` are internal","+\t// directory identifiers that can be set to arbitrary values (e.g. a custom","+\t// UPN like `ceo@target-company.com`) and do not prove email ownership.","+\t//","+\t// The legacy v1 `/openid/userinfo` endpoint does not expose an","+\t// `email_verified` claim, so there is no explicit signal to report and","+\t// the status is Unknown. For stricter verification, use the Entra ID","+\t// provider, which returns `email_verified` via Microsoft Graph's OIDC","+\t// userinfo endpoint."," \treturn oidc.Profile{"," \t\tProviderUserID: userProfile.OID,","-\t\tEmail:          email,","-\t\tEmailVerified:  email != \"\",","+\t\tEmail:          userProfile.Email,","+\t\tEmailVerified:  oidc.EmailVerificationStatusUnknown,"," \t\tName:           userProfile.Name,"," \t\tPicture:        \"\","," \t}, nil"],"additions":15,"deletions":16,"truncated":false},{"path":"services/auth/go/providers/azuread_internal_test.go","lines":["@@ -0,0 +1,51 @@","+package providers","+","+import (","+\t\"encoding/json\"","+\t\"testing\"","+)","+","+// TestAzureADProfileIgnoresUPNAndPreferredUsername verifies that the Azure AD","+// user profile struct no longer deserializes the `upn` or `preferred_username`","+// claims. These fields are internal directory identifiers and cannot be used","+// to prove ownership of an external email, so they must never be treated as","+// an account-linking email.","+func TestAzureADProfileIgnoresUPNAndPreferredUsername(t *testing.T) {","+\tt.Parallel()","+","+\tbody := `{","+\t\t\"oid\": \"00000000-0000-0000-66f3-3332eca7ea81\",","+\t\t\"name\": \"Jane\",","+\t\t\"email\": \"\",","+\t\t\"upn\": \"attacker@tenant.onmicrosoft.com\",","+\t\t\"preferred_username\": \"ceo@target-company.com\"","+\t}`","+","+\tvar profile azureUser","+\tif err := json.Unmarshal([]byte(body), &profile); err != nil {","+\t\tt.Fatalf(\"unmarshal failed: %v\", err)","+\t}","+","+\tif profile.Email != \"\" {","+\t\tt.Errorf(\"email should be empty when the claim is empty, got %q\", profile.Email)","+\t}","+}","+","+func TestAzureADProfileUsesEmailOnly(t *testing.T) {","+\tt.Parallel()","+","+\tbody := `{","+\t\t\"oid\": \"00000000-0000-0000-66f3-3332eca7ea81\",","+\t\t\"name\": \"Jane\",","+\t\t\"email\": \"jane@contoso.com\"","+\t}`","+","+\tvar profile azureUser","+\tif err := json.Unmarshal([]byte(body), &profile); err != nil {","+\t\tt.Fatalf(\"unmarshal failed: %v\", err)","+\t}","+","+\tif profile.Email != \"jane@contoso.com\" {","+\t\tt.Errorf(\"email: got %q, want %q\", profile.Email, \"jane@contoso.com\")","+\t}","+}"],"additions":51,"deletions":0,"truncated":false},{"path":"services/auth/go/providers/bitbucket.go","lines":["@@ -99,34 +99,30 @@ func (b *Bitbucket) GetProfile("," \t\treturn oidc.Profile{}, fmt.Errorf(\"Bitbucket email decode error: %w\", err)"," \t}"," ","-\t// Pick the first verified email","-\tvar (","-\t\tprimaryEmail  string","-\t\tfallbackEmail string","-\t)","+\t// Pick the first confirmed email. Bitbucket lets users add any email to","+\t// their account without proof of ownership until they click the","+\t// confirmation link, so unconfirmed addresses must never be reported as","+\t// verified.","+\tvar primaryEmail string"," "," \tfor _, e := range emailResp.Values {"," \t\tif e.IsConfirmed {"," \t\t\tprimaryEmail = e.Email"," \t\t\tbreak","-\t\t} else if fallbackEmail == \"\" {","-\t\t\tfallbackEmail = e.Email"," \t\t}"," \t}"," "," \tif primaryEmail == \"\" {","-\t\tif fallbackEmail == \"\" {","-\t\t\treturn oidc.Profile{}, ErrNoConfirmedBitbucketEmail","-\t\t}","-","-\t\tprimaryEmail = fallbackEmail","+\t\treturn oidc.Profile{}, ErrNoConfirmedBitbucketEmail"," \t}"," ","-\t// Step 3: Return profile","+\t// Step 3: Return profile. We only reach this point after selecting a","+\t// confirmed email, so the status reflects Bitbucket's explicit","+\t// `is_confirmed` signal."," \treturn oidc.Profile{"," \t\tProviderUserID: user.UUID,"," \t\tEmail:          primaryEmail,","-\t\tEmailVerified:  primaryEmail != \"\",","+\t\tEmailVerified:  oidc.EmailVerificationStatusVerified,"," \t\tName:           user.DisplayName,"," \t\tPicture:        user.Links.Avatar.Href,"," \t}, nil"],"additions":10,"deletions":14,"truncated":false},{"path":"services/auth/go/providers/bitbucket_internal_test.go","lines":["@@ -0,0 +1,161 @@","+package providers","+","+import (","+\t\"context\"","+\t\"encoding/json\"","+\t\"errors\"","+\t\"fmt\"","+\t\"net/http\"","+\t\"net/http/httptest\"","+\t\"strings\"","+\t\"testing\"","+)","+","+// newBitbucketTestServer serves the two endpoints used by Bitbucket.GetProfile.","+// The caller supplies the body returned for /user/emails.","+func newBitbucketTestServer(t *testing.T, emailsBody string) *httptest.Server {","+\tt.Helper()","+","+\treturn httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\tswitch {","+\t\tcase strings.HasSuffix(r.URL.Path, \"/user/emails\"):","+\t\t\tw.Header().Set(\"Content-Type\", \"application/json\")","+\t\t\t_, _ = w.Write([]byte(emailsBody))","+\t\tcase strings.HasSuffix(r.URL.Path, \"/user\"):","+\t\t\tw.Header().Set(\"Content-Type\", \"application/json\")","+\t\t\t_, _ = w.Write([]byte(`{","+\t\t\t\t\"uuid\": \"{00000000-0000-0000-0000-000000000000}\",","+\t\t\t\t\"display_name\": \"Jane\",","+\t\t\t\t\"links\": {\"avatar\": {\"href\": \"https://example.com/a.png\"}}","+\t\t\t}`))","+\t\tdefault:","+\t\t\thttp.NotFound(w, r)","+\t\t}","+\t}))","+}","+","+// bitbucketGetProfileWithBase is a test-only variant of Bitbucket.GetProfile","+// that uses baseURL instead of the hard-coded Bitbucket API host, so we can","+// exercise the email-selection logic against an httptest server.","+//","+// This mirrors the production code exactly; it intentionally only differs in","+// the two URLs it targets.","+func bitbucketGetProfileWithBase(","+\tctx context.Context,","+\tbaseURL, accessToken string,","+) (string, bool, error) {","+\tvar user bitbucketAPIUser","+\tif err := fetchOAuthProfile(ctx, baseURL+\"/user\", accessToken, &user); err != nil {","+\t\treturn \"\", false, err","+\t}","+","+\treq, err := http.NewRequestWithContext(","+\t\tctx,","+\t\thttp.MethodGet,","+\t\tbaseURL+\"/user/emails\",","+\t\tnil,","+\t)","+\tif err != nil {","+\t\treturn \"\", false, fmt.Errorf(\"new request: %w\", err)","+\t}","+","+\treq.Header.Set(\"Authorization\", \"Bearer \"+accessToken)","+","+\tresp, err := http.DefaultClient.Do(req)","+\tif err != nil {","+\t\treturn \"\", false, fmt.Errorf(\"do request: %w\", err)","+\t}","+\tdefer resp.Body.Close()","+","+\tvar emailResp bitbucketEmailsResponse","+\tif err := json.NewDecoder(resp.Body).Decode(&emailResp); err != nil {","+\t\treturn \"\", false, fmt.Errorf(\"decode response: %w\", err)","+\t}","+","+\tvar primaryEmail string","+","+\tfor _, e := range emailResp.Values {","+\t\tif e.IsConfirmed {","+\t\t\tprimaryEmail = e.Email","+\t\t\tbreak","+\t\t}","+\t}","+","+\tif primaryEmail == \"\" {","+\t\treturn \"\", false, ErrNoConfirmedBitbucketEmail","+\t}","+","+\treturn primaryEmail, true, nil","+}","+","+func TestBitbucketRejectsUnconfirmedEmails(t *testing.T) {","+\tt.Parallel()","+","+\ttests := []struct {","+\t\tname          string","+\t\temailsBody    string","+\t\texpectedEmail string","+\t\texpectedErr   error","+\t}{","+\t\t{","+\t\t\tname: \"picks first confirmed email\",","+\t\t\temailsBody: `{","+\t\t\t\t\"values\": [","+\t\t\t\t\t{\"email\": \"unconfirmed@target.io\", \"is_confirmed\": false},","+\t\t\t\t\t{\"email\": \"jane@bitbucket.io\", \"is_confirmed\": true}"],"additions":105,"deletions":0,"truncated":false}],"additions":626,"deletions":60,"truncated":true,"file_count":12},"error":null,"fetched_at":"2026-05-20T17:34:33.866723+00:00"}