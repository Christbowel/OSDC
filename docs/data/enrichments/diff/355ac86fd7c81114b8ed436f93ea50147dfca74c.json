> 0 FROM glob('{TEST_DIR}/tmp_dd/*.block');","-true","-","-# Baseline: with .block files on disk, OVERFLOW_STRINGS counter must be > 0.","-# (If this fails, the bug already fired during insert-time evict/read cycles.)","-query I","-SELECT temporary_storage_bytes > 0 FROM duckdb_memory() WHERE tag = 'OVERFLOW_STRINGS';","-true","-","-# Phase 2: full scan forces every .block to be read back through ReadTemporaryBuffer.","-# count(*) avoids materialising the strings themselves while still pinning each block,","-# so the read-back path runs without OOM under the tight budget.","-statement ok","-SELECT count(s) FROM r1;","-","-# Phase 3: insert another ~57 MB to force fresh OVERFLOW_STRINGS evictions.","-loop b 0 5","-","-statement ok","-INSERT INTO r1 SELECT range + 100 + ${b}*20, hex(repeat(md5(range::VARCHAR)::BLOB, 9000)) FROM range(20);","-","-endloop","-","-# .block files exist again from the new evictions.","-query I","-SELECT count(*) > 0 FROM glob('{TEST_DIR}/tmp_dd/*.block');","-true","-","-# Core regression assertion: after the read-back scan and a fresh wave of writes,","-# the per-tag counter must reflect the on-disk eviction state.","-# FAILS with the double-decrement bug (counter remains clamped to 0).","-# PASSES once the duplicate decrement at standard_buffer_manager.cpp:569 is removed.","-query I","-SELECT temporary_storage_bytes > 0 FROM duckdb_memory() WHERE tag = 'OVERFLOW_STRINGS';","-true"],"additions":0,"deletions":82,"truncated":false},{"path":"test/sql/outofcore/block_file_evicted_bytes_accounting.test_slow","lines":["@@ -42,15 +42,20 @@ statement ok"," SET memory_limit = '50MB';"," "," statement ok","-CREATE TABLE t (id INTEGER, val VARCHAR);","+ATTACH '{TEST_DIR}/acct.db' AS acct;","+","+statement ok","+CREATE TABLE acct.t (id INTEGER, val VARCHAR);"," "," # Write ~57 MB of incompressible OVERFLOW_STRINGS data in 20-row batches."," # Each row → one OVERFLOW_STRINGS block of ~576 KB → one .block file on eviction."," # 50 MB budget vs ~57 MB workload guarantees eviction during inserts."," loop b 0 5"," ","-statement ok","-INSERT INTO t SELECT range + {b}*20, hex(repeat(md5(range::VARCHAR)::BLOB, 9000)) FROM range(20);","+statement maybe","+INSERT INTO acct.t SELECT range + {b}*20, hex(repeat(md5(range::VARCHAR)::BLOB, 9000)) FROM range(20);","+----","+<REGEX>:.*invalidated.*"," "," endloop"," "],"additions":8,"deletions":3,"truncated":false},{"path":"test/sql/storage/attach/attach_invalidation.test","lines":["@@ -0,0 +1,160 @@","+# name: test/sql/storage/attach/attach_invalidation.test","+# description: A checkpoint failure on an attached database is scoped to that database","+# group: [attach]","+","+require no_alternative_verify","+","+foreach abort_mode before_header before_header_non_fatal","+","+statement ok","+PRAGMA disable_checkpoint_on_shutdown;","+","+statement ok","+SET wal_autocheckpoint = '1TB';","+","+statement ok","+SET auto_checkpoint_skip_wal_threshold = 9999999999;","+","+statement ok","+ATTACH '{TEST_DIR}/attach_invalidation_a_{abort_mode}.db' AS a;","+","+statement ok","+ATTACH '{TEST_DIR}/attach_invalidation_b_{abort_mode}.db' AS b;","+","+statement ok","+CREATE TABLE a.tbl(i INTEGER);","+","+statement ok","+CREATE TABLE b.tbl(i INTEGER);","+","+statement ok","+INSERT INTO a.tbl SELECT range::INTEGER FROM range(10);","+","+statement ok","+INSERT INTO b.tbl VALUES (100);","+","+statement ok","+CHECKPOINT a;","+","+statement ok","+INSERT INTO a.tbl VALUES (10);","+","+statement ok","+PRAGMA debug_checkpoint_abort = '{abort_mode}';","+","+# the failing checkpoint is scoped to \"a\"","+statement error","+CHECKPOINT a;","+----","+<REGEX>:IO Error: Checkpoint failed for database \"a\".*Checkpoint aborted before header write.*","+","+# \"a\" is invalidated: reads, writes and further checkpoints all fail","+statement error","+SELECT COUNT(*) FROM a.tbl;","+----","+<REGEX>:IO Error: Database \"a\" has been invalidated because checkpointing failed.*","+","+statement error","+INSERT INTO a.tbl VALUES (11);","+----","+<REGEX>:IO Error: Database \"a\" has been invalidated because checkpointing failed.*","+","+statement error","+CHECKPOINT a;","+----","+<REGEX>:IO Error: Database \"a\" has been invalidated because checkpointing failed.*","+","+# the instance and the sibling database \"b\" are unaffected","+query I","+SELECT 42;","+----","+42","+","+statement ok","+INSERT INTO b.tbl VALUES (101);","+","+query I","+SELECT COUNT(*) FROM b.tbl;","+----","+2","+","+# immediate transaction mode must skip the invalidated database when starting transactions","+statement ok","+SET immediate_transaction_mode = true;","+","+statement ok","+BEGIN;","+","+query I","+SELECT COUNT(*) FROM b.tbl;","+----","+2","+","+statement error","+SELECT COUNT(*) FROM a.tbl;","+----","+<REGEX>:IO Error: Database \"a\" has been invalidated because checkpointing failed.*","+","+statement ok","+ROLLBACK;","+","+statement ok","+SET immediate_transaction_mode = false;","+","+# detach + reattach clears the invalidation and recovers committed data from the WAL","+statement ok","+PRAGMA debug_checkpoint_abort = 'none';","+","+statement ok","+DETACH a;","+","+statement ok","+ATTACH '{TEST_DIR}/attach_invalidation_a_{abort_mode}.db' AS a;","+","+query I","+SELECT COUNT(*) FROM a.tbl;","+----","+11","+","+# the same scoping applies to a failing auto-checkpoint (triggered by the WAL size, not an explicit CHECKPOINT)","+statement ok","+SET wal_autocheckpoint = '1KB';","+","+statement ok","+PRAGMA debug_checkpoint_abort = '{abort_mode}';","+","+statement ok","+INSERT INTO a.tbl SELECT (range + 1000)::INTEGER FROM range(10000);","+","+statement error","+SELECT COUNT(*) FROM a.tbl;","+----","+<REGEX>:IO Error: Database \"a\" has been invalidated because checkpointing failed.*","+","+query I","+SELECT COUNT(*) FROM b.tbl;","+----","+2","+","+statement ok","+PRAGMA debug_checkpoint_abort = 'none';","+","+statement ok","+DETACH a;","+","+statement ok","+ATTACH '{TEST_DIR}/attach_invalidation_a_{abort_mode}.db' AS a;","+","+query I","+SELECT COUNT(*) FROM a.tbl;","+----","+10011","+","+# detach both so the next iteration can reattach fresh database files","+statement ok","+DETACH a;","+","+statement ok","+DETACH b;","+","+endloop"],"additions":160,"deletions":0,"truncated":false},{"path":"test/sql/storage/attach/attach_invalidation_default_db.test","lines":["@@ -0,0 +1,58 @@","+# name: test/sql/storage/attach/attach_invalidation_default_db.test","+# description: A checkpoint failure on the default database is instance-wide, even with another database attached","+# group: [attach]","+","+require skip_reload","+","+require no_alternative_verify"],"additions":7,"deletions":0,"truncated":false}],"additions":340,"deletions":209,"truncated":true,"file_count":17},"error":null,"fetched_at":"2026-06-27T10:39:06.880104+00:00"}