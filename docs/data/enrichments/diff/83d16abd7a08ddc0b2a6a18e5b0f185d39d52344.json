A:    JWTAuthIssuerCustomCA.Get(&st.SV),","+\t\tjwks:        mustParseJWKS(JWTAuthJWKS.Get(&st.SV)),","+\t\tclaim:       rawClaim,","+\t\t// If rawClaim is a JSON Pointer, parse it once here to save CPU cycles later.","+\t\tclaimSegments:        mustParseClaimSegments(rawClaim),"," \t\tjwksAutoFetchEnabled: JWKSAutoFetchEnabled.Get(&st.SV),"," \t\thttpClient: httputil.NewClient("," \t\t\thttputil.WithClientTimeout(clientTimeout),","@@ -289,6 +294,114 @@ func (authenticator *jwtAuthenticator) RetrieveIdentity("," \treturn authenticator.retrieveIdentityLocked(user, tokenBytes, identMap)"," }"," ","+// mustParseClaimSegments pre-parses the claim setting into decoded RFC 6901","+// pointer segments so that per-login lookups avoid repeated string splitting","+// and escape decoding. For simple claim names (no leading \"/\") and for empty","+// string the result is nil.","+func mustParseClaimSegments(claim string) []string {","+\t// Not a JSON Pointer (RFC 6901)","+\tif claim == \"\" || !strings.HasPrefix(claim, \"/\") {","+\t\treturn nil","+\t}","+\t// JSON Pointer (RFC 6901): split and decode escape sequences.","+\traw := strings.Split(claim[1:], \"/\")","+\tsegments := make([]string, len(raw))","+\tfor i, tok := range raw {","+\t\ttok = strings.ReplaceAll(tok, \"~1\", \"/\")","+\t\ttok = strings.ReplaceAll(tok, \"~0\", \"~\")","+\t\tsegments[i] = tok","+\t}","+\treturn segments","+}","+","+// lookupIdentityClaimByJSONPointer resolves a claim value from the token","+// using pre-parsed, decoded RFC 6901 JSON Pointer segments. The token is","+// converted to a generic map and the segments are walked to locate the","+// target value. The returned bool and error follow the same tri-state","+// contract as resolveJSONPointer.","+func lookupIdentityClaimByJSONPointer(token jwt.Token, claimSegments []string) (any, bool, error) {","+\tallClaims, err := token.AsMap(context.Background())","+\tif err != nil {","+\t\treturn nil, false, err","+\t}","+\treturn resolveJSONPointer(allClaims, claimSegments)","+}","+","+// resolveJSONPointer traverses a map according to pre-parsed, decoded","+// RFC 6901 JSON Pointer segments. Both JSON objects (map[string]any)","+// and JSON arrays ([]any) are supported as intermediate or leaf values","+// per RFC 6901 §4.","+//","+// The return contract is tri-state:","+//   - (value, true, nil): the pointer resolved to a value.","+//   - (nil, false, nil): a map segment referenced a key that is not","+//     present. This is treated as a legitimately absent claim so that","+//     callers can surface a uniform \"missing claim\" error regardless","+//     of whether a simple claim name or a JSON Pointer was configured.","+//   - (nil, false, err): the pointer is malformed relative to the","+//     document (e.g. an array index that is non-numeric, negative,","+//     has a leading zero, is out of bounds, or an intermediate value","+//     that is neither a JSON object nor a JSON array). These indicate","+//     misconfiguration rather than an absent claim.","+func resolveJSONPointer(m map[string]any, segments []string) (any, bool, error) {","+\tvar current any = m","+\tfor _, tok := range segments {","+\t\tswitch v := current.(type) {","+\t\tcase map[string]any:","+\t\t\tvar ok bool","+\t\t\tcurrent, ok = v[tok]","+\t\t\tif !ok {","+\t\t\t\treturn nil, false, nil","+\t\t\t}","+\t\tcase []any:","+\t\t\t// RFC 6901 §4: for arrays the reference token must be an","+\t\t\t// unsigned base-10 integer (leading zeros are not allowed,","+\t\t\t// and \"-\" refers to a nonexistent element past the end).","+\t\t\tidx, err := strconv.Atoi(tok)","+\t\t\tif err != nil || idx < 0 || tok == \"-\" || (len(tok) > 1 && tok[0] == '0') {","+\t\t\t\treturn nil, false, fmt.Errorf(","+\t\t\t\t\t\"JSON pointer: invalid array index %q\", tok,","+\t\t\t\t)","+\t\t\t}","+\t\t\tif idx >= len(v) {","+\t\t\t\treturn nil, false, fmt.Errorf(","+\t\t\t\t\t\"JSON pointer: array index %d out of bounds (len %d)\",","+\t\t\t\t\tidx, len(v),","+\t\t\t\t)","+\t\t\t}","+\t\t\tcurrent = v[idx]","+\t\tdefault:","+\t\t\treturn nil, false, fmt.Errorf(","+\t\t\t\t\"JSON pointer: value at %q is neither an object nor an array\",","+\t\t\t\ttok,","+\t\t\t)","+\t\t}","+\t}","+\treturn current, true, nil","+}","+","+// lookupIdentityClaim extracts the identity claim from the token. For simple","+// claim names (claimSegments == nil) it uses the token's native Get method;","+// for JSON Pointers it delegates to lookupIdentityClaimByJSONPointer which","+// resolves the pre-parsed pointer segments against the token's claims map.","+func (authenticator *jwtAuthenticator) lookupIdentityClaim(","+\tunverifiedToken jwt.Token,","+) (claimValue any, ok bool, err error) {","+\tif authenticator.mu.conf.claimSegments == nil {","+\t\t// The top-level claim path (non JSON Pointer scenario)","+\t\tclaimValue, ok = unverifiedToken.Get(authenticator.mu.conf.claim)","+\t} else {","+\t\t// The JSON Pointer scenario (supports top-level and nested claims)","+\t\tclaimValue, ok, err = lookupIdentityClaimByJSONPointer(unverifiedToken, authenticator.mu.conf.claimSegments)","+\t\tif err != nil {","+\t\t\treturn nil, false, errors.WithDetailf(","+\t\t\t\terrors.Newf(\"JWT authentication: failed to extract claim\"),","+\t\t\t\t\"failed to extract claim %s: %v\", authenticator.mu.conf.claim, err)","+\t\t}","+\t}","+\treturn claimValue, ok, nil","+}","+"," // retrieveIdentityLocked contains the core principal-to-user mapping"," // logic. The caller must already hold a.mu; this helper therefore"," // performs no locking or config reloads and must never call anything","@@ -312,7 +425,10 @@ func (authenticator *jwtAuthenticator) retrieveIdentityLocked("," \tif authenticator.mu.conf.claim == \"\" || authenticator.mu.conf.claim == \"sub\" {"," \t\ttokenPrincipals = []string{unverifiedToken.Subject()}"," \t} else {","-\t\tclaimValue, ok := unverifiedToken.Get(authenticator.mu.conf.claim)","+\t\tclaimValue, ok, err := authenticator.lookupIdentityClaim(unverifiedToken)","+\t\tif err != nil {","+\t\t\treturn user, err","+\t\t}"," \t\tif !ok {"," \t\t\treturn user, errors.WithDetailf("," \t\t\t\terrors.Newf(\"JWT authentication: missing claim\"),"],"additions":123,"deletions":7,"truncated":false},{"path":"pkg/security/jwtauth/authentication_jwt_test.go","lines":["@@ -1224,3 +1224,362 @@ func TestGetHTTPResponseNon2xx(t *testing.T) {"," \trequire.Contains(t, errors.FlattenDetails(err), \"403 Forbidden\")"," \trequire.Contains(t, errors.FlattenDetails(err), \"boom\")"," }","+","+func TestLookupIdentityClaimByJSONPointer(t *testing.T) {","+\tdefer leaktest.AfterTest(t)()","+\tdefer log.Scope(t).Close(t)","+","+\t// Build a token with a mix of flat and nested claims for the test cases.","+\ttok := makeTokenWithClaims(t, map[string]any{","+\t\tjwt.SubjectKey: username1,","+\t\tjwt.IssuerKey:  issuer1,","+\t\t\"email\":        \"alice@example.com\",","+\t\t\"count\":        42,","+\t\t\"user\": map[string]any{","+\t\t\t\"name\": \"alice\",","+\t\t\t\"profile\": map[string]any{","+\t\t\t\t\"role\": \"admin\",","+\t\t\t},","+\t\t},","+\t\t\"roles\": []any{\"viewer\", \"editor\", \"admin\"},","+\t\t\"nested_arr\": map[string]any{","+\t\t\t\"items\": []any{","+\t\t\t\tmap[string]any{\"id\": \"first\"},","+\t\t\t\tmap[string]any{\"id\": \"second\"},","+\t\t\t},","+\t\t},","+\t\t// Keys with characters that require RFC 6901 escaping.","+\t\t\"a/b\":   \"slash-value\",","+\t\t\"a~c\":   \"tilde-value\",","+\t\t\"~0\":    \"literal-tilde-zero\",","+\t\t\"~1\":    \"literal-tilde-one\",","+\t\t\"empty\": \"\",","+\t})","+","+\ttype testCase struct {","+\t\tname      string","+\t\tpointer   string","+\t\twantValue interface{}","+\t\twantOK    bool","+\t\twantErr   bool","+\t}","+","+\t// ── Simple claim names use token.Get directly (production path) ──","+\tt.Run(\"simple_claim_found\", func(t *testing.T) {","+\t\tv, ok := tok.Get(\"email\")","+\t\trequire.True(t, ok)","+\t\trequire.Equal(t, \"alice@example.com\", v)","+\t})","+\tt.Run(\"simple_claim_standard_field\", func(t *testing.T) {","+\t\tv, ok := tok.Get(\"sub\")","+\t\trequire.True(t, ok)","+\t\trequire.Equal(t, username1, v)","+\t})","+\tt.Run(\"simple_claim_integer\", func(t *testing.T) {","+\t\tv, ok := tok.Get(\"count\")","+\t\trequire.True(t, ok)","+\t\trequire.Equal(t, 42, v)","+\t})","+\tt.Run(\"simple_claim_empty_string\", func(t *testing.T) {","+\t\tv, ok := tok.Get(\"empty\")","+\t\trequire.True(t, ok)","+\t\trequire.Equal(t, \"\", v)","+\t})","+\tt.Run(\"simple_claim_missing\", func(t *testing.T) {","+\t\t_, ok := tok.Get(\"nonexistent\")","+\t\trequire.False(t, ok)","+\t})","+","+\tcases := []testCase{","+\t\t// ── JSON Pointers ──","+\t\t{","+\t\t\tname:      \"pointer_shallow\",","+\t\t\tpointer:   \"/email\",","+\t\t\twantValue: \"alice@example.com\",","+\t\t\twantOK:    true,","+\t\t},","+\t\t{","+\t\t\tname:      \"pointer_nested_one_level\",","+\t\t\tpointer:   \"/user/name\",","+\t\t\twantValue: \"alice\",","+\t\t\twantOK:    true,","+\t\t},","+\t\t{","+\t\t\tname:      \"pointer_nested_two_levels\",","+\t\t\tpointer:   \"/user/profile/role\",","+\t\t\twantValue: \"admin\",","+\t\t\twantOK:    true,","+\t\t},","+\t\t{","+\t\t\tname:    \"pointer_missing_leaf\",","+\t\t\tpointer: \"/user/missing\",","+\t\t\twantOK:  false,","+\t\t\twantErr: false,","+\t\t},","+\t\t{","+\t\t\tname:    \"pointer_missing_intermediate\",","+\t\t\tpointer: \"/nonexistent/deep/path\",","+\t\t\twantOK:  false,","+\t\t\twantErr: false,","+\t\t},","+\t\t{","+\t\t\tname:    \"pointer_non_object_intermediate\",","+\t\t\tpointer: \"/email/something\",","+\t\t\twantOK:  false,","+\t\t\twantErr: true,","+\t\t},","+\t\t{","+\t\t\t// RFC 6901: \"~1\" decodes to \"/\", so this looks up the key \"a/b\".","+\t\t\tname:      \"pointer_rfc6901_escaped_slash\",","+\t\t\tpointer:   \"/a~1b\",","+\t\t\twantValue: \"slash-value\",","+\t\t\twantOK:    true,","+\t\t},","+\t\t{","+\t\t\t// RFC 6901: \"~0\" decodes to \"~\", so this looks up the key \"a~c\".","+\t\t\