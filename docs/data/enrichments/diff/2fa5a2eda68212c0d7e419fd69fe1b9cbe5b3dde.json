guage governing permissions and","+limitations under the License.","+*/","+","+package deferredpodscheduling","+","+import (","+\t\"context\"","+\t\"fmt\"","+\t\"time\"","+","+\tv1 \"k8s.io/api/core/v1\"","+\t\"k8s.io/apimachinery/pkg/runtime\"","+\t\"k8s.io/component-helpers/resource\"","+\t\"k8s.io/klog/v2\"","+\tfwk \"k8s.io/kube-scheduler/framework\"","+\t\"k8s.io/kubernetes/pkg/scheduler/framework/plugins/feature\"","+\t\"k8s.io/kubernetes/pkg/scheduler/framework/plugins/names\"","+)","+","+type DeferredPodScheduling struct {","+\tenableInPlacePodVerticalScalingSchedulerPreemption bool","+}","+","+var _ fwk.PreFilterPlugin = &DeferredPodScheduling{}","+var _ fwk.FilterPlugin = &DeferredPodScheduling{}","+var _ fwk.EnqueueExtensions = &DeferredPodScheduling{}","+var _ fwk.PermitPlugin = &DeferredPodScheduling{}","+","+const (","+\tName                                  = names.DeferredPodScheduling","+\tErrReasonNodeDisablesResizePreemption = \"node had resize preemption disabled\"","+)","+","+func (pl *DeferredPodScheduling) Name() string {","+\treturn Name","+}","+","+// EventsToRegister returns the possible events that may make a Pod","+// failed by this plugin schedulable.","+func (pl *DeferredPodScheduling) EventsToRegister(_ context.Context) ([]fwk.ClusterEventWithHint, error) {","+\treturn []fwk.ClusterEventWithHint{","+\t\t{","+\t\t\tEvent:          fwk.ClusterEvent{Resource: fwk.Node, ActionType: fwk.UpdateNodePreemptionPolicy},","+\t\t\tQueueingHintFn: pl.isSchedulableAfterNodeChange,","+\t\t},","+\t\t{","+\t\t\tEvent:          fwk.ClusterEvent{Resource: fwk.Node, ActionType: fwk.Add},","+\t\t\tQueueingHintFn: pl.isSchedulableAfterNodeAdd,","+\t\t},","+\t}, nil","+}","+","+func (pl *DeferredPodScheduling) isSchedulableAfterNodeChange(logger klog.Logger, pod *v1.Pod, oldObj, newObj interface{}) (fwk.QueueingHint, error) {","+\tif !pl.enableInPlacePodVerticalScalingSchedulerPreemption || !resource.IsPodResizeDeferred(pod) {","+\t\treturn fwk.QueueSkip, nil","+\t}","+\toldNode, ok := oldObj.(*v1.Node)","+\tif !ok {","+\t\treturn fwk.Queue, fmt.Errorf(\"got object of type %T, want *v1.Node\", oldObj)","+\t}","+\tnewNode, ok := newObj.(*v1.Node)","+\tif !ok {","+\t\treturn fwk.Queue, fmt.Errorf(\"got object of type %T, want *v1.Node\", newObj)","+\t}","+","+\tif pod.Spec.NodeName != newNode.Name {","+\t\treturn fwk.QueueSkip, nil","+\t}","+","+\toldNodeDisabled := oldNode.Spec.PodPreemptionPolicy != nil && len(oldNode.Spec.PodPreemptionPolicy.DisableResizePreemption) > 0","+\tnewNodeDisabled := newNode.Spec.PodPreemptionPolicy != nil && len(newNode.Spec.PodPreemptionPolicy.DisableResizePreemption) > 0","+","+\t// If resize preemption was disabled and is now enabled, the pod may be schedulable.","+\tif oldNodeDisabled && !newNodeDisabled {","+\t\tlogger.V(5).Info(\"Node preemption policy changed from disabled to enabled, queueing pod\", \"pod\", klog.KObj(pod), \"node\", newNode.Name)","+\t\treturn fwk.Queue, nil","+\t}","+","+\treturn fwk.QueueSkip, nil","+}","+","+func (pl *DeferredPodScheduling) isSchedulableAfterNodeAdd(logger klog.Logger, pod *v1.Pod, oldObj, newObj interface{}) (fwk.QueueingHint, error) {","+\tif !pl.enableInPlacePodVerticalScalingSchedulerPreemption || !resource.IsPodResizeDeferred(pod) {","+\t\treturn fwk.QueueSkip, nil","+\t}","+\tnode, ok := newObj.(*v1.Node)","+\tif !ok {","+\t\treturn fwk.Queue, fmt.Errorf(\"got object of type %T, want *v1.Node\", newObj)","+\t}","+","+\tif pod.Spec.NodeName != node.Name {","+\t\treturn fwk.QueueSkip, nil","+\t}","+","+\t// If the added node has preemption enabled, the pod may be schedulable.","+\tif node.Spec.PodPreemptionPolicy == nil || len(node.Spec.PodPreemptionPolicy.DisableResizePreemption) == 0 {","+\t\tlogger.V(5).Info(\"Node added with preemption enabled, queueing pod\", \"pod\", klog.KObj(pod), \"node\", node.Name)","+\t\treturn fwk.Queue, nil","+\t}","+","+\treturn fwk.QueueSkip, nil","+}","+","+func (pl *DeferredPodScheduling) PreFilter(ctx context.Context, state fwk.CycleState, pod *v1.Pod, nodes []fwk.NodeInfo) (*fwk.PreFilterResult, *fwk.Status) {","+\tif !pl.enableInPlacePodVerticalScalingSchedulerPreemption || !resource.IsPodResizeDeferred(pod) {","+\t\treturn nil, fwk.NewStatus(fwk.Skip)","+\t}","+\treturn nil, nil","+}","+","+func (pl *DeferredPodScheduling) PreFilterExtensions() fwk.PreFilterExtensions {","+\treturn nil","+}","+","+func (pl *DeferredPodScheduling) Filter(ctx context.Context, _ fwk.CycleState, pod *v1.Pod, nodeInfo fwk.NodeInfo) *fwk.Status {","+\tif !pl.enableInPlacePodVerticalScalingSchedulerPreemption || !resource.IsPodResizeDeferred(pod) {","+\t\treturn nil","+\t}","+","+\tnode := nodeInfo.Node()","+\tif node == nil {","+\t\treturn fwk.NewStatus(fwk.Error, \"node not found\")","+\t}","+","+\tif pod.Spec.NodeName != \"\" && pod.Spec.NodeName != node.Name {","+\t\treturn fwk.NewStatus(fwk.UnschedulableAndUnresolvable, \"pod assigned to different node\")","+\t}","+","+\tif node.Spec.PodPreemptionPolicy != nil && len(node.Spec.PodPreemptionPolicy.DisableResizePreemption) > 0 {","+\t\treturn fwk.NewStatus(fwk.UnschedulableAndUnresolvable, ErrReasonNodeDisablesResizePreemption)","+\t}","+\treturn nil","+}","+","+// Permit invoked at the permit extension point.","+// It rejects deferred resize pods that successfully fit in order to keep them in the Unschedulable queue until","+// Kubelet can successfully actuate the resize.","+func (pl *DeferredPodScheduling) Permit(ctx context.Context, state fwk.CycleState, p *v1.Pod, nodeName string) (*fwk.Status, time.Duration) {","+\tif !pl.enableInPlacePodVerticalScalingSchedulerPreemption || !resource.IsPodResizeDeferred(p) {","+\t\treturn nil, 0","+\t}","+\treturn fwk.NewStatus(fwk.UnschedulableAndUnresolvable, \"pod resize fits, waiting for Kubelet actuation\"), 0","+}","+","+func New(_ context.Context, _ runtime.Object, _ fwk.Handle, fts feature.Features) (fwk.Plugin, error) {","+\treturn &DeferredPodScheduling{","+\t\tenableInPlacePodVerticalScalingSchedulerPreemption: fts.EnableInPlacePodVerticalScalingSchedulerPreemption,","+\t}, nil","+}"],"additions":162,"deletions":0,"truncated":false},{"path":"pkg/scheduler/framework/plugins/deferredpodscheduling/deferred_pod_scheduling_test.go","lines":["@@ -0,0 +1,392 @@","+/*","+Copyright The Kubernetes Authors.","+","+Licensed under the Apache License, Version 2.0 (the \"License\");","+you may not use this file except in compliance with the License.","+You may obtain a copy of the License at","+","+    http://www.apache.org/licenses/LICENSE-2.0","+","+Unless required by applicable law or agreed to in writing, software","+distributed under the License is distributed on an \"AS IS\" BASIS,","+WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.","+See the License for the specific language governing permissions and","+limitations under the License.","+*/","+","+package deferredpodscheduling","+","+import (","+\t\"context\"","+\t\"testing\"","+","+\tv1 \"k8s.io/api/core/v1\"","+\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"","+\t\"k8s.io/klog/v2/ktesting\"","+\tfwk \"k8s.io/kube-scheduler/framework\"","+\t\"k8s.io/kubernetes/pkg/scheduler/framework\"","+\tst \"k8s.io/kubernetes/pkg/scheduler/testing\"","+)","+","+func TestDeferredPodScheduling_PreFilter(t *testing.T) {","+\ttests := []struct {","+\t\tname       string","+\t\tpod        *v1.Pod","+\t\tgateOn     bool","+\t\twantStatus *fwk.Status","+\t}{","+\t\t{","+\t\t\tname: \"feature gate off, deferred pod -> skip\",","+\t\t\tpod: st.MakePod().Name(\"pod1\").Node(\"node1\").","+\t\t\t\tCondition(v1.PodResizePending, v1.ConditionTrue, v1.PodReasonDeferred).Obj(),","+\t\t\tgateOn:     false,","+\t\t\twantStatus: fwk.NewStatus(fwk.Skip),","+\t\t},","+\t\t{","+\t\t\tname:       \"feature gate on, non-deferred pod -> skip\",","+\t\t\tpod:        st.MakePod().Name(\"pod1\").Node(\"node1\").Obj(),","+\t\t\tgateOn:     true,","+\t\t\twantStatus: fwk.NewStatus(fwk.Skip),","+\t\t},","+\t\t{","+\t\t\tname: \"feature gate on, deferred pod -> success/nil\",","+\t\t\tpod: st.MakePod().Name(\"pod1\").Node(\"node1\").","+\t\t\t\tCondition(v1.PodResizePending, v1.ConditionTrue, v1.PodReasonDeferred).Obj(),","+\t\t\tgateOn:     true,","+\t\t\twantStatus: nil,","+\t\t},","+\t}","+","+\tfor _, tt := range tests {","+\t\tt.Run(tt.name, func(t *testing.T) {","+\t\t\tpl := &DeferredPodScheduling{","+\t\t\t\tenableInPlacePodVerticalScalingSchedulerPreemption: tt.gateOn,","+\t\t\t}","+\t\t\t_, status := pl.PreFilter(context.Background(), nil, tt.pod, nil)","+\t\t\tif !statusEqual(status, tt.wantStatus) {","+\t\t\t\tt.Errorf(\"PreFilter status = %v, want %v\", status, tt.wantStatus)","+\t\t\t}","+\t\t})","+\t}","+}","+","+func TestDeferredPodScheduling_Filter(t *testing.T) {","+\ttests := []struct {","+\t\tname       string","+\t\tpod        *v1.Pod","+\t\tnode       *v1.Node","+\t\tgateOn     bool","+\t\twantStatus *fwk.Status","+\t}{","+\t\t{","+\t\t\tname: \"feature gate off -> success (ignore disabled policy)\",","+\t\t\tpod: st.MakePod().Name(\"pod1\").Node(\"node1\").","+\t\t\t\tCondition(v1.PodResizePending, v1.ConditionTrue, v1.PodReasonDeferred).Obj(),","+\t\t\tnode: &v1.Node{","+\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"node1\"},","+\t\t\t\tSpec: v1.NodeSpec{","+\t\t\t\t\tPodPreemptionPolicy: &v1.NodePodPreemptionPolicy{","+\t\t\t\t\t\tDisableResizePreemption: []string{\"policy1\"},","+\t\t\t\t\t},","+\t\t\t\t},","+\t\t\t},","+\t\t\tgateOn:     false,","+\t\t\twantStatus: nil,","+\t\t},","+\t\t{","+\t\t\tname: \"feature gate on, non-deferred pod -> success (ignore disabled policy)\",","+\t\t\tpod:  st.MakePod().Name(\"pod1\").Node(\"node1\").Obj(),","+\t\t\tnode: &v1.Node{","+\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"node1\"},","+\t\t\t\tSpec: v1.NodeSpec{","+\t\t\t\t\tPodPreemptionPolicy: &v1.NodePodPreemptionPolicy{","+\t\t\t\t\t\tDisableResizePreemption: []string{\"policy1\"},","+\t\t\t\t\t},","+\t\t\t\t},","+\t\t\t},","+\t\t\tgateOn:     true,","+\t\t\twantStatus: nil,","+\t\t},","+\t\t{","+\t\t\tname: \"node has nil preemption policy -> success\",","+\t\t\tpod: st.MakePod().Name(\"pod1\").Node(\"node1\").","+\t\t\t\tCondition(v1.PodResizePending, v1.ConditionTrue, v1.PodReasonDeferred).Obj(),","+\t\t\tnode:       st.MakeNode().Name(\"node1\").Obj(),","+\t\t\tgateOn:     true,","+\t\t\twantStatus: nil,","+\t\t},","+\t\t{","+\t\t\tname: \"node has empty disable preemption policy -> success\",","+\t\t\tpod: st.MakePod().Name(\"pod1\").Node(\"node1\").","+\t\t\t\tCondition(v1.PodResizePending, v1.ConditionTrue, v1.PodReasonDeferred).Obj(),","+\t\t\tnode: &v1.Node{","+\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"node1\"},","+\t\t\t\tSpec: v1.NodeSpec{","+\t\t\t\t\tPodPreemptionPolicy: &v1.NodePodPreemptionPolicy{","+\t\t\t\t\t\tDisableResizePreemption: []string{},","+\t\t\t\t\t},","+\t\t\t\t},","+\t\t\t},","+\t\t\tgateOn:     true,","+\t\t\twantStatus: nil,","+\t\t},","+\t\t{","+\t\t\tname: \"node has disabled preemption policy -> unschedulable\",","+\t\t\tpod: st.MakePod().Name(\"pod1\").Node(\"node1\").","+\t\t\t\tCondition(v1.PodResizePending, v1.ConditionTrue, v1.PodReasonDeferred).Obj(),","+\t\t\tnode: &v1.Node{","+\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"node1\"},","+\t\t\t\tSpec: v1.NodeSpec{","+\t\t\t\t\tPodPreemptionPolicy: &v1.NodePodPreemptionPolicy{","+\t\t\t\t\t\tDisableResizePreemption: []string{\"policy1\"},","+\t\t\t\t\t},","+\t\t\t\t},","+\t\t\t},","+\t\t\tgateOn:     true,","+\t\t\twantStatus: fwk.NewStatus(fwk.UnschedulableAndUnresolvable, ErrReasonNodeDisablesResizePreemption),","+\t\t},","+\t\t{","+\t\t\tname: \"node name does not match pod assigned node -> unschedulable\",","+\t\t\tpod: st.MakePod().Name(\"pod1\").Node(\"node1\").","+\t\t\t\tCondition(v1.PodResizePending, v1.ConditionTrue, v1.PodReasonDeferred).Obj(),","+\t\t\tnode:       st.MakeNode().Name(\"node2\").Obj(),","+\t\t\tgateOn:     true,","+\t\t\twantStatus: fwk.NewStatus(fwk.UnschedulableAndUnresolvable, \"pod assigned to dif