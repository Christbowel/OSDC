{"id":"93ef7260f8ad03235ecfb74c6e7016124f6bd5a8","axis":"silent","repo":"kserve/kserve","sha":"93ef7260f8ad03235ecfb74c6e7016124f6bd5a8","parsed":{"files":[{"path":".github/workflows/e2e-test-llmisvc.yaml","lines":["@@ -18,7 +18,7 @@ on:","       - \"hack/setup/quick-install/llmisvc-dependency-install.sh\"","       - \"hack/setup/infra/manage.prometheus-helm.sh\"","       - \"hack/setup/infra/manage.prometheus-adapter-helm.sh\"","-      - \"hack/setup/infra/manage.wva-helm.sh\"","+      - \"hack/setup/infra/manage.wva-kustomize.sh\"","       - \"hack/setup/infra/manage.jaeger-helm.sh\"","       - \"hack/setup/infra/manage.kserve-helm.sh\"","       - \"hack/setup/quick-install/*-helm.sh\""],"additions":1,"deletions":1,"truncated":false},{"path":"Makefile","lines":["@@ -236,9 +236,6 @@ manifests: controller-gen kustomize yq"," \t$(KUSTOMIZE) build config/crd/full/llmisvc | $(YQ) 'select(.metadata.name == \"llminferenceservices.serving.kserve.io\")' > charts/kserve-llmisvc-crd/templates/serving.kserve.io_llminferenceservices.yaml"," \t$(KUSTOMIZE) build config/crd/full/llmisvc | $(YQ) 'select(.metadata.name == \"llminferenceserviceconfigs.serving.kserve.io\")' > charts/kserve-llmisvc-crd/templates/serving.kserve.io_llminferenceserviceconfigs.yaml"," \t","-\t# Copy the WVA VariantAutoscaling CRD for envtest","-\t$(KUSTOMIZE) build https://github.com/llm-d/llm-d-workload-variant-autoscaler.git/config/crd?ref=$(WVA_VERSION) > test/crds/wva_variantautoscalings.yaml","-"," \t# Copy the full crd to the test folder"," \t$(KUSTOMIZE) build config/crd/full > test/crds/serving.kserve.io_all_crds.yaml"," \techo \"---\" >> test/crds/serving.kserve.io_all_crds.yaml"],"additions":0,"deletions":3,"truncated":false},{"path":"charts/kserve-llmisvc-resources/files/llmisvc/resources.yaml","lines":["@@ -1319,13 +1319,8 @@ rules:","   resources:","   - variantautoscalings","   verbs:","-  - create","   - delete","-  - get","   - list","-  - patch","-  - update","-  - watch"," - apiGroups:","   - networking.k8s.io","   resources:"],"additions":0,"deletions":5,"truncated":false},{"path":"cmd/llmisvc/main.go","lines":["@@ -374,6 +374,15 @@ func main() {"," \t\tos.Exit(1)"," \t}"," ","+\t// Legacy VariantAutoscaling cleanup. Best-effort, never blocks the manager.","+\t// Can be removed in a future release cycle.","+\tif err := mgr.Add(leaderRunnable(func(ctx context.Context) error {","+\t\tcleanupLegacyVAs(ctx, dynamic.NewForConfigOrDie(cfg), setupLog)","+\t\treturn nil","+\t})); err != nil {","+\t\tsetupLog.Error(err, \"unable to register legacy VA cleanup, stale VAs may remain until manual cleanup or LLMInferenceService deletion\")","+\t}","+"," \tsetupLog.Info(\"starting manager\")"," \tif err := mgr.Start(ctx); err != nil {"," \t\tsetupLog.Error(err, \"unable to run the manager\")"],"additions":9,"deletions":0,"truncated":false},{"path":"cmd/llmisvc/migration.go","lines":["@@ -24,9 +24,68 @@ import ("," "," \t\"github.com/go-logr/logr\""," \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"","+\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"","+\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"","+\t\"k8s.io/apimachinery/pkg/runtime/schema\""," \t\"k8s.io/apimachinery/pkg/util/wait\"","+\t\"k8s.io/client-go/dynamic\"","+","+\t\"github.com/kserve/kserve/pkg/constants\""," )"," ","+// cleanupLegacyVAs deletes all VariantAutoscaling CRs left over from before","+// the annotation-based WVA migration. Best-effort: logs errors but never fails.","+// Can be removed in a future release cycle.","+func cleanupLegacyVAs(ctx context.Context, dynClient dynamic.Interface, log logr.Logger) {","+\tvaGVR := schema.GroupVersionResource{Group: \"llmd.ai\", Version: \"v1alpha1\", Resource: \"variantautoscalings\"}","+\tselector := constants.KubernetesPartOfLabelKey + \"=\" + constants.LLMInferenceServicePartOfValue","+","+\tvar list *unstructured.UnstructuredList","+\tvar lastErr error","+\t_ = wait.ExponentialBackoffWithContext(ctx, wait.Backoff{","+\t\tDuration: 1 * time.Second, Factor: 2, Steps: 3,","+\t}, func(ctx context.Context) (bool, error) {","+\t\tvar listErr error","+\t\tlist, listErr = dynClient.Resource(vaGVR).Namespace(\"\").List(ctx, metav1.ListOptions{","+\t\t\tLabelSelector: selector,","+\t\t})","+\t\tif listErr == nil {","+\t\t\treturn true, nil","+\t\t}","+\t\tif apierrors.IsNotFound(listErr) {","+\t\t\tlist = nil","+\t\t\treturn true, nil","+\t\t}","+\t\tlastErr = listErr","+\t\tlog.Error(listErr, \"legacy VA cleanup: failed to discover VariantAutoscaling resources, retrying\")","+\t\treturn false, nil","+\t})","+\tif list == nil {","+\t\tif lastErr != nil {","+\t\t\tlog.Error(lastErr, \"legacy VA cleanup: retries exhausted, stale VAs may remain until manual cleanup or LLMInferenceService deletion\")","+\t\t} else {","+\t\t\tlog.Info(\"VariantAutoscaling CRD not installed, skipping legacy VA cleanup\")","+\t\t}","+\t\treturn","+\t}","+","+\tvar deleted int","+\tfor i := range list.Items {","+\t\tva := &list.Items[i]","+\t\tif err := dynClient.Resource(vaGVR).Namespace(va.GetNamespace()).Delete(ctx, va.GetName(), metav1.DeleteOptions{}); err != nil {","+\t\t\tif !apierrors.IsNotFound(err) {","+\t\t\t\tlog.Error(err, \"failed to delete legacy VariantAutoscaling\", \"namespace\", va.GetNamespace(), \"name\", va.GetName())","+\t\t\t}","+\t\t\tcontinue","+\t\t}","+\t\tdeleted++","+\t\tlog.Info(\"deleted legacy VariantAutoscaling\", \"namespace\", va.GetNamespace(), \"name\", va.GetName())","+\t}","+\tif len(list.Items) > 0 {","+\t\tlog.Info(\"legacy VA cleanup completed; WVA >= v0.8.0 is required for annotation-based discovery\", \"deleted\", deleted, \"found\", len(list.Items))","+\t}","+}","+"," // fastMigrationBackoff is the phase-1 exponential backoff configuration."," // Cap must not be set: setting Cap zeroes Steps on first hit, causing early exit."," var fastMigrationBackoff = wait.Backoff{"],"additions":59,"deletions":0,"truncated":false},{"path":"config/rbac/llmisvc/role.yaml","lines":["@@ -199,13 +199