server-sent-requested-padding\",","+\t\t},","+\t})","+\t// Test that padding of 16k works.","+\ttestCases = append(testCases, testCase{","+\t\tname:     \"ServerPadding-16kPadding\",","+\t\ttestType: clientTest,","+\t\tconfig: Config{","+\t\t\tMinVersion: VersionTLS13,","+\t\t\tBugs: ProtocolBugs{","+\t\t\t\tSendServerPaddingLength: ptrTo(uint16(16384)),","+\t\t\t},","+\t\t},","+\t\tflags: []string{","+\t\t\t\"-request-server-padding\", \"16384\",","+\t\t\t\"-expect-server-sent-requested-padding\",","+\t\t},","+\t})","+\t// Server sends less than requested padding; should fail the","+\t// connection.","+\ttestCases = append(testCases, testCase{","+\t\tname:     \"ServerPadding-NotEnoughPadding\",","+\t\ttestType: clientTest,","+\t\tconfig: Config{","+\t\t\tMinVersion: VersionTLS13,","+\t\t\tBugs: ProtocolBugs{","+\t\t\t\tSendServerPaddingLength: ptrTo(uint16(5)),","+\t\t\t},","+\t\t},","+\t\tflags: []string{","+\t\t\t\"-request-server-padding\", \"10\",","+\t\t},","+\t\tshouldFail:         true,","+\t\texpectedError:      \":DECODE_ERROR:\",","+\t\texpectedLocalError: \"remote error: error decoding message\",","+\t})","+\t// Server sends more than requested padding; should fail the","+\t// connection.","+\ttestCases = append(testCases, testCase{","+\t\tname:     \"ServerPadding-TooMuchPadding\",","+\t\ttestType: clientTest,","+\t\tconfig: Config{","+\t\t\tMinVersion: VersionTLS13,","+\t\t\tBugs: ProtocolBugs{","+\t\t\t\tSendServerPaddingLength: ptrTo(uint16(50)),","+\t\t\t},","+\t\t},","+\t\tflags: []string{","+\t\t\t\"-request-server-padding\", \"10\",","+\t\t},","+\t\tshouldFail:         true,","+\t\texpectedError:      \":DECODE_ERROR:\",","+\t\texpectedLocalError: \"remote error: error decoding message\",","+\t})","+\t// Test server not sending padding in response to a padding request; should","+\t// not fail connection but also should not be counted as server sent correct","+\t// amount of padding.","+\ttestCases = append(testCases, testCase{","+\t\tname:     \"ServerPadding-NoPaddingSent\",","+\t\ttestType: clientTest,","+\t\tconfig: Config{","+\t\t\tMinVersion: VersionTLS13,","+\t\t},","+\t\tflags: []string{","+\t\t\t\"-request-server-padding\", \"10\",","+\t\t},","+\t})","+\t// TLS 1.2 connection should send no padding back without error.","+\ttestCases = append(testCases, testCase{","+\t\tname:     \"ServerPadding-TLS12-NoPadding\",","+\t\ttestType: clientTest,","+\t\tconfig: Config{","+\t\t\tMaxVersion: VersionTLS12,","+\t\t},","+\t\tflags: []string{","+\t\t\t\"-request-server-padding\", \"10\",","+\t\t},","+\t})","+\t// TLS 1.2 connection sending padding should result in a failed connection.","+\ttestCases = append(testCases, testCase{","+\t\tname:     \"ServerPadding-TLS12-PaddingSent\",","+\t\ttestType: clientTest,","+\t\tconfig: Config{","+\t\t\tMaxVersion: VersionTLS12,","+\t\t\tBugs: ProtocolBugs{","+\t\t\t\tSendServerPaddingLength: ptrTo(uint16(10)),","+\t\t\t},","+\t\t},","+\t\tflags: []string{","+\t\t\t\"-request-server-padding\", \"10\",","+\t\t},","+\t\tshouldFail:         true,","+\t\texpectedError:      \":UNEXPECTED_EXTENSION:\",","+\t\texpectedLocalError: \"remote error: unsupported extension\",","+\t})","+","+\t// Base test; runner doesn't ask for padding, shim doesn't send padding.","+\ttestCases = append(testCases, testCase{","+\t\tname:     \"ServerPaddingServer-NotRequested\",","+\t\ttestType: serverTest,","+\t\tconfig: Config{","+\t\t\tMinVersion: VersionTLS13,","+\t\t},","+\t})","+\t// Shim doesn't support padding.","+\ttestCases = append(testCases, testCase{","+\t\tname:     \"ServerPaddingServer-NoServerSupport\",","+\t\ttestType: serverTest,","+\t\tconfig: Config{","+\t\t\tMinVersion:           VersionTLS13,","+\t\t\tRequestServerPadding: ptrTo(uint16(10)),","+\t\t},","+\t})","+\t// Runner requests padding, shim sends padding.","+\ttestCases = append(testCases, testCase{","+\t\tname:     \"ServerPaddingServer-BasicPadding\",","+\t\ttestType: serverTest,","+\t\tconfig: Config{","+\t\t\tMinVers