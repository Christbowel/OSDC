{"id":"c094769a43d92e1ca73d6352ed0e7f28392c0e0d","axis":"silent","repo":"NVIDIA/OpenShell","sha":"c094769a43d92e1ca73d6352ed0e7f28392c0e0d","parsed":{"files":[{"path":"Cargo.lock","lines":["@@ -157,6 +157,16 @@ dependencies = [","  \"password-hash\","," ]"," ","+[[package]]","+name = \"assert-json-diff\"","+version = \"2.0.2\"","+source = \"registry+https://github.com/rust-lang/crates.io-index\"","+checksum = \"47e4f2b81832e72834d7518d8487a0396a28cc408186a2e8854c0f98011faf12\"","+dependencies = [","+ \"serde\",","+ \"serde_json\",","+]","+"," [[package]]"," name = \"async-stream\""," version = \"0.3.6\"","@@ -958,6 +968,24 @@ version = \"2.10.0\""," source = \"registry+https://github.com/rust-lang/crates.io-index\""," checksum = \"d7a1e2f27636f116493b8b860f5546edb47c8d8f8ea73e1d2a20be88e28d1fea\""," ","+[[package]]","+name = \"deadpool\"","+version = \"0.12.3\"","+source = \"registry+https://github.com/rust-lang/crates.io-index\"","+checksum = \"0be2b1d1d6ec8d846f05e137292d0b89133caf95ef33695424c09568bdd39b1b\"","+dependencies = [","+ \"deadpool-runtime\",","+ \"lazy_static\",","+ \"num_cpus\",","+ \"tokio\",","+]","+","+[[package]]","+name = \"deadpool-runtime\"","+version = \"0.1.4\"","+source = \"registry+https://github.com/rust-lang/crates.io-index\"","+checksum = \"092966b41edc516079bdf31ec78a2e0588d1d0c08f78b91d8307215928642b2b\"","+"," [[package]]"," name = \"delegate\""," version = \"0.13.5\"","@@ -1456,9 +1484,11 @@ source = \"registry+https://github.com/rust-lang/crates.io-index\""," checksum = \"899def5c37c4fd7b2664648c28120ecec138e4d395b459e5ca34f9cce2dd77fd\""," dependencies = [","  \"cfg-if\",","+ \"js-sys\",","  \"libc\",","  \"r-efi\",","  \"wasip2\",","+ \"wasm-bindgen\","," ]"," "," [[package]]","@@ -1604,6 +1634,12 @@ version = \"0.5.0\""," source = \"registry+https://github.com/rust-lang/crates.io-index\""," checksum = \"2304e00983f87ffb38b55b444b5e3b60a884b5d30c0fca7d82fe33449bbe55ea\""," ","+[[package]]","+name = \"hermit-abi\"","+version = \"0.5.2\"","+source = \"registry+https://github.com/rust-lang/crates.io-index\"","+checksum = \"fc0fef456e4baa96da950455cd02c081ca953b141298e41db3fc7e36b1da849c\"","+"," [[package]]"," name = \"hex\""," version = \"0.4.3\"","@@ -1751,6 +1787,7 @@ dependencies = [","  \"tokio\",","  \"tokio-rustls\",","  \"tower-service\",","+ \"webpki-roots 1.0.6\","," ]"," "," [[package]]","@@ -1772,13 +1809,16 @@ version = \"0.1.20\""," source = \"registry+https://github.com/rust-lang/crates.io-index\""," checksum = \"96547c2556ec9d12fb1578c4eaf448b04993e7fb79cbaad930a656880a6bdfa0\""," dependencies = [","+ \"base64 0.22.1\",","  \"bytes\",","  \"futures-channel\",","  \"futures-util\",","  \"http\",","  \"http-body\",","  \"hyper\",","+ \"ipnet\",","  \"libc\",","+ \"percent-encoding\",","  \"pin-project-lite\",","  \"socket2 0.6.2\",","  \"tokio\",","@@ -2016,6 +2056,22 @@ dependencies = [","  \"zeroize\","," ]"," ","+[[package]]","+name = \"ipnet\"","+version = \"2.11.0\"","+source = \"registry+https://github.com/rust-lang/crates.io-index\"","+checksum = \"469fb0b9cefa57e3ef31275ee7cacb78f2fdca44e4765491884a2b119d4eb130\"","+","+[[package]]","+name = \"iri-string\"","+version = \"0.7.10\"","+source = \"registry+https://github.com/rust-lang/crates.io-index\"","+checksum = \"c91338f0783edbd6195decb37bae672fd3b165faffb89bf7b9e6942f8b1a731a\"","+dependencies = [","+ \"memchr\",","+ \"serde\",","+]","+"," [[package]]"," name = \"is_ci\""," version = \"1.2.0\"","@@ -2361,6 +2417,12 @@ version = \"0.4.29\""," source = \"registry+https://github.com/rust-lang/crates.io-index\""," checksum = \"5e5032e24019045c762d3c0f28f5b6b8bbf38563a65908389bf7978758920897\""," ","+[[package]]","+name = \"lru-slab\"","+version = \"0.1.2\"","+source = \"registry+https://github.com/rust-lang/crates.io-index\"","+checksum = \"112b39cec0b298b6c1999fee3e31427f74f676e4cb9879ed1a121b43661a4154\"","+"," [[package]]"," name = \"matchers\""," version = \"0.2.0\"","@@ -2544,6 +2606,22 @@ dependencies = [","  \"tonic-