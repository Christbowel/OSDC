dfV4+p6VjEcOGdCtXc6rilE6iYpg==\"","+    }","+  },","+  \"workspace\": {","+    \"dependencies\": [","+      \"npm:@denotest/has-patch-versions@0.1\"","+    ]","+  }","+}"],"additions":16,"deletions":0,"truncated":false},{"path":"tests/specs/outdated/update_lockfile_only_bumps_within_range_deno_json/deno.lock.out","lines":["@@ -0,0 +1,12 @@","+{","+  \"version\": \"5\",","+  \"specifiers\": {","+    \"npm:@denotest/has-patch-versions@0.1\": \"0.1.1\"","+  },","+[WILDCARD]","+  \"workspace\": {","+    \"dependencies\": [","+      \"npm:@denotest/has-patch-versions@0.1\"","+    ]","+  }","+}"],"additions":12,"deletions":0,"truncated":false},{"path":"tests/specs/outdated/update_lockfile_only_bumps_within_range_deno_json/update.out","lines":["@@ -0,0 +1,2 @@","+[WILDCARD]Updated 1 dependency:","+ - npm:@denotest/has-patch-versions 0.1.0 -> 0.1.1"],"additions":2,"deletions":0,"truncated":false},{"path":"tests/specs/outdated/update_lockfile_only_stale_npm_cache/__test__.jsonc","lines":["@@ -0,0 +1,45 @@","+{","+  \"tempDir\": true,","+  \"envs\": {","+    \"DENO_DIR\": \"$PWD/deno_dir\"","+  },","+  \"tests\": {","+    // Regression test for denoland/deno#35348: `--lockfile-only` must bump the","+    // lockfile to the newer in-range version (0.1.0 -> 0.1.1) even when the","+    // cached npm registry packument is stale and predates 0.1.1. `setup.ts`","+    // simulates that stale cache by dropping 0.1.1/0.2.0 from the cached","+    // registry.json and pinning the lock back at 0.1.0. Before the fix the","+    // installer re-resolved against the stale cache and reported \"Updated 0","+    // dependencies\"; now it refetches metadata for the updated package.","+    \"stale_npm_cache\": {","+      \"steps\": [","+        {","+          \"args\": \"install\",","+          \"output\": \"[WILDCARD]\"","+        },","+        {","+          \"args\": \"run -A setup.ts\",","+          \"output\": \"[WILDCARD]\"","+        },","+        {","+          \"args\": \"update --lockfile-only\",","+          \"output\": \"update.out\"","+        },","+        {","+          \"args\": [","+            \"eval\",","+            \"console.log(Deno.readTextFileSync('./deno.lock').trim());\"","+          ],","+          \"output\": \"deno.lock.out\"","+        },","+        {","+          \"args\": [","+            \"eval\",","+            \"console.log(Deno.readTextFileSync('./package.json').trim());\"","+          ],","+          \"output\": \"package.json.out\"","+        }","+      ]","+    }","+  }","+}"],"additions":45,"deletions":0,"truncated":false},{"path":"tests/specs/outdated/update_lockfile_only_stale_npm_cache/deno.lock.out","lines":["@@ -0,0 +1,14 @@","+{","+  \"version\": \"5\",","+  \"specifiers\": {","+    \"npm:@denotest/has-patch-versions@0.1\": \"0.1.1\"","+  },","+[WILDCARD]","+  \"workspace\": {","+    \"packageJson\": {","+      \"dependencies\": [","+        \"npm:@denotest/has-patch-versions@0.1\"","+      ]","+    }","+  }","+}"],"additions":14,"deletions":0,"truncated":false},{"path":"tests/specs/outdated/update_lockfile_only_stale_npm_cache/package.json","lines":["@@ -0,0 +1,5 @@","+{","+  \"dependencies\": {","+    \"@denotest/has-patch-versions\": \"^0.1.0\"","+  }","+}"],"additions":5,"deletions":0,"truncated":false},{"path":"tests/specs/outdated/update_lockfile_only_stale_npm_cache/package.json.out","lines":["@@ -0,0 +1,5 @@","+{","+  \"dependencies\": {","+    \"@denotest/has-patch-versions\": \"^0.1.0\"","+  }","+}"],"additions":5,"deletions":0,"truncated":false},{"path":"tests/specs/outdated/update_lockfile_only_stale_npm_cache/setup.ts","lines":["@@ -0,0 +1,37 @@","+// Simulate a stale npm registry metadata cache. The user installed","+// @denotest/has-patch-versions back when only 0.1.0 existed, so their cached","+// packument predates the newer in-range 0.1.1 (and the out-of-range 0.2.0) and","+// their lockfile is pinned at 0.1.0. `deno update --lockfile-only` must still","+// pick up 0.1.1 by refetching metadata for the package. See denoland/deno#35348.","+","+// Drop 0.1.1 and 0.2.0 from the cached packument so the npm registry cache no","+// longer knows about any version newer than 0.1.0. The host directory is the","+// fixed test registry port (PUBLIC_NPM_REGISTRY_PORT = 4260).","+const registryPath =","+  \"deno_dir/npm/localhost_4260/@denotest/has-patch-versions/registry.json\";","+const registry = JSON.parse(Deno.readTextFileSync(registryPath));","+delete registry.versions[\"0.1.1\"];","+delete registry.versions[\"0.2.0\"];","+if (registry[\"dist-tags\"]) {","+  registry[\"dist-tags\"].latest = \"0.1.0\";","+}","+// Drop the cached etag. In the real-world scenario the cached packument","+// predates 0.1.1, so its stored etag no longer matches the registry and the","+// conditional refetch returns the updated packument. Here the test registry","+// always serves the full packument, so a kept etag would yield a spurious 304","+// Not Modified and hand back this truncated cache. Removing it makes the","+// refetch unconditional, mirroring a genuinely stale cache entry.","+delete registry[\"_deno.etag\"];","+Deno.writeTextFileSync(registryPath, JSON.stringify(registry));","+","+// Pin the lockfile back at the outdated 0.1.0.","+const lockPath = \"deno.lock\";","+const lock = JSON.parse(Deno.readTextFileSync(lockPath));","+lock.specifiers[\"npm:@denotest/has-patch-versions@0.1\"] = \"0.1.0\";","+lock.npm = {","+  \"@denotest/has-patch-versions@0.1.0\": {","+    \"integrity\":","+      \"sha512-H/MBo0jKDdMsX4AAGEGQbZj70nfNe3oUNZXbohYHhqf9EfpLnXp/7FC29ZdfV4+p6VjEcOGdCtXc6rilE6iYpg==\",","+  },","+};","+Deno.writeTextFileSync(lockPath, JSON.stringify(lock, null, 2) + \"\\n\");"],"additions":37,"deletions":0,"truncated":false},{"path":"tests/specs/outdated/update_lockfile_only_stale_npm_cache/update.out","lines":["@@ -0,0 +1,2 @@","+[WILDCARD]Updated 1 dependency:","+ - npm:@denotest/has-patch-versions 0.1.0 -> 0.1.1"],"additions":2,"deletions":0,"truncated":false},{"path":"tests/specs/outdated/update_only_req/update.out","lines":["@@ -1,2 +1,4 @@","+Download http://localhost:4260/@denotest%2fupdate-latest-semver","+Download http://localhost:4260/@denotest/update-latest-semver/1.0.1.tgz"," Updated 1 dependency:","  - npm:@denotest/update-latest-semver ^1.0.0 -> ^1.0.1",""],"additions":2,"deletions":0,"truncated":false}],"additions":343,"deletions":1,"truncated":false,"file_count":34},"error":null,"fetched_at":"2026-06-20T10:27:32.082317+00:00"}