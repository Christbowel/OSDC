_model.Repository{ID: 11})","+\trequire.NoError(t, baseRepo.LoadOwner(t.Context()))","+\trequire.NoError(t, headRepo.LoadOwner(t.Context()))","+","+\t// An open PR from the head repo owner, with maintainer edits allowed: this grants the base","+\t// repo owner write access to exactly this head branch and nothing else.","+\tpr := &issues_model.PullRequest{","+\t\tIssue: &issues_model.Issue{","+\t\t\tRepoID:   baseRepo.ID,","+\t\t\tPosterID: headRepo.OwnerID,","+\t\t},","+\t\tHeadRepoID:          headRepo.ID,","+\t\tBaseRepoID:          baseRepo.ID,","+\t\tHeadBranch:          \"granted-branch\",","+\t\tBaseBranch:          \"master\",","+\t\tAllowMaintainerEdit: true,","+\t}","+\trequire.NoError(t, issues_model.NewPullRequest(t.Context(), baseRepo, pr.Issue, nil, nil, pr))","+","+\t// The pusher is the base repo owner (the maintainer) with only read access on the head repo.","+\tmaintainer := baseRepo.Owner","+\theadPerm, err := access.GetIndividualUserRepoPermission(t.Context(), headRepo, maintainer)","+\trequire.NoError(t, err)","+","+\tmockCtx, _ := contexttest.MockPrivateContext(t, \"/\")","+\tctx := &preReceiveContext{","+\t\tPrivateContext: mockCtx,","+\t\tloadedPusher:   true,","+\t\tuser:           maintainer,","+\t\tuserPerm:       headPerm,","+\t}","+","+\t// The granted branch must be writable...","+\tassert.True(t, ctx.canWriteCodeRef(git.RefNameFromBranch(\"granted-branch\")))","+","+\t// ...but another branch in the same push must NOT inherit that grant.","+\tassert.False(t, ctx.canWriteCodeRef(git.RefNameFromBranch(\"master\")))","+","+\t// ...and a tag sharing the granted branch's name must NOT inherit it either: the grant is","+\t// scoped to PR head branches, so a non-branch ref can never match it. (A tag ref already","+\t// yields an empty branch name, so this guards the per-ref evaluation, not the IsBranch check.)","+\tassert.False(t, ctx.canWriteCodeRef(git.RefNameFromTag(\"granted-branch\")))","+}"],"additions":70,"deletions":0,"truncated":false