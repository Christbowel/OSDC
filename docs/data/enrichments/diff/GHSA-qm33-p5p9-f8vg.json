equire\"","+","+\t\"github.com/juev/nebula-mesh/internal/models\"","+)","+","+// TestCreateHost_RequiresNetworkOwnership verifies that non-owners cannot create hosts in foreign networks","+func TestCreateHost_RequiresNetworkOwnership(t *testing.T) {","+\tsrv, testDB := newTestServer(t)","+","+\t// Create two operators with different CAs","+\t_, _, ca1 := createOperatorWithCA(t, srv)","+\top2Key, _, _ := createOperatorWithCA(t, srv)","+","+\t// op1 creates a network under ca1","+\tnetwork := &models.Network{","+\t\tID:    \"test-net-1\",","+\t\tName:  \"Test Network 1\",","+\t\tCAID:  ca1.ID,","+\t\tCIDRs: []string{\"10.0.0.0/8\"},","+\t}","+\trequire.NoError(t, testDB.CreateNetwork(context.Background(), network))","+","+\t// op2 tries to create a host in op1's network → should fail with 403","+\treqBody := createHostRequest{","+\t\tName:      \"attacker-host\",","+\t\tNetworkID: network.ID,","+\t\tNebulaIPs: []string{\"10.0.0.5\"},","+\t}","+\tbody, _ := json.Marshal(reqBody)","+\treq := httptest.NewRequest(\"POST\", \"/api/v1/hosts\", bytes.NewReader(body))","+\treq.Header.Set(\"Authorization\", \"Bearer \"+op2Key)","+\treq.Header.Set(\"Content-Type\", \"application/json\")","+","+\tw := httptest.NewRecorder()","+\tsrv.ServeHTTP(w, req)","+","+\tassert.Equal(t, http.StatusForbidden, w.Code, \"non-owner should not be able to create host in foreign network\")","+}","+","+// TestCreateHost_OwnerSucceeds verifies that owners can create hosts in their","+// own networks and that the resulting host inherits the network's CAID rather","+// than the server's defaultCAID. The newTestServer fixture's defaultCAID","+// belongs to a different operator, so a stamping bug would surface here.","+func TestCreateHost_OwnerSucceeds(t *testing.T) {","+\tsrv, testDB := newTestServer(t)","+","+\t// Create operator with CA","+\topKey, _, ca := createOperatorWithCA(t, srv)","+\trequire.NotEqual(t, srv.defaultCAID, ca.ID,","+\t\t\"fixture invariant: operator CA must differ from defaultCAID\")","+","+\t// op creates a network under their CA","+\tnetwork := &models.Network{","+\t\tID:    \"test-net-owner\",","+\t\tName:  \"Owner Network\",","+\t\tCAID:  ca.ID,","+\t\tCIDRs: []string{\"10.0.0.0/8\"},","+\t}","+\trequire.NoError(t, testDB.CreateNetwork(context.Background(), network))","+","+\t// op creates a host in their own network → should succeed","+\treqBody := createHostRequest{","+\t\tName:      \"owner-host\",","+\t\tNetworkID: network.ID,","+\t\tNebulaIPs: []string{\"10.0.0.5\"},","+\t}","+\tbody, _ := json.Marshal(reqBody)","+\treq := httptest.NewRequest(\"POST\", \"/api/v1/hosts\", bytes.NewReader(body))","+\treq.Header.Set(\"Authorization\", \"Bearer \"+opKey)","+\treq.Header.Set(\"Content-Type\", \"application/json\")","+","+\tw := httptest.NewRecorder()","+\tsrv.ServeHTTP(w, req)","+","+\trequire.Equal(t, http.StatusCreated, w.Code, \"owner should be able to create host in own network\")","+","+\tvar resp createHostResponse","+\trequire.NoError(t, json.NewDecoder(w.Body).Decode(&resp))","+\tassert.Equal(t, network.CAID, resp.Host.CAID,","+\t\t\"host must inherit network.CAID, not server defaultCAID\")","+}","+","+// TestRotateCert_RequiresOwnership verifies that non-owners cannot trigger","+// cert rotation on hosts they don't own. Covers both new_key=true (sets","+// pending_rekey) and new_key=false (re-signs immediately). Without an","+// ownership gate, this endpoint reproduces the GHSA-598g class of bug on","+// the most destructive primitive in the host surface.","+func TestRotateCert_RequiresOwnership(t *testing.T) {","+\tsrv, testDB := newTestServer(t)","+","+\t_, _, ca1 := createOperatorWithCA(t, srv)","+\top2Key, _, _ := createOperatorWithCA(t, srv)"],"additions":104,"deletions":0,"truncated":false}],"additions":808,"deletions":3,"truncated":true,"file_count":8},"error":null,"fetched_at":"2026-06-09T10:50:06.378439+00:00"}