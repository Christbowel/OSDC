{"id":"GHSA-qm33-p5p9-f8vg","axis":"advisories","repo":"forgekeep/nebula-mesh","sha":"8baaace54c2a23e7c351b3efab5a31ab07b125dc","parsed":{"files":[{"path":"internal/api/audit.go","lines":["@@ -10,6 +10,10 @@ import ("," const defaultAuditLimit = 100"," "," func (s *Server) handleGetAuditLog(w http.ResponseWriter, r *http.Request) {","+\tif !actorIsAdmin(r.Context()) {","+\t\twriteError(w, http.StatusForbidden, \"audit log access requires the admin role\")","+\t\treturn","+\t}"," \tfilter := store.AuditFilter{"," \t\tAction: r.URL.Query().Get(\"action\"),"," \t\tLimit:  defaultAuditLimit,"],"additions":4,"deletions":0,"truncated":false},{"path":"internal/api/audit_authz_test.go","lines":["@@ -0,0 +1,33 @@","+package api","+","+import (","+\t\"net/http\"","+\t\"net/http/httptest\"","+\t\"testing\"","+)","+","+func TestGetAuditLog_RequiresAdminRole(t *testing.T) {","+\tsrv, _ := newTestServer(t)","+\tuserKey := createUserWithAPIKey(t, srv, \"user\")","+","+\treq := httptest.NewRequest(\"GET\", \"/api/v1/audit-log\", nil)","+\treq.Header.Set(\"Authorization\", \"Bearer \"+userKey)","+\trec := httptest.NewRecorder()","+\tsrv.ServeHTTP(rec, req)","+\tif rec.Code != http.StatusForbidden {","+\t\tt.Errorf(\"non-admin status = %d, want 403\", rec.Code)","+\t}","+}","+","+func TestGetAuditLog_AdminSucceeds(t *testing.T) {","+\tsrv, _ := newTestServer(t)","+\tadminKey := createUserWithAPIKey(t, srv, \"admin\")","+","+\treq := httptest.NewRequest(\"GET\", \"/api/v1/audit-log\", nil)","+\treq.Header.Set(\"Authorization\", \"Bearer \"+adminKey)","+\trec := httptest.NewRecorder()","+\tsrv.ServeHTTP(rec, req)","+\tif rec.Code != http.StatusOK {","+\t\tt.Errorf(\"admin status = %d, want 200; body=%s\", rec.Code, rec.Body.String())","+\t}","+}"],"additions":33,"deletions":0,"truncated":false},{"path":"internal/api/authz.go","lines":["@@ -0,0 +1,52 @@","+package api","+","+import (","+\t\"context\"","+\t\"errors\"","+","+\t\"github.com/juev/nebula-mesh/internal/models\"","+\t\"github.com/juev/nebula-mesh/internal/store\"","+)","+","+// actorOwnsCA returns true if the actor in ctx is admin, or owns the CA with caID.","+// Returns (false, nil) for empty caID or ErrNotFound. Errors only for unexpected DB errors.","+func (s *Server) actorOwnsCA(ctx context.Context, caID string) (bool, error) {","+\tif actorIsAdmin(ctx) {","+\t\treturn true, nil","+\t}","+\tif caID == \"\" {","+\t\treturn false, nil","+\t}","+\tactor := ActorOf(ctx)","+\tif actor == nil {","+\t\t// actorIsAdmin returned false but ActorOf is nil — defensive; treat as","+\t\t// forbidden. Unreachable on the current bearerAuth path; if it ever","+\t\t// fires it usually means middleware ordering regressed, so log loud.","+\t\ts.logger.Warn(\"authz: nil actor with non-admin context — bearerAuth ordering regression?\", \"ca_id\", caID)","+\t\treturn false, nil","+\t}","+\tca, err := s.store.GetCA(ctx, caID)","+\tif err != nil {","+\t\tif errors.Is(err, store.ErrNotFound) {","+\t\t\treturn false, nil","+\t\t}","+\t\treturn false, err","+\t}","+\treturn ca.OwnerOperatorID == actor.ID, nil","+}","+","+// canAccessHost returns true if the actor in ctx is admin, or owns the host's CA.","+func (s *Server) canAccessHost(ctx context.Context, h *models.Host) (bool, error) {","+\tif h == nil {","+\t\treturn false, nil","+\t}","+\treturn s.actorOwnsCA(ctx, h.CAID)","+}","+","+// canAccessNetwork returns true if the actor in ctx is admin, or owns the network's CA.","+func (s *Server) canAccessNetwork(ctx context.Context, n *models.Network) (bool, error) {","+\tif n == nil {","+\t\treturn false, nil","+\t}","+\treturn s.actorOwnsCA(ctx, n.CAID)","+}"],"additions":52,"deletions":0,"truncated":false},{"path":"internal/api/authz_test.go","lines":["@@ -0,0 +1,284 @@","+package api","+","+import (","+\t\"bytes\"","+\t\"context\"","+\t\"crypto/sha256\"","+\t\"encoding/hex\"","+\t\"io\"","+\t\"log/slog\"","+\t\"testing\"","+\t\"time\"","+","+\t\"github.com/google/uuid\"","+\t\"github.com/juev/nebula-mesh/internal/keystore\"","+\t\"github.com/juev/nebula-mesh/internal/models\"","+\t\"github.com/juev/nebula-mesh/internal/pki\"","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+)","+","+// createOperatorWithCA creates a non-admin operator with an API key and a CA owned by that operator.","+// Returns (plaintext apiKey, operator, ca).","+func createOperatorWithCA(t *testing.T, srv *Server) (string, *models.Operator, *models.CA) {","+\tt.Helper()","+\tctx := context.Background()","+","+\t// Create non-admin operator","+\top := &models.Operator{","+\t\tID:           uuid.New().String(),","+\t\tUsername:     \"user-\" + uuid.New().String()[:6],","+\t\tPasswordHash: \"test-hash\",","+\t\tRole:         \"user\",","+\t\tStatus:       models.OperatorStatusActive,","+\t\tAuthProvider: models.OperatorAuthLocal,","+\t\tCreatedAt:    time.Now(),","+\t\tUpdatedAt:    time.Now(),","+\t}","+\terr := srv.store.CreateOperator(ctx, op)","+\trequire.NoError(t, err)","+","+\t// Create API key for operator","+\trawKey := uuid.New().String()","+\tkeySum := sha256.Sum256([]byte(rawKey))","+\terr = srv.store.CreateOperatorAPIKey(ctx, &models.OperatorAPIKey{","+\t\tID:         uuid.New().String(),","+\t\tOperatorID: op.ID,","+\t\tKeyHash:    hex.EncodeToString(keySum[:]),","+\t})","+\trequire.NoError(t, err)","+","+\t// Create CA owned by operator using pki.MintAndStoreCA","+\t// Requires master keystore and logger (reuse from srv if available, or create minimal ones)","+\tmaster := srv.master","+\tif master == nil {","+\t\t// Fallback: create a temporary master for this test","+\t\trawMaster := bytes.Repeat([]byte{0x77}, keystore.MasterKeySize)","+\t\tmaster, err = keystore.NewMaster(rawMaster)","+\t\trequire.NoError(t, err)","+\t}","+","+\tlogger := slog.New(slog.NewTextHandler(io.Discard, nil))","+\tca, _, err := pki.MintAndStoreCA(ctx, srv.store, master, logger, pki.MintRequest{","+\t\tOperator: op,","+\t\tName:     \"test-ca-\" + uuid.New().String()[:6],","+\t\tDuration: 365 * 24 * time.Hour,","+\t})","+\trequire.NoError(t, err)","+","+\treturn rawKey, op, ca","+}","+","+func TestActorOwnsCA_Admin(t *testing.T) {","+\tsrv, st := newTestServer(t)","+\tctx := context.Background()","+","+\t// Admin operator","+\tadminOp := &models.Operator{","+\t\tID:           \"admin-op\",","+\t\tUsername:     \"admin-test\",","+\t\tPasswordHash: \"hash\",","+\t\tRole:         \"admin\",","+\t\tStatus:       models.OperatorStatusActive,","+\t\tAuthProvider: models.OperatorAuthLocal,","+\t}","+\tctx = context.WithValue(ctx, actorContextKey, adminOp)","+","+\t// Get the default CA from newTestServer (owned by test-admin, not admin-op)","+\tcas, err := st.ListCAs(ctx)","+\trequire.NoError(t, err)","+\trequire.True(t, len(cas) > 0, \"should have at least one CA from newTestServer\")","+\tca := cas[0]","+","+\t// Admin should have access to any CA, even one owned by another operator","+\tok, err := srv.actorOwnsCA(ctx, ca.ID)","+\trequire.NoError(t, err)","+\tassert.True(t, ok, \"admin should have access to any CA\")","+}","+","+func TestActorOwnsCA_Owner(t *testing.T) {","+\tsrv, _ := newTestServer(t)","+\tapiKey, op, ca := createOperatorWithCA(t, srv)","+","+\t// Authenticate as owner","+\tctx := context.Background()","+\tctx = context.WithValue(ctx, actorContextKey, op)","+","+\t// Owner should have access","+\tok, err := srv.actorOwnsCA(ctx, ca.ID)","+\trequire.NoError(t, err)","+\tassert.True(t, ok, \"owner should have access to owned CA\")","+\t_ = apiKey // prevent unused warning","+}","+","+func TestActorOwnsCA_NonOwner(t *testing.T) {","+\tsrv, _ := newTestServer(t)","+\t_, owner, ca := createOperatorWithCA(t, srv)","+","+\t// Create different non-admin operator","+\tctx := context.Background()","+\tother := &models.Operator{","+\t\tID:           uuid.New().String(),","+\t\tUsername:     \"other-user\",","+\t\tPasswordHash: \"hash\",","+\t\tRole:         \"user\",","+\t\tStatus:       models.OperatorStatusActive,","+\t\tAuthProvider: models.OperatorAuthLocal,","+\t}","+\terr := srv.store.CreateOperator(ctx, other)","+\trequire.NoError(t, err)","+","+\t// Other operator should not have access","+\tctx = context.WithValue(ctx, actorContextKey, other)","+\tok, err := srv.actorOwnsCA(ctx, ca.ID)","+\trequire.NoError(t, err)","+\tassert.False(t, ok, \"non-owner should not have access\")","+\t_ = owner // prevent unused warning","+}","+","+func TestActorOwnsCA_EmptyCAID(t *testing.T) {","+\tsrv, _ := newTestServer(t)","+\tctx := context.Background()","+","+\top := &models.Operator{","+\t\tID:           uuid.New().String(),","+\t\tUsername:     \"test-user\",","+\t\tPasswordHash: \"hash\",","+\t\tRole:         \"user\",","+\t\tStatus:       models.OperatorStatusActive,","+\t\tAuthProvider: models.OperatorAuthLocal,","+\t}","+\tctx = context.WithValue(ctx, actorContextKey, op)","+","+\t// Empty CA ID should return false","+\tok, err := srv.actorOwnsCA(ctx, \"\")","+\trequire.NoError(t, err)","+\tassert.False(t, ok, \"empty caID should return false\")","+}","+","+func TestActorOwnsCA_CANotFound(t *testing.T) {","+\tsrv, _ := newTestServer(t)","+\tctx := context.Background()","+","+\top := &models.Operator{","+\t\tID:           uuid.New().String(),","+\t\tUsername:     \"test-user\",","+\t\tPasswordHash: \"hash\",","+\t\tRole:         \"user\",","+\t\tStatus:       models.OperatorStatusActive,","+\t\tAuthProvider: models.OperatorAuthLocal,","+\t}","+\terr := srv.store.CreateOperator(ctx, op)","+\trequire.NoError(t, err)","+","+\tctx = context.WithValue(ctx, actorContextKey, op)","+","+\t// Non-existent CA should return false without error","+\tok, err := srv.actorOwnsCA(ctx, \"nonexistent-ca-id\")","+\trequire.NoError(t, err)","+\tassert.False(t, ok, \"non-existent CA should return false\")","+}","+","+func TestCanAccessHost_Owner(t *testing.T) {","+\tsrv, _ := newTestServer(t)","+\t_, op, ca := createOperatorWithCA(t, srv)","+","+\tctx := context.Background()","+\tctx = context.WithValue(ctx, actorContextKey, op)","+","+\t// Create host in operator's CA","+\thost := &models.Host{","+\t\tID:        uuid.New().String(),","+\t\tNetworkID: \"test-network\",","+\t\tCAID:      ca.ID,","+\t\tName:      \"test-host\",","+\t}","+","+\tok, err := srv.canAccessHost(ctx, host)","+\trequire.NoError(t, err)","+\tassert.True(t, ok, \"owner should have access to host in their CA\")","+}","+","+func TestCanAccessHost_NonOwner(t *testing.T) {","+\tsrv, _ := newTestServer(t)","+\t_, op1, ca := createOperatorWithCA(t, srv)","+","+\t// Create another operator","+\top2 := &models.Operator{","+\t\tID:           uuid.New().String(),","+\t\tUsername:     \"other-user\",","+\t\tPasswordHash: \"hash\",","+\t\tRole:         \"user\",","+\t\tStatus:       models.OperatorStatusActive,","+\t\tAuthProvider: models.OperatorAuthLocal,","+\t}","+\terr := srv.store.CreateOperator(context.Background(), op2)","+\trequire.NoError(t, err)","+","+\tctx := context.Background()","+\tctx = context.WithValue(ctx, actorContextKey, op2)","+","+\t// Try to access host in other operator's CA","+\thost := &models.Host{","+\t\tID:        uuid.New().String(),","+\t\tNetworkID: \"test-network\",","+\t\tCAID:      ca.ID,","+\t\tName:      \"test-host\",","+\t}","+","+\tok, err := srv.canAccessHost(ctx, host)","+\trequire.NoError(t, err)","+\tassert.False(t, ok, \"non-owner should not have access to host in other's CA\")","+\t_ = op1 // prevent unused warning","+}","+","+func TestCanAccessNetwork_Owner(t *testing.T) {","+\tsrv, _ := newTestServer(t)","+\t_, op, ca := createOperatorWithCA(t, srv)","+","+\tctx := context.Background()","+\tctx = context.WithValue(ctx, actorContextKey, op)","+","+\t// Create network in operator's CA","+\tnetwork := &models.Network{","+\t\tID:   uuid.New().String(),","+\t\tName: \"test-network\",","+\t\tCAID: ca.ID,","+\t}","+","+\tok, err := srv.canAccessNetwork(ctx, network)","+\trequire.NoError(t, err)","+\tassert.True(t, ok, \"owner should have access to network in their CA\")","+}","+","+func TestCanAccessNetwork_NonOwner(t *testing.T) {","+\tsrv, _ := newTestServer(t)","+\t_, op1, ca := createOperatorWithCA(t, srv)","+","+\t// Create another operator","+\top2 := &models.Operator{","+\t\tID:           uuid.New().String(),","+\t\tUsername:     \"other-user\",","+\t\tPasswordHash: \"hash\",","+\t\tRole:         \"user\",","+\t\tStatus:       models.OperatorStatusActive,","+\t\tAuthProvider: models.OperatorAuthLocal,","+\t}","+\terr := srv.store.CreateOperator(context.Background(), op2)","+\trequire.NoError(t, err)","+","+\tctx := context.Background()","+\tctx = context.WithValue(ctx, actorContextKey, op2)","+","+\t// Try to access network in other operator's CA","+\tnetwork := &models.Network{","+\t\tID:   uuid.New().String(),","+\t\tName: \"test-network\",","+\t\tCAID: ca.ID,","+\t}","+","+\tok, err := srv.canAccessNetwork(ctx, network)","+\trequire.NoError(t, err)","+\tassert.False(t, ok, \"non-owner should not have access to network in other's CA\")","+\t_ = op1 // prevent unused warning","+}"],"additions":284,"deletions":0,"truncated":false},{"path":"internal/api/firewall.go","lines":["@@ -29,6 +29,27 @@ var defaultFirewallRules = firewallRulesRequest{"," func (s *Server) handleGetFirewall(w http.ResponseWriter, r *http.Request) {"," \tnetworkID := chi.URLParam(r, \"id\")"," ","+\tnetwork, err := s.store.GetNetwork(r.Context(), networkID)","+\tif errors.Is(err, store.ErrNotFound) {","+\t\twriteError(w, http.StatusNotFound, \"network not found\")","+\t\treturn","+\t}","+\tif err != nil {","+\t\ts.logger.Error(\"get network for firewall\", \"error\", err)","+\t\twriteError(w, http.StatusInternalServerError, \"failed to load network\")","+\t\treturn","+\t}","+\tok, err := s.canAccessNetwork(r.Context(), network)","+\tif err != nil {","+\t\ts.logger.Error(\"authz check\", \"error\", err)","+\t\twriteError(w, http.StatusInternalServerError, \"authz check failed\")","+\t\treturn","+\t}","+\tif !ok {","+\t\twriteError(w, http.StatusForbidden, \"forbidden\")","+\t\treturn","+\t}","+"," \trules, err := s.getFirewallRules(r, networkID)"," \tif err != nil {"," \t\ts.logger.Error(\"get firewall rules\", \"error\", err)","@@ -42,6 +63,27 @@ func (s *Server) handleGetFirewall(w http.ResponseWriter, r *http.Request) {"," func (s *Server) handleUpdateFirewall(w http.ResponseWriter, r *http.Request) {"," \tnetworkID := chi.URLParam(r, \"id\")"," ","+\tnetwork, err := s.store.GetNetwork(r.Context(), networkID)","+\tif errors.Is(err, store.ErrNotFound) {","+\t\twriteError(w, http.StatusNotFound, \"network not found\")","+\t\treturn","+\t}","+\tif err != nil {","+\t\ts.logger.Error(\"get network for firewall update\", \"error\", err)","+\t\twriteError(w, http.StatusInternalServerError, \"failed to load network\")","+\t\treturn","+\t}","+\tok, err := s.canAccessNetwork(r.Context(), network)","+\tif err != nil {","+\t\ts.logger.Error(\"authz check\", \"error\", err)","+\t\twriteError(w, http.StatusInternalServerError, \"authz check failed\")","+\t\treturn","+\t}","+\tif !ok {","+\t\twriteError(w, http.StatusForbidden, \"forbidden\")","+\t\treturn","+\t}","+"," \tvar req firewallRulesRequest"," \tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {"," \t\twriteError(w, http.StatusBadRequest, \"invalid request body\")"],"additions":42,"deletions":0,"truncated":false},{"path":"internal/api/firewall_authz_test.go","lines":["@@ -0,0 +1,124 @@","+package api","+","+import (","+\t\"bytes\"","+\t\"context\"","+\t\"encoding/json\"","+\t\"fmt\"","+\t\"net/http\"","+\t\"net/http/httptest\"","+\t\"testing\"","+","+\t\"github.com/juev/nebula-mesh/internal/models\"","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+)","+","+// TestGetFirewall_RequiresOwnership verifies that a non-owner cannot read","+// firewall rules of another operator's network.","+func TestGetFirewall_RequiresOwnership(t *testing.T) {","+\tsrv, testDB := newTestServer(t)","+","+\t_, _, ca1 := createOperatorWithCA(t, srv)","+\top2Key, _, _ := createOperatorWithCA(t, srv)","+","+\tnet1 := &models.Network{","+\t\tID:    \"net-fw-get-1\",","+\t\tName:  \"Net FW Get 1\",","+\t\tCAID:  ca1.ID,","+\t\tCIDRs: []string{\"10.0.0.0/8\"},","+\t}","+\trequire.NoError(t, testDB.CreateNetwork(context.Background(), net1))","+","+\treq := httptest.NewRequest(\"GET\", fmt.Sprintf(\"/api/v1/networks/%s/firewall\", net1.ID), nil)","+\treq.Header.Set(\"Authorization\", \"Bearer \"+op2Key)","+\tw := httptest.NewRecorder()","+\tsrv.ServeHTTP(w, req)","+","+\tassert.Equal(t, http.StatusForbidden, w.Code, \"non-owner should not read firewall rules of foreign network\")","+}","+","+// TestUpdateFirewall_RequiresOwnership verifies that a non-owner cannot","+// mutate firewall rules of another operator's network.","+func TestUpdateFirewall_RequiresOwnership(t *testing.T) {","+\tsrv, testDB := newTestServer(t)","+","+\t_, _, ca1 := createOperatorWithCA(t, srv)","+\top2Key, _, _ := createOperatorWithCA(t, srv)","+","+\tnet1 := &models.Network{","+\t\tID:    \"net-fw-upd-1\",","+\t\tName:  \"Net FW Upd 1\",","+\t\tCAID:  ca1.ID,","+\t\tCIDRs: []string{\"10.0.0.0/8\"},","+\t}","+\trequire.NoError(t, testDB.CreateNetwork(context.Background(), net1))","+","+\tbody, _ := json.Marshal(map[string]any{","+\t\t\"inbound\": []map[string]string{","+\t\t\t{\"port\": \"22\", \"proto\": \"tcp\", \"group\": \"admin\"},","+\t\t},","+\t\t\"outbound\": []map[string]string{","+\t\t\t{\"port\": \"any\", \"proto\": \"any\", \"group\": \"any\"},","+\t\t},","+\t})","+\treq := httptest.NewRequest(\"PUT\", fmt.Sprintf(\"/api/v1/networks/%s/firewall\", net1.ID), bytes.NewBuffer(body))","+\treq.Header.Set(\"Authorization\", \"Bearer \"+op2Key)","+\tw := httptest.NewRecorder()","+\tsrv.ServeHTTP(w, req)","+","+\tassert.Equal(t, http.StatusForbidden, w.Code, \"non-owner should not update firewall rules of foreign network\")","+}","+","+// TestGetFirewall_OwnerSucceeds verifies the happy path: the owner of the","+// network's CA can