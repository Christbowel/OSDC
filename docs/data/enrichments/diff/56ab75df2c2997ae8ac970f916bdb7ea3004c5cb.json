reserveGlobalState    disabled","+ */","+class IncludeExtendsBlockLeakIssue1189Test extends PHPUnit_Smarty","+{","+    public function setUp(): void","+    {","+        $this->setUpSmarty(__DIR__);","+    }","+","+    /**","+     * Sequence: include parent -> include child(extends parent) -> include parent.","+     * Expected: PARENT CHILD PARENT","+     * Bug (#1189): PARENT CHILD CHILD","+     */","+    public function testBlockOverrideDoesNotLeakIntoLaterParentInclude()","+    {","+        $result = $this->smarty->fetch('top.tpl');","+        $this->assertSame('PARENT CHILD PARENT', preg_replace('/\\s+/', ' ', trim($result)));","+    }","+}"],"additions":33,"deletions":0,"truncated":false},{"path":"tests/UnitTests/TemplateSource/_Issues/1189/templates/child.tpl","lines":["@@ -0,0 +1,2 @@","+{extends file=\"parent.tpl\"}","+{block name=message}CHILD{/block}","\\ No newline at end of file"],"additions":2,"deletions":0,"truncated":false},{"path":"tests/UnitTests/TemplateSource/_Issues/1189/templates/parent.tpl","lines":["@@ -0,0 +1 @@","+{block name=message}PARENT{/block}","\\ No newline at end of file"],"additions":1,"deletions":0,"truncated":false},{"path":"tests/UnitTests/TemplateSource/_Issues/1189/templates/top.tpl","lines":["@@ -0,0 +1 @@","+{include file=\"parent.tpl\"} {include file=\"child.tpl\"} {include file=\"parent.tpl\"}","\\ No newline at end of file",""],"additions":1,"deletions":0,"truncated":false}],"additions":43,"deletions":2,"truncated":false,"file_count":5},"error":null,"fetched_at":"2026-06-24T10:42:02.876776+00:00"}