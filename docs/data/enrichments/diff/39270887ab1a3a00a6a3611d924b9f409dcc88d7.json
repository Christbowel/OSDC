ler is the entry point for the jaeger-query AI gateway. It owns the","-// per-turn contextual tools store, the session-stream registry, and the chat","-// handler, and registers them on the caller-provided mux (see RegisterRoutes in","-// routes.go).","-//","-// Callers construct a Handler once (in jaegerquery's Start path), then call","-// RegisterRoutes when wiring the HTTP mux. This mirrors the APIHandler /","-// HTTPGateway pattern used by sibling jaeger-query subsystems and keeps all","-// AI dependencies inside the jaegerai package.","-type Handler struct {","-\tlogger *zap.Logger","-\t// store and streams are two per-session registries that are separate only","-\t// during this transition, because they're keyed differently: store by the","-\t// ACP session id (read by the ext-method tool-call dispatch), streams by the","-\t// gateway-minted UUID in the session-scoped MCP URL — and there is no bridge","-\t// between the two ids. Once UI tools are served over the MCP endpoint and the","-\t// ext-method path is retired, they collapse into one session container keyed","-\t// by the UUID.","-\tstore              *ContextualToolsStore","-\tstreams            *sessionStreams","-\tagentURL           string","-\tbasePath           string","-\tmaxRequestBodySize int64","-\t// mcpHandler serves the session-scoped MCP endpoint. Non-nil only when the","-\t// operator enabled MCP (HandlerParams.EnableMCP); otherwise the endpoint is","-\t// not mounted and the gateway advertises AI chat only.","-\tmcpHandler http.Handler","-}","-","-// HandlerParams carries the dependencies for the AI gateway Handler. Grouping","-// them in a struct keeps the constructor readable as the gateway gains MCP","-// wiring (query service, tenancy, telemetry) on top of the chat parameters.","-type HandlerParams struct {","-\tLogger             *zap.Logger","-\tAgentURL           string","-\tBasePath           string","-\tMaxRequestBodySize int64","-\t// EnableMCP mounts the session-scoped telemetry MCP endpoint. When false,","-\t// only the chat endpoint is registered.","-\tEnableMCP    bool","-\tQueryService *querysvc.QueryService","-\tTenancyMgr   *tenancy.Manager","-\tTelset       telemetry.Settings","-}","-","-// NewHandler constructs a jaegerai.Handler with a freshly-allocated","-// ContextualToolsStore and sessionStreams. basePath is normalized once so the","-// registered mux patterns use a single canonical prefix. When p.EnableMCP is","-// set, the session-scoped MCP handler is built from the supplied query service,","-// tenancy manager, and telemetry settings.","-func NewHandler(p HandlerParams) *Handler {","-\tbasePath := normalizeBasePath(p.BasePath)","-\th := &Handler{","-\t\tlogger:             p.Logger,","-\t\tstore:              NewContextualToolsStore(),","-\t\tstreams:            newSessionStreams(),","-\t\tagentURL:           p.AgentURL,","-\t\tbasePath:           basePath,","-\t\tmaxRequestBodySize: p.MaxRequestBodySize,","-\t}","-\tif p.EnableMCP {","-\t\th.mcpHandler = newMCPSessionHandler(p.Telset, p.QueryService, p.TenancyMgr, h.streams, basePath, p.Logger)","-\t}","-\treturn h","-}","-"," // ChatRequest is the AG-UI payload accepted by the chat endpoint. It is the"," // AG-UI RunAgentInput shape — messages, tools, context, thread/run ids — so"," // the gateway can be addressed by stock AG-UI clients without translation."," type ChatRequest = aguitypes.RunAgentInput"," ","-// ChatHandler manages the AI gateway requests. Incoming AG-UI RunAgentInput","+// chatEndpoint manages the AI gateway requests. Incoming AG-UI RunAgentInput"," // payloads are translated into ACP prompts against a sidecar agent, and the"," // resulting ACP notifications are streamed back to the caller as AG-UI SSE"," // events.","-type ChatHandler struct {","+type chatEndpoint struct {"," \tLogger   *zap.Logger"," \tctxTools *ContextualToolsStore","-\t// streams registers this turn's SSE streaming client under a session id so","-\t// the session-scoped MCP endpoint can confirm the id belongs to an active","-\t// turn. May be nil in tests that do not exercise session registration.","-\tstreams            *sessionStreams","+\t// turns registers each turn's SSE streaming client and UI tools so the","+\t// turn-scoped MCP endpoint can resolve an active turn. Always non-nil (set by","+\t// the constructor).","+\tturns              *turnRegistry"," \tsidecarWSURL       string"," \tbasePath           string"," \tmaxRequestBodySize int64"," }"," ","-// NewChatHandler wires the chat endpoint against a sidecar WebSocket URL.","-// ctxTools may be nil in tests that do not exercise contextual tooling.","-// basePath is the jaeger-query base path; it is normalized once and kept","-// on the handler for consistency with other route handlers in this","-// package (APIHandler, static_handler) even though ServeHTTP does not","-// currently read it.","-func NewChatHandler(logger *zap.Logger, ctxTools *ContextualToolsStore, sidecarWSURL, basePath string, maxRequestBodySize int64) *ChatHandler {","-\treturn &ChatHandler{","+// newChatEndpoint wires the chat endpoint against a sidecar WebSocket URL.","+// ctxTools may be nil in tests that do not exercise contextual tooling. basePath","+// is the jaeger-query base path; it is normalized once and kept on the endpoint","+// for consistency with sibling handlers even though ServeHTTP does not currently","+// read it.","+func newChatEndpoint(logger *zap.Logger, ctxTools *ContextualToolsStore, turns *turnRegistry, sidecarWSURL, basePath string, maxRequestBodySize int64) *chatEndpoint {","+\treturn &chatEndpoint{"," \t\tLogger:             logger,"," \t\tctxTools:           ctxTools,","+\t\tturns:              turns,"," \t\tsidecarWSURL:       sidecarWSURL,"," \t\tbasePath:           normalizeBasePath(basePath),"," \t\tmaxRequestBodySize: maxRequestBodySize,"," \t}"," }"," ","-func (h *ChatHandler) ServeHTTP(w http.ResponseWriter, r *http.Request) {","+func (h *chatEndpoint) ServeHTTP(w http.ResponseWri