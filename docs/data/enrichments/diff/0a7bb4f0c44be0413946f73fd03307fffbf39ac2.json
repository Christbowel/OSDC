 &[","+        0x01, // little-endian","+        0x01, 0x00, 0x00, 0x80, // type = Point | Z flag","+        0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0xF0, 0x3F, // x = 1.0","+        0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x40, // y = 2.0","+        0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x08, 0x40, // z = 3.0","+    ];","+    let bbox = ewkb_to_bbox(ewkb).unwrap().bbox.unwrap();","+    assert_eq!(bbox, Bbox::from_corners(1.0, 2.0, 1.0, 2.0));","+}"],"additions":70,"deletions":0,"truncated":false},{"path":"src/common/io/tests/it/main.rs","lines":["@@ -23,5 +23,6 @@ mod bincode_serialization;"," mod borsh_serialization;"," mod cursor_ext;"," mod escape;","+mod geometry;"," mod interval;"," mod serialization_format_compatibility;"],"additions":1,"deletions":0,"truncated":false},{"path":"src/query/expression/src/types/geometry.rs","lines":["@@ -17,7 +17,9 @@ use std::ops::Range;"," "," use databend_common_exception::ErrorCode;"," use databend_common_exception::Result;","+use databend_common_io::Bbox;"," use databend_common_io::GEOGRAPHY_SRID;","+use databend_common_io::ewkb_to_bbox;"," use databend_common_io::ewkb_to_geo;"," use geo::Geometry;"," use geozero::ToGeo;","@@ -242,3 +244,21 @@ pub fn extract_geo_and_srid(value: ScalarRef) -> Result<Option<(Geometry<f64>, i","     };","     Ok(Some((geo, srid)))"," }","+","+/// Compute the bounding box of a geometry/geography scalar by streaming over its","+/// EWKB coordinates, avoiding the cost of materializing a `geo::Geometry`.","+///","+/// SRID follows the same rule as [`extract_geo_and_srid`]: geometries carry their","+/// own SRID (0 when absent), geographies are always [`GEOGRAPHY_SRID`].","+pub fn extract_bbox_and_srid(value: ScalarRef) -> Result<Option<(Option<Bbox>, i32)>> {","+    let (ewkb, geography_srid) = match value {","+        ScalarRef::Geometry(buf) => (buf, None),","+        ScalarRef::Geography(buf) => (buf.0, Some(GEOGRAPHY_SRID)),","+        _ => return Ok(None),","+    };","+    let Some(result) = ewkb