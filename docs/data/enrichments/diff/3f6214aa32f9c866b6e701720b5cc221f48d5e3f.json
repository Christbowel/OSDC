,"+CALL run_and_check_idx(240, 2, 't1_ahi_default');","+result_msg","+# No AHI used in SELECT (idx_2)","+CALL run_and_check_idx(240, 3, 't1_ahi_default');","+result_msg","+# No AHI used in SELECT (idx_3)","+RENAME TABLE t1_ahi_default TO t1;","+ALTER TABLE t1 adaptive_hash_index=OFF, ALGORITHM=INSTANT, LOCK=NONE;","+RENAME TABLE t1 TO t1_ahi_no;","+CALL run_and_check_idx(240, 1, 't1_ahi_no');","+result_msg","+# No AHI used in SELECT (idx_1)","+CALL run_and_check_idx(240, 2, 't1_ahi_no');","+result_msg","+# No AHI used in SELECT (idx_2)","+CALL run_and_check_idx(240, 3, 't1_ahi_no');","+result_msg","+# No AHI used in SELECT (idx_3)","+RENAME TABLE t1_ahi_no TO t1;","+ALTER TABLE t1 adaptive_hash_index='ON', ALGORITHM=INSTANT, LOCK=NONE;","+RENAME TABLE t1 TO t1_ahi_yes;","+CALL run_and_check_idx(240, 1, 't1_ahi_yes');","+result_msg","+# No AHI used in SELECT (idx_1)","+CALL run_and_check_idx(240, 2, 't1_ahi_yes');","+result_msg","+# No AHI used in SELECT (idx_2)","+CALL run_and_check_idx(240, 3, 't1_ahi_yes');","+result_msg","+# No AHI used in SELECT (idx_3)","+ALTER TABLE t1_ahi_yes ADD INDEX idx_4 (col2) complete_fields=3  /* complete_fields=3 > n_uniq==2 (col2 + id), will get clamped to 2 in innodb_ahi_enable() */;","+ALTER TABLE t1_ahi_yes ADD INDEX idx_5 (col3) bytes_from_incomplete_field=5  /* bytes_from_incomplete_field=5 > maximum of 4 (col3 INT), will get clamped in rec_fold() */;","+ALTER TABLE t1_ahi_yes ADD INDEX idx_6 (col2, col1) complete_fields=0 bytes_from_incomplete_field=0 for_equal_hash_point_to_last_record=0  /* complete_fields=0 bytes_from_incomplete_field=0 will disable AHI in innodb_ahi_enable() */;","+ALTER TABLE t1_ahi_yes ADD INDEX idx_7 (col3, col2) complete_fields=0 bytes_from_incomplete_field=0 for_equal_hash_point_to_last_record=1  /* complete_fields=0 bytes_from_incomplete_field=0 will disable AHI in innodb_ahi_enable() */;","+ALTER TABLE t1_ahi_yes ADD INDEX idx_8 (col3, col2, col1) complete_fields=4 bytes_from_incomplete_field=1  /* bytes_from_incomplete_field=1 is inapplicable since complete_fields=4 covers all unique fields (col3 + col2 + col1 + id), will get reset to 0 in innodb_ahi_enable() */;","+CALL run_and_check_idx(240, 4, 't1_ahi_yes');","+result_msg","+# No AHI used in SELECT (idx_4)","+CALL run_and_check_idx(240, 5, 't1_ahi_yes');","+result_msg","+# No AHI used in SELECT (idx_5)","+CALL run_and_check_idx(240, 6, 't1_ahi_yes');","+result_msg","+# No AHI used in SELECT (idx_6)","+CALL run_and_check_idx(240, 7, 't1_ahi_yes');","+result_msg","+# No AHI used in SELECT (idx_7)","+CALL run_and_check_idx(240, 8, 't1_ahi_yes');","+result_msg","+# No AHI used in SELECT (idx_8)","+DROP TABLE t1_ahi_yes;","+SET GLOBAL DEBUG_DBUG=@orig_debug;","+#","+# Test ALTER TABLE adaptive_hash_index=OFF with concurrent AHI access","+#","+CREATE TABLE t1_ahi_default_2 (","+id INT PRIMARY KEY,","+col1 INT,","+INDEX idx_1 (col1) adaptive_hash_index=DEFAULT complete_fields=0 bytes_from_incomplete_field=3 for_equal_hash_point_to_last_record=0","+) ENGINE=InnoDB STATS_PERSISTENT=0 adaptive_hash_index=DEFAULT;","+INSERT INTO t1_ahi_default_2 SELECT seq, seq FROM seq_0_to_255;","+CALL run_and_check_idx(240, 1, 't1_ahi_default_2');","+result_msg","+# No AHI used in SELECT (idx_1)","+connect con1, localhost, root;","+CALL run_and_check_idx(-1, 1, 't1_ahi_default_2');;","+connection default;","+SET GLOBAL innodb_adaptive_hash_index= OFF;","+CALL run_and_check_idx(240, 1, 't1_ahi_default_2');","+result_msg","+# No AHI used in SELECT (idx_1)","+SET GLOBAL innodb_adaptive_hash_index= ON;","+CALL run_and_check_idx(240, 1, 't1_ahi_default_2');","+result_msg","+# Used AHI in SELECT (idx_1)","+SET GLOBAL innodb_adaptive_hash_index= IF_SPECIFIED;","+CALL run_and_check_idx(240, 1, 't1_ahi_default_2');","+result_msg","+# No AHI used in SELECT (idx_1)","+SET GLOBAL innodb_adaptive_hash_index= @combination_value;","+CALL run_and_check_idx(240, 1, 't1_ahi_default_2');","+result_msg","+# No AHI used in SELECT (idx_1)","+KILL con1_id;","+connection con1;","+Got one of the listed errors","+disconnect con1;","+connection default;","+DROP TABLE t1_ahi_default_2;","+DROP PROCEDURE run_and_check_idx;","+SET @@global.innodb_adaptive_hash_index= @start_global_value;","+SET GLOBAL innodb_monitor_disable= module_adaptive_hash;","+SET GLOBAL innodb_monitor_disable= default;","+SET GLOBAL innodb_monitor_enable= default;"],"additions":114,"deletions":0,"truncated":false},{"path":"mysql-test/suite/innodb/r/innodb_buffer_pool_resize.result","lines":["@@ -20,12 +20,12 @@ SET STATEMENT foreign_key_checks=0, unique_checks=0 FOR"," INSERT INTO t2 SELECT seq*4,seq*4 FROM seq_1_to_16384;"," SELECT @@GLOBAL.innodb_adaptive_hash_index;"," @@GLOBAL.innodb_adaptive_hash_index","-1","+ON"," SET STATEMENT max_statement_time=1e-9 FOR"," SET GLOBAL innodb_buffer_pool_size = 7340032;"," SELECT @@GLOBAL.innodb_adaptive_hash_index;"," @@GLOBAL.innodb_adaptive_hash_index","-1","+ON"," FOUND 1 /innodb_buffer_pool_size=7m.*resized from|innodb_buffer_pool_size change aborted/ in mysqld.1.err"," set global innodb_buffer_pool_size = 7340032;"," select count(val) from t1;"],"additions":2,"deletions":2,"truncated":false},{"path":"mysql-test/suite/innodb/r/innodb_buffer_pool_resize_temporary.result","lines":["@@ -10,7 +10,7 @@ SET GLOBAL innodb_buffer_pool_size=8388608;"," ERROR HY000: innodb_buffer_pool_size change aborted"," SELECT @@GLOBAL.innodb_adaptive_hash_index,@@GLOBAL.innodb_buffer_pool_size;"," @@GLOBAL.innodb_adaptive_hash_index\t@@GLOBAL.innodb_buffer_pool_size","-1\t16777216","+ON\t16777216"," SET GLOBAL innodb_adaptive_hash_index = @old_innodb_adaptive_hash_index;"," CREATE TEMPORARY TABLE t1 (a INT PRIMARY KEY) ENGINE=InnoDB;"," INSERT INTO t1 SELECT seq FROM seq_1_to_200;"],"additions":1,"deletions":1,"truncated":false},{"path":"mysql-test/suite/innodb/t/index_ahi_option.combinations","lines":["@@ -0,0 +1,3 @@","+[ahi]","+[no_ahi]","+[if_specified]"],"additions":3,"deletions":0,"truncated":false},{"path":"mysql-test/suite/innodb/t/index_ahi_option.test","lines":["@@ -0,0 +1,248 @@","+--source include/have_innodb.inc","+--source include/not_embedded.inc","+--source include/have_sequence.inc","+--source include/have_partition.inc","+","+--echo #","+--echo # Test InnoDB index-level adaptive_hash_index options","+--echo #","+","+SET @start_global_value= @@global.innodb_adaptive_hash_index;","+if ($MTR_COMBINATION_AHI) {","+  SET @combination_value= 'ON';","+}","+if ($MTR_COMBINATION_NO_AHI) {","+  SET @combination_value= 'OFF';","+}","+if ($MTR_COMBINATION_IF_SPECIFIED) {","+  SET @combination_value= 'if_specified';","+}","+SET GLOBAL innodb_adaptive_hash_index= @combination_value;","+","+CREATE TABLE t1 (","+  id INT PRIMARY KEY,","+  col1 INT, col2 INT, col3 INT,","+  INDEX idx_1 (col1) adaptive_hash_index=DEFAULT,","+  INDEX idx_2 (col1, col2) adaptive_hash_index=YES,","+  INDEX idx_3 (col1, col2, col3) adaptive_hash_index=NO","+) ENGINE=InnoDB STATS_PERSISTENT=0 adaptive_hash_index=DEFAULT;","+","+INSERT INTO t1 SELECT seq, seq, seq << 8, seq << 16 FROM seq_0_to_255;","+","+#","+# AHI usage in searches is verified by measuring an increase in","+# the \"count\" of \"adaptive_hash_searches\" InnoDB metric.","+# An alternative strategy would use \"ANALYZE FORMAT=JSON\" and","+# check the \"pages_accessed\" entry: lower values w.r.t. the","+# base case would imply that AHI was used for the search.","+# Unfortunately, that is not really stable.","+# Hopefully using \"innodb_metrics\" is more stable.","+#","+","+--disable_query_log","+--disable_result_log","+DELIMITER $$;","+","+CREATE PROCEDURE run_and_check_idx(p_rounds INT, p_idx_num INT, p_table_name VARCHAR(64))","+BEGIN","+  DECLARE start_val BIGINT;","+  DECLARE end_val BIGINT;","+  DECLARE i INT DEFAULT 0;","+","+  SELECT count INTO start_val FROM information_schema.innodb_metrics WHERE name = 'adaptive_hash_searches';","+","+  IF p_idx_num = 1 THEN","+    SET @query = CONCAT('SELECT COUNT(*) INTO @dummy FROM ', p_table_name, ' FORCE INDEX(idx_1) WHERE col1 >= 0 AND col1 < (1 << 8)');","+  ELSEIF p_idx_num = 2 THEN","+    SET @query = CONCAT('SELECT COUNT(*) INTO @dummy FROM ', p_table_name, ' FORCE INDEX(idx_2) WHERE col1 = 50 AND col2 >= 0 AND col2 < (1 << 16)');","+  ELSEIF p_idx_num = 3 THEN","+    SET @query = CONCAT('SELECT COUNT(*) INTO @dummy FROM ', p_table_name, ' FORCE INDEX(idx_3) WHERE col1 = 50 AND col2 = (50 << 8) AND col3 >= 0 AND col3 < (1 << 24)');","+  END IF;","+","+  PREPARE stmt FROM @query;","+  WHILE i < p_rounds OR p_rounds < 0 DO","+    EXECUTE stmt;","+    SET i= i + 1;","+  END WHILE;","+  DEALLOCATE PREPARE stmt;","+","+  IF COALESCE(@dummy, 0) = 0 THEN","+    SELECT '# WARNING: No rows selected' AS warning_msg;","+  END IF;","+","+  SELECT count INTO end_val FROM information_schema.innodb_metrics WHERE name = 'adaptive_hash_searches';","+","+  IF end_val > start_val + COALESCE(@ahi_check_threshold, 0) THEN","+    SELECT CONCAT('# Used AHI in SELECT (idx_', p_idx_num, ')') AS result_msg;","+  ELSE","+    SELECT CONCAT('# No AHI used in SELECT (idx_', p_idx_num, ')') AS result_msg;","+  END IF;","+","+END$$","+","+DELIMITER ;$$","+--enable_result_log","+--enable_query_log","+","+SET GLOBAL innodb_monitor_enable= module_adaptive_hash;","+let $query_rounds= 240;","+","+eval CALL run_and_check_idx($query_rounds, 1, 't1');","+eval CALL run_and_check_idx($query_rounds, 2, 't1');","+eval CALL run_and_check_idx($query_rounds, 3, 't1');","+","+ALTER TABLE t1 adaptive_hash_index=OFF, ALGORITHM=INSTANT, LOCK=NONE;","+","+eval CALL run_and_check_idx($query_rounds, 1, 't1');"],"additions":96,"deletions":0,"truncated":false}],"additions":711,"deletions":3,"truncated":true,"file_count":10},"error":null,"fetched_at":"2026-05-29T11:02:47.452970+00:00"}