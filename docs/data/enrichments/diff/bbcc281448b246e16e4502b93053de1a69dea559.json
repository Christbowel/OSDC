uteConfiguration {","+\t\treturn &route.RouteConfiguration{","+\t\t\tName: \"inbound|http|80\",","+\t\t\tVirtualHosts: []*route.VirtualHost{","+\t\t\t\t{","+\t\t\t\t\tName:    \"vhost1\",","+\t\t\t\t\tDomains: []string{\"original.com\"},","+\t\t\t\t},","+\t\t\t},","+\t\t}","+\t}","+\twantRC := func(domains ...string) *route.RouteConfiguration {","+\t\treturn &route.RouteConfiguration{","+\t\t\tName: \"inbound|http|80\",","+\t\t\tVirtualHosts: []*route.VirtualHost{","+\t\t\t\t{","+\t\t\t\t\tName:    \"vhost1\",","+\t\t\t\t\tDomains: domains,","+\t\t\t\t},","+\t\t\t},","+\t\t}","+\t}","+","+\tsidecarNode := &model.Proxy{Type: model.SidecarProxy, ConfigNamespace: \"not-default\"}","+","+\ttests := []struct {","+\t\tname      string","+\t\toperation networking.EnvoyFilter_Patch_Operation","+\t\twant      *route.RouteConfiguration","+\t}{","+\t\t{","+\t\t\tname:      \"MERGE appends to domains list\",","+\t\t\toperation: networking.EnvoyFilter_Patch_MERGE,","+\t\t\twant:      wantRC(\"original.com\", \"patched.com\"),","+\t\t},","+\t\t{","+\t\t\tname:      \"MERGE_AND_REPLACE_LIST replaces domains list\",","+\t\t\toperation: networking.EnvoyFilter_Patch_MERGE_AND_REPLACE_LIST,","+\t\t\twant:      wantRC(\"patched.com\"),","+\t\t},","+\t}","+","+\tfor _, tt := range tests {","+\t\tt.Run(tt.name, func(t *testing.T) {","+\t\t\tserviceDiscovery := memory.NewServiceDiscovery()","+\t\t\tenv := newTestEnvironment(t, serviceDiscovery, testMesh, buildEnvoyFilterConfigStore(vhostPatch(tt.operation)))","+\t\t\tpush := model.NewPushContext()","+\t\t\tpush.InitContext(env, nil, nil)","+","+\t\t\tefw := push.EnvoyFilters(sidecarNode)","+\t\t\tgot := ApplyRouteConfigurationPatches(networking.EnvoyFilter_SIDECAR_INBOUND, sidecarNode, efw, inputRC())","+\t\t\tif diff := cmp.Diff(tt.want, got, protocmp.Transform()); diff != \"\" {","+\t\t\t\tt.Errorf(\"%s mismatch (-want +got):\\n%s\", tt.name, diff)","+\t\t\t}","+\t\t})","+\t}","+}","+"," func Test_routeMatch(t *testing.T) {"," \ttype args struct {"," \t\thttpRoute *route.Route"],"additions":83,"deletions":0,"truncated":false},{"path":"pilot/pkg/networking/core/envoyfilter/util.go","lines":["@@ -14,6 +14,36 @@"," "," package envoyfilter"," ","+import (","+\t\"google.golang.org/protobuf/proto\"","+","+\tnetworking \"istio.io/api/networking/v1alpha3\"","+\t\"istio.io/istio/pkg/proto/merge\"","+)","+","+// isMergeOperation reports whether the operation merges the patch value into the","+// existing config. Both MERGE and MERGE_AND_REPLACE_LIST are merge operations; they","+// differ only in how repeated (list) fields are handled (see mergePatchValue).","+func isMergeOperation(operation networking.EnvoyFilter_Patch_Operation) bool {","+\treturn operation == networking.EnvoyFilter_Patch_MERGE ||","+\t\toperation == networking.EnvoyFilter_Patch_MERGE_AND_REPLACE_LIST","+}","+","+// mergePatchValue merges src into dst using the semantics of the given patch operation.","+// MERGE appends repeated (list) fields, while MERGE_AND_REPLACE_LIST replaces them","+// wholesale. Both operations merge scalar and message fields identically.","+//","+// Note: this only governs the top-level proto merge. Filter-level merges of Any-typed","+// configs (HTTP/network/listener filters and transport sockets) go through","+// util.MergeAnyWithAny and are not affected by the replace-list semantics.","+func mergePatchValue(operation networking.EnvoyFilter_Patch_Operation, dst, src proto.Message) {","+\tif operation == networking.EnvoyFilter_Patch_MERGE_AND_REPLACE_LIST {","+\t\tmerge.MergeWithReplaceList(dst, src)","+\t\treturn","+\t}","+\tmerge.Merge(dst, src)","+}","+"," // replaceFunc find and replace the first matching element."," // If the f function returns true, the returned value will be used for replacement."," func replaceFunc[E any](s []E, f func(e E) (bool, E)) ([]E, bool) {"],"additions":30,"deletions":0,"truncated":false},{"path":"pkg/proto/merge/merge.go","lines":["@@ -35,6 +35,9 @@ type ("," \tMergeFunction func(dst, src protoreflect.Message) protoreflect.Message"," \tmergeOptions  struct {"," \t\tcustomMergeFn map[protoreflect.FullName]MergeFunction","+\t\t// replaceList, when true, makes repeated (list) fields present in src","+\t\t// fully replace the corresponding list in dst instead of being appended.","+\t\treplaceList bool"," \t}"," )"," type OptionFn func(options mergeOptions) mergeOptions","@@ -52,6 +55,15 @@ var ReplaceMergeFn MergeFunction = func(dst, src protoreflect.Message) protorefl"," \treturn src"," }"," ","+// ReplaceListOptionFn makes repeated (list) fields present in src fully replace","+// the corresponding list in dst instead of being appended to it. Singular and","+// map fields retain normal merge semantics. The replacement is recursive: any","+// list set by src at any nesting level replaces the matching list in dst.","+var ReplaceListOptionFn OptionFn = func(options mergeOptions) mergeOptions {","+\toptions.replaceList = true","+\treturn options","+}","+"," var options = []OptionFn{"," \t// Workaround https://github.com/golang/protobuf/issues/1359, merge duration properly"," \tMergeFunctionOptionFn((&durationpb.Duration{}).ProtoReflect().Descriptor().FullName(), ReplaceMergeFn),","@@ -61,6 +73,14 @@ func Merge(dst, src proto.Message) {"," \tmerge(dst, src, options...)"," }"," ","+// MergeWithReplaceList behaves like Merge, except that repeated (list) fields","+// present in src fully replace the corresponding list in dst rather than being","+// appended. This is useful for callers that want proto merge semantics for","+// scalar and message fields while overwriting arrays wholesale.","+func MergeWithReplaceList(dst, src proto.Message) {","+\tmerge(dst, src, append(append([]OptionFn{}, options...), ReplaceListOptionFn)...)","+}","+"," // Merge Code of proto.Merge with modifications to support custom types"," func merge(dst, src proto.Message, opts ...OptionFn) {"," \tmo := mergeOptions{customMergeFn: map[protoreflect.FullName]MergeFunction{}}","@@ -87,7 +107,13 @@ func (o mergeOptions) mergeMessage(dst, src protoreflect.Message) {"," \tsrc.Range(func(fd protoreflect.FieldDescriptor, v protoreflect.Value) bool {"," \t\tswitch {"," \t\tcase fd.IsList():","-\t\t\to.mergeList(dst.Mutable(fd).List(), v.List(), fd)","+\t\t\tdstList := dst.Mutable(fd).List()","+\t\t\tif o.replaceList {","+\t\t\t\t// Replace semantics: drop the existing entries so the src list","+\t\t\t\t// fully overwrites dst instead of being appended.","+\t\t\t\tdstList.Truncate(0)","+\t\t\t}","+\t\t\to.mergeList(dstList, v.List(), fd)"," \t\tcase fd.IsMap():"," \t\t\to.mergeMap(dst.Mutable(fd).Map(), v.Map(), fd.MapValue())"," \t\tcase fd.Message() != nil:"],"additions":27,"deletions":1,"truncated":false},{"path":"pkg/proto/merge/merge_test.go","lines":["@@ -37,3 +37,71 @@ func TestMerge(t *testing.T) {"," \t// dst duration not changed after merge"," \tassert.Equal(t, dst, &durationpb.Duration{Seconds: 789, Nanos: 999})"," }","+","+func filterNames(filters []*listener.ListenerFilter) []string {","+\tnames := make([]string, 0, len(filters))","+\tfor _, f := range filters {","+\t\tnames = append(names, f.GetName())","+\t}","+\treturn names","+}","+","+// TestMerge_AppendsList verifies the default Merge semantics: repeated fields are appended.","+func TestMerge_AppendsList(t *testing.T) {","+\tdst := &listener.Listener{ListenerFilters: []*listener.ListenerFilter{{Name: \"a\"}, {Name: \"b\"}}}","+\tsrc := &listener.Listener{ListenerFilters: []*listener.ListenerFilter{{Name: \"c\"}}}","+","+\tMerge(dst, src)","+","+\tassert.Equal(t, filterNames(dst.ListenerFilters), []string{\"a\", \"b\", \"c\"})","+}","+","+// TestMergeWithReplaceList verifies that lists in src fully replace lists in dst.","+func TestMergeWithReplaceList(t *testing.T) {","+\tdst := &listener.Listener{","+\t\tName:            \"keep-me\",","+\t\tListenerFilters: []*listener.ListenerFilter{{Name: \"a\"}, {Name: \"b\"}},","+\t}","+\tsrc := &listener.Listener{ListenerFilters: []*listener.ListenerFilter{{Name: \"c\"}}}","+","+\tMergeWithReplaceList(dst, src)","+","+\t// The list is replaced, not appended.","+\tassert.Equal(t, filterNames(dst.ListenerFilters), []string{\"c\"})","+\t// Scalar fields not set by src are left untouched (sparse merge).","+\tassert.Equal(t, dst.Name, \"keep-me\")","+}","+","+// TestMergeWithReplaceList_EmptyListNotCleared verifies that a list absent from src","+// leaves the dst list untouched (src.Range only visits set fields).","+func TestMergeWithReplaceList_EmptyListNotCleared(t *testing.T) {","+\tdst := &listener.Listener{ListenerFilters: []*listener.ListenerFilter{{Name: \"a\"}}}","+\tsrc := &listener.Listener{Name: \"set-name\"}","+","+\tMergeWithReplaceList(dst, src)","+","+\tassert.Equal(t, filterNames(dst.ListenerFilters), []string{\"a\"})","+\tassert.Equal(t, dst.Name, \"set-name\")","+}","+","+// TestMergeWithReplaceList_Nested verifies replace semantics apply recursively into","+// nested messages.","+func TestMergeWithReplaceList_Nested(t *testing.T) {","+\tdst := &listener.Listener{","+\t\tFilterChains: []*listener.FilterChain{{","+\t\t\tFilters: []*listener.Filter{{Name: \"f1\"}, {Name: \"f2\"}},","+\t\t}},","+\t}","+\tsrc := &listener.Listener{","+\t\tFilterChains: []*listener.FilterChain{{","+\t\t\tFilters: []*listener.Filter{{Name: \"f3\"}},","+\t\t}},","+\t}","+","+\tMergeWithReplaceList(dst, src)","+","+\t// Top-level FilterChains list is replaced wholesale.","+\tassert.Equal(t, len(dst.FilterChains), 1)","+\tassert.Equal(t, dst.FilterChains[0].Filters[0].GetName(), \"f3\")","+\tassert.Equal(t, len(dst.FilterChains[0].Filters), 1)","+}"],"additions":68,"deletions":0,"truncated":false},{"path":"releasenotes/notes/envoyfilter-merge-and-replace-list.yaml","lines":["@@ -0,0 +1,14 @@","+apiVersion: release-notes/v2","+kind: feature","+area: traffic-management","+issues:","+  - 60498","+releaseNotes:","+  - |","+    **Added** a new `MERGE_AND_REPLACE_LIST` patch operation to `EnvoyFilter`. It behaves like","+    `MERGE`, except that repeated (list) fields present in the patch fully replace the","+    corresponding list in the generated configuration instead of being appended to it. This","+    applies to the `CLUSTER`, `LISTENER`, `FILTER_CHAIN`, `ROUTE_CONFIGURATION`, `VIRTUAL_HOST`,","+    and `HTTP_ROUTE` patch targets. Lists nested inside `Any`-typed filter configurations (HTTP,","+    network, and listener filters, and transport sockets) are not affected and continue to follow","+    `MERGE` semantics.",""],"additions":14,"deletions":0,"truncated":false}],"additions":234,"deletions":14,"truncated":false,"file_count":8},"error":null,"fetched_at":"2026-06-19T12:43:45.783161+00:00"}