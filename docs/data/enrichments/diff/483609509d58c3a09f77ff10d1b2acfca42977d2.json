sandbox execution","+ * - **toolsStore**: Exposes the tool definition when the sandbox is enabled","+ * - **agenticStore**: Dispatches ToolSource.FRONTEND calls here","+ *","+ * @see SANDBOX_TOOL_DEFINITION in constants/sandbox.ts - tool schema sent to the LLM","+ * @see agenticStore in stores/agentic.svelte.ts - tool dispatch","+ */","+export { SandboxService } from './sandbox.service';","+"," /**","  * **RouterService** — Dynamic route URL construction utility","  *"],"additions":20,"deletions":0,"truncated":false},{"path":"tools/ui/src/lib/services/sandbox-harness.ts","lines":["@@ -0,0 +1,25 @@","+import WORKER_SHIM from './sandbox-worker.js?raw';","+","+/**","+ * Harness loaded as srcdoc into a sandboxed iframe (allow-scripts only).","+ * The opaque origin is the security boundary: no access to the app origin,","+ * its storage or its API. The harness spawns a worker so model code never","+ * runs on a main thread, which makes the parent timeout enforceable by","+ * removing the iframe.","+ */","+export const SANDBOX_HARNESS_HTML = `<!doctype html><script>","+const SHIM = ${JSON.stringify(WORKER_SHIM)};","+addEventListener('message', (event) => {","+\tconst respond = (payload) => parent.postMessage(payload, '*');","+\tlet worker;","+\ttry {","+\t\tworker = new Worker(URL.createObjectURL(new Blob([SHIM], { type: 'text/javascript' })));","+\t} catch (err) {","+\t\trespond({ logs: [], result: null, error: 'Worker creation failed: ' + err });","+\t\treturn;","+\t}","+\tworker.onmessage = (msg) => respond(msg.data);","+\tworker.onerror = (err) => respond({ logs: [], result: null, error: String(err.message || err) });","+\tworker.postMessage({ code: event.data.code });","+});","+</script>`;"],"additions":25,"deletions":0,"truncated":false},{"path":"tools/ui/src/lib/services/sandbox-worker.js","lines":["@@ -0,0 +1,30 @@","+const logs = [];","+const fmt = (value) => {","+\tif (typeof value === 'string') return value;","+\ttry {","+\t\treturn JSON.stringify(value);","+\t} catch {","+\t\treturn String(value);","+\t}","+};","+const capture =","+\t(level, prefix) =>","+\t(...args) => {","+\t\tlogs.push(prefix + args.map(fmt).join(' '));","+\t};","+console.log = capture('log', '');","+console.info = capture('info', '');","+console.debug = capture('debug', '');","+console.warn = capture('warn', 'warn: ');","+console.error = capture('error', 'error: ');","+self.onmessage = async (event) => {","+\tconst reply = { logs, result: null, error: null };","+\ttry {","+\t\tconst AsyncFunction = Object.getPrototypeOf(async function () {}).constructor;","+\t\tconst value = await new AsyncFunction(event.data.code)();","+\t\tif (value !== undefined) reply.result = fmt(value);","+\t} catch (err) {","+\t\treply.error = err instanceof Error ? err.stack || err.message : String(err);","+\t}","+\tself.postMessage(reply);","+};"],"additions":30,"deletions":0,"truncated":false},{"path":"tools/ui/src/lib/services/sandbox.service.ts","lines":["@@ -0,0 +1,112 @@","+import {","+\tNEWLINE_SEPARATOR,","+\tSANDBOX_EMPTY_OUTPUT,","+\tSANDBOX_OUTPUT_MAX_CHARS,","+\tSANDBOX_TIMEOUT_MS_DEFAULT,","+\tSANDBOX_TIMEOUT_MS_MAX,","+\tSANDBOX_TOOL_NAME,","+\tSANDBOX_TRUNCATION_NOTICE","+} from '$lib/constants';","+import { SANDBOX_HARNESS_HTML } from './sandbox-harness';","+import type { ToolExecutionResult } from '$lib/types';","+","+interface SandboxReply {","+\tlogs?: unknown;","+\tresult?: unknown;","+\terror?: unknown;","+}","+","+function formatReply(reply: SandboxReply): ToolExecutionResult {","+\tconst lines: string[] = [];","+","+\tif (Array.isArray(reply.logs)) {","+\t\tfor (const line of reply.logs) lines.push(String(line));","+\t}","+","+\tif (reply.error != null) {","+\t\tlines.push(`Error: ${String(reply.error)}`);","+\t} else if (reply.result != null) {","+\t\tlines.push(`=> ${String(reply.result)}`);","+\t}","+","+\tlet content = lines.join(NEWLINE_SEPARATOR);","+\tif (!content) content = SANDBOX_EMPTY_OUTPUT;","+\tif (content.length > SANDBOX_OUTPUT_MAX_CHARS) {","+\t\tcontent = `${content.slice(0, SANDBOX_OUTPUT_MAX_CHARS)}${NEWLINE_SEPARATOR}${SANDBOX_TRUNCATION_NOTICE}`;","+\t}","+","+\treturn { content, isError: reply.error != null };","+}","+","+export class SandboxService {","+\t/**","+\t * Execute a frontend sandbox tool call and return its output.","+\t * One disposable iframe per execution, removed on completion,","+\t * timeout or abort. Removing the iframe terminates the worker","+\t * at the browser level, so runaway code cannot outlive it.","+\t */","+\tstatic executeTool(","+\t\ttoolName: string,","+\t\tparams: Record<string, unknown>,","+\t\tsignal?: AbortSignal","+\t): Promise<ToolExecutionResult> {","+\t\tif (toolName !== SANDBOX_TOOL_NAME) {","+\t\t\treturn Promise.resolve({ content: `Unknown frontend tool: ${toolName}`, isError: true });","+\t\t}","+","+\t\tconst code = typeof params.code === 'string' ? params.code : '';","+\t\tif (!code) {","+\t\t\treturn Promise.resolve({ content: 'Missing required parameter: code', isError: true });","+\t\t}","+","+\t\tconst requested = Number(params.timeout_ms);","+\t\tconst timeoutMs =","+\t\t\tNumber.isFinite(requested) && requested > 0","+\t\t\t\t? Math.min(requested, SANDBOX_TIMEOUT_MS_MAX)","+\t\t\t\t: SANDBOX_TIMEOUT_MS_DEFAULT;","+","+\t\treturn new Promise<ToolExecutionResult>((resolve, reject) => {","+\t\t\tconst iframe = document.createElement('iframe');","+\t\t\tiframe.setAttribute('sandbox', 'allow-scripts');","+\t\t\tiframe.style.display = 'none';","+\t\t\tiframe.srcdoc = SANDBOX_HARNESS_HTML;","+","+\t\t\tlet settled = false;","+","+\t\t\tconst cleanup = () => {","+\t\t\t\tsettled = true;","+\t\t\t\tclearTimeout(timer);","+\t\t\t\twindow.removeEventListener('message', onMessage);","+\t\t\t\tsignal?.removeEventListener('abort', onAbort);","+\t\t\t\tiframe.remove();","+\t\t\t};","+","+\t\t\tconst finish = (result: ToolExecutionResult) => {","+\t\t\t\tif (settled) return;","+\t\t\t\tcleanup();","+\t\t\t\tresolve(result);","+\t\t\t};","+","+\t\t\tconst onAbort = () => {","+\t\t\t\tif (settled) return;","+\t\t\t\tcleanup();","+\t\t\t\treject(new DOMException('Sandbox execution aborted', 'AbortError'));","+\t\t\t};","+","+\t\t\tconst onMessage = (event: MessageEvent) => {","+\t\t\t\tif (event.source !== iframe.contentWindow) return;","+\t\t\t\tfinish(formatReply((event.data ?? {}) as SandboxReply));","+\t\t\t};","+","+\t\t\tconst timer = setTimeout(","+\t\t\t\t() => finish({ content: `Execution timed out after ${timeoutMs} ms`, isError: true }),","+\t\t\t\ttimeoutMs","+\t\t\t);","+","+\t\t\twindow.addEventListener('message', onMessage);","+\t\t\tsignal?.addEventListener('abort', onAbort);","+\t\t\tiframe.onload = () => iframe.contentWindow?.postMessage({ code }, '*');","+\t\t\tdocument.body.appendChild(iframe);","+\t\t});","+\t}","+}"],"additions":112,"deletions":0,"truncated":false},{"path":"tools/ui/src/lib/stores/agentic.svelte.ts","lines":["@@ -29,6 +29,7 @@ import { permissionsStore } from '$lib/stores/permissions.svelte';"," import { ToolSource, ToolPermissionDecision } from '$lib/enums';"," import { SvelteMap } from 'svelte/reactivity';"," import { ToolsService } from '$lib/services/tools.service';","+import { SandboxService } from '$lib/services/sandbox.service';"," import { isAbortError } from '$lib/utils';"," import { DEFAULT_AGENTIC_CONFIG, NEWLINE_SEPARATOR } from '$lib/constants';"," import {","@@ -784,6 +785,13 @@ class AgenticStore {"," "," \t\t\t\t\t\t\tresult = executionResult.content;"," ","+\t\t\t\t\t\t\tif (executionResult.isError) toolSuccess = false;","+\t\t\t\t\t\t} else if (toolSource === ToolSource.FRONTEND) {","+\t\t\t\t\t\t\tconst args = this.parseToolArguments(toolCall.function.arguments);","+\t\t\t\t\t\t\tconst executionResult = await SandboxService.executeTool(toolName, args, signal);","+","+\t\t\t\t\t\t\tresult = executionResult.content;","+"," \t\t\t\t\t\t\tif (executionResult.isError) toolSuccess = false;"," \t\t\t\t\t\t} else {"," \t\t\t\t\t\t\tconst mcpCall: MCPToolCall = {"],"addit