std::filesystem::path filePath) const"," {","+    // Capture config fields needed for retention after compression","+    auto basePath = m_config.basePath;","+    auto maxFiles = m_config.maxFiles;","+    auto maxAccumulatedSize = m_config.maxAccumulatedSize;","+    auto latestLink = m_stateData.latestLink;","+    auto channelName = m_channelName;","+","     return scheduler::TaskConfig {","         .interval = 0, // One-time task","         .CPUPriority = 0,","         .timeout = 0,","-        .taskFunction = [filePath, compressionLevel = m_config.compressionLevel]()","-        { compressLogFile(filePath, compressionLevel); },","+        .taskFunction =","+            [filePath,","+             compressionLevel = m_config.compressionLevel,","+             basePath = std::move(basePath),","+             maxFiles,","+             maxAccumulatedSize,","+             latestLink = std::move(latestLink),","+             channelName = std::move(channelName)]()","+        {","+            compressLogFile(filePath, compressionLevel);","+","+            // Run retention cleanup after compression so that cleanup always sees","+            // files in their final (compressed) state, avoiding race conditions","+            // where cleanup could observe in-transit files with uncompressed sizes.","+            if (maxFiles > 0 || maxAccumulatedSize > 0)","+            {","+                deleteOldFilesStatic(basePath, latestLink, maxFiles, maxAccumulatedSize, channelName);","+            }","+        },","     };"," }"," ","+void ChannelHandler::deleteOldFiles()","+{","+    deleteOldFilesStatic(","+        m_config.basePath, m_stateData.latestLink, m_config.maxFiles, m_config.maxAccumulatedSize, m_channelName);","+}","+","+void ChannelHandler::deleteOldFilesStatic(const std::filesystem::path& basePath,","+                                          const std::filesystem::path& latestLink,","+                                          size_t maxFiles,","+                                          size_t maxAccumulatedSize,","+                                          const std::string& channelName)","+{","+    if (maxFiles == 0 && maxAccumulatedSize == 0)","+    {","+        return;","+    }","+","+    // Metadata for each rotated file found during the scan","+    struct FileInfo","+    {","+        std::filesystem::path path;","+        std::time_t mtime;","+        std::int64_t size;","+        bool valid; // marked false after successful deletion","+","+        bool operator<(const FileInfo& other) const { return mtime < other.mtime; }","+    };","+","+    std::vector<FileInfo> rotatedFiles;","+    std::int64_t totalSize = 0;","+","+    // Identify the active file by inode via latestLink.","+    //","+    // latestLink (\"<basePath>/<channelName>.<ext>\") is always recreated as a","+    // hard link to the current active file after every rotation. Reading its","+    // inode at *execution time* (not at task-creation time) means we always","+    // exclude the real active file, regardless of how many rotations occurred","+    // between when the task was scheduled and when it runs.","+    //","+    // If stat(latestLink) fails we cannot safely identify the active file —","+    // path-based comparison would use values captured at task-creation time,","+    // which may be stale in async contexts. Aborting is safer than risking","+    // deletion of the current active file.","+    ino_t activeInode = 0;","+    {","+        struct stat linkStat {};","+        if (::stat(latestLink.c_str(), &linkStat) == 0)","+        {","+            activeInode = linkStat.st_ino;","+        }","+        else","+        {","+            LOG_WARNING(\"Cannot stat latestLink '{}' for channel '{}'; aborting retention cleanup to avoid \"","+                        \"deleting the active file with stale path information\",","+                        latestLink.string(),","+                        channelName);","+            return;","+        }","+    }","+","+    try","+    {","+        for (const auto& entry : std::filesystem::recursive_directory_iterator(","+                 basePath, std::filesystem::directory_options::skip_permission_denied))","+        {","+            if (!entry.is_regular_file())","+            {","+                continue;","+            }","+","+            const auto& filePath = entry.path();","+","+            struct stat fileStat {};","+            if (::stat(filePath.c_str(), &fileStat) != 0)","+            {","+                continue;","+            }","+","+            // Exclude the current active file by inode — robust even after multiple rotations.","+            if (fileStat.st_ino == activeInode)","+            {","+                continue;","+            }","+","+            const auto fileSize = static_cast<std::int64_t>(fileStat.st_size);","+            if (fileSize < 0)","+            {","+                continue;","+            }","+","+            rotatedFiles.push_back({filePath, fileStat.st_mtime, fileSize, true});","+            totalSize += fileSize;","+        }","+    }","+    catch (const std::filesystem::filesystem_error& e)","+    {","+        LOG_WARNING(\"Failed to scan basePath for retention cleanup of channel '{}': {}\", channelName, e.what());","+        return;","+    }","+","+    if (rotatedFiles.empty())","+    {","+        return;","+    }","+","+    // Sort oldest first (by mtime ascending)","+    std::sort(rotatedFiles.begin(), rotatedFiles.end());","+","+    size_t filesDeleted = 0;","+","+    // Strategy 1: delete oldest files until accumulated size fits the limit","+    if (maxAccumulatedSize > 0 && totalSize > static_cast<std::int64_t>(maxAccumulatedSize))","+    {","+        const auto sizeToFree = totalSize - static_cast<std::int64_t>(maxAccumulatedSize);","+        std::int64_t freedSize = 0;","+","+        for (auto& file : rotatedFiles)","+        {","+            if (freedSize >= sizeToFree)","+            {","+                break;","+            }","+            if (!file.valid)","+            {","+                continue;","+            }","+","+            std::error_code ec;","+            if (std::filesystem::remove(file.path, ec) && !ec)","+            {","+                freedSize += file.size;","+                totalSize -= file.size;","+                file.valid = false;","+                ++filesDeleted;","+                LOG_DEBUG(\"Retention (size): deleted '{}' for channel '{}'\", file.path.string(), channelName);","+            }","+        }","+    }","+","+    // Strategy 2: delete oldest files until file-count fits the limit","+    if (maxFiles > 0)","+    {","+        const size_t remainingFiles = rotatedFiles.size() - filesDeleted;","+        if (remainingFiles > maxFiles)","+        {","+            const size_t filesToDelete = remainingFiles - maxFiles;","+            size_t deletedCount = 0;","+","+            for (auto& file : rotatedFiles)","+            {","+                if (deletedCount >= filesToDelete)","+                {","+                    break;","+                }","+                if (!file.valid)","+                {","+                    continue;","+                }","+","+                std::error_code ec;","+                if (std::filesystem::remove(file.path, ec) && !ec)","+                {","+                    file.valid = false;","+                    ++deletedCount;","+                    ++filesDeleted;","+                    LOG_DEBUG(\"Retention (count): deleted '{}' for channel '{}'\", file.path.string(), channelName);","+                }","+            }","+        }","+    }","+","+    if (filesDeleted > 0)","+    {","+        LOG_INFO(\"Retention cleanup for channel '{}': deleted {} file(s)\", channelName, filesDeleted);","+    }","+}","+"," std::optional<std::filesystem::path> ChannelHandler::getPreviousCurrentFilePathFromStore() const"," {","     if (!m_store)"],"additions":221,"deletions":2,"truncated":false},{"path":"src/engine/sour