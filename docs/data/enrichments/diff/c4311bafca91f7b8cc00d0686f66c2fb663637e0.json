tiveSeriesChunkBufferPool.Get().(*bytes.Buffer)","+\t\t\tfirstItem = true","+\t\t}","+\t}","+}","+"," func (d *shardActiveSeriesResponseDecoder) nextToken() byte {"," \tfor {"," \t\tc := d.readByte()"],"additions":77,"deletions":0,"truncated":false},{"path":"pkg/frontend/querymiddleware/shard_active_series_test.go","lines":["@@ -5,6 +5,7 @@ package querymiddleware"," import ("," \t\"bytes\""," \t\"context\"","+\t\"encoding/binary\""," \t\"fmt\""," \t\"io\""," \t\"net/http\"","@@ -29,6 +30,7 @@ import ("," "," \tapierror \"github.com/grafana/mimir/pkg/api/error\""," \t\"github.com/grafana/mimir/pkg/cardinality\"","+\tquerierapi \"github.com/grafana/mimir/pkg/querier/api\""," \t\"github.com/grafana/mimir/pkg/storage/sharding\""," \t\"github.com/grafana/mimir/pkg/streamingpromql/requestoptions\""," )","@@ -317,6 +319,7 @@ func Test_shardActiveSeriesMiddleware_RoundTrip(t *testing.T) {"," \t\t\ts := newShardActiveSeriesMiddleware("," \t\t\t\tupstream,"," \t\t\t\t0,","+\t\t\t\tfalse,"," \t\t\t\tmockLimits{maxShardedQueries: tenantMaxShardCount, totalShards: tenantShardCount},"," \t\t\t\tlog.NewNopLogger(),"," \t\t\t)","@@ -378,7 +381,9 @@ func Test_shardBySeriesBase_cardinalityShardingMaxShardedQueries(t *testing.T) {"," \t\tname       string"," \t\tmiddleware func(http.RoundTripper, int, Limits, log.Logger) http.RoundTripper"," \t}{","-\t\t{\"active series\", newShardActiveSeriesMiddleware},","+\t\t{\"active series\", func(upstream http.RoundTripper, maxConcurrency int, limits Limits, logger log.Logger) http.RoundTripper {","+\t\t\treturn newShardActiveSeriesMiddleware(upstream, maxConcurrency, false, limits, logger)","+\t\t}},"," \t\t{\"active native histogram metrics\", newShardActiveNativeHistogramMetricsMiddleware},"," \t}"," ","@@ -457,6 +462,7 @@ func Test_shardActiveSeriesMiddleware_RoundTrip_concurrent(t *testing.T) {"," \ts := newShardActiveSeriesMiddleware("," \t\tupstream,"," \t\t0,","+\t\tfalse,"," \t\tmockLimits{maxShardedQueries: shardCount, totalShards: s