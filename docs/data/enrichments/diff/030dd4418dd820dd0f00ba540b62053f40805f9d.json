NewRowReader(ctx context.Context, sec *Section) *RowReader {","+\treturn &RowReader{","+\t\tctx: ctx,","+\t\treader: NewReader(ReaderOptions{","+\t\t\tColumns:   sec.Columns(),","+\t\t\tAllocator: memory.DefaultAllocator,","+\t\t}),","+\t}","+}","+","+var _ iter.CloseIterator[Row] = (*RowReader)(nil)","+","+// Next advances the cursor. Returns false on exhaustion (natural EOF or any","+// error). Subsequent calls continue to return false.","+func (r *RowReader) Next() bool {","+\tif r.exhausted {","+\t\treturn false","+\t}","+\trec, err := r.next()","+\tif errors.Is(err, io.EOF) {","+\t\tr.exhausted = true","+\t\treturn false","+\t}","+\tif err != nil {","+\t\tr.err = err","+\t\tr.exhausted = true","+\t\treturn false","+\t}","+\tr.cur = rec","+\treturn true","+}","+","+// next reads the next Row from the section. Returns io.EOF when exhausted.","+func (r *RowReader) next() (Row, error) {","+\tif !r.opened {","+\t\tif err := r.reader.Open(r.ctx); err != nil {","+\t\t\treturn Row{}, fmt.Errorf(\"opening reader: %w\", err)","+\t\t}","+\t\tr.opened = true","+\t}","+","+\tif r.batch == nil || r.index >= int(r.batch.NumRows()) {","+\t\tr.batch = nil","+","+\t\tbatch, err := r.reader.Read(r.ctx, 8192)","+\t\tif errors.Is(err, io.EOF) && batch == nil {","+\t\t\treturn Row{}, io.EOF","+\t\t}","+\t\tif err != nil && !errors.Is(err, io.EOF) {","+\t\t\treturn Row{}, fmt.Errorf(\"reading batch: %w\", err)","+\t\t}","+","+\t\tif batch != nil && batch.NumRows() > 0 {","+\t\t\tr.batch = batch","+\t\t\tr.index = 0","+\t\t\tif r.columns == nil {","+\t\t\t\tr.columns = BuildColumnIndex(batch.Schema())","+\t\t\t}","+\t\t} else {","+\t\t\t// Empty or nil batch: treat as end of section.","+\t\t\treturn Row{}, io.EOF","+\t\t}","+\t}","+","+\trow := DecodeRow(r.batch, r.columns, r.index)","+\tr.index++","+\treturn row, nil","+}","+","+// At returns the current record. Undefined if Next has not been called or if","+// the last Next call returned false.","+func (r *RowReader) At() Row { return r.cur }","+","+// Err returns any error that caused iteration to end. nil on natural EOF.","+func (r *RowReader) Err() error { return r.err }","+","+// Close releases the underlying reader. Repeat calls return nil without","+// re-closing.","+func (r *RowReader) Close() error {","+\t// Mark exhausted so a stray Next() after Close() returns false instead of","+\t// dereferencing the now-nil reader.","+\tr.exhausted = true","+\tr.batch = nil","+\tif r.reader != nil {","+\t\terr := r.reader.Close()","+\t\tr.reader = nil","+\t\treturn err","+\t}","+\treturn nil","+}"],"additions":125,"deletions":0,"truncated":false},{"path":"pkg/dataobj/sections/postings/row_reader_test.go","lines":["@@ -0,0 +1,179 @@","+package postings_test","+","+import (","+\t\"context\"","+\t\"testing\"","+\t\"time\"","+","+\t\"github.com/stretchr/testify/require\"","+","+\t\"github.com/grafana/loki/v3/pkg/dataobj\"","+\t\"github.com/grafana/loki/v3/pkg/dataobj/sections/postings\"","+)","+","+// TestRowReader_RoundTrip builds a postings section with one label and one","+// bloom entry and verifies RowReader returns both in sort order.","+func TestRowReader_RoundTrip(t *testing.T) {","+\tctx := context.Background()","+","+\tb := postings.NewBuilder(nil, 0, 0)","+\tts := time.Unix(0, 0).UTC()","+","+\tb.ObserveLabelPosting(postings.LabelObservation{","+\t\tObjectPath:       \"/obj\",","+\t\tSectionIndex:     0,","+\t\tColumnName:       \"env\",","+\t\tLabelValue:       \"prod\",","+\t\tStreamID:         1,","+\t\tTimestamp:        ts,","+\t\tUncompressedSize: 100,","+\t})","+","+\tb.PrepareBloomColumn(\"/obj\", 0, \"trace_id\", 1000)","+\trequire.NoError(t, b.ObserveBloomPosting(postings.BloomObservation{","+\t\tObjectPath:       \"/obj\",","+\t\tSectionIndex:     0,","+\t\tColumnName:       \"trace_id\",","+\t\tStreamID:         2,","+\t\tTimestamp:        ts,","+\t\tUncompressedSize: 200,","+\t}))","+","+\tobjBuilder := dataobj.NewBuilder(nil)","+\trequire.NoError(t, objBuilder.Append(b))","+\tobj, closer, err := objBuilder.Flush()","+\trequire.NoError(t, err)","+\tdefer closer.Close()","+","+\tvar sec *postings.Section","+\tfor _, s := range obj.Sections() {","+\t\tif !postings.CheckSection(s) {","+\t\t\tcontinue","+\t\t}","+\t\tsec, err = postings.Open(ctx, s)","+\t\trequire.NoError(t, err)","+\t\tbreak","+\t}","+\trequire.NotNil(t, sec)","+","+\treader := postings.NewRowReader(ctx, sec)","+\tdefer reader.Close()","+","+\tvar rows []postings.Row","+\tfor reader.Next() {","+\t\trows = append(rows, reader.At())","+\t}","+\trequire.NoError(t, reader.Err())","+","+\trequire.Len(t, rows, 2)","+","+\trequire.Equal(t, postings.KindBloom, rows[0].Kind)","+\trequire.Equal(t, \"/obj\", rows[0].ObjectPath)","+\trequire.Equal(t, int64(0), rows[0].SectionIndex)","+\trequire.Equal(t, \"trace_id\", rows[0].ColumnName)","+\trequire.NotNil(t, rows[0].BloomFilter, \"bloom row should have non-nil bloom filter\")","+","+\trequire.Equal(t, postings.KindLabel, rows[1].Kind)","+\trequire.Equal(t, \"/obj\", rows[1].ObjectPath)","+\trequire.Equal(t, int64(0), rows[1].SectionIndex)","+\trequire.Equal(t, \"env\", rows[1].ColumnName)","+\trequire.Equal(t, \"prod\", rows[1].LabelValue)","+\trequire.NotEmpty(t, rows[1].StreamIDBitmap, \"label row should have non-empty stream id bitmap\")","+}","+","+// TestRowReader_RoundTrip_BitLevelAssertion verifies stream-id bitmaps survive","+// the round trip and differ for distinct stream IDs.","+func TestRowReader_RoundTrip_BitLevelAssertion(t *testing.T) {","+\tctx := context.Background()","+","+\tb := postings.NewBuilder(nil, 0, 0)","+\tts := time.Unix(0, 0).UTC()","+","+\tb.ObserveLabelPosting(postings.LabelObservation{","+\t\tObjectPath:       \"/obj\",","+\t\tSectionIndex:     0,","+\t\tColumnName:       \"env\",","+\t\tLabelValue:       \"prod\",","+\t\tStreamID:         5,","+\t\tTimestamp:        ts,","+\t\tUncompressedSize: 100,","+\t})","+\tb.ObserveLabelPosting(postings.LabelObservation{","+\t\tObjectPath:       \"/obj\",","+\t\tSectionIndex:     0,","+\t\tColumnName:       \"env\",","+\t\tLabelValue:       \"staging\",","+\t\tStreamID:         10,","+\t\tTimestamp:        ts,","+\t\tUncompressedSize: 100,","+\t})","+","+\tobjBuilder := dataobj.NewBuilder(nil)","+\trequire.NoError(t, objBuilder.Append(b))","+\tobj, closer, err := objBuilder.Flush()","+\trequire.NoError(t, err)","+\tdefer closer.Close()","+","+\tvar sec *postings.Section","+\tfor _, s := range obj.Sections() {","+\t\tif !postings.CheckSection(s) {","+\t\t\tcontinue","+\t\t}","+\t\tsec, err = postings.Open(ctx, s)","+\t\trequire.NoError(t, err)","+\t\tbreak","+\t}","+\trequire.NotNil(t, sec)","+","+\treader := postings.NewRowReader(ctx, sec)","+\tdefer reader.Close()","+","+\tvar rows []postings.Row","+\tfor reader.Next() {","+\t\trows = append(rows, reader.At())","+\t}","+\trequire.NoError(t, reader.Err())","+","+\trequire.Len(t, rows, 2)","+\trequire.NotEmpty(t, rows[0].StreamIDBitmap, \"first row should have non-empty bitmap\")","+\trequire.NotEmpty(t, rows[1].StreamIDBitmap, \"second row should have non-empty bitmap\")","+\trequire.NotEqual(t, rows[0].StreamIDBitmap, rows[1].StreamIDBitmap, \"bitmaps for different stream IDs should differ\")","+}","+","+// TestRowReader_CloseIdempotent verifies Close can be called more than once.","+func TestRowReader_CloseIdempotent(t *testing.T) {","+\tctx := context.Background()","+","+\tb := postings.NewBuilder(nil, 0, 0)","+\tb.ObserveLabelPosting(postings.LabelObservation{","+\t\tObjectPath:   \"/obj\",","+\t\tSectionIndex: 0,","+\t\tColumnName:   \"env\",","+\t\tLabelValue:   \"prod\",","+\t\tStreamID:     1,","+\t\tTimestamp:    time.Unix(0, 0).UTC(),","+\t})","+","+\tobjBuilder := dataobj.NewBuilder(nil)","+\trequire.NoError(t, objBuilder.Append(b))","+\tobj, closer, err := objBuilder.Flush()","+\trequire.NoError(t, err)","+\tdefer closer.Close()","+","+\tvar sec *postings.Section","+\tfor _, s := range obj.Sections() {","+\t\tif !postings.CheckSection(s) {","+\t\t\tcontinue","+\t\t}","+\t\tsec, err = postings.Open(ctx, s)","+\t\trequire.NoError(t, err)","+\t\tbreak","+\t}","+\trequire.NotNil(t, sec)","+","+\treader := postings.NewRowReader(ctx, sec)","+\trequire.True(t, reader.Next())","+\trequire.NoError(t, reader.Close())","+\trequire.NoError(t, reader.Close(), \"second Close must be a safe no-op\")","+\trequire.False(t, reader.Next(), \"Next() after Close() must return false, not panic\")","+}"],"additions":179,"deletions":0,"truncated":false},{"path":"pkg/dataobj/sections/stats/row_reader.go","lines":["@@ -0,0 +1,134 @@","+package stats","+","+import (","+\t\"context\"","+\t\"errors\"","+\t\"fmt\"","+\t\"io\"","+","+\t\"github.com/apache/arrow-go/v18/arrow\"","+\t\"github.com/apache/arrow-go/v18/arrow/memory\"","+","+\titer \"github.com/grafana/loki/v3/pkg/iter/v2\"","+)","+","+// RowReader reads [Stat] records from a stats [Section] one row at a time, in","+// section order. It is a row-level cursor over the batch-level [Reader].","+// It implements [iter.CloseIterator] over [Stat].","+//","+// A RowReader is not safe for concurrent use.","+type RowReader struct {","+\tctx     context.Context","+\treader  *Reader","+\tbatch   arrow.RecordBatch","+\tindex   int","+\tcolumns ColumnIndex","+\topened  bool","+","+\tcur       Stat  // current value, valid between Next() returning true and the next Next() call","+\terr       error // captured if iteration ends with anything other than io.EOF","+\texhausted bool  // set when Next has returned false; further calls return false without work","+}","+","+// NewRowReader creates a RowReader over all of sec's columns. The underlying","+// reader is opened lazily on the first call to Next. The provided ctx governs","+// all subsequent I/O (Open and Read).","+func NewRowReader(ctx context.Context, sec *Section) *RowReader {","+\treturn &RowReader{","+\t\tctx: ctx,","+\t\treader: NewReader(ReaderOptions{","+\t\t\tColumns:   sec.Columns(),","+\t\t\tAllocator: memory.DefaultAllocator,","+\t\t}),","+\t}",