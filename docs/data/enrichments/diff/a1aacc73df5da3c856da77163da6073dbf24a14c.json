total_supplier_count +","+\t       1;","+}","+","+static void AppendPartName(tpch_append_information &info, DBGenContext *ctx) {","+\tpermute_dist(&colors, &ctx->Seed[P_NAME_SD], ctx);","+\tidx_t length = 0;","+\tfor (idx_t i = 0; i < P_NAME_SCL; i++) {","+\t\tlength += NumericCast<idx_t>(colors.list[ctx->permute[i]].length);","+\t}","+\tlength += P_NAME_SCL - 1;","+","+\tauto &result = append_empty_string(info, length);","+\tauto target = result.GetDataWriteable();","+\tfor (idx_t i = 0; i < P_NAME_SCL; i++) {","+\t\tauto &member = colors.list[ctx->permute[i]];","+\t\tauto member_length = NumericCast<idx_t>(member.length);","+\t\tauto member_text = member.text;","+\t\tmemcpy(target, member_text, member_length);","+\t\ttarget += member_length;","+\t\tif (i + 1 < P_NAME_SCL) {","+\t\t\t*target++ = ' ';","+\t\t}","+\t}","+\tresult.Finalize();","+}","+","+static void AppendSupplierComment(tpch_append_information &info, DBGenContext *ctx) {","+\tconst char *source;","+\tauto length = dbg_text_source(int(S_CMNT_LEN * V_STR_LOW), int(S_CMNT_LEN * V_STR_HGH), &ctx->Seed[S_CMNT_SD],","+\t                              &source);","+\t// Supplier comments can be patched with BBB text, so they need writable vector-owned storage.","+\tauto &result = append_empty_string(info, NumericCast<idx_t>(length));","+\tauto target = result.GetDataWriteable();","+\tmemcpy(target, source, NumericCast<idx_t>(length));","+","+\tDSS_HUGE bad_press, noise, offset, type;","+\tRANDOM(bad_press, 1, 10000, &ctx->Seed[BBB_CMNT_SD]);","+\tRANDOM(type, 0, 100, &ctx->Seed[BBB_TYPE_SD]);","+\tRANDOM(noise, 0, (length - BBB_CMNT_LEN), &ctx->Seed[BBB_JNK_SD]);","+\tRANDOM(offset, 0, (length - (BBB_CMNT_LEN + noise)), &ctx->Seed[BBB_OFFSET_SD]);","+\tif (bad_press <= S_CMNT_BBB) {","+\t\ttype = (type < BBB_DEADBEATS) ? 0 : 1;","+\t\tmemcpy(target + offset, BBB_BASE, BBB_BASE_LEN);","+\t\tif (type == 0) {","+\t\t\tmemcpy(target + BBB_BASE_LEN + offset + noise, BBB_COMPLAIN, BBB_TYPE_LEN);","+\t\t} else {","+