/../../../tmp/escape\", true},","+\t\t{\"slash\", \"a/b\", true},","+\t\t{\"dot\", \"a.b\", true},","+\t\t{\"leading-dotdot\", \"..\", true},","+\t\t{\"valid\", \"my-note-1\", false},","+\t}","+","+\tfor _, tc := range cases {","+\t\tt.Run(tc.name, func(t *testing.T) {","+\t\t\tbody := `{\"name\":\"x\",\"slug\":\"` + tc.slug + `\"}`","+\t\t\treq := httptest.NewRequest(http.MethodPost, \"/api/books\", strings.NewReader(body))","+\t\t\treq.Header.Set(\"Content-Type\", \"application/json\")","+\t\t\trec := httptest.NewRecorder()","+\t\t\tmux.ServeHTTP(rec, req)","+","+\t\t\t// A valid slug is accepted (2xx); any invalid slug is rejected","+\t\t\t// with a non-2xx (huma returns 422 for pattern violations, 400","+\t\t\t// for malformed JSON such as bare backslashes).","+\t\t\trejected := rec.Code < 200 || rec.Code > 299","+\t\t\tif rejected != tc.wantReject {","+\t\t\t\tt.Fatalf(\"slug %q: status=%d rejected=%v, want rejected=%v\",","+\t\t\t\t\ttc.slug, rec.Code, rejected, tc.wantReject)","+\t\t\t}","+\t\t})","+\t}","+}",""],"additions":67,"deletions":0,"truncated":false}],"additions":103,"deletions":10,"truncated":false,"file_count":3},"error":null,"fetched_at":"2026-07-10T10:52:44.273096+00:00"}