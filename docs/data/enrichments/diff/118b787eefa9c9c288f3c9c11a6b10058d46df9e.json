;","+  }","+};","+","+await promise;"],"additions":32,"deletions":0,"truncated":false},{"path":"tests/specs/mod.rs","lines":["@@ -539,6 +539,17 @@ fn should_run(if_cond: Option<&str>) -> bool {","       \"notWindowsArm\" => {","         !(cfg!(target_os = \"windows\") && cfg!(target_arch = \"aarch64\"))","       }","+      \"notWindowsArmOrMacIntel\" => {","+        !((cfg!(target_os = \"windows\") && cfg!(target_arch = \"aarch64\"))","+          || (cfg!(target_os = \"macos\") && cfg!(target_arch = \"x86_64\")))","+      }","+      \"notSlowCiShard\" => {","+        let is_linux_x86_ci =","+          *IS_CI && cfg!(target_os = \"linux\") && cfg!(target_arch = \"x86_64\");","+        !((cfg!(target_os = \"windows\") && cfg!(target_arch = \"aarch64\"))","+          || (cfg!(target_os = \"macos\") && cfg!(target_arch = \"x86_64\"))","+          || is_linux_x86_ci)","+      }","       value => panic!(\"Unknown if condition: {}\", value),","     }","   } else {"],"additions":11,"deletions":0,"truncated":false},{"path":"tests/specs/npm/playwright_compat/__test__.jsonc","lines":["@@ -1,5 +1,5 @@"," {","-  \"if\": \"notWindowsArm\",","+  \"if\": \"notSlowCiShard\",","   \"envs\": {","     \"PLAYWRIGHT_BROWSERS_PATH\": \"../../../../.ms-playwright\"","   },"],"additions":1,"deletions":1,"truncated":false},{"path":"tests/specs/run/classic_worker_blob_url/runs_with_testing_features.js","lines":["@@ -7,6 +7,7 @@ const blob = new Blob([code], { type: \"text/javascript\" });"," const url = URL.createObjectURL(blob);"," "," const worker = new Worker(url);","+URL.revokeObjectURL(url);"," const { promise, resolve } = Promise.withResolvers();"," worker.onmessage = (event) => {","   console.log(JSON.stringify(event.data));"],"additions":1,"deletions":0,"truncated":false},{"path":"tests/specs/worker/worker_blob_url_revoke/__test__.jsonc","lines":["@@ -0,0 +1,14 @@","+{","+  \"tests\": {","+    \"js\": {","+      \"if\": \"notWindowsArmOrMacIntel\",","+      \"args\": \"run --quiet mai