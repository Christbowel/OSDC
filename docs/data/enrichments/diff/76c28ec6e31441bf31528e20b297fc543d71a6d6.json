}","+\tif marked {","+\t\tdata[linodeDisableCheckKey] = \"true\"","+\t}","+\treturn &corev1.ConfigMap{","+\t\tObjectMeta: v1.ObjectMeta{","+\t\t\tName:            linodeDisableCheckConfigMap,","+\t\t\tNamespace:       cattleNamespace,","+\t\t\tResourceVersion: \"1\",","+\t\t},","+\t\tData: data,","+\t}","+}","+","+func markerNotFound() error {","+\treturn apierrors.NewNotFound(","+\t\tschema.GroupResource{Group: \"\", Resource: \"configmaps\"},","+\t\tlinodeDisableCheckConfigMap,","+\t)","+}","+","+func activeNodeDriver() *mgmtv3.NodeDriver {","+\treturn &mgmtv3.NodeDriver{","+\t\tObjectMeta: v1.ObjectMeta{Name: linodeDriver, ResourceVersion: \"1\"},","+\t\tSpec:       mgmtv3.NodeDriverSpec{Active: true},","+\t}","+}","+","+// parentSchemaWithField returns a minimal DynamicSchema that has a given field.","+func parentSchemaWithField(name, field string) *mgmtv3.DynamicSchema {","+\treturn &mgmtv3.DynamicSchema{","+\t\tObjectMeta: v1.ObjectMeta{Name: name, ResourceVersion: \"1\"},","+\t\tSpec: mgmtv3.DynamicSchemaSpec{","+\t\t\tResourceFields: map[string]mgmtv3.Field{field: {}},","+\t\t},","+\t}","+}","+","+// setupTeardownExpectations sets up the mock expectations for the full linode","+// teardown path (deactivate NodeDriver, delete schemas, remove fields, delete","+// CRDs). All operations tolerate NotFound.","+func setupTeardownExpectations(","+\tmockND *ctrlfake.MockNonNamespacedControllerInterface[*mgmtv3.NodeDriver, *mgmtv3.NodeDriverList],","+\tmockDS *ctrlfake.MockNonNamespacedControllerInterface[*mgmtv3.DynamicSchema, *mgmtv3.DynamicSchemaList],","+\tmockCRD *ctrlfake.MockNonNamespacedControllerInterface[*apiextv1.CustomResourceDefinition, *apiextv1.CustomResourceDefinitionList],","+\tndActive bool,","+) {","+\t// NodeDriver: Get + Update (if active)","+\tif ndActive {","+\t\tmockND.EXPECT().Get(linodeDriver, v1.GetOptions{}).Return(activeNodeDriver(), nil)","+\t\tmockND.EXPECT().Update(gomock.Any()).DoAndReturn(func(nd *mgmtv3.NodeDriver) (*mgmtv3.NodeDrive