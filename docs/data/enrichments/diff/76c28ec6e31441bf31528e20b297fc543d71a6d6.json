 {","-\t\tlinodeBuiltin = isCommandAvailable(\"docker-machine-driver-linode\")","-\t}","-\tlinodeDriverURL := fmt.Sprintf(\"https://github.com/linode/docker-machine-driver-linode/releases/download/v0.1.16/docker-machine-driver-linode_linux-%s.zip\", runtime.GOARCH)","+","+\tlinodeDriverURL := fmt.Sprintf(","+\t\t\"https://github.com/linode/docker-machine-driver-linode/releases/download/v0.1.16/docker-machine-driver-linode_linux-%s.zip\",","+\t\truntime.GOARCH,","+\t)"," \tlinodeDriverChecksum := \"d9c3b8c389a022b0e5c5e8912496c18a673fa74bb52ec6ab51c0a93e0f4de06d\""," \tif runtime.GOARCH == \"arm64\" {","-\t\t// overwrite arm driver version here"," \t\tlinodeDriverChecksum = \"1a8336f66bffc2186f5fb77642f509b9370f177397ee71f1a8cb522e5979dbec\""," \t}","-\tif err := addMachineDriver(Linodedriver, linodeDriverURL, \"\", linodeDriverChecksum, []string{\"api.linode.com\"}, linodeBuiltin, linodeBuiltin, false, nil, management); err != nil {","+\t// The linode docker-machine driver binary is no longer shipped inside the","+\t// rancher image; it is downloaded from upstream on first activation.","+\t//","+\t// createActive=false: fresh installations land with the driver inactive.","+\t// updateActive=nil:   the \"disable if unused\" decision is made once per","+\t//   Rancher installation by disableUnusedLinodeNodeDriver, which runs early","+\t//   in rancher.New() before informers start. After that the admin's choice","+\t//   is preserved across restarts.","+\tif err := addMachineDriver(Linodedriver, linodeDriverURL, \"\", linodeDriverChecksum, []string{\"api.linode.com\"}, false, false, false, nil, management); err != nil {"," \t\treturn err"," \t}"," \tif err := addMachineDriver(OCIDriver, \"https://github.com/rancher-plugins/rancher-machine-driver-oci/releases/download/v1.3.0/docker-machine-driver-oci-linux\", \"\", \"0a1afa6a0af85ecf3d77cc554960e36e1be5fd12b22b0155717b9289669e4021\", []string{\"*.oraclecloud.com\"}, false, false, false, nil, management); err != nil {","@@ -388,7 +393,3 @@ func deleteMachineDriver(name, urlPrefix string, ndClient normanv3.NodeDriverInt"," \t\tlogrus.Warnf(\"Error deleting node driver %s: %v\", name, err)"," \t}"," }","-","-func isCommandAvailable(name string) bool {","-\treturn exec.Command(\"command\", \"-v\", name).Run() == nil","-}"],"additions":14,"deletions":13,"truncated":false},{"path":"pkg/rancher/driver_migration.go","lines":["@@ -0,0 +1,219 @@","+package rancher","+","+import (","+\t\"fmt\"","+","+\t\"github.com/rancher/rancher/pkg/data/management\"","+\t\"github.com/rancher/rancher/pkg/wrangler\"","+\t\"github.com/sirupsen/logrus\"","+\tcorev1 \"k8s.io/api/core/v1\"","+\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"","+\tv1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"","+\t\"k8s.io/client-go/util/retry\"","+)","+","+const (","+\tlinodeDriver = management.Linodedriver","+","+\t// One-shot ConfigMap marker: gates the \"disable linode if unused\" evaluation","+\t// so it runs only on the first Rancher start, not on every subsequent restart.","+\tlinodeDisableCheckConfigMap = \"disableunusedlinodenodedriver\"","+\tlinodeDisableCheckKey       = \"unusedLinodeNodeDriverDisabled\"","+","+\tlinodeMachineConfigKind = \"LinodeConfig\"","+","+\t// DynamicSchema object names created by the nodedriver lifecycle for linode.","+\tlinodeConfigSchemaName           = \"linodeconfig\"","+\tlinodeCredentialConfigSchemaName = \"linodecredentialconfig\"","+","+\t// Parent DynamicSchema objects that embed the linode config fields.","+\tlinodeParentNodeConfig   = \"nodeconfig\"","+\tlinodeParentNodeTemplate = \"nodetemplateconfig\"","+\tlinodeParentCredential   = \"credentialconfig\"","+","+\t// Fields in the parent DynamicSchema objects that embed the linode config fields.","+\tlinodeConfigField     = \"linodeConfig\"","+\tlinodeCredentialField = \"linodecredentialConfig\"","+","+\t// CRD names generated from the linodeconfig DynamicSchema.","+\tlinodeConfigCRD          = \"linodeconfigs.rke-machine-config.cattle.io\"","+\tlinodeMachineCRD         = \"linodemachines.rke-machine.cattle.io\"","+\tlinodeMachineTemplateCRD = \"linodemachinetemplates.rke-machine.cattle.io\"","+)","+","+// disableUnusedLinodeNodeDriver runs once per Rancher installation (gated by a","+// ConfigMap marker in cattle-system) to disable the linode NodeDriver and","+// remove its associated DynamicSchema objects, parent-schema fields, and","+// generated CRDs when no provisioning cluster is using it.","+//","+// This function MUST be called early in rancher.New(), before the wrangler","+// SharedCacheFactory and lasso dynamic controller start (i.e. before","+// MultiClusterManager.Start / steveserver.New). The reason is that once lasso","+// starts it caches the RESTMappings of the linode CRDs in an internal","+// memory-cache that is never invalidated on CRD deletion, so deleting the CRDs","+// after that point causes lasso to keep resurrecting watchers for the deleted","+// GVKs, which then 404 forever. Deleting the CRDs before lasso ever sees them","+// ensures the mappings are never cached and no watchers are started.","+//","+// All operations use direct API calls (not informer caches) because this","+// function runs before any informer is synced. All deletes and updates tolerate","+// NotFound, so the function is idempotent and safe on fresh installs where the","+// driver and its CRDs do not yet exist.","+func disableUnusedLinodeNodeDriver(w *wrangler.Context) error {","+\tcm, err := w.Core.ConfigMap().Get(cattleNamespace, linodeDisableCheckConfigMap, v1.GetOptions{})","+\tif err != nil && !apierrors.IsNotFound(err) {","+\t\treturn fmt.Errorf(\"DisableUnusedLinodeNodeDriver: failed to get marker ConfigMap: %w\", err)","+\t}","+\t// Marker already set on a previous start: nothing to do.","+\tif cm != nil && cm.Data[linodeDisableCheckKey] == \"true\" {","+\t\treturn nil","+\t}","+","+\tinUse, err := linodeNodeDriverInUse(w)","+\tif err != nil {","+\t\treturn err","+\t}","+","+\tif inUse {","+\t\tlogrus.Info(\"disableUnusedLinodeNodeDriver: linode node driver is in use by one or more provisioning clusters; leaving state unchanged\")","+\t} else {","+\t\tlogrus.Info(\"disableUnusedLinodeNodeDriver: deactivating the unused linode node driver\")","+\t\terr := retry.RetryOnConflict(retry.DefaultRetry, func() error {","+\t\t\t// 1. Deactivate the NodeDriver CR.","+\t\t\tnd, err := w.Mgmt.NodeDriver().Get(linodeDriver, v1.GetOptions{})","+\t\t\tif apierrors.IsNotFound(err) {","+\t\t\t\treturn nil","+\t\t\t}","+\t\t\tif err != nil {","+\t\t\t\treturn err","+\t\t\t}","+\t\t\tif !nd.Spec.Active {","+\t\t\t\treturn nil // Already inactive.","+\t\t\t}","+\t\t\tnd = nd.DeepCopy()","+\t\t\tnd.Spec.Active = false","+\t\t\tif _, err := w.Mgmt.NodeDriver().Update(nd); err != nil {","+\t\t\t\treturn fmt.Errorf(\"failed to update NodeDriver: %w\", err)","+\t\t\t}","+\t\t\tlogrus.Debug(\"disableUnusedLinodeNodeDriver: deactivated nodeDriver linode\")","+","+\t\t\t// 2. Delete the linodeconfig and linodecredentialconfig DynamicSchema","+\t\t\t//    objects. These are the source objects that the CAPR dynamicschema","+\t\t\t//    controller uses to generate the rke-machine CRDs; deleting them","+\t\t\t//    prevents any future re-generation.","+\t\t\tfor _, schemaName := range []string{linodeConfigSchemaName, linodeCredentialConfigSchemaName} {","+\t\t\t\tif err := w.Mgmt.DynamicSchema().Delete(schemaName, &v1.DeleteOptions{}); err != nil && !apierrors.IsNotFound(err) {","+\t\t\t\t\treturn fmt.Errorf(\"failed to delete DynamicSchema %s: %w\", schemaName, err)","+\t\t\t\t}","+\t\t\t\tlogrus.Debugf(\"disableUnusedLinodeNodeDriver: deleted DynamicSchema %s\", schemaName)","+\t\t\t}","+","+\t\t\t// 3. Remove the linode config fields from the parent schemas so that","+\t\t\t//    getStyle() can never return node=true for linode, even if the","+\t\t\t//    DynamicSchema objects are re-created.","+\t\t\tparentFields := []struct{ schema, field string }{","+\t\t\t\t{linodeParentNodeConfig, linodeConfigField},","+\t\t\t\t{linodeParentNodeTemplate, linodeConfigField},","+\t\t\t\t{linodeParentCredential, linodeCredentialField},","+\t\t\t}","+\t\t\tfor _, pf := range parentFields {","+\t\t\t\tif err := removeFieldFromSchema(w, pf.schema, pf.field); err != nil {","+\t\t\t\t\treturn fmt.Errorf(\"failed to remove field %s from schema %s: %w\", pf.field, pf.schema, err)","+\t\t\t\t}","+\t\t\t\tlogrus.Debugf(\"disableUnusedLinodeNodeDriver: disabled %s from schema %s\", pf.field, pf.schema)","+\t\t\t}","+","+\t\t\t// 4. Delete the three CRDs generated from the linodeconfig DynamicSchema.","+\t\t\t//    This must happen before lasso's dynamic controller starts so the CRD","+\t\t\t//    RESTMappings are never cached in lasso's internal memory-cache mapper.","+\t\t\tfor _, crdName := range []string{linodeConfigCRD, linodeMachineCRD, linodeMachineTemplateCRD} {","+\t\t\t\tif err := w.CRD.CustomResourceDefinition().Delete(crdName, &v1.DeleteOptions{}); err != nil && !apierrors.IsNotFound(err) {","+\t\t\t\t\treturn fmt.Errorf(\"failed to delete CRD %s: %w\", crdName, err)","+\t\t\t\t}","+\t\t\t\tlogrus.Debugf(\"disableUnusedLinodeNodeDriver: deleted CRD %s\", crdName)","+\t\t\t}","+\t\t\treturn nil","+\t\t})","+\t\tif err != nil {","+\t\t\treturn fmt.Errorf(\"disableUnusedLinodeNodeDriver: failed to deactivate linode NodeDriver: %w\", err)","+\t\t}","+\t}","+","+\treturn retry.RetryOnConflict(retry.DefaultRetry, func() error {","+\t\tcm, err := w.Core.ConfigMap().Get(cattleNamespace, linodeDisableCheckConfigMap, v1.GetOptions{})","+\t\tif apierrors.IsNotFound(err) {","+\t\t\tcm = &corev1.ConfigMap{","+\t\t\t\tObjectMeta: v1.ObjectMeta{","+\t\t\t\t\tNamespace: cattleNamespace,","+\t\t\t\t\tName:      linodeDisableCheckConfigMap,","+\t\t\t\t},","+\t\t\t\tData: make(map[string]string, 1),","+\t\t\t}","+\t\t} else if err != nil {","+\t\t\treturn err","+\t\t}","+","+\t\t// Marker already set by another Rancher pod: nothing to do.","+\t\tif cm != nil && cm.Data[linodeDisableCheckKey] == \"true\" {","+\t\t\treturn nil","+\t\t}","+","+\t\t// Persist the marker regardless of in-use status so the evaluation never","+\t\t// re-runs on subsequent starts (admin's choices are preserved thereafter).","+\t\tif cm.Data == nil {","+\t\t\tcm.Data = make(map[string]string, 1)","+\t\t}","+\t\tcm.Data[linodeDisableCheckKey] = \"true\"","+","+\t\tif cm.ResourceVersion == \"\" {","+\t\t\t_, err = w.Core.ConfigMap().Create(cm)","+\t\t\tif apierrors.IsAlreadyExists(err) {","+\t\t\t\treturn nil","+\t\t\t}","+\t\t\treturn err","+\t\t}","+\t\t_, err = w.Core.ConfigMap().Update(cm)","+\t\treturn err","+\t})","+}","+","+// linodeNodeDriverInUse reports whether any provisioning.cattle.io/v1 Cluster","+// has a MachinePool whose machineConfigRef matches the linode node driver.","+func linodeNodeDriverInUse(w *wrangler.Context) (bool, error) {","+\tclusters, err := w.Provisioning.Cluster().List(\"\", v1.ListOptions{})","+\tif err != nil {","+\t\treturn false, fmt.Errorf(\"linodeNodeDriverInUse: failed to list provisioning clusters: %w\", err)","+\t}","+\tfor _, cluster := range clusters.Items {","+\t\tif cluster.Spec.RKEConfig == nil {","+\t\t\tcontinue","+\t\t}","+\t\tfor _, pool := range cluster.Spec.RKEConfig.MachinePools {","+\t\t\t// APIVersion is empty when the cluster is created via UI, so we don't check it here.","+\t\t\tif pool.NodeConfig != nil && pool.NodeConfig.Kind == linodeMachineConfigKind {","+\t\t\t\treturn true, nil","+\t\t\t}","+\t\t}","+\t}","+\treturn false, nil","+}","+","+// removeFieldFromSchema removes the named field from the ResourceFields of the","+// specified DynamicSchema. Tolerates NotFound (schema does not exist yet) and","+// is a no-op when the field is already absent.","+func removeFieldFromSchema(w *wrangler.Context, schemaName, fieldName string) error {","+\tschema, err := w.Mgmt.DynamicSchema().Get(schemaName, v1.GetOptions{})","+\tif apierrors.IsNotFound(err) {","+\t\treturn nil","+\t}","+\tif err != nil {","+\t\treturn err","+\t}","+\tif _, ok := schema.Spec.ResourceFields[fieldName]; !ok {","+\t\treturn nil // Field already absent.","+\t}","+\tschema = schema.DeepCopy()","+\tdelete(schema.Spec.ResourceFields, fieldName)","+\t_, err = w.Mgmt.DynamicSchema().Update(schema)","+\treturn err","+}"],"additions":219,"deletions":0,"truncated":false},{"path":"pkg/rancher/driver_migration_test.go","lines":["@@ -0,0 +1,438 @@","+package rancher","+","+import (","+\t\"errors\"","+\t\"testing\"","+","+\tmgmtv3 \"github.com/rancher/rancher/pkg/apis/management.cattle.io/v3\"","+\tprovv1 \"github.com/rancher/rancher/pkg/apis/provisioning.cattle.io/v1\"","+\t\"github.com/rancher/rancher/pkg/capr\"","+\tmanagementv3 \"github.com/rancher/rancher/pkg/generated/controllers/management.cattle.io/v3\"","+\tprovisioningv1 \"github.com/rancher/rancher/pkg/generated/controllers/provisioning.cattle.io/v1\"","+\t\"github.com/rancher/rancher/pkg/wrangler\"","+\tcrdv1 \"github.com/rancher/wrangler/v3/pkg/generated/controllers/apiextensions.k8s.io/v1\"","+\tcorev1wrangler \"github.com/rancher/wrangler/v3/pkg/generated/controllers/core/v1\"","+\tctrlfake \"github.com/rancher/wrangler/v3/pkg/generic/fake\"","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+\t\"go.uber.org/mock/gomock\"","+\tcorev1 \"k8s.io/api/core/v1\"","+\tapiextv1 \"k8s.io/apiextensions-apiserver/pkg/apis/apiextensions/v1\"","+\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"","+\tv1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"","+\t\"k8s.io/apimachinery/pkg/runtime/schema\"","+)","+","+type stubProvisioningV1ForLinode struct {","+\tprovisioningv1.Interface","+\tclusterCtrl provisioningv1.ClusterController","+}","+","+func (s *stubProvisioningV1ForLinode) Cluster() provisioningv1.ClusterController {","+\treturn s.clusterCtrl","+}","+","+type stubCoreV1ForLinode struct {","+\tcorev1wrangler.Interface","+\tconfigMapCtrl corev1wrangler.ConfigMapController","+}","+","+func (s *stubCoreV1ForLinode) ConfigM