stIntegrationBackendReadAtRVEdgeCases(t *testing.T, backend resource.StorageBackend, nsPrefix string) {"," \tctx := types.WithAuthInfo(context.Background(), authn.NewAccessTokenAuthInfo(authn.Claims[authn.AccessTokenClaims]{"," \t\tClaims: jwt.Claims{Subject: \"testuser\"},"," \t\tRest:   authn.AccessTokenClaims{},"," \t}))","-\tns := nsPrefix + \"-pre-del-rv\"","+\tns := nsPrefix + \"-read-rv\"","+\tkey := &resourcepb.ResourceKey{","+\t\tName:      \"target\",","+\t\tNamespace: ns,","+\t\tGroup:     \"group\",","+\t\tResource:  \"resource\",","+\t}"," ","-\trvAdd, err := WriteEvent(ctx, backend, \"target\", resourcepb.WatchEvent_ADDED, WithNamespace(ns))","+\trvCreate, err := WriteEvent(ctx, backend, \"target\", resourcepb.WatchEvent_ADDED,","+\t\tWithNamespace(ns), WithValue(\"target-create\"))"," \trequire.NoError(t, err)"," ","-\t// Unrelated traffic so the target's RVs are not contiguous in the global stream."," \t_, err = WriteEvent(ctx, backend, \"noise-a\", resourcepb.WatchEvent_ADDED, WithNamespace(ns))"," \trequire.NoError(t, err)"," ","-\trvMod1, err := WriteEvent(ctx, backend, \"target\", resourcepb.WatchEvent_MODIFIED, WithNamespaceAndRV(ns, rvAdd))","+\trvUpdate, err := WriteEvent(ctx, backend, \"target\", resourcepb.WatchEvent_MODIFIED,","+\t\tWithNamespaceAndRV(ns, rvCreate), WithValue(\"target-update\"))"," \trequire.NoError(t, err)"," "," \t_, err = WriteEvent(ctx, backend, \"noise-b\", resourcepb.WatchEvent_ADDED, WithNamespace(ns))"," \trequire.NoError(t, err)"," ","-\trvMod2, err := WriteEvent(ctx, backend, \"target\", resourcepb.WatchEvent_MODIFIED, WithNamespaceAndRV(ns, rvMod1))","+\trvDelete, err := WriteEvent(ctx, backend, \"target\", resourcepb.WatchEvent_DELETED,","+\t\tWithNamespaceAndRV(ns, rvUpdate), WithValue(\"target-delete\"))"," \trequire.NoError(t, err)"," ","-\trvDel, err := WriteEvent(ctx, backend, \"target\", resourcepb.WatchEvent_DELETED, WithNamespaceAndRV(ns, rvMod2))","+\t_, err = WriteEvent(ctx, backend, \"noise-c\", resou