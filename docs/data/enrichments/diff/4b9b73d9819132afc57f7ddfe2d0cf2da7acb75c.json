 rv+1\", requestRV: rvUpdate + 1, expectedRV: rvUpdate, expectedSubstring: \"target-update\"},","+\t\t{name: \"delete rv-1\", requestRV: rvDelete - 1, expectedRV: rvUpdate, expectedSubstring: \"target-update\"},","+\t\t{name: \"delete rv\", requestRV: rvDelete, expectedStatus: http.StatusNotFound},","+\t\t{name: \"delete rv+1\", requestRV: rvDelete + 1, expectedStatus: http.StatusNotFound},","+\t\t{name: \"recreate rv-1\", requestRV: rvRecreate - 1, expectedStatus: http.StatusNotFound},","+\t\t{name: \"recreate rv\", requestRV: rvRecreate, expectedRV: rvRecreate, expectedSubstring: \"target-recreate\"},","+\t\t{name: \"recreate rv+1\", requestRV: rvRecreate + 1, expectedRV: rvRecreate, expectedSubstring: \"target-recreate\"},","+\t}","+","+\tfor _, tc := range cases {","+\t\tt.Run(tc.name, func(t *testing.T) {","+\t\t\tresp := backend.ReadResource(ctx, &resourcepb.ReadRequest{","+\t\t\t\tKey:             key,","+\t\t\t\tResourceVersion: tc.requestRV,","+\t\t\t})","+\t\t\tif tc.expectedStatus != 0 {","+\t\t\t\trequire.NotNil(t, resp.Error)","+\t\t\t\trequire.Equal(t, tc.expectedStatus, resp.Error.Code)","+\t\t\t\treturn","+\t\t\t}","+\t\t\trequire.Nil(t, resp.Error, \"ReadResource error: %v\", resp.Error)","+\t\t\trequire.Equal(t, tc.expectedRV, resp.ResourceVersion)","+\t\t\trequire.Contains(t, string(resp.Value), tc.expectedSubstring)","+\t\t})","+\t}"," }"," "," // runTestIntegrationBackendErrorResponses tests that the server API returns",""],"additions":66,"deletions":33,"truncated":false}],"additions":151,"deletions":40,"truncated":false,"file_count":9},"error":null,"fetched_at":"2026-06-25T10:32:51.659240+00:00"}