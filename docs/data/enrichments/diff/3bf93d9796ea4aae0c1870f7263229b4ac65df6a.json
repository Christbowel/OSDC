\")","+\tif err != nil {","+\t\tt.Fatal(err)","+\t}","+\twant := `unknown configuration option \"metrics_export.typo\" encountered`","+\tif !slices.Contains(conf.Warnings, want) {","+\t\tt.Fatalf(\"expected warning %q, got %v\", want, conf.Warnings)","+\t}","+}"],"additions":28,"deletions":0,"truncated":false},{"path":"internal/metricsexport/validate.rego","lines":["@@ -0,0 +1,76 @@","+# METADATA","+# description: |","+#   Injects defaults and validates the metrics_export configuration (OTLP metrics","+#   export). Evaluated by parseMetricsExportConfig. Field type validation is","+#   handled by unmarshaling into the Go struct.","+#","+#   Input: {\"config\": <raw metrics_export config>}","+#   Entrypoints: processed (config + defaults), errors (fatal).","+package opa.config.metrics_export","+","+import future.keywords.not","+","+_default_grpc_address := \"localhost:4317\"","+","+_default_http_address := \"localhost:4318\"","+","+_default_export_interval_ms := 60000","+","+_default_service_name := \"opa\"","+","+_default_encryption_scheme := \"off\"","+","+_supported_types := {\"\", \"otlp/grpc\", \"otlp/http\"}","+","+_supported_encryption := {\"off\", \"tls\", \"mtls\"}","+","+# The address defaults from the (case-insensitive) type, but only when the type","+# selects an exporter.","+_default_address := _default_grpc_address if lower(input.config.type) == \"otlp/grpc\"","+","+_default_address := _default_http_address if lower(input.config.type) == \"otlp/http\"","+","+# METADATA","+# entrypoint: true","+# description: the config with metrics_export defaults injected for absent options.","+processed := object.union_n(array.concat([input.config], [patch | some patch in _patches]))","+","+_patches contains {\"address\": _default_address} if _empty([\"address\"])","+","+_patches contains {\"export_interval_ms\": _default_export_interval_ms} if _absent([\"export_interval_ms\"])","+","+_patches contains {\"service_name\": _default_service_name} if _empty([\"service_name\"])","+","+_patches contains {\"encryption\": _default_encryption_scheme} if _empty([\"encryption\"])","+","+_patches contains {\"allow_insecure_tls\": false} if _absent([\"allow_insecure_tls\"])","+","+errors contains msg if {","+\tinput.config.type","+\tnot lower(input.config.type) in _supported_types","+\tmsg := $`unknown metrics_export.type \"{input.config.type}\", must be \"otlp/grpc\", \"otlp/http\" or \"\" (unset)`","+}","+","+errors contains msg if {","+\tprocessed.export_interval_ms <= 0","+\tmsg := $`metrics_export.export_interval_ms must be a positive value, got {processed.export_interval_ms}`","+}","+","+errors contains msg if {","+\tnot processed.encryption in _supported_encryption","+\tmsg := $`unsupported metrics_export.encryption \"{processed.encryption}\"`","+}","+","+# _absent is true when the option at path is missing or explicitly null (a nil","+# pointer in Go).","+_absent(path) if object.get(input.config, path, null) == null","+","+# _empty is true when a string option is missing, null, or the empty string,","+# matching the pre-Rego behavior that defaulted on \"\".","+_empty(path) if not _nonempty(path)","+","+_nonempty(path) if {","+\tv := object.get(input.config, path, null)","+\tv != null","+\tv != \"\"","+}"],"additions":76,"deletions":0,"truncated":false},{"path":"internal/metricsexport/validate_test.rego","lines":["@@ -0,0 +1,55 @@","+package opa.config.metrics_export_test","+","+import data.opa.config.metrics_export","+","+test_empty_config_defaults if {","+\tresult := metrics_export.processed with input as {\"config\": {}}","+\tresult.export_interval_ms == 60000","+\tresult.service_name == \"opa\"","+\tresult.encryption == \"off\"","+\tresult.allow_insecure_tls == false","+\tnot result.address # no address without a type","+}","+","+test_address_default_from_type[tc.note] if {","+\tsome tc in [","+\t\t{\"note\": \"grpc\", \"type\": \"otlp/grpc\", \"want\": \"localhost:4317\"},","+\t\t{\"note\": \"http\", \"type\": \"otlp/http\", \"want\": \"localhost:4318\"},","+\t\t{\"note\": \"case-insensitive\", \"type\": \"OTLP/GRPC\", \"want\": \"localhost:4317\"},","+\t]","+","+\tresult := metrics_export.processed with input as {\"config\": {\"type\": tc.type}}","+\tresult.address == tc.want","+}","+","+test_preserves_configured_values[tc.note] if {","+\tsome tc in [","+\t\t{\"note\": \"interval\", \"config\": {\"export_interval_ms\": 30000}, \"key\": \"export_interval_ms\", \"want\": 30000},","+\t\t{\"note\": \"allow_insecure_tls\", \"config\": {\"allow_insecure_tls\": true}, \"key\": \"allow_insecure_tls\", \"want\": true},","+\t]","+","+\tresult := metrics_export.processed with input as {\"config\": tc.config}","+\tresult[tc.key] == tc.want","+}","+","+test_valid_configs_have_no_errors[tc.note] if {","+\tsome tc in [","+\t\t{\"note\": \"empty\", \"config\": {}},","+\t\t{\"note\": \"grpc\", \"config\": {\"type\": \"otlp/grpc\"}},","+\t\t{\"note\": \"encryption tls\", \"config\": {\"encryption\": \"tls\"}},","+\t]","+","+\tmetrics_export.errors == set() with input as {\"config\": tc.config}","+}","+","+test_invalid_configs_report_one_error[tc.note] if {","+\tsome tc in [","+\t\t{\"note\": \"invalid type\", \"config\": {\"type\": \"unknown\"}},","+\t\t{\"note\": \"zero interval\", \"config\": {\"export_interval_ms\": 0}},","+\t\t{\"note\": \"negative interval\", \"config\": {\"export_interval_ms\": -1}},","+\t\t{\"note\": \"unsupported encryption\", \"config\": {\"encryption\": \"bad\"}},","+\t]","+","+\terrs := metrics_export.errors with input as {\"config\": tc.config}","+\tcount(errs) == 1","+}"],"additions":55,"deletions":0,"truncated":false},{"path":"v1/config/spec.go","lines":["@@ -0,0 +1,130 @@","+// Copyright 2026 The OPA Authors.  All rights reserved.","+// Use of this source code is governed by an Apache2","+// license that can be found in the LICENSE file.","+","+package config","+","+import (","+\t\"reflect\"","+\t\"slices\"","+\t\"strings\"","+\t\"sync\"","+)","+","+// ConfigSpec lists the recognized option keys of one config subtree, used to","+// warn about unrecognized options. Each Pattern segment matches a path segment;","+// \"*\" matches any segment (e.g. a map entry), and an empty Pattern matches the","+// top-level object. Subtrees no spec matches are \"open\" (any key allowed).","+type ConfigSpec struct {","+\tPattern []string `json:\"pattern\"`","+\tKeys    []string `json:\"keys\"`","+}","+","+var (","+\tspecMu          sync.RWMutex","+\tregisteredSpecs []ConfigSpec","+)","+","+// RegisterConfigSpec registers specs so ParseConfig recognizes a plugin's or","+// subsystem's options. Typically called from an init function.","+func RegisterConfigSpec(specs ...ConfigSpec) {","+\tspecMu.Lock()","+\tdefer specMu.Unlock()","+\tregisteredSpecs = append(registeredSpecs, specs...)","+}","+","+// SpecsFromStruct derives the ConfigSpecs for the config subtree decoded into T,","+// rooted at pattern. Keys are T's JSON field names, so they stay in sync with","+// the decode types. Nested structs become child specs; a map/slice contributes","+// a \"*\" segment; anonymous embedded structs are flattened (as encoding/json","+// does). Assumes the types are not self-referential.","+func SpecsFromStruct[T any](pattern ...string) []ConfigSpec {","+\tvar specs []ConfigSpec","+\tcollectStructSpec(&specs, pattern, reflect.TypeFor[T]())","+\treturn specs","+}","+","+func collectStructSpec(specs *[]ConfigSpec, pattern []string, t reflect.Type) {","+\tt = derefType(t)","+\tif t.Kind() != reflect.Struct {","+\t\treturn","+\t}","+\t*specs = append(*specs, ConfigSpec{Pattern: slices.Clone(pattern), Keys: structKeys(specs, pattern, t)})","+}","+","+// structKeys returns t's JSON keys, recursing into nested object fields and","+// flattening anonymous embedded structs.","+func structKeys(specs *[]ConfigSpec, pattern []string, t reflect.Type) []string {","+\tvar keys []string","+\tfor i := range t.NumField() {","+\t\tfield := t.Field(i)","+","+\t\tname := strings.Split(field.Tag.Get(\"json\"), \",\")[0]","+\t\tif name == \"-\" {","+\t\t\tcontinue","+\t\t}","+","+\t\t// encoding/json promotes an unnamed embedded struct's fields to this","+\t\t// level (even when the embedded type is unexported); flatten it.","+\t\tif field.Anonymous && name == \"\" && derefType(field.Type).Kind() == reflect.Struct {","+\t\t\tkeys = append(keys, structKeys(specs, pattern, derefType(field.Type))...)","+\t\t\tcontinue","+\t\t}","+","+\t\tif !field.IsExported() {","+\t\t\tcontinue","+\t\t}","+","+\t\tif name == \"\" {","+\t\t\tname = field.Name // untagged: encoding/json uses the field name","+\t\t}","+\t\tkeys = append(keys, name)","+","+\t\tcollectFieldSpec(specs, slices.Concat(pattern, []string{name}), field.Type)","+\t}","+\treturn keys","+}","+","+// collectFieldSpec recurses into a field: a struct becomes a child spec; a","+// map/slice/array of structs becomes a \"*\" wildcard level.","+func collectFieldSpec(specs *[]ConfigSpec, pattern []string, ft reflect.Type) {","+\tft = derefType(ft)","+\tswitch ft.Kind() {","+\tcase reflect.Struct:","+\t\tcollectStructSpec(specs, pattern, ft)","+\tcase reflect.Map, reflect.Slice, reflect.Array:","+\t\tif elem := derefType(ft.Elem()); elem.Kind() == reflect.Struct {","+\t\t\tcollectStructSpec(specs, slices.Concat(pattern, []string{\"*\"}), elem)","+\t\t}","+\t}","+}","+","+func derefType(t reflect.Type) reflect.Type {","+\tfor t.Kind() == reflect.Pointer {","+\t\tt = t.Elem()","+\t}","+\treturn t","+}","+","+// registeredConfigSpecs returns the registered specs in the policy's input shape.","+func registeredConfigSpecs() []any {","+\tspecMu.RLock()","+\tdefer specMu.RUnlock()","+","+\tout := make([]any, 0, len(registeredSpecs))","+\tfor _, s := range registeredSpecs {","+\t\tout = append(out, map[string]any{","+\t\t\t\"pattern\": toAnySlice(s.Pattern),","+\t\t\t\"keys\":    toAnySlice(s.Keys),","+\t\t})","+\t}","+\treturn out","+}","+","+func toAnySlice(in []string) []any {","+\tout := make([]any, len(in))","+\tfor i, s := range in {","+\t\tout[i] = s","+\t}","+\treturn out","+}"],"additions":130,"deletions":0,"truncated":false},{"path":"v1/config/spec_test.go","lines":["@@ -0,0 +1,76 @@","+// Copyright 2026 The OPA Authors.  All rights reserved.","+// Use of this source code is governed by an Apache2","+// license that can be found in the LICENSE file.","+","+package config","+","+import (","+\t\"slices\"","+\t\"strings\"","+\t\"testing\"","+)","+","+func TestSpecsFromStruct(t *testing.T) {","+\ttype leaf struct {","+\t\tBuckets []float64 `json:\"buckets,omitempty\"`","+\t}","+\ttype mid struct {","+\t\tLeaf   *leaf  `json:\"leaf,omitempty\"`","+\t\tName   string `json:\"name\"`","+\t\thidden string //nolint:unused // unexported: must be ignored","+\t\tSkip   string `json:\"-\"`","+\t}","+\ttype namedEntry struct {","+\t\tValue string `json:\"value\"`","+\t}","+\ttype embedded struct {","+\t\tShared string `json:\"shared\"`","+\t}","+\ttype root struct {","+\t\tembedded","+\t\tMid     mid                    `json:\"mid\"`","+\t\tEntries map[string]*namedEntry `json:\"entries,omitempty\"`","+\t\tList    []namedEntry           `json:\"list,omitempty\"`","+\t\tRaw     string                 `json:\"raw,omitempty\"`","+\t}","+","+\tspecs := SpecsFromStruct[root](\"top\")","+","+\t// Collect into a lookup keyed by the dotted pattern for easy assertion.","+\tgot := map[string][]string{}","+\tfor _, s := range specs {","+\t\tgot[strings.Join(s.Pattern, \".\")] = s.Keys","+\t}","+","+\twant := map[string][]string{","+\t\t\"top\":           {\"shared\", \"mid\", \"entries\", \"list\", \"raw\"}, // embedded flattened, \"-\" skipped, unexported skipped","+\t\t\"top.mid\":       {\"leaf\", \"name\"},","+\t\t\"top.mid.leaf\":  {\"buckets\"},","+\t\t\"top.entries.*\": {\"value\"},","+\t\t\"top.list.*\":    {\"value\"},","+\t}","+","+\tif len(got) != len(want) {","+\t\tt.Fatalf(\"expected %d specs, got %d: %v\", len(want), len(got), got)","+\t}","+\tfor pat, wantKeys := range want {","+\t\tgotKeys, ok := got[pat]","+\t\tif !ok {","+\t\t\tt.Errorf(\"missing spec for pattern %q\", pat)","+\t\t\tcontinue","+\t\t}","+\t\tif !equalUnordered(gotKeys, wantKeys) {","+\t\t\tt.Errorf(\"pattern %q: want keys %v, got %v\", pat, wantKeys, gotKeys)","+\t\t}","+\t}","+}","+","+func equalUnordered(a, b []string) bool {","+\tif len(a) != len(b) {","+\t\treturn false","+\t}","+\tac, bc := slices.Clone(a), slices.Clone(b)","+\tslices.Sort(ac)","+\tslices.Sort(bc)","+\treturn slices.Equal(ac, bc)","+}"],"additions":76,"deletions":0,"truncated":false},{"path":"v1/config/validate.go","lines":["@@ -7,140 +7,40 @@ package config"," import ("," \t\"context\""," \t_ \"embed\"","-\t\"errors\"","-\t\"fmt\"","-\t\"slices\"","-\t\"strings\"","-\t\"sync\""," ","+\t\"github.com/open-policy-agent/opa/internal/configpolicy\""," \t\"github.com/open-policy-agent/opa/v1/ast\"","-\t\"github.com/open-policy-agent/opa/v1/storage/inmem\"","-\t\"github.com/open-policy-agent/opa/v1/topdown\""," \t\"github.com/open-policy-agent/opa/v1/version\""," )"," ","-// coreValidationModule is the embedded policy that injects OPA's config","-// defaults and reports unrecognized options.","+// coreValidationModule injects OPA's config defaults and reports unrecognized","+// options."," //"," //go:embed validate.rego"," var coreValidationModule string"," "," const coreValidationPolicyName = \"opa/config/validate.rego\""," ","-// validationQuery yields a document with `processed`, `warnings` and `errors`.","-// The result is bound to x. (The topdown package is used directly rather than","-// the rego package to avoid a config -> rego -> bundle import cycle.)","+// validationQuery binds the policy's result document (processed/warnings/errors) to x."," const validationQuery = \"data.opa.config = x\""," ","-// validationQueryBody is parsed once; the query never changes.","-var validationQueryBody = ast.MustParseBody(validationQuery)","+var validationPolicy = configpolicy.New(coreValidationPolicyName, coreValidationModule, validationQuery)"," ","-// The policy is static, so it is compiled once and reused across all calls.","-var (","-\tcompileOnce    sync.Once","-\tcompiledPolicy *ast.Compiler","-\tcompileErr     error","-)","-","-// evaluateConfigPolicy runs the validation policy against raw. It returns the","-// config with defaults injected and any warnings; a non-empty set of policy","-// `errors` is returned as a single error.","+// evaluateConfigPolicy runs the policy against raw, returning the config with","+// defaults injected and any warnings. Specs registered via RegisterConfigSpec","+// are supplied so plugin-owned options are recognized."," func evaluateConfigPolicy(ctx context.Context, raw any, id string) (map[string]any, []string, error) {","-\tcompiler, err := compileValidationPolicy()","-\tif err != nil {","-\t\treturn nil, nil, err","-\t}","-","-\tinputValue, err := ast.InterfaceToValue(map[string]any{","+\tinput := map[string]any{"," \t\t\"config\": raw,"," \t\t\"runtime\": map[string]any{"," \t\t\t\"id\":      id,"," \t\t\t\"version\": version.Version,"," \t\t},","-\t})","-\tif err != nil {","-\t\treturn nil, nil, fmt.Errorf(\"config validation: %w\", err)","-\t}","-","-\tstore := inmem.New()","-\ttxn, err := store.NewTransaction(ctx)","-\tif err != nil {","-\t\treturn nil, nil, fmt.Errorf(\"config validation: %w\", err)","-\t}","-\tdefer store.Abort(ctx, txn)","-","-\tqrs, err := topdown.NewQuery(validationQueryBody).","-\t\tWithCompiler(compiler).","-\t\tWithStore(store).","-\t\tWithTransaction(txn).","-\t\tWithInput(ast.NewTerm(inputValue)).","-\t\tRun(ctx)","-\tif err != nil {","-\t\treturn nil, nil, fmt.Errorf(\"config validation: %w\", err)","-\t}","-\tif len(qrs) != 1 {","-\t\treturn nil, nil, errors.New(\"config validation: policy produced no result\")"],"additions":9,"deletions":53,"truncated":false}],"additions":769,"deletions":112,"truncated":true,"file_count":10},"error":null,"fetched_at":"2026-07-18T09:24:34.347431+00:00"}