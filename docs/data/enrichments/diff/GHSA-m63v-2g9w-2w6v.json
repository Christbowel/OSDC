eldPath, cap))","+\t\t\t}","+\t\t}"," \t}","-"," \treturn errs"," }"],"additions":50,"deletions":28,"truncated":false},{"path":"pkg/apis/core/v1/podspec_safety_test.go","lines":["@@ -169,6 +169,65 @@ func TestValidatePodSpecSafety_DangerousFields(t *testing.T) {"," \t}"," }"," ","+// TestValidateContainerSafety covers the standalone-container check used for","+// Environment Runtime.Container / Builder.Container. Closes GHSA-m63v-2g9w-2w6v.","+func TestValidateContainerSafety(t *testing.T) {","+\ton := true","+\toff := false","+","+\tt.Run(\"nil container is accepted\", func(t *testing.T) {","+\t\tif err := ValidateContainerSafety(\"Environment.spec.runtime.container\", nil); err != nil {","+\t\t\tt.Fatalf(\"nil container must be accepted, got: %v\", err)","+\t\t}","+\t})","+","+\tt.Run(\"nil securityContext is accepted\", func(t *testing.T) {","+\t\tc := &apiv1.Container{Name: \"py\", Image: \"fission/python-env:latest\"}","+\t\tif err := ValidateContainerSafety(\"Environment.spec.runtime.container\", c); err != nil {","+\t\t\tt.Fatalf(\"container without securityContext must be accepted, got: %v\", err)","+\t\t}","+\t})","+","+\tt.Run(\"benign securityContext is accepted\", func(t *testing.T) {","+\t\tc := &apiv1.Container{","+\t\t\tName: \"py\",","+\t\t\tSecurityContext: &apiv1.SecurityContext{","+\t\t\t\tAllowPrivilegeEscalation: &off,","+\t\t\t\tCapabilities:             &apiv1.Capabilities{Add: []apiv1.Capability{\"NET_BIND_SERVICE\"}},","+\t\t\t},","+\t\t}","+\t\tif err := ValidateContainerSafety(\"Environment.spec.runtime.container\", c); err != nil {","+\t\t\tt.Fatalf(\"benign container must be accepted, got: %v\", err)","+\t\t}","+\t})","+","+\tcases := []struct {","+\t\tname      string","+\t\tsc        *apiv1.SecurityContext","+\t\twantInErr string","+\t}{","+\t\t{\"privileged\", &apiv1.SecurityContext{Privileged: &on}, \"privileged\"},","+\t\t{\"allowPrivilegeEscalation\", &apiv1.SecurityContext{AllowPrivilegeEscalation: &on}, \"allowPrivilegeEscalation\"},","+\t\t{\"SYS_ADMIN\", &apiv1.SecurityContext{Capabilities: &apiv1.Capabilities{Add: []apiv1.Capability{\"SYS_ADMIN\"}}}, \"SYS_ADMIN\"},","+\t\t{\"NET_ADMIN\", &apiv1.SecurityContext{Capabilities: &apiv1.Capabilities{Add: []apiv1.Capability{\"NET_ADMIN\"}}}, \"NET_ADMIN\"},","+\t}","+\tfor _, tc := range cases {","+\t\tt.Run(tc.name, func(t *testing.T) {","+\t\t\tc := &apiv1.Container{Name: \"py\", SecurityContext: tc.sc}","+\t\t\terr := ValidateContainerSafety(\"Environment.spec.runtime.container\", c)","+\t\t\tif err == nil {","+\t\t\t\tt.Fatalf(\"expected rejection for %s, got nil\", tc.name)","+\t\t\t}","+\t\t\tif !strings.Contains(err.Error(), tc.wantInErr) {","+\t\t\t\tt.Fatalf(\"error must mention %q, got: %v\", tc.wantInErr, err)","+\t\t\t}","+\t\t\tif !strings.Contains(err.Error(), \"Environment.spec.runtime.container\") {","+\t\t\t\tt.Fatalf(\"error must include the field prefix, got: %v\", err)","+\t\t\t}","+\t\t})","+\t}","+}","+"," // TestValidatePodSpecSafety_BenignCapability asserts that NET_BIND_SERVICE"," // (and other non-dangerous capabilities) flow through. The denylist is"," // intentionally narrow so legitimate function workloads can still bind to"],"additions":59,"deletions":0,"truncated":false},{"path":"pkg/apis/core/v1/validation.go","lines":["@@ -662,6 +662,14 @@ func (e *Environment) Validate() error {"," \t// GHSA-wmgg-3p4h-48x7."," \terrs = errors.Join(errs, ValidatePodSpecSafety(\"Environment.spec.runtime.podspec\", e.Spec.Runtime.PodSpec))"," \terrs = errors.Join(errs, ValidatePodSpecSafety(\"Environment.spec.builder.podspec\", e.Spec.Builder.PodSpec))","+\t// The standalone Runtime.Container / Builder.Container fields are merged","+\t// into the runtime / builder pod without going through any PodSpec, so","+\t// ValidatePodSpecSafety above does not reach them. Validate their","+\t// SecurityContext directly — otherwise a tenant could set","+\t// spec.runtime.container.securityContext.privileged=true and bypass the","+\t// PodSpe