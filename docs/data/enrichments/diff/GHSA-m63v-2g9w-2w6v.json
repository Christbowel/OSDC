ies must be left untouched, got %v\", src.SecurityContext.Capabilities.Add)","+\t}","+}","+"," func Test_mergeVolumeLists(t *testing.T) {"," \ttype args struct {"," \t\tdst []apiv1.Volume"],"additions":55,"deletions":0,"truncated":false},{"path":"pkg/webhook/environment_test.go","lines":["@@ -109,6 +109,40 @@ func TestEnvironmentWebhook_Validate_RejectsDangerousPodSpec(t *testing.T) {"," \t\t\t},"," \t\t\twantInErr: \"serviceAccountName\","," \t\t},","+\t\t// Runtime.Container / Builder.Container are a separate injection path","+\t\t// from the PodSpec cases above. Closes GHSA-m63v-2g9w-2w6v.","+\t\t{","+\t\t\tname: \"runtime container privileged\",","+\t\t\tmutate: func(e *v1.Environment) {","+\t\t\t\te.Spec.Runtime.Container = &apiv1.Container{","+\t\t\t\t\tName:            \"py\",","+\t\t\t\t\tSecurityContext: &apiv1.SecurityContext{Privileged: &on},","+\t\t\t\t}","+\t\t\t},","+\t\t\twantInErr: \"privileged\",","+\t\t},","+\t\t{","+\t\t\tname: \"runtime container SYS_ADMIN capability\",","+\t\t\tmutate: func(e *v1.Environment) {","+\t\t\t\te.Spec.Runtime.Container = &apiv1.Container{","+\t\t\t\t\tName: \"py\",","+\t\t\t\t\tSecurityContext: &apiv1.SecurityContext{","+\t\t\t\t\t\tCapabilities: &apiv1.Capabilities{Add: []apiv1.Capability{\"SYS_ADMIN\"}},","+\t\t\t\t\t},","+\t\t\t\t}","+\t\t\t},","+\t\t\twantInErr: \"SYS_ADMIN\",","+\t\t},","+\t\t{","+\t\t\tname: \"builder container allowPrivilegeEscalation\",","+\t\t\tmutate: func(e *v1.Environment) {","+\t\t\t\te.Spec.Builder.Container = &apiv1.Container{","+\t\t\t\t\tName:            \"py-builder\",","+\t\t\t\t\tSecurityContext: &apiv1.SecurityContext{AllowPrivilegeEscalation: &on},","+\t\t\t\t}","+\t\t\t},","+\t\t\twantInErr: \"allowPrivilegeEscalation\",","+\t\t},"," \t}"," "," \tr := &Environment{}",""],"additions":34,"deletions":0,"truncated":false}],"additions":217,"deletions":28,"truncated":false,"file_count":6},"error":null,"fetched_at":"2026-07-01T11:08:39.416730+00:00"}