ply_PolicyCallback(t *testing.T) {","+\tmainConfig := `","+\t\tterraform {","+\t\t\trequired_providers {","+\t\t\t\ttest = {","+\t\t\t\t\tsource = \"hashicorp/test\"","+\t\t\t\t\tversion = \"1.0.0\"","+\t\t\t\t}","+\t\t\t}","+\t\t}","+","+\t\tresource \"test_instance\" \"foo\" {","+\t\t\tami = \"bar\"","+\t\t}","+","+\t\tresource \"test_instance\" \"baz\" {","+\t\t\tami = \"qux\"","+\t\t\tdepends_on = [test_instance.foo]","+\t\t}","+","+\t\tresource \"test_instance\" \"boop\" {","+\t\t\tami = \"booper\"","+\t\t\tdepends_on = [test_instance.baz]","+\t\t}","+\t`","+","+\tpolicyConfig := `","+\t\tresource_policy \"test_instance\" \"policy_name\" {","+\t\t\tenforce {","+\t\t\t\tcondition = core::getresources(\"some_resource_type\", {})[0].value != null","+\t\t\t}","+\t\t}","+\t`","+","+\tmod := testModuleInline(t, map[string]string{","+\t\t\"main.tf\":           mainConfig,","+\t\t\"main.tfpolicy.hcl\": policyConfig,","+\t})","+","+\tproviderAddr := addrs.NewDefaultProvider(\"test\")","+\tprovider := testProvider(\"test\")","+\tprovider.PlanResourceChangeFn = func(req providers.PlanResourceChangeRequest) providers.PlanResourceChangeResponse {","+\t\treturn providers.PlanResourceChangeResponse{","+\t\t\tPlannedState: req.ProposedNewState,","+\t\t}","+\t}","+\t// Apply echoes the planned config back as the new state, so the applied","+\t// instances carry concrete ami values in state for the callback to read.","+\tprovider.ApplyResourceChangeFn = func(req providers.ApplyResourceChangeRequest) (resp providers.ApplyResourceChangeResponse) {","+\t\tresp.NewState = req.PlannedState","+\t\treturn resp","+\t}","+","+\ttype callbackResult struct {","+\t\tmatchAllResults  []cty.Value","+\t\tfilteredResults  []cty.Value","+\t\tnoMatchCount     int","+\t\tunknownTypeCount int","+\t}","+","+\t// The plan policy client allows everything; the callback assertions run","+\t// during apply only.","+\tplanPolicyClient := policy.NewTestMockClient(t)","+\tplanPolicyClient.EvaluateFn = func(ctx context.Context, req policy.EvaluationRequest[*proto.PolicyEvaluateResourceRequest_ResourceMetadata]) policy.EvaluationResponse {","+\t\treturn policy.EvaluationResponse{Overall: policy.AllowResult}","+\t}","+","+\tvar mu sync.Mutex","+\tresults := make(map[string]callbackResult)","+","+\tapplyPolicyClient := policy.NewTestMockClient(t)","+\tapplyPolicyClient.EvaluateFn = func(ctx context.Context, req policy.EvaluationRequest[*proto.PolicyEvaluateResourceRequest_ResourceMetadata]) policy.EvaluationResponse {","+\t\tcr := callbackResult{}","+","+\t\tif req.Callbacks.GetResources == nil {","+\t\t\tt.Errorf(\"GetResources callback was nil\")","+\t\t\treturn policy.EvaluationResponse{Overall: policy.AllowResult}","+\t\t}","+","+\t\t// 1. Match all test_instance resources with null attrs (no filter).","+\t\tall, _, err := req.Callbacks.GetResources(t.Context(), \"test_instance\", cty.NullVal(cty.DynamicPseudoType))","+\t\tif err != nil {","+\t\t\tt.Errorf(\"GetResources(test_instance, null): %v\", err)","+\t\t} else {","+\t\t\tcr.matchAllResults = all","+\t\t}","+","+\t\t// 2. Match resources with ami=\"bar\" filter.","+\t\tfiltered, _, err := req.Callbacks.GetResources(t.Context(), \"test_instance\", cty.ObjectVal(map[string]cty.Value{","+\t\t\t\"ami\": cty.StringVal(\"bar\"),","+\t\t}))","+\t\tif err != nil {","+\t\t\tt.Errorf(\"GetResources(test_instance, ami=bar): %v\", err)","+\t\t} else {","+\t\t\tcr.filteredResults = filtered","+\t\t}","+","+\t\t// 3. Match with an attribute filter that will never match.","+\t\tnoMatch, _, err := req.Callbacks.GetResources(t.Context(), \"test_instance\", cty.ObjectVal(map[string]cty.Value{","+\t\t\t\"ami\": cty.StringVal(\"nonexistent\"),","+\t\t}))","+\t\tif err != nil {","+\t\t\tt.Errorf(\"GetResources(test_instance, ami=nonexistent): %v\", err)","+\t\t} else {","+\t\t\tcr.noMatchCount = len(noMatch)","+\t\t}","+","+\t\t// 4. Query for a resource type that doesn't exist in the config.","+\t\tunknown, _, err := req.Callbacks.GetResources(t.Context(), \"nonexistent_resource\", cty.NullVal(cty.DynamicPseudoType))","+\t\tif err != nil {","+\t\t\tt.Errorf(\"GetResources(nonexistent_resource): %v\", err)","+\t\t} else {","+\t\t\tcr.unknownTypeCount = len(unknown)","+\t\t}","+","+\t\tami := req.Attrs.Raw.GetAttr(\"ami\").AsString()","+\t\tmu.Lock()","+\t\tresults[ami] = cr","+\t\tmu.Unlock()","+","+\t\treturn policy.EvaluationResponse{Overall: policy.AllowResult}","+\t}","+","+\tctx, diags := NewContext(&ContextOpts{","+\t\tProviders: map[addrs.Provider]providers.Factory{","+\t\t\tproviderAddr: testProviderFuncFixed(provider),","+\t\t},","+\t})","+\ttfdiags.AssertNoDiagnostics(t, diags)","+","+\tplan, diags := ctx.Plan(mod, states.NewState(), &PlanOpts{","+\t\tMode:         plans.NormalMode,","+\t\tSetVariables: testInputValuesUnset(mod.Module.Variables),","+\t\tPolicyClient: planPolicyClient,","+\t})","+\ttfdiags.AssertNoDiagnostics(t, diags)","+","+\t_, diags = ctx.Apply(plan, mod, &ApplyOpts{","+\t\tPolicyClient: applyPolicyClient,","+\t})","+\ttfdiags.AssertNoDiagnostics(t, diags)","+","+\t// We expect exactly 3 evaluations (one per test_instance resource) during","+\t// apply.","+\tif len(results) != 3 {","+\t\tt.Fatalf(\"expected 3 policy evaluations during apply, got %d\", len(results))","+\t}","+","+\tfor ami, cr := range results {","+\t\t// match-all reads every test_instance from state: all 3 instances.","+\t\tif len(cr.matchAllResults) != 3 {","+\t\t\tt.Errorf(\"evaluation[%s]: expected 3 results for matchAll from state, got %d\", ami, len(cr.matchAllResults))","+\t\t}","+\t\t// ami=\"bar\" matches exactly the one foo instance.","+\t\tif len(cr.filteredResults) != 1 {","+\t\t\tt.Errorf(\"evaluation[%s]: expected 1 result for ami=bar filter, got %d\", ami, len(cr.filteredResults))","+\t\t}","+\t\t// ami=\"nonexistent\" matches nothing.","+\t\tif cr.noMatchCount != 0 {","+\t\t\tt.Errorf(\"evaluation[%s]: expected 0 results for ami=nonexistent filter, got %d\", ami, cr.noMatchCount)","+\t\t}","+\t\t// An unknown resource type returns nothing.","+\t\tif cr.unknownTypeCount != 0 {","+\t\t\tt.Errorf(\"evaluation[%s]: expected 0 results for nonexistent_resource, got %d\", ami, cr.unknownTypeCount)","+\t\t}","+\t}","+}","+","+// TestContext2Apply_PolicySpanParentage verifies the OpenTelemetry wiring that","+// makes per-resource policy spans children of the enclosing \"terraform apply\"","+// command span.","+func TestContext2Apply_PolicySpanParentage(t *testing.T) {","+\t// Collect spans into an in-memory exporter. The tracer provider is a","+\t// global, so this test must not run in parallel. We restore the previous","+\t// provider (rather than setting nil) so later tests in this package that","+\t// emit spans -- e.g. the policy-phase span -- don't hit a nil provider.","+\tprevProvider := otel.GetTracerProvider()","+\texp := tracetest.NewInMemoryExporter()","+\tprovider := sdktrace.NewTracerProvider(sdktrace.WithSpanProcessor(sdktrace.NewSimpleSpanProcessor(exp)))","+\totel.SetTracerProvider(provider)","+\tt.Cleanup(func() {","+\t\tprovider.Shutdown(context.Background())","+\t\totel.SetTracerProvider(prevProvider)","+\t})","+","+\tmainConfig := `","+\t\tterraform {","+\t\t\trequired_providers {","+\t\t\t\ttest = {","+\t\t\t\t\tsource = \"hashicorp/test\"","+\t\t\t\t\tversion = \"1.0.0\"","+\t\t\t\t}","+\t\t\t}","+\t\t}","+","+\t\tresource \"test_instance\" \"foo\" {","+\t\t\tami = \"bar\"","+\t\t}","+\t`","+\tpolicyConfig := `","+\t\tresource_policy \"test_instance\" \"policy_name\" {","+\t\t\tenforce {","+\t\t\t\tcondition = attrs.ami != \"\"","+\t\t\t}","+\t\t}","+\t`","+\tmod := testModuleInline(t, map[string]string{","+\t\t\"main.tf\":           mainConfig,","+\t\t\"main.tfpolicy.hcl\": policyConfig,","+\t})","+","+\tproviderAddr := addrs.NewDefaultProvider(\"test\")","+\tprov := testProvider(\"test\")","+\tprov.PlanResourceChangeFn = func(req providers.PlanResourceChangeRequest) providers.PlanResourceChangeResponse {","+\t\treturn providers.PlanResourceChangeResponse{PlannedState: req.ProposedNewState}","+\t}","+\tprov.ApplyResourceChangeFn = func(req providers.ApplyResourceChangeRequest) (resp providers.ApplyResourceChangeResponse) {","+\t\tresp.NewState = req.PlannedState","+\t\treturn resp","+\t}","+","+\t// Plan with an allow-all client (no spans needed during plan here).","+\tplanClient := policy.NewTestMockClient(t)","+\tplanClient.EvaluateFn = func(ctx context.Context, req policy.EvaluationRequest[*proto.PolicyEvaluateResourceRequest_ResourceMetadata]) policy.EvaluationResponse {","+\t\treturn policy.EvaluationResponse{Overall: policy.AllowResult}","+\t}","+","+\t// The apply client starts a span named like the real client's, using the","+\t// context the engine passes in. That context is ctx.StopCtx() (the run","+\t// context), which acquireRun parents on the caller context we set below.","+\tvar evaluateSpanContext trace.SpanContext","+\tapplyClient := policy.NewTestMockClient(t)","+\tapplyClient.EvaluateFn = func(ctx context.Context, req policy.EvaluationRequest[*proto.PolicyEvaluateResourceRequest_ResourceMetadata]) policy.EvaluationResponse {","+\t\t_, span := otel.Tracer(\"test\").Start(ctx, \"policy.client.evaluate_resource\")","+\t\tevaluateSpanContext = span.SpanContext()","+\t\tspan.End()","+\t\treturn policy.EvaluationResponse{Overall: policy.AllowResult}","+\t}","+","+\ttfCtx, diags := NewContext(&ContextOpts{","+\t\tProviders: map[addrs.Provider]providers.Factory{","+\t\t\tproviderAddr: testProviderFuncFixed(prov),","+\t\t},","+\t})","+\ttfdiags.AssertNoDiagnostics(t, diags)","+","+\tplan, diags := tfCtx.Plan(mod, states.NewState(), &PlanOpts{","+\t\tMode:         plans.NormalMode,","+\t\tSetVariables: testInputValuesUnset(mod.Module.Variables),","+\t\tPolicyClient: planClient,","+\t})","+\ttfdiags.AssertNoDiagnostics(t, diags)","+","+\t// Open the command-level span, exactly as command.ApplyCommand does via","+\t// Meta.StartCommandSpan, and install it as the caller context so the apply","+\t// walk's run context is parented under it.","+\tcommandCtx, commandSpan := otel.Tracer(\"test\").Start(context.Background(), \"terraform apply\")","+\tcommandSpanContext := commandSpan.SpanContext()","+\ttfCtx.SetTracingContext(commandCtx)","+","+\t_, diags = tfCtx.Apply(plan, mod, &ApplyOpts{","+\t\tPolicyClient: applyClient,","+\t})","+\ttfdiags.AssertNoDiagnostics(t, diags)","+\tcommandSpan.End()","+","+\tif !evaluateSpanContext.IsValid() {","+\t\tt.Fatal(\"policy evaluate span was never started during apply\")","+\t}","+","+\t// The evaluate span must belong to the same trace as the command span...","+\tif evaluateSpanContext.TraceID() != commandSpanContext.TraceID() {","+\t\tt.Errorf(\"policy evaluate span is in a different trace than the terraform apply span\\n  apply trace:    %s\\n  evaluate trace: %s\",","+\t\t\tcommandSpanContext.TraceID(), evaluateSpanContext.TraceID())","+\t}","+","+\t// ...and it must be a descendant of the command span. We find the recorded","+\t// evaluate span in the exporter and walk its parent chain up to the command","+\t// span.","+\tspans := exp.GetSpans()","+\tbyID := make(map[trace.SpanID]tracetest.SpanStub, len(spans))","+\tfor _, s := range spans {"],"additions":288,"deletions":0,"truncated":false}],"additions":491,"deletions":22,"truncated":true,"file_count":13},"error":null,"fetched_at":"2026-06-24T10:41:45.196886+00:00"}