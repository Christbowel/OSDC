{"id":"01debdf37c3ef3690dbe06988c71e63408de7c29","axis":"silent","repo":"WordPress/wordpress-develop","sha":"01debdf37c3ef3690dbe06988c71e63408de7c29","parsed":{"files":[{"path":"src/wp-includes/abilities-api.php","lines":["@@ -396,33 +396,203 @@ function wp_get_ability( string $name ): ?WP_Ability {"," }"," "," /**","- * Retrieves all registered abilities.","+ * Retrieves registered abilities, optionally filtered by the given arguments.","  *","- * Returns an array of all ability instances currently registered in the system.","- * Use this for discovery, debugging, or building administrative interfaces.","+ * When called without arguments, returns all registered abilities. When called","+ * with an $args array, returns only abilities that match every specified condition.","  *","- * Example:","+ * Filtering pipeline (executed in order):","+ *","+ * 1. Declarative filters (`category`, `namespace`, `meta`) — per-item, AND logic between","+ *    arg types, OR logic within multi-value `category` arrays.","+ * 2. `item_include_callback` — per-item, caller-scoped. Return true to include, false to exclude.","+ * 3. `wp_get_abilities_item_include` filter — per-item, ecosystem-scoped. Plugins can enforce","+ *    universal inclusion rules regardless of what the caller passed.","+ * 4. `result_callback` — on the full matched array, caller-scoped. Sort, slice, or reshape.","+ * 5. `wp_get_abilities_result` filter — on the full array, ecosystem-scoped.","+ *","+ * Steps 1–3 run inside a single loop over the registry — no extra iteration.","  *","- *     // Prints information about all available abilities.","+ * Examples:","+ *","+ *     // All abilities (unchanged behaviour).","  *     $abilities = wp_get_abilities();","- *     foreach ( $abilities as $ability ) {","- *         echo $ability->get_label() . ': ' . $ability->get_description() . \"\\n\";","- *     }","+ *","+ *     // Filter by category.","+ *     $abilities = wp_get_abilities( array( 'category' => 'content' ) );","+ *","+ *     // Filter by multiple categories (OR logic).","+ *     $abilities = wp_get_abilities( array( 'category' => array( 'content', 'settings' ) ) );","+ *","+ *     // Filter by namespace.","+ *     $abilities = wp_get_abilities( array( 'namespace' => 'woocommerce' ) );","+ *","+ *     // Filter by meta.","+ *     $abilities = wp_get_abilities( array( 'meta' => array( 'show_in_rest' => true ) ) );","+ *","+ *     // Combine filters (AND logic between arg types).","+ *     $abilities = wp_get_abilities( array(","+ *         'category'  => 'content',","+ *         'namespace' => 'core',","+ *         'meta'      => array( 'show_in_rest' => true ),","+ *     ) );","+ *","+ *     // Caller-scoped per-item callback.","+ *     $abilities = wp_get_abilities( array(","+ *         'item_include_callback' => function ( WP_Ability $ability ) {","+ *             return current_user_can( 'manage_options' );","+ *         },","+ *     ) );","+ *","+ *     // Caller-scoped result callback (sort + paginate).","+ *     $abilities = wp_get_abilities( array(","+ *         'result_callback' => function ( array $abilities ) {","+ *             usort( $abilities, fn( $a, $b ) => strcasecmp( $a->get_label(), $b->get_label() ) );","+ *             return array_slice( $abilities, 0, 10 );","+ *         },","+ *     ) );","+ *","+ * The pipeline always runs, even when called with no arguments. This ensures that the","+ * `wp_get_abilities_item_include` and `wp_get_abilities_result` filters always fire,","+ * giving plugins a reliable place to enforce universal inclusion or shaping rules.","+ * For raw, unfiltered registry data that bypasses the filter pipeline entirely, use","+ * {@see WP_Abilities_Registry::get_all_registered()} directly.","  *","  * @since 6.9.0","+ * @since 7.1.0 Added the `$args` parameter for filtering support.","  *","  * @see WP_Abilities_Registry::get_all_registered()","  *","- * @return WP_Ability[] An array of registered WP_Ability instances. Returns an empty","- *                     array if no abilities are registered or if the registry is unavailable.","+ * @param array $args {","+ *     Optional. Arguments to filter the returned abilities. Default empty array (returns all).","+ *","+ *     @type string|string[] $category              Filter by category slug. A single string or an array of","+ *                                                  slugs — abilities matching any of the given slugs are","+ *                                                  included (OR logic within this arg type).","+ *     @type string          $namespace             Filter by ability namespace prefix. Pass the namespace","+ *                                                  without a trailing slash, e.g. `'woocommerce'` matches","+ *                                                  `'woocommerce/create-order'`.","+ *     @type array           $meta                  Filter by meta key/value pairs. All conditions must","+ *                                                  match (AND logic). Supports nested arrays for structured","+ *                                                  meta, e.g. `array( 'mcp' => array( 'public' => true ) )`.","+ *     @type callable        $item_include_callback Optional. A callback invoked per ability after declarative","+ *                                                  filters. Receives a WP_Ability instance, returns bool.","+ *                                                  Return true to include, false to exclude.","+ *     @type callable        $result_callback       Optional. A callback invoked once on the full matched","+ *                                                  array. Receives WP_Ability[], must return WP_Ability[].","+ *                                                  Use for sorting, slicing, or reshaping the result.","+ * }","+ * @return WP_Ability[] An array of registered WP_Ability instances matching the given args,","+ *                      keyed by ability name. Returns an empty array if no abilities are","+ *                      registered, the registry is unavailable, or no abilities match the","+ *                      given args.","  */","-function wp_get_abilities(): array {","+function wp_get_abilities( array $args = array() ): array {"," \t$registry = WP_Abilities_Registry::get_instance();"," \tif ( null === $registry ) {"," \t\treturn array();"," \t}"," ","-\treturn $registry->get_all_registered();","+\t$abilities = $registry->get_all_registered();","+","+\t$category              = isset( $args['category'] ) ? (array) $args['category'] : array();","+\t$namespace             = isset( $args['namespace'] ) && is_string( $args['namespace'] ) ? rtrim( $args['namespace'], '/' ) . '/' : '';","+\t$meta                  = isset( $args['meta'] ) && is_array( $args['meta'] ) ? $args['meta'] : array();","+\t$item_include_callback = isset( $args['item_include_callback'] ) && is_callable( $args['item_include_callback'] ) ? $args['item_include_callback'] : null;","+\t$result_callback       = isset( $args['result_callback'] ) && is_callable( $args['result_callback'] ) ? $args['result_callback'] : null;","+","+\t$matched = array();","+","+\tforeach ( $abilities as $name => $ability ) {","+\t\t// Step 1a: Filter by category (OR logic within the arg).","+\t\tif ( ! empty( $category ) && ! in_array( $ability->get_category(), $category, true ) ) {","+\t\t\tcontinue;","+\t\t}","+","+\t\t// Step 1b: Filter by namespace prefix.","+\t\tif ( '' !== $namespace && ! str_starts_with( $ability->get_name(), $namespace ) ) {","+\t\t\tcontinue;","+\t\t}","+","+\t\t// Step 1c: Filter by meta key/value pairs (AND logic, supports nested arrays).","+\t\tif ( ! empty( $meta ) && ! _wp_get_abilities_match_meta( $ability->get_meta(), $meta ) ) {","+\t\t\tcontinue;","+\t\t}","+","+\t\t// Step 2: Caller-scoped per-item callback.","+\t\t$include = true;","+\t\tif ( null !== $item_include_callback ) {","+\t\t\t$include = (bool) call_user_func( $item_include_callback, $ability );","+\t\t}","+","+\t\t/**","+\t\t * Filters whether an individual ability should be included in the result set.","+\t\t *","+\t\t * Fires after the declarative filters and the caller-scoped item_include_callback.","+\t\t * Plugins can use this to enforce universal inclusion rules regardless of","+\t\t * what the caller passed in $args.","+\t\t *","+\t\t * @since 7.1.0","+\t\t *","+\t\t * @param bool       $include Whether to include the ability. Default true (after declarative filters pass).","+\t\t * @param WP_Ability $ability The ability instance being evaluated.","+\t\t * @param array      $args    The full $args array passed to wp_get_abilities().","+\t\t */","+\t\t$include = (bool) apply_filters( 'wp_get_abilities_item_include', $include, $ability, $args );","+","+\t\tif ( $include ) {","+\t\t\t$matched[ $name ] = $ability;","+\t\t}","+\t}","+","+\t// Step 4: Caller-scoped result callback.","+\tif ( null !== $result_callback ) {","+\t\t$matched = (array) call_user_func( $result_callback, $matched );","+\t}","+","+\t/**","+\t * Filters the full list of matched abilities after all per-item filtering is complete.","+\t *","+\t * Fires after the caller-scoped result_callback. Plugins can use this to sort,","+\t * paginate, or reshape the final result set universally.","+\t *","+\t * @since 7.1.0","+\t *","+\t * @param WP_Ability[] $matched The matched abilities after all filtering.","+\t * @param array        $args    The full $args array passed to wp_get_abilities().","+\t */","+\treturn (array) apply_filters( 'wp_get_abilities_result', $matched, $args );","+}","+","+/**","+ * Checks whether an ability's meta array matches a set of required key/value conditions.","+ *","+ * All conditions must match (AND logic). Supports nested arrays for structured meta,","+ * e.g. `array( 'mcp' => array( 'public' => true ) )`.","+ *","+ * @since 7.1.0","+ * @access private","+ *","+ * @param array $meta       The ability's meta array.","+ * @param array $conditions The required key/value conditions to match against.","+ * @return bool True if all conditions match, false otherwise.","+ */","+function _wp_get_abilities_match_meta( array $meta, array $conditions ): bool {","+\tforeach ( $conditions as $key => $value ) {","+\t\tif ( ! array_key_exists( $key, $meta ) ) {","+\t\t\treturn false;","+\t\t}","+","+\t\tif ( is_array( $value ) ) {","+\t\t\tif ( ! is_array( $meta[ $key ] ) || ! _wp_get_abilities_match_meta( $meta[ $key ], $value ) ) {","+\t\t\t\treturn false;","+\t\t\t}","+\t\t} elseif ( $meta[ $key ] !== $value ) {","+\t\t\treturn false;","+\t\t}","+\t}","+","+\treturn true;"," }"," "," /**"],"additions":182,"deletions":12,"truncated":false},{"path":"src/wp-includes/rest-api/endpoints/class-wp-rest-abilities-v1-list-controller.php","lines":["@@ -86,26 +86,20 @@ public function register_routes(): void {"," \t * @return WP_REST_Response Response object on success."," \t */"," \tpublic function get_items( $request ) {","-\t\t$abilities = array_filter(","-\t\t\twp_get_abilities(),","-\t\t\tstatic function ( $ability ) {","-\t\t\t\treturn $ability->get_meta_item( 'show_in_rest' );","-\t\t\t}","+\t\t$query_args = array(","+\t\t\t'meta' => array( 'show_in_rest' => true ),"," \t\t);"," ","-\t\t// Filter by ability category if specified.","-\t\t$category = $request['category'];","-\t\tif ( ! empty( $category ) ) {","-\t\t\t$abilities = array_filter(","-\t\t\t\t$abilities,","-\t\t\t\tstatic function ( $ability ) use ( $category ) {","-\t\t\t\t\treturn $ability->get_category() === $category;","-\t\t\t\t}","-\t\t\t);","-\t\t\t// Reset array keys after filtering.","-\t\t\t$abilities = array_values( $abilities );","+\t\tif ( ! empty( $request['category'] ) ) {","+\t\t\t$query_args['category'] = $request['category'];","+\t\t}","+","+\t\tif ( ! empty( $request['namespace'] ) ) {","+\t\t\t$query_args['namespace'] = $request['namespace'];"," \t\t}"," ","+\t\t$abilities = wp_get_abilities( $query_args );","+"," \t\t$page     = $request['page'];"," \t\t$per_page = $request['per_page'];"," \t\t$offset   = ( $page - 1 ) * $per_page;","@@ -418,26 +412,32 @@ public function get_item_schema(): array {"," \t */"," \tpublic function get_collection_params(): array {"," \t\treturn array(","-\t\t\t'context'  => $this->get_context_param( array( 'default' => 'view' ) ),","-\t\t\t'page'     => array(","+\t\t\t'context'   => $this->get_context_param( array( 'default' => 'view' ) ),","+\t\t\t'page'      => array("," \t\t\t\t'description' => __( 'Current page of the collection.' ),"," \t\t\t\t'type'        => 'integer',"," \t\t\t\t'default'     => 1,"," \t\t\t\t'minimum'     => 1,"," \t\t\t),","-\t\t\t'per_page' => array(","+\t\t\t'per_page'  => array("," \t\t\t\t'description' => __( 'Maximum number of items to be returned in result set.' ),"," \t\t\t\t'type'        => 'integer',"," \t\t\t\t'default'     => 50,"," \t\t\t\t'minimum'     => 1,"," \t\t\t\t'maximum'     => 100,"," \t\t\t),","-\t\t\t'category' => array(","+\t\t\t'category'  => array("," \t\t\t\t'description'       => __( 'Limit results to abilities in specific ability category.' ),"," \t\t\t\t'type'              => 'string',"," \t\t\t\t'sanitize_callback' => 'sanitize_key',"," \t\t\t\t'validate_callback' => 'rest_validate_request_arg',"," \t\t\t),","+\t\t\t'namespace' => array(","+\t\t\t\t'description'       => __( 'Limit results to abilities in a specific namespace.' ),","+\t\t\t\t'type'              => 'string',","+\t\t\t\t'sanitize_callback' => 'sanitize_key',","+\t\t\t\t'validate_callback' => 'rest_validate_request_arg',","+\t\t\t),"," \t\t);"," \t}"," }"],"additions":20,"deletions":20,"truncated":false},{"path":"tests/phpunit/tests/abilities-api/wpGetAbilities.php","lines":["@@ -0,0 +1,787 @@","+<?php declare( strict_types=1 );","+","+/**","+ * Tests for the filtering support added to wp_get_abilities().","+ *","+ * @covers wp_get_abilities","+ *","+ * @group abilities-api","+ */","+class Tests_Abilities_API_WpGetAbilities extends WP_UnitTestCase {","+","+\t/**","+\t * Test ability names registered during a test, used for teardown cleanup.","+\t *","+\t * @var string[]","+\t */","+\tprivate $registered_ability_names = array();","+","+\t/**","+\t * Set up before each test.","+\t */","+\tpublic function set_up(): void {","+\t\tglobal $wp_current_filter;","+","+\t\tparent::set_up();","+","+\t\t$wp_current_filter[] = 'wp_abilities_api_categories_init';","+\t\twp_register_ability_category(","+\t\t\t'math',","+\t\t\tarray(","+\t\t\t\t'label'       => 'Math',","+\t\t\t\t'description' => 'Mathematical operations.',","+\t\t\t)","+\t\t);","+\t\twp_register_ability_category(","+\t\t\t'text',","+\t\t\tarray(","+\t\t\t\t'label'       => 'Text',","+\t\t\t\t'description' => 'Text operations.',","+\t\t\t)","+\t\t);","+\t}","+","+\t/**","+\t * Tear down after each test.","+\t */","+\tpublic function tear_down(): void {","+\t\tforeach ( $this->registered_ability_names as $name ) {","+\t\t\twp_unregister_ability( $name );","+\t\t}","+","+\t\t$this->registered_ability_names = array();","+","+\t\twp_unregister_ability_category( 'math' );","+\t\twp_unregister_ability_category( 'text' );","+","+\t\tparent::tear_down();","+\t}","+","+\t/**","+\t * Simulates the `wp_abilities_api_init` action.","+\t */","+\tprivate function simulate_wp_abilities_init(): void {","+\t\tglobal $wp_current_filter;","+","+\t\t$wp_current_filter[] = 'wp_abilities_api_init';","+\t}","+","+\t/**","+\t * Registers a test ability and tracks its name for teardown.","+\t *","+\t * @param string  $name      The ability name.","+\t * @param array   $overrides Optional args to merge into the defaults.","+\t * @return WP_Ability|null The registered ability, or null on failure.","+\t */","+\tprivate function register_test_ability( string $name, array $overrides = array() ): ?WP_Ability {","+\t\t$args = array_merge(","+\t\t\tarray(","+\t\t\t\t'label'               => 'Test Ability',","+\t\t\t\t'description'         => 'A test ability.',","+\t\t\t\t'category'            => 'math',","+\t\t\t\t'input_schema'        => array(","+\t\t\t\t\t'type'       => 'object',","+\t\t\t\t\t'properties' => array(),","+\t\t\t\t),","+\t\t\t\t'output_schema'       => array(","+\t\t\t\t\t'type'       => 'object',","+\t\t\t\t\t'properties' => array(),","+\t\t\t\t),","+\t\t\t\t'execute_callback'    => static function (): array {","+\t\t\t\t\treturn array();","+\t\t\t\t},","+\t\t\t\t'permission_callback' => static function (): bool {","+\t\t\t\t\treturn true;","+\t\t\t\t},","+\t\t\t\t'meta'                => array(),","+\t\t\t),","+\t\t\t$overrides","+\t\t);","+","+\t\t$ability = wp_register_ability( $name, $args );","+","+\t\tif ( null !== $ability ) {","+\t\t\t$this->registered_ability_names[] = $name;","+\t\t}","+","+\t\treturn $ability;","+\t}","+","+\t// -------------------------------------------------------------------------","+\t// Category filter","+\t// -------------------------------------------------------------------------","+","+\t/**","+\t * Tests filtering by a single category string.","+\t *","+\t * @ticket 64990","+\t */","+\tpublic function test_filter_by_single_category(): void {","+\t\t$this->simulate_wp_abilities_init();","+","+\t\t$this->register_test_ability( 'test/math-add', array( 'category' => 'math' ) );","+\t\t$this->register_test_ability( 'test/text-upper', array( 'category' => 'text' ) );","+","+\t\t$result = wp_get_abilities( array( 'category' => 'math' ) );","+\t\t$names  = array_map(","+\t\t\tstatic function ( WP_Ability $a ) {","+\t\t\t\treturn $a->get_name();","+\t\t\t},","+\t\t\t$result","+\t\t);","+","+\t\t$this->assertContains( 'test/math-add', $names );","+\t\t$this->assertNotContains( 'test/text-upper', $names );","+\t}","+","+\t/**","+\t * Tests that passing an array of categories uses OR logic.","+\t *","+\t * @ticket 64990","+\t */","+\tpublic function test_filter_by_category_array_uses_or_logic(): void {","+\t\t$this->simulate_wp_abilities_init();","+","+\t\t$this->register_test_ability( 'test/math-add', array( 'category' => 'math' ) );","+\t\t$this->register_test_ability( 'test/text-upper', array( 'category' => 'text' ) );","+","+\t\t$result = wp_get_abilities( array( 'category' => array( 'math', 'text' ) ) );","+\t\t$names  = array_map(","+\t\t\tstatic function ( WP_Ability $a ) {","+\t\t\t\treturn $a->get_name();","+\t\t\t},","+\t\t\t$result","+\t\t);","+","+\t\t$this->assertContains( 'test/math-add', $names );","+\t\t$this->assertContains( 'test/text-upper', $names );","+\t}","+","+\t/**","+\t * Tests that filtering by a non-existent category returns an empty array.","+\t *","+\t * @ticket 64990","+\t */","+\tpublic function test_filter_by_nonexistent_category_returns_empty(): void {","+\t\t$this->simulate_wp_abilities_init();","+","+\t\t$this->register_test_ability( 'test/math-add', array( 'category' => 'math' ) );","+","+\t\t$result = wp_get_abilities( array( 'category' => 'nonexistent' ) );","+","+\t\t$this->assertSame( array(), $result );","+\t}","+","+\t// -------------------------------------------------------------------------","+\t// Namespace filter","+\t// -------------------------------------------------------------------------","+","+\t/**","+\t * Tests filtering by namespace prefix.","+\t *","+\t * @ticket 64990","+\t */","+\tpublic function test_filter_by_namespace(): void {","+\t\t$this->simulate_wp_abilities_init();","+","+\t\t$this->register_test_ability( 'test/ability-one' );","+\t\t$this->register_test_ability( 'other/ability-two', array( 'category' => 'text' ) );","+","+\t\t$result = wp_get_abilities( array( 'namespace' => 'test' ) );","+\t\t$names  = array_map(","+\t\t\tstatic function ( WP_Ability $a ) {","+\t\t\t\treturn $a->get_name();","+\t\t\t},","+\t\t\t$result","+\t\t);","+","+\t\t$this->assertContains( 'test/ability-one', $names );","+\t\t$this->assertNotContains( 'other/ability-two', $names );","+\t}","+","+\t/**","+\t * Tests that a namespace with a trailing slash produces the same result as one without.","+\t *","+\t * @ticket 64990","+\t 