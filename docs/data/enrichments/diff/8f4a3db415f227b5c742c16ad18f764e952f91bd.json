ubsequent call should return the cached value, not call the factory again.","+\t\tconst result2 = await pipeline.getActions();","+\t\tassert.equal(callCount, 1, 'factory should not be called again while cached');","+\t\tassert.equal(result2, firstActions);","+","+\t\t// After clearing, the next call should invoke the factory again.","+\t\tpipeline.clearActions();","+\t\tconst result3 = await pipeline.getActions();","+\t\tassert.equal(callCount, 2, 'factory should be called again after clearActions()');","+\t\tassert.equal(result3, secondActions);","+\t});","+","+\tit('getActions() returns NOOP when no actions factory is configured', async () => {","+\t\tconst pipeline = createBasicPipeline();","+\t\tconst result = await pipeline.getActions();","+\t\tassert.ok(result, 'should return a non-undefined value');","+\t\tassert.deepEqual(result.server, {}, 'should return noop actions with empty server');","+\t});","+});"],"additions":43,"deletions":0,"truncated":false},{"path":"packages/astro/test/units/test-utils.ts","lines":["@@ -121,7 +121,7 @@ function buffersToString(buffers: Buffer[]): string {","  * methods with minimal stubs so Pipeline can be instantiated without","  * a real build or dev server.","  */","-class TestPipeline extends Pipeline {","+export class TestPipeline extends Pipeline {"," \theadElements(): HeadElements {"," \t\treturn { scripts: new Set(), styles: new Set(), links: new Set() } as HeadElements;"," \t}","@@ -145,6 +145,10 @@ class TestPipeline extends Pipeline {"," \toverride async getMiddleware(): Promise<MiddlewareHandler> {"," \t\treturn NOOP_MIDDLEWARE_FN;"," \t}","+","+\tclearActions(): void {","+\t\tthis.resolvedActions = undefined;","+\t}"," }"," "," /**","@@ -169,7 +173,7 @@ export function createBasicPipeline("," \t\tsite?: string;"," \t\tlogging?: AstroLogger;"," \t} = {},","-): Pipeline {","+): TestPipeline {"," \tconst mode = options.mode ?? 'development';"," \treturn new TestPipeline("," \t\toptions.logger ?? defaultLogger,",""],"ad