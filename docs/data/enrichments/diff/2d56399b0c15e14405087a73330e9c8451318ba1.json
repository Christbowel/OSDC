cp-request","+ *   - on-frontend-http-request","+ *   - on-backend-tcp-request","+ *   - on-backend-http-request","+ *   - on-server-session -> on-server-session-start","+ *   - on-tcp-response","+ *   - on-http-response","+ *","+ * FLT_OTEL_EVENT_NONE is used as an index for 'otel-scope' sections that do not","+ * have an event defined.  The 'otel-scope' sections thus defined can be used","+ * within the 'otel-group' section.","+ *","+ * A description of the macro arguments can be found in the structure","+ * flt_otel_event_data definition.","+ *","+ * The following table is derived from the definitions AN_REQ_* and AN_RES_*","+ * found in the HAProxy include file include/haproxy/channel-t.h.","+ */","+#define FLT_OTEL_EVENT_DEFINES                                                                                \\","+\t/* Stream lifecycle pseudo-events (an_bit = 0, not tied to a channel analyzer) */                     \\","+\tFLT_OTEL_EVENT_DEF(              NONE,    ,        ,        , 0, \"\")                                  \\","+\tFLT_OTEL_EVENT_DEF(      STREAM_START,    ,        ,        , 0, \"on-stream-start\")                   \\","+\tFLT_OTEL_EVENT_DEF(       STREAM_STOP,    ,        ,        , 0, \"on-stream-stop\")                    \\","+\tFLT_OTEL_EVENT_DEF( CLIENT_SESS_START, REQ, CON_ACC,        , 1, \"on-client-session-start\")           \\","+\tFLT_OTEL_EVENT_DEF(      IDLE_TIMEOUT,    ,        ,        , 0, \"on-idle-timeout\")                   \\","+\tFLT_OTEL_EVENT_DEF(       BACKEND_SET,    ,        ,        , 0, \"on-backend-set\")                    \\","+\t                                                                                                      \\","+\t/* Request analyzers */                                                                               \\","+/*\tFLT_OTEL_EVENT_DEF(      FLT_START_FE, REQ,        ,        ,  , \"on-filter-start\") */                \\","+\tFLT_OTEL_EVENT_DEF(        INSPECT_FE, REQ, REQ_CNT,        , 1, \"on-frontend-tcp-request\")           \\","+\tFLT_OTEL_EVENT_DEF(         WAIT_HTTP, REQ,        ,        , 1, \"on-http-wait-request\")              \\","+\tFLT_OTEL_EVENT_DEF(         HTTP_BODY, REQ,        ,        , 1, \"on-http-body-request\")              \\","+\tFLT_OTEL_EVENT_DEF(   HTTP_PROCESS_FE, REQ, HRQ_HDR,        , 1, \"on-frontend-http-request\")          \\","+\tFLT_OTEL_EVENT_DEF(   SWITCHING_RULES, REQ,        ,        , 1, \"on-switching-rules-request\")        \\","+/*\tFLT_OTEL_EVENT_DEF(      FLT_START_BE, REQ,        ,        ,  , \"\") */                               \\","+\tFLT_OTEL_EVENT_DEF(        INSPECT_BE, REQ, REQ_CNT, REQ_CNT, 1, \"on-backend-tcp-request\")            \\","+\tFLT_OTEL_EVENT_DEF(   HTTP_PROCESS_BE, REQ, HRQ_HDR, HRQ_HDR, 1, \"on-backend-http-request\")           \\","+/*\tFLT_OTEL_EVENT_DEF(       HTTP_TARPIT, REQ,        ,        , 1, \"on-http-tarpit-request\") */         \\","+\tFLT_OTEL_EVENT_DEF(         SRV_RULES, REQ,        ,        , 1, \"on-process-server-rules-request\")   \\","+\tFLT_OTEL_EVENT_DEF(        HTTP_INNER, REQ,        ,        , 1, \"on-http-process-request\")           \\","+\tFLT_OTEL_EVENT_DEF(   PRST_RDP_COOKIE, REQ,        ,        , 1, \"on-tcp-rdp-cookie-request\")         \\","+\tFLT_OTEL_EVENT_DEF(    STICKING_RULES, REQ,        ,        , 1, \"on-process-sticking-rules-request\") \\","+/*\tFLT_OTEL_EVENT_DEF(     FLT_HTTP_HDRS, REQ,        ,        ,  , \"\") */                               \\","+/*\tFLT_OTEL_EVENT_DEF(    HTTP_XFER_BODY, REQ,        ,        ,  , \"\") */                               \\","+/*\tFLT_OTEL_EVENT_DEF(          WAIT_CLI, REQ,        ,        ,  , \"\") */                               \\","+/*\tFLT_OTEL_EVENT_DEF(     FLT_XFER_DATA, REQ,        ,        ,  , \"\") */                               \\","+/*\tFLT_OTEL_EVENT_DEF(           FLT_END, REQ,        ,        ,  , \"\") */                               \\","+\tFLT_OTEL_EVENT_DEF(      HTTP_HEADERS, REQ, HRQ_HDR, HRQ_HDR, 1, \"on-http-headers-request\")           \\","+\tFLT_OTEL_EVENT_DEF(          HTTP_END, REQ,        ,        , 1, \"on-http-end-request\")               \\","+\tFLT_OTEL_EVENT_DEF(   CLIENT_SESS_END, REQ,        ,        , 0, \"on-client-session-end\")             \\","+\tFLT_OTEL_EVENT_DEF(SERVER_UNAVAILABLE, REQ,        ,        , 0, \"on-server-unavailable\")             \\","+\t                                                                                                      \\","+\t/* Response analyzers */                                                                              \\","+\tFLT_OTEL_EVENT_DEF( SERVER_SESS_START, RES,        , SRV_CON, 0, \"on-server-session-start\")           \\","+/*\tFLT_OTEL_EVENT_DEF(      FLT_START_FE, RES,        ,        ,  , \"\") */                               \\","+/*\tFLT_OTEL_EVENT_DEF(      FLT_START_BE, RES,        ,        ,  , \"\") */                               \\","+\tFLT_OTEL_EVENT_DEF(           INSPECT, RES, RES_CNT, RES_CNT, 0, \"on-tcp-response\")                   \\","+\tFLT_OTEL_EVENT_DEF(         WAIT_HTTP, RES,        ,        , 1, \"on-http-wait-response\")             \\","+\tFLT_OTEL_EVENT_DEF(       STORE_RULES, RES,        ,        , 1, \"on-process-store-rules-response\")   \\","+\tFLT_OTEL_EVENT_DEF(   HTTP_PROCESS_BE, RES, HRS_HDR, HRS_HDR, 1, \"on-http-response\")                  \\","+\tFLT_OTEL_EVENT_DEF(      HTTP_HEADERS, RES, HRS_HDR, HRS_HDR, 1, \"on-http-headers-response\")          \\","+\tFLT_OTEL_EVENT_DEF(          HTTP_END, RES,        ,        , 0, \"on-http-end-response\")              \\","+\tFLT_OTEL_EVENT_DEF(        HTTP_REPLY, RES,        ,        , 0, \"on-http-reply\")                     \\","+/*\tFLT_OTEL_EVENT_DEF(   HTTP_PROCESS_FE, RES,        ,        ,  , \"\") */                               \\","+/*\tFLT_OTEL_EVENT_DEF(     FLT_HTTP_HDRS, RES,        ,        ,  , \"\") */                               \\","+/*\tFLT_OTEL_EVENT_DEF(    HTTP_XFER_BODY, RES,        ,        ,  , \"\") */                               \\","+/*\tFLT_OTEL_EVENT_DEF(          WAIT_CLI, RES,        ,        ,  , \"\") */                               \\","+/*\tFLT_OTEL_EVENT_DEF(     FLT_XFER_DATA, RES,        ,        ,  , \"\") */                               \\","+/*\tFLT_OTEL_EVENT_DEF(           FLT_END, RES,        ,        ,  , \"\") */                               \\","+\tFLT_OTEL_EVENT_DEF(   SERVER_SESS_END, RES,        ,        , 0, \"on-server-session-end\")","+","+enum FLT_OTEL_EVENT_enum {","+#define FLT_OTEL_EVENT_DEF(a,b,c,d,e,f)   FLT_OTEL_EVENT_##b##_##a,","+\tFLT_OTEL_EVENT_DEFINES","+\tFLT_OTEL_EVENT_MAX","+#undef FLT_OTEL_EVENT_DEF","+};","+","+/* Per-event metadata mapping analyzer bits to filter event names. */","+struct flt_otel_event_data {","+\tuint        an_bit;           /* Used channel analyser. */","+\tconst char *an_name;          /* Channel analyser name. */","+\tuint        smp_opt_dir;      /* Fetch direction (request/response). */","+\tuint        smp_val_fe;       /* Valid FE fetch location. */","+\tuint        smp_val_be;       /* Valid BE fetch location. */","+\tbool        flag_http_inject; /* Span context injection allowed. */","+\tconst char *name;             /* Filter event name. */","+};","+","+","+/* Per-event metadata table indexed by FLT_OTEL_EVENT_* constants. */","+extern const struct flt_otel_event_data flt_otel_event_data[FLT_OTEL_EVENT_MAX];","+","+#endif /* _OTEL_EVENT_H_ */","+","+/*","+ * Local variables:","+ *  c-indent-level: 8","+ *  c-basic-offset: 8","+ * End:","+ *","+ * vi: noexpandtab shiftwidth=8 tabstop=8","+ */"],"additions":135,"deletions":0,"truncated":false},{"path":"addons/otel/include/filter.h","lines":["@@ -3,6 +3,12 @@"," #ifndef _OTEL_FILTER_H_"," #define _OTEL_FILTER_H_"," ","+#define FLT_OTEL_FMT_NAME           \"'\" FLT_OTEL_OPT_NAME \"' : \"","+#define FLT_OTEL_FMT_TYPE           \"'filter' : \"","+","+#define FLT_OTEL_CONDITION_IF       \"if\"","+#define FLT_OTEL_CONDITION_UNLESS   \"unless\"","+"," /* Return codes for OTel filter operations. */"," enum FLT_OTEL_RET_enum {"," \tFLT_OTEL_RET_ERROR  = -1,","@@ -12,7 +18,8 @@ enum FLT_OTEL_RET_enum {"," };"," "," ","-extern const char *otel_flt_id;","+extern const char     *otel_flt_id;","+extern struct flt_ops  flt_otel_ops;"," "," #endif /* _OTEL_FILTER_H_ */"," "],"additions":8,"deletions":1,"truncated":false},{"path":"addons/otel/include/include.h","lines":["@@ -27,6 +27,7 @@"," "," #include \"config.h\""," #include \"define.h\"","+#include \"event.h\""," #include \"conf.h\""," #include \"conf_funcs.h\""," #include \"filter.h\""],"additions":1,"deletions":0,"truncated":false},{"path":"addons/otel/include/parser.h","lines":["@@ -3,8 +3,163 @@"," #ifndef _OTEL_PARSER_H_"," #define _OTEL_PARSER_H_"," ","-#define FLT_OTEL_SCOPE      \"OTEL\"","-#define FLT_OTEL_OPT_NAME   \"opentelemetry\"","+#define FLT_OTEL_SCOPE                        \"OTEL\"","+","+/*","+ * filter FLT_OTEL_OPT_NAME FLT_OTEL_OPT_FILTER_ID <FLT_OTEL_OPT_FILTER_ID_DEFAULT> FLT_OTEL_OPT_CONFIG <file>","+ */","+#define FLT_OTEL_OPT_NAME                     \"opentelemetry\"","+#define FLT_OTEL_OPT_FILTER_ID                \"id\"","+#define FLT_OTEL_OPT_FILTER_ID_DEFAULT        \"otel-filter\"","+#define FLT_OTEL_OPT_CONFIG                   \"config\"","+","+#define FLT_OTEL_PARSE_SECTION_INSTR_ID       \"otel-instrumentation\"","+#define FLT_OTEL_PARSE_SECTION_GROUP_ID       \"otel-group\"","+#define FLT_OTEL_PARSE_SECTION_SCOPE_ID       \"otel-scope\"","+","+#define FLT_OTEL_PARSE_SPAN_ROOT              \"root\"","+#define FLT_OTEL_PARSE_SPAN_PARENT            \"parent\"","+#define FLT_OTEL_PARSE_CTX_AUTONAME           \"-\"","+#define FLT_OTEL_PARSE_CTX_IGNORE_NAME        '-'","+#define FLT_OTEL_PARSE_CTX_USE_HEADERS        \"use-headers\"","+#define FLT_OTEL_PARSE_OPTION_HARDERR         \"hard-errors\"","+#define FLT_OTEL_PARSE_OPTION_DISABLED        \"disabled\"","+#define FLT_OTEL_PARSE_OPTION_NOLOGNORM       \"dontlog-normal\"","+","+/*","+ * A description of the macro arguments can be found in the structure","+ * flt_otel_parse_data definition","+ */","+#define FLT_OTEL_PARSE_INSTR_DEFINES                                                                                                                                      \\","+\tFLT_OTEL_PARSE_INSTR_DEF(         ID, 0, CHAR, 2, 2, \"otel-instrumentation\", \" <name>\")                                                                           \\","+\tFLT_OTEL_PARSE_INSTR_DEF(        ACL, 0, CHAR, 3, 0, \"acl\",                  \" <name> <criterion> [flags] [operator] <value> ...\")                                \\","+\tFLT_OTEL_PARSE_INSTR_DEF(        LOG, 0, CHAR, 2, 0, \"log\",                  \" { global | <addr> [len <len>] [format <fmt>] <facility> [<level> [<minlevel>]] }\") \\","+\tFLT_OTEL_PARSE_INSTR_DEF(     CONFIG, 0, NONE, 2, 2, \"config\",               \" <file>\")                                                                           \\","+\tFLT_OTEL_PARSE_INSTR_DEF(     GROUPS, 0, NONE, 2, 0, \"groups\",               \" <name> ...\")                                                                       \\","+\tFLT_OTEL_PARSE_INSTR_DEF(     SCOPES, 0, NONE, 2, 0, \"scopes\",               \" <name> ...\")                                                                       \\","+\tFLT_OTEL_PARSE_INSTR_DEF( RATE_LIMIT, 0, NONE, 2, 2, \"rate-limit\",           \" <value>\")                                                                          \\","+\tFLT_OTEL_PARSE_INSTR_DEF(     OPTION, 0, NONE, 2, 2, \"option\",               \" { disabled | dontlog-normal | hard-errors }\")                                      \\","+\tFLT_OTEL_PARSE_INSTR_DEF(DEBUG_LEVEL, 0, NONE, 2, 2, \"debug-level\",          \" <value>\")","+","+#define FLT_OTEL_PARSE_GROUP_DEFINES                                             \\","+\tFLT_OTEL_PARSE_GROUP_DEF(    ID, 0, CHAR, 2, 2, \"otel-group\", \" <name>\") \\","+\tFLT_OTEL_PARSE_GROUP_DEF(SCOPES, 0, NONE, 2, 0, \"scopes\",   \" <name> ...\")","+","+#define FLT_OTEL_PARSE_SCOPE_INJECT_HELP      \" <name-prefix> [use-headers]\"","+#define FLT_OTEL_PARSE_SCOPE_EXTRACT_HELP     \" <name-prefix> [use-headers]\"","+","+/*","+ * The first argument of the FLT_OTEL_PARSE_SCOPE_STATUS_DEF() macro is defined","+ * as otelc_span_status_t in <opentelemetry-c-wrapper/span.h> .","+ */","+#define FLT_OTEL_PARSE_SCOPE_STATUS_DEFINES               \\","+\tFLT_OTEL_PARSE_SCOPE_STATUS_DEF(IGNORE, \"ignore\") \\","+\tFLT_OTEL_PARSE_SCOPE_STATUS_DEF( UNSET, \"unset\" ) \\","+\tFLT_OTEL_PARSE_SCOPE_STATUS_DEF(    OK, \"ok\"    ) \\","+\tFLT_OTEL_PARSE_SCOPE_STATUS_DEF( ERROR, \"error\" )","+","+/*","+ * In case the possibility of working with OpenTelemetry context via HAProxy","+ * variables is not used, args_max member of the structure flt_otel_parse_data","+ * should be reduced for 'inject' keyword.  However, this is not critical","+ * because in this case the 'use-vars' argument cannot be entered anyway,","+ * so I will not complicate it here with additional definitions.","+ */","+#define FLT_OTEL_PARSE_SCOPE_DEFINES                                                                                                \\","+\tFLT_OTEL_PARSE_SCOPE_DEF(          ID, 0, CHAR, 2, 2, \"otel-scope\",   \" <name>\")                                            \\","+\tFLT_OTEL_PARSE_SCOPE_DEF(        SPAN, 0, NONE, 2, 7, \"span\",         \" <name> [<reference>] [root]\")                       \\","+\tFLT_OTEL_PARSE_SCOPE_DEF(   ATTRIBUTE, 1, NONE, 3, 0,   \"attribute\",  \" <key> <sample> ...\")                                \\","+\tFLT_OTEL_PARSE_SCOPE_DEF(       EVENT, 1, NONE, 4, 0,   \"event\",      \" <name> <key> <sample> ...\")                         \\","+\tFLT_OTEL_PARSE_SCOPE_DEF(     BAGGAGE, 1,  VAR, 3, 0,   \"baggage\",    \" <key> <sample> ...\")                                \\","+\tFLT_OTEL_PARSE_SCOPE_DEF(      INJECT, 1,  CTX, 2, 4,   \"inject\",     FLT_OTEL_PARSE_SCOPE_INJECT_HELP)                     \\","+\tFLT_OTEL_PARSE_SCOPE_DEF(     EXTRACT, 0,  CTX, 2, 3,   \"extract\",    FLT_OTEL_PARSE_SCOPE_EXTRACT_HELP)                    \\","+\tFLT_OTEL_PARSE_SCOPE_DEF(      STATUS, 1, NONE, 2, 0,   \"status\",     \" <code> [<sample> ...]\")                             \\","+\tFLT_OTEL_PARSE_SCOPE_DEF(      FINISH, 0, NONE, 2, 0,   \"finish\",     \" <name> ...\")                                        \\","+\tFLT_OTEL_PARSE_SCOPE_DEF(IDLE_TIMEOUT, 0, NONE, 2, 2, \"idle-timeout\", \" <time>\")                                            \\","+\tFLT_OTEL_PARSE_SCOPE_DEF(         ACL, 0, CHAR, 3, 0, \"acl\",          \" <name> <criterion> [flags] [operator] <value> ...\") \\","+\tFLT_OTEL_PARSE_SCOPE_DEF(    ON_EVENT, 0, NONE, 2, 0, \"otel-event\",   \" <name> [{ if | unless } <condition>]\")","+","+/* Invalid character check modes for identifier validation. */","+enum FLT_OTEL_PARSE_INVCHAR_enum {","+\tFLT_OTEL_PARSE_INVALID_NONE,","+\tFLT_OTEL_PARSE_INVALID_CHAR,","+\tFLT_OTEL_PARSE_INVALID_DOM,","+\tFLT_OTEL_PARSE_INVALID_CTX,","+\tFLT_OTEL_PARSE_INVALID_VAR,","+};","+","+enum FLT_OTEL_PARSE_INSTR_enum {","+#define FLT_OTEL_PARSE_INSTR_DEF(a,b,c,d,e,f,g)   FLT_OTEL_PARSE_INSTR_##a,","+\tFLT_OTEL_PARSE_INSTR_DEFINES","+#undef FLT_OTEL_PARSE_INSTR_DEF","+};","+","+enum FLT_OTEL_PARSE_GROUP_enum {","+#define FLT_OTEL_PARSE_GROUP_DEF(a,b,c,d,e,f,g)   FLT_OTEL_PARSE_GROUP_##a,","+\tFLT_OTEL_PARSE_GROUP_DEFINES","+#undef FLT_OTEL_PARSE_GROUP_DEF","+};","+","+enum FLT_OTEL_PARSE_SCOPE_enum {","+#define FLT_OTEL_PARSE_SCOPE_DEF(a,b,c,d,e,f,g)   FLT_OTEL_PARSE_SCOPE_##a,","+\tFLT_OTEL_PARSE_SCOPE_DEFINES","+#undef FLT_OTEL_PARSE_SCOPE_DEF","+};","+","+/* Context storage type flags for inject/extract operations. */","+enum FLT_OTEL_CTX_USE_enum {","+\tFLT_OTEL_CTX_USE_HEADERS = 1 << 0,","+};","+","+/* Logging state flags for the OTel filter. */","+enum FLT_OTEL_LOGGING_enum {","+\tFLT_OTEL_LOGGING_OFF       = 0,","+\tFLT_OTEL_LOGGING_ON        = 1 << 0,","+\tFLT_OTEL_LOGGING_NOLOGNORM = 1 << 1,","+};","+","+/* Keyword metadata used by the configuration section parsers. */","+struct flt_otel_parse_data {","+\tint         keyword;       /* Keyword index. */","+\tbool        flag_check_id; /* Whether the group ID must be defined for the keyword. */","+\tint         check_name;    /* Checking allowed characters in the name. */","+\tint         args_min;      /* The minimum number of arguments required. */","+\tint         args_max;      /* The maximum number of arguments allowed. */","+\tconst char *name;          /* Keyword name. */","+\tconst char *usage;         /* Usage text to be printed in case of an error. */","+};","+","+#define FLT_OTEL_PARSE_KEYWORD(n,s)           (strcmp(args[n], (s)) == 0)","+","+#define FLT_OTEL_PARSE_WARNING(f, ...) \\","+\tha_warning(\"parsing [%s:%d] : \" FLT_OTEL_FMT_TYPE FLT_OTEL_FMT_NAME \"'\" f \"'\\n\", ##__VA_ARGS__);","+","+#define FLT_OTEL_PARSE_ALERT(f, ...)                                                                           \\","+\tdo {                                                                                                   \\","+\t\tha_alert(\"parsing [%s:%d] : \" FLT_OTEL_FMT_TYPE FLT_OTEL_FMT_NAME \"'\" f \"'\\n\", ##__VA_ARGS__); \\","+\t\t                                                                                               \\","+\t\tretval |= ERR_ABORT | ERR_ALERT;                                                               \\","+\t} while (0)","+","+#define FLT_OTEL_POST_PARSE_ALERT(f, ...) \\","+\tFLT_OTEL_PARSE_ALERT(f, flt_otel_current_config->cfg_file, ##__VA_ARGS__)","+","+#define FLT_OTEL_PARSE_ERR(e,f, ...)                            \\","+\tdo {                                                    \\","+\t\tif (*(e) == NULL)                               \\","+\t\t\t(void)memprintf((e), f, ##__VA_ARGS__); \\","+\t\t                                                \\","+\t\tretval |= ERR_ABORT | ERR_ALERT;                \\","+\t} while (0)","+","+#define FLT_OTEL_PARSE_IFERR_ALERT()                         \\","+\tdo {                                                 \\","+\t\tif (err == NULL)                             \\","+\t\t\tbreak;                               \\","+\t\t                                             \\","+\t\tFLT_OTEL_PARSE_ALERT(\"%s\", file, line, err); \\","+\t\tFLT_OTEL_ERR_FREE(err);                      \\","+\t} while (0)"," "," #endif /* _OTEL_PARSER_H_ */"," "],"additions":157,"deletions":2,"truncated":false},{"path":"addons/otel/include/util.h","lines":["@@ -34,6 +34,12 @@ int         flt_otel_args_count(const char **args);"," /* Concatenate argument array elements into a single string. */"," int         flt_otel_args_concat(const char **args, int idx, int n, char **str);"," ","+/* Parse a string to double with range validation. */","+bool        flt_otel_strtod(const char *nptr, double *value, double limit_min, double limit_max, char **err);","+","+/* Parse a string to int64_t with range validation. */","+bool        flt_otel_strtoll(const char *nptr, int64_t *value, int64_t limit_min, int64_t limit_max, char **err);","+"," /* Convert sample data to a string representation. */"," int         flt_otel_sample_to_str(const struct sample_data *data, char *value, size_t size, char **err);"," "],"additions":6,"deletions":0,"truncated":false},{"path":"addons/otel/src/event.c","lines":["@@ -0,0 +1,19 @@","+/* SPDX-License-Identifier: GPL-2.0-or-later */","+","+#include \"../include/include.h\"","+","+","+/* Event data table built from the X-macro list. */","+#define FLT_OTEL_EVENT_DEF(a,b,c,d,e,f)   { AN_##b##_##a, OTELC_STRINGIFY_ARG(AN_##b##_##a), SMP_OPT_DIR_##b, SMP_VAL_FE_##c, SMP_VAL_BE_##d, e, f },","+const struct flt_otel_event_data flt_otel_event_data[FLT_OTEL_EVENT_MAX] = { FLT_OTEL_EVENT_DEFINES };","+#undef FLT_OTEL_EVENT_DEF","+","+","+/*","+ * Local variables:","+ *  c-indent-level: 8","+ *  c-basic-offset: 8","+ * End:","+ *","+ * vi: noexpandtab shiftwidth=8 tabstop=8","+ */"],"additions":19,"deletions":0,"truncated":false},{"path":"addons/otel/src/parser.c","lines":["@@ -8,6 +8,1261 @@ static struct otelc_dbg_mem_data dbg_mem_data[1000000];"," static struct otelc_dbg_mem      dbg_mem;"," #endif"," ","+static struct flt_otel_conf       *flt_otel_current_config = NULL;","+static struct flt_otel_conf_instr *flt_otel_current_instr = NULL;","+static struct flt_otel_conf_group *flt_otel_current_group = NULL;","+static struct flt_otel_conf_scope *flt_otel_current_scope = NULL;","+static struct flt_otel_conf_span  *flt_otel_current_span = NULL;","+","+","+/***","+ * NAME","+ *   flt_otel_parse_strdup - string duplication with error handling","+ *","+ * SYNOPSIS","+ *   static int flt_otel_parse_strdup(char **dst, size_t *dst_len, const char *src, char **err, const char *err_msg)","+ *","+ * ARGUMENTS","+ *   dst     - pointer to the destination string pointer","+ *   dst_len - optional pointer to store the duplicated string length","+ *   src     - source string to duplicate","+ *   err     - indirect pointer to error message string","+ *   err_msg - context label used in error messages","+ *","+ * DESCRIPTION","+ *   Duplicates the string <src> into <*dst> with error handling.  Optionally","+ *   stores the string length in <dst_len>.  On failure, an error message is","+ *   formatted using <err_msg> as context.","+ *","+ * RETURN VALUE","+ *   Returns ERR_NONE (== 0) in case of success,","+ *   or a combination of ERR_* flags if an error is encountered.","+ */","+static int flt_otel_parse_strdup(char **dst, size_t *dst_len, const char *src, char **err, const char *err_msg)","+{","+\tint retval = ERR_NONE;","+","+\tOTELC_FUNC(\"%p:%p, %p, %p, %p:%p, \\\"%s\\\"\", OTELC_DPTR_ARGS(dst), dst_len, src, OTELC_DPTR_ARGS(err), OTELC_STR_ARG(err_msg));","+","+\t/* dst_len is not set if the string has not been copied. */","+\t*dst = OTELC_STRDUP(src);","+\tif (*dst == NULL)","+\t\tFLT_OTEL_PARSE_ERR(err, \"'%s' : out of memory\", err_msg);","+\telse if (dst_len != NULL)","+\t\t*dst_len = strlen(*dst);","+","+\tOTELC_RETURN_INT(retval);","+}","+","+","+/***","+ * NAME","+ *   flt_otel_parse_keyword - keyword argument parser","+ *","+ * SYNOPSIS","+ *   static int flt_otel_parse_keyword(char **ptr, char **args, int cur_arg, int pos, char **err, const char *err_msg)","+ *","+ * ARGUMENTS","+ *   ptr     - pointer to the destination string pointer","+ *   args    - configuration line arguments array","+ *   cur_arg - current argument index for error reporting","+ *   pos     - position of the keyword in <args>","+ *   err     - indirect pointer to error message string","+ *   err_msg - context label used in error messages","+ *","+ * DESCRIPTION","+ *   Parses a single keyword argument from the configuration line.  Checks","+ *   that the keyword has not already been set and that a value is present","+ *   at position <pos> + 1 in <args>.  The value is duplicated via","+ *   flt_otel_parse_strdup() into <*ptr>.","+ *","+ * RETURN VALUE","+ *   Returns ERR_NONE (== 0) in case of success,","+ *   or a combination of ERR_* flags if an error is encountered.","+ */","+static int flt_otel_parse_keyword(char **ptr, char **args, int cur_arg, int pos, char **err, const char *err_msg)","+{","+\tint retval = ERR_NONE;","+","+\tOTELC_FUNC(\"%p:%p, %p, %d, %d, %p:%p, \\\"%s\\\"\", OTELC_DPTR_ARGS(ptr), args, cur_arg, pos, OTELC_DPTR_ARGS(err), OTELC_STR_ARG(err_msg));","+","+\t/* Reject duplicate keyword assignments. */","+\tif (*ptr != NULL) {","+\t\tif (cur_arg == pos)","+\t\t\tFLT_OTEL_PARSE_ERR(err, FLT_OTEL_FMT_TYPE \"%s already set\", err_msg);","+\t\telse","+\t\t\tFLT_OTEL_PARSE_ERR(err, \"'%s' : %s already set\", args[cur_arg], err_msg);","+\t}","+\telse if (!FLT_OTEL_ARG_ISVALID(pos + 1)) {","+\t\tif (cur_arg == pos)","+\t\t\tFLT_OTEL_PARSE_ERR(err, FLT_OTEL_FMT_TYPE \"no %s set\", err_msg);","+\t\telse","+\t\t\tFLT_OTEL_PARSE_ERR(err, \"'%s' : no %s set\", args[cur_arg], err_msg);","+\t}","+\telse {","+\t\tretval = flt_otel_parse_strdup(ptr, NULL, args[pos + 1], err, args[cur_arg]);","+\t}","+","+\tOTELC_RETURN_INT(retval);","+}","+","+","+/***","+ * NAME","+ *   flt_otel_parse_invalid_char - name character validation","+ *","+ * SYNOPSIS","+ *   static const char *flt_otel_parse_invalid_char(const char *name, int type)","+ *","+ * ARGUMENTS","+ *   name - string to validate","+ *   type - validation type selector","+ *","+ * DESCRIPTION","+ *   Validates characters in a <name> string according to the specified <type>.","+ *   Uses HAProxy's invalid_char() for identifiers, invalid_domainchar() for","+ *   domains, invalid_prefix_char() for context prefixes, and a custom","+ *   alphanumeric check for variables.","+ *","+ * RETURN VALUE","+ *   Returns a pointer to the first invalid character in <name>,","+ *   or NULL if all characters are valid.","+ */","+static const char *flt_otel_parse_invalid_char(const char *name, int type)","+{","+\tconst char *retptr = NULL;","+","+\tOTELC_FUNC(\"\\\"%s\\\", %d\", OTELC_STR_ARG(name), type);","+","+\tif (!OTELC_STR_IS_VALID(name))","+\t\tOTELC_RETURN_EX(retptr, const char *, \"%p\");","+","+\t/* Dispatch to the appropriate character validation function. */","+\tif (type == FLT_OTEL_PARSE_INVALID_CHAR) {","+\t\tretptr = invalid_char(name);","+\t}","+\telse if (type == FLT_OTEL_PARSE_INVALID_DOM) {","+\t\tretptr = invalid_domainchar(name);","+\t}","+\telse if (type == FLT_OTEL_PARSE_INVALID_CTX) {","+\t\tretptr = invalid_prefix_char(name);","+\t}","+\telse if (type == FLT_OTEL_PARSE_INVALID_VAR) {","+\t\tretptr = name;","+","+\t\t/*","+\t\t * Allowed characters are letters, numbers and '_', the first","+\t\t * character in the string must not be a number.","+\t\t */","+\t\tif (!isdigit(*retptr))","+\t\t\tfor (++retptr; (*retptr == '_') || isalnum(*retptr); retptr++);","+","+\t\tif (*retptr == '\\0')","+\t\t\tretptr = NULL;","+\t}","+","+\tOTELC_RETURN_EX(retptr, const char *, \"%p\");","+}","+","+","+/***","+ * NAME","+ *   flt_otel_parse_cfg_check - configuration keyword validation","+ *","+ * SYNOPSIS","+ *   static int flt_otel_parse_cfg_check(const char *file, int line, char **args, const void *id, const struct flt_otel_parse_data *parse_data, size_t parse_data_size, const struct flt_otel_parse_data **pdata, char **err)","+ *","+ * ARGUMENTS","+ *   file            - configuration file path","+ *   line            - configuration file line number","+ *   args            - configuration line arguments array","+ *   id              - parent section identifier","+ *   parse_data      - keyword definition table","+ *   parse_data_size - number of entries in <parse_data>","+ *   pdata           - output pointer to the matched keyword entry","+ *   err             - indirect pointer to error message string","+ *","+ * DESCRIPTION","+ *   Common validation for configuration keywords.  Looks up <args[0]> in the","+ *   <parse_data> table, checks argument count bounds, validates the first","+ *   argument's characters according to the keyword's check_name type, and","+ *   verifies that the parent section ID is set when required.","+ *","+ * RETURN VALUE","+ *   Returns ERR_NONE (== 0) in case of success,","+ *   or a combination of ERR_* flags if an error is encountered.","+ */","+static int flt_otel_parse_cfg_check(const char *file, int line, char **args, const void *id, const struct flt_otel_parse_data *parse_data, size_t parse_data_size, const struct flt_otel_parse_data **pdata, char **err)","+{","+\tint i, argc, retval = ERR_NONE;","+","+\tOTELC_FUNC(\"\\\"%s\\\", %d, %p, %p, %p, %zu, %p:%p, %p:%p\", OTELC_STR_ARG(file), line, args, id, parse_data, parse_data_size, OTELC_DPTR_ARGS(pdata), OTELC_DPTR_ARGS(err));","+","+\tFLT_OTEL_ARGS_DUMP();","+","+\t*pdata = NULL;","+","+\t/* First check here if args[0] is the correct keyword. */","+\tfor (i = 0; (*pdata == NULL) && (i < parse_data_size); i++)","+\t\tif (FLT_OTEL_PARSE_KEYWORD(0, parse_data[i].name))","+\t\t\t*pdata = parse_data + i;","+","+\tif (*pdata == NULL)","+\t\tFLT_OTEL_PARSE_ERR(err, \"'%s' : unknown keyword\", args[0]);","+\telse","+\t\targc = flt_otel_args_count((const char **)args);","+","+\tif ((retval & ERR_CODE) || (id == NULL))","+\t\t/* Do nothing. */;","+\telse if ((id != flt_otel_current_instr) && (flt_otel_current_config->instr == NULL))","+\t\tFLT_OTEL_PARSE_ERR(err, \"instrumentation not defined\");","+","+\t/*","+\t * Checking that fewer arguments are specified in the configuration","+\t * line than is required.","+\t */","+\tif (!(retval & ERR_CODE))","+\t\tif (argc < (*pdata)->args_min)","+\t\t\tFLT_OTEL_PARSE_ERR(err, \"'%s' : too few arguments (use '%s%s')\", args[0], (*pdata)->name, (*pdata)->usage);","+","+\t/*","+\t * Checking that more arguments are specified in the configuration","+\t * line than the maximum allowed.","+\t */","+\tif (!(retval & ERR_CODE) && ((*pdata)->args_max > 0))","+\t\tif (argc > (*pdata)->args_max)","+\t\t\tFLT_OTEL_PARSE_ERR(err, \"'%s' : too many arguments (use '%s%s')\", args[0], (*pdata)->name, (*pdata)->usage);","+","+\t/* Checking that the first argument has only allowed characters. */","+\tif (!(retval & ERR_CODE) && ((*pdata)->check_name != FLT_OTEL_PARSE_INVALID_NONE)) {","+\t\tconst char *ic;","+","+\t\tic = flt_otel_parse_invalid_char(args[1], (*pdata)->check_name);","+\t\tif (ic != NULL)","+\t\t\tFLT_OTEL_PARSE_ERR(err, \"%s '%s' : invalid character '%c'\", args[0], args[1], *ic);","+\t}","+","+\t/* Checking that the data group name is defined. */","+\tif (!(retval & ERR_CODE) && (*pdata)->flag_check_id && (id == NULL))","+\t\tFLT_OTEL_PARSE_ERR(err, \"'%s' : %s ID not set (use '%s%s')\", args[0], parse_data[1].name, parse_data[1].name, parse_data[1].usage);","+","+\tOTELC_RETURN_INT(retval);","+}","+","+","+/***","+ * NAME","+ *   flt_otel_parse_cfg_sample_expr - sample expression parser","+ *","+ * SYNOPSIS","+ *   static int flt_otel_parse_cfg_sample_expr(const char *file, int line, char **args, int *idx, struct list *head, char **err)","+ *","+ * ARGUMENTS","+ *   file - configuration file path","+ *   line - configuration file line number","+ *   args - configuration line arguments array","+ *   idx  - pointer to the current position in <args>"],"additions":254,"deletions":0,"truncated":false}],"additions":581,"deletions":3,"truncated":true,"file_count":8},"error":null,"fetched_at":"2026-05-20T17:37:01.932755+00:00"}