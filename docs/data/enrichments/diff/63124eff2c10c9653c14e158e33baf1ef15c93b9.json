covery/networkpolicy\""," \t\"github.com/projectdiscovery/rawhttp\""," \t\"github.com/projectdiscovery/retryablehttp-go\"","-\tmapsutil \"github.com/projectdiscovery/utils/maps\""," )"," "," type Dialers struct {"," \tFastdialer                 *fastdialer.Dialer"," \tRawHTTPClient              *rawhttp.Client"," \tDefaultHTTPClient          *retryablehttp.Client","-\tHTTPClientPool             *mapsutil.SyncLockMap[string, *retryablehttp.Client]","+\tHTTPClientPool             *HTTPPool"," \tNetworkPolicy              *networkpolicy.NetworkPolicy"," \tLocalFileAccessAllowed     bool"," \tRestrictLocalNetworkAccess bool"],"additions":1,"deletions":2,"truncated":false},{"path":"pkg/protocols/common/protocolstate/httppool.go","lines":["@@ -0,0 +1,225 @@","+package protocolstate","+","+import (","+\t\"net/http\"","+\t\"sync\"","+\t\"sync/atomic\"","+\t\"time\"","+","+\t\"github.com/projectdiscovery/retryablehttp-go\"","+\t\"golang.org/x/sync/singleflight\"","+)","+","+// closeIdler is implemented by transports that can drop idle connections.","+type closeIdler interface{ CloseIdleConnections() }","+","+// httpTransportEntry tracks a pooled transport and its last access time.","+type httpTransportEntry struct {","+\trt         http.RoundTripper","+\tlastAccess atomic.Int64 // unix nanoseconds","+}","+","+func (e *httpTransportEntry) touch(now int64) { e.lastAccess.Store(now) }","+","+// httpClientEntry tracks a pooled client, the transport it shares and its","+// last access time.","+type httpClientEntry struct {","+\tclient     *retryablehttp.Client","+\ttransport  *httpTransportEntry","+\tlastAccess atomic.Int64 // unix nanoseconds","+}","+","+func (e *httpClientEntry) touch(now int64) {","+\te.lastAccess.Store(now)","+\tif e.transport != nil {","+\t\t// keep the shared transport alive while any of its clients is active","+\t\te.transport.touch(now)","+\t}","+}","+","+// HTTPPool is a two-level cache for retryablehttp clients and the","+// http.RoundTripper transports they share.","+//","+// Design goals (hot path = one lookup per outgoing request):","+//   - lock-free cache hits: sync.Map reads plus atomic last-access updates,","+//     no global mutex acquisition per request","+//   - singleflight creation: concurrent first requests to the same key build","+//     exactly one client/transport instead of N-1 orphans holding sockets","+//   - transport/client split: client-level settings (redirect policy, cookie","+//     jar, timeout) get their own cheap client wrapper while sharing one","+//     transport (and therefore one connection pool) per host","+//   - eviction closes connections: idle transports get CloseIdleConnections()","+//     instead of being silently dropped for the GC to find","+type HTTPPool struct {","+\tclients     sync.Map // string -> *httpClientEntry","+\ttransports  sync.Map // string -> *httpTransportEntry","+\tclientSF    singleflight.Group","+\ttransportSF singleflight.Group","+","+\tinactivity      time.Duration","+\tcleanupInterval time.Duration","+\tlastCleanup     atomic.Int64 // unix nanoseconds","+\tcleanupRunning  atomic.Bool","+}","+","+// NewHTTPPool creates a pool whose entries are evicted after the given","+// inactivity duration, checked lazily at most once per cleanupInterval.","+func NewHTTPPool(inactivity, cleanupInterval time.Duration) *HTTPPool {","+\tp := &HTTPPool{","+\t\tinactivity:      inactivity,","+\t\tcleanupInterval: cleanupInterval,","+\t}","+\tp.lastCleanup.Store(time.Now().UnixNano())","+\treturn p","+}","+","+// GetClient returns a cached client for the key, refreshing its eviction","+// timestamp. The hit path performs no locking.","+func (p *HTTPPool) GetClient(key string) (*retryablehttp.Client, bool) {","+\tv, ok := p.clients.Load(key)","+\tif !ok {","+\t\treturn nil, false","+\t}","+\tentry := v.(*httpClientEntry)","+\tentry.touch(time.Now().UnixNano())","+\tp.maybeCleanup()","+\treturn entry.client, true","+}","+","+// GetOrCreateClient returns the cached client for clientKey or builds it","+// exactly once (singleflight) using a transport shared via transportKey.","+func (p *HTTPPool) GetOrCreateClient(","+\tclientKey, transportKey string,","+\tcreateTransport func() (http.RoundTripper, error),","+\tcreateClient func(rt http.RoundTripper) (*retryablehttp.Client, error),","+) (*retryablehttp.Client, error) {","+\tif client, ok := p.GetClient(clientKey); ok {","+\t\treturn client, nil","+\t}","+\tv, err, _ := p.clientSF.Do(clientKey, func() (interface{}, error) {","+\t\tif existing, ok := p.clients.Load(clientKey); ok {","+\t\t\treturn existing.(*httpClientEntry), nil","+\t\t}","+\t\ttEntry, err := p.getOrCreateTransportEntry(transportKey, createTransport)","+\t\tif err != nil {","+\t\t\treturn nil, err","+\t\t}","+\t\tclient, err := createClient(tEntry.rt)","+\t\tif err != nil {","+\t\t\treturn nil, err","+\t\t}","+\t\tentry := &httpClientEntry{client: client, transport: tEntry}","+\t\tentry.touch(time.Now().UnixNano())","+\t\tp.clients.Store(clientKey, entry)","+\t\treturn entry, nil","+\t})","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\tentry := v.(*httpClientEntry)","+\tentry.touch(time.Now().UnixNano())","+\treturn entry.client, nil","+}","+","+// GetOrCreateTransport returns the shared transport for the key, building it","+// exactly once. Used directly by callers that need an uncached client (e.g.","+// explicit per-request cookie jars) but still want pooled connections.","+func (p *HTTPPool) GetOrCreateTransport(key string, create func() (http.RoundTripper, error)) (http.RoundTripper, error) {","+\tentry, err := p.getOrCreateTransportEntry(key, create)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\treturn entry.rt, nil","+}","+","+func (p *HTTPPool) getOrCreateTransportEntry(key string, create func() (http.RoundTripper, error)) (*httpTransportEntry, error) {","+\tif v, ok := p.transports.Load(key); ok {","+\t\tentry := v.(*httpTransportEntry)","+\t\tentry.touch(time.Now().UnixNano())","+\t\treturn entry, nil","+\t}","+\tv, err, _ := p.transportSF.Do(key, func() (interface{}, error) {","+\t\tif existing, ok := p.transports.Load(key); ok {","+\t\t\treturn existing.(*httpTransportEntry), nil","+\t\t}","+\t\trt, err := create()","+\t\tif err != nil {","+\t\t\treturn nil, err","+\t\t}","+\t\tentry := &httpTransportEntry{rt: rt}","+\t\tentry.touch(time.Now().UnixNano())","+\t\tp.transports.Store(key, entry)","+\t\treturn entry, nil","+\t})","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\tentry := v.(*httpTransportEntry)","+\tentry.touch(time.Now().UnixNano())","+\treturn entry, nil","+}","+","+// maybeCleanup spawns a single background eviction pass if the cleanup","+// interval has elapsed. Uses CAS so only one goroutine wins.","+func (p *HTTPPool) maybeCleanup() {","+\tif p.inactivity <= 0 {","+\t\treturn","+\t}","+\tnow := time.Now().UnixNano()","+\tlast := p.lastCleanup.Load()","+\tif now-last < p.cleanupInterval.Nanoseconds() {","+\t\treturn","+\t}","+\tif !p.lastCleanup.CompareAndSwap(last, now) {","+\t\treturn","+\t}","+\tif !p.cleanupRunning.CompareAndSwap(false, true) {","+\t\treturn","+\t}","+\tgo func() {","+\t\tdefer p.cleanupRunning.Store(false)","+\t\tp.evictInactive()","+\t}()","+}","+","+// evictInactive drops clients and transports idle for longer than the","+// inactivity window. Evicted transports get their idle connections closed","+// immediately instead of waiting for the GC / IdleConnTimeout.","+func (p *HTTPPool) evictInactive() {","+\tdeadline := time.Now().Add(-p.inactivity).UnixNano()","+","+\tp.clients.Range(func(k, v interface{}) bool {","+\t\tif v.(*httpClientEntry).lastAccess.Load() < deadline {","+\t\t\tp.clients.Delete(k)","+\t\t}","+\t\treturn true","+\t})","+\t// Transports are touched whenever one of their clients is touched, so a","+\t// transport only goes idle once all clients sharing it are idle too.","+\tp.transports.Range(func(k, v interface{}) bool {","+\t\tentry := v.(*httpTransportEntry)","+\t\tif entry.lastAccess.Load() < deadline {","+\t\t\tp.transports.Delete(k)","+\t\t\tif ci, ok := entry.rt.(closeIdler); ok {","+\t\t\t\tci.CloseIdleConnections()","+\t\t\t}","+\t\t}","+\t\treturn true","+\t})","+}","+","+// Close drops all cached clients and transports, closing idle connections so","+// no transport goroutines linger after shutdown.","+func (p *HTTPPool) Close() {","+\tp.clients.Range(func(k, _ interface{}) bool {","+\t\tp.clients.Delete(k)","+\t\treturn true","+\t})","+\tp.transports.Range(func(k, v interface{}) bool {","+\t\tp.transports.Delete(k)","+\t\tif ci, ok := v.(*httpTransportEntry).rt.(closeIdler); ok {","+\t\t\tci.CloseIdleConnections()","+\t\t}","+\t\treturn true","+\t})","+}"],"additions":225,"deletions":0,"truncated":false},{"path":"pkg/protocols/common/protocolstate/httppool_test.go","lines":["@@ -0,0 +1,183 @@","+package protocolstate","+","+import (","+\t\"net/http\"","+\t\"sync\"","+\t\"sync/atomic\"","+\t\"testing\"","+\t\"time\"","+","+\t\"github.com/projectdiscovery/retryablehttp-go\"","+\tmapsutil \"github.com/projectdiscovery/utils/maps\"","+\t\"github.com/stretchr/testify/require\"","+)","+","+type fakeTransport struct {","+\tclosedIdle atomic.Int64","+}","+","+func (f *fakeTransport) RoundTrip(*http.Request) (*http.Response, error) { return nil, nil }","+func (f *fakeTransport) CloseIdleConnections()                           { f.closedIdle.Add(1) }","+","+func newFakeClient(rt http.RoundTripper) (*retryablehttp.Client, error) {","+\treturn retryablehttp.NewWithHTTPClient(&http.Client{Transport: rt}, retryablehttp.DefaultOptionsSingle), nil","+}","+","+func TestHTTPPool_ClientCaching(t *testing.T) {","+\tpool := NewHTTPPool(time.Minute, time.Minute)","+","+\tcreateTransport := func() (http.RoundTripper, error) { return &fakeTransport{}, nil }","+","+\tc1, err := pool.GetOrCreateClient(\"client-a\", \"transport-a\", createTransport, newFakeClient)","+\trequire.NoError(t, err)","+\tc2, err := pool.GetOrCreateClient(\"client-a\", \"transport-a\", createTransport, newFakeClient)","+\trequire.NoError(t, err)","+\trequire.Same(t, c1, c2, \"same client key must hit the cache\")","+","+\tcached, ok := pool.GetClient(\"client-a\")","+\trequire.True(t, ok)","+\trequire.Same(t, c1, cached)","+}","+","+func TestHTTPPool_TransportSharedAcrossClients(t *testing.T) {","+\tpool := NewHTTPPool(time.Minute, time.Minute)","+","+\tvar created atomic.Int64","+\tcreateTransport := func() (http.RoundTripper, error) {","+\t\tcreated.Add(1)","+\t\treturn &fakeTransport{}, nil","+\t}","+","+\tc1, err := pool.GetOrCreateClient(\"client-a\", \"transport-shared\", createTransport, newFakeClient)","+\trequire.NoError(t, err)","+\tc2, err := pool.GetOrCreateClient(\"client-b\", \"transport-shared\", createTransport, newFakeClient)","+\trequire.NoError(t, err)","+","+\trequire.NotSame(t, c1, c2, \"different client keys must produce different clients\")","+\trequire.Same(t, c1.HTTPClient.Transport, c2.HTTPClient.Transport,","+\t\t\"clients with the same transport key must share one transport\")","+\trequire.EqualValues(t, 1, created.Load(), \"transport must be created exactly once\")","+}","+","+func TestHTTPPool_SingleflightCreation(t *testing.T) {","+\tpool := NewHTTPPool(time.Minute, time.Minute)","+","+\tvar transportsCreated, clientsCreated atomic.Int64","+\tcreateTransport := func() (http.RoundTripper, error) {","+\t\ttransportsCreated.Add(1)","+\t\ttime.Sleep(10 * time.Millisecond) // widen the race window","+\t\treturn &fakeTransport{}, nil","+\t}","+\tcreateClient := func(rt http.RoundTripper) (*retryablehttp.Client, error) {","+\t\tclientsCreated.Add(1)","+\t\treturn newFakeClient(rt)","+\t}","+","+\tconst workers = 32","+\tclients := make([]*retryablehttp.Client, workers)","+\tvar wg sync.WaitGroup","+\tfor i := 0; i < workers; i++ {","+\t\twg.Add(1)","+\t\tgo func(idx int) {","+\t\t\tdefer wg.Done()","+\t\t\tc, err := pool.GetOrCreateClient(\"client-key\", \"transport-key\", createTransport, createClient)","+\t\t\trequire.NoError(t, err)","+\t\t\tclients[idx] = c","+\t\t}(i)","+\t}","+\twg.Wait()","+","+\tfor i := 1; i < workers; i++ {","+\t\trequire.Same(t, clients[0], clients[i], \"all concurrent callers must receive the same client\")","+\t}","+\trequire.EqualValues(t, 1, transportsCreated.Load(), \"singleflight must build exactly one transport\")","+\trequire.EqualValues(t, 1, clientsCreated.Load(), \"singleflight must build exactly one client\")","+}","+","+func TestHTTPPool_EvictionClosesIdleConnections(t *testing.T) {","+\tpool := NewHTTPPool(10*time.Millisecond, time.Hour)","+","+\tft := &fakeTransport{}","+\t_, err := pool.GetOrCreateClient(\"client-a\", \"transport-a\",","+\t\tfunc() (http.RoundTripper, error) { return ft, nil }, newFakeClient)","+\trequire.NoError(t, err)","+","+\ttime.Sleep(20 * time.Millisecond)","+\tpool.evictInactive()","+","+\t_, ok := pool.GetClient(\"client-a\")","+\trequire.False(t, ok, \"idle client must be evicted\")","+\trequire.EqualValues(t, 1, ft.closedIdle.Load(), \"evicted transport must close idle connections\")","+}","+","+func TestHTTPPool_ActiveClientKeepsTransportAlive(t *testing.T) {","+\tpool := NewHTTPPool(50*time.Millisecond, time.Hour)","+","+\tft := &fakeTransport{}","+\t_, err := pool.GetOrCreateClient(\"client-a\", \"transport-a\",","+\t\tfunc() (http.RoundTripper, error) { return ft, nil }, newFakeClient)","+\trequire.NoError(t, err)","+","+\t// keep touching the client; the shared transport must stay alive too","+\tfor i := 0; i < 5; i++ {","+\t\ttime.Sleep(20 * time.Millisecond)","+\t\t_, ok := pool.GetClient(\"client-a\")","+\t\trequire.True(t, ok)","+\t\tpool.evictInactive()","+\t}","+\trequire.EqualValues(t, 0, ft.closedIdle.Load(), \"active transport must not be evicted\")","+}","+","+// BenchmarkHTTPPool_GetClientParallel measures the lock-free hit path under","+// contention; compare with BenchmarkSyncLockMap_GetParallel (the previous","+// pool backing) to see the effect of removing per-hit mutex acquisitions.","+func BenchmarkHTTPPool_GetClientParallel(b *testing.B) {","+\tpool := NewHTTPPool(90*time.Second, 30*time.Second)","+\t_, err := pool.GetOrCreateClient(\"key\", \"tkey\",","+\t\tfunc() (http.RoundTripper, error) { return &fakeTransport{}, nil }, newFakeClient)","+\trequire.NoError(b, err)","+","+\tb.ReportAllocs()","+\tb.RunParallel(func(pb *testing.PB) {","+\t\tfor pb.Next() {","+\t\t\tif _, ok := pool.GetClient(\"key\"); !ok {","+\t\t\t\tb.Fatal(\"cache miss\")","+\t\t\t}","+\t\t}","+\t})","+}","+","+// BenchmarkSyncLockMap_GetParallel benchmarks the previous pool backing","+// (mapsutil.SyncLockMap with eviction) for comparison.","+func BenchmarkSyncLockMap_GetParallel(b *testing.B) {","+\tm := mapsutil.NewSyncLockMap(","+\t\tmapsutil.WithEviction[string, *retryablehttp.Client](90*time.Second, 30*time.Second),","+\t)","+\tclient, err := newFakeClient(&fakeTransport{})","+\trequire.NoError(b, err)","+\trequire.NoError(b, m.Set(\"key\", client))","+","+\tb.ReportAllocs()","+\tb.RunParallel(func(pb *testing.PB) {","+\t\tfor pb.Next() {","+\t\t\tif _, ok := m.Get(\"key\"); !ok {","+\t\t\t\tb.Fatal(\"cache miss\")","+\t\t\t}","+\t\t}","+\t})","+}","+","+func TestHTTPPool_Close(t *testing.T) {","+\tpool := NewHTTPPool(time.Minute, time.Minute)","+","+\tft := &fakeTransport{}","+\t_, err := pool.GetOrCreateClient(\"client-a\", \"transport-a\",","+\t\tfunc() (http.RoundTripper, error) { return ft, nil }, newFakeClient)","+\trequire.NoError(t, err)","+","+\tpool.Close()","+","+\t_, ok := pool.GetClient(\"client-a\")","+\trequire.False(t, ok, \"Close must drop all clients\")","+\trequire.EqualValues(t, 1, ft.closedIdle.Load(), \"Close must close idle connections on transports\")","+}"],"additions":183,"deletions":0,"truncated":false},{"path":"pkg/protocols/common/protocolstate/state.go","lines":["@@ -16,7 +16,6 @@ import ("," \t\"github.com/projectdiscovery/networkpolicy\""," \t\"github.com/projectdiscovery/nuclei/v3/pkg/types\""," \t\"github.com/projectdiscovery/nuclei/v3/pkg/utils/e