{"id":"4801b21f31455d3ce6cb33e6233148caba9921c6","axis":"silent","repo":"tinacms/tinacms","sha":"4801b21f31455d3ce6cb33e6233148caba9921c6","parsed":{"files":[{"path":".changeset/standardize-on-date-fns.md","lines":["@@ -0,0 +1,6 @@","+---","+'tinacms': patch","+'@tinacms/graphql': patch","+---","+","+Standardize date handling on date-fns and remove the moment stack. `@tinacms/graphql` moves to date-fns v4 (collapsing the previous v2/v4 split), and `tinacms` drops `moment`, `moment-timezone`, and `react-datetime`. The date-field display label now formats with date-fns via a non-breaking moment→date-fns token converter, so existing `dateFormat`/`timeFormat` schemas (moment token syntax) keep working unchanged. Also removes the orphaned vendored react-datetime views. Net effect: the admin bundle no longer ships moment (~18.6 KB gzip smaller first load)."],"additions":6,"deletions":0,"truncated":false},{"path":"packages/@tinacms/graphql/package.json","lines":["@@ -36,7 +36,7 @@","         \"@tinacms/mdx\": \"workspace:*\",","         \"@tinacms/schema-tools\": \"workspace:*\",","         \"abstract-level\": \"catalog:\",","-        \"date-fns\": \"^2.30.0\",","+        \"date-fns\": \"4.1.0\",","         \"es-toolkit\": \"^1.42.0\",","         \"fast-glob\": \"catalog:\",","         \"fs-extra\": \"catalog:\","],"additions":1,"deletions":1,"truncated":false},{"path":"packages/@tinacms/graphql/src/resolver/index.ts","lines":["@@ -3,7 +3,7 @@"," */"," "," import path from 'path';","-import isValid from 'date-fns/isValid/index.js';","+import { isValid } from 'date-fns';"," import { JSONPath } from 'jsonpath-plus';"," import { NAMER } from '../ast-builder';"," import { Database } from '../database';"],"additions":1,"deletions":1,"truncated":false},{"path":"packages/tinacms/package.json","lines":["@@ -106,13 +106,11 @@","     \"is-hotkey\": \"catalog:\",","     \"lucide-react\": \"catalog:\",","     \"mermaid\": \"^11.12.2\",","-    \"moment\": \"catalog:\",","     \"monaco-