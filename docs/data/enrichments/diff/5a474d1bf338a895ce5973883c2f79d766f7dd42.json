Placed in the Public Domain."," "," tid=\"known hosts command \"","@@ -38,7 +38,10 @@ _EOF"," chmod a+x $OBJ/knownhosts_command"," ${SSH} -F $OBJ/ssh_proxy x true && fail \"ssh connect succeeded with bad exit\""," ","+cp $OBJ/sshd_proxy $OBJ/sshd_proxy.bak"," for keytype in ${SSH_HOSTKEY_TYPES} ; do","+\tgrep -vi HostKeyAlgorithms $OBJ/sshd_proxy.bak > $OBJ/sshd_proxy","+\techo \"HostKeyAlgorithms=+$keytype\" >> $OBJ/sshd_proxy"," \talgs=$keytype"," \ttest \"x$keytype\" = \"xssh-rsa\" && algs=ssh-rsa,rsa-sha2-256,rsa-sha2-512"," \tverbose \"keytype $keytype\""],"additions":4,"deletions":1,"truncated":false},{"path":"regress/unittests/Makefile","lines":["@@ -1,6 +1,6 @@","-#\t$OpenBSD: Makefile,v 1.14 2026/05/31 11:39:44 djm Exp $","+#\t$OpenBSD: Makefile,v 1.15 2026/06/14 04:08:05 djm Exp $"," "," SUBDIR=\ttest_helper sshbuf sshkey bitmap kex hostkeys utf8 match conversion","-SUBDIR+=authopt misc sshsig servconf","+SUBDIR+=authopt misc sshsig servconf crypto"," "," .include <bsd.subdir.mk>"],"additions":2,"deletions":2,"truncated":false},{"path":"regress/unittests/authopt/Makefile","lines":["@@ -1,4 +1,4 @@","-#\t$OpenBSD: Makefile,v 1.12 2026/02/06 23:39:14 dtucker Exp $","+#\t$OpenBSD: Makefile,v 1.13 2026/06/14 04:08:05 djm Exp $"," "," PROG=test_authopt"," SRCS=tests.c","@@ -14,7 +14,7 @@ SRCS+=addr.c addrmatch.c bitmap.c"," SRCS+=cipher-chachapoly.c chacha.c poly1305.c ssh-ecdsa-sk.c ssh-sk.c"," SRCS+=ssh-ed25519-sk.c sk-usbhid.c ssh-pkcs11-client.c"," SRCS+=ssherr-libcrypto.c","-","+SRCS+=ssh-mldsa-eddsa.c libcrux-mlkem-mldsa.c"," SRCS+=digest-openssl.c ed25519-openssl.c"," #SRCS+=digest-libc.c ed25519.c"," SRCS+=utf8.c"],"additions":2,"deletions":2,"truncated":false},{"path":"regress/unittests/crypto/Makefile","lines":["@@ -0,0 +1,26 @@","+#\t$OpenBSD: Makefile,v 1.1 2026/06/14 04:08:05 djm Exp $","+","+PROG=test_crypto","+SRCS=tests.c","+SRCS+=test_mldsa.c","+SRCS+=test_mlkem.c","+SRCS+=test_ed25519.c","+SRCS+=test_mldsa_eddsa.c","+","+# From usr.bin/ssh","+SRCS+=sshbuf-getput-basic.c sshbuf-getput-crypto.c sshbuf-misc.c sshbuf.c","+SRCS+=sshbuf-io.c atomicio.c sshkey.c authfile.c cipher.c log.c ssh-rsa.c","+SRCS+=ssh-ecdsa.c ssh-ed25519.c mac.c umac.c umac128.c hmac.c misc.c","+SRCS+=ssherr.c uidswap.c cleanup.c xmalloc.c match.c krl.c fatal.c","+SRCS+=addr.c addrmatch.c bitmap.c","+SRCS+=cipher-chachapoly.c chacha.c poly1305.c ssh-ecdsa-sk.c ssh-sk.c","+SRCS+=ssh-ed25519-sk.c sk-usbhid.c ssh-pkcs11-client.c","+SRCS+=utf8.c ssherr-libcrypto.c libcrux-mlkem-mldsa.c ssh-mldsa-eddsa.c","+","+SRCS+=digest-openssl.c ed25519-openssl.c","+#SRCS+=digest-libc.c ed25519.c","+","+run-regress-${PROG}: ${PROG}","+\tenv ${TEST_ENV} ./${PROG} ${UNITTEST_ARGS} -d ${.CURDIR}/testdata","+","+.include <bsd.regress.mk>"],"additions":26,"deletions":0,"truncated":false},{"path":"regress/unittests/crypto/test_ed25519.c","lines":["@@ -0,0 +1,104 @@","+/* \t$OpenBSD: test_ed25519.c,v 1.1 2026/06/14 04:08:05 djm Exp $ */","+/*","+ * Regress test for Ed25519 keypair from seed","+ *","+ * Placed in the public domain","+ */","+","+#include <sys/types.h>","+#include <stdio.h>","+#include <stdint.h>","+#include <stdlib.h>","+#include <string.h>","+","+#include \"../test_helper/test_helper.h\"","+#include \"crypto_api.h\"","+#include \"xmalloc.h\"","+","+struct ed25519_kat {","+\tconst char *sk;","+\tconst char *pk;","+\tconst char *msg;","+\tconst char *sig;","+};","+","+static const struct ed25519_kat ed25519_kats[] = {","+\t{","+\t\t\"9d61b19deffd5a60ba844af492ec2cc44449c569\"","+\t\t\"7b326919703bac031cae7f60\",","+\t\t\"d75a980182b10ab7d54bfed3c964073a0ee172f3\"","+\t\t\"daa62325af021a68f707511a\",","+\t\t\"\",","+\t\t\"e5564300c360ac729086e2cc806e828a84877f1e\"","+\t\t\"b8e5d974d873e065224901555fb8821590a33bac\"","+\t\t\"c61e39701cf9b46bd25bf5f0595bbe2465514143\"","+\t\t\"8e7a100b\"","+\t},","+\t{","+\t\t\"4ccd089b28ff96da9db6c346ec114e0f5b8a319f\"","+\t\t\"35aba624da8cf6ed4fb8a6fb\",","+\t\t\"3d4017c3e843895a92b70aa74d1b7ebc9c982ccf\"","+\t\t\"2ec4968cc0cd55f12af4660c\",","+\t\t\"72\",","+\t\t\"92a009a9f0d4cab8720e820b5f642540a2b27b54\"","+\t\t\"16503f8fb3762223ebdb69da085ac1e43e15996e\"","+\t\t\"458f3613d0f11d8c387b2eaeb4302aeeb00d2916\"","+\t\t\"12bb0c00\"","+\t},","+\t{","+\t\t\"c5aa8df43f9f837bedb7442f31dcb7b166d38535\"","+\t\t\"076f094b85ce3a2e0b4458f7\",","+\t\t\"fc51cd8e6218a1a38da47ed00230f0580816ed13\"","+\t\t\"ba3303ac5deb911548908025\",","+\t\t\"af82\",","+\t\t\"6291d657deec24024827e69c3abe01a30ce548a2\"","+\t\t\"84743a445e3680d7db5ac3ac18ff9b538d16f290\"","+\t\t\"ae67f760984dc6594a7c15e9716ed28dc027bece\"","+\t\t\"ea1ec40a\"","+\t}","+};","+","+void ed25519_tests(void);","+","+static void","+hex2bin(uint8_t *bin, const char *hex, size_t len)","+{","+\tsize_t i;","+\tfor (i = 0; i < len; i++)","+\t\tsscanf(hex + i * 2, \"%02hhx\", &bin[i]);","+}","+","+void","+ed25519_tests(void)","+{","+\tuint8_t pk[32], sk[64], seed[32];","+\tuint8_t expected_pk[32], expected_sig[64];","+\tuint8_t *msg, *tmp;","+\tsize_t i, msglen;","+\tunsigned long long smlen;","+","+\tfor (i = 0; i < sizeof(ed25519_kats)/sizeof(ed25519_kats[0]); i++) {","+\t\tTEST_START(\"Ed25519 keypair from seed\");","+\t\thex2bin(seed, ed25519_kats[i].sk, 32);","+\t\thex2bin(expected_pk, ed25519_kats[i].pk, 32);","+\t\tASSERT_INT_EQ(crypto_sign_ed25519_keypair_from_seed(pk, sk, seed), 0);","+\t\tASSERT_MEM_EQ(pk, expected_pk, 32);","+\t\tTEST_DONE();","+","+\t\tTEST_START(\"Ed25519 sign/verify KAT\");","+\t\tmsglen = strlen(ed25519_kats[i].msg) / 2;","+\t\tmsg = malloc(msglen + 64);","+\t\ttmp = malloc(msglen + 64);","+\t\thex2bin(msg + 64, ed25519_kats[i].msg, msglen);","+\t\thex2bin(expected_sig, ed25519_kats[i].sig, 64);","+","+\t\tASSERT_INT_EQ(crypto_sign_ed25519(msg, &smlen, msg + 64, msglen, sk), 0);","+\t\tASSERT_MEM_EQ(msg, expected_sig, 64);","+","+\t\tASSERT_INT_EQ(crypto_sign_ed25519_open(tmp, &smlen, msg, msglen + 64, pk), 0);","+\t\tASSERT_INT_EQ(smlen, msglen);","+\t\tfree(msg);","+\t\tfree(tmp);","+\t\tTEST_DONE();","+\t}","+}"],"additions":104,"deletions":0,"truncated":false},{"path":"regress/unittests/crypto/test_mldsa.c","lines":["@@ -0,0 +1,143 @@","+/* \t$OpenBSD: test_mldsa.c,v 1.1 2026/06/14 04:08:06 djm Exp $ */","+/*","+ * Regress test for ML-DSA","+ *","+ * Placed in the public domain","+ */","+","+#include <sys/types.h>","+#include <stdio.h>","+#include <stdint.h>","+#include <stdlib.h>","+#include <string.h>","+","+#include \"../test_helper/test_helper.h\"","+#include \"crypto_api.h\"","+#include \"xmalloc.h\"","+#include \"sshbuf.h\"","+","+/* in tests.c */","+struct sshbuf *load_text_file(const char *name);","+char *get_json_string(struct sshbuf *content, const char *key, int consume);","+","+void mldsa_tests(void);","+","+struct kat {","+\tchar *seed;","+\tchar *pk_hash;","+\tchar *sk_hash;","+\tchar *msg;","+\tchar *rand;","+\tchar *sig_hash;","+};","+","+static void","+load_kats(const char *file, struct kat ***katsp, size_t *nkatsp)","+{","+\tstruct sshbuf *json_buf;","+\tstruct kat *kat = NULL, **kats = NULL;","+\tsize_t nkats = 0;","+","+\tjson_buf = load_text_file(file);","+\twhile (sshbuf_find(json_buf, 0, \"key_generation_seed\",","+\t    strlen(\"key_generation_seed\"), NULL) == 0) {","+\t\tkat = xcalloc(1, sizeof(*kat));","+\t\tkat->seed = get_json_string(json_buf, \"key_generation_seed\", 1);","+\t\tkat->pk_hash = get_json_string(json_buf,","+\t\t    \"sha3_256_hash_of_verification_key\", 1);","+\t\tkat->sk_hash = get_json_string(json_buf,","+\t\t    \"sha3_256_hash_of_signing_key\", 1);","+\t\tkat->msg = get_json_string(json_buf, \"message\", 1);","+\t\tkat->rand = get_json_string(json_buf, \"signing_randomness\", 1);","+\t\tkat->sig_hash = get_json_string(json_buf,","+\t\t    \"sha3_256_hash_of_signature\", 1);","+\t\tkats = xrecallocarray(kats, nkats, nkats + 1, sizeof(*kats));","+\t\tkats[nkats++] = kat;","+\t}","+\t*katsp = kats;","+\t*nkatsp = nkats;","+\tsshbuf_free(json_buf);","+}","+","+static void","+free_kats(struct kat **kats, size_t nkats)","+{","+\tsize_t i;","+\tstruct kat *kat;","+","+\tfor (i = 0; i < nkats; i++) {","+\t\tkat = kats[i];","+\t\tfree(kat->seed);","+\t\tfree(kat->pk_hash);","+\t\tfree(kat->sk_hash);","+\t\tfree(kat->msg);","+\t\tfree(kat->rand);","+\t\tfree(kat->sig_hash);","+\t\tfree(kat);","+\t}","+\tfree(kats);","+}","+","+static void","+hex2bin(uint8_t *bin, const char *hex, size_t len)","+{","+\tsize_t i;","+\tfor (i = 0; i < len; i++)","+\t\tsscanf(hex + i * 2, \"%02hhx\", &bin[i]);","+}","+","+void","+mldsa_tests(void)","+{","+\tuint8_t pk[MLDSA44_PUBLICKEYBYTES];","+\tuint8_t sk[MLDSA44_SECRETKEYBYTES];","+\tuint8_t sig[MLDSA44_SIGBYTES];","+\tuint8_t pk_hash[32], sk_hash[32], sig_hash[32];","+\tuint8_t expected_pk_hash[32], expected_sk_hash[32];","+\tuint8_t expected_sig_hash[32];","+\tuint8_t seed[32], rand[32];","+\tuint8_t *msg;","+\tsize_t nkats, i, msglen;","+\tstruct kat **kats, *kat;","+","+\tTEST_START(\"ML-DSA 44 KATs\");","+\tload_kats(\"nistkats-44.json\", &kats, &nkats);","+\tfor (i = 0; i < nkats; i++) {","+\t\tkat = kats[i];","+\t\ttest_subtest_info(\"vector %zu\", i);","+","+\t\thex2bin(seed, kat->seed, 32);","+\t\thex2bin(expected_pk_hash, kat->pk_hash, 32);","+\t\thex2bin(expected_sk_hash, kat->sk_hash, 32);","+","+\t\t/* Keypair generation */","+\t\tASSERT_INT_EQ(crypto_sign_mldsa44_keypair_seeded(pk,","+\t\t    sk, seed), 0);","+","+\t\tsha3_256(pk_hash, pk, sizeof(pk));","+\t\tsha3_256(sk_hash, sk, sizeof(sk));","+","+\t\tASSERT_MEM_EQ(pk_hash, expected_pk_hash, 32);","+\t\tASSERT_MEM_EQ(sk_hash, expected_sk_hash, 32);","+","+\t\tmsglen = strlen(kat->msg) / 2;","+\t\tmsg = malloc(msglen);","+\t\thex2bin(msg, kat->msg, msglen);","+\t\thex2bin(rand, kat->rand, 32);","+\t\thex2bin(expected_sig_hash, kat->sig_hash, 32);","+","+\t\t/* Signing */","+\t\tASSERT_INT_EQ(crypto_sign_mldsa44_seeded(sig, msg,","+\t\t    msglen, NULL, 0, sk, rand), 0);","+","+\t\tsha3_256(sig_hash, sig, sizeof(sig));","+\t\tASSERT_MEM_EQ(sig_hash, expected_sig_hash, 32);","+","+\t\t/* Verification */","+\t\tASSERT_INT_EQ(crypto_sign_mldsa44_verify(sig, msg,","+\t\t    msglen, NULL, 0, pk), 0);","+\t\tfree(msg);","+\t}","+\tfree_kats(kats, nkats);","+\tTEST_DONE();","+}"],"additions":143,"deletions":0,"truncated":false},{"path":"regress/unittests/crypto/test_mldsa_eddsa.c","lines":["@@ -0,0 +1,192 @@","+/* \t$OpenBSD: test_mldsa_eddsa.c,v 1.1 2026/06/14 04:08:06 djm Exp $ */","+/*","+ * Regress test for MLDSA44-Ed25519 composite signature","+ *","+ * Placed in the public domain","+ */","+","+#include <sys/types.h>","+#include <stdio.h>","+#include <stdint.h>","+#include <stdlib.h>","+#include <string.h>","+#include <ctype.h>","+#include <fcntl.h>","+#include <unistd.h>","+","+#include \"../test_helper/test_helper.h\"","+#include \"crypto_api.h\"","+#include \"ssherr.h\"","+#include \"sshkey.h\"","+#include \"sshbuf.h\"","+#include \"log.h\"","+","+/* in tests.c */","+struct sshbuf *load_text_file(const char *name);","+char *get_json_string(struct sshbuf *content, const char *key, int consume);","+","+void mldsa_eddsa_tests(void);","+","+/*","+ * Simple JSON-ish parser for tvec.json.","+ * Extracts the base64 value for a given key and decodes it into a new sshbuf.","+ * Errors cause ASSERT_* failures.","+ */","+static struct sshbuf *","+get_json_b64(struct sshbuf *content, const char *key)","+{","+\tchar *b64;","+\tstruct sshbuf *ret;","+","+\tb64 = get_json_string(content, key, 0);","+\tASSERT_PTR_NE(ret = sshbuf_new(), NULL);","+\tASSERT_INT_EQ(sshbuf_b64tod(ret, b64), 0);","+\tfree(b64);","+\treturn ret;","+}","+","+static void","+onerror(void *fuzz)","+{","+\tfprintf(stderr, \"Failed during fuzz:\\n\");","+\tfuzz_dump((struct fuzz *)fuzz);","+}","+","+static void","+sig_fuzz(const uint8_t *m, size_t m_len, const uint8_t *ctx, size_t ctx_len,","+    const uint8_t *pk, const uint8_t *s)","+{","+\tstruct fuzz *fuzz;","+\tu_int fuzzers = FUZZ_1_BIT_FLIP | FUZZ_1_BYTE_FLIP;","+","+\tif (test_is_fast())","+\t\tfuzzers &= ~FUZZ_1_BIT_FLIP;","+\tif (test_is_slow())","+\t\tfuzzers |= FUZZ_2_BYTE_FLIP; /* FUZZ_2_BIT_FLIP much too slow */","+","+\tASSERT_INT_EQ(crypto_sign_mldsa44_ed25519_verify(s, m, m_len,","+\t    ctx, ctx_len, pk), 0);","+\tfuzz = fuzz_begin(fuzzers, s, MLDSA44_ED25519_SIG_SZ);","+\tTEST_ONERROR(onerror, fuzz);","+\tfor(; !fuzz_done(fuzz); fuzz_next(fuzz)) {","+\t\t/* Ensure 1-bit difference at least */","+\t\tif (fuzz_matches_original(fuzz))","+\t\t\tcontinue;","+\t\tASSERT_INT_NE(crypto_sign_mldsa44_ed25519_verify(fuzz_ptr(fuzz),","+\t\t    m, m_len, ctx, ctx_len, pk), 0);","+\t}","+\tfuzz_cleanup(fuzz);","+}","+","+","+void","+mldsa_eddsa_tests(void)","+{","+\tuint8_t pk[MLDSA44_ED25519_PK_SZ];","+\tuint8_t sk[MLDSA44_ED25519_SK_SZ];","+\tuint8_t sig[MLDSA44_ED25519_SIG_SZ];","+\tstruct sshbuf *b_m = NULL, *b_ctx = NULL, *b_pk = NULL;","+\tstruct sshbuf *b_sk = NULL, *b_s = NULL, *b_sWithContext = NULL;","+\tstruct sshbuf *json_buf = NULL;","+\tconst uint8_t *tvec_m;","+\tsize_t tvec_m_len;","+\tconst uint8_t *tvec_ctx;","+\tsize_t tvec_ctx_len;","+\tconst uint8_t *tvec_pk;","+\tconst uint8_t *tvec_sk;","+\tconst uint8_t *tvec_s;","+\tconst uint8_t *tvec_sWithContext;","+","+\tTEST_START(\"MLDSA44-Ed25519-SHA512 load test vectors\");","+\tjson_buf = load_text_file(\"draft-ietf-lamps-pq-composite-sigs.json\");","+\tb_m = get_json_b64(json_buf, \"m\");","+\tb_ctx = get_json_b64(json_buf, \"ctx\");","+\tb_pk = get_json_b64(json_buf, \"pk\");","+\tb_sk = get_json_b64(json_buf, \"sk\");","+\tb_s = get_json_b64(json_buf, \"s\");","+\tb_sWithContext = get_json_b64(json_buf, \"sWithContext\");","+\tASSERT_INT_EQ(sshbuf_len(b_pk), MLDSA44_ED25519_PK_SZ);","+\tASSERT_INT_EQ(sshbuf_len(b_sk), MLDSA44_ED25519_SK_SZ);","+\tASSERT_INT_EQ(sshbuf_len(b_s), MLDSA44_ED25519_SIG_SZ);","+\tASSERT_INT_EQ(sshbuf_len(b_sWithContext), MLDSA44_ED25519_SIG_SZ);","+\tTEST_DONE();","+","+\ttvec_m = sshbuf_ptr(b_m);","+\ttvec_m_len = sshbuf_len(b_m);","+\ttvec_ctx = sshbuf_ptr(b_ctx);","+\ttvec_ctx_len = sshbuf_len(b_ctx);","+\ttvec_pk = sshbuf_ptr(b_pk);","+\ttvec_sk = sshbuf_ptr(b_sk);","+\ttvec_s = sshbuf_ptr(b_s);","+\ttvec_sWithContext = sshbuf_ptr(b_sWithContext);","+","+\tTEST_START(\"MLDSA44-Ed25519-SHA512 raw self-consistency\");","+\tASSERT_INT_EQ(crypto_sign_mldsa44_ed25519_keygen(pk, sk), 0);","+\tASSERT_INT_EQ(crypto_sign_mldsa44_ed25519_sign(sig,","+\t    tvec_m, tvec_m_len, tvec_ctx, tvec_ctx_len, sk), 0);","+\tASSERT_INT_EQ(crypto_sign_mldsa44_ed25519_verify(sig,","+\t    tvec_m, tvec_m_len, tvec_ctx, tvec_ctx_len, pk), 0);","+\tTEST_DONE();","+","+\tTEST_START(\"MLDSA44-Ed25519-SHA512 raw KAT key expansion\");","+\tuint8_t pk_expanded[MLDSA44_ED25519_PK_SZ];","+\tuint8_t sk_expanded[MLDSA44_ED25519_SK_SZ];","+","+\t/* Expansion: mldsa_seed (sk[0:32]) and ed25519_seed (sk[32:64]) */","+\tASSERT_INT_EQ(crypto_sign_mldsa44_ed25519_keygen_seeded(pk_expanded,","+\t    sk_expanded, tvec_sk, tvec_sk + 32), 0);","+\tASSERT_MEM_EQ(pk_expanded, tvec_pk, MLDSA44_ED25519_PK_SZ);","+\t/* sk_expanded should also match tvec_sk */","+\tASSERT_MEM_EQ(sk_expanded, tvec_sk, MLDSA44_ED25519_SK_SZ);","+\tTEST_DONE();","+","+\tTEST_START(\"MLDSA44-Ed25519-SHA512 raw KAT verify (no context)\");","+\tASSERT_INT_EQ(crypto_sign_mldsa44_ed25519_verify(tvec_s, tvec_m,","+\t    tvec_m_len, NULL, 0, tvec_pk), 0);","+\tTEST_DONE();","+","+\tTEST_START(\"MLDSA44-Ed25519-SHA512 raw KAT verify (with context)\");","+\tASSERT_INT_EQ(crypto_sign_mldsa44_ed25519_verify(tvec_sWithContext,","+\t    tvec_m, tvec_m_len, tvec_ctx, tvec_ctx_len, tvec_pk), 0);","+\tTEST_DONE();","+","+\tTEST_START(\"MLDSA44-Ed25519-SHA512 raw round-trip (no context)\");","+\tASSERT_INT_EQ(crypto_sign_mldsa44_ed25519_sign(sig, tvec_m, tvec_m_len,","+\t    NULL, 0, tvec_sk), 0);","+\tASSERT_INT_EQ(crypto_sign_mldsa44_ed25519_verify(sig,","+\t    tvec_m, tvec_m_len, NULL, 0, tvec_pk), 0);","+\tTEST_DONE();","+","+\tTEST_START(\"MLDSA44-Ed25519-SHA512 raw round-trip (with context)\");","+\tASSERT_INT_EQ(crypto_sign_mldsa44_ed25519_sign(sig,","+\t    tvec_m, tvec_m_len, tvec_ctx, tvec_ctx_len, tvec_sk), 0);","+\tASSERT_INT_EQ(crypto_sign_mldsa44_ed25519_verify(sig,","+\t    tvec_m, tvec_m_len, tvec_ctx, tvec_ctx_len, tvec_pk), 0);","+\tTEST_DONE();","+","+\tTEST_START(\"MLDSA44-Ed25519-SHA512 raw KAT verify (no context)\");","+\tASSERT_INT_EQ(crypto_sign_mldsa44_ed25519_verify(tvec_s, tvec_m,","+\t    tvec_m_len, NULL, 0, tvec_pk), 0);","+\tTEST_DONE();","+","+\tTEST_START(\"MLDSA44-Ed25519-SHA512 fuzz raw verify (with context)\");","+\tASSERT_INT_EQ(crypto_sign_mldsa44_ed25519_verify(tvec_sWithContext,","+\t    tvec_m, tvec_m_len, tvec_ctx, tvec_ctx_len, tvec_pk), 0);","+\tsig_fuzz(tvec_m, tvec_m_len, NULL, 0, tvec_pk, tvec_s);","+\tTEST_DONE();","+","+\tTEST_START(\"MLDSA44-Ed25519-SHA512 fuzz raw verify (with context)\");","+\tASSERT_INT_EQ(crypto_sign_mldsa44_ed25519_verify(tvec_sWithContext,","+\t    tvec_m, tvec_m_len, tvec_ctx, tvec_ctx_len, tvec_pk), 0);","+\tsig_fuzz(tvec_m, tvec_m_len, tvec_ctx, tvec_ctx_len,","+\t    tvec_pk, tvec_sWithContext);","+\tTEST_DONE();","+","+\tsshbuf_free(json_buf);","+\tsshbuf_free(b_m);","+\tsshbuf_free(b_ctx);","+\tsshbuf_free(b_pk);","+\tsshbuf_free(b_sk);","+\tsshbuf_free(b_s);","+\tsshbuf_free(b_sWithContext);","+}"],"additions":192,"deletions":0,"truncated":false},{"path":"regress/unittests/crypto/test_mlkem.c","lines":["@@ -0,0 +1,167 @@","+/* \t$OpenBSD: test_mlkem.c,v 1.1 2026/06/14 04:08:06 djm Exp $ */","+/*","+ * Regress test for ML-KEM","+ *","+ * Placed in the public domain","+ */","+","+#include <sys/types.h>","+#include <stdio.h>","+#include <stdint.h>","+#include <stdlib.h>","+#include <string.h>","+","+#include \"../test_helper/test_helper.h\"","+#include \"crypto_api.h\"","+","+struct mlkem768_kat {","+\tconst char *seed;","+\tconst char *pk_hash;","+\tconst char *sk_hash;","+\tconst char *enc_seed;","+\tconst char *ct_hash;","+\tconst char *shared_secret;","+};","+","+static const struct mlkem768_kat mlkem768_kats[] = {","+\t{","+\t