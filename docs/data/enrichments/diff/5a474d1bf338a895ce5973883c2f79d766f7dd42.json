 %zu\", i);","+","+\t\thex2bin(seed, mlkem768_kats[i].seed, 64);","+\t\thex2bin(expected_pk_hash, mlkem768_kats[i].pk_hash, 32);","+\t\thex2bin(expected_sk_hash, mlkem768_kats[i].sk_hash, 32);","+","+\t\t/* Keypair generation */","+\t\tASSERT_INT_EQ(crypto_kem_mlkem768_keypair_seeded(pk, sk, seed), 0);","+","+\t\tsha3_256(pk_hash, pk, sizeof(pk));","+\t\tsha3_256(sk_hash, sk, sizeof(sk));","+","+\t\tASSERT_MEM_EQ(pk_hash, expected_pk_hash, 32);","+\t\tASSERT_MEM_EQ(sk_hash, expected_sk_hash, 32);","+","+\t\thex2bin(enc_seed, mlkem768_kats[i].enc_seed, 32);","+\t\thex2bin(expected_ct_hash, mlkem768_kats[i].ct_hash, 32);","+\t\thex2bin(expected_shared_secret,","+\t\t    mlkem768_kats[i].shared_secret, 32);","+","+\t\t/* Encapsulation */","+\t\tASSERT_INT_EQ(crypto_kem_mlkem768_enc_seeded(ct, shared_secret,","+\t\t    pk, enc_seed), 0);","+","+\t\tsha3_256(ct_hash, ct, sizeof(ct));","+\t\tASSERT_MEM_EQ(ct_hash, expected_ct_hash, 32);","+\t\tASSERT_MEM_EQ(shared_secret, expected_shared_secret, 32);","+","+\t\t/* Decapsulation */","+\t\tASSERT_INT_EQ(crypto_kem_mlkem768_dec(shared_secret2, ct, sk), 0);","+\t\tASSERT_MEM_EQ(shared_secret, shared_secret2, 32);","+\t}","+\tTEST_DONE();","+}"],"additions":167,"deletions":0,"truncated":false},{"path":"regress/unittests/crypto/testdata/draft-ietf-lamps-pq-composite-sigs.json","lines":["@@ -0,0 +1,8 @@","+    {","+      \"m\": \"VGhlIHF1aWNrIGJyb3duIGZveCBqdW1wcyBvdmVyIHRoZSBsYXp5IGRvZy4=\",","+      \"ctx\": \"VGhlIGxldGhhcmdpYywgY29sb3JsZXNzIGRvZyBzYXQgYmVuZWF0aCB0aGUgZW5lcmdldGljLCBzdGF0aW9uYXJ5IGZveC4=\",","+      \"pk\": \"\",","+      \"sk\": \"AdjfWRUtikTjmiXmd17xigBEsg5YwsQ0asN8J9FSF2xb6mwkVGF7+0hHnrixO3EamBFrc/fsrDD68d2bT6F9aA==\",","+      \"s\": \"\","],"additions":6,"deletions":0,"truncated":false}],"additions":694,"deletions":13,"truncated":true,"file_count":13},"error":null,"fetched_at":"2026-06-14T10:40:42.181367+00:00"}