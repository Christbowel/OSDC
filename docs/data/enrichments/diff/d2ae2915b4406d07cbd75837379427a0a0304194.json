 during a redirect or in-page navigation. */","+\treadonly url?: string;","+\treadonly title?: string;","+\t/** Favicon data URI; hashed and deduped against the sibling favicons store. Pass `null` to explicitly clear. */","+\treadonly favicon?: string | null;","+}","+","+/**","+ * Handle returned by {@link BrowserHistoryStore.add}. `update` and `delete`","+ * are no-ops once the underlying entry has been evicted.","+ */","+export interface IBrowserHistoryItemHandle {","+\treadonly id: number;","+\tupdate(patch: IBrowserHistoryUpdate): void;","+\tdelete(): void;","+}","+","+/** Returned by {@link BrowserHistoryStore.add} when the store is disabled (max entries = 0). */","+const NOOP_HANDLE: IBrowserHistoryItemHandle = Object.freeze({","+\tid: -1,","+\tupdate: () => { },","+\tdelete: () => { },","+});","+","+/**","+ * On-disk shape of an entries snapshot. See {@link ISerializedBrowserHistoryEntry}","+ * for the backwards-compatibility rules; the same constraints apply here.","+ */","+export interface ISerializedBrowserHistoryEntriesSnapshot {","+\treadonly items: readonly ISerializedBrowserHistoryEntry[];","+}","+","+/**","+ * On-disk shape of a favicons snapshot. See {@link ISerializedBrowserHistoryEntry}","+ * for the backwards-compatibility rules; the same constraints apply here.","+ */","+export interface ISerializedBrowserFaviconsSnapshot {","+\t/** Map from content hash to data URI. */","+\treadonly map: Readonly<Record<string, string>>;","+}","+","+const DEFAULT_MAX_ENTRIES = 200;","+","+export class BrowserHistoryEntriesStore extends Disposable {","+","+\tprivate _nextId: number = 1;","+\tprivate _items: IBrowserHistoryEntry[] = [];","+\tprivate _maxEntries: number;","+","+\tprivate readonly _onDidChange = this._register(new Emitter<void>());","+\treadonly onDidChange: Event<void> = this._onDidChange.event;","+","+\tconstructor(maxEntries: number = DEFAULT_MAX_ENTRIES) {","+\t\tsuper();","+\t\tthis._maxEntries = maxEntries;","+\t}","+","+\tget items(): readonly IBrowserHistoryEntry[] {","+\t\treturn this._items;","+\t}","+","+\tget maxEntries(): number {","+\t\treturn this._maxEntries;","+\t}","+","+\tsetMaxEntries(max: number): void {","+\t\tif (max < 0 || max === this._maxEntries) {","+\t\t\treturn;","+\t\t}","+\t\tthis._maxEntries = max;","+\t\tif (this._evictIfNeeded()) {","+\t\t\tthis._onDidChange.fire();","+\t\t}","+\t}","+","+\tadd(url: string, title: string, faviconHash: string | undefined, userInitiated: boolean): IBrowserHistoryEntry {","+\t\tconst entry: IBrowserHistoryEntry = userInitiated","+\t\t\t? { id: this._nextId++, url, time: Date.now(), title, icon: faviconHash, explicit: true }","+\t\t\t: { id: this._nextId++, url, time: Date.now(), title, icon: faviconHash };","+\t\tthis._items.push(entry);","+\t\tthis._evictIfNeeded();","+\t\tthis._onDidChange.fire();","+\t\treturn entry;","+\t}","+","+\tupdate(id: number, patch: { url?: string; title?: string; faviconHash?: string | null }): boolean {","+\t\tconst idx = this._indexOf(id);","+\t\tif (idx === -1) {","+\t\t\treturn false;","+\t\t}","+\t\tconst existing = this._items[idx];","+\t\tconst nextTitle = patch.title && patch.title.length > 0 ? patch.title : existing.title;","+\t\tconst nextUrl = patch.url && patch.url.length > 0 ? patch.url : existing.url;","+\t\t// Distinguish \"leave alone\" (undefined) from explicit clear (null).","+\t\tconst nextFaviconHash = patch.faviconHash === undefined","+\t\t\t? existing.icon","+\t\t\t: (patch.faviconHash ?? undefined);","+\t\tif (nextUrl === existing.url && nextTitle === existing.title && nextFaviconHash === existing.icon) {","+\t\t\treturn false;","+\t\t}","+\t\tthis._items[idx] = { ...existing, url: nextUrl, title: nextTitle, icon: nextFaviconHash };","+\t\tthis._onDidChange.fire();","+\t\treturn true;","+\t}","+","+\tdelete(id: number): boolean {","+\t\tconst idx = this._indexOf(id);","+\t\tif (idx === -1) {","+\t\t\treturn false;","+\t\t}","+\t\tthis._items.splice(idx, 1);","+\t\tthis._onDidChange.fire();","+\t\treturn true;","+\t}","+","+\tclear(): void {","+\t\tif (this._items.length === 0 && this._nextId === 1) {","+\t\t\treturn;","+\t\t}","+\t\tthis._items = [];","+\t\tthis._nextId = 1;","+\t\tthis._onDidChange.fire();","+\t}","+","+\tserialize(): ISerializedBrowserHistoryEntriesSnapshot {","+\t\treturn { items: this._items.slice() };","+\t}","+","+\thydrate(snapshot: ISerializedBrowserHistoryEntriesSnapshot | undefined): void {","+\t\tthis._items = [];","+\t\tthis._nextId = 1;","+\t\tif (snapshot && Array.isArray(snapshot.items)) {","+\t\t\tfor (const e of snapshot.items) {","+\t\t\t\tif (isValidEntry(e)) {","+\t\t\t\t\tthis._items.push(e);","+\t\t\t\t}","+\t\t\t}","+\t\t\t// Restored ids must not collide with future adds.","+\t\t\tfor (const e of this._items) {","+\t\t\t\tif (e.id >= this._nextId) {","+\t\t\t\t\tthis._nextId = e.id + 1;","+\t\t\t\t}","+\t\t\t}","+\t\t\tthis._evictIfNeeded();","+\t\t}","+\t\tthis._onDidChange.fire();","+\t}","+","+\tprivate _indexOf(id: number): number {","+\t\t// Walk newest-first; mutations target the just-added entry in the common case.","+\t\tfor (let i = this._items.length - 1; i >= 0; i--) {","+\t\t\tif (this._items[i].id === id) {","+\t\t\t\treturn i;","+\t\t\t}","+\t\t}","+\t\treturn -1;","+\t}","+","+\tprivate _evictIfNeeded(): boolean {","+\t\tif (this._items.length > this._maxEntries) {","+\t\t\tthis._items.splice(0, this._items.length - this._maxEntries);","+\t\t\treturn true;","+\t\t}","+\t\treturn false;","+\t}","+}","+","+/**","+ * Lives separately from {@link BrowserHistoryEntriesStore} so the (large)","+ * favicon map is only rewritten when an image is added or removed, not on","+ * every navigation.","+ */","+export class BrowserFaviconsStore extends Disposable {","+","+\tprivate readonly _byHash = new Map<string, string>();","+","+\tprivate readonly _onDidChange = this._register(new Emitter<void>());","+\treadonly onDidChange: Event<void> = this._onDidChange.event;","+","+\tget(hash: string): string | undefined {","+\t\treturn this._byHash.get(hash);","+\t}","+","+\tregister(dataUri: string): string {","+\t\tconst sha = new StringSHA1();","+\t\tsha.update(dataUri);","+\t\tconst hash = sha.digest();","+\t\tif (!this._byHash.has(hash)) {","+\t\t\tthis._byHash.set(hash, dataUri);","+\t\t\tthis._onDidChange.fire();","+\t\t}","+\t\treturn hash;","+\t}","+","+\tgc(referenced: ReadonlySet<string>): void {","+\t\tif (this._byHash.size === 0) {","+\t\t\treturn;","+\t\t}","+\t\tlet changed = false;","+\t\tfor (const hash of this._byHash.keys()) {","+\t\t\tif (!referenced.has(hash)) {","+\t\t\t\tthis._byHash.delete(hash);","+\t\t\t\tchanged = true;","+\t\t\t}","+\t\t}","+\t\tif (changed) {","+\t\t\tthis._onDidChange.fire();","+\t\t}","+\t}","+","+\tclear(): void {","+\t\tif (this._byHash.size === 0) {","+\t\t\treturn;","+\t\t}","+\t\tthis._byHash.clear();","+\t\tthis._onDidChange.fire();","+\t}","+","+\tserialize(): ISerializedBrowserFaviconsSnapshot {","+\t\treturn { map: Object.fromEntries(this._byHash) };","+\t}","+","+\thydrate(snapshot: ISerializedBrowserFaviconsSnapshot | undefined): void {","+\t\tthis._byHash.clear();","+\t\tif (snapshot?.map && typeof snapshot.map === 'object') {","+\t\t\tfor (const [k, v] of Object.entries(snapshot.map)) {","+\t\t\t\tif (typeof v === 'string') {","+\t\t\t\t\tthis._byHash.set(k, v);","+\t\t\t\t}","+\t\t\t}","+\t\t}","+\t\tthis._onDidChange.fire();","+\t}","+}","+","+/**","+ * Per-session browser history. The two sub-stores are exposed directly so","+ * persistence layers can flush them independently.","+ */","+export class BrowserHistoryStore extends Disposable {","+","+\treadonly entries: BrowserHistoryEntriesStore;","+\treadonly favicons: BrowserFaviconsStore;","+","+\tprivate readonly _onDidChange = this._register(new Emitter<void>());","+\treadonly onDidChange: Event<void> = this._onDidChange.event;","+","+\tconstructor(maxEntries?: number) {","+\t\tsuper();","+\t\tthis.entries = this._register(new BrowserHistoryEntriesStore(maxEntries));","+\t\tthis.favicons = this._register(new BrowserFaviconsStore());","+","+\t\tthis._register(this.entries.onDidChange(() => {","+\t\t\tthis._gcFavicons();","+\t\t\tthis._onDidChange.fire();","+\t\t}));","+\t\tthis._register(this.favicons.onDidChange(() => this._onDidChange.fire()));","+\t}","+","+\tadd(url: string, title: string, favicon?: string, userInitiated = false): IBrowserHistoryItemHandle {","+\t\tif (this.entries.maxEntries === 0) {","+\t\t\t// History disabled: skip favicon hashing and entry creation entirely.","+\t\t\treturn NOOP_HANDLE;","+\t\t}","+\t\tconst faviconHash = favicon ? this.favicons.register(favicon) : undefined;","+\t\tconst entry = this.entries.add(url, title, faviconHash, userInitiated);","+\t\treturn this._handleFor(entry.id);","+\t}","+","+\tsetMaxEntries(max: number): void {","+\t\tthis.entries.setMaxEntries(max);","+\t}","+","+\tclear(): void {","+\t\tthis.entries.clear();","+\t\tthis.favicons.clear();","+\t}","+","+\tprivate _handleFor(id: number): IBrowserHistoryItemHandle {","+\t\treturn {","+\t\t\tid,","+\t\t\tupdate: patch => {","+\t\t\t\tconst next: { url?: string; title?: string; faviconHash?: string | null } = {};","+\t\t\t\tif (patch.url !== undefined) {","+\t\t\t\t\tnext.url = patch.url;","+\t\t\t\t}","+\t\t\t\tif (patch.title !== undefined) {","+\t\t\t\t\tnext.title = patch.title;","+\t\t\t\t}","+\t\t\t\tif (patch.favicon !== undefined) {","+\t\t\t\t\t// null is the explicit-clear sentinel; a data URI registers and references it.","+\t\t\t\t\tnext.faviconHash = patch.favicon === null ? null : this.favicons.register(patch.favicon);","+\t\t\t\t}","+\t\t\t\tthis.entries.update(id, next);","+\t\t\t},","+\t\t\tdelete: () => {","+\t\t\t\tthis.entries.delete(id);","+\t\t\t},","+\t\t};","+\t}","+","+\tprivate _gcFavicons(): void {","+\t\tconst referenced = new Set<string>();","+\t\tfor (const e of this.entries.items) {","+\t\t\tif (e.icon) {","+\t\t\t\treferenced.add(e.icon);","+\t\t\t}","+\t\t}","+\t\tthis.favicons.gc(referenced);","+\t}","+}","+","+function isValidEntry(value: unknown): value is ISerializedBrowserHistoryEntry {","+\tif (!value || typeof value !== 'object') {","+\t\treturn false;","+\t}","+\tconst e = value as ISerializedBrowserHistoryEntry;","+\treturn typeof e.id === 'number'","+\t\t&& typeof e.url === 'string'","+\t\t&& typeof e.time === 'number'","+\t\t&& typeof e.title === 'string'","+\t\t&& (e.icon === undefined || typeof e.icon === 'string')","+\t\t&& (e.explicit === undefined || e.explicit === true);","+}"],"additions":362,"deletions":0,"truncated":false},{"path":"src/vs/platform/browserView/common/browserView.ts","lines":["@@ -33,6 +33,9 @@ export enum BrowserViewCommandId {"," \tAddFavorite = `${commandPrefix}.addFavorite`,"," \tRemoveFavorite = `${commandPrefix}.removeFavorite`,"," ","+\t// History","+\tShowHistory = `${commandPrefix}.showHistory`,","+"," \t// Chat actions"," \tAddElementToChat = `${commandPrefix}.addElementToChat`,"," \tAddConsoleLogsToChat = `${commandPrefix}.addConsoleLogsToChat`,","@@ -89,6 +92,8 @@ export interface IBrowserViewTheme {"," "," export interface IBrowserViewConfiguration {"," \treadonly aiFeaturesDisabled?: boolean;","+\t/** Maximum number of entries to retain per browser session history. */","+\treadonly maxHistoryEntries?: number;"," }"," "," export interface IBrowserViewBounds {","@@ -180,6 +185,12 @@ export interface IBrowserViewCreateOptions {"," \treadonly initialState?: Partial<IBrowserViewState>;"," }"," ","+/** `applicationSharedStorage` keys this session writes to. Empty for ephemeral sessions. */","+export interface IBrowserViewStorageKeys {","+\treadonly history?: string;","+\treadonly favicons?: string;","+}","+"," export interface IBrowserViewState {"," \turl: string;"," \ttitle: string;","@@ -194,6 +205,7 @@ export interface IBrowserViewState {"," \tlastError: IBrowserViewLoadError | undefined;"," \tcertificateError: IBrowserViewCertificateError | undefined;"," \tstorageScope: BrowserViewStorageScope;","+\tstorageKe