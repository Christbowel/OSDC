{"id":"9a53f77d35e76bcb0165b44cbd2b7e48d48c9f59","axis":"silent","repo":"withastro/astro","sha":"9a53f77d35e76bcb0165b44cbd2b7e48d48c9f59","parsed":{"files":[{"path":".changeset/clear-planets-divide.md","lines":["@@ -0,0 +1,66 @@","+---","+'@astrojs/cloudflare': minor","+---","+","+Adds an opt-in CDN cache provider for Astro [route caching](https://docs.astro.build/en/guides/caching/) on Cloudflare Workers","+","+> [!WARNING]","+> This provider requires the Cloudflare Workers Cache feature, which is currently in private beta. It is opt-in: nothing changes unless you import `cacheCloudflare()` and set it as your provider. But without beta access it does not work and should not be used. Cloudflare Workers run in front of the cache, so cached responses are never served, and calling `cache.invalidate()` throws an error.","+","+#### Setup","+","+Import `cacheCloudflare()` from `@astrojs/cloudflare/cache` and set it as your cache provider:","+","+```js","+import { defineConfig } from 'astro/config';","+import cloudflare from '@astrojs/cloudflare';","+import { cacheCloudflare } from '@astrojs/cloudflare/cache';","+","+export default defineConfig({","+  adapter: cloudflare(),","+  cache: {","+    provider: cacheCloudflare(),","+  },","+});","+```","+","+The adapter automatically enables the Worker caching layer when a Cloudflare cache provider is configured. No manual wrangler.jsonc changes are needed.","+","+#### Caching responses","+","+Use `Astro.cache.set()` in your pages and API routes to cache responses. The provider sets `Cloudflare-CDN-Cache-Control` and `Cache-Tag` headers, which are read by Cloudflare's built-in caching layer. Cache hits bypass Worker execution entirely, meaning your Worker is not invoked for cached responses.","+","+```astro","+---","+Astro.cache.set({ maxAge: 300, tags: ['products'] });","+const data = await fetchProducts();","+---","+<ProductList items={data} />","+```","+","+You can also set cache rules for groups of routes in your config:","+","+```js","+cache: { provider: cacheCloudflare() },","+routeRules: {","+  '/products/[...slug]': { maxAge: 3600, tags: ['products'] },","+  '/api/[...path]': { maxAge: 60, swr: 600 },","+},","+```","+","+#### Invalidation","+","+Purge cached responses by tag or path from any API route or server endpoint:","+","+```ts","+// src/pages/api/purge.ts","+export async function POST({ request, cache }) {","+  await cache.invalidate({ tags: ['products'] });","+  return new Response('Purged');","+}","+","+// Path-based invalidation (implemented via an auto-generated path tag)","+await cache.invalidate({ path: '/products/123' });","+```","+","+Both tag-based and path-based invalidation are supported."],"additions":66,"deletions":0,"truncated":false},{"path":".changeset/dry-olives-glow.md","lines":["@@ -0,0 +1,7 @@","+---","+'astro': patch","+---","+","+Adds shared helper utilities for CDN cache provider authors for [route caching](https://docs.astro.build/en/guides/caching/)","+","+Exports `astro/cache/provider-utils` with helpers for building platform-specific cache-control headers, generating path-based invalidation tags, and normalizing invalidation options. These are used internally by the first-party Netlify, Vercel, and Cloudflare cache providers."],"additions":7,"deletions":0,"truncated":false},{"path":".changeset/green-tools-wear.md","lines":["@@ -0,0 +1,61 @@","+---","+'@astrojs/vercel': minor","+---","+","+Adds a CDN cache provider for Astro [route caching](https://docs.astro.build/en/guides/caching/) on Vercel","+","+#### Setup","+","+Import `cacheVercel()` from `@astrojs/vercel/cache` and set it as your cache provider:","+","+```js","+import { defineConfig } from 'astro/config';","+import vercel from '@astrojs/vercel';","+import { cacheVercel } from '@astrojs/vercel/cache';","+","+export default defineConfig({","+  adapter: vercel(),","+  cache: {","+    provider: cacheVercel(),","+  },","+});","+```","+","+#### Caching responses","+","+Use `Astro.cache.set()` in your pages and API routes to cache responses on Vercel's edge network. The provider sets `Vercel-CDN-Cache-Control` and `Vercel-Cache-Tag` headers on responses.","+","+```astro","+---","+Astro.cache.set({ maxAge: 300, tags: ['products'] });","+const data = await fetchProducts();","+---","+<ProductList items={data} />","+```","+","+You can also set cache rules for groups of routes in your config:","+","+```js","+cache: { provider: cacheVercel() },","+routeRules: {","+  '/products/[...slug]': { maxAge: 3600, tags: ['products'] },","+  '/api/[...path]': { maxAge: 60, swr: 600 },","+},","+```","+","+#### Invalidation","+","+Purge cached responses by tag or path from any API route or server endpoint:","+","+```ts","+// src/pages/api/purge.ts","+export async function POST({ request, cache }) {","+  await cache.invalidate({ tags: ['products'] });","+  return new Response('Purged');","+}","+","+// Path-based invalidation","+await cache.invalidate({ path: '/products/123' });","+```","+","+Both tag-based and path-based invalidation are supported. Tag invalidation is a soft invalidation, marking cached responses as stale so they can be revalidated in the background via stale-while-revalidate."],"additions":61,"deletions":0,"truncated":false},{"path":".changeset/heavy-sides-jam.md","lines":["@@ -0,0 +1,61 @@","+---","+'@astrojs/netlify': minor","+---","+","+Adds a CDN cache provider for Astro [route caching](https://docs.astro.build/en/guides/caching/) on Netlify","+","+#### Setup","+","+Import `cacheNetlify()` from `@astrojs/netlify/cache` and set it as your cache provider:","+","+```js","+import { defineConfig } from 'astro/config';","+import netlify from '@astrojs/netlify';","+import { cacheNetlify } from '@astrojs/netlify/cache';","+","+export default defineConfig({","+  adapter: netlify(),","+  cache: {","+    provider: cacheNetlify(),","+  },","+});","+```","+","+#### Caching responses","+","+Use `Astro.cache.set()` in your pages and API routes to cache responses on Netlify's edge network. The provider uses [Netlify's durable cache](https://docs.netlify.com/platform/caching/#durable-directive) so cached responses are shared across all edge nodes, reducing function invocations.","+","+```astro","+---","+Astro.cache.set({ maxAge: 300, tags: ['products'] });","+const data = await fetchProducts();","+---","+<ProductList items={data} />","+```","+","+You can also set cache rules for groups of routes in your config:","+","+```js","+cache: { provider: cacheNetlify() },","+routeRules: {","+  '/products/[...slug]': { maxAge: 3600, tags: ['products'] },","+  '/api/[...path]': { maxAge: 60, swr: 600 },","+},","+```","+","+#### Invalidation","+","+Purge cached responses by tag or path from any API route or server endpoint:","+","+```ts","+// src/pages/api/purge.ts","+export async function POST({ request, cache }) {","+  await cache.invalidate({ tags: ['products'] });","+  return new Response('Purged');","+}","+","+// Path-based invalidation","+await cache.invalidate({ path: '/products/123' });","+```","+","+Both tag-based and path-based invalidation are supported."],"additions":61,"deletions":0,"truncated":false},{"path":".changeset/itchy-months-press.md","lines":["@@ -0,0 +1,7 @@","+---","+'astro': patch","+---","+","+Passes the `Request` object to `CacheProvider.setHeaders()` for [route caching](https://docs.astro.build/en/guides/caching/)","+","+Cache providers now receive the incoming `Request` as a second argument to `setHeaders(options, request)`. This allows CDN providers to read the request URL, headers, and other properties when generating cache response headers, for example to auto-tag responses with their pathname for path-based invalidation."],"additions":7,"deletions":0,"truncated":false},{"path":"packages/astro/package.json","lines":["@@ -75,6 +75,7 @@","     \"./assets/services/sharp\": \"./dist/assets/services/sharp.js\",","     \"./assets/services/noop\": \"./dist/assets/services/noop.js\",","     \"./cache/memory\": \"./dist/core/cache/memory-provider.js\",","+    \"./cache/provider-utils\": \"./dist/core/cache/provider-utils.js\",","     \"./fetch\": \"./dist/core/fetch/index.js\",","     \"./hono\": \"./dist/core/hono/index.js\",","     \"./assets/fonts/runtime.js\": \"./dist/assets/fonts/runtime.js\",","@@ -284,6 +285,7 @@","       \"./assets/services/sharp\": \"./dist/assets/services/sharp.js\",","       \"./assets/services/noop\": \"./dist/assets/services/noop.js\",","       \"./cache/memory\": \"./dist/core/cache/memory-provider.js\",","+      \"./cache/provider-utils\": \"./dist/core/cache/provider-utils.js\",","       \"./fetch\": \"./dist/core/fetch/index.js\",","       \"./hono\": \"./dist/core/hono/index.js\",","       \"./assets/fonts/runtime.js\": \"./dist/assets/fonts/runtime.js\","],"additions":2,"deletions":0,"truncated":false},{"path":"packages/astro/src/core/cache/handler.ts","lines":["@@ -101,7 +101,7 @@ export class CacheHandler {"," \t\t\t\t},"," \t\t\t\tasync () => {"," \t\t\t\t\tconst res = await next();","-\t\t\t\t\tapplyCacheHeaders(cache!, res);","+\t\t\t\t\tapplyCacheHeaders(cache!, res, state.request);"," \t\t\t\t\treturn res;"," \t\t\t\t},"," \t\t\t);","@@ -113,7 +113,7 @@ export class CacheHandler {"," "," \t\tconst response = await next();"," \t\t// Apply cache headers for CDN-based providers (no onRequest)","-\t\tapplyCacheHeaders(cache!, response);","+\t\tapplyCacheHeaders(cache!, response, state.request);"," \t\treturn response;"," \t}"," }"],"additions":2,"deletions":2,"truncated":false},{"path":"packages/astro/src/core/cache/provider-utils.ts","lines":["@@ -0,0 +1,88 @@","+/**","+ * Shared utilities for CDN cache providers.","+ *","+ * These helpers are used by first-party adapter cache providers","+ * (@astrojs/netlify/cache, @astrojs/vercel/cache, @astrojs/cloudflare/cache)","+ * to implement common patterns like cache-control header generation,","+ * path-based invalidation via tags, and tag normalization.","+ */","+import type { CacheOptions, InvalidateOptions } from './types.js';","+","+/**","+ * Prefix used for auto-generated path tags.","+ * Responses are tagged with `astro-path:{pathname}` so that","+ * `invalidate({ path })` can be implemented via tag-based purge","+ * on platforms that don't support native path invalidation.","+ */","+const PATH_TAG_PREFIX = 'astro-path:';","+","+/**","+ * Generate a cache tag for a given path.","+ * Used by Netlify and Vercel providers to support `invalidate({ path })`.","+ */","+export function pathTag(path: string): string {","+\treturn `${PATH_TAG_PREFIX}${path}`;","+}","+","+/**","+ * Build cache-control directives from CacheOptions.","+ * Returns the directive string (e.g. `\"public, max-age=300, stale-while-revalidate=60\"`)","+ * without the header name, so each provider can use its own header","+ * (`Netlify-CDN-Cache-Control`, `Vercel-CDN-Cache-Control`, `Cloudflare-CDN-Cache-Control`).","+ *","+ * Returns `undefined` if no caching directives are present.","+ */","+export function buildCacheControlDirectives(","+\toptions: CacheOptions,","+\textraDirectives?: string[],","+): string | undefined {","+\tconst directives: string[] = [];","+","+\tif (extraDirectives) {","+\t\tdirectives.push(...extraDirectives);","+\t}","+","+\tif (options.maxAge !== undefined) {","+\t\tdirectives.push(`max-age=${options.maxAge}`);","+\t}","+","+\tif (options.swr !== undefined) {","+\t\tdirectives.push(`stale-while-revalidate=${options.swr}`);","+\t}","+","+\treturn directives.length > 0 ? directives.join(', ') : undefined;","+}","+","+/**","+ * Set common conditional headers (Last-Modified, ETag) on a Headers object.","+ */","+export function setConditionalHeaders(headers: Headers, options: CacheOptions): void {","+\tif (options.lastModified) {","+\t\theaders.set('Last-Modified', options.lastModified.toUTCString());","+\t}","+\tif (options.etag) {","+\t\theaders.set('ETag', options.etag);","+\t}","+}","+","+/**","+ * Normalize `InvalidateOptions.tags` to a flat string array.","+ */","+export function normalizeTags(tags: string | string[] | undefined): string[] {","+\tif (!tags) return [];","+\treturn Array.isArray(tags) ? tags : [tags];","+}","+","+/**","+ * Collect all tags needed to invalidate the given options,","+ * including the path tag if `options.path` is set.","+ * Used by providers that implement path invalidation via tags","+ * (Netlify, Vercel) rather than native path purge (Cloudflare).","+ */","+export function collectInvalidationTags(options: InvalidateOptions): string[] {","+\tconst tags = normalizeTags(options.tags);","+\tif (options.path) {","+\t\ttags.push(pathTag(options.path));","+\t}","+\treturn tags;","+}"],"additions":88,"deletions":0,"truncated":false},{"path":"packages/astro/src/core/cache/runtime/cache.ts","lines":["@@ -112,12 +112,13 @@ export class AstroCache implements CacheLike {"," \t}"," "," \t/** @internal */","-\t[APPLY_HEADERS](response: Response): void {","+\t[APPLY_HEADERS](response: Response, request: Request): void {"," \t\tif (this.#disabled) return;"," \t\tconst finalOptions: CacheOptions = { ...this.#options, tags: this.tags };"," \t\tif (finalOptions.maxAge === undefined && !finalOptions.tags?.length) return;"," ","-\t\tconst headers = this.#provider?.setHeaders?.(finalOptions) ?? defaultSetHeaders(finalOptions);","+\t\tconst headers =","+\t\t\tthis.#provider?.setHeaders?.(finalOptions, request) ?? defaultSetHeaders(finalOptions);"," \t\tfor (const [key, value] of headers) {"," \t\t\tresponse.headers.set(key, value);"," \t\t}","@@ -134,9 +135,9 @@ export class AstroCache implements CacheLike {"," /**","  * Apply cache headers to a response.","  */","-export function applyCacheHeaders(cache: CacheLike, response: Response): void {","+export function applyCacheHeaders(cache: CacheLike, response: Response, request: Request): void {"," \tif (APPLY_HEADERS in cache) {","-\t\t(cache as AstroCache)[APPLY_HEADERS](response);","+\t\t(cache as AstroCache)[APPLY_HEADERS](response, request);"," \t}"," }"," "],"additions":5,"deletions":4,"truncated":false},{"path":"packages/astro/src/core/cache/types.ts","lines":["@@ -27,7 +27,7 @@ export interface InvalidateOptions {"," "," export interface CacheProvider {"," \tname: string;","-\tsetHeaders?(options: CacheOptions): Headers;","+\tsetHeaders?(options: CacheOptions, request: Request): Headers;"," \tonRequest?("," \t\tcontext: {"," \t\t\trequest: Request;"],"additions":1,"deletions":1,"truncated":false},{"path":"packages/astro/test/units/cache/noop.test.ts","lines":["@@ -4,6 +4,8 @@ import { NoopAstroCache, DisabledAstroCache } from '../../../dist/core/cache/run"," import { applyCacheHeaders, isCacheActive } from '../../../dist/core/cache/runtime/cache.js';"," import { defaultLogger } from '../test-utils.ts';"," ","+const dummyRequest = new Request('http://localhost/');","+"," describe('NoopAstroCache', () => {"," \tit('enabled is false', () => {"," \t\tconst cache = new NoopAstroCache();","@@ -38,7 +40,7 @@ describe('NoopAstroCache', () => {"," \tit('applyCacheHeaders() no-ops for noop cache', () => {"," \t\tconst cache = new NoopAstroCache();"," \t\tconst response = new Response('test');","-\t\tapplyCacheHeaders(cache, response);","+\t\tapplyCacheHeaders(cache, response, dummyRequest);"," \t\tassert.equal(response.headers.get('CDN-Cache-Control'), null);"," \t\tassert.equal(response.headers.get('Cache-Tag'), null);"," \t});","@@ -85,7 +87,7 @@ describe('DisabledAstroCache', () => {"," \tit('applyCacheHeaders() no-ops for disabled cache', () => {"," \t\tconst cache = new DisabledAstroCache(defaultLogger);"," \t\tconst response = new Response('test');","-\t\tapplyCacheHeaders(cache, response);","+\t\tapplyCacheHeaders(cache, response, dummyRequest);"," \t\tassert.equal(response.headers.get('CDN-Cache-Control'), null);"," \t});"," "],"additions":4,"deletions":2,"truncated":false},{"path":"packages/astro/test/units/cache/provider-utils.test.ts","lines":["@@ -0,0 +1,135 @@","+import assert from 'node:assert/strict';","+import { describe, it } from 'node:test';","+import {","+\tbuildCacheControlDirectives,","+\tcollectInvalidationTags,","+\tnormalizeTags,","+\tpathTag,","+\tsetConditionalHeaders,","+} from '../../../dist/core/cache/provider-utils.js';","+","+describe('cache provider-utils', () => {","+\tdescribe('pathTag', () => {","+\t\tit('generates a prefixed tag from a path', () => {","+\t\t\tassert.equal(pathTag('/products/123'), 'astro-path:/products/123');","+\t\t});","+","+\t\tit('handles root path', () => {","+\t\t\tassert.equal(pathTag('/'), 'astro-path:/');","+\t\t});","+\t});","+","+\tdescribe('buildCacheControlDirectives', () => {","+\t\tit('returns undefined when no caching directives', () => {","+\t\t\tassert.equal(buildCacheControlDirectives({}), undefined);","+\t\t\tassert.equal(buildCacheControlDirectives({ tags: ['foo'] }), undefined);","+\t\t});","+","+\t\tit('builds max-age directive', () => {","+\t\t\tassert.equal(buildCacheControlDirectives({ maxAge: 300 }), 'max-age=300');","+\t\t});","+","+\t\tit('builds max-age + stale-while-revalidate', () => {","+\t\t\tassert.equal(","+\t\t\t\tbuildCacheControlDirectives({ maxAge: 300, swr: 60 }),","+\t\t\t\t'max-age=300, stale-while-revalidate=60',","+\t\t\t);","+\t\t});","+","+\t\tit('builds swr only', () => {","+\t\t\tassert.equal(buildCacheControlDirectives({ swr: 60 }), 'stale-while-revalidate=60');","+\t\t});","+","+\t\tit('prepends extra directives', () => {","+\t\t\tassert.equal(","+\t\t\t\tbuildCacheControlDirectives({ maxAge: 300 }, ['public', 'durable']),","+\t\t\t\t'public, durable, max-age=300',","+\t\t\t);","+\t\t});","+","+\t\tit('combines all options', () => {","+\t\t\tassert.equal(","+\t\t\t\tbuildCacheControlDirectives({ maxAge: 3600, swr: 120 }, ['public']),","+\t\t\t\t'public, max-age=3600, stale-while-revalidate=120',","+\t\t\t);","+\t\t});","+","+\t\tit('handles maxAge of 0', () => {","+\t\t\tassert.equal(buildCacheControlDirectives({ maxAge: 0 }), 'max-age=0');","+\t\t});","+\t});","+","+\tdescribe('setConditionalHeaders', () => {","+\t\tit('sets Last-Modified header', () => {","+\t\t\tconst headers = new Headers();","+\t\t\tconst date = new Date('2026-04-15T12:00:00Z');","+\t\t\tsetConditionalHeaders(headers, { lastModified: date });","+\t\t\tassert.equal(headers.get('Last-Modified'), 'Wed, 15 Apr 2026 12:00:00 GMT');","+\t\t});","+","+\t\tit('sets ETag header', () => {","+\t\t\tconst headers = new Headers();","+\t\t\tsetConditionalHeaders(headers, { etag: '\"abc123\"' });","+\t\t\tassert.equal(headers.get('ETag'), '\"abc123\"');","+\t\t});","+","+\t\tit('sets both headers', () => {","+\t\t\tconst headers = new Headers();","+\t\t\tconst date = new Date('2026-04-15T12:00:00Z');","+\t\t\tsetConditionalHeaders(headers, { lastModified: date, etag: '\"abc123\"' });","+\t\t\tassert.equal(headers.get('Last-Modified'), 'Wed, 15 Apr 2026 12:00:00 GMT');","+\t\t\tassert.equal(headers.get('ETag'), '\"abc123\"');","+\t\t});","+","+\t\tit('does nothing when no conditional options', () => {","+\t\t\tconst headers = new Headers();","+\t\t\tsetConditionalHeaders(headers, {});","+\t\t\tassert.equal([...headers.entries()].length, 0);","+\t\t});","+\t});","+","+\tdescribe('normalizeTags', () => {","+\t\tit('returns empty array for undefined', () => {","+\t\t\tassert.deepEqual(normalizeTags(undefined), []);","+\t\t});","+","+\t\tit('wraps a single string in an array', () => {","+\t\t\tassert.deepEqual(normalizeTags('products'), ['products']);","+\t\t});","+","+\t\tit('passes through an array', () => {","+\t\t\tassert.deepEqual(normalizeTags(['a', 'b']), ['a', 'b']);","+\t\t});","+\t});","+","+\tdescribe('collectInvalidationTags', () => {","+\t\tit('collects tags from options', () => {","+\t\t\tassert.deepEqual(collectInvalidationTags({ tags: ['products', 'home'] }), [","+\t\t\t\t'products',","+\t\t\t\t'home',","+\t\t\t]);","+\t\t});","+","+\t\tit('handles single string tag', () => {","+\t\t\tassert.deepEqual(collectInvalidationTags({ tags: 'products' }), ['products']);","+\t\t});","+","