d lazily: a top-level `cloudflare:workers` import in this module","+\t\t\t// breaks the `prerenderEnvironment: 'node'` build, where the provider is","+\t\t\t// loaded by Node during prerendering and the `cloudflare:` scheme is rejected.","+\t\t\tconst { cache } = await import('cloudflare:workers');","+\t\t\tconst tags = collectInvalidationTags(options);","+\t\t\tif (tags.length > 0) {","+\t\t\t\tawait cache.purge({ tags });","+\t\t\t}","+\t\t},","+\t};","+};","+","+export default factory;"],"additions":50,"deletions":0,"truncated":false},{"path":"packages/integrations/cloudflare/src/index.ts","lines":["@@ -180,12 +180,15 @@ export default function createIntegration({"," \t\t\t\tconst prebundleContentRuntime = command === 'dev' && usesContentCollections;"," \t\t\t\tconst isTypeGenPhase = command === 'build' || command === 'sync';"," ","+\t\t\t\tconst needsWorkerCache = config.cache?.provider?.name === 'cloudflare';","+"," \t\t\t\tconst adapterPluginConfig: Partial<PluginConfig> = {"," \t\t\t\t\tconfig: cloudflareConfigCustomizer({"," \t\t\t\t\t\tneedsSessionKVBinding,"," \t\t\t\t\t\tsessionKVBindingName,"," \t\t\t\t\t\timagesBindingName:"," \t\t\t\t\t\t\tneedsImagesBinding || needsImagesBindingForDev ? imagesBindingName : false,","+\t\t\t\t\t\tneedsWorkerCache,"," \t\t\t\t\t}),"," \t\t\t\t\t...(prerenderEnvironment === 'workerd' && {"," \t\t\t\t\t\texperimental: {","@@ -396,6 +399,7 @@ export default function createIntegration({"," \t\t\t\t\t\t\t\t\t\t\t\tbuildAssets: config.build.assets ?? '_astro',"," \t\t\t\t\t\t\t\t\t\t\t}"," \t\t\t\t\t\t\t\t\t\t: null,","+\t\t\t\t\t\t\t\tcacheProviderEnabled: needsWorkerCache,"," \t\t\t\t\t\t\t}),"," \t\t\t\t\t\t\tcfPrismPlugin(),"," \t\t\t\t\t\t],"],"additions":4,"deletions":0,"truncated":false},{"path":"packages/integrations/cloudflare/src/utils/handler.ts","lines":["@@ -1,5 +1,9 @@"," import { env as globalEnv } from 'cloudflare:workers';","-import { compileImageConfig, isPrerender } from 'virtual:astro-cloudflare:config';","