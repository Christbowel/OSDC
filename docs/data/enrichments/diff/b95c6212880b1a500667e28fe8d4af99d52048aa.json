"+  // acquisition fails and the run exits non-zero, so a clean exit proves the","+  // tasks ran sequentially. With `--jobs 1` they never overlap, even when","+  // `DENO_JOBS` asks for more.","+  \"tempDir\": true,","+  \"tests\": {","+    \"concurrency_one_is_sequential\": {","+      \"args\": \"task -r --no-prefix --jobs 1 work\",","+      \"output\": \"sequential.out\"","+    },","+    // The `--concurrency` alias behaves the same as `--jobs` and overrides","+    // `DENO_JOBS`.","+    \"flag_overrides_deno_jobs\": {","+      \"args\": \"task -r --no-prefix --concurrency 1 work\",","+      \"envs\": {","+        \"DENO_JOBS\": \"3\"","+      },","+      \"output\": \"sequential.out\"","+    },","+    \"invalid_zero\": {","+      \"args\": \"task -r --jobs 0 work\",","+      \"exitCode\": 1,","+      \"output\": \"invalid.out\"","+    }","+  }","+}"],"additions":28,"deletions":0,"truncated":false},{"path":"tests/specs/task/workspace_concurrency/a/deno.json","lines":["@@ -0,0 +1,8 @@","+{","+  \"name\": \"@app/a\",","+  \"version\": \"0.0.1\",","+  \"exports\": \"./main.ts\",","+  \"tasks\": {","+    \"work\": \"deno run -A main.ts\"","+  }","+}"],"additions":8,"deletions":0,"truncated":false},{"path":"tests/specs/task/workspace_concurrency/a/main.ts","lines":["@@ -0,0 +1,16 @@","+// Acquire an exclusive lock in the shared workspace root. If another task is","+// holding it, the tasks are overlapping (i.e. running concurrently) and this","+// run is NOT sequential, so fail loudly.","+const NAME = \"a\";","+const root = Deno.env.get(\"INIT_CWD\")!;","+const lock = `${root}/running.lock`;","+try {","+  await Deno.writeTextFile(lock, NAME, { createNew: true });","+} catch {","+  console.error(`${NAME}: overlap detected — tasks ran concurrently`);","+  Deno.exit(1);","+}","+console.log(`${NAME} running`);","+await new Promise((r) => setTimeout(r, 100));","+await Deno.remove(lock);","+console.log(`${NAME} done`);"],"additions":16,"deletions":0,"truncated":false},{"pat