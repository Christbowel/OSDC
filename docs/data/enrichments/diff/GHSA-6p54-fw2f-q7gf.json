 (at your option) any later version.","+//","+// This program is distributed in the hope that it will be useful,","+// but WITHOUT ANY WARRANTY; without even the implied warranty of","+// MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the","+// GNU Affero General Public License for more details.","+//","+// You should have received a copy of the GNU Affero General Public License","+// along with this program.  If not, see <https://www.gnu.org/licenses/>.","+","+package router","+","+// TestNonGetRoutesBlockPublicRequests enforces the invariant:","+//","+//\tEvery non-GET route that lives under /organizations must block a","+//\tfully-authenticated user that has NO membership in a public resource.","+//","+// Threat model: when an org/project/asset is marked public, the group-level","+// RBAC middleware sets IsPublicRequest=true and continues processing. A","+// non-GET route that is missing DisallowPublicRequests or a write-action RBAC","+// check will pass the middleware chain and reach its handler. Because the","+// handler is a zero-value stub it panics → 500.  Any properly protected route","+// returns 4xx before the handler and the test passes.","+//","+// TestReadOnlyMemberCannotWriteToProtectedRoutes enforces the invariant:","+//","+//\tEvery non-GET route that requires explicit write permission must block a","+//\tread-only member (has ActionRead access but not ActionUpdate/ActionDelete).","+//","+// Routes listed in memberOnlyPaths intentionally use DisallowPublicRequests","+// instead of write-level RBAC: any authenticated member (not just writers)","+// is allowed. Those are skipped from the second test.","+//","+// HOW TO ADD NEW ROUTERS","+// If you add a new router to RouterModule (providers.go) and it registers","+// non-GET routes, register it in buildSecurityTestServer below and ensure it","+// is called so the routes appear in e.Routes().","+//","+// HOW TO ADD AN INTENTIONALLY PUBLIC NON-GET ROUTE","+// Add its exact path template to intentionallyPublicPaths below and explain","+// why it is safe without authentication.","+//","+// HOW TO ADD A MEMBER-ONLY WRITE ROUTE (DisallowPublicRequests, no write RBAC)","+// Add \"METHOD /path/template/\" to memberOnlyPaths and explain why any member","+// (not just a writer) should be allowed.","+","+import (","+\t\"fmt\"","+\t\"net/http\"","+\t\"net/http/httptest\"","+\t\"regexp\"","+\t\"strings\"","+\t\"testing\"","+","+\t\"github.com/google/uuid\"","+\t\"github.com/l3montree-dev/devguard/controllers\"","+\t\"github.com/l3montree-dev/devguard/controllers/dependencyfirewall\"","+\t\"github.com/l3montree-dev/devguard/database/models\"","+\t\"github.com/l3montree-dev/devguard/integrations/gitlabint\"","+\t\"github.com/l3montree-dev/devguard/middlewares\"","+\t\"github.com/l3montree-dev/devguard/mocks\"","+\t\"github.com/l3montree-dev/devguard/shared\"","+\t\"github.com/labstack/echo/v4\"","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/mock\"","+)","+","+// intentionallyPublicPaths lists non-GET route path templates that are","+// explicitly designed to be callable without membership in the resource.","+// Each entry must include a comment explaining why it is safe.","+var intentionallyPublicPaths = map[string]bool{","+\t// none yet","+}","+","+// memberOnlyPaths lists non-GET routes that are intentionally accessible to","+// any authenticated member (not restricted to writers). They use","+// DisallowPublicRequests instead of write-level RBAC because the business rule","+// is: \"if you can read the resource you can also perform this action.\"","+// Key format: \"METHOD /full/echo/path/template/\"","+var memberOnlyPaths = map[string]bool{","+\t// Vuln triage actions — any member who can read the asset version may triage findings.","+\t\"POST /api/v1/organizations/:organization/projects/:project/assets/:assetSlug/refs/:assetVersionSlug/dependency-vulns/sync/\":                            true,","+\t\"POST /api/v1/organizations/:organization/projects/:project/assets/:assetSlug/refs/:assetVersionSlug/dependency-vulns/batch/\":                           true,","+\t\"POST /api/v1/organizations/:organization/projects/:project/assets/:assetSlug/refs/:assetVersionSlug/dependency-vulns/:dependencyVulnID/\":               true,","+\t\"POST /api/v1/organizations/:organization/projects/:project/assets/:assetSlug/refs/:assetVersionSlug/dependency-vulns/:dependencyVulnID/mitigate/\":      true,","+\t\"POST /api/v1/organizations/:organization/projects/:project/assets/:assetSlug/refs/:assetVersionSlug/first-party-vulns/:firstPartyVulnID/\":              true,","+\t\"POST /api/v1/organizations/:organization/projects/:project/assets/:assetSlug/refs/:assetVersionSlug/first-party-vulns/:firstPartyVulnID/mitigate/\":     true,","+\t\"POST /api/v1/organizations/:organization/projects/:project/assets/:assetSlug/refs/:assetVersionSlug/license-risks/\":                                    true,","+\t\"POST /api/v1/organizations/:organization/projects/:project/assets/:assetSlug/refs/:assetVersionSlug/license-risks/:licenseRiskID/\":                     true,","+\t\"POST /api/v1/organizations/:organization/projects/:project/assets/:assetSlug/refs/:assetVersionSlug/license-risks/:licenseRiskID/mitigate/\":            true,","+\t\"POST /api/v1/organizations/:organization/projects/:project/assets/:assetSlug/refs/:assetVersionSlug/license-risks/:licenseRiskID/final-license-decision/\": true,","+\t// VEX rules — any member may create/edit/delete VEX rules (membership = passed read RBAC).","+\t\"POST /api/v1/organizations/:organization/projects/:project/assets/:assetSlug/refs/:assetVersionSlug/vex-rules/\":                 true,","+\t\"PUT /api/v1/organizations/:organization/projects/:project/assets/:assetSlug/refs/:assetVersionSlug/vex-rules/:ruleId/\":          true,","+\t\"POST /api/v1/organizations/:organization/projects/:project/assets/:assetSlug/refs/:assetVersionSlug/vex-rules/:ruleId/reapply/\": true,","+\t\"DELETE /api/v1/organizations/:organization/projects/:project/assets/:assetSlug/refs/:assetVersionSlug/vex-rules/:ruleId/\":       true,","+}","+","+var echoParamRe = regexp.MustCompile(`:[^/]+`)","+","+// fillParams replaces every Echo path parameter with a stable dummy value so","+// the router can match the route without a real database record.","+func fillParams(path string) string {","+\treturn echoParamRe.ReplaceAllString(path, \"test-id\")","+}","+","+func buildSecurityTestServer(t *testing.T, ac *mocks.AccessControl) *echo.Echo {","+\tt.Helper()","+","+\t// middlewares.Server() sets the package-level middlewares.E used by","+\t// GoroutineSafeContext inside ExternalEntityProviderOrgSyncMiddleware.","+\te := middlewares.Server()","+\t// Surface panics as 500 so the assertion can catch unprotected handlers.","+\te.HTTPErrorHandler = func(err error, c echo.Context) {","+\t\tcode := http.StatusInternalServerError","+\t\tif he, ok := err.(*echo.HTTPError); ok {","+\t\t\tcode = he.Code","+\t\t}","+\t\t_ = c.NoContent(code)","+\t}","+","+\torgID := uuid.New()","+\tprojectID := uuid.New()","+\tassetID := uuid.New()","+","+\t//  PAT service / verifier","+\t// Any request is treated as coming from \"test-user\" with manage+scan scopes","+\t// so NeededScope middleware always passes.  The real protection must then","+\t// come from DisallowPublicRequests or a write-action RBAC check.","+\tpatService := &mocks.PersonalAccessTokenService{}","+\tpatService.On(\"VerifyRequestSignature\", mock.Anything, mock.Anything).","+\t\tMaybe().Return(\"test-user\", \"manage scan\", nil)","+","+\trbacProvider := &mocks.RBACProvider{}","+\trbacProvider.On(\"GetDomainRBAC\", mock.Anything).Maybe().Return(ac)","+","+\t//  Domain objects (all public so group RBAC sets IsPublicRequest)","+\torg := &models.Org{Model: models.Model{ID: orgID}, Slug: \"test-org\", IsPublic: true}","+\torgService := &mocks.OrgService{}","+\torgService.On(\"ReadBySlug\", mock.Anything, mock.Anything).Maybe().Return(org, nil)","+","+\tproj := models.Project{Model: models.Model{ID: projectID}, Slug: \"test-project\", IsPublic: true}","+\tprojectRepo := &mocks.ProjectRepository{}","+\tprojectRepo.On(\"ReadBySlug\", mock.Anything, mock.Anything, mock.Anything, mock.Anything).Maybe().Return(proj, nil)","+","+\tasset := models.Asset{Model: models.Model{ID: assetID}, Slug: \"test-asset\", IsPublic: true}","+\tassetRepo := &mocks.AssetRepository{}","+\tassetRepo.On(\"ReadBySlug\", mock.Anything, mock.Anything, mock.Anything, mock.Anything).Maybe().Return(asset, nil)","+","+\t// AssetVersion: always not found → AssetVersionMiddleware returns a 404","+\t// which is still < 500, so sub-routes that rely on it are implicitly safe.","+\tassetVersionRepo := &mocks.AssetVersionRepository{}","+\tassetVersionRepo.On(\"ReadBySlug\", mock.Anything, mock.Anything, mock.Anything, mock.Anything).","+\t\tMaybe().Return(models.AssetVersion{}, fmt.Errorf(\"not found\"))","+","+\t// VulnEvent: no access → EventMiddleware returns 403","+\tvulnEventRepo := &mocks.VulnEventRepository{}","+\tvulnEventRepo.On(\"HasAccessToEvent\", mock.Anything, mock.Anything, mock.Anything, mock.Anything).","+\t\tMaybe().Return(false, nil)","+","+\t// Artifact: not found → ArtifactMiddleware returns 404","+\tartifactRepo := &mocks.ArtifactRepository{}","+\tartifactRepo.On(\"ReadArtifact\", mock.Anything, mock.Anything, mock.Anything, mock.Anything, mock.Anything).","+\t\tMaybe().Return(models.Artifact{}, fmt.Errorf(\"not found\"))","+","+\t// ExternalEntityProviderService: methods used as handlers (GET only) or","+\t// fire-and-forget goroutines; just needs to not crash on method-value take.","+\textEntityService := &mocks.ExternalEntityProviderService{}","+\textEntityService.On(\"SyncOrgs\", mock.Anything).Maybe().Return([]*models.Org{}, nil)","+\textEntityService.On(\"TriggerOrgSync\", mock.Anything).Maybe().Return(nil)","+\textEntityService.On(\"TriggerSync\", mock.Anything).Maybe().Return(nil)","+","+\t// ConfigService: return error so InstanceSettings middleware passes through","+\tconfigService := &mocks.ConfigService{}","+\tconfigService.On(\"GetInstanceSettings\", mock.Anything).","+\t\tMaybe().Return(models.Config{}, fmt.Errorf(\"not found\"))","+","+\t// PublicClient: return error → SessionMiddleware falls through to PAT verifier","+\tpublicClient := &mocks.PublicClient{}","+\tpublicClient.On(\"GetIdentityFromCookie\", mock.Anything, mock.Anything).","+\t\tMaybe().Return(nil, fmt.Errorf(\"no cookie\"))","+","+\t//  Build the full router hierarchy using the REAL constructors","+\t// This is the point: if someone adds a route without protection and also","+\t// registers it here (or in RouterModule), the test will catch it.","+\t//","+\t// Use new(T) instead of nil for controllers: some methods use value","+\t// receivers, and taking a method value from a nil pointer panics.","+\tapiV1 := APIV1Router{Group: e.Group(\"/api/v1\")}","+","+\tsessionRouter := NewSessionRouter(","+\t\tapiV1,","+\t\tpublicClient,","+\t\tpatService,","+\t\textEntityService,","+\t\tnew(controllers.IntegrationController),","+\t\tnew(controllers.OrgController),","+\t\tnew(controllers.ScanController),","+\t\tnew(controllers.AttestationController),","+\t\tnew(controllers.PatController),","+\t\tassetRepo,","+\t\tprojectRepo,","+\t\trbacProvider,","+\t\torgService,","+\t\tmap[string]*gitlabint.GitlabOauth2Config{},","+\t\tassetVersionRepo,","+\t)","+","+\torgRouter := NewOrgRouter(","+\t\tsessionRouter,","+\t\tconfigService,","+\t\tnew(controllers.OrgController),","+\t\tnew(controllers.ProjectController),","+\t\tnew(dependencyfirewall.DependencyProxyController),","+\t\tnew(controllers.DependencyVulnController),","+\t\tnew(controllers.FirstPartyVulnController),","+\t\tnew(controllers.PolicyController),","+\t\tnew(controllers.IntegrationController),","+\t\tnew(controllers.WebhookController),","+\t\textEntityService,","+\t\torgService,","+\t\tmap[string]*gitlabint.GitlabOauth2Config{},","+\t\trbacProvider,","+\t\tnew(controllers.StatisticsController),","+\t)","+","+\tprojectRouter := NewProjectRouter(","+\t\torgRouter,","+\t\tnew(controllers.ProjectController),","+\t\tnew(controllers.AssetController),","+\t\tnew(dependencyfirewall.DependencyProxyController),","+\t\tnew(controllers.DependencyVulnController),","+\t\tnew(controllers.PolicyController),","+\t\tnew(controllers.ReleaseController),","+\t\tnew(controllers.StatisticsController),","+\t\tnew(controllers.WebhookController),","+\t\tprojectRepo,","+\t\tnew(controllers.ComponentController),","+\t)","+","+\tassetRouter := NewAssetRouter(","+\t\tprojectRouter,","+\t\tnew(controllers.AssetController),","+\t\tnew(dependencyfirewall.DependencyProxyController),","+\t\tnew(controllers.AssetVersionController),","+\t\tnew(controllers.ComplianceController),","+\t\tnew(controllers.StatisticsController),","+\t\tnew(controllers.ComponentController),","+\t\tnew(controllers.InToToController),","+\t\tnew(controllers.IntegrationController),","+\t\tnew(controllers.ScanController),","+\t\tassetRepo,","+\t)","+","+\tassetVersionRouter := NewAssetVersionRouter(","+\t\tassetRouter,","+\t\tnew(controllers.AssetVersionController),","+\t\tnew(controllers.FirstPartyVulnController),","+\t\tnew(controllers.ComplianceController),","+\t\tnew(controllers.ComponentController),","+\t\tnew(controllers.StatisticsController),","+\t\tnew(controllers.AttestationController),","+\t\tnew(controllers.InToToController),","+\t\tnew(controllers.VulnEventController),","+\t\tnew(controllers.ArtifactController),","+\t\tnew(controllers.ExternalReferenceController),","+\t\tassetVersionRepo,","+\t\tassetRepo,","+\t\tvulnEventRepo,","+\t)","+","+\t// Sub-routers under /refs/:assetVersionSlug — all non-GET routes in these","+\t// must be protected.  Add new routers from RouterModule (providers.go) here.","+\tNewDependencyVulnRouter(assetVersionRouter, new(controllers.DependencyVulnController), new(controllers.VulnEventController))","+\tNewFirstPartyVulnRouter(assetVersionRout