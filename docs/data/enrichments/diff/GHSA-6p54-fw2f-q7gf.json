icRequests or a write-action RBAC middleware\",","+\t\t\t\tmethod, route.Path, rec.Code,","+\t\t\t)","+\t\t})","+\t}","+}","+","+// TestReadOnlyMemberCannotWriteToProtectedRoutes enforces that every non-GET","+// route requiring explicit write permission still blocks a read-only member","+// (has ActionRead access, but not ActionUpdate or ActionDelete).","+//","+// Routes listed in memberOnlyPaths are skipped: those routes intentionally","+// grant access to any authenticated member via DisallowPublicRequests.","+func TestReadOnlyMemberCannotWriteToProtectedRoutes(t *testing.T) {","+\te := buildSecurityTestServer(t, readOnlyMemberAC())","+","+\tfor _, route := range e.Routes() {","+\t\tmethod := route.Method","+\t\tpath := route.Path","+","+\t\tif method == http.MethodGet || method == \"echo_route_not_found\" {","+\t\t\tcontinue","+\t\t}","+\t\tif !strings.Contains(path, \":organization\") {","+\t\t\tcontinue","+\t\t}","+\t\tif intentionallyPublicPaths[path] {","+\t\t\tcontinue","+\t\t}","+\t\t// Member-only routes are intentionally accessible to read-only members;","+\t\t// they are tested for public-visitor blocking in the first test.","+\t\tif memberOnlyPaths[method+\" \"+path] {","+\t\t\tcontinue","+\t\t}","+","+\t\tfilledPath := fillParams(path)","+","+\t\tt.Run(method+\" \"+route.Path, func(t *testing.T) {","+\t\t\treq := httptest.NewRequest(method, filledPath, nil)","+\t\t\trec := httptest.NewRecorder()","+\t\t\te.ServeHTTP(rec, req)","+","+\t\t\tassert.Less(t, rec.Code, 500,","+\t\t\t\t\"route %s %s reached its handler for a read-only member \"+","+\t\t\t\t\t\"(status %d); add a write-action RBAC middleware (e.g. assetScopedRBAC ActionUpdate)\",","+\t\t\t\tmethod, route.Path, rec.Code,","+\t\t\t)","+\t\t})","+\t}","+}"],"additions":404,"deletions":0,"truncated":false},{"path":"router/vex_rule_router.go","lines":["@@ -37,10 +37,10 @@ func NewVEXRuleRouter("," "," \t// Write access - requires asset update permission"," \truleWriteGroup := ruleGroup.Group(\"\",