n.hpp","+index 719573c..72fb189 100644","+--- a/src/include/mysql_connection.hpp","+@@ -22,7 +22,7 @@ class MySQLTextWriter;","+ struct MySQLBinaryReader;","+ class MySQLSchemaEntry;","+ class MySQLTableEntry;","+-class MySQLStatement;","++struct MySQLStatement;","+ class MySQLResult;","+ struct IndexInfo;","+ ","+diff --git a/src/include/mysql_scanner.hpp b/src/include/mysql_scanner.hpp","+index 79b9e01..e689e9d 100644","+--- a/src/include/mysql_scanner.hpp","+@@ -68,6 +68,9 @@ struct MySQLQueryBindData : public FunctionData {","+ \tunique_ptr<MySQLResult> result;","+ \tunique_ptr<MySQLStatement> stmt;","+ \tvector<Value> params;","++\t//! Whether the query must be executed through the transaction's connection","++\t//! (set when a remote transaction was active at bind time)","++\tbool use_transaction_connection = false;","+ ","+ public:","+ \tunique_ptr<FunctionData> Copy() const override {","+diff --git a/src/include/mysql_sql_writer.hpp b/src/include/mysql_sql_writer.hpp","+new file mode 100644","+index 0000000..4ccc58e","+--- /dev/null","+@@ -0,0 +1,89 @@","++//===----------------------------------------------------------------------===//","++//                         DuckDB","++//","++// mysql_sql_writer.hpp","++//","++//===----------------------------------------------------------------------===//","++","++#pragma once","++","++#include \"duckdb/common/optional_ptr.hpp\"","++#include \"duckdb/common/types.hpp\"","++#include \"duckdb/parser/parsed_expression.hpp\"","++#include \"duckdb/parser/query_node.hpp\"","++#include \"duckdb/parser/result_modifier.hpp\"","++#include \"duckdb/parser/tableref.hpp\"","++","++namespace duckdb {","++class CaseExpression;","++class FunctionArgument;","++class CastExpression;","++class ClientContext;","++class ColumnRefExpression;","++class FunctionExpression;","++class OperatorExpression;","++class RecursiveCTENode;","++class SelectNode;","++class SetOperationNode;","++class SubqueryExpression;","++class WindowExpression;","++class CommonTableExpressionMap;","++","++//! Serializes a parsed query tree into MySQL-compatible SQL.","++//! This mirrors the structure of the DuckDB ToString() methods, with MySQL-specific","++//! differences applied during serialization:","++//! * identifiers are quoted with backticks","++//! * string literals escape backslashes (MySQL treats backslash as an escape character)","++//! * cast types are remapped (e.g. INTEGER -> SIGNED, VARCHAR -> CHAR)","++//! * functions are remapped where semantics are identical under a different name","++//!   (e.g. count_star() -> count(*), log -> log10, length -> char_length)","++//! * ORDER BY entries get an explicit NULL ordering key (MySQL sorts NULLs first when","++//!   ascending, DuckDB defaults to NULLS LAST)","++//! * unnamed derived tables get a generated alias (required by MySQL)","++//! Constructs that cannot be serialized are rejected up-front by MySQLCatalog::SupportsPushdown -","++//! encountering them here is an internal error.","++struct MySQLVersion;","++","++class MySQLSQLWriter {","++public:","++\tMySQLSQLWriter(ClientContext &context, const MySQLVersion &version);","++","++\t//! Convert a query node to a MySQL-compatible SQL string","++\tstatic string MySQLToString(ClientContext &context, const MySQLVersion &version, const QueryNode &node);","++","++private:","++\tstring WriteQueryNode(const QueryNode &node);","++\tstring WriteSelectNode(const SelectNode &node);","++\tstring WriteSetOperationNode(const SetOperationNode &node);","++\tstring WriteRecursiveCTENode(const RecursiveCTENode &node);","++\tstring WriteCTEMap(const CommonTableExpressionMap &cte_map);","++\tstring WriteResultModifiers(const QueryNode &node,","++\t                            optional_ptr<const vector<unique_ptr<ParsedExpression>>> select_list);","++\tstring WriteOrderList(const vector<OrderByNode> &orders,","++\t                      optional_ptr<const vector<unique_ptr<ParsedExpression>>> select_list);","++","++\tstring WriteTableRef(const TableRef &ref);","++","++\tstring WriteExpression(const ParsedExpression &expr);","++\tstring WriteExpressionList(const vector<unique_ptr<ParsedExpression>> &expressions, const string &separator = \", \");","++\tstring WriteArgumentList(const vector<FunctionArgument> &arguments);","++\tstring WriteFunction(const FunctionExpression &func);","++\tstring WriteFunctionCall(const string &function_name, const vector<FunctionArgument> &children, bool distinct);","++\tstring WriteWindow(const WindowExpression &window);","++\tstring WriteOperator(const OperatorExpression &op);","++\tstring WriteCase(const CaseExpression &case_expr);","++\tstring WriteSubquery(const SubqueryExpression &subquery);","++\tstring WriteColumnRef(const ColumnRefExpression &column_ref);","++\tstring WriteConstant(const Value &value);","++\tstring WriteCastType(const LogicalType &type);","++\tstring WriteIdentifier(const string &identifier);","++","++private:","++\tClientContext &context;","++\t//! The NO PAD binary collation attached to string literals (derived from the server version)","++\tstring binary_collation;","++\t//! Counter for generating aliases for unnamed derived tables (MySQL requires an alias)","++\tidx_t unnamed_subquery_index = 0;","++};","++","++} // namespace duckdb","+diff --git a/src/include/mysql_utils.hpp b/src/include/mysql_utils.hpp","+index 7fd38a3..281e787 100644","+--- a/src/include/mysql_utils.hpp","+@@ -25,6 +25,75 @@ enum mysql_ssl_mode_compat {","+ \tSSL_MODE_VERIFY_IDENTITY","+ };","+ ","++//! The type of server we are connected to","++enum class MySQLServerType : uint8_t { MYSQL, MARIADB };","++","++//! Server version information, parsed from the server version string on attach","++struct MySQLVersion {","++\tidx_t major_version = 0;","++\tidx_t minor_version = 0;","++\tidx_t patch_version = 0;","++\tMySQLServerType server_type = MySQLServerType::MYSQL;","++","++\t//! Parse a server version string (e.g. \"9.6.0\", \"8.0.42-log\", \"11.4.2-MariaDB\",","++\t//! \"5.5.5-10.11.6-MariaDB-log\")","++\tstatic MySQLVersion Parse(const string &version_string);","++","++\tbool IsAtLeast(idx_t major_p, idx_t minor_p, idx_t patch_p) const {","++\t\tif (major_version != major_p) {","++\t\t\treturn major_version > major_p;","++\t\t}","++\t\tif (minor_version != minor_p) {","++\t\t\treturn minor_version > minor_p;","++\t\t}","++\t\treturn patch_version >= patch_p;","++\t}","++","++\t//! Whether the server supports window functions and (recursive) CTEs","++\tbool SupportsWindowFunctions() const {","++\t\tswitch (server_type) {","++\t\tcase MySQLServerType::MARIADB:","++\t\t\t// window functions: MariaDB 10.2.0, CTEs: 10.2.1, recursive CTEs: 10.2.2","++\t\t\treturn IsAtLeast(10, 2, 2);","++\t\tdefault:","++\t\t\t// window functions and CTEs were added during the MySQL 8.0 development cycle -","++\t\t\t// require the first GA release","++\t\t\treturn IsAtLeast(8, 0, 11);","++\t\t}","++\t}","++","++\t//! Whether the server supports (recursive) common table expressions","++\tbool SupportsCTEs() const {","++\t\treturn SupportsWindowFunctions();","++\t}","++","++\t//! Whether the server supports the EXCEPT / INTERSECT set operations","++\tbool SupportsExceptIntersect(bool all) const {","++\t\tswitch (server_type) {","++\t\tcase MySQLServerType::MARIADB:","++\t\t\t// EXCEPT / INTERSECT: MariaDB 10.3, the ALL variants: MariaDB 10.5","++\t\t\treturn all ? IsAtLeast(10, 5, 0) : IsAtLeast(10, 3, 0);","++\t\tdefault:","++\t\t\t// EXCEPT / INTERSECT (including ALL) were added in MySQL 8.0.31","++\t\t\treturn IsAtLeast(8, 0, 31);","++\t\t}","++\t}","++","++\t//! The NO PAD binary collation used to give string literals byte-wise comparison","++\t//! semantics, or an empty string if the server has no suitable collation","++\t//! (in which case string literals cannot be pushed down)","++\tstring GetBinaryCollation() const {","++\t\tswitch (server_type) {","++\t\tcase MySQLServerType::MARIADB:","++\t\t\t// utf8mb4_nopad_bin is available since MariaDB 1