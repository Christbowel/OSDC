ache_;","+ \tMySQLStatsCache stats_cache_;","+diff --git a/src/include/storage/mysql_statistics.hpp b/src/include/storage/mysql_statistics.hpp","+index 377b093..827533a 100644","+--- a/src/include/storage/mysql_statistics.hpp","+@@ -11,6 +11,7 @@","+ #include \"duckdb.hpp\"","+ #include \"duckdb/common/case_insensitive_map.hpp\"","+ #include \"duckdb/planner/table_filter.hpp\"","++#include \"mysql_utils.hpp\"","+ ","+ #include <chrono>","+ #include <deque>","+@@ -152,13 +153,6 @@ struct CachedBufferPoolRate {","+ \tstd::chrono::steady_clock::time_point cached_at;","+ };","+ ","+-struct CachedVersionInfo {","+-\tstring mysql_version;","+-\tbool has_histogram_support = false;","+-\tbool detected = false;","+-\tstd::chrono::steady_clock::time_point cached_at;","+-};","+-","+ struct StatsEvictionEntry {","+ \tstring key;","+ \tidx_t seq;","+@@ -169,7 +163,6 @@ public:","+ \tstatic constexpr int64_t TABLE_STATS_TTL_SECONDS = 300;","+ \tstatic constexpr int64_t COST_CONSTANTS_TTL_SECONDS = 1800;","+ \tstatic constexpr int64_t BUFFER_POOL_TTL_SECONDS = 300;","+-\tstatic constexpr int64_t VERSION_TTL_SECONDS = 3600;","+ \tstatic constexpr idx_t MAX_TABLE_STATS_ENTRIES = 1000;","+ ","+ \tusing InvalidationCallback = std::function<void(const string &schema, const string &table)>;","+@@ -185,9 +178,6 @@ public:","+ \tbool GetBufferPoolHitRate(double &out);","+ \tvoid StoreBufferPoolHitRate(double hit_rate);","+ ","+-\tbool GetVersionInfo(string &version, bool &has_histogram_support);","+-\tvoid StoreVersionInfo(const string &version, bool has_histogram_support);","+-","+ \tvoid Clear();","+ \tvoid Invalidate(const string &schema, const string &table);","+ ","+@@ -199,7 +189,6 @@ private:","+ \tidx_t next_eviction_seq_ = 0;","+ \tCachedCostConstants cost_constants_;","+ \tCachedBufferPoolRate buffer_pool_;","+-\tCachedVersionInfo version_info_;","+ ","+ \tstatic string MakeCacheKey(const string &schema, const string &table);","+ \tvoid EvictOldest();","+@@ -208,7 +197,8 @@ private:","+ ","+ class MySQLStatisticsCollector {","+ public:","+-\tMySQLStatisticsCollector(MySQLConnection &connection, MySQLStatsCache &shared_cache);","++\tMySQLStatisticsCollector(MySQLConnection &connection, MySQLStatsCache &shared_cache,","++\t                         const MySQLVersion &server_version);","+ ","+ \tMySQLTableStats GetTableStats(const string &schema, const string &table);","+ \tbool HasUsableIndex(const string &schema, const string &table, const vector<string> &columns);","+@@ -232,21 +222,16 @@ public:","+ \tExplainAnalyzeResult RunExplainAnalyze(const string &query);","+ ","+ \tbool SupportsExplainAnalyze() const;","+-\tint GetMajorVersion() const;","+-\tint GetMinorVersion() const;","+-\tint GetPatchVersion() const;","+ \tdouble EstimateSelectivity(const string &schema, const string &table, const string &column,","+ \t                           ExpressionType comparison, const Value &value);","+ ","+ private:","+ \treference<MySQLConnection> connection_;","+ \treference<MySQLStatsCache> shared_cache_;","++\tMySQLVersion server_version_;","+ \tbool has_histogram_support_ = false;","+-\tbool version_detected_ = false;","+ \tbool stats_expiry_set_ = false;","+-\tstring mysql_version_;","+ ","+-\tvoid DetectVersion();","+ \tvoid EnsureFreshStats();","+ \tvoid FetchTableMetadata(const string &schema, const string &table, MySQLTableStats &stats);","+ \tvoid FetchInnoDBStats(const string &schema, const string &table, MySQLTableStats &stats);","+diff --git a/src/include/storage/mysql_transaction.hpp b/src/include/storage/mysql_transaction.hpp","+index ba4ceae..5bca78a 100644","+--- a/src/include/storage/mysql_transaction.hpp","+@@ -28,6 +28,11 @@ public:","+ \tvoid Rollback();","+ ","+ \tMySQLConnection &GetConnection();","++\t//! Whether a transaction has been started on the remote server - if so, queries must be","++\t//! executed through the transaction's connection so they see uncommitted changes","++\tbool HasStartedTransaction() const {","++\t\treturn transactions_enabled && transaction_state == MySQLTransactionState::TRANSACTION_STARTED;","++\t}","+ \tunique_ptr<MySQLResult> Query(const string &query);","+ \tstatic MySQLTransaction &Get(ClientContext &context, Catalog &catalog);","+ \tAccessMode GetAccessMode() const {","+diff --git a/src/mysql_extension.cpp b/src/mysql_extension.cpp","+index d2427fc..44e762e 100644","+--- a/src/mysql_extension.cpp","+@@ -249,9 +249,9 @@ static void LoadInternal(ExtensionLoader &loader) {","+ \tconfig.AddExtensionOption(\"mysql_order_pushdown_enabled\",","+ \t                          \"Push ORDER BY and LIMIT clauses to MySQL (default: true)\", LogicalType::BOOLEAN,","+ \t                          Value::BOOLEAN(true));","+-\tOptimizerExtension mysql_optimizer;","+-\tmysql_optimizer.optimize_function = MySQLOptimizer::Optimize;","+-\tOptimizerExtension::Register(config, std::move(mysql_optimizer));","++\t// OptimizerExtension mysql_optimizer;","++\t// mysql_optimizer.optimize_function = MySQLOptimizer::Optimize;","++\t// OptimizerExtension::Register(config, std::move(mysql_optimizer));","+ }","+ ","+ void MysqlScannerExtension::Load(ExtensionLoader &loader) {","+diff --git a/src/mysql_filter_pushdown.cpp b/src/mysql_filter_pushdown.cpp","+index 63ae838..95a1684 100644","+--- a/src/mysql_filter_pushdown.cpp","+@@ -1,10 +1,260 @@","+ #include \"mysql_filter_pushdown.hpp\"","+ ","+-#include \"dbconnector/table_scan/filter_pushdown.hpp\"","++#include \"duckdb/planner/expression/bound_comparison_expression.hpp\"","++#include \"duckdb/planner/expression/bound_conjunction_expression.hpp\"","++#include \"duckdb/planner/expression/bound_constant_expression.hpp\"","++#include \"duckdb/planner/expression/bound_function_expression.hpp\"","++#include \"duckdb/planner/expression/bound_operator_expression.hpp\"","++#include \"duckdb/planner/filter/table_filter_functions.hpp\"","++#include \"duckdb/common/enum_util.hpp\"","++#include \"duckdb/common/string_util.hpp\"","++","++#include \"dbconnector/query/query_writer.hpp\"","++","+ #include \"dbconnector/table_scan/filter_util.hpp\"","+ ","++#include \"mysql_utils.hpp\"","++","+ namespace duckdb {","+ ","++// This is a MySQL-specific variant of dbconnector::table_scan::FilterPushdown.","++// The main difference is the handling of string constants: MySQL string comparisons are","++// collation-dependent (case-insensitive with the default collation) while DuckDB compares","++// bytes. We compare against binary strings (CAST(... AS BINARY)) to match DuckDB's semantics.","++","++static string WriteFilterConstant(const Value &constant) {","++\tauto constant_string = dbconnector::query::QueryWriter::WriteConstant(constant);","++\tif (constant.type().id() == LogicalTypeId::VARCHAR) {","++\t\t// force a binary (byte-wise) comparison to match DuckDB's string comparison semantics","++\t\treturn \"CAST(\" + constant_string + \" AS BINARY)\";","++\t}","++\treturn constant_string;","++}","++","++//! Where a constant sorts relative to every value a MySQL column can contain. MySQL has no","++//! infinite dates / timestamps and no inf / nan doubles, so DuckDB's non-finite constants","++//! compare above (infinity, nan) or below (-infinity) every value in the column.","++enum class MySQLConstantRange { FINITE, ABOVE_ALL_VALUES, BELOW_ALL_VALUES };","++","++static MySQLConstantRange GetConstantRange(const Value &constant) {","++\tif (constant.IsNull()) {","++\t\treturn MySQLConstantRange::FINITE;","++\t}","++\tswitch (constant.type().id()) {","++\tcase LogicalTypeId::FLOAT: {","++\t\tauto value = FloatValue::Get(constant);","++\t\tif (Value::FloatIsFinite(value)) {","++\t\t\treturn MySQLConstantRange::FINITE;","++\t\t}","++\t\t// DuckDB sorts nan above infinity","++\t\treturn value < 0 ? MySQLConstantRange::BELOW_ALL_VALUES : MySQLConstantRange::ABOVE_ALL_VALUES;","++\t}","++\tcase LogicalTypeId::DOUBLE: {","++\t\tauto value = DoubleValue::Get(constant);","++\t\tif (Value::DoubleIsFinite(value)) {","++\t\t\treturn MySQLConstantRange::FINITE;","++\t\t}","++\t\treturn value < 0 ? MySQLConstantRange::BELOW_ALL_VALUES : MySQLConstantRange::ABOVE_ALL_VALUES;","++\t}","++\tcase LogicalTypeId::DATE: {","++\t\tauto value = DateValue::Get(constant);","++\t\tif (Value::IsFinite(value)) {","++\t\t\treturn MySQLConstantRange::FINITE;","++\t\t}","++\t\treturn value == date_t::ninfinity() ? MySQLConstantRange::BELOW_ALL_VALUES","++\t\t                                    : MySQLConstantRange::ABOVE_ALL_VALUES;","++\t}","++\tcase LogicalTypeId::TIMESTAMP: {","++\t\tauto value = TimestampValue::Get(constant);","++\t\tif (Value::IsFinite(value)) {","++\t\t\treturn MySQLConstantRange::FINITE;","++\t\t}","++\t\treturn value == timestamp_t::ninfinity() ? MySQLConstantRange::BELOW_ALL_VALUES","++\t\t                                         : MySQLConstantRange::ABOVE_ALL_VALUES;","++\t}","++\tdefault:","++\t\treturn MySQLConstantRange::FINITE;","++\t}","++}","++","++//! Serialize a comparison against a constant that compares above / below every value the column","++//! can contain - the comparison is always true (for non-NULL values) or always false","++static string WriteNonFiniteComparison(const string &column_name, ExpressionType comparison_type,","++                                       MySQLConstantRange range) {","++\tbool always_true;","++\tswitch (comparison_type) {","++\tcase ExpressionType::COMPARE_LESSTHAN:","++\tcase ExpressionType::COMPARE_LESSTHANOREQUALTO:","++\t\talways_true = range == MySQLConstantRange::ABOVE_ALL_VALUES;","++\t\tbreak;","++\tcase ExpressionType::COMPARE_GREATERTHAN:","++\tcase ExpressionType::COMPARE_GREATERTHANOREQUALTO:","++\t\talways_true = range == MySQLConstantRange::BELOW_ALL_VALUES;","++\t\tbreak;","++\tcase ExpressionType::COMPARE_NOTEQUAL:","++\t\talways_true = true;","++\t\tbreak;","++\tcase ExpressionType::COMPARE_EQUAL:","++\t\talways_true = false;","++\t\tbreak;","++\tdefault:","++\t\treturn string();","++\t}","++\t// note: a NULL value compares as NULL and is filtered out either way, matching IS NOT NULL","++\treturn always_true ? column_name + \" IS NOT NULL\" : \"FALSE\";","++}","++","++static string TransformComparisonOperator(ExpressionType type) {","++\tswitch (type) {","++\tcase ExpressionType::COMPARE_EQUAL:","++\t\treturn \"=\";","++\tcase ExpressionType::COMPARE_NOTEQUAL:","++\t\treturn \"!=\";","++\tcase ExpressionType::COMPARE_LESSTHAN:","++\t\treturn \"<\";","++\tcase ExpressionType::COMPARE_GREATERTHAN:","++\t\treturn \">\";","++\tcase ExpressionType::COMPARE_LESSTHANOREQUALTO:","++\t\treturn \"<=\";","++\tcase ExpressionType::COMPARE_GREATERTHANOREQUALTO:","++\t\treturn \">=\";","++\tdefault:","++\t\t// unsupported comparison type","++\t\treturn string();","++\t}","++}","++","++static bool IsDirectReference(const Expression &expr) {","++\tswitch (expr.GetExpressionClass()) {","++\tcase ExpressionClass::BOUND_REF:","++\tcase ExpressionClass::BOUND_COLUMN_REF:","++\t\treturn true;","++\tdefault:","++\t\treturn false;","++\t}","++}","++","++static string TransformFilterExpression(const string &column_name, const Expression &expr);","++","++static string CreateConjunctionExpression(const string &column_name, const vector<unique_ptr<Expression>> &filters,","++                                          const string &op) {","++\tvector<string> filter_entries;","++\tfor (auto &filter : filters) {","++\t\tauto new_filter = TransformFilterExpression(column_name, *filter);","++\t\tif (new_filter.empty()) {","++\t\t\tcontinue;","++\t\t}","++\t\tfilter_entries.push_back(std::move(new_filter));","++\t}","++\tif (filter_entries.empty()) {","++\t\treturn string();","++\t}","++\treturn \"(\" + StringUtil::Join(filter_entries, \" \" + op + \" \") + \")\";","++}","++","++static string TransformFilterExpression(const string &column_name, const Expression &expr) {","++\tif (BoundComparisonExpression::IsComparison(expr)) {","++\t\tauto &comparison = expr.Cast<BoundFunctionExpression>();","++\t\tauto comparison_type = 