{"id":"GHSA-gx55-f84r-v3r7","axis":"advisories","repo":"fission/fission","sha":"e484df8460bb4e8026e24210120602aa7f181f64","parsed":{"files":[{"path":"charts/fission-all/templates/webhook-server/webhooks.yaml","lines":["@@ -72,6 +72,7 @@ webhooks:","     - v1","     operations:","     - CREATE","+    - UPDATE","     resources:","     - environments","   sideEffects: None"],"additions":1,"deletions":0,"truncated":false},{"path":"pkg/apis/core/v1/podspec_safety.go","lines":["@@ -0,0 +1,117 @@","+/*","+Copyright 2026 The Fission Authors.","+","+Licensed under the Apache License, Version 2.0 (the \"License\");","+you may not use this file except in compliance with the License.","+You may obtain a copy of the License at","+","+    http://www.apache.org/licenses/LICENSE-2.0","+","+Unless required by applicable law or agreed to in writing, software","+distributed under the License is distributed on an \"AS IS\" BASIS,","+WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.","+See the License for the specific language governing permissions and","+limitations under the License.","+*/","+","+package v1","+","+import (","+\t\"errors\"","+\t\"fmt\"","+","+\tapiv1 \"k8s.io/api/core/v1\"","+)","+","+// dangerousCapabilities lists Linux capabilities that effectively grant root","+// or break the container sandbox. Tenants that can write to Environment or","+// Function PodSpec must not be able to add these via securityContext.","+var dangerousCapabilities = map[apiv1.Capability]struct{}{","+\t\"SYS_ADMIN\":       {},","+\t\"NET_ADMIN\":       {},","+\t\"SYS_PTRACE\":      {},","+\t\"SYS_MODULE\":      {},","+\t\"DAC_READ_SEARCH\": {},","+\t\"DAC_OVERRIDE\":    {},","+}","+","+// ValidatePodSpecSafety rejects PodSpec fields that would let a low-privilege","+// tenant escalate to host or cluster level when the executor or buildermgr","+// schedules a pod from a user-supplied podspec.","+//","+// The fission-executor and fission-builder service accounts have the","+// authority to create Deployments and Pods, so any field that crosses","+// the container sandbox boundary (host namespaces, privileged contexts,","+// hostPath mounts, alternate service accounts, dangerous capabilities)","+// would let a Function- or Environment-CRUD tenant escape the boundary","+// of their own RBAC and reach node-level state.","+//","+// Closes GHSA-gx55-f84r-v3r7, GHSA-wmgg-3p4h-48x7, GHSA-v455-mv2v-5g92.","+//","+// The fieldPath argument is used as a prefix in error messages so the","+// caller can identify which podspec failed (e.g.","+// \"Environment.spec.runtime.podspec\" / \"Function.spec.podspec\").","+func ValidatePodSpecSafety(fieldPath string, ps *apiv1.PodSpec) error {","+\tif ps == nil {","+\t\treturn nil","+\t}","+\tvar errs error","+","+\tif ps.HostNetwork {","+\t\terrs = errors.Join(errs, fmt.Errorf(\"%s.hostNetwork is not allowed\", fieldPath))","+\t}","+\tif ps.HostPID {","+\t\terrs = errors.Join(errs, fmt.Errorf(\"%s.hostPID is not allowed\", fieldPath))","+\t}","+\tif ps.HostIPC {","+\t\terrs = errors.Join(errs, fmt.Errorf(\"%s.hostIPC is not allowed\", fieldPath))","+\t}","+\tif ps.ServiceAccountName != \"\" {","+\t\terrs = errors.Join(errs, fmt.Errorf(\"%s.serviceAccountName override is not allowed\", fieldPath))","+\t}","+\t// DeprecatedServiceAccount is the pre-1.8 alias for ServiceAccountName.","+\t// Kubernetes still honors it for backward compatibility so a tenant could","+\t// otherwise bypass the ServiceAccountName check by setting this field.","+\tif ps.DeprecatedServiceAccount != \"\" {","+\t\terrs = errors.Join(errs, fmt.Errorf(\"%s.serviceAccount (deprecated, alias for serviceAccountName) override is not allowed\", fieldPath))","+\t}","+\tfor i, v := range ps.Volumes {","+\t\tif v.HostPath != nil {","+\t\t\terrs = errors.Join(errs, fmt.Errorf(\"%s.volumes[%d].hostPath (%q) is not allowed\", fieldPath, i, v.Name))","+\t\t}","+\t}","+","+\tcheckContainer := func(group string, c apiv1.Container) error {","+\t\tvar cerrs error","+\t\tsc := c.SecurityContext","+\t\tif sc == nil {","+\t\t\treturn nil","+\t\t}","+\t\tif sc.Privileged != nil && *sc.Privileged {","+\t\t\tcerrs = errors.Join(cerrs, fmt.Errorf(","+\t\t\t\t\"%s.%s[%s].securityContext.privileged=true is not allowed\", fieldPath, group, c.Name))","+\t\t}","+\t\tif sc.AllowPrivilegeEscalation != nil && *sc.AllowPrivilegeEscalation {","+\t\t\tcerrs = errors.Join(cerrs, fmt.Errorf(","+\t\t\t\t\"%s.%s[%s].securityContext.allowPrivilegeEscalation=true is not allowed\", fieldPath, group, c.Name))","+\t\t}","+\t\tif sc.Capabilities != nil {","+\t\t\tfor _, cap := range sc.Capabilities.Add {","+\t\t\t\tif _, bad := dangerousCapabilities[cap]; bad {","+\t\t\t\t\tcerrs = errors.Join(cerrs, fmt.Errorf(","+\t\t\t\t\t\t\"%s.%s[%s].securityContext.capabilities.add[%q] is not allowed\", fieldPath, group, c.Name, cap))","+\t\t\t\t}","+\t\t\t}","+\t\t}","+\t\treturn cerrs","+\t}","+","+\tfor _, c := range ps.Containers {","+\t\terrs = errors.Join(errs, checkContainer(\"containers\", c))","+\t}","+\tfor _, c := range ps.InitContainers {","+\t\terrs = errors.Join(errs, checkContainer(\"initContainers\", c))","+\t}","+","+\treturn errs","+}"],"additions":117,"deletions":0,"truncated":false},{"path":"pkg/apis/core/v1/podspec_safety_test.go","lines":["@@ -0,0 +1,202 @@","+/*","+Copyright 2026 The Fission Authors.","+","+Licensed under the Apache License, Version 2.0 (the \"License\");","+you may not use this file except in compliance with the License.","+You may obtain a copy of the License at","+","+    http://www.apache.org/licenses/LICENSE-2.0","+","+Unless required by applicable law or agreed to in writing, software","+distributed under the License is distributed on an \"AS IS\" BASIS,","+WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.","+See the License for the specific language governing permissions and","+limitations under the License.","+*/","+","+package v1","+","+import (","+\t\"strings\"","+\t\"testing\"","+","+\tapiv1 \"k8s.io/api/core/v1\"","+)","+","+func TestValidatePodSpecSafety_Nil(t *testing.T) {","+\tif err := ValidatePodSpecSafety(\"Function.spec.podspec\", nil); err != nil {","+\t\tt.Fatalf(\"nil podspec must be accepted, got: %v\", err)","+\t}","+}","+","+func TestValidatePodSpecSafety_Benign(t *testing.T) {","+\tallow := false","+\tps := &apiv1.PodSpec{","+\t\tContainers: []apiv1.Container{{","+\t\t\tName:    \"user\",","+\t\t\tImage:   \"alpine:3.19\",","+\t\t\tCommand: []string{\"/bin/sh\", \"-c\", \"echo hi\"},","+\t\t\tEnv:     []apiv1.EnvVar{{Name: \"FOO\", Value: \"bar\"}},","+\t\t\tSecurityContext: &apiv1.SecurityContext{","+\t\t\t\tAllowPrivilegeEscalation: &allow,","+\t\t\t\tCapabilities: &apiv1.Capabilities{","+\t\t\t\t\tAdd: []apiv1.Capability{\"NET_BIND_SERVICE\"},","+\t\t\t\t},","+\t\t\t},","+\t\t}},","+\t\tVolumes: []apiv1.Volume{{","+\t\t\tName: \"cm\",","+\t\t\tVolumeSource: apiv1.VolumeSource{","+\t\t\t\tConfigMap: &apiv1.ConfigMapVolumeSource{","+\t\t\t\t\tLocalObjectReference: apiv1.LocalObjectReference{Name: \"my-cm\"},","+\t\t\t\t},","+\t\t\t},","+\t\t}},","+\t\tNodeSelector: map[string]string{\"role\": \"fn\"},","+\t}","+\tif err := ValidatePodSpecSafety(\"Function.spec.podspec\", ps); err != nil {","+\t\tt.Fatalf(\"benign podspec must be accepted, got: %v\", err)","+\t}","+}","+","+func TestValidatePodSpecSafety_DangerousFields(t *testing.T) {","+\ton := true","+\tcases := []struct {","+\t\tname      string","+\t\tmutate    func(*apiv1.PodSpec)","+\t\twantInErr string","+\t}{","+\t\t{","+\t\t\tname:      \"hostNetwork\",","+\t\t\tmutate:    func(ps *apiv1.PodSpec) { ps.HostNetwork = true },","+\t\t\twantInErr: \"hostNetwork\",","+\t\t},","+\t\t{","+\t\t\tname:      \"hostPID\",","+\t\t\tmutate:    func(ps *apiv1.PodSpec) { ps.HostPID = true },","+\t\t\twantInErr: \"hostPID\",","+\t\t},","+\t\t{","+\t\t\tname:      \"hostIPC\",","+\t\t\tmutate:    func(ps *apiv1.PodSpec) { ps.HostIPC = true },","+\t\t\twantInErr: \"hostIPC\",","+\t\t},","+\t\t{","+\t\t\tname:      \"serviceAccountName override\",","+\t\t\tmutate:    func(ps *apiv1.PodSpec) { ps.ServiceAccountName = \"cluster-admin\" },","+\t\t\twantInErr: \"serviceAccountName\",","+\t\t},","+\t\t{","+\t\t\tname:      \"deprecated serviceAccount (alias) override\",","+\t\t\tmutate:    func(ps *apiv1.PodSpec) { ps.DeprecatedServiceAccount = \"cluster-admin\" },","+\t\t\twantInErr: \"serviceAccount\",","+\t\t},","+\t\t{","+\t\t\tname: \"hostPath volume\",","+\t\t\tmutate: func(ps *apiv1.PodSpec) {","+\t\t\t\tps.Volumes = []apiv1.Volume{{","+\t\t\t\t\tName: \"host-root\",","+\t\t\t\t\tVolumeSource: apiv1.VolumeSource{","+\t\t\t\t\t\tHostPath: &apiv1.HostPathVolumeSource{Path: \"/\"},","+\t\t\t\t\t},","+\t\t\t\t}}","+\t\t\t},","+\t\t\twantInErr: \"hostPath\",","+\t\t},","+\t\t{","+\t\t\tname: \"privileged container\",","+\t\t\tmutate: func(ps *apiv1.PodSpec) {","+\t\t\t\tps.Containers = []apiv1.Container{{","+\t\t\t\t\tName:            \"user\",","+\t\t\t\t\tSecurityContext: &apiv1.SecurityContext{Privileged: &on},","+\t\t\t\t}}","+\t\t\t},","+\t\t\twantInErr: \"privileged\",","+\t\t},","+\t\t{","+\t\t\tname: \"allowPrivilegeEscalation=true\",","+\t\t\tmutate: func(ps *apiv1.PodSpec) {","+\t\t\t\tps.Containers = []apiv1.Container{{","+\t\t\t\t\tName:            \"user\",","+\t\t\t\t\tSecurityContext: &apiv1.SecurityContext{AllowPrivilegeEscalation: &on},","+\t\t\t\t}}","+\t\t\t},","+\t\t\twantInErr: \"allowPrivilegeEscalation\",","+\t\t},","+\t\t{","+\t\t\tname: \"SYS_ADMIN capability\",","+\t\t\tmutate: func(ps *apiv1.PodSpec) {","+\t\t\t\tps.Containers = []apiv1.Container{{","+\t\t\t\t\tName: \"user\",","+\t\t\t\t\tSecurityContext: &apiv1.SecurityContext{","+\t\t\t\t\t\tCapabilities: &apiv1.Capabilities{","+\t\t\t\t\t\t\tAdd: []apiv1.Capability{\"SYS_ADMIN\"},","+\t\t\t\t\t\t},","+\t\t\t\t\t},","+\t\t\t\t}}","+\t\t\t},","+\t\t\twantInErr: \"SYS_ADMIN\",","+\t\t},","+\t\t{","+\t\t\tname: \"NET_ADMIN capability\",","+\t\t\tmutate: func(ps *apiv1.PodSpec) {","+\t\t\t\tps.Containers = []apiv1.Container{{","+\t\t\t\t\tName: \"user\",","+\t\t\t\t\tSecurityContext: &apiv1.SecurityContext{","+\t\t\t\t\t\tCapabilities: &apiv1.Capabilities{","+\t\t\t\t\t\t\tAdd: []apiv1.Capability{\"NET_ADMIN\"},","+\t\t\t\t\t\t},","+\t\t\t\t\t},","+\t\t\t\t}}","+\t\t\t},","+\t\t\twantInErr: \"NET_ADMIN\",","+\t\t},","+\t\t{","+\t\t\tname: \"privileged init container\",","+\t\t\tmutate: func(ps *apiv1.PodSpec) {","+\t\t\t\tps.InitContainers = []apiv1.Container{{","+\t\t\t\t\tName:            \"init\",","+\t\t\t\t\tSecurityContext: &apiv1.SecurityContext{Privileged: &on},","+\t\t\t\t}}","+\t\t\t},","+\t\t\twantInErr: \"initContainers\",","+\t\t},","+\t}","+","+\tfor _, tc := range cases {","+\t\tt.Run(tc.name, func(t *testing.T) {","+\t\t\tps := &apiv1.PodSpec{Containers: []apiv1.Container{{Name: \"user\"}}}","+\t\t\ttc.mutate(ps)","+\t\t\terr := ValidatePodSpecSafety(\"Function.spec.podspec\", ps)","+\t\t\tif err == nil {","+\t\t\t\tt.Fatalf(\"expected rejection for %s, got nil\", tc.name)","+\t\t\t}","+\t\t\tif !strings.Contains(err.Error(), tc.wantInErr) {","+\t\t\t\tt.Fatalf(\"error must mention %q, got: %v\", tc.wantInErr, err)","+\t\t\t}","+\t\t\tif !strings.Contains(err.Error(), \"Function.spec.podspec\") {","+\t\t\t\tt.Fatalf(\"error must include the field prefix, got: %v\", err)","+\t\t\t}","+\t\t})","+\t}","+}","+","+// TestValidatePodSpecSafety_BenignCapability asserts that NET_BIND_SERVICE","+// (and other non-dangerous capabilities) flow through. The denylist is","+// intentionally narrow so legitimate function workloads can still bind to","+// privileged ports etc.","+func TestValidatePodSpecSafety_BenignCapability(t *testing.T) {","+\tps := &apiv1.PodSpec{","+\t\tContainers: []apiv1.Container{{","+\t\t\tName: \"user\",","+\t\t\tSecurityContext: &apiv1.SecurityContext{","+\t\t\t\tCapabilities: &apiv1.Capabilities{","+\t\t\t\t\tAdd: []apiv1.Capability{\"NET_BIND_SERVICE\", \"CHOWN\"},","+\t\t\t\t},","+\t\t\t},","+\t\t}},","+\t}","+\tif err := ValidatePodSpecSafety(\"Function.spec.podspec\", ps); err != nil {","+\t\tt.Fatalf(\"non-dangerous capabilities must flow through, got: %v\", err)","+\t}","+}"],"additions":202,"deletions":0,"truncated":false},{"path":"pkg/apis/core/v1/validation.go","lines":["@@ -296,6 +296,9 @@ func (spec FunctionSpec) Validate() error {"," \tif spec.InvokeStrategy.ExecutionStrategy.ExecutorType == ExecutorTypeContainer && spec.PodSpec == nil {"," \t\terrs = errors.Join(errs, MakeValidationErr(ErrorInvalidObject, \"FunctionSpec.PodSpec\", \"\", \"executor type container requires a pod spec\"))"," \t}","+\t// Reject podspec fields that would let a tenant escalate via the","+\t// executor service account. Closes GHSA-v455-mv2v-5g92.","+\terrs = errors.Join(errs, ValidatePodSpecSafety(\"Function.spec.podspec\", spec.PodSpec))"," "," \t// TODO Add below validation warning"," \t// if spec.FunctionTimeout <= 0 {","@@ -666,6 +669,11 @@ func (e *Environment) Validate() error {"," \t\t\t}"," \t\t}"," \t}","+\t// Reject podspec fields that would let a tenant escalate via the","+\t// executor / buildermgr service accounts. Closes GHSA-gx55-f84r-v3r7,","+\t// GHSA-wmgg-3p4h-48x7.","+\terrs = errors.Join(errs, ValidatePodSpecSafety(\"Environment.spec.runtime.podspec\", e.Spec.Runtime.PodSpec))","+\terrs = errors.Join(errs, ValidatePodSpecSafety(\"Environment.spec.builder.podspec\", e.Spec.Builder.PodSpec))"," \treturn errs"," }"," "],"additions":8,"deletions":0,"truncated":false},{"path":"pkg/executor/util/merge.go","lines":["@@ -79,8 +79,29 @@ func MergePodSpec(srcPodSpec *apiv1.PodSpec, targetPodSpec *apiv1.PodSpec) (*api"," \t\tsrcPodSpec.InitContainers = cList"," \t}"," ","-\t// For volumes - if duplicate exist, throw error","-\tvols, err := mergeVolumeLists(srcPodSpec.Volumes, targetPodSpec.Volumes)","+\t// Sanitize per-container SecurityContext after the merge. The admission","+\t// webhook rejects privileged=true / allowPrivilegeEscalation=true and","+\t// dangerous capabilities (SYS_ADMIN, NET_ADMIN, etc.) at submit time,","+\t// but a webhook-bypass cluster (failurePolicy=Ignore or a stale object","+\t// from a pre-webhook upgrade window) could still reach this code path.","+\t// Strip the dangerous bits from the merged result so the resulting pod","+\t// cannot escape its container even if admission was bypassed. Closes","+\t// GHSA-gx55-f84r-v3r7 / GHSA-wmgg-3p4h-48x7 / GHSA-v455-mv2v-5g92.","+\tfor i := range srcPodSpec.Containers {","+\t\tsanitizeContainerSecurityContext(&srcPodSpec.Containers[i])","+\t}","+\tfor i := range srcPodSpec.InitContainers {","+\t\tsanitizeContainerSecurityContext(&srcPodSpec.InitContainers[i])","+\t}","+","+\t// For volumes - if duplicate exist, throw error. hostPath volumes are","+\t// stripped from the target before merge: a tenant-supplied hostPath","+\t// mount is a node-escape primitive (read /etc, the container runtime","+\t// socket, etc.). The admission webhook rejects them, and this layer","+\t// makes them unreachable even on webhook-bypass clusters. Closes","+\t// GHSA-gx55-f84r-v3r7 / GHSA-wmgg-3p4h-48x7 / GHSA-v455-mv2v-5g92.","+\tfilteredTargetVols := stripHostPathVolumes(targetPodSpec.Volumes)","+\tvols, err := mergeVolumeLists(srcPodSpec.Volumes, filteredTargetVols)"," \tif err != nil {"," \t\tmultierr = errors.Join(multierr, err)"," \t} else {","@@ -113,6 +134,16 @@ func MergePodSpec(srcPodSpec *apiv1.PodSpec, targetPodSpec *apiv1.PodSpec) (*api"," \t}"," "," \t// TODO - Security context should be merged instead of overriding.","+\t// Pod-level SecurityContext IS propagated: the chart's","+\t// runtimePodSpec.podSpec.securityContext / builderPodSpec.podSpec.","+\t// securityContext are operator-supplied hardening (fsGroup,","+\t// runAsNonRoot=true, runAsUser=10001, runAsGroup=10001) that must","+\t// reach the pool / builder pods. The node-escape primitives flagged","+\t// by GHSA-gx55-f84r-v3r7 / GHSA-wmgg-3p4h-48x7 / GHSA-v455-mv2v-5g92","+\t// live at container-level (privileged, allowPrivilegeEscalation,","+\t// dangerous capabilities) and at pod level (hostNetwork, hostPID,","+\t// hostIPC, hostPath volumes, serviceAccountName override) — all of","+\t// which are denylisted in pkg/apis/core/v1/podspec_safety.go."," \tif targetPodSpec.SecurityContext != nil {"," \t\tsrcPodSpec.SecurityContext = targetPodSpec.SecurityContext"," \t}","@@ -142,29 +173,22 @@ func MergePodSpec(srcPodSpec *apiv1.PodSpec, targetPodSpec *apiv1.PodSpec) (*api"," \t\tsrcPodSpec.DNSPolicy = targetPodSpec.DNSPolicy"," \t}"," ","-\tif targetPodSpec.ServiceAccountName != \"\" {","-\t\tsrcPodSpec.ServiceAccountName = targetPodSpec.ServiceAccountName","-\t}","-","-\tif targetPodSpec.DeprecatedServiceAccount != \"\" {","-\t\tsrcPodSpec.DeprecatedServiceAccount = targetPodSpec.DeprecatedServiceAccount","-\t}","+\t// ServiceAccountName / DeprecatedServiceAccount intentionally not","+\t// propagated: the controller chooses the SA for the pod","+\t// (fission-fetcher for runtime pods, fission-builder for build pods).","+\t// Letting a user-supplied podspec override it would defeat the SA-token","+\t// scoping introduced by GHSA-85g2-pmrx-r49q and GHSA-8wcj-mfrc-jx5q.","+\t// Closes GHSA-gx55-f84r-v3r7 / GHSA-wmgg-3p4h-48x7 / GHSA-v455-mv2v-5g92."," "," \tif targetPodSpec.AutomountServiceAccountToken != nil {"," \t\tsrcPodSpec.AutomountServiceAccountToken = targetPodSpec.AutomountServiceAccountToken"," \t}"," ","-\tif targetPodSpec.HostNetwork {","-\t\tsrcPodSpec.HostNetwork = targetPodSpec.HostNetwork","-\t}","-","-\tif targetPodSpec.HostPID {","-\t\tsrcPodSpec.HostPID = targetPodSpec.HostPID","-\t}","-","-\tif targetPodSpec.HostIPC {","-\t\tsrcPodSpec.HostIPC = targetPodSpec.HostIPC","-\t}","+\t// HostNetwork / HostPID / HostIPC intentionally not propagated.","+\t// A pod sharing host namespaces is a node-escape primitive — the","+\t// admission webhook rejects these fields, and this layer makes them","+\t// unreachable even on webhook-bypass clusters.","+\t// Closes GHSA-gx55-f84r-v3r7 / GHSA-wmgg-3p4h-48x7 / GHSA-v455-mv2v-5g92."," "," \tif targetPodSpec.ShareProcessNamespace != nil {"," \t\tsrcPodSpec.ShareProcessNamespace = targetPodSpec.ShareProcessNamespace","@@ -288,3 +312,79 @@ func checkSliceConflicts(field string, objs any) (err error) {"," \t}"," \treturn errs"," }","+","+// stripHostPathVolumes returns a copy of vols with any volume whose source","+// is a hostPath removed. Defense in depth — the admission webhook already","+// rejects hostPath in tenant-supplied podspecs (see","+// pkg/apis/core/v1/podspec_safety.go), but on webhook-bypass clusters","+// (failurePolicy=Ignore, or stale objects from a pre-webhook upgrade","+// window) this layer makes the dangerous primitive unreachable.","+// Closes GHSA-gx55-f84r-v3r7 / GHSA-wmgg-3p4h-48x7 / GHSA-v455-mv2v-5g92.","+func stripHostPathVolumes(vols []apiv1.Volume) []apiv1.Volume {","+\tif len(vols) == 0 {","+\t\treturn vols","+\t}","+\tout := make([]apiv1.Volume, 0, len(vols))","+\tfor _, v := range vols {","+\t\tif v.HostPath != nil {","+\t\t\tcontinue","+\t\t}","+\t\tout = append(out, v)","+\t}","+\treturn out","+}","+","+// dangerousMergeContainerCapabilities lists the Linux capabilities that","+// effectively bypass the container sandbox. Kept in sync with the","+// authoritative denylist in pkg/apis/core/v1/podspec_safety.go — the","+// admission webhook is the primary defence; this is the merge-layer","+// belt-and-braces for webhook-bypass clusters.","+var dangerousMergeContainerCapabilities = map[apiv1.Capability]struct{}{","+\t\"SYS_ADMIN\":       {},","+\t\"NET_ADMIN\":       {},","+\t\"SYS_PTRACE\":      {},","+\t\"SYS_MODULE\":      {},","+\t\"DAC_READ_SEARCH\": {},","+\t\"DAC_OVERRIDE\":    {},","+}","+","+// sanitizeContainerSecurityContext zeroes out the privilege-escalation bits","+// of a container's SecurityContext after a MergePodSpec call. The merge","+// path uses mergo.WithOverride and unconditionally copies SecurityContext","+// fields from the target container, so a tenant-supplied podspec with","+// privileged=true / allowPrivilegeEscalation=true / Capabilities.Add =","+// [SYS_ADMIN, ...] would otherwise reach the running pod on","+// webhook-bypass clusters (failurePolicy=Ignore or stale objects from a","+// pre-webhook upgrade). The webhook is the primary defence; this is","+// defence in depth. Closes GHSA-gx55-f84r-v3r7 / GHSA-wmgg-3p4h-48x7 /","+// GHSA-v455-mv2v-5g92.","+func sanitizeContainerSecurityContext(c *apiv1.Container) {","+\tif c.SecurityContext == nil {","+\t\treturn","+\t}","+\t// Deep-copy before mutating. MergeContainer does a shallow struct copy","+\t// (`dstC := *dst`) and mergo.WithOverride aliases src.SecurityContext","+\t// onto dstC.SecurityContext, so mutating in place would leak into the","+\t// caller's targetPodSpec — which is typically env.Spec.Runtime.PodSpec","+\t// from an informer cache. Allocating a fresh SecurityContext (and a","+\t// fresh Capabilities.Add slice via a new backing array) keeps the","+\t// sanitization local to the merged result.","+\tc.SecurityContext = c.SecurityContext.DeepCopy()","+\tsc := c.SecurityContext","+\tif sc.Privileged != nil && *sc.Privileged {","+\t\tsc.Privileged = new(false)","+\t}","+\tif sc.AllowPrivilegeEscalation != nil && *sc.AllowPrivilegeEscalation {","+\t\tsc.AllowPrivilegeEscalation = new(false)","+\t}","+\tif sc.Capabilities != nil && len(sc.Capabilities.Add) > 0 {","+\t\tfiltered := make([]apiv1.Capability, 0, len(sc.Capabilities.Add))","+\t\tfor _, cap := range sc.Capabilities.Add {","+\t\t\tif _, bad := dangerousMergeContainerCapabilities[cap]; bad {","+\t\t\t\tcontinue","+\t\t\t}","+\t\t\tfiltered = append(filtered, cap)","+\t\t}","+\t\tsc.Capabilities.Add = filtered","+\t}","+}"],"additions":120,"deletions":20,"truncated":false},{"path":"pkg/executor/util/merge_test.go","lines":["@@ -331,3 +331,149 @@ func Test_mergeContainerList(t *testing.T) {"," \t\t})"," \t}"," }","+","+// TestMergePodSpec_StripsDangerousFields pin