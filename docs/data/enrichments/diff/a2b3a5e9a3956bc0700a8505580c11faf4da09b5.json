suffix)+2)","+\tcompacted = append(compacted, prefix...)","+\tcompacted = append(compacted, CompactionSummaryMessages(summary, req.ContinueTask)...)","+\tcompacted = append(compacted, suffix...)","+\tresult.Messages = compacted","+\tresult.Compacted = true","+\tresult.Summary = summary","+\treturn result, nil","+}","+","+func (c *SimpleCompactor) shouldCompact(req CompactionRequest) bool {","+\tcontextWindow := c.contextWindowTokens(req.Options)","+\tthreshold := int(float64(contextWindow) * c.threshold())","+\tif threshold <= 0 {","+\t\treturn false","+\t}","+\tif req.Latest.PromptEvalCount > 0 && req.Latest.PromptEvalCount >= threshold {","+\t\treturn true","+\t}","+\treturn estimateCompactionRequestTokens(req) >= threshold","+}","+","+func (c *SimpleCompactor) contextWindowTokens(options map[string]any) int {","+\treturn ResolveContextWindowTokens(options, c.Options.ContextWindowTokens)","+}","+","+func (c *SimpleCompactor) keepUserTurns(options map[string]any) int {","+\tcontextWindow := c.contextWindowTokens(options)","+\tif contextWindow > 0 && contextWindow < compactOnlySummaryContextTokens {","+\t\treturn 0","+\t}","+\tif c.Options.KeepUserTurns > 0 {","+\t\treturn c.Options.KeepUserTurns","+\t}","+\treturn defaultCompactionKeepUserTurns","+}","+","+func (c *SimpleCompactor) threshold() float64 {","+\treturn ResolveCompactionThreshold(c.Options.Threshold)","+}","+","+func ResolveContextWindowTokens(options map[string]any, configured int) int {","+\tif n := intOption(options, \"num_ctx\"); n > 0 {","+\t\treturn n","+\t}","+\tif configured > 0 {","+\t\treturn configured","+\t}","+\treturn defaultCompactionContextWindowTokens","+}","+","+func ResolveCompactionThreshold(configured float64) float64 {","+\tif configured > 0 {","+\t\treturn configured","+\t}","+\treturn defaultCompactionThreshold","+}","+","+func (c *SimpleCompactor) summarize(ctx context.Context, req CompactionRequest, previousSummary string, archive []api.Message) (string, error) {","+\tbody, err := compactionPrompt(previousSummary, archive, c.compactionPromptBodyBudgetTokens(req.Options))","+\tif err != nil {","+\t\treturn \"\", err","+\t}","+","+\tchatReq := &api.ChatRequest{","+\t\tModel: req.Model,","+\t\tMessages: []api.Message{","+\t\t\t{","+\t\t\t\tRole:    \"system\",","+\t\t\t\tContent: compactionSystemPrompt,","+\t\t\t},","+\t\t\t{","+\t\t\t\tRole:    \"user\",","+\t\t\t\tContent: body,","+\t\t\t},","+\t\t},","+\t\tOptions: req.Options,","+\t\tThink:   req.Think,","+\t}","+\tif req.KeepAlive != nil {","+\t\tchatReq.KeepAlive = req.KeepAlive","+\t}","+","+\tvar summary strings.Builder","+\tif err := c.Client.Chat(ctx, chatReq, func(response api.ChatResponse) error {","+\t\tsummary.WriteString(response.Message.Content)","+\t\tif req.Progress != nil {","+\t\t\ttokens := response.EvalCount","+\t\t\tif tokens <= 0 {","+\t\t\t\ttokens = estimateCompactionTokens(summary.String())","+\t\t\t}","+\t\t\treq.Progress(CompactionProgress{Tokens: tokens})","+\t\t}","+\t\treturn nil","+\t}); err != nil {","+\t\treturn \"\", err","+\t}","+\treturn summary.String(), nil","+}","+","+func (c *SimpleCompactor) summarizeEmptyFallback(ctx context.Context, req CompactionRequest, previousSummary string, archive []api.Message) (string, error) {","+\tretry := req","+\tretry.Think = &api.ThinkValue{Value: false}","+\tsummary, err := c.summarize(ctx, retry, previousSummary, archive)","+\tif err == nil {","+\t\treturn summary, nil","+\t}","+\tif !isUnsupportedCompactionThinkError(err) {","+\t\treturn \"\", err","+\t}","+\tif req.Think == nil {","+\t\treturn \"\", nil","+\t}","+\tretry.Think = nil","+\treturn c.summarize(ctx, retry, previousSummary, archive)","+}","+","+func isUnsupportedCompactionThinkError(err error) bool {","+\tif err == nil {","+\t\treturn false","+\t}","+\ttext := strings.ToLower(err.Error())","+\tif !strings.Contains(text, \"think\") {","+\t\treturn false","+\t}","+\tvar statusErr api.StatusError","+\tif errors.As(err, &statusErr) && statusErr.StatusCode != 0 {","+\t\treturn statusErr.StatusCode == http.StatusBadRequest","+\t}","+\treturn strings.Contains(text, \"does not support\") || strings.Contains(text, \"not supported\") || strings.Contains(text, \"unsupported\")","+}","+","+// compactionSummaryMessageForTask renders a compaction summary as the content","+// string stored on the synthetic tool-result message.","+func compactionSummaryMessageForTask(summary string, continueTask bool) string {","+\tcontent := CompactionSummaryMessagePrefix + strings.TrimSpace(summary)","+\tif continueTask {","+\t\tcontent = strings.TrimSpace(content) + \"\\n\\n\" + CompactionContinueInstruction","+\t}","+\treturn content","+}","+","+// CompactionSummaryMessages renders a compaction summary as the assistant","+// tool-call plus tool-result pair that represents a compacted turn in the","+// message history.","+func CompactionSummaryMessages(summary string, continueTask bool) []api.Message {","+\treturn []api.Message{","+\t\t{","+\t\t\tRole: \"assistant\",","+\t\t\tToolCalls: []api.ToolCall{{","+\t\t\t\tID: CompactionToolCallID,","+\t\t\t\tFunction: api.ToolCallFunction{","+\t\t\t\t\tName: CompactionToolName,","+\t\t\t\t},","+\t\t\t}},","+\t\t},","+\t\t{","+\t\t\tRole:       \"tool\",","+\t\t\tToolName:   CompactionToolName,","+\t\t\tToolCallID: CompactionToolCallID,","+\t\t\tContent:    compactionSummaryMessageForTask(summary, continueTask),","+\t\t},","+\t}","+}","+","+func (c *SimpleCompactor) compactionPromptBodyBudgetTokens(options map[string]any) int {","+\tcontextWindow := c.contextWindowTokens(options)","+\tthreshold := int(float64(contextWindow) * c.threshold())","+\tif threshold <= 0 {","+\t\treturn 0","+\t}","+\tsystemTokens := estimateCompactionTokens(\"system\") + estimateCompactionTokens(compactionSystemPrompt)","+\tuserRoleTokens := estimateCompactionTokens(\"user\")","+\tbudget := threshold - systemTokens - userRoleTokens","+\tif budget <= 0 {","+\t\treturn 0","+\t}","+\treturn budget","+}","+","+func truncateCompactionSummary(summary string) string {","+\tif len(summary) <= maxCompactionSummaryBytes {","+\t\treturn summary","+\t}","+\tlimit := maxCompactionSummaryBytes - len(compactionSummaryTruncated)","+\tif limit < 0 {","+\t\tlimit = 0","+\t}","+\tvar b strings.Builder","+\tfor _, r := range summary {","+\t\tif b.Len()+len(string(r)) > limit {","+\t\t\tbreak","+\t\t}","+\t\tb.WriteRune(r)","+\t}","+\treturn strings.TrimSpace(b.String()) + compactionSummaryTruncated","+}","+","+func estimateCompactionTokens(text string) int {","+\ttext = strings.TrimSpace(text)","+\tif text == \"\" {","+\t\treturn 0","+\t}","+\treturn max(1, (len([]rune(text))+3)/4)","+}","+","+func estimateMessagesTokens(messages []api.Message) int {","+\tvar total int","+\tfor _, msg := range messages {","+\t\ttotal += estimateCompactionTokens(msg.Role)","+\t\ttotal += estimateCompactionTokens(msg.Content)","+\t\ttotal += estimateCompactionTokens(msg.Thinking)","+\t\ttotal += estimateCompactionTokens(msg.ToolName)","+\t\ttotal += estimateCompactionTokens(msg.ToolCallID)","+\t\tfor _, call := range msg.ToolCalls {","+\t\t\ttotal += estimateCompactionTokens(call.Function.Name)","+\t\t\ttotal += estimateCompactionTokens(call.Function.Arguments.String())","+\t\t}","+\t}","+\treturn total","+}","+","+func estimateCompactionRequestTokens(req CompactionRequest) int {","+\trequestMessages := sanitizeMessagesForEstimate(req.Messages)","+\tif strings.TrimSpace(req.SystemPrompt) != \"\" {","+\t\trequestMessages = make([]api.Message, 0, len(req.Messages)+1)","+\t\trequestMessages = append(requestMessages, api.Message{Role: \"system\", Content: strings.TrimSpace(req.SystemPrompt)})","+\t\trequestMessages = append(requestMessages, sanitizeMessagesForEstimate(req.Messages)...)","+\t}","+","+\tpayload := struct {","+\t\tMessages []api.Message   `json:\"messages,omitempty\"`","+\t\tTools    api.Tools       `json:\"tools,omitempty\"`","+\t\tFormat   json.RawMessage `json:\"format,omitempty\"`","+\t}{","+\t\tMessages: reque