ments in the array for each specified path in the variant, or `0` if not an array.\";","+\tstatic constexpr const char *Example = \"variant_array_length(['duck', 'goose']::VARIANT)\\001variant_array_length({'a': ['duck', 'goose']}::VARIANT, 'a')\\001variant_array_length({'a': 1, 'b': ['duck', 'goose']}::VARIANT, ['a', 'b'])\";","+\tstatic constexpr const char *Categories = \"variant\\001variant\\001variant\";","+","+\tstatic ScalarFunctionSet GetFunctions();","+};","+"," struct VariantExistsFun {"," \tstatic constexpr const char *Name = \"variant_exists\";"," \tstatic constexpr const char *Parameters = \"input_variant::VARIANT,path::VARCHAR\\001input_variant::VARIANT,path::VARCHAR[]\";"],"additions":10,"deletions":0,"truncated":false},{"path":"src/include/duckdb/function/scalar/variant_path_function.hpp","lines":["@@ -0,0 +1,115 @@","+//===----------------------------------------------------------------------===//","+//                         DuckDB","+//","+// duckdb/function/scalar/variant_path_function.hpp","+//","+//","+//===----------------------------------------------------------------------===//","+","+#pragma once","+","+#include \"duckdb/common/vector/flat_vector.hpp\"","+#include \"duckdb/function/scalar/variant_utils.hpp\"","+","+namespace duckdb {","+","+struct VariantPathFunction {","+\t//! Executes scalar VARIANT functions that accept an optional constant path argument.","+\t//! The function may be called as f(VARIANT), f(VARIANT, VARCHAR) or f(VARIANT, VARCHAR[]).","+\t//! `collect_fn` is run once for each requested path and produces an intermediate result.","+\t//! `write_fn` writes one row from that intermediate result.","+\ttemplate <class COLLECTED_TYPE, class RESULT_TYPE, class COLLECT_FUNCTION, class WRITE_FUNCTION>","+\tstatic void Execute(DataChunk &input, const ExpressionState &state, Vector &result,","+\t                    const COLLECT_FUNCTION &collect_fn, const WRITE_FUNCTION &write_fn) {","+\t\tD_ASSERT(input.ColumnCount() == 1 || input.ColumnCount() == 2);","+\t\tconst auto count = input.size();","+\t\tconst auto &variant_vec = input.data[0];","+","+\t\tif (input.ColumnCount() == 2) {","+\t\t\tconst auto &path = input.data[1];","+\t\t\tD_ASSERT(path.GetVectorType() == VectorType::CONSTANT_VECTOR);","+\t\t\t(void)path;","+\t\t}","+","+\t\tauto &func_expr = state.expr.Cast<BoundFunctionExpression>();","+\t\tauto &info = func_expr.BindInfo()->Cast<VariantPathBindData>();","+\t\tauto n_columns = input.ColumnCount();","+","+\t\tif (n_columns == 1) {","+\t\t\tExecuteUnary<COLLECTED_TYPE, RESULT_TYPE>(variant_vec, {}, result, count, collect_fn, write_fn);","+\t\t\treturn;","+\t\t}","+","+\t\tD_ASSERT(n_columns == 2);","+\t\tconst auto &path_type_id = input.data[1].GetType().id();","+","+\t\tif (path_type_id == LogicalTypeId::VARCHAR) {","+\t\t\tExecuteUnary<COLLECTED_TYPE, RESULT_TYPE>(variant_vec, info.paths[0], result, count, collect_fn, write_fn);","+\t\t\treturn;","+\t\t}","+\t\tif (path_type_id == LogicalTypeId::LIST) {","+\t\t\tExecuteMany<COLLECTED_TYPE, RESULT_TYPE>(variant_vec, info.paths, result, count, collect_fn, write_fn);","+\t\t\treturn;","+\t\t}","+\t}","+","+private:","+\t//! Executes a single path and writes RESULT_TYPE per input row.","+\ttemplate <class COLLECTED_TYPE, class RESULT_TYPE, class COLLECT_FUNCTION, class WRITE_FUNCTION>","+\tstatic void ExecuteUnary(const Vector &variant_vec, const vector<VariantPathComponent> &components, Vector &result,","+\t                         const idx_t count, const COLLECT_FUNCTION &collect_fn, const WRITE_FUNCTION &write_fn) {","+\t\tRecursiveUnifiedVectorFormat source_format;","+\t\tVector::RecursiveToUnifiedFormat(variant_vec, source_format);","+\t\tconst UnifiedVariantVectorData variant(source_format);","+","+\t\tconst COLLECTED_TYPE collected = collect_fn(variant, components, count);","+","+\t\tresult.Initialize(VectorDataInitialization::UNINITIALIZED, count);","+\t\tauto row_writer = FlatVector::Writer<RESULT_TYPE>(result, count);","+","+\t\tfor (idx_t row_idx = 0; row_idx < count; row_idx++) {","+\t\t\tif (!variant.RowIsValid(row_idx)) {","+\t\t\t\trow_writer.WriteNull();","+\t\t\t\tcontinue;","+\t\t\t}","+","+\t\t\twrite_fn(variant, row_writer, collected, row_idx);","+\t\t}","+\t}","+","+\t//! Executes a list of paths and writes LIST<RESULT_TYPE> per input row.","+\ttemplate <class COLLECTED_TYPE, class RESULT_TYPE, class COLLECT_FUNCTION, class WRITE_FUNCTION>","+\tstatic void ExecuteMany(const Vector &variant_vec, const vector<vector<VariantPathComponent>> &paths,","+\t                        Vector &result, const idx_t count, const COLLECT_FUNCTION &collect_fn,","+\t                        const WRITE_FUNCTION &write_fn) {","+\t\tvector<COLLECTED_TYPE> collected_by_path;","+\t\tcollected_by_path.reserve(paths.size());","+","+\t\tRecursiveUnifiedVectorFormat source_format;","+\t\tVector::RecursiveToUnifiedFormat(variant_vec, source_format);","+\t\tconst UnifiedVariantVectorData variant(source_format);","+","+\t\tfor (const auto &path : paths) {","+\t\t\tcollected_by_path.push_back(collect_fn(variant, path, count));","+\t\t}","+","+\t\tresult.Initialize(VectorDataInitialization::UNINITIALIZED, count);","+\t\tauto result_writer = FlatVector::Writer<VectorListType<RESULT_TYPE>>(result, count);","+","+\t\tfor (idx_t row_idx = 0; row_idx < count; row_idx++) {","+\t\t\tif (!variant.RowIsValid(row_idx)) {","+\t\t\t\tresult_writer.WriteNull();","+\t\t\t\tcontinue;","+\t\t\t}","+","+\t\t\tauto row_writer = result_writer.WriteList(paths.size());","+","+\t\t\tidx_t path_idx = 0;","+\t\t\tfor (auto &path_writer : row_writer) {","+\t\t\t\twrite_fn(variant, path_writer, collected_by_path[path_idx], row_idx);","+\t\t\t\tpath_idx++;","+\t\t\t}","+\t\t}","+\t}","+};","+} // namespace duckdb"],"additions":115,"deletions":0,"truncated":false},{"path":"src/include/duckdb/function/scalar/variant_utils.hpp","lines":["@@ -113,14 +113,6 @@ struct VariantPathSelection {"," };"," "," struct VariantUtils {","-\tusing unary_path_function_t = void (*)(const Vector &, const vector<VariantPathComponent> &, Vector &, idx_t);","-\tusing many_path_function_t = void (*)(const Vector &, const vector<vector<VariantPathComponent>> &, Vector &,","-\t                                      idx_t);","-","-\t//! Generic dispatcher for function execution, used by functions that take an (optional) path(s)","-\tDUCKDB_API static void ExecutePathFunction(DataChunk &input, const ExpressionState &state, Vector &result,","-\t                                           const unary_path_function_t &unary_fn,","-\t                                           const many_path_function_t &many_fn);"," \tDUCKDB_API static bool IsNestedType(const UnifiedVariantVectorData &variant, idx_t row, uint32_t value_index);"," \tDUCKDB_API static VariantDecimalData DecodeDecimalData(const UnifiedVariantVectorData &variant, idx_t row,"," \t                                                       uint32_t value_index);"],"additions":0,"deletions":8,"truncated":false},{"path":"test/configs/storage_compatibility.json","lines":["@@ -125,6 +125,7 @@","         \"test/sql/function/variant/variant_typeof.test\",","         \"test/sql/function/variant/variant_keys.test\",","         \"test/sql/function/variant/variant_exists.test\",","+        \"test/sql/function/variant/variant_array_length.test\",","         \"test/sql/storage/types/variant/append_shredded.test\",","         \"test/sql/storage/types/variant/big_table.test_slow\",","         \"test/sql/storage/types/variant/extension_types.test\","],"additions":1,"deletions":0,"truncated":false},{"path":"test/sql/function/variant/variant_array_length.test","lines":["@@ -0,0 +1,204 @@","+# name: test/sql/function/variant/variant_array_length.test","+# group: [variant]","+","+require json","+","+load {TEST_DIR}/variant_array_length.db readwrite v1.5.0","+","+statement ok","+CREATE MACRO struct_cast_data() AS TABLE (","+\tSELECT {'a': [","+\t\t{","+\t\t\t'b': 'hello',","+\t\t\t'c': NULL,","+\t\t\t'a': '1970/03/15'::DATE","+\t\t},","+\t\t{","+\t\t\t'b': NULL,","+\t\t\t'c': True,","+\t\t\t'a': '2020/11/03'::DATE","+\t\t}","+\t]}::VARIANT AS a","+\tUNION ALL","+\tSELECT {'a': [","+\t\t{","+\t\t\t'b': 'this is a long string',","+\t\t\t'c': False,","+\t\t\t'a': '1953/9/16'::DATE","+\t\t}","+\t],","+\t'b': 42,","+\t'c': {","+\t    'd': 'world'","+\t}}::VARIANT","+);","+","+# FIXME: Can have VARCHAR as input for variant parameter (should produce `2`).","+","+query I","+select variant_array_length('{\"a\": [1, 2], \"b\": {\"c\": 12, \"d\": 10}}', 'a');","+----","+NULL","+","+# Empty path supplied","+","+query I","+select variant_array_length(a, '') from struct_cast_data();","+----","+0","+0","+","+query I","+select variant_array_length([1, 2]::VARIANT, '');","+----","+2","+","+query I","+select variant_array_length(a, []) from struct_cast_data();","+----","+[]","+[]","+","+query I","+select variant_array_length(a, ['']) from struct_cast_data();","+----","+[0]","+[0]","+","+query I","+select variant_array_length([1, 2]::VARIANT, ['']);","+----","+[2]","+","+# Single path supplied","+","+query I","+select variant_array_length(a, 'a') from struct_cast_data();","+----","+2","+1","+","+query I","+select variant_array_length(a, ['a']) from struct_cast_data();","+----","+[2]","+[1]","+","+# Multiple paths supplied","+","+query I","+select variant_array_length(a, ['a', 'c']) from struct_cast_data();","+----","+[2, NULL]","+[1, 0]","+","+# FIXME: map type is currently casted into a shape inconsistent with respect to JSON (should produce `0`)","+","+query I","+select variant_array_length(MAP {'a': 1, 'b': 2}::VARIANT, 'a');","+----","+NULL","+","+# NULL returns NULL","+","+query I","+select variant_array_length(NULL::VARIANT, NULL);","+----","+NULL","+","+query I","+select variant_array_length(NULL, NULL);","+----","+NULL","+","+query I","+select variant_array_length(NULL::VARIANT, 'a');","+----","+NULL","+","+query I","+select variant_array_length(j, 'a') from (values ({'a': [1, 2]}::VARIANT), (NULL::VARIANT)) t(j);","+----","+2","+NULL","+","+query I","+select variant_array_length(j, ['a', 'b']) from (values ({'a': [1, 2]}::VARIANT), (NULL::VARIANT)) t(j);","+----","+[2, NULL]","+NULL","+","+# NULL path returns NULL","+","+query I","+select variant_array_length({'a': 1}::VARIANT, NULL);","+----","+NULL","+","+# FIXME: Support for JSONPath and JSONPointer","+","+query I","+select variant_array_length({'a': 1, 'b': {'c': [1, 2, 3]}}::VARIANT, '$.b.c');","+----","+NULL","+","+# Incorrect parameters","+","+statement error","+select variant_array_length({'a': 1}::VARIANT, [1]);","+----","+<REGEX>:.*No function matches the given name and argument types 'variant_array_length\\(VARIANT, INTEGER\\[\\]\\)'.*","+","+statement error","+select variant_array_length({'a': []}::VARIANT, [NULL]);","+----","+Binder Error: 'variant_array_length' does not accept NULL paths","+","+statement error","+select variant_array_length({'a': []}::VARIANT, [NULL::VARCHAR]);","+----","+Binder Error: 'variant_array_length' does not accept NULL paths","+","+statement error","+select variant_array_length({'c': []}::VARIANT, ['c', NULL]::VARCHAR[]);","+----","+Binder Error: 'variant_array_length' does not accept NULL paths","+","+query I","+select variant_array_length({'c': []}::VARIANT, []::VARCHAR[]);","+----","+[]","+","+# FIXME: malformed JSON object should result in an error","+","+statement ok","+select variant_array_length('{\"a\"\\: 1}'::VARIANT, 'a');","+","+# Table of varying objects","+","+statement ok","+create table t1 as","+select range, case when range % 2 = 0 then {\"duck\": [42]}::VARIANT else {\"duck\": [42, 42]}::VARIANT end j","+from range(4096)","+","+query II","+select range % 2 g, sum(variant_array_length(j, 'duck')) c","+from t1","+group by g","+order by all","+----","+0\t2048","+1\t4096","+","+# Table whilst applying list of paths","+","+statement ok","+create table t2 as","+select range, {'duck': [42], 'goose': [42, 43]}::VARIANT j",