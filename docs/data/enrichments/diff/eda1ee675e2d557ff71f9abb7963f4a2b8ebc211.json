ach test path needs.","+//","+// `assertSupportedInstalledPackageVersion` is a no-op here because no current","+// test exercises the runtime floor guard. In production, the helper would","+// read the installed version via `getInstalledPackageVersion` and throw when","+// below floor; making the mock a no-op lets tests transitively load the","+// guard without depending on a built devkit/nx dist.","+","+export function assertSupportedInstalledPackageVersion(","+  _packageName: string,","+  _minSupportedVersion: string","+): void {","+  /* no-op */","+}"],"additions":16,"deletions":0,"truncated":false},{"path":"packages/angular-rspack/vitest.config.mts","lines":["@@ -5,9 +5,27 @@ export default defineConfig({","   cacheDir: '../../node_modules/.vite/angular-rspack/unit',","   root: __dirname,","   resolve: {","-    alias: {","-      '@nx/devkit': resolve('./test-utils/nx-devkit-mock.ts'),","-    },","+    // Use regex aliases so each subpath is intercepted independently. Plain","+    // string aliases (e.g., `'@nx/devkit'`) do prefix matching in vite, which","+    // would rewrite `@nx/devkit/internal` to `<mock-file-path>/internal` and","+    // fail to resolve.","+    alias: [","+      {","+        find: /^@nx\\/devkit$/,","+        replacement: resolve('./test-utils/nx-devkit-mock.ts'),","+      },","+      {","+        find: /^@nx\\/devkit\\/internal$/,","+        replacement: resolve('./test-utils/nx-devkit-internal-mock.ts'),","+      },","+      // Load the sibling workspace package from source so its imports","+      // (e.g. `@nx/devkit/internal`) go through the aliases above instead of","+      // resolving via the built dist's CJS `require`.","+      {","+        find: /^@nx\\/angular-rspack-compiler$/,","+        replacement: resolve('../angular-rspack-compiler/src/index.ts'),","+      },","+    ],","   },","   test: {","     watch: false,"],"additions":21,"deletions":3,"truncated":false},{"path":"packages/devkit/internal.ts","lines":["@@ -59,7 +59,10 @@