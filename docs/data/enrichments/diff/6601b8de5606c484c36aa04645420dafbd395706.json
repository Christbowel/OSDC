pe staticLimits struct {","+\toooWindow time.Duration","+}","+","+func (l staticLimits) GetMaxOutOfOrderTimeWindow(context.Context) (time.Duration, error) {","+\treturn l.oooWindow, nil","+}","+","+// TestMaterializer_computeRanges verifies that the split ranges are computed correctly at materialize time, including","+// the fallback reasons that depend on runtime state (the out-of-order window and current time).","+func TestMaterializer_computeRanges(t *testing.T) {","+\thourInMs := int64(time.Hour / time.Millisecond)","+\tminuteInMs := int64(time.Minute / time.Millisecond)","+","+\t// A fixed \"now\" of 100h keeps the out-of-order threshold well after all the timestamps used below, unless a test","+\t// deliberately configures an out-of-order window.","+\tfixedNow := timestamp.Time(100 * hourInMs)","+","+\tnewMaterializer := func(oooWindow time.Duration) *Materializer {","+\t\treturn NewMaterializer(true, 2*time.Hour, staticLimits{oooWindow: oooWindow}, func() time.Time { return fixedNow }, nil, nil, nil)","+\t}","+","+\t// inner builds an inner matrix selector with the given range and offset.","+\tinner := func(rng, offset time.Duration) *core.MatrixSelector {","+\t\treturn &core.MatrixSelector{MatrixSelectorDetails: &core.MatrixSelectorDetails{","+\t\t\tRange:  rng,","+\t\t\tOffset: offset,","+\t\t}}","+\t}","+","+\tinstantAt := func(evalTimeMs int64) types.QueryTimeRange {","+\t\treturn types.NewInstantQueryTimeRange(timestamp.Time(evalTimeMs))","+\t}","+","+\tt.Run(\"splits a 5h range into cacheable blocks\", func(t *testing.T) {","+\t\tm := newMaterializer(0)","+\t\tranges, notApplied, err := m.computeRanges(context.Background(), inner(5*time.Hour, 0), instantAt(6*hourInMs))","+\t\trequire.NoError(t, err)","+\t\trequire.Empty(t, notApplied)","+\t\trequire.Equal(t, []Range{","+\t\t\t{Start: 1 * hourInMs, End: 2*hourInMs - 1, Cacheable: false},","+\t\t\t{Start: 2*hourInMs - 1, End: 4*hourInMs - 1, Cacheable: true},","+\t\t\t{Start: 4*hourInMs - 1, End: 6*hourInMs - 1, Cacheable: true},","+\t\t\t{Start: 6*hourInMs - 1, End: 6 * hourInMs, Cacheable: false},","+\t\t}, ranges)","+\t})","+","+\tt.Run(\"falls back when there is no complete cacheable block\", func(t *testing.T) {","+\t\tm := newMaterializer(0)","+\t\t// Query at 4h30m with 3h range and 31m offset -> data-time (59m, 3h59m]. First aligned boundary is 2h, and","+\t\t// 2h + 2h = 4h > 3h59m, so no complete block fits.","+\t\tranges, notApplied, err := m.computeRanges(context.Background(), inner(3*time.Hour, 31*time.Minute), instantAt(4*hourInMs+30*minuteInMs))","+\t\trequire.NoError(t, err)","+\t\trequire.Equal(t, \"no_complete_cache_block\", notApplied)","+\t\trequire.Nil(t, ranges)","+\t})","+","+\tt.Run(\"falls back when every block is within the out-of-order window\", func(t *testing.T) {","+\t\t// With now=100h, a 99h out-of-order window puts the threshold at 1h, before the first aligned block boundary","+\t\t// (2h-1ms), so no block can be cached.","+\t\tm := newMaterializer(99 * time.Hour)","+\t\tranges, notApplied, err := m.computeRanges(context.Background(), inner(5*time.Hour, 0), instantAt(6*hourInMs))","+\t\trequire.NoError(t, err)"],"additions":67,"deletions":0,"truncated":false}],"additions":197,"deletions":417,"truncated":true,"file_count":7},"error":null,"fetched_at":"2026-07-03T10:25:39.615326+00:00"}