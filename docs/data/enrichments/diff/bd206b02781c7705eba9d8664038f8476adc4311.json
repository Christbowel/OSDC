{"id":"bd206b02781c7705eba9d8664038f8476adc4311","axis":"silent","repo":"grafana/mimir","sha":"bd206b02781c7705eba9d8664038f8476adc4311","parsed":{"files":[{"path":"CHANGELOG.md","lines":["@@ -9,6 +9,7 @@"," * [CHANGE] Alertmanager: The `cortex_alertmanager_dispatcher_aggregation_group_limit_reached_total` counter is now best-effort under concurrent alert ingest. The upstream alertmanager v0.32.0 ingests alerts via worker goroutines and the group-limit check is a racy check-then-act, so the configured limit can be exceeded under burst load. #15144"," * [CHANGE] Querier: The experimental PromQL duration arithmetic helpers `min(...)` and `max(...)` used inside `[...]` range/subquery brackets and `offset` clauses have been renamed to `min_of(...)` and `max_of(...)`. #15593 #15603"," * [CHANGE] Querier, Store-gateway: Only send non-opaque GRPC types between queriers and store-gateways. Note that this change requires upgrading from Mimir 3.1. See associated release notes for more information. #15358","+* [CHANGE] Querier: Remove experimental MQE Projection Pushdown optimization pass and associated CLI flag `querier.mimir-query-engine.enable-projection-pushdown`. #15618"," * [FEATURE] API: Add alertmanager limits (alertmanager_notification_rate_limit, alertmanager_max_dispatcher_aggregation_groups, alertmanager_max_templates_count) to the user limits API response. #15308"," * [FEATURE] Mimirtool: Add AWS Signature Version 4 (SigV4) support for shared Mimir API client commands including `mimirtool rules`, `mimirtool alertmanager`, `mimirtool alerts`, `mimirtool backfill`, and `mimirtool analyze ruler`. #14959"," * [FEATURE] Cost attribution: Support multiple named cost attribution trackers per tenant via new `additional_cost_attribution_trackers` config field. #15302"],"additions":1,"deletions":0,"truncated":false},{"path":"cmd/mimir/config-descriptor.json","lines":["@@ -2658,17 +2658,6 @@","               \"fieldType\": \"boolean\",","               \"fieldCategory\": \"experimental\"","             },","-            {","-              \"kind\": \"field\",","-              \"name\": \"enable_projection_pushdown\",","-              \"required\": false,","-              \"desc\": \"Enable projection pushdown to only fetch labels required for the query from storage.\",","-              \"fieldValue\": null,","-              \"fieldDefaultValue\": false,","-              \"fieldFlag\": \"querier.mimir-query-engine.enable-projection-pushdown\",","-              \"fieldType\": \"boolean\",","-              \"fieldCategory\": \"experimental\"","-            },","             {","               \"kind\": \"field\",","               \"name\": \"enable_multi_aggregation\","],"additions":0,"deletions":11,"truncated":false},{"path":"cmd/mimir/help-all.txt.tmpl","lines":["@@ -2307,8 +2307,6 @@ Usage of ./cmd/mimir/mimir:","     \t[experimental] Enable computing multiple aggregations over the same data without buffering. Requires common subexpression elimination to be enabled. (default true)","   -querier.mimir-query-engine.enable-narrow-binary-selectors","     \t[experimental] Enable generating selectors for one side of a binary expression based on results from the other side.","-  -querier.mimir-query-engine.enable-projection-pushdown","-    \t[experimental] Enable projection pushdown to only fetch labels required for the query from storage.","   -querier.mimir-query-engine.enable-prune-toggles","     \t[experimental] Enable pruning query expressions that are toggled off with constants. (default true)","   -querier.mimir-query-engine.enable-range-query-range-vector-common-subexpression-elimination"],"additions":0,"deletions":2,"truncated":false},{"path":"docs/sources/mimir/configure/configuration-parameters/index.md","lines":["@@ -2005,11 +2005,6 @@ mimir_query_engine:","   # CLI flag: -querier.mimir-query-engine.enable-reduce-matchers","   [enable_reduce_matchers: <boolean> | default = true]"," ","-  # (experimental) Enable projection pushdown to only fetch labels required for","-  # the query from storage.","-  # CLI flag: -querier.mimir-query-engine.enable-projection-pushdown","-  [enable_projection_pushdown: <boolean> | default = false]","-","   # (experimental) Enable computing multiple aggregations over the same data","   # without buffering. Requires common subexpression elimination to be enabled.","   # CLI flag: -querier.mimir-query-engine.enable-multi-aggregation"],"additions":0,"deletions":5,"truncated":false},{"path":"pkg/streamingpromql/config.go","lines":["@@ -45,7 +45,6 @@ type EngineOpts struct {"," \tEnableNarrowBinarySelectors                               bool `yaml:\"enable_narrow_binary_selectors\" category:\"experimental\"`"," \tEnableEliminateDeduplicateAndMerge                        bool `yaml:\"enable_eliminate_deduplicate_and_merge\" category:\"experimental\"`"," \tEnableReduceMatchers                                      bool `yaml:\"enable_reduce_matchers\" category:\"experimental\"`","-\tEnableProjectionPushdown                                  bool `yaml:\"enable_projection_pushdown\" category:\"experimental\"`"," \tEnableMultiAggregation                                    bool `yaml:\"enable_multi_aggregation\" category:\"experimental\"`"," \tEnableRemoveStaticallyEmptyExpressions                    bool `yaml:\"enable_remove_statically_empty_expressions\" category:\"experimental\"`"," ","@@ -75,7 +74,6 @@ func (o *EngineOpts) RegisterFlags(f *flag.FlagSet) {"," \tf.BoolVar(&o.EnableNarrowBinarySelectors, \"querier.mimir-query-engine.enable-narrow-binary-selectors\", false, \"Enable generating selectors for one side of a binary expression based on results from the other side.\")"," \tf.BoolVar(&o.EnableEliminateDeduplicateAndMerge, \"querier.mimir-query-engine.enable-eliminate-deduplicate-and-merge\", true, \"Enable eliminating redundant DeduplicateAndMerge nodes from the query plan when it can be proven that each input series produces a unique output series.\")"," \tf.BoolVar(&o.EnableReduceMatchers, \"querier.mimir-query-engine.enable-reduce-matchers\", true, \"Enable eliminating duplicate or redundant matchers that are part of selector expressions.\")","-\tf.BoolVar(&o.EnableProjectionPushdown, \"querier.mimir-query-engine.enable-projection-pushdown\", false, \"Enable projection pushdown to only fetch labels required for the query from storage.\")"," \tf.BoolVar(&o.EnableMultiAggregation, \"querier.mimir-query-engine.enable-multi-aggregation\", true, \"Enable computing multiple aggregations over the same data without buffering. Requires common subexpression elimination to be enabled.\")"," \tf.BoolVar(&o.EnableRemoveStaticallyEmptyExpressions, \"querier.mimir-query-engine.enable-remove-statically-empty-expressions\", true, \"Enable removing expressions that are guaranteed to produce no results.\")"," ","@@ -130,7 +128,6 @@ func NewTestEngineOpts() EngineOpts {"," \t\tEnableNarrowBinarySelectors:                               true,"," \t\tEnableEliminateDeduplicateAndMerge:                        true,"," \t\tEnableReduceMatchers:                                      true,","-\t\tEnableProjectionPushdown:                                  true,"," \t\tEnableMultiAggregation:                                    true,"," \t\tEnableRemoveStaticallyEmptyExpressions:                    true,"," \t\tEnableRangeQueryRangeVectorCommonSubexpressionElimination: true,"],"additions":0,"deletions":3,"truncated":false},{"path":"pkg/streamingpromql/operators/selectors/selector.go","lines":["@@ -45,12 +45,6 @@ type Selector struct {"," \t// This flag has no effect unless Smoothed is set to true."," \tCounterAware bool"," ","-\t// Pass the set of labels required for the query to the Querier to avoid transferring labels that aren't needed","-\t// back and forth between the querier and storage layer (ingesters, store-gateways). The storage layer may also","-\t// apply further optimizations based on this information.","-\tProjectionInclude bool","-\tProjectionLabels  []string","-"," \t// Subsets to report in operator stats."," \tSubsets []Subset"," ","@@ -182,10 +176,6 @@ func (s *Selector) loadSeriesSet(ctx context.Context, matchers types.Matchers) e"," \t\tStep:  s.TimeRange.IntervalMilliseconds,"," \t\tRange: s.Range.Milliseconds(),"," ","-\t\t// Mimir Queriers don't use projection hints for anything at time of writing.","-\t\tProjectionInclude: s.ProjectionInclude,","-\t\tProjectionLabels:  s.ProjectionLabels,","-"," \t\t// Mimir doesn't use Grouping or By, so there's no need to include them here."," \t\t//"," \t\t// Mimir does use Func to determine if it's a /series request, but this doesn't go"],"additions":0,"deletions":10,"truncated":false},{"path":"pkg/streamingpromql/optimize/plan/projection_pushdown.go","lines":["@@ -1,264 +0,0 @@","-// SPDX-License-Identifier: AGPL-3.0-only","-","-package plan","-","-import (","-\t\"context\"","-\t\"fmt\"","-\t\"maps\"","-\t\"slices\"","-","-\t\"github.com/go-kit/log\"","-\t\"github.com/prometheus/client_golang/prometheus\"","-\t\"github.com/prometheus/client_golang/prometheus/promauto\"","-","-\t\"github.com/grafana/mimir/pkg/streamingpromql/operators/functions\"","-\t\"github.com/grafana/mimir/pkg/streamingpromql/optimize\"","-\t\"github.com/grafana/mimir/pkg/streamingpromql/planning\"","-\t\"github.com/grafana/mimir/pkg/streamingpromql/planning/core\"","-\t\"github.com/grafana/mimir/pkg/util/spanlogger\"","-)","-","-type SkipReason int","-","-const (","-\tSkipReasonOk              = SkipReason(0)","-\tSkipReasonNoAggregations  = SkipReason(1)","-\tSkipReasonBinaryOperation = SkipReason(2)","-\tSkipReasonDeduplicate     = SkipReason(3)","-\tSkipReasonNotSupported    = SkipReason(4)","-)","-","-func (r SkipReason) String() string {","-\tswitch r {","-\tcase SkipReasonOk:","-\t\treturn \"\"","-\tcase SkipReasonNoAggregations:","-\t\treturn \"no-aggregations\"","-\tcase SkipReasonBinaryOperation:","-\t\treturn \"binary-operation\"","-\tcase SkipReasonDeduplicate:","-\t\treturn \"deduplicate-and-merge\"","-\tcase SkipReasonNotSupported:","-\t\treturn \"not-supported\"","-\tdefault:","-\t\tpanic(fmt.Sprintf(\"unexpected projection skip reason %d, this is a bug\", r))","-\t}","-}","-","-var _ optimize.QueryPlanOptimizationPass = &ProjectionPushdownOptimizationPass{}","-","-type ProjectionPushdownOptimizationPass struct {","-\texamined prometheus.Counter","-\tmodified prometheus.Counter","-\tskipped  *prometheus.CounterVec","-\tlogger   log.Logger","-}","-","-func NewProjectionPushdownOptimizationPass(reg prometheus.Registerer, logger log.Logger) *ProjectionPushdownOptimizationPass {","-\tpass := &ProjectionPushdownOptimizationPass{","-\t\texamined: promauto.With(reg).NewCounter(prometheus.CounterOpts{","-\t\t\tName: \"cortex_mimir_query_engine_projection_pushdown_examined_total\",","-\t\t\tHelp: \"Total number of selectors that the optimization pass examined to see if projections could be used.\",","-\t\t}),","-\t\tmodified: promauto.With(reg).NewCounter(prometheus.CounterOpts{","-\t\t\tName: \"cortex_mimir_query_engine_projection_pushdown_modified_total\",","-\t\t\tHelp: \"Total number of selectors where projections could be used.\",","-\t\t}),","-\t\tskipped: promauto.With(reg).NewCounterVec(prometheus.CounterOpts{","-\t\t\tName: \"cortex_mimir_query_engine_projection_pushdown_skipped_total\",","-\t\t\tHelp: \"Total number of selectors where projections could not be used.\",","-\t\t}, []string{\"reason\"}),","-\t\tlogger: logger,","-\t}","-","-\t// Initialize each of the expected reasons to skip applying projections to a query.","-\t// This makes testing the pass easier since all series exist even when we haven't","-\t// skipped something for a particular reason.","-\tpass.skipped.WithLabelValues(SkipReasonBinaryOperation.String())","-\tpass.skipped.WithLabelValues(SkipReasonDeduplicate.String())","-\tpass.skipped.WithLabelValues(SkipReasonNoAggregations.String())","-\tpass.skipped.WithLabelValues(SkipReasonNotSupported.String())","-","-\treturn pass","-}","-","-func (p *ProjectionPushdownOptimizationPass) Name() string {","-\treturn \"Push down label projections\"","-}","-","-func (p *ProjectionPushdownOptimizationPass) Apply(ctx context.Context, plan *planning.QueryPlan, v planning.QueryPlanVersion) (*planning.QueryPlan, error) {","-\tspanlog := spanlogger.FromContext(ctx, p.logger)","-\tvar (","-\t\tselectors = 0","-\t\tmodified  = 0","-\t)","-","-\t_ = optimize.Walk(plan.Root, optimize.VisitorFunc(func(node planning.Node, path []planning.Node) error {","-\t\tswitch e := node.(type) {","-\t\tcase *core.MatrixSelector:","-\t\t\tselectors++","-","-\t\t\tm, skipped := examinePath(path)","-\t\t\tif skipped != SkipReasonOk {","-\t\t\t\tp.skipped.WithLabelValues(skipped.String()).Inc()","-\t\t\t\treturn nil","-\t\t\t}","-","-\t\t\trequired := flattenLabels(m)","-\t\t\te.ProjectionLabels = required","-\t\t\te.ProjectionInclude = true","-","-\t\t\tmodified++","-\t\t\tspanlog.DebugLog(","-\t\t\t\t\"msg\", \"applying projection to selector\",","-\t\t\t\t\"selector_matchers\", core.LabelMatchersStringer(e.Matchers),","-\t\t\t\t\"required_labels\", required,","-\t\t\t)","-\t\tcase *core.VectorSelector:","-\t\t\tselectors++","-","-\t\t\tm, skipped := examinePath(path)","-\t\t\tif skipped != SkipReasonOk {","-\t\t\t\tp.skipped.WithLabelValues(skipped.String()).Inc()","-\t\t\t\treturn nil","-\t\t\t}","-","-\t\t\trequired := flattenLabels(m)","-\t\t\te.ProjectionLabels = required","-\t\t\te.ProjectionInclude = true","-","-\t\t\tmodified++","-\t\t\tspanlog.DebugLog(","-\t\t\t\t\"msg\", \"applying projection to selector\",","-\t\t\t\t\"selector_matchers\", core.LabelMatchersStringer(e.Matchers),","-\t\t\t\t\"required_labels\", required,","-\t\t\t)","-\t\t}","-\t\treturn nil","-\t}))","-","-\tp.examined.Add(float64(selectors))","-\tp.modified.Add(float64(modified))","-","-\treturn plan, nil","-}","-","-// flattenLabels converts a set of labels to a slice and sorts them.","-func flattenLabels(m map[string]struct{}) []string {","-\tret := make([]string, 0, len(m))","-\tfor k := range m {","-\t\tret = append(ret, k)","-\t}","-","-\tslices.Sort(ret)","-\treturn ret","-}","-","-// examinePath looks at the nodes that lead to a leaf node, starting from the closest, to the","-// root and returns a set of any labels that are specifically required the expressions. An enum","-// is returned to indicate if the expressions are eligible for projection and why.","-func examinePath(path []planning.Node) (map[string]struct{}, SkipReason) {","-\trequiredLabels := make(map[string]struct{})","-","-\tfor i := len(path) - 1; i >= 0; i-- {","-\t\tswitch e := path[i].(type) {","-\t\tcase *core.AggregateExpression:","-\t\t\tm, skipped := examineAggregate(e)","-\t\t\tif skipped != SkipReasonOk {","-\t\t\t\treturn nil, skipped","-\t\t\t}","-","-\t\t\tmaps.Copy(requiredLabels, m)","-\t\t\t// We stop examining the path to the root as soon as we find the first","-\t\t\t// aggregation: if this aggregation requires specific labels those are","-\t\t\t// the labels we need to fetch since any expressions that occur after","-\t\t\t// this aggregation could not use any others and still work.","-\t\t\treturn requiredLabels, SkipReasonOk","-\t\tcase *core.BinaryExpression:","-\t\t\treturn nil, SkipReasonBinaryOperation","-\t\tcase *core.DeduplicateAndMerge:","-\t\t\treturn nil, SkipReasonDeduplicate","-\t\tcase *core.FunctionCall:","-\t\t\tm, skipped := examineFunction(e)","-\t\t\tif skipped != SkipReasonOk {","-\t\t\t\treturn nil, skipped","-\t\t\t}","-","-\t\t\tmaps.Copy(requiredLabels, m)","-\t\tcase *core.DropName:","-\t\t\t// DropName isn't unsafe to use with projections, but it requires a","-\t\t\t// DeduplicateAndMerge node which doesn't work with projections. Don't","-\t\t\t// do anything here and let the logic hit the DeduplicateAndMerge block.","-\t\tcase *core.StepInvariantExpression, *core.Subquery, *core.UnaryExpression:","-\t\t\t// These type of expressions are safe to use projections with, but they don't","-\t\t\t// need any special handling that affects which labels we need from storage.","-\t\tdefault:","-\t\t\t// Anything we haven't accounted for results in projections not being used.","-\t\t\treturn nil, SkipReasonNotSupported","-\t\t}","-\t}","-","-\t// If we've made it this far, there's no aggregations applied to the selector","-\t// so we can't use projections for this leg of the query.","-\treturn nil, SkipReasonNoAggregations","-}","-","-func examineAggregate(a *core.AggregateExpression) (map[string]struct{}, SkipReason) {","-\t// In order to keep this implementation simple, we only support including specific","-\t// fields as part of a projection - not excluding all fields except specific ones.","-\tif a.Without {","-\t\treturn nil, SkipReasonNotSupported","-\t}","-","-\t// These aggregations limit the number of results, they don't actually aggregate the","-\t// series by any or all labels.","-\tif a.Op == core.AGGREGATION_TOPK ||","-\t\ta.Op == core.AGGREGATION_BOTTOMK ||","-\t\ta.Op == core.AGGREGATION_LIMITK ||","-\t\ta.Op == core.AGGREGATION_LIMIT_RATIO {","-\t\treturn nil, SkipReasonNotSupported","-\t}","-","-\trequiredLabels := make(map[string]struct{})","-\tfor _, l := range a.Grouping {","-\t\trequiredLabels[l] = struct{}{}","-\t}","-","-\treturn requiredLabels, SkipReasonOk","-}","-","-func examineFunction(f *core.FunctionCall) (map[string]struct{}, SkipReason) {","-\tswitch f.Function {","-\tcase functions.FUNCTION_INFO:","-\t\t// Keep this implementation simple and skip any projection when the","-\t\t// query uses the info function. Note that at time of writing MQE does","-\t\t// not support the info function at all so this code path isn't exercised.","-\t\treturn nil, SkipReasonNotSupported","-\tcase functions.FUNCTION_LABEL_JOIN:","-\t\treturn functionLabelArgs(f.Function, f.Args[3:]...), SkipReasonOk","-\tcase functions.FUNCTION_LABEL_REPLACE:","-\t\treturn functionLabelArgs(f.Function, f.Args[3]), SkipReasonOk","-\tcase functions.FUNCTION_SORT_BY_LABEL:","-\t\treturn functionLabelArgs(f.Function, f.Args[1:]...), SkipReasonOk","-\tcase functions.FUNCTION_SORT_BY_LABEL_DESC:","-\t\treturn functionLabelArgs(f.Function, f.Args[1:]...), SkipReasonOk","-\tdefault:","-\t\t// Not a function that requires any particular label.","-\t\treturn nil, SkipReasonOk","-\t}","-}","-","-func functionLabelArgs(fn functions.Function, args ...planning.Node) map[string]struct{} {","-\trequired := make(map[string]struct{})","-","-\tfor _, arg := range args {","-\t\tif a, ok := arg.(*core.StringLiteral); ok {","-\t\t\trequired[a.Value] = struct{}{}","-\t\t} else {","-\t\t\tpanic(fmt.Sprintf(\"expected StringLiteral function argument for %s, got %+v\", fn, arg))","-\t\t}","-\t}","-","-\treturn required","-}"],"additions":0,"deletions":264,"truncated":false},{"path":"pkg/streamingpromql/optimize/plan/projection_pushdown_test.go","lines":["@@ -1,399 +0,0 @@","-// SPDX-License-Identifier: AGPL-3.0-only","-","-package plan_test","-","-import (","-\t\"context\"","-\t\"fmt\"","-\t\"strings\"","-\t\"testing\"","-\t\"time\"","-","-\t\"github.com/prometheus/client_golang/prometheus\"","-\t\"github.com/prometheus/client_golang/prometheus/testutil\"","-\t\"github.com/stretchr/testify/require\"","-","-\t\"github.com/grafana/mimir/pkg/streamingpromql\"","-\t\"github.com/grafana/mimir/pkg/streamingpromql/optimize/plan\"","-\t\"github.com/grafana/mimir/pkg/streamingpromql/testutils\"","-\t\"github.com/grafana/mimir/pkg/streamingpromql/types\"","-)","-","-func TestProjectionPushdownOptimizationPass(t *testing.T) {","-\ttestCases := map[string]struct {","-\t\texpr             string","-\t\texpectedPlan     string","-\t\texpectedModified int","-\t\texpectedSkip     map[plan.SkipReason]int","-\t}{","-\t\t\"raw vector selector\": {","-\t\t\texpr:             `foo{job=\"a\"}`,","-\t\t\texpectedPlan:     `- VectorSelector: {job=\"a\", __name__=\"foo\"}`,","-\t\t\texpectedModified: 0,","-\t\t\texpectedSkip:     map[plan.SkipReason]int{pla