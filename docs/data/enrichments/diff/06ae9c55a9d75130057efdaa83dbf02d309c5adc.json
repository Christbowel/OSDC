import { assertType, describe, expectTypeOf, test } from 'vitest';","+import type { MergeCoreCollection, RegularCollections, SingletonCollections } from '../src/index.js';","+import type { TestSchema } from './schema.js';","+","+describe('SingletonCollections', () => {","+\ttest('includes user-defined singleton collections', () => {","+\t\texpectTypeOf<SingletonCollections<TestSchema>>().toEqualTypeOf<'user_defined_singleton'>();","+\t});","+","+\ttest('excludes regular array collections', () => {","+\t\t// @ts-expect-error","+\t\tassertType<SingletonCollections<TestSchema>>('collection_a');","+\t});","+","+\ttest('excludes core collections defined as singular custom-field types', () => {","+\t\t// @ts-expect-error","+\t\tassertType<SingletonCollections<TestSchema>>('directus_users');","+\t});","+});","+","+describe('RegularCollections', () => {","+\ttest('includes user-defined array collections', () => {","+\t\texpectTypeOf<'collection_a'>().toExtend<RegularCollections<TestSchema>>();","+\t});","+","+\ttest('excludes user-defined singleton collections', () => {","+\t\t// @ts-expect-error","+\t\tassertType<RegularCollections<TestSchema>>('user_defined_singleton');","+\t});","+});","+","+describe('MergeCoreCollection', () => {","+\ttest('merges custom fields onto the builtin collection', () => {","+\t\ttype MergedUser = MergeCoreCollection<TestSchema, 'directus_users', { id: string; email: string | null }>;","+","+\t\tassertType<MergedUser>({ id: '1', email: 'a@b.com', custom_field: true });","+\t});","+","+\ttest('builtin fields cannot be overriden by custom core collection fields', () => {","+\t\ttype MergedUser = MergeCoreCollection<TestSchema, 'directus_users', { id: string; email: string | null }>;","+","+\t\texpectTypeOf<MergedUser['id']>().toEqualTypeOf<string>();","+\t\texpectTypeOf<MergedUser['custom_field']>().toEqualTypeOf<boolean | undefined>();","+\t});","+","+\ttest('custom fields absent when schema has no extension for that collection', () => {","+\t\t