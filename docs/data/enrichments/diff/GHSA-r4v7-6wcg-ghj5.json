ilCounts = cache.NewCache[int](time.Minute, 10*time.Minute)","+\tauthLockouts   = cache.NewCache[bool](time.Minute, 10*time.Minute)","+)","+","+// Per-route-class token buckets (keys: IP or username). Expired entries are dropped by go-cache.","+var (","+\tauthRateLimitCredentialByIP       = cache.NewCache[*rate.Limiter](authLimiterEntryTTL)","+\tauthRateLimitCredentialByUsername = cache.NewCache[*rate.Limiter](authLimiterEntryTTL)","+\tauthRateLimitModerateByIP         = cache.NewCache[*rate.Limiter](authLimiterEntryTTL)","+\tauthRateLimitOIDCByIP             = cache.NewCache[*rate.Limiter](authLimiterEntryTTL)","+\tauthRateLimitAuthenticatedByUser  = cache.NewCache[*rate.Limiter](authLimiterEntryTTL)","+)","+","+const authRateKeySep = \"\\x1e\"","+","+// AuthRateLimitKind selects which /api/auth rate limit tier applies (see withRateLimit and withRateLimitChain).","+type AuthRateLimitKind int","+","+const (","+\t// AuthRateLimitCredential: strict per-IP and per-username limits; no failed-login lockout.","+\tAuthRateLimitCredential AuthRateLimitKind = iota","+\t// AuthRateLimitCredentialLockout: same limits as Credential, plus lockout after repeated 401s.","+\tAuthRateLimitCredentialLockout","+\tAuthRateLimitModerate","+\tAuthRateLimitOIDC","+\t// AuthRateLimitAuthenticated: per logged-in username (compose: withUser(withRateLimitChain(AuthRateLimitAuthenticated, h))).","+\tAuthRateLimitAuthenticated","+)","+","+// withRateLimitChain applies a rate limit tier then fn for nesting inside withUser / withOrWithoutUser / withoutUser.","+func withRateLimitChain(kind AuthRateLimitKind, fn handleFunc) handleFunc {","+\tswitch kind {","+\tcase AuthRateLimitCredential:","+\t\treturn withAuthRateLimitCredential(false, fn)","+\tcase AuthRateLimitCredentialLockout:","+\t\treturn withAuthRateLimitCredential(true, fn)","+\tcase AuthRateLimitModerate:","+\t\treturn withAuthRateLimitModerate(fn)","+\tcase AuthRateLimitOIDC:","+\t\treturn withAuthRateLimitOIDC(fn)","+\tcase AuthRateLim