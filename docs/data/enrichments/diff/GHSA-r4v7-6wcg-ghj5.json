y-After.","+func withRateLimitInternal(fn handleFunc, allow func(*http.Request, *requestContext) (retryAfter int, ok bool)) handleFunc {","+\treturn func(w http.ResponseWriter, r *http.Request, d *requestContext) (int, error) {","+\t\tif !authRateLimitActive() {","+\t\t\treturn fn(w, r, d)","+\t\t}","+\t\tif after, ok := allow(r, d); !ok {","+\t\t\tw.Header().Set(\"Retry-After\", strconv.Itoa(after))","+\t\t\treturn http.StatusTooManyRequests, fmt.Errorf(\"too many requests\")","+\t\t}","+\t\treturn fn(w, r, d)","+\t}","+}","+","+// withAuthRateLimitCredential enforces the credential tier (and optional per-username limits).","+// When trackFailures is true, 401 responses increment failed-attempt state for lockout; success clears it.","+func withAuthRateLimitCredential(trackFailures bool, fn handleFunc) handleFunc {","+\treturn func(w http.ResponseWriter, r *http.Request, d *requestContext) (int, error) {","+\t\tif !authRateLimitActive() {","+\t\t\treturn fn(w, r, d)","+\t\t}","+\t\tusername := r.URL.Query().Get(\"username\")","+\t\tif isAuthLockout(getRemoteIP(r), username) {","+\t\t\tw.Header().Set(\"Retry-After\", strconv.Itoa(authLockoutRetryAfterSecs()))","+\t\t\treturn http.StatusTooManyRequests, fmt.Errorf(\"too many failed authentication attempts\")","+\t\t}","+\t\tif after, ok := allowCredential(r, username); !ok {","+\t\t\tw.Header().Set(\"Retry-After\", strconv.Itoa(after))","+\t\t\treturn http.StatusTooManyRequests, fmt.Errorf(\"too many requests\")","+\t\t}","+\t\tstatus, err := fn(w, r, d)","+\t\tif !trackFailures {","+\t\t\treturn status, err","+\t\t}","+\t\tip := getRemoteIP(r)","+\t\tif status == http.StatusUnauthorized && username != \"\" {","+\t\t\trecordAuthFailure(ip, username)","+\t\t}","+\t\tif err == nil && (status == 0 || status == http.StatusOK) {","+\t\t\tclearAuthLockout(ip, username)","+\t\t}","+\t\treturn status, err","+\t}","+}","+","+func withAuthRateLimitModerate(fn handleFunc) handleFunc {","+\treturn withRateLimitInternal(fn, func(r *http.Request, _ *requestContext) (int, bool) {","+\t\treturn allowModerate(r)","+\t})","+}","+","+func withAuthRateLimitOIDC(fn handleFunc) handleFunc {","+\treturn withRateLimitInternal(fn, func(r *http.Request, _ *requestContext) (int, bool) {","+\t\treturn allowOIDC(r)","+\t})","+}","+","+func withAuthRateLimitAuthenticated(fn handleFunc) handleFunc {","+\treturn withRateLimitInternal(fn, func(_ *http.Request, d *requestContext) (int, bool) {","+\t\tif d.user == nil || d.user.Username == \"\" || d.user.Username == \"anonymous\" {","+\t\t\treturn 0, true","+\t\t}","+\t\treturn allowAuthenticated(d.user.Username)","+\t})","+}"],"additions":269,"deletions":0,"truncated":false},{"path":"backend/http/httpRouter.go","lines":["@@ -80,6 +80,10 @@ func StartHttp(ctx context.Context, storage *bolt.BoltStore, shutdownComplete ch"," \tpublicRoutes := http.NewServeMux()"],"additions":0,"deletions":0,"truncated":false}],"additions":412,"deletions":71,"truncated":true,"file_count":23},"error":null,"fetched_at":"2026-06-26T10:41:49.221215+00:00"}