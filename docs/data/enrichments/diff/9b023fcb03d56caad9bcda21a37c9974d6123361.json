r::new(","+            input.span(),","+            format!(","+                \"unexpected end of input, expected parentheses\\n\\","+                 help: the correct format looks like `#[diesel({help})]`\",","+            ),","+        ));","+    }","+","+    let content;","+    parenthesized!(content in input);","+    content.parse()","+}","+","+pub fn parse_paren_list<T, D>(","+    input: ParseStream,","+    help: &str,","+    sep: D,","+) -> Result<syn::punctuated::Punctuated<T, <D as Peek>::Token>>","+where","+    T: Parse,","+    D: Peek,","+    D::Token: Parse,","+{","+    if input.is_empty() {","+        return Err(syn::Error::new(","+            input.span(),","+            format!(","+                \"unexpected end of input, expected parentheses\\n\\","+                 help: the correct format looks like `#[diesel({help})]`\",","+            ),","+        ));","+    }","+","+    let content;","+    parenthesized!(content in input);","+    content.parse_terminated(T::parse, sep)","+}"],"additions":90,"deletions":0,"truncated":false},{"path":"diesel_derives/Cargo.toml","lines":["@@ -15,7 +15,8 @@ include = [\"src/**/*.rs\", \"src/tests/snapshots/*\", \"LICENSE-*\", \"README.md\", \"bu"," syn = { version = \"2.0\", features = [\"derive\", \"fold\", \"full\", \"visit-mut\"] }"," quote = \"1.0.9\""," proc-macro2 = \"1.0.27\"","-diesel_table_macro_syntax = {version = \"0.3\", path = \"../diesel_table_macro_syntax\"}","+diesel_table_macro_syntax = { version = \"0.3\", path = \"../diesel_table_macro_syntax\" }","+diesel_attribute_parser = { version = \"0.1\", path = \"../diesel_attribute_parser\" }"," dsl_auto_type = { version = \"0.2\", path = \"../dsl_auto_type\" }"," "," [dev-dependencies]","@@ -35,15 +36,15 @@ name = \"tests\""," "," [features]"," default = []","-nightly = [\"proc-macro2/nightly\"]","+nightly = [\"proc-macro2/nightly\", \"diesel_attribute_parser/nightly\"]"," postgres = []"," sqlite = []"," mysql = []"," 32-column-tables = []"," 64-colu