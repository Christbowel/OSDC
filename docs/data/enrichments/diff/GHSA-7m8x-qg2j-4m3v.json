{"id":"GHSA-7m8x-qg2j-4m3v","axis":"advisories","repo":"fission/fission","sha":"94bf5792396989fdd71961e8701833c8110da889","parsed":{"files":[{"path":"pkg/executor/util/merge_allowlist.go","lines":["@@ -0,0 +1,279 @@","+/*","+Copyright 2026 The Fission Authors.","+","+Licensed under the Apache License, Version 2.0 (the \"License\");","+you may not use this file except in compliance with the License.","+You may obtain a copy of the License at","+","+\thttp://www.apache.org/licenses/LICENSE-2.0","+","+Unless required by applicable law or agreed to in writing, software","+distributed under the License is distributed on an \"AS IS\" BASIS,","+WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.","+See the License for the specific language governing permissions and","+limitations under the License.","+*/","+","+package util","+","+import (","+\tapiv1 \"k8s.io/api/core/v1\"","+)","+","+// MergeAllowedPodSpecFields overlays a small allowlist of fields from `user`","+// onto a deep copy of `src`. The merge uses allowlist semantics: only the","+// fields explicitly listed below are ever copied from `user` to the result.","+// Every other PodSpec field present in `user` is silently dropped, regardless","+// of whether DisallowedPodSpecFields enumerates it. The returned PodSpec is","+// always a fresh deep copy; `src` is not mutated.","+//","+// Allowed (everything else is dropped):","+//   - NodeSelector","+//   - Tolerations","+//   - Affinity","+//   - RuntimeClassName","+//   - Containers[i].Resources, when the container name matches a","+//     controller-built container","+//","+// The slice of dropped field names returned alongside the merged spec is","+// produced by DisallowedPodSpecFields for caller-side audit logging. That","+// helper enumerates every populated PodSpec field that is not on the","+// allowlist above, so admission errors and audit logs cover the same","+// surface the merge helper silently drops.","+//","+// This is the controller-side defence for GHSA-7m8x-qg2j-4m3v; the","+// validating webhook in pkg/webhook/messagequeuetrigger.go rejects the same","+// disallowed fields at admission time.","+func MergeAllowedPodSpecFields(src, user *apiv1.PodSpec) (*apiv1.PodSpec, []string) {","+\tif src == nil {","+\t\treturn nil, nil","+\t}","+\tout := src.DeepCopy()","+\tif user == nil {","+\t\treturn out, nil","+\t}","+","+\t// --- Allowlisted merges ---","+","+\tif len(user.NodeSelector) > 0 {","+\t\tif out.NodeSelector == nil {","+\t\t\tout.NodeSelector = make(map[string]string, len(user.NodeSelector))","+\t\t}","+\t\tfor k, v := range user.NodeSelector {","+\t\t\tout.NodeSelector[k] = v","+\t\t}","+\t}","+\tif len(user.Tolerations) > 0 {","+\t\tout.Tolerations = append(out.Tolerations, user.Tolerations...)","+\t}","+\tif user.Affinity != nil {","+\t\tout.Affinity = user.Affinity.DeepCopy()","+\t}","+\tif user.RuntimeClassName != nil {","+\t\trc := *user.RuntimeClassName","+\t\tout.RuntimeClassName = &rc","+\t}","+","+\t// Per-container Resources merge (name-matched only).","+\tfor i := range out.Containers {","+\t\tfor j := range user.Containers {","+\t\t\tif user.Containers[j].Name != out.Containers[i].Name {","+\t\t\t\tcontinue","+\t\t\t}","+\t\t\tif len(user.Containers[j].Resources.Limits) > 0 ||","+\t\t\t\tlen(user.Containers[j].Resources.Requests) > 0 {","+\t\t\t\tout.Containers[i].Resources = *user.Containers[j].Resources.DeepCopy()","+\t\t\t}","+\t\t}","+\t}","+","+\treturn out, DisallowedPodSpecFields(user)","+}","+","+// DisallowedPodSpecFields returns the deduplicated list of populated","+// PodSpec field names in `ps` that are NOT on the","+// MessageQueueTrigger.Spec.PodSpec allowlist. The pod-level allowlist is","+// NodeSelector, Tolerations, Affinity, and RuntimeClassName; the","+// per-container allowlist is Name (metadata, used for the per-container","+// Resources match) and Resources itself. Every other settable field is","+// reported here so the admission webhook can fail loudly on the same","+// surface that MergeAllowedPodSpecFields would otherwise silently drop.","+//","+// This is the single source of truth shared by the controller-side merge","+// in MergeAllowedPodSpecFields and the admission webhook in","+// pkg/webhook/messagequeuetrigger.go — extend this function (and only","+// this function) when changing what the webhook rejects.","+//","+// The returned names use the JSON form without a leading \"spec.podspec.\"","+// prefix; callers that surface the names in user-facing errors should","+// prepend their own prefix.","+func DisallowedPodSpecFields(ps *apiv1.PodSpec) []string {","+\tif ps == nil {","+\t\treturn nil","+\t}","+","+\tseen := make(map[string]struct{})","+\tvar bad []string","+\tadd := func(name string) {","+\t\tif _, ok := seen[name]; ok {","+\t\t\treturn","+\t\t}","+\t\tseen[name] = struct{}{}","+\t\tbad = append(bad, name)","+\t}","+","+\t// Pod-level fields. Enumerate every populated PodSpec field other than","+\t// the pod-level allowlist (NodeSelector, Tolerations, Affinity,","+\t// RuntimeClassName) so that admission errors match what the merge helper","+\t// would silently drop.","+\tif len(ps.Volumes) > 0 {","+\t\tadd(\"volumes\")","+\t}","+\tif len(ps.InitContainers) > 0 {","+\t\tadd(\"initContainers\")","+\t}","+\tif len(ps.EphemeralContainers) > 0 {","+\t\tadd(\"ephemeralContainers\")","+\t}","+\tif ps.RestartPolicy != \"\" {","+\t\tadd(\"restartPolicy\")","+\t}","+\tif ps.TerminationGracePeriodSeconds != nil {","+\t\tadd(\"terminationGracePeriodSeconds\")","+\t}","+\tif ps.ActiveDeadlineSeconds != nil {","+\t\tadd(\"activeDeadlineSeconds\")","+\t}","+\tif ps.DNSPolicy != \"\" {","+\t\tadd(\"dnsPolicy\")","+\t}","+\tif ps.ServiceAccountName != \"\" {","+\t\tadd(\"serviceAccountName\")","+\t}","+\tif ps.AutomountServiceAccountToken != nil {","+\t\tadd(\"automountServiceAccountToken\")","+\t}","+\tif ps.NodeName != \"\" {","+\t\tadd(\"nodeName\")","+\t}","+\tif ps.HostNetwork {","+\t\tadd(\"hostNetwork\")","+\t}","+\tif ps.HostPID {","+\t\tadd(\"hostPID\")","+\t}","+\tif ps.HostIPC {","+\t\tadd(\"hostIPC\")","+\t}","+\tif ps.ShareProcessNamespace != nil {","+\t\tadd(\"shareProcessNamespace\")","+\t}","+\tif ps.SecurityContext != nil {","+\t\tadd(\"securityContext\")","+\t}","+\tif len(ps.ImagePullSecrets) > 0 {","+\t\tadd(\"imagePullSecrets\")","+\t}","+\tif ps.Hostname != \"\" {","+\t\tadd(\"hostname\")","+\t}","+\tif ps.Subdomain != \"\" {","+\t\tadd(\"subdomain\")","+\t}","+\tif ps.SchedulerName != \"\" {","+\t\tadd(\"schedulerName\")","+\t}","+\tif len(ps.HostAliases) > 0 {","+\t\tadd(\"hostAliases\")","+\t}","+\tif ps.PriorityClassName != \"\" {","+\t\tadd(\"priorityClassName\")","+\t}","+\tif ps.Priority != nil {","+\t\tadd(\"priority\")","+\t}","+\tif ps.DNSConfig != nil {","+\t\tadd(\"dnsConfig\")","+\t}","+\tif len(ps.ReadinessGates) > 0 {","+\t\tadd(\"readinessGates\")","+\t}","+\tif ps.EnableServiceLinks != nil {","+\t\tadd(\"enableServiceLinks\")","+\t}","+\tif ps.PreemptionPolicy != nil {","+\t\tadd(\"preemptionPolicy\")","+\t}","+\tif len(ps.Overhead) > 0 {","+\t\tadd(\"overhead\")","+\t}","+\tif len(ps.TopologySpreadConstraints) > 0 {","+\t\tadd(\"topologySpreadConstraints\")","+\t}","+\tif ps.SetHostnameAsFQDN != nil {","+\t\tadd(\"setHostnameAsFQDN\")","+\t}","+\tif ps.OS != nil {","+\t\tadd(\"os\")","+\t}","+\tif ps.HostUsers != nil {","+\t\tadd(\"hostUsers\")","+\t}","+\tif len(ps.SchedulingGates) > 0 {","+\t\tadd(\"schedulingGates\")","+\t}","+\tif len(ps.ResourceClaims) > 0 {","+\t\tadd(\"resourceClaims\")","+\t}","+","+\t// Container-level fields. Within a container the only allowlisted","+\t// fields are Name (used for the per-container Resources match) and","+\t// Resources itself. Everything else flagged here would let a caller","+\t// run arbitrary code or exfiltrate data through the connector pod.","+\tfor i := range ps.Containers {","+\t\tc := ps.Containers[i]","+\t\tif c.Image != \"\" {","+\t\t\tadd(\"containers[].image\")","+\t\t}","+\t\tif len(c.Command) > 0 {","+\t\t\tadd(\"containers[].command\")","+\t\t}","+\t\tif len(c.Args) > 0 {","+\t\t\tadd(\"containers[].args\")","+\t\t}","+\t\tif len(c.Env) > 0 {","+\t\t\tadd(\"containers[].env\")","+\t\t}","+\t\tif len(c.EnvFrom) > 0 {","+\t\t\tadd(\"containers[].envFrom\")","+\t\t}","+\t\tif len(c.VolumeMounts) > 0 {","+\t\t\tadd(\"containers[].volumeMounts\")","+\t\t}","+\t\tif len(c.VolumeDevices) > 0 {","+\t\t\tadd(\"containers[].volumeDevices\")","+\t\t}","+\t\tif len(c.Ports) > 0 {","+\t\t\tadd(\"containers[].ports\")","+\t\t}","+\t\tif c.WorkingDir != \"\" {","+\t\t\tadd(\"containers[].workingDir\")","+\t\t}","+\t\tif c.Lifecycle != nil {","+\t\t\tadd(\"containers[].lifecycle\")","+\t\t}","+\t\tif c.LivenessProbe != nil {","+\t\t\tadd(\"containers[].livenessProbe\")","+\t\t}","+\t\tif c.ReadinessProbe != nil {","+\t\t\tadd(\"containers[].readinessProbe\")","+\t\t}","+\t\tif c.StartupProbe != nil {","+\t\t\tadd(\"containers[].startupProbe\")","+\t\t}","+\t\tif c.SecurityContext != nil {","+\t\t\tadd(\"containers[].securityContext\")","+\t\t}","+\t}","+\treturn bad","+}"],"additions":279,"deletions":0,"truncated":false},{"path":"pkg/executor/util/merge_allowlist_test.go","lines":["@@ -0,0 +1,444 @@","+/*","+Copyright 2026 The Fission Authors.","+","+Licensed under the Apache License, Version 2.0 (the \"License\");","+you may not use this file except in compliance with the License.","+You may obtain a copy of the License at","+","+\thttp://www.apache.org/licenses/LICENSE-2.0","+","+Unless required by applicable law or agreed to in writing, software","+distributed under the License is distributed on an \"AS IS\" BASIS,","+WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.","+See the License for the specific language governing permissions and","+limitations under the License.","+*/","+","+package util","+","+import (","+\t\"testing\"","+","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+\tapiv1 \"k8s.io/api/core/v1\"","+\t\"k8s.io/apimachinery/pkg/api/resource\"","+)","+","+func TestMergeAllowedPodSpecFieldsDropsImageOverride(t *testing.T) {","+\tsrc := &apiv1.PodSpec{","+\t\tContainers: []apiv1.Container{{Name: \"connector\", Image: \"fission/keda-kafka:1.0\"}},","+\t}","+\tuser := &apiv1.PodSpec{","+\t\tContainers:   []apiv1.Container{{Name: \"connector\", Image: \"evil/registry:latest\"}},","+\t\tNodeSelector: map[string]string{\"role\": \"mqt\"},","+\t}","+","+\tout, dropped := MergeAllowedPodSpecFields(src, user)","+","+\tassert.Equal(t, \"fission/keda-kafka:1.0\", out.Containers[0].Image,","+\t\t\"user-supplied container image must NOT override controller-set image\")","+\tassert.Equal(t, map[string]string{\"role\": \"mqt\"}, out.NodeSelector,","+\t\t\"node selector must flow through\")","+\tassert.Contains(t, dropped, \"containers[].image\", \"image override must be reported as dropped\")","+}","+","+func TestMergeAllowedPodSpecFieldsAcceptsTolerations(t *testing.T) {","+\tsrc := &apiv1.PodSpec{","+\t\tContainers: []apiv1.Container{{Name: \"connector\"}},","+\t}","+\tuser := &apiv1.PodSpec{","+\t\tTolerations: []apiv1.Toleration{{Key: \"dedicated\", Operator: apiv1.TolerationOpEqual, Value: \"mqt\"}},","+\t}","+\tout, dropped := MergeAllowedPodSpecFields(src, user)","+\trequire.Len(t, out.Tolerations, 1)","+\tassert.Empty(t, dropped, \"tolerations are allowlisted and must not be reported as dropped\")","+}","+","+func TestMergeAllowedPodSpecFieldsAcceptsAffinityAndRuntimeClass(t *testing.T) {","+\tsrc := &apiv1.PodSpec{Containers: []apiv1.Container{{Name: \"connector\"}}}","+\trc := \"kata\"","+\taff := &apiv1.Affinity{","+\t\tNodeAffinity: &apiv1.NodeAffinity{","+\t\t\tRequiredDuringSchedulingIgnoredDuringExecution: &apiv1.NodeSelector{","+\t\t\t\tNodeSelectorTerms: []apiv1.NodeSelectorTerm{{","+\t\t\t\t\tMatchExpressions: []apiv1.NodeSelectorRequirement{{","+\t\t\t\t\t\tKey:      \"topology.kubernetes.io/zone\",","+\t\t\t\t\t\tOperator: apiv1.NodeSelectorOpIn,","+\t\t\t\t\t\tValues:   []string{\"us-east-1a\"},","+\t\t\t\t\t}},","+\t\t\t\t}},","+\t\t\t},","+\t\t},","+\t}","+\tuser := &apiv1.PodSpec{","+\t\tAffinity:         aff,","+\t\tRuntimeClassName: &rc,","+\t}","+\tout, _ := MergeAllowedPodSpecFields(src, user)","+\trequire.NotNil(t, out.Affinity)","+\trequire.NotNil(t, out.RuntimeClassName)","+\tassert.Equal(t, \"kata\", *out.RuntimeClassName)","+}","+","+func TestMergeAllowedPodSpecFieldsAppliesContainerResources(t *testing.T) {","+\tsrc := &apiv1.PodSpec{","+\t\tContainers: []apiv1.Container{{Name: \"connector\", Image: \"fission/keda-kafka:1.0\"}},","+\t}","+\tuser := &apiv1.PodSpec{","+\t\tContainers: []apiv1.Container{{","+\t\t\tName: \"connector\",","+\t\t\tResources: apiv1.ResourceRequirements{","+\t\t\t\tRequests: apiv1.ResourceList{apiv1.ResourceCPU: resource.MustParse(\"100m\")},","+\t\t\t\tLimits:   apiv1.ResourceList{apiv1.ResourceMemory: resource.MustParse(\"128Mi\")},","+\t\t\t},","+\t\t}},","+\t}","+\tout, dropped := MergeAllowedPodSpecFields(src, user)","+\tassert.Equal(t, \"fission/keda-kafka:1.0\", out.Containers[0].Image,","+\t\t\"image must remain controller-set after Resources merge\")","+\tassert.Equal(t, resource.MustParse(\"100m\"), out.Containers[0].Resources.Requests[apiv1.ResourceCPU])","+\tassert.Equal(t, resource.MustParse(\"128Mi\"), out.Containers[0].Resources.Limits[apiv1.ResourceMemory])","+\tassert.Empty(t, dropped, \"name-matched Resources must not be reported as dropped\")","+}","+","+func TestMergeAllowedPodSpecFieldsDropsDangerousFields(t *testing.T) {","+\tsrc := &apiv1.PodSpec{","+\t\tContainers: []apiv1.Container{{Name: \"connector\", Image: \"fission/keda-kafka:1.0\"}},","+\t}","+\trunAsUser := int64(0)","+\tautomount := true","+\tshare := true","+\tgracePeriod := int64(60)","+\tdeadline := int64(120)","+\tpriority := int32(1000)","+\tenableLinks := true","+\tpreempt := apiv1.PreemptNever","+\tfqdn := true","+\thostUsers := false","+\tuser := &apiv1.PodSpec{","+\t\tContainers: []apiv1.Container{{","+\t\t\tName:            \"connector\",","+\t\t\tImage:           \"evil:latest\",","+\t\t\tCommand:         []string{\"/bin/sh\"},","+\t\t\tArgs:            []string{\"-c\", \"curl evil\"},","+\t\t\tEnv:             []apiv1.EnvVar{{Name: \"INJECTED\", Value: \"yes\"}},","+\t\t\tEnvFrom:         []apiv1.EnvFromSource{{SecretRef: &apiv1.SecretEnvSource{LocalObjectReference: apiv1.LocalObjectReference{Name: \"any-secret\"}}}},","+\t\t\tVolumeMounts:    []apiv1.VolumeMount{{Name: \"host\", MountPath: \"/host\"}},","+\t\t\tPorts:           []apiv1.ContainerPort{{ContainerPort: 1234}},","+\t\t\tWorkingDir:      \"/evil\",","+\t\t\tLifecycle:       &apiv1.Lifecycle{},","+\t\t\tLivenessProbe:   &apiv1.Probe{},","+\t\t\tReadinessProbe:  &apiv1.Probe{},","+\t\t\tStartupProbe:    &apiv1.Probe{},","+\t\t\tSecurityContext: &apiv1.SecurityContext{RunAsUser: &runAsUser},","+\t\t}},","+\t\tInitContainers:                []apiv1.Container{{Name: \"init\", Image: \"evil:latest\"}},","+\t\tVolumes:                       []apiv1.Volume{{Name: \"host\", VolumeSource: apiv1.VolumeSource{HostPath: &apiv1.HostPathVolumeSource{Path: \"/\"}}}},","+\t\tImagePullSecrets:              []apiv1.LocalObjectReference{{Name: \"creds\"}},","+\t\tServiceAccountName:            \"cluster-admin\",","+\t\tAutomountServiceAccountToken:  &automount,","+\t\tNodeName:                      \"evil-node\",","+\t\tHostNetwork:                   true,","+\t\tHostPID:                       true,","+\t\tHostIPC:                       true,","+\t\tShareProcessNamespace:         &share,","+\t\tSecurityContext:               &apiv1.PodSecurityContext{RunAsUser: &runAsUser},","+\t\tSchedulerName:                 \"evil-scheduler\",","+\t\tHostAliases:                   []apiv1.HostAlias{{IP: \"1.2.3.4\", Hostnames: []string{\"evil\"}}},","+\t\tPriorityClassName:             \"high\",","+\t\tDNSConfig:                     &apiv1.PodDNSConfig{},","+\t\tTopologySpreadConstraints:     []apiv1.TopologySpreadConstraint{{}},","+\t\tRestartPolicy:                 apiv1.RestartPolicyNever,","+\t\tTerminationGracePeriodSeconds: &gracePeriod,","+\t\tActiveDeadlineSeconds:         &deadline,","+\t\tDNSPolicy:                     apiv1.DNSClusterFirst,","+\t\tHostname:                      \"evil-host\",","+\t\tSubdomain:                     \"evil\",","+\t\tPriority:                      &priority,","+\t\tReadinessGates:                []apiv1.PodReadinessGate{{ConditionType: \"evil\"}},","+\t\tEnableServiceLinks:            &enableLinks,","+\t\tPreemptionPolicy:              &preempt,","+\t\tOverhead:                      apiv1.ResourceList{apiv1.ResourceCPU: resource.MustParse(\"10m\")},","+\t\tSetHostnameAsFQDN:             &fqdn,","+\t\tOS:                            &apiv1.PodOS{Name: apiv1.Linux},","+\t\tHostUsers:                     &hostUsers,","+\t\tSchedulingGates:               []apiv1.PodSchedulingGate{{Name: \"evil\"}},","+\t\tResourceClaims:                []apiv1.PodResourceClaim{{Name: \"evil\"}},","+\t}","+\tout, dropped := MergeAllowedPodSpecFields(src, user)","+","+\t// Output must look identical to src (modulo nil vs empty).","+\tassert.Equal(t, \"fission/keda-kafka:1.0\", out.Containers[0].Image)","+\tassert.Empty(t, out.Containers[0].Command)","+\tassert.Empty(t, out.Containers[0].Args)","+\tassert.Empty(t, out.Containers[0].Env)","+\tassert.Empty(t, out.Containers[0].EnvFrom)","+\tassert.Empty(t, out.Containers[0].VolumeMounts)","+\tassert.Empty(t, out.Containers[0].Ports)","+\tassert.Empty(t, out.Containers[0].WorkingDir)","+\tassert.Nil(t, out.Containers[0].Lifecycle)","+\tassert.Nil(t, out.Containers[0].LivenessProbe)","+\tassert.Nil(t, out.Containers[0].ReadinessProbe)","+\tassert.Nil(t, out.Containers[0].StartupProbe)","+\tassert.Nil(t, out.Containers[0].SecurityContext)","+\tassert.Empty(t, out.InitContainers)","+\tassert.Empty(t, out.Volumes)","+\tassert.Empty(t, out.ImagePullSecrets)","+\tassert.Empty(t, out.Service