com/feature/condregister/oauthkey","         tailscale.com/feature/portmapper                             from tailscale.com/feature/condregister/portmapper","         tailscale.com/feature/useproxy                               from tailscale.com/feature/condregister/useproxy","@@ -319,7 +321,7 @@ tailscale.com/cmd/tsidp dependencies: (generated by github.com/tailscale/depawar","         tailscale.com/wgengine/filter                                from tailscale.com/control/controlclient+","         tailscale.com/wgengine/filter/filtertype                     from tailscale.com/types/netmap+","      💣 tailscale.com/wgengine/magicsock                             from tailscale.com/ipn/ipnlocal+","-        tailscale.com/wgengine/netlog                                from tailscale.com/wgengine+","+        tailscale.com/wgengine/netlog                                from tailscale.com/feature/netlog","         tailscale.com/wgengine/netstack                              from tailscale.com/tsnet","         tailscale.com/wgengine/netstack/gro                          from tailscale.com/net/tstun+","         tailscale.com/wgengine/router                                from tailscale.com/ipn/ipnlocal+"],"additions":3,"deletions":1,"truncated":false},{"path":"feature/condregister/maybe_netlog.go","lines":["@@ -0,0 +1,6 @@","+// Copyright (c) Tailscale Inc & contributors","+// SPDX-License-Identifier: BSD-3-Clause","+","+package condregister","+","+import _ \"tailscale.com/feature/condregister/netlog\""],"additions":6,"deletions":0,"truncated":false},{"path":"feature/condregister/netlog/doc.go","lines":["@@ -0,0 +1,8 @@","+// Copyright (c) Tailscale Inc & contributors","+// SPDX-License-Identifier: BSD-3-Clause","+","+// Package netlog registers support for network flow logging if it's","+// not disabled via the ts_omit_netlog or ts_omit_logtail build tags.","+// It is pulled out separately from the main condregister package so","+// that tsnet can link it without linking every conditional feature.","+package netlog"],"additions":8,"deletions":0,"truncated":false},{"path":"feature/condregister/netlog/maybe_netlog.go","lines":["@@ -0,0 +1,8 @@","+// Copyright (c) Tailscale Inc & contributors","+// SPDX-License-Identifier: BSD-3-Clause","+","+//go:build !ts_omit_netlog && !ts_omit_logtail","+","+package netlog","+","+import _ \"tailscale.com/feature/netlog\""],"additions":8,"deletions":0,"truncated":false},{"path":"feature/netlog/netlog.go","lines":["@@ -0,0 +1,119 @@","+// Copyright (c) Tailscale Inc & contributors","+// SPDX-License-Identifier: BSD-3-Clause","+","+// Package netlog registers the network flow logging feature and wires","+// it into the WireGuard engine. The logger implementation itself lives","+// in tailscale.com/wgengine/netlog.","+package netlog","+","+import (","+\t\"context\"","+\t\"time\"","+","+\t\"tailscale.com/envknob\"","+\t\"tailscale.com/feature\"","+\t\"tailscale.com/types/logid\"","+\t\"tailscale.com/wgengine\"","+\t\"tailscale.com/wgengine/netlog\"","+\t\"tailscale.com/wgengine/router\"","+)","+","+func init() {","+\tfeature.Register(\"netlog\")","+\twgengine.HookNewNetLogger.Set(newNetLogger)","+}","+","+// uploadTimeout is the maximum time to wait when shutting down the","+// network logger as it uploads the final network log messages.","+const uploadTimeout = 5 * time.Second","+","+// netLogger implements [wgengine.NetLogger] on top of [netlog.Logger],","+// tracking the logging identity and running state across engine","+// reconfigurations. One netLogger exists per engine.","+type netLogger struct {","+\tdeps   wgengine.NetLoggerDeps","+\tlogger netlog.Logger","+","+\t// The fields below are only accessed from Reconfig and","+\t// ReconfigDone, which the engine serializes under its internal","+\t// lock.","+","+\t// nodeID and domainID are the logging IDs from the last Reconfig,","+\t// or zero if logging was not enabled then.","+\tnodeID, domainID logid.PrivateID","+\t// logExitFlows is whether exit node flows were logged as of the","+\t// last Reconfig.","+\tlogExitFlows bool","+\t// shouldRun is whether the last Reconfig wanted the logger","+\t// running. ReconfigDone consults it to shut down a stopping","+\t// logger after the router has been reconfigured.","+\tshouldRun bool","+}","+","+func newNetLogger(deps wgengine.NetLoggerDeps) wgengine.NetLogger {","+\treturn &netLogger{deps: deps}","+}","+","+func (nl *netLogger) Reconfig(routerCfg *router.Config, routerChanged bool) (changed bool) {","+\tlogf := nl.deps.Logf","+\tsrc := nl.deps.Source()","+","+\tvar nodeID, domainID logid.PrivateID","+\tvar logExitFlows bool","+\tif src != nil {","+\t\tif nid, did, lef, ok := src.NetLogIDs(); ok {","+\t\t\tnodeID, domainID, logExitFlows = nid, did, lef","+\t\t}","+\t}","+\tidsValid := !nodeID.IsZero() && !domainID.IsZero()","+\tidsWereValid := !nl.nodeID.IsZero() && !nl.domainID.IsZero()","+\tchanged = nodeID != nl.nodeID || domainID != nl.domainID || logExitFlows != nl.logExitFlows","+\tidsChanged := idsValid && idsWereValid && changed","+\tnl.nodeID, nl.domainID, nl.logExitFlows = nodeID, domainID, logExitFlows","+","+\tnl.shouldRun = idsValid && !routerCfg.Equal(&router.Config{}) && !envknob.NoLogsNoSupport()","+","+\t// Shut down the logger if the IDs changed while it was running,","+\t// letting the startup logic below bring it back up with the new","+\t// identity.","+\tif idsChanged && nl.logger.Running() {","+\t\tlogf(\"wgengine: Reconfig: shutting down network logger\")","+\t\tnl.shutdown()","+\t}","+","+\t// Start the logger before the engine configures the router so","+\t// that it captures initial packets.","+\tif nl.shouldRun && !nl.logger.Running() {","+\t\tlogf(\"wgengine: Reconfig: starting up network logger (node:%s tailnet:%s)\", nodeID.Public(), domainID.Public())","+\t\tif err := nl.logger.Startup(logf, src, nodeID, domainID, nl.deps.Tun, nl.deps.Sock, nl.deps.NetMon, nl.deps.Health, nl.deps.Bus, logExitFlows); err != nil {","+\t\t\tlogf(\"wgengine: Reconfig: error starting up network logger: %v\", err)","+\t\t}","+\t\tnl.logger.ReconfigRoutes(routerCfg)","+\t} else if routerChanged && nl.logger.Running() {","+\t\tnl.logger.ReconfigRoutes(routerCfg)","+\t}","+\treturn changed","+}","+","+func (nl *netLogger) ReconfigDone() {","+\t// Shut down a stopping logger only now, after the engine has","+\t// configured the router, so that it captures final packets.","+\tif !nl.shouldRun && nl.logger.Running() {","+\t\tnl.deps.Logf(\"wgengine: Reconfig: shutting down network logger\")","+\t\tnl.shutdown()","+\t}","+}","+","+func (nl *netLogger) Shutdown() {","+\tnl.shutdown()","+}","+","+// shutdown stops the logger, waiting up to uploadTimeout for it to","+// flush its final messages.","+func (nl *netLogger) shutdown() {","+\tctx, cancel := context.WithTimeout(context.Background(), uploadTimeout)","+\tdefer cancel()","+\tif err := nl.logger.Shutdown(ctx); err != nil {","+\t\tnl.deps.Logf(\"wgengine: error shutting down network logger: %v\", err)","+\t}","+}"],"additions":119,"deletions":0,"truncated":false},{"path":"ipn/ipnlocal/local.go","lines":["@@ -103,7 +103,6 @@ import ("," \t\"tailscale.com/wgengine\""," \t\"tailscale.com/wgengine/filter\""," \t\"tailscale.com/wgengine/magicsock\"","-\t\"tailscale.com/wgengine/netlog\""," \t\"tailscale.com/wgengine/router\""," \t\"tailscale.com/wgengine/wgcfg\""," \t\"tailscale.com/wgengine/wgcfg/nmcfg\"","@@ -636,7 +635,7 @@ func NewLocalBackend(logf logger.Logf, logID logid.PublicID, sys *tsd.System, lo"," \te.SetPeerByIPPacketFunc(b.lookupPeerByIP)"," \te.SetPeerForIPFunc(b.peerForIP)"," \te.SetPeerSessionStateFunc(b.onPeerWireGuardState)","-\te.SetNetLogNodeSource(netLogNodeSource{b})","+\te.SetNetLogSource(netLogNodeSource{b})"," \te.SetWGPeerLookup(b.lookupPeerWireGuardString)"," \tb.dialer.SetResolveMagicDNS(b.resolveMagicDNS)"," ","@@ -8017,9 +8016,10 @@ func (n noiseRoundTripper) RoundTrip(req *http.Request) (*http.Response, error)"," \treturn n.lb.DoNoiseRequest(req)"," }"," ","-// netLogNodeSource adapts LocalBackend's nodeBackend to [netlog.NodeSource].","-// Each method consults [LocalBackend.currentNode] so that profile rotations","-// are picked up automatically without re-installing the source.","+// netLogNodeSource adapts LocalBackend to [wgengine.NetLogSource].","+// Each method consults [LocalBackend.currentNode] or the current netmap","+// so that profile rotations are picked up automatically without","+// re-installing the source."," type netLogNodeSource struct {"," \tb *LocalBackend"," }","@@ -8048,8 +8048,37 @@ func (s netLogNodeSource) NodeByAddr(addr netip.Addr) (_ tailcfg.NodeView, _ tai"," \treturn nv, up, true"," }"," ","-// Compile-time assertion that netLogNodeSource implements [netlog.NodeSource].","-var _ netlog.NodeSource = netLogNodeSource{}","+// NetLogIDs implements [wgengine.NetLogSource], returning the network","+// flow logging identity from the current netmap. ok is false if the","+// netmap does not enable network flow logging for this node.","+func (s netLogNodeSource) NetLogIDs() (nodeID, domainID logid.PrivateID, logExitFlows bool, ok bool) {","+\tnm := s.b.NetMap()","+\tif nm == nil || !nm.SelfNode.Valid() {","+\t\treturn","+\t}","+\tif !nm.SelfNode.HasCap(tailcfg.CapabilityDataPlaneAuditLogs) {","+\t\treturn","+\t}","+\tif nm.SelfNode.DataPlaneAuditLogID() == \"\" || nm.DomainAuditLogID == \"\" {","+\t\treturn","+\t}","+\tnodeID, errNode := logid.ParsePrivateID(nm.SelfNode.DataPlaneAuditLogID())","+\tif errNode != nil {","+\t\ts.b.logf(\"[v1] netlog: unable to parse node audit log ID: %v\", errNode)","+\t}","+\tdomainID, errDomain := logid.ParsePrivateID(nm.DomainAuditLogID)","+\tif errDomain != nil {","+\t\ts.b.logf(\"[v1] netlog: unable to parse domain audit log ID: %v\", errDomain)","+\t}","+\tif errNode != nil || errDomain != nil {","+\t\treturn logid.PrivateID{}, logid.PrivateID{}, false, false","+\t}","+\treturn nodeID, domainID, nm.SelfNode.HasCap(tailcfg.NodeAttrLogExitFlows), true","+}","+","+// Compile-time assertion that netLogNodeSource implements","+// [wgengine.NetLogSource].","+var _ wgengine.NetLogSource = netLogNodeSource{}"," "," // lookupPeerWireGuardString returns the Tailscale-conventional short string"," // (e.g. \"[IMTBr]\") for the peer whose wireguard-go-formatted public key"],"additions":36,"deletions":7,"truncated":false},{"path":"ipn/ipnlocal/state_test.go","lines":["@@ -47,7 +47,6 @@ import ("," \t\"tailscale.com/wgengine\""," \t\"tailscale.com/wgengine/filter\""," \t\"tailscale.com/wgengine/magicsock\"","-\t\"tailscale.com/wgengine/netlog\""," \t\"tailscale.com/wgengine/router\""," \t\"tailscale.com/wgengine/wgcfg\""," \t\"tailscale.com/wgengine/wgint\"","@@ -1989,7 +1988,7 @@ func (e *mockEngine) PeerKeyForIP(netip.Addr) (_ key.NodePublic, _ netip.Prefix,"," }"," func (e *mockEngine) SetPeerSessionStateFunc(func(key.NodePublic, wgengine.PeerWireGuardState)) {"," }","-func (e *mockEngine) SetNetLogNodeSource(netlog.NodeSource)                            {}","+func (e *mockEngine) SetNetLogSource(wgengine.NetLogSource)                            {}"," func (e *mockEngine) SetWGPeerLookup(func(wgString string) (tsString string, ok bool)) {}"," func (e *mockEngine) ProbeLocks()                                                      {}"," "],"additions":1,"deletions":2,"truncated":false},{"path":"tsnet/depaware.txt","lines":["@@ -147,9 +147,11 @@ tailscale.com/tsnet dependencies: (generated by github.com/tailscale/depaware)","         tailscale.com/feature/buildfeatures                          from tailscale.com/wgengine/magicsock+","         tailscale.com/feature/c2n                                    from tailscale.com/tsnet","         tailscale.com/feature/condlite/expvar                        from tailscale.com/wgengine/magicsock","+        tailscale.com/feature/condregister/netlog                    from tailscale.com/tsnet","         tailscale.com/feature/condregister/oauthkey                  from tailscale.com/tsnet","         tailscale.com/feature/condregister/portmapper                from tailscale.com/tsnet","         tailscale.com/feature/condregister/useproxy                  from tailscale.com/tsnet","+        tailscale.com/feature/netlog                                 from tailscale.com/feature/condregister/netlog","         tailscale.com/feature/oauthkey                               from tailscale.com/feature/condregister/oauthkey","         tailscale.com/feature/portmapper                             from tailscale.com/feature/condregister/portmapper","         tailscale.com/feature/useproxy                               from tailscale.com/feature/condregister/useproxy","@@ -314,7 +316,7 @@ tailscale.com/tsnet dependencies: (generated by github.com/tailscale/depaware)","         tailscale.com/wgengine/filter                                from tailscale.com/control/controlclient+","         tailscale.com/wgengine/filter/filtertype                     from tailscale.com/types/netmap+","      💣 tailscale.com/wgengine/magicsock                             from tailscale.com/ipn/ipnlocal+","-        tailscale.com/wgengine/netlog                                from tailscale.com/wgengine+","+        tailscale.com/wgengine/netlog                                from tailscale.com/feature/netlog","         tailscale.com/wgengine/netstack                              from tailscale.com/tsnet","         tailscale.com/wgengine/netstack/gro                          from tailscale.com/net/tstun+","         tailscale.com/wgengine/router                                from tailscale.com/ipn/ipnlocal+"],"additions":3,"deletions":1,"truncated":false},{"path":"tsnet/tsnet.go","lines":["@@ -163,6 +163,7 @@ import ("," \t\"tailscale.com/control/controlclient\""," \t\"tailscale.com/envknob\""," \t_ \"tailscale.com/feature/c2n\"","+\t_ \"tailscale.com/feature/condregister/netlog\""," \t_ \"tailscale.com/feature/condregister/oauthkey\""," \t_ \"tailscale.com/feature/condregister/portmapper\""," \t_ \"tailscale.com/feature/condregister/useproxy\""],"additions":1,"deletions":0,"truncated":false},{"path":"wgengine/netlog_hooks.go","lines":["@@ -0,0 +1,86 @@","+// Copyright (c) Tailscale Inc & contributors","+// SPDX-License-Identifier: BSD-3-Clause","+","+package wgengine","+","+import (","+\t\"net/netip\"","+","+\t\"tailscale.com/feature\"","+\t\"tailscale.com/health\"","+\t\"tailscale.com/net/netmon\"","+\t\"tailscale.com/net/tstun\"","+\t\"tailscale.com/tailcfg\"","+\t\"tailscale.com/types/logger\"","+\t\"tailscale.com/types/logid\"","+\t\"tailscale.com/util/eventbus\"","+\t\"tailscale.com/wgengine/magicsock\"","+\t\"tailscale.com/wgengine/router\"","+)","+","+// NetLogSource provides the network flow logging feature what it needs","+// from the rest of the system (in practice, ipnlocal.LocalBackend):","+// on-demand node lookups and the current audit logging identity.","+type NetLogSource interface {","+\t// SelfNode returns the current self node and its owning user profile.","+\t// The views are invalid if there is no current node.","+\tSelfNode() (tailcfg.NodeView, tailcfg.UserProfileView)","+","+\t// NodeByAddr returns the node assigned the given address along with","+\t// its owning user profile.","+\t// ok is false if no node is known to own addr.","+\tNodeByAddr(addr netip.Addr) (node tailcfg.NodeView, user tailcfg.UserProfileView, ok bool)","+","+\t// NetLogIDs returns the audit logging IDs from the current netmap,","+\t// along with whether exit node flows should be logged.","+\t// ok is false if network flow logging should not run.","+\tNetLogIDs() (nodeID, domainID logid.PrivateID, logExitFlows bool, ok bool)","+}","+","+// NetLogger is the engine's handle on the network flow logger","+// lifecycle, implemented by the feature/netlog package.","+//","+// Reconfig and ReconfigDone are only called from [Engine.Reconfig],","+// serialized by the engine's internal lock. Shutdown may be called","+// concurrently with them from [Engine.Close].","+type NetLogger interface {","+\t// Reconfig is called near the top of every [Engine.Reconfig],","+\t// before its ErrNoChanges early return (so identity-only changes","+\t// still take effect) and before the router is configured (so a","+\t// starting logger captures initial packets). It reports whether","+\t// network logging state changed, which suppresses the engine's","+\t// ErrNoChanges early return.","+\tReconfig(routerCfg *router.Config, routerChanged bool) (changed bool)","+","+\t// ReconfigDone is called at the end of [Engine.Reconfig], after","+\t// the router is configured, so that a logger stopping as a result","+\t// of the preceding Reconfig call captures final packets. It may","+\t// block to flush pending messages.","+\tReconfigDone()","+","+\t// Shutdown stops the logger. It may block to flush pending","+\t// messages, bounded by an internal upload timeout.","+\tShutdown()","+}","+","+// NetLoggerDeps are the engine-owned dependencies passed to","+// [HookNewNetLogger] to construct a [NetLogger].","+type NetLoggerDeps struct {","+\tLogf   logger.Logf","+\tTun    *tstun.Wrapper","+\tSock   *magicsock.Conn","+\tNetMon *netmon.Monitor","+\tHealth *health.Tracker","+\tBus    *eventbus.Bus","+","+\t// Source returns the [NetLogSource] installed via","+\t// [Engine.SetNetLogSource], or nil if none has been installed yet.","+\t// It is a func because the source is installed after the engine","+\t// (and thus the NetLogger) is constructed.","+\tSource func() NetLogSource","+}","+","+// HookNewNetLogger is set by the feature/netlog package to construct","+// each engine's [NetLogger]. If unset, network flow logging is not","+// linked into the binary and the engine skips all NetLogger calls.","+var HookNewNetLogger feature.Hook[func(NetLoggerDeps) NetLogger]"],"additions":86,"deletions":0,"truncated":false},{"path":"wgengine/userspace.go","lines":["@@ -58,7 +58,6 @@ import ("," \t\"tailscale.com/version\""," \t\"tailscale.com/wgengine/filter\""," \t\"tailscale.com/wgengine/magicsock\"","-\t\"tailscale.com/wgengine/netlog\""," \t\"tailscale.com/wgengine/netstack/gro\""," \t\"tailscale.com/wgengine/router\""," \t\"tailscale.com/wgengine/wgcfg\"","@@ -66,10 +65,6 @@ import ("," \t\"tailscale.com/wgengine/wglog\""," )"," ","-// networkLoggerUploadTimeout is the maximum timeout to wait when","-// shutting down the network logger as it uploads the last network log messages.","-const networkLoggerUploadTimeout = 5 * time.Second","-"," type userspaceEngine struct {"," \t// eventBus will eventually become required, but for now may be nil."," \teventBus    *eventbus.Bus","@@ -156,13 +151,16 @@ type userspaceEngine struct {"," \t// value of the ICMP identifier and sequence number concatenated."," \ticmpEchoResponseCallback map[uint32]func()"," ","-\t// networkLogger logs statistics about network connections.","-\tnetworkLogger netlog.Logger","+\t// netlogger is the network flow logger handle constructed via","+\t// [HookNewNetLogger], or nil if the feature/netlog package is not","+\t// linked into the binary.","+\tnetlogger NetLogger"," ","-\t// netLogSource is the [netlog.NodeSource] installed via","-\t// [Engine.SetNetLogNodeSource]; it is read when starting up the network","-\t// logger from inside Reconfig. It may be nil if no source was installed.","-\tnetLogSource syncs.AtomicValue[netlog.NodeSource]","+\t// netLogSource is the [NetLogSource] installed via","+\t// [Engine.SetNetLogSource]; the netlogger reads it on each","+\t// Reconfig via [NetLoggerDeps.Source]. It may be nil if no source","+\t// was installed.","+\tnetLogSource syncs.AtomicValue[NetLogSource]"," "," \t// wgPeerLookup is the lookup function installed via"," \t// [Engine.SetWGPeerLookup]; it is consulted by [wgLogger] to translate","@@ -454,6 +452,18 @@ func NewUserspaceEngine(logf logger.Logf, conf Config) (_ Engine, reterr error)"," \tclosePool.add(e.magicConn)"," \te.magicConn.SetNetworkUp(e.netMon.InterfaceState().AnyInterfaceUp())"," ","+\tif newNetLogger, ok := HookNewNetLogger.GetOk(); ok {","+\t\te.netlogger = newNetLogger(NetLoggerDeps{","+\t\t\tLogf:   logf,","+\t\t\tTun:    e.tundev,","+\t\t\tSock:   e.magicConn,","+\t\t\tNetMon: e.netMon,","+\t\t\tHealth: e.health,","+\t\t\tBus:    e.eventBus,","+\t\t\tSource: e.netLogSource.Load,","+\t\t})","+\t}","+"," \ttsTUNDev.SetDiscoKey(e.magicConn.DiscoPublicKey())"," "," \tif conf.RespondToPing {","@@ -758,9 +768,9 @@ func (e *userspaceEngine) SetPeerSessionStateFunc(fn func(key.NodePublic, PeerWi"," \t})"," }"," ","-// SetNetLogNodeSource installs the [netlog.NodeSource] used by the engine's","-// network logger.","-func (e *userspaceEngine) SetNetLogNodeSource(src netlog.NodeSource) {","+// SetNetLogSource installs the [NetLogSource] consulted by the engine's","+// network flow logger.","+func (e *userspaceEngine) SetNetLogSource(src NetLogSource) {"," \te.netLogSource.Store(src)"," }"," ","@@ -864,17 +874,18 @@ func (e *userspaceEngine) Reconfig(cfg *wgcfg.Config, routerCfg *router.Config,"," "," \tlistenPortChanged := listenPort != e.magicConn.LocalPort()"," \tpeerMTUChanged := peerMTUEnable != e.magicConn.PeerMTUEnabled()","-\tif !engineChanged && !routerChanged && !dnsChanged && !listenPortChanged && !isSubnetRouterChanged && !peerMTUChanged {","-\t\treturn ErrNoChanges","+","+\t// Let the network flow logger react before the early return below,","+\t// so that logging identity changes take effect even when nothing","+\t// else changed, and before the router is configured, so that a","+\t// starting logger captures initial packets.","+\tnetlogChanged := false","+\tif e.netlogger != nil {","+\t\tnetlogChanged = e.netlogger.Reconfig(routerCfg, routerChanged)"," \t}","-\tnewLogIDs := cfg.NetworkLogging","-\toldLogIDs := e.lastCfgFull.NetworkLogging","-\tnetLogIDsNowValid := !newLogIDs.NodeID.IsZero() && !newLogIDs.DomainID.IsZero()","-\tnetLogIDsWasValid := !oldLogIDs.NodeID.IsZero() && !oldLogIDs.DomainID.IsZero()"],"additions":32,"deletions":20,"truncated