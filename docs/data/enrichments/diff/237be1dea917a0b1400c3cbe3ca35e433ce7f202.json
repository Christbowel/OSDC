{"id":"237be1dea917a0b1400c3cbe3ca35e433ce7f202","axis":"silent","repo":"grafana/grafana","sha":"237be1dea917a0b1400c3cbe3ca35e433ce7f202","parsed":{"files":[{"path":"pkg/storage/unified/search/bleve.go","lines":["@@ -622,7 +622,13 @@ func (b *bleveBackend) BuildIndex("," }"," "," func (b *bleveBackend) getResourceDir(key resource.NamespacedResource) string {","-\treturn filepath.Join(b.opts.Root, cleanFileSegment(key.Namespace), cleanFileSegment(fmt.Sprintf(\"%s.%s\", key.Resource, key.Group)))","+\treturn filepath.Join(b.opts.Root, resourceSubPath(key))","+}","+","+// resourceSubPath returns the namespaced on-disk/object-store path for a resource,","+// for example: default/dashboards.dashboard.grafana.app","+func resourceSubPath(key resource.NamespacedResource) string {","+\treturn filepath.Join(cleanFileSegment(key.Namespace), cleanFileSegment(fmt.Sprintf(\"%s.%s\", key.Resource, key.Group)))"," }"," "," func cleanFileSegment(input string) string {"],"additions":7,"deletions":1,"truncated":false},{"path":"pkg/storage/unified/search/bleve_snapshot_upload.go","lines":["@@ -0,0 +1,116 @@","+package search","+","+import (","+\t\"context\"","+\t\"errors\"","+\t\"fmt\"","+\t\"os\"","+\t\"path/filepath\"","+\t\"time\"","+","+\t\"github.com/blevesearch/bleve/v2\"","+","+\t\"github.com/grafana/grafana/pkg/storage/unified/resource\"","+)","+","+func (b *bleveBackend) uploadSnapshot(ctx context.Context, key resource.NamespacedResource, idx *bleveIndex) (retErr error) {","+\tlock, err := b.opts.Snapshot.Store.LockBuildIndex(ctx, key)","+\tif err != nil {","+\t\treturn fmt.Errorf(\"acquiring snapshot upload lock: %w\", err)","+\t}","+\tdefer func() {","+\t\treleaseErr := lock.Release()","+\t\tif releaseErr == nil {","+\t\t\treturn","+\t\t}","+\t\tif retErr == nil {","+\t\t\tretErr = fmt.Errorf(\"releasing snapshot upload lock: %w\", releaseErr)","+\t\t\treturn","+\t\t}","+\t\tretErr = errors.Join(retErr, fmt.Errorf(\"releasing snapshot upload lock: %w\", releaseErr))","+\t}()","+","+\tstagingDir, err := b.newSnapshotStagingDir(key)","+\tif err != nil {","+\t\treturn fmt.Errorf(\"creating snapshot staging dir: %w\", err)","+\t}","+\tdefer func() { _ = os.RemoveAll(stagingDir) }()","+","+\tstart := time.Now()","+\tif err := b.snapshotIndex(idx.index, stagingDir); err != nil {","+\t\treturn err","+\t}","+\t// Lock loss is checked only at step boundaries. The main value of the","+\t// distributed lock is preventing duplicate snapshot/upload work up front, and","+\t// the upload path is safe to retry because remote snapshots are immutable and","+\t// keyed by unique ULIDs.","+\tif err := checkSnapshotLock(lock); err != nil {","+\t\treturn err","+\t}","+","+\t// Read RV/build info from the staged snapshot instead of the live index so","+\t// the uploaded metadata matches the copied snapshot contents even if the live","+\t// index advanced while CopyTo was running.","+\tsnapshotIdx, err := bleve.OpenUsing(stagingDir, map[string]interface{}{\"bolt_timeout\": boltTimeout})","+\tif err != nil {","+\t\treturn fmt.Errorf(\"opening staged snapshot: %w\", err)","+\t}","+","+\trv, rvErr := getRV(snapshotIdx)","+\tbi, biErr := getBuildInfo(snapshotIdx)","+\tif closeErr := snapshotIdx.Close(); closeErr != nil {","+\t\treturn fmt.Errorf(\"closing staged snapshot: %w\", closeErr)","+\t}","+\tif rvErr != nil {","+\t\treturn fmt.Errorf(\"reading snapshot rv: %w\", rvErr)","+\t}","+\tif biErr != nil {","+\t\treturn fmt.Errorf(\"reading snapshot build info: %w\", biErr)","+\t}","+","+\t_, err = b.opts.Snapshot.Store.UploadIndex(ctx, key, stagingDir, IndexMeta{","+\t\tGrafanaBuildVersion:   bi.BuildVersion,","+\t\tLatestResourceVersion: rv,","+\t})","+\tif err != nil {","+\t\treturn fmt.Errorf(\"uploading snapshot: %w\", err)","+\t}","+\tif err := checkSnapshotLock(lock); err != nil {","+\t\treturn err","+\t}","+","+\telapsed := time.Since(start)","+\tb.log.Info(\"Uploaded remote index snapshot\", \"key\", key, \"elapsed\", elapsed, \"rv\", rv)","+\treturn nil","+}","+","+func (b *bleveBackend) snapshotIndex(idx bleve.Index, destDir string) error {","+\tcopyable, ok := idx.(bleve.IndexCopyable)","+\tif !ok {","+\t\treturn fmt.Errorf(\"index does not support snapshot copy\")","+\t}","+\tif err := copyable.CopyTo(bleve.FileSystemDirectory(destDir)); err != nil {","+\t\treturn fmt.Errorf(\"copying index snapshot: %w\", err)","+\t}","+\treturn nil","+}","+","+func (b *bleveBackend) newSnapshotStagingDir(key resource.NamespacedResource) (string, error) {","+\tparent := filepath.Join(b.opts.Root, \"snapshots\", resourceSubPath(key))","+\tif !isPathWithinRoot(parent, b.opts.Root) {","+\t\treturn \"\", fmt.Errorf(\"invalid path %s\", parent)","+\t}","+\tif err := os.MkdirAll(parent, 0o700); err != nil {","+\t\treturn \"\", err","+\t}","+\treturn os.MkdirTemp(parent, \"upload-*\")","+}","+","+func checkSnapshotLock(lock IndexStoreLock) error {","+\tselect {","+\tcase <-lock.Lost():","+\t\treturn fmt.Errorf(\"snapshot upload lock lost\")","+\tdefault:","+\t\treturn nil","+\t}","+}"],"additions":116,"deletions":0,"truncated":false},{"path":"pkg/storage/unified/search/bleve_snapshot_upload_test.go","lines":["@@ -0,0 +1,160 @@","+package search","+","+import (","+\t\"context\"","+\t\"errors\"","+\t\"io/fs\"","+\t\"os\"","+\t\"path/filepath\"","+\t\"sync/atomic\"","+\t\"testing\"","+\t\"time\"","+","+\t\"github.com/blevesearch/bleve/v2\"","+\t\"github.com/oklog/ulid/v2\"","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+","+\t\"github.com/grafana/grafana/pkg/storage/unified/resource\"","+)","+","+type uploadTestStore struct {","+\tlockErr error","+","+\tuploadErr   error","+\tuploadCalls atomic.Int32","+\tuploadMeta  IndexMeta","+\tuploaded    []string","+}","+","+func (s *uploadTestStore) LockBuildIndex(context.Context, resource.NamespacedResource) (IndexStoreLock, error) {","+\tif s.lockErr != nil {","+\t\treturn nil, s.lockErr","+\t}","+\treturn &noopIndexStoreLock{lost: make(chan struct{})}, nil","+}","+","+func (s *uploadTestStore) UploadIndex(_ context.Context, _ resource.NamespacedResource, localDir string, meta IndexMeta) (ulid.ULID, error) {","+\ts.uploadCalls.Add(1)","+\ts.uploadMeta = meta","+","+\terr := filepath.WalkDir(localDir, func(path string, d fs.DirEntry, err error) error {","+\t\tif err != nil {","+\t\t\treturn err","+\t\t}","+\t\tif d.IsDir() {","+\t\t\treturn nil","+\t\t}","+\t\trel, err := filepath.Rel(localDir, path)","+\t\tif err != nil {","+\t\t\treturn err","+\t\t}","+\t\ts.uploaded = append(s.uploaded, filepath.ToSlash(rel))","+\t\treturn nil","+\t})","+\tif err != nil {","+\t\treturn ulid.ULID{}, err","+\t}","+\tif s.uploadErr != nil {","+\t\treturn ulid.ULID{}, s.uploadErr","+\t}","+\treturn ulid.Make(), nil","+}","+","+func (s *uploadTestStore) DownloadIndex(context.Context, resource.NamespacedResource, ulid.ULID, string) (*IndexMeta, error) {","+\tpanic(\"DownloadIndex not implemented for uploadTestStore\")","+}","+","+func (s *uploadTestStore) ListIndexes(context.Context, resource.NamespacedResource) (map[ulid.ULID]*IndexMeta, error) {","+\tpanic(\"ListIndexes not implemented for uploadTestStore\")","+}","+","+func (s *uploadTestStore) DeleteIndex(context.Context, resource.NamespacedResource, ulid.ULID) error {","+\tpanic(\"DeleteIndex not implemented for uploadTestStore\")","+}","+","+func (s *uploadTestStore) CleanupIncompleteUploads(context.Context, resource.NamespacedResource, time.Duration) (int, error) {","+\tpanic(\"CleanupIncompleteUploads not implemented for uploadTestStore\")","+}","+","+func newUploadTestIndex(t *testing.T, be *bleveBackend, key resource.NamespacedResource, rv int64) *bleveIndex {","+\tt.Helper()","+\tresourceDir := be.getResourceDir(key)","+\trequire.NoError(t, os.MkdirAll(resourceDir, 0o750))","+","+\tidx, err := newBleveIndex(filepath.Join(resourceDir, formatIndexName(time.Now())), bleve.NewIndexMapping(), time.Now(), be.opts.BuildVersion, nil)","+\trequire.NoError(t, err)","+\tt.Cleanup(func() { _ = idx.Close() })","+","+\trequire.NoError(t, idx.Index(\"dash-1\", map[string]string{\"title\": \"Production Overview\"}))","+\trequire.NoError(t, setRV(idx, rv))","+","+\twrapped := be.newBleveIndex(key, idx, indexStorageFile, nil, nil, nil, nil, be.log)","+\twrapped.resourceVersion.Store(rv)","+\treturn wrapped","+}","+","+func TestSnapshotIndex_CreatesUsableCopy(t *testing.T) {","+\tbe, _ := newTestBleveBackend(t, SnapshotOptions{})","+\tkey := newTestNsResource()","+\tsrc := newUploadTestIndex(t, be, key, 42)","+","+\tdestDir := filepath.Join(t.TempDir(), \"snapshot\")","+\trequire.NoError(t, be.snapshotIndex(src.index, destDir))","+","+\tcopied, err := bleve.OpenUsing(destDir, map[string]interface{}{\"bolt_timeout\": boltTimeout})","+\trequire.NoError(t, err)","+\tdefer func() { _ = copied.Close() }()","+","+\trv, err := getRV(copied)","+\trequire.NoError(t, err)","+\tassert.Equal(t, int64(42), rv)","+","+\tcount, err := copied.DocCount()","+\trequire.NoError(t, err)","+\tassert.Equal(t, uint64(1), count)","+}","+","+func TestUploadSnapshot_Success(t *testing.T) {","+\tstore := &uploadTestStore{}","+\tbe, _ := newTestBleveBackend(t, SnapshotOptions{Store: store})","+\tkey := newTestNsResource()","+\tidx := newUploadTestIndex(t, be, key, 42)","+","+\trequire.NoError(t, be.uploadSnapshot(context.Background(), key, idx))","+\tassert.Equal(t, int32(1), store.uploadCalls.Load())","+\tassert.Equal(t, int64(42), store.uploadMeta.LatestResourceVersion)","+\tassert.Equal(t, be.opts.BuildVersion, store.uploadMeta.GrafanaBuildVersion)","+\tassert.NotEmpty(t, store.uploaded)","+","+\tsnapshotParent := filepath.Join(be.opts.Root, \"snapshots\", resourceSubPath(key))","+\tentries, err := os.ReadDir(snapshotParent)","+\trequire.NoError(t, err)","+\tassert.Empty(t, entries)","+}","+","+func TestUploadSnapshot_LockContention(t *testing.T) {","+\tstore := &uploadTestStore{lockErr: errLockHeld}","+\tbe, _ := newTestBleveBackend(t, SnapshotOptions{Store: store})","+\tkey := newTestNsResource()","+\tidx := newUploadTestIndex(t, be, key, 42)","+","+\terr := be.uploadSnapshot(context.Background(), key, idx)","+\trequire.ErrorIs(t, err, errLockHeld)","+\tassert.Zero(t, store.uploadCalls.Load())","+}","+","+func TestUploadSnapshot_UploadErrorCleansStagingDir(t *testing.T) {","+\tstore := &uploadTestStore{uploadErr: errors.New(\"boom\")}","+\tbe, _ := newTestBleveBackend(t, SnapshotOptions{Store: store})","+\tkey := newTestNsResource()","+\tidx := newUploadTestIndex(t, be, key, 42)","+","+\terr := be.uploadSnapshot(context.Background(), key, idx)","+\trequire.Error(t, err)","+","+\tsnapshotParent := filepath.Join(be.opts.Root, \"snapshots\", resourceSubPath(key))","+\tentries, readErr := os.ReadDir(snapshotParent)","+\trequire.NoError(t, readErr)","+\tassert.Empty(t, entries)","+}"],"additions":160,"deletions":0,"truncated":false},{"path":"pkg/storage/unified/search/remote_index_store.go","lines":["@@ -109,16 +109,16 @@ func NewBucketRemoteIndexStore(bucket resource.CDKBucket, lockBackend lockBacken"," "," // indexPrefix returns the object storage prefix for a namespaced resource + index key."," func indexPrefix(ns resource.NamespacedResource, indexKey string) string {","-\treturn fmt.Sprintf(\"%s/%s.%s/%s/\", ns.Namespace, ns.Group, ns.Resource, indexKey)","+\treturn fmt.Sprintf(\"%s/%s/\", resourceSubPath(ns), indexKey)"," }"," "," // nsPrefix returns the object storage prefix for a namespaced resource (without index key)."," func nsPrefix(ns resource.NamespacedResource) string {","-\treturn fmt.Sprintf(\"%s/%s.%s/\", ns.Namespace, ns.Group, ns.Resource)","+\treturn fmt.Sprintf(\"%s/\", resourceSubPath(ns))"," }"," "," func buildIndexLockKey(ns resource.NamespacedResource) string {","-\treturn fmt.Sprintf(\"%s/%s.%s/locks/build\", ns.Namespace, ns.Group, ns.Resource)","+\treturn fmt.Sprintf(\"%s/locks/build\", resourceSubPath(ns))"," }"," "," func (s *BucketRemoteIndexStore) LockBuildIndex(ctx context.Context, nsResource resource.Names