tions points at, if we generated it.","+","+    Only paths inside the conf output directory are removed, so an explicitly-configured","+    metricsFilePath elsewhere is never touched.","+    \"\"\"","+    try:","+        with open(conf_path, \"r\") as f:","+            conf = yaml.safe_load(f) or {}","+    except (OSError, yaml.YAMLError):","+        return","+    metrics_path = (conf.get(\"extensionOptions\") or {}).get(\"metricsFilePath\")","+    if not metrics_path:","+        return","+    if os.path.dirname(os.path.abspath(metrics_path)) != os.path.abspath(conf_out_dir):","+        return","+    try:","+        os.remove(metrics_path)","+        logger.info(\"Deleted extension metrics file %s\", metrics_path)","+    except FileNotFoundError:","+        pass","+    except OSError as e:","+        logger.warning(\"Failed to delete extension metrics file %s: %s\", metrics_path, e)","+","+"," def delete_extension_configs(extension_names: str, logger: logging.Logger):","-    \"\"\"Delete extension .conf files.\"\"\"","+    \"\"\"Delete extension .conf files and any generated metrics files they reference.\"\"\"","     conf_out_dir = get_conf_out_dir()","     extension_names = [item.strip() for item in extension_names.split(\",\")]","     for name in extension_names:","         file_name = f\"{name}.conf\"","         file_path = os.path.join(conf_out_dir, file_name)","+        _delete_generated_metrics_file(file_path, conf_out_dir, logger)","         try:","             os.remove(file_path)","             logger.info(\"Deleted extension configuration file %s\", file_path)"],"additions":31,"deletions":1,"truncated":false},{"path":"buildscripts/resmokelib/extensions/download_external_extensions.py","lines":["@@ -0,0 +1,123 @@","+\"\"\"Download externally-published extensions (see etc/extensions.yml) for resmoke runs.","+","+Mirrors src/mongo/db/extension/extensions/download_external_extension.py, the bazel-side","+downloader.","+\"\"\"","+","+import hashlib","+import io