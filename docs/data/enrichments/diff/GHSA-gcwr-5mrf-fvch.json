{"id":"GHSA-gcwr-5mrf-fvch","axis":"advisories","repo":"surrealdb/surrealdb","sha":"36f0a41a69b551172c7d1d13b1e8dbbd868e2ead","parsed":{"files":[{"path":"surrealdb/core/src/expr/statements/kill.rs","lines":["@@ -2,11 +2,13 @@ use anyhow::{Result, bail};"," use reblessive::tree::Stk;"," use surrealdb_types::ToSql;"," ","+use crate::catalog::SubscriptionDefinition;"," use crate::ctx::FrozenContext;"," use crate::dbs::Options;"," use crate::doc::CursorDoc;"," use crate::err::Error;"," use crate::expr::{Expr, FlowResultExt as _};","+use crate::iam::Error as IamError;"," use crate::types::{PublicAction, PublicNotification, PublicValue};"," use crate::val::{Uuid, Value};"," ","@@ -56,6 +58,43 @@ impl KillStatement {"," \t\t// Fetch the live query key if it exists"," \t\tmatch txn.get(&key, None).await? {"," \t\t\tSome(live) => {","+\t\t\t\t// Verify that the requesting user is the owner of this live query.","+\t\t\t\t// Root-level users may kill any live query; all other users may only","+\t\t\t\t// kill live queries they themselves created.","+\t\t\t\tif opt.auth_enabled && !opt.auth.is_root() {","+\t\t\t\t\tlet table_key = crate::key::table::lq::new(live.ns, live.db, &live.tb, lid);","+\t\t\t\t\tlet subscription: Option<SubscriptionDefinition> =","+\t\t\t\t\t\ttxn.get(&table_key, None).await?;","+\t\t\t\t\tif let Some(sub) = subscription {","+\t\t\t\t\t\t// For live queries created before auth tracking was introduced","+\t\t\t\t\t\t// (sub.auth is None), we have no ownership information and","+\t\t\t\t\t\t// cannot verify the caller is the original owner. Fail closed:","+\t\t\t\t\t\t// only root may kill legacy live queries without auth metadata.","+\t\t\t\t\t\t//","+\t\t\t\t\t\t// Compare only user identity (id + level), not the full Auth","+\t\t\t\t\t\t// snapshot. Roles are excluded so that a legitimate owner whose","+\t\t\t\t\t\t// roles were changed by an admin after the LIVE query was created","+\t\t\t\t\t\t// can still kill their own live query.","+\t\t\t\t\t\tlet is_owner = sub.auth.as_ref().is_some_and(|live_auth| {","+\t\t\t\t\t\t\tlive_auth.id() == opt.auth.id() && live_auth.level() == opt.auth.level()","+\t\t\t\t\t\t});","+\t\t\t\t\t\tif !is_owner {","+\t\t\t\t\t\t\tbail!(Error::IamError(IamError::NotAllowed {","+\t\t\t\t\t\t\t\tactor: opt.auth.id().to_string(),","+\t\t\t\t\t\t\t\taction: \"KILL\".to_string(),","+\t\t\t\t\t\t\t\tresource: lid.to_string(),","+\t\t\t\t\t\t\t}));","+\t\t\t\t\t\t}","+\t\t\t\t\t} else {","+\t\t\t\t\t\t// Deny when the subscription record is absent — fail closed","+\t\t\t\t\t\t// to prevent ownership bypass via a missing or corrupted entry.","+\t\t\t\t\t\tbail!(Error::IamError(IamError::NotAllowed {","+\t\t\t\t\t\t\tactor: opt.auth.id().to_string(),","+\t\t\t\t\t\t\taction: \"KILL\".to_string(),","+\t\t\t\t\t\t\tresource: lid.to_string(),","+\t\t\t\t\t\t}));","+\t\t\t\t\t}","+\t\t\t\t}"," \t\t\t\t// Delete the node live query"," \t\t\t\tlet key = crate::key::node::lq::new(nid, lid);"," \t\t\t\ttxn.clr(&key).await?;","@@ -90,3 +129,347 @@ impl KillStatement {"," \t\tOk(Value::None)"," \t}"," }","+","+#[cfg(test)]","+#[allow(clippy::unwrap_used)]","+mod tests {","+\tuse std::sync::Arc;","+","+\tuse anyhow::Result;","+\tuse surrealdb_types::vars;","+","+\tuse crate::catalog::providers::CatalogProvider;","+\tuse crate::channel::Receiver;","+\tuse crate::dbs::{Capabilities, Session};","+\tuse crate::iam::{Actor, Auth, Level, Role};","+\tuse crate::kvs::Datastore;","+\tuse crate::kvs::LockType::Optimistic;","+\tuse crate::kvs::TransactionType::Write;","+\tuse crate::types::{PublicNotification, PublicRecordId, PublicRecordIdKey, PublicValue};","+","+\tasync fn new_ds_with_auth() -> Result<(Receiver<PublicNotification>, Datastore)> {","+\t\tlet (send, recv) = crate::channel::bounded(1000);","+\t\tlet ds = Datastore::builder()","+\t\t\t.with_capabilities(Capabilities::all())","+\t\t\t.with_auth(true)","+\t\t\t.with_notify(send)","+\t\t\t.build_with_path(\"memory\")","+\t\t\t.await?;","+\t\tOk((recv, ds))","+\t}","+","+\tasync fn new_ds_no_auth() -> Result<(Receiver<PublicNotification>, Datastore)> {","+\t\tlet (send, recv) = crate::channel::bounded(1000);","+\t\tlet ds = Datastore::builder()","+\t\t\t.with_capabilities(Capabilities::all())","+\t\t\t.with_auth(false)","+\t\t\t.with_notify(send)","+\t\t\t.build_with_path(\"memory\")","+\t\t\t.await?;","+\t\tOk((recv, ds))","+\t}","+","+\t/// Build a database-level session with an explicit user `id` and `role`.","+\t///","+\t/// Unlike [`Session::for_level`], this gives each user a distinct identity","+\t/// so tests can verify that ownership is checked by user ID rather than","+\t/// just by role.","+\tfn db_session(ns: &str, db: &str, id: &str, role: Role) -> Session {","+\t\tlet auth =","+\t\t\tAuth::new(Actor::new(id.into(), vec![role], Level::Database(ns.into(), db.into())));","+\t\tSession {","+\t\t\tau: Arc::new(auth),","+\t\t\tns: Some(ns.to_string()),","+\t\t\tdb: Some(db.to_string()),","+\t\t\trt: true,","+\t\t\t..Default::default()","+\t\t}","+\t}","+","+\tasync fn setup_table(ds: &Datastore, ns: &str, db: &str, tb: &str) {","+\t\tlet tx = ds.transaction(Write, Optimistic).await.unwrap();","+\t\ttx.ensure_ns_db(None, ns, db).await.unwrap();","+\t\ttx.commit().await.unwrap();","+\t\tlet ses = Session::owner().with_ns(ns).with_db(db);","+\t\tds.execute(&format!(\"DEFINE TABLE {tb}\"), &ses, None).await.unwrap();","+\t}","+","+\tasync fn start_live_query(ds: &Datastore, ses: &Session, tb: &str) -> PublicValue {","+\t\tlet stmt = format!(\"LIVE SELECT * FROM {tb}\");","+\t\tlet mut res = ds.execute(&stmt, ses, None).await.unwrap();","+\t\tres.remove(0).result.unwrap()","+\t}","+","+\tasync fn kill_live_query(","+\t\tds: &Datastore,","+\t\tses: &Session,","+\t\tlid: &PublicValue,","+\t) -> anyhow::Result<()> {","+\t\tlet mut res = ds.execute(\"KILL $uuid\", ses, Some(vars!(\"uuid\": lid.clone()))).await?;","+\t\tres.remove(0).result.map_err(anyhow::Error::from)?;","+\t\tOk(())","+\t}","+","+\t/// A user who created a live query can kill it.","+\t#[tokio::test]","+\tasync fn test_kill_own_live_query_succeeds() {","+\t\tlet (_, ds) = new_ds_with_auth().await.unwrap();","+\t\tlet (ns, db, tb) = (\"test\", \"test\", \"person\");","+\t\tsetup_table(&ds, ns, db, tb).await;","+","+\t\tlet ses = Session::for_level(Level::Database(ns.to_string(), db.to_string()), Role::Owner)","+\t\t\t.with_rt(true);","+","+\t\tlet lid = start_live_query(&ds, &ses, tb).await;","+\t\tkill_live_query(&ds, &ses, &lid)","+\t\t\t.await","+\t\t\t.expect(\"owner should be able to kill their own live query\");","+\t}","+","+\t/// A user can kill their own live query even if their roles changed after the LIVE","+\t/// query was created.  This covers the case where an admin runs `DEFINE USER ... ROLES`","+\t/// between the LIVE and the KILL: the stored auth snapshot has the old roles, but","+\t/// the current session carries the new roles.  Only identity (id + level) is","+\t/// compared, so the role difference must not block the owner.","+\t#[tokio::test]","+\tasync fn test_kill_own_live_query_after_role_change_succeeds() {","+\t\tlet (_, ds) = new_ds_with_auth().await.unwrap();","+\t\tlet (ns, db, tb) = (\"test\", \"test\", \"person\");","+\t\tsetup_table(&ds, ns, db, tb).await;","+","+\t\tlet alice_owner = db_session(ns, db, \"alice\", Role::Owner);","+\t\tlet lid = start_live_query(&ds, &alice_owner, tb).await;","+","+\t\t// Simulate an admin changing alice's role from Owner → Editor.","+\t\tlet alice_editor = db_session(ns, db, \"alice\", Role::Editor);","+\t\tkill_live_query(&ds, &alice_editor, &lid)","+\t\t\t.await","+\t\t\t.expect(\"user should be able to kill their own live query even after a role change\");","+\t}","+","+\t/// A database-level user cannot kill a live query created by a different database user.","+\t///","+\t/// Both users have the *same* role here to ensure the check is driven by identity","+\t/// (user ID + level), not by role difference.  Previously `Session::for_level`","+\t/// hard-coded `id = \"system_auth\"` for all system sessions, making the two users","+\t/// indistinguishable by identity.  We use `db_session` to give each user a","+\t/// distinct ID so the test genuinely exercises identity-based ownership.","+\t#[tokio::test]","+\tasync fn test_kill_other_db_users_live_query_fails() {","+\t\tlet (_, ds) = new_ds_with_auth().await.unwrap();","+\t\tlet (ns, db, tb) = (\"test\", \"test\", \"person\");","+\t\tsetup_table(&ds, ns, db, tb).await;","+","+\t\tlet alice_ses = db_session(ns, db, \"alice\", Role::Owner);","+\t\tlet bob_ses = db_session(ns, db, \"bob\", Role::Owner);","+","+\t\tlet lid = start_live_query(&ds, &alice_ses, tb).await;","+\t\tassert!(","+\t\t\tkill_live_query(&ds, &bob_ses, &lid).await.is_err(),","+\t\t\t\"a different db user should not be able to kill another user's live query\"","+\t\t);","+\t}","+","+\t/// A record user cannot kill a root user's live query.","+\t#[tokio::test]","+\tasync fn test_record_user_cannot_kill_root_live_query() {","+\t\tlet (_, ds) = new_ds_with_auth().await.unwrap();","+\t\tlet (ns, db, tb, ac) = (\"test\", \"test\", \"person\", \"user\");","+\t\tsetup_table(&ds, ns, db, tb).await;","+","+\t\tlet root_ses = Session::owner().with_ns(ns).with_db(db).with_rt(true);","+\t\tlet record_ses = Session::for_record(","+\t\t\tns,","+\t\t\tdb,","+\t\t\tac,","+\t\t\tPublicValue::RecordId(PublicRecordId {","+\t\t\t\ttable: \"person\".to_string().into(),","+\t\t\t\tkey: PublicRecordIdKey::String(\"alice\".to_string()),","+\t\t\t}),","+\t\t)","+\t\t.with_rt(true);","+","+\t\tlet lid = start_live_query(&ds, &root_ses, tb).await;","+\t\tassert!(","+\t\t\tkill_live_query(&ds, &record_ses, &lid).await.is_err(),","+\t\t\t\"a record user should not be able to kill a root user's live query\"","+\t\t);","+\t}","+","+\t/// A root user can kill any user's live query.","+\t#[tokio::test]","+\tasync fn test_root_can_kill_any_live_query() {","+\t\tlet (_, ds) = new_ds_with_auth().await.unwrap();","+\t\tlet (ns, db, tb, ac) = (\"test\", \"test\", \"person\", \"user\");","+\t\tsetup_table(&ds, ns, db, tb).await;","+","+\t\tlet record_ses = Session::for_record(","+\t\t\tns,","+\t\t\tdb,","+\t\t\tac,","+\t\t\tPublicValue::RecordId(PublicRecordId {","+\t\t\t\ttable: \"person\".to_string().into(),","+\t\t\t\tkey: PublicRecordIdKey::String(\"alice\".to_string()),","+\t\t\t}),","+\t\t)","+\t\t.with_rt(true);","+\t\tlet root_ses = Session::owner().with_ns(ns).with_db(db).with_rt(true);","+","+\t\tlet lid = start_live_query(&ds, &record_ses, tb).await;","+\t\tkill_live_query(&ds, &root_ses, &lid)","+\t\t\t.await","+\t\t\t.expect(\"a root user should be able to kill any live query\");","+\t}","+","+\t/// When authentication is disabled, any user can kill any live query (backwards compat).","+\t///","+\t/// Use `db_session` with distinct IDs (alice/bob) so the two sessions are genuinely","+\t/// different identities.  With the identity-based ownership check in place, if a","+\t/// regression caused auth-disabled sessions to enter the ownership block, `is_owner`","+\t/// would return `false` (alice ≠ bob) and the test would correctly fail.  Using","+\t/// `Session::for_level` for both would give them the same `id=\"system_auth\"`, making","+\t/// `is_owner` true and masking the regression.","+\t#[tokio::test]","+\tasync fn test_kill_any_live_query_when_auth_disabled() {","+\t\tlet (_, ds) = new_ds_no_auth().await.unwrap();","+\t\tlet (ns, db, tb) = (\"test\", \"test\", \"person\");","+\t\tsetup_table(&ds, ns, db, tb).await;","+","+\t\tlet ses_a = db_session(ns, db, \"alice\", Role::Owner);","+\t\tlet ses_b = db_session(ns, db, \"bob\", Role::Editor);","+","+\t\tlet lid = start_live_query(&ds, &ses_a, tb).await;","+\t\tkill_live_query(&ds, &ses_b, &lid)","+\t\t\t.await","+\t\t\t.expect(\"with auth disabled, any user should be able to kill any live query\");","+\t}","+","+\t/// A non-root user cannot kill a live query whose subscription record has auth: None","+\t/// (legacy queries created before auth tracking was introduced, e.g. v3.0.0 and betas).","+\t/// Without ownership metadata we cannot verify the caller is the creator, so we fail closed.","+\t#[tokio::test]","+\tasync fn test_kill_legacy_live_query_auth_none_fails_for_non_root() {","+\t\tlet (_, ds) = new_ds_with_auth().await.unwrap();","+\t\tlet (ns, db, tb) = (\"test\", \"test\", \"person\");","+\t\tsetup_table(&ds, ns, db, tb).await;","+","+\t\tlet ses = Session::for_level(Level::Database(ns.to_string(), db.to_string()), Role::Owner)","+\t\t\t.with_rt(true);","+","+\t\tlet lid = start_live_query(&ds, &ses, tb).await;","+\t\tlet live_uuid = match &lid {","+\t\t\tPublicValue::Uuid(u) => (*u).into_inner(),","+\t\t\t_ => panic!(\"expected uuid\"),","+\t\t};","+","+\t\t// Simulate a legacy live query by clearing auth on the stored SubscriptionDefinition.","+\t\t{","+\t\t\tlet txn = ds.transaction(Write, Optimistic).await.unwrap();","+\t\t\tlet db_def = txn.ensure_ns_db(None, ns, db).await.unwrap();","+\t\t\tlet tb_name = crate::val::TableName::from(tb);","+\t\t\tlet key = crate::key::table::lq::new(","+\t\t\t\tdb_def.namespace_id,","+\t\t\t\tdb_def.database_id,","+\t\t\t\t&tb_name,","+\t\t\t\tlive_uuid,","+\t\t\t);","+\t\t\tlet mut sub: crate::catalog::SubscriptionDefinition =","+\t\t\t\ttxn.get(&key, None).await.unwrap().expect(\"subscription must exist\");","+\t\t\tsub.auth = None;","+\t\t\ttxn.set(&key, &sub).await.unwrap();","+\t\t\ttxn.commit().await.unwrap();","+\t\t}","+","+\t\tassert!(","+\t\t\tkill_live_query(&ds, &ses, &lid).await.is_err(),","+\t\t\t\"non-root user should not be able to kill a legacy live query with auth: None (fail closed)\"","+\t\t);","+\t}","+","+\t/// Root can kill a live query whose subscription record has auth: None (legacy queries).","+\t/// Root bypasses ownership checks entirely.","+\t#[tokio::test]","+\tasync fn test_root_can_kill_legacy_live_query_auth_none() {","+\t\tlet (_, ds) = new_ds_with_auth().await.unwrap();","+\t\tlet (ns, db, tb) = (\"test\", \"test\", \"person\");","+\t\tsetup_table(&ds, ns, db, tb).await;","+","+\t\tlet db_ses =","+\t\t\tSession::for_level(Level::Database(ns.to_string(), db.to_string()), Role::Owner)","+\t\t\t\t.with_rt(true);","+\t\tlet root_ses = Session::owner().with_ns(ns).with_db(db).with_rt(true);","+","+\t\tlet lid = start_live_query(&ds, &db_ses, tb).await;","+\t\tlet live_uuid = match &lid {","+\t\t\tPublicValue::Uuid(u) => (*u).into_inner(),","+\t\t\t_ => panic!(\"expected uuid\"),","+\t\t};","+","+\t\t// Simulate a legacy live query by clearing auth on the stored SubscriptionDefinition.","+\t\t{","+\t\t\tlet txn = ds.transaction(Write, Optimistic).await.unwrap();","+\t\t\tlet db_def = txn.ensure_ns_db(None, ns, db).await.unwrap();","+\t\t\tlet tb_name = crate::val::TableName::from(tb);","+\t\t\tlet key = crate::key::table::lq::new(","+\t\t\t\tdb_def.namespace_id,","+\t\t\t\tdb_def.database_id,","+\t\t\t\t&tb_name,","+\t\t\t\tlive_uuid,","+\t\t\t);","+\t\t\tlet mut sub: crate::catalog::SubscriptionDefinition =","+\t\t\t\ttxn.get(&key, None).await.unwrap().expect(\"subscription must exist\");","+\t\t\tsub.auth = None;","+\t\t\ttxn.set(&key, &sub).await.unwrap();","+\t\t\ttxn.commit().await.unwrap();","+\t\t}","+","+\t\tkill_live_query(&ds, &root_ses, &lid)","+\t\t\t.await","+\t\t\t.expect(\"root should be able to kill a legacy live query with auth: None\");","+\t}","+","+\t/// When the table-level subscription record is missing, KILL must fail closed for","+\t/// non-root users rather than silently skipping the ownership check.","+\t///","+\t/// Use `db_session` with distinct IDs (alice/bob) for consistency with the rest of","+\t/// the ownership-related tests in this module.  The `else` branch is an unconditional","+\t/// `bail!` that ignores caller identity, so production behaviour is not affected, but","+\t/// using genuinely distinct principals future-proofs the test against any weakening","+\t/// of that branch.","+\t#[tokio::test]","+\tasync fn test_kill_without_subscription_record_fails_closed() {","+\t\tlet (_, ds) = new_ds_with_auth().await.unwrap();","+\t\tlet (ns, db, tb) = (\"test\", \"test\", \"person\");","+\t\tsetup_table(&ds, ns, db, tb).await;","+","+\t\tlet owner_ses = db_session(ns, db, \"alice\", Role::Owner);","+\t\tlet other_ses = db_session(ns, db, \"bob\", Role::Editor);","+","+\t\tlet lid = start_live_query(&ds, &owner_ses, tb).await;","+\t\tlet live_uuid = match &lid {","+\t\t\tPublicValue::Uuid(u) => (*u).into_inner(),","+\t\t\t_ => panic!(\"expected uuid\"),","+\t\t};","+","+\t\t// Delete the table-level subscription record to simulate data corruption or a","+\t\t// concurrent cleanup race, then verify that KILL is denied for a non-root user.","+\t\t{","+\t\t\tlet txn = ds.transaction(Write, Optimistic).await.unwrap();","+\t\t\tlet db_def = txn.ensure_ns_db(None, ns, db).await.unwrap();","+\t\t\tlet tb_name = crate::val::TableName::from(tb);","+\t\t\tlet key = crate::key::table::lq::new(","+\t\t\t\tdb_def.namespace_id,","+\t\t\t\tdb_def.database_id,","+\t\t\t\t&tb_name,","+\t\t\t\tlive_uuid,","+\t\t\t);","+\t\t\ttxn.clr(&key).await.unwrap();","+\t\t\ttxn.commit().await.unwrap();","+\t\t}","+","+\t\tassert!(","+\t\t\tkill_live_query(&ds, &other_ses, &lid).await.is_err(),","+\t\t\t\"KILL should fail closed when the subscription record is absent\"","+\t\t);","+\t}","+}",""],"additions":383,"deletions":0,"truncated":false}],"additions":383,"deletions":0,"truncated":false,"file_count":1},"error":null,"fetched_at":"2026-07-02T10:21:00.873717+00:00"}