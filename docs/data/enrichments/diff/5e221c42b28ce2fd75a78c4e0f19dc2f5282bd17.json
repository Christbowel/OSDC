moModel';","+","+/**","+ * Watches for models with active promotions and shows a one-time","+ * chat input notification the first time a promo appears. Dismissals","+ * are persisted by promo id so the same promo is never shown again.","+ */","+export class ChatPromoNotificationContribution extends Disposable implements IWorkbenchContribution {","+","+\tstatic readonly ID = 'workbench.contrib.chatPromoNotification';","+","+\tconstructor(","+\t\t@ILanguageModelsService private readonly _languageModelsService: ILanguageModelsService,","+\t\t@IChatInputNotificationService private readonly _chatInputNotificationService: IChatInputNotificationService,","+\t\t@IStorageService private readonly _storageService: IStorageService,","+\t) {","+\t\tsuper();","+","+\t\tthis._register(CommandsRegistry.registerCommand(USE_PROMO_MODEL_COMMAND_ID, (accessor: ServicesAccessor, modelId: string) => {","+\t\t\tconst chatWidgetService = accessor.get(IChatWidgetService);","+\t\t\tconst widget = chatWidgetService.lastFocusedWidget;","+\t\t\tif (widget) {","+\t\t\t\twidget.input.switchModelByIdentifier(modelId);","+\t\t\t}","+\t\t\tthis._chatInputNotificationService.dismissNotification(PROMO_NOTIFICATION_ID);","+\t\t\tthis._persistDismissedPromo();","+\t\t}));","+","+\t\tthis._register(this._languageModelsService.onDidChangeLanguageModels(() => this._update()));","+\t\tthis._register(this._chatInputNotificationService.onDidDismiss(id => {","+\t\t\tif (id === PROMO_NOTIFICATION_ID) {","+\t\t\t\tthis._persistDismissedPromo();","+\t\t\t}","+\t\t}));","+\t\tthis._update();","+\t}","+","+\tprivate _currentPromoId: string | undefined;","+","+\tprivate _update(): void {","+\t\tconst dismissed = this._getDismissedPromoIds();","+\t\tconst modelIds = this._languageModelsService.getLanguageModelIds();","+","+\t\t// Find the first model with a promo that hasn't been dismissed","+\t\tlet promoMetadata: ILanguageModelChatMetadata | undefined;","+\t\tlet promoIdentifier: string | undefined;","+\t\tfor (const id of modelIds) {","+\t\t\tconst meta = this._languageModelsService.lookupLanguageModel(id);","+\t\t\tif (meta?.promo && !dismissed.has(meta.promo.id)) {","+\t\t\t\tpromoMetadata = meta;","+\t\t\t\tpromoIdentifier = id;","+\t\t\t\tbreak;","+\t\t\t}","+\t\t}","+","+\t\tif (!promoMetadata?.promo || !promoIdentifier) {","+\t\t\tif (this._currentPromoId) {","+\t\t\t\tthis._chatInputNotificationService.deleteNotification(PROMO_NOTIFICATION_ID);","+\t\t\t\tthis._currentPromoId = undefined;","+\t\t\t}","+\t\t\treturn;","+\t\t}","+","+\t\t// Don't re-show the same promo notification","+\t\tif (this._currentPromoId === promoMetadata.promo.id) {","+\t\t\treturn;","+\t\t}","+","+\t\tthis._currentPromoId = promoMetadata.promo.id;","+\t\tconst endsAtDate = new Date(promoMetadata.promo.endsAt);","+\t\tconst formattedDate = endsAtDate.toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' });","+","+\t\tthis._chatInputNotificationService.setNotification({","+\t\t\tid: PROMO_NOTIFICATION_ID,","+\t\t\tseverity: ChatInputNotificationSeverity.Info,","+\t\t\tmessage: promoMetadata.promo.message,","+\t\t\tdescription: localize('chat.promo.endsAt', \"Ends {0}.\", formattedDate),","+\t\t\tactions: [{","+\t\t\t\tlabel: localize('chat.promo.useModel', \"Use {0}\", promoMetadata.name),","+\t\t\t\tcommandId: USE_PROMO_MODEL_COMMAND_ID,","+\t\t\t\tcommandArgs: [promoIdentifier],","+\t\t\t}],","+\t\t\tdismissible: true,","+\t\t\tautoDismissOnMessage: false,","+\t\t});","+\t}","+","+\tprivate _persistDismissedPromo(): void {","+\t\tif (!this._currentPromoId) {","+\t\t\treturn;","+\t\t}","+\t\tconst dismissed = this._getDismissedPromoIds();","+\t\tdismissed.add(this._currentPromoId);","+\t\tthis._storageService.store(","+\t\t\tDISMISSED_PROMOS_STORAGE_KEY,","+\t\t\tJSON.stringify([...dismissed]),","+\t\t\tStorageScope.APPLICATION,","+\t\t\tStorageTarget.USER,","+\t\t);","+\t\tthis._currentPromoId = undefined;","+\t}","+","+\tprivate _getDismissedPromoIds(): Set<string> {","+\t\tconst raw = this._storageService.get(DISMISSED_PROMOS_STORAGE_KEY, StorageScope.APPLICATION);","+\t\tif (!raw) {","+\t\t\treturn new Set();","+\t\t}","+\t\ttry {","+\t\t\tconst parsed = JSON.parse(raw);","+\t\t\tif (Array.isArray(parsed)) {","+\t\t\t\treturn new Set(parsed.filter((v): v is string => typeof v === 'string'));","+\t\t\t}","+\t\t} catch {","+\t\t\t// ignore malformed data","+\t\t}","+\t\treturn new Set();","+\t}","+}"],"additions":135,"deletions":0,"truncated":false},{"path":"src/vs/workbench/contrib/chat/browser/chatSessions/chatSessionPickerActionItem.ts","lines":["@@ -184,6 +184,7 @@ export class ChatSessionPickerActionItem extends ActionWidgetDropdownActionViewI"," \t\t\t\t\tlongContextCacheCost: optionItem.modelMetadata.longContextCacheCost,"," \t\t\t\t\tlongContextCacheWriteCost: optionItem.modelMetadata.longContextCacheWriteCost,"," \t\t\t\t\tpriceCategory: optionItem.modelMetadata.priceCategory,","+\t\t\t\t\tpromo: optionItem.modelMetadata.promo,"," \t\t\t\t\tmaxInputTokens: optionItem.modelMetadata.maxInputTokens ?? 0,"," \t\t\t\t\tmaxOutputTokens: optionItem.modelMetadata.maxOutputTokens ?? 0,"," \t\t\t\t\tcapabilities: optionItem.modelMetadata.capabilities ? {"],"additions":1,"deletions":0,"truncated":false},{"path":"src/vs/workbench/contrib/chat/browser/widget/input/chatModelPicker.ts","lines":["@@ -393,7 +393,8 @@ function createModelAction("," \t// Strip the detail when suppressVendorInDetail is set — the vendor is"," \t// shown either inline (promoted) or in a section header (Other Models)."," \tconst detail = suppressVendorInDetail ? undefined : model.metadata.detail;","-\tconst textParts = [detail, pricingForDescription].filter(Boolean);","+\tconst promoDetail = model.metadata.promo ? localize('chat.promo.discount', \"{0}% discount\", model.metadata.promo.discountPercent) : undefined;","+\tconst textParts = [detail, promoDetail, pricingForDescription].filter(Boolean);"," \tconst textDescription = textParts.length > 0 ? textPart