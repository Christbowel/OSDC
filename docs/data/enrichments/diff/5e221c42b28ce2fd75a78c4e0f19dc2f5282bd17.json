alse;","+\t\t\tonDidChange.fire();","+\t\t},","+\t\tdeleteNotification(id: string) {","+\t\t\tif (lastNotification?.id === id && !deleted) {","+\t\t\t\tdeleted = true;","+\t\t\t\tdismissed = false;","+\t\t\t\tonDidChange.fire();","+\t\t\t}","+\t\t},","+\t\tdismissNotification(id: string) {","+\t\t\tif (!lastNotification || lastNotification.id !== id || deleted || dismissed) {","+\t\t\t\treturn;","+\t\t\t}","+\t\t\tdismissed = true;","+\t\t\tonDidDismiss.fire(id);","+\t\t\tonDidChange.fire();","+\t\t},","+\t\tgetActiveNotification() { return deleted || dismissed ? undefined : lastNotification; },","+\t\thandleMessageSent() { },","+\t};","+","+\treturn {","+\t\tservice,","+\t\tonDidDismiss,","+\t\tgetNotification(): IChatInputNotification | undefined { return deleted || dismissed ? undefined : lastNotification; },","+\t\tdismiss(id?: string) {","+\t\t\tconst notificationId = id ?? lastNotification?.id;","+\t\t\tif (notificationId) {","+\t\t\t\tservice.dismissNotification(notificationId);","+\t\t\t}","+\t\t},","+\t};","+}","+","+function createMockLanguageModelsService(models: { identifier: string; metadata: Partial<ILanguageModelChatMetadata> }[], disposables: Pick<DisposableStore, 'add'>) {","+\tconst onDidChangeLanguageModels = disposables.add(new Emitter<string | undefined>());","+\tconst service = {","+\t\t_serviceBrand: undefined,","+\t\tonDidChangeLanguageModels: onDidChangeLanguageModels.event,","+\t\tgetLanguageModelIds() { return models.map(m => m.identifier); },","+\t\tlookupLanguageModel(id: string) {","+\t\t\tconst match = models.find(m => m.identifier === id);","+\t\t\treturn match?.metadata as ILanguageModelChatMetadata | undefined;","+\t\t},","+\t} as unknown as ILanguageModelsService;","+","+\treturn { service, onDidChangeLanguageModels };","+}","+","+suite('ChatPromoNotificationContribution', () => {","+","+\tconst disposables = ensureNoDisposablesAreLeakedInTestSuite();","+","+\ttest('shows notification for model with promo', () => {","+\t\tconst notifService = createMockNotificationService(disposables);","+\t\tconst { service: lmService } = createMockLanguageModelsService([{","+\t\t\tidentifier: 'copilot:gpt-5.5',","+\t\t\tmetadata: { name: 'GPT-5.5', id: 'gpt-5.5', promo: { id: 'promo-1', discountPercent: 20, endsAt: '2026-07-20T23:59:59Z', message: 'Get 20% off' } },","+\t\t}], disposables);","+\t\tconst storageService = disposables.add(new InMemoryStorageService());","+","+\t\tconst contribution = disposables.add(new ChatPromoNotificationContribution(","+\t\t\tlmService,","+\t\t\tnotifService.service,","+\t\t\tstorageService,","+\t\t));","+\t\tassert.ok(contribution);","+","+\t\tconst notification = notifService.getNotification();","+\t\tassert.ok(notification, 'Expected a notification to be shown');","+\t\tassert.ok(notification.message.toString().includes('20% off'));","+\t\tassert.strictEqual(notification.actions.length, 1);","+\t\tassert.ok(notification.actions[0].label.includes('GPT-5.5'));","+\t});","+","+\ttest('does not show notification for already-dismissed promo', () => {","+\t\tconst notifService = createMockNotificationService(disposables);","+\t\tconst { service: lmService } = createMockLanguageModelsService([{","+\t\t\tidentifier: 'copilot:gpt-5.5',","+\t\t\tmetadata: { name: 'GPT-5.5', id: 'gpt-5.5', promo: { id: 'promo-1', discountPercent: 20, endsAt: '2026-07-20T23:59:59Z', message: 'Get 20% off' } },","+\t\t}], disposables);","+\t\tconst storageService = disposables.add(new InMemoryStorageService());","+\t\t// Pre-seed dismissed promo","+\t\tstorageService.store('chat.dismissedPromoIds', JSON.stringify(['promo-1']), StorageScope.APPLICATION, 0 /* StorageTarget.USER */);","+","+\t\tconst contribution = disposables.add(new ChatPromoNotificationContribution(","+\t\t\tlmService,","+\t\t\tnotifService.service,","+\t\t\tstorageService,","+\t\t));","+\t\tassert.ok(contribution);","+","+\t\tconst notification = notifService.getNotification();","+\t\tassert.strictEqual(notification, undefined, 'Sh