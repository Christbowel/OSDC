p interface target (libnccl_ep.so + headers). It is","+# NOT added to Caffe2_CUDA_DEPENDENCY_LIBS: the EP code lives in its own optional","+# extension (torch._nccl_ep, see torch/CMakeLists.txt), which links it, so","+# libtorch_cuda does not depend on libnccl_ep and torch imports without nccl4py."," if(USE_NCCL_EP)","   message(STATUS \"USE_NCCL_EP is ON\")","   include(${CMAKE_CURRENT_LIST_DIR}/External/nccl_ep.cmake)","-  list(APPEND Caffe2_CUDA_DEPENDENCY_LIBS __caffe2_nccl_ep)"," endif()"," "," # ---[ XCCL"],"additions":4,"deletions":6,"truncated":false},{"path":"cmake/External/nccl_ep.cmake","lines":["@@ -45,10 +45,19 @@ if(NOT __NCCL_EP_INCLUDED)","       -DCMAKE_BUILD_TYPE=${CMAKE_BUILD_TYPE}","       -DCMAKE_CXX_COMPILER=${CMAKE_CXX_COMPILER}","       -DCMAKE_CUDA_COMPILER=${CMAKE_CUDA_COMPILER}","+      # Link the CUDA runtime dynamically (CMake defaults to static). The static","+      # cudart does not support CUDA minor-version (enhanced) compatibility, so a","+      # static-cudart libnccl_ep cannot run on a minor-older driver; the shared","+      # libcudart does, matching how libtorch_cuda links it.","+      -DCMAKE_CUDA_RUNTIME_LIBRARY=Shared","       ${__NCCL_EP_ARCH_ARG}","       -DNCCL_HOME=${__NCCL_BUILD_DIR}","       -DNCCL_EP_BUILDDIR=${__NCCL_BUILD_DIR}","       -DNCCL_EP_SOURCE_DIR=${PROJECT_SOURCE_DIR}/third_party/nccl/contrib/nccl_ep","+    # Build the static lib; the _nccl_ep extension statically links it, so its","+    # ncclEp* symbols are embedded in the extension and its nccl* references","+    # resolve against torch_cuda's own (statically-linked) NCCL. No runtime","+    # libnccl_ep.so and no nccl4py dependency.","     BUILD_BYPRODUCTS \"${__NCCL_BUILD_DIR}/lib/libnccl_ep.a\"","     INSTALL_COMMAND \"\"","     # NCCL (Makefile) must finish first: nccl_ep links -lnccl and includes its headers.","@@ -57,12 +66,16 @@ if(NOT __NCCL_EP_INCLUDED)"," ","   set(NCCL_EP_LIBRARIES \"${__NCCL_BUILD_DIR}/lib/libnccl_ep.a\")","   set(NCCL_EP_INCL