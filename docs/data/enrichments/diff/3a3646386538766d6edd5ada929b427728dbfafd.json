ented as host-prefix CIDRs (/32 for IPv4, /128 for","+\t// IPv6) and delegated prefixes as /28 CIDRs for IPv4 and /80 CIDRs for IPv6.","+\tFromResource: func(node *ciliumv2.CiliumNode) ipamTypes.IPAMPoolSpec {","+\t\tpools := ipamTypes.IPAMPoolSpec{","+\t\t\tRequested: node.Spec.IPAM.Pools.Requested,","+\t\t\tAllocated: node.Spec.IPAM.Pools.Allocated,","+\t\t}","+","+\t\tif len(node.Status.ENI.ENIs) == 0 {","+\t\t\treturn pools","+\t\t}","+","+\t\tvar cidrs []iputil.Prefix","+\t\tfor _, eni := range node.Status.ENI.ENIs {","+\t\t\tif eni.IsExcludedBySpec(node.Spec.ENI) {","+\t\t\t\tcontinue","+\t\t\t}"," ","-\tvar cidrs []iputil.Prefix","-\tfor _, eni := range node.Status.ENI.ENIs {","-\t\tif eni.IsExcludedBySpec(node.Spec.ENI) {","-\t\t\tcontinue","-\t\t}","+\t\t\tvar prefixes []netip.Prefix","+\t\t\tfor _, p := range eni.Prefixes {","+\t\t\t\tcidrs = append(cidrs, p)","+\t\t\t\tif p.IsValid() {","+\t\t\t\t\tprefixes = append(prefixes, p.Prefix)","+\t\t\t\t}","+\t\t\t}"," ","-\t\tvar prefixes []netip.Prefix","-\t\tfor _, p := range eni.Prefixes {","-\t\t\tcidrs = append(cidrs, p)","-\t\t\tif p.IsValid() {","-\t\t\t\tprefixes = append(prefixes, p.Prefix)","+\t\t\t// In parseENI (pkg/aws/api), we currently use PrefixToIps to flatten each prefixes","+\t\t\t// into 16 individual IPs and append those IPs to the ENI Addresses field.","+\t\t\t// Here we need to apply a reverse logic to only advertise as /32 CIDRs in the pool","+\t\t\t// regular secondary addresses (or the ENI primary IP when using UsePrimaryAddress)","+\t\t\t// and not addresses that are already being advertised through a /28 CIDR.","+\t\t\tfor _, addr := range eni.Addresses {","+\t\t\t\tif !addr.IsValid() {","+\t\t\t\t\tcontinue","+\t\t\t\t}","+\t\t\t\tif addressCoveredByPrefix(addr.Addr, prefixes) {","+\t\t\t\t\tcontinue","+\t\t\t\t}","+\t\t\t\tcidrs = append(cidrs, iputil.PrefixFrom(netip.PrefixFrom(addr.Addr, addr.BitLen())))"," \t\t\t}"," \t\t}"," ","-\t\t// In parseENI (pkg/aws/api), we currently us