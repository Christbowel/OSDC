rg.hibernate.testing.orm.junit.SessionFactory;","+import org.hibernate.testing.orm.junit.SessionFactoryScope;","+import org.hibernate.testing.orm.junit.Setting;","+import org.junit.jupiter.api.Test;","+","+import static org.assertj.core.api.Assertions.assertThat;","+import static org.assertj.core.api.Assertions.assertThatThrownBy;","+","+/**","+ * Tests for JPA 4.0 bean validation lifecycle event separation:","+ * EM-level (persist, merge, remove) vs DB-level (stateless) (insert, update, upsert, delete).","+ */","+class BeanValidationNewLifecycleTest {","+","+\tpublic interface PersistGroup {}","+\tpublic interface InsertGroup {}","+\tpublic interface RemoveGroup {}","+\tpublic interface DeleteGroup {}","+","+\t@Entity(name = \"DualValidatedItem\")","+\tpublic static class DualValidatedItem {","+\t\t@Id","+\t\t@GeneratedValue","+\t\tprivate Integer id;","+","+\t\t@NotNull(groups = PersistGroup.class)","+\t\tprivate String persistField;","+","+\t\t@NotNull(groups = InsertGroup.class)","+\t\tprivate String insertField;","+","+\t\t@Size(min = 3, groups = RemoveGroup.class)","+\t\tprivate String removeField;","+","+\t\t@Size(min = 3, groups = DeleteGroup.class)","+\t\tprivate String deleteField;","+","+\t\tpublic Integer getId() {","+\t\t\treturn id;","+\t\t}","+","+\t\tpublic String getPersistField() {","+\t\t\treturn persistField;","+\t\t}","+","+\t\tpublic void setPersistField(String persistField) {","+\t\t\tthis.persistField = persistField;","+\t\t}","+","+\t\tpublic String getInsertField() {","+\t\t\treturn insertField;","+\t\t}","+","+\t\tpublic void setInsertField(String insertField) {","+\t\t\tthis.insertField = insertField;","+\t\t}","+","+\t\tpublic String getRemoveField() {","+\t\t\treturn removeField;","+\t\t}","+","+\t\tpublic void setRemoveField(String removeField) {","+\t\t\tthis.removeField = removeField;","+\t\t}","+","+\t\tpublic String getDeleteField() {","+\t\t\treturn deleteField;","+\t\t}","+","+\t\tpublic void setDeleteField(String deleteField) {","+\t\t\tthis.deleteField = deleteField;","+\t\t}","+\t}","+","+\t@Entity(name = \"ValidatedItem\")","+\tpublic static class ValidatedItem {","+\t\t@Id","+\t\t@GeneratedValue","+\t\tprivate Integer id;","+","+\t\t@NotNull","+\t\tprivate String name;","+","+\t\tpublic Integer getId() {","+\t\t\treturn id;","+\t\t}","+","+\t\tpublic void setId(Integer id) {","+\t\t\tthis.id = id;","+\t\t}","+","+\t\tpublic String getName() {","+\t\t\treturn name;","+\t\t}","+","+\t\tpublic void setName(String name) {","+\t\t\tthis.name = name;","+\t\t}","+\t}","+","+\t/**","+\t * Default behavior: insert validates with Default group,","+\t * persist does not validate (empty groups by default).","+\t */","+\t@ServiceRegistry(settings = {","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_VALIDATION_MODE, value = \"callback\"),","+\t\t\t@Setting(name = BeanValidationIntegrator.APPLY_CONSTRAINTS, value = \"false\"),","+\t})","+\t@DomainModel(annotatedClasses = ValidatedItem.class)","+\t@SessionFactory","+\t@Test","+\tvoid testInsertValidatesByDefault(SessionFactoryScope scope) {","+\t\tscope.inTransaction( s -> {","+\t\t\tvar item = new ValidatedItem();","+\t\t\t// name is null, violates @NotNull","+\t\t\tassertThatThrownBy( () -> {","+\t\t\t\ts.persist( item );","+\t\t\t\ts.flush();","+\t\t\t} ).isInstanceOf( ConstraintViolationException.class );","+\t\t} );","+\t}","+","+\t/**","+\t * When pre-insert is disabled but pre-persist is enabled,","+\t * persist validation fires at insert time.","+\t */","+\t@ServiceRegistry(settings = {","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_VALIDATION_MODE, value = \"callback\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_INSERT_VALIDATION_GROUP, value = \"\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_PERSIST_VALIDATION_GROUP,","+\t\t\t\t\tvalue = \"jakarta.validation.groups.Default\"),","+\t\t\t@Setting(name = BeanValidationIntegrator.APPLY_CONSTRAINTS, value = \"false\"),","+\t})","+\t@DomainModel(annotatedClasses = ValidatedItem.class)","+\t@SessionFactory","+\t@Test","+\tvoid testPersistGroupValidation(SessionFactoryScope scope) {","+\t\tscope.inTransaction( s -> {","+\t\t\tvar item = new ValidatedItem();","+\t\t\t// name is null, violates @NotNull -- persist group is configured","+\t\t\tassertThatThrownBy( () -> {","+\t\t\t\ts.persist( item );","+\t\t\t\ts.flush();","+\t\t\t} ).isInstanceOf( ConstraintViolationException.class );","+\t\t} );","+\t}","+","+\t/**","+\t * When both pre-insert and pre-persist are disabled,","+\t * no validation occurs on persist+flush.","+\t */","+\t@ServiceRegistry(settings = {","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_VALIDATION_MODE, value = \"callback\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_INSERT_VALIDATION_GROUP, value = \"\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_PERSIST_VALIDATION_GROUP, value = \"\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_UPDATE_VALIDATION_GROUP, value = \"\"),","+\t\t\t@Setting(name = BeanValidationIntegrator.APPLY_CONSTRAINTS, value = \"false\"),","+\t})","+\t@DomainModel(annotatedClasses = ValidatedItem.class)","+\t@SessionFactory","+\t@Test","+\tvoid testNoValidationWhenBothDisabled(SessionFactoryScope scope) {","+\t\tscope.inTransaction( s -> {","+\t\t\tvar item = new ValidatedItem();","+\t\t\t// name is null, but no validation groups configured","+\t\t\ts.persist( item );","+\t\t\ts.flush();","+\t\t} );","+\t}","+","+\t/**","+\t * Merge validation fires when pre-merge group is configured.","+\t */","+\t@ServiceRegistry(settings = {","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_VALIDATION_MODE, value = \"callback\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_MERGE_VALIDATION_GROUP,","+\t\t\t\t\tvalue = \"jakarta.validation.groups.Default\"),","+\t\t\t@Setting(name = BeanValidationIntegrator.APPLY_CONSTRAINTS, value = \"false\"),","+\t})","+\t@DomainModel(annotatedClasses = ValidatedItem.class)","+\t@SessionFactory","+\t@Test","+\tvoid testMergeGroupValidation(SessionFactoryScope scope) {","+\t\tscope.inTransaction( s -> {","+\t\t\tvar item = new ValidatedItem();","+\t\t\titem.setName( \"valid\" );","+\t\t\ts.persist( item );","+\t\t\ts.flush();","+","+\t\t\titem.setName( null );","+\t\t\ts.detach( item );","+","+\t\t\tassertThatThrownBy( () -> s.merge( item ) )","+\t\t\t\t\t.isInstanceOf( ConstraintViolationException.class );","+\t\t} );","+\t}","+","+\t/**","+\t * Merge does not validate by default (empty groups).","+\t * Also disables update validation so the dirty merged entity","+\t * does not fail at flush time -- we are only testing merge here.","+\t */","+\t@ServiceRegistry(settings = {","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_VALIDATION_MODE, value = \"callback\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_INSERT_VALIDATION_GROUP, value = \"\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_UPDATE_VALIDATION_GROUP, value = \"\"),","+\t\t\t@Setting(name = BeanValidationIntegrator.APPLY_CONSTRAINTS, value = \"false\"),","+\t})","+\t@DomainModel(annotatedClasses = ValidatedItem.class)","+\t@SessionFactory","+\t@Test","+\tvoid testMergeNoValidationByDefault(SessionFactoryScope scope) {","+\t\tscope.inTransaction( s -> {","+\t\t\tvar item = new ValidatedItem();","+\t\t\titem.setName( \"valid\" );","+\t\t\ts.persist( item );","+\t\t\ts.flush();","+","+\t\t\titem.setName( null );","+\t\t\ts.detach( item );","+","+\t\t\t// merge should succeed -- no merge validation by default","+\t\t\ts.merge( item );","+\t\t} );","+\t}","+","+\t/**","+\t * Remove validation fires when pre-remove group is configured.","+\t */","+\t@ServiceRegistry(settings = {","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_VALIDATION_MODE, value = \"callback\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_REMOVE_VALIDATION_GROUP,","+\t\t\t\t\tvalue = \"jakarta.validation.groups.Default\"),","+\t\t\t@Setting(name = BeanValidationIntegrator.APPLY_CONSTRAINTS, value = \"false\"),","+\t})","+\t@DomainModel(annotatedClasses = ValidatedItem.class)","+\t@SessionFactory","+\t@Test","+\tvoid testRemoveGroupValidation(SessionFactoryScope scope) {","+\t\tscope.inTransaction( s -> {","+\t\t\tvar item = new ValidatedItem();","+\t\t\titem.setName( \"valid\" );","+\t\t\ts.persist( item );","+\t\t\ts.flush();","+","+\t\t\titem.setName( null );","+","+\t\t\tassertThatThrownBy( () -> {","+\t\t\t\ts.remove( item );","+\t\t\t\ts.flush();","+\t\t\t} ).isInstanceOf( ConstraintViolationException.class );","+\t\t} );","+\t}","+","+\t/**","+\t * Both persist and insert validation fire on persist+flush,","+\t * each with its own group. The first to fail (persist) throws","+\t * with its own violation.","+\t */","+\t@ServiceRegistry(settings = {","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_VALIDATION_MODE, value = \"callback\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_PERSIST_VALIDATION_GROUP,","+\t\t\t\t\tvalue = \"org.hibernate.orm.test.annotations.beanvalidation.BeanValidationNewLifecycleTest$PersistGroup\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_INSERT_VALIDATION_GROUP,","+\t\t\t\t\tvalue = \"org.hibernate.orm.test.annotations.beanvalidation.BeanValidationNewLifecycleTest$InsertGroup\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_UPDATE_VALIDATION_GROUP, value = \"\"),","+\t\t\t@Setting(name = BeanValidationIntegrator.APPLY_CONSTRAINTS, value = \"false\"),","+\t})","+\t@DomainModel(annotatedClasses = DualValidatedItem.class)","+\t@SessionFactory","+\t@Test","+\tvoid testPersistAndInsertBothValidate(SessionFactoryScope scope) {","+\t\tscope.inTransaction( s -> {","+\t\t\tvar item = new DualValidatedItem();","+\t\t\t// both persistField and insertField are null -- violates both groups","+\t\t\tassertThatThrownBy( () -> {","+\t\t\t\ts.persist( item );","+\t\t\t\ts.flush();","+\t\t\t} ).isInstanceOf( ConstraintViolationException.class )","+\t\t\t\t\t.satisfies( ex -> {","+\t\t\t\t\t\tvar violations = ((ConstraintViolationException) ex).getConstraintViolations();","+\t\t\t\t\t\tassertThat( violations )","+\t\t\t\t\t\t\t\t.extracting( v -> ((ConstraintViolation<?>) v).getPropertyPath().toString() )","+\t\t\t\t\t\t\t\t.containsExactly( \"persistField\" );","+\t\t\t\t\t} );","+\t\t} );","+\t}","+","+\t/**","+\t * When only persist validation fails but insert would pass,","+\t * the persist violation is thrown first.","+\t */","+\t@ServiceRegistry(settings = {","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_VALIDATION_MODE, value = \"callback\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_PERSIST_VALIDATION_GROUP,","+\t\t\t\t\tvalue = \"org.hibernate.orm.test.annotations.beanvalidation.BeanValidationNewLifecycleTest$PersistGroup\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_INSERT_VALIDATION_GROUP,","+\t\t\t\t\tvalue = \"org.hibernate.orm.test.annotations.beanvalidation.BeanValidationNewLifecycleTest$InsertGroup\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_UPDATE_VALIDATION_GROUP, value = \"\"),","+\t\t\t@Setting(name = BeanValidationIntegrator.APPLY_CONSTRAINTS, value = \"false\"),","+\t})","+\t@DomainModel(annotatedClasses = DualValidatedItem.class)","+\t@SessionFactory","+\t@Test","+\tvoid testPersistFailsBeforeInsert(SessionFactoryScope scope) {","+\t\tscope.inTransaction( s -> {","+\t\t\tvar item = new DualValidatedItem();","+\t\t\titem.setInsertField( \"valid\" ); // insert group passes","+\t\t\t// persistField is null -- persist group fails first","+\t\t\tassertThatThrownBy( () -> {","+\t\t\t\ts.persist( item );","+\t\t\t\ts.flush();","+\t\t\t} ).isInstanceOf( ConstraintViolationException.class )","+\t\t\t\t\t.satisfies( ex -> {","+\t\t\t\t\t\tvar violations = ((ConstraintViolationException) ex).getConstraintViolations();","+\t\t\t\t\t\tassertThat( violations )","+\t\t\t\t\t\t\t\t.extracting( v -> ((ConstraintViolation<?>) v).getPropertyPath().toString() )","+\t\t\t\t\t\t\t\t.containsExactly( \"persistField\" );","+\t\t\t\t\t} );","+\t\t} );","+\t}","+","+\t/**","+\t * When persist passes but insert fails, the insert violation is thrown.","+\t */","+\t@ServiceRegistry(settings = {","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_VALIDATION_MODE, value = \"callback\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_PERSIST_VALIDATION_GROUP,","+\t\t\t\t\tvalue = \"org.hibernate.orm.test.annotations.beanvalidation.BeanValidationNewLifecycleTest$PersistGroup\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_INSERT_VALIDATION_GROUP,","+\t\t\t\t\tvalue = \"org.hibernate.orm.test.annotations.beanvalidation.BeanValidationNewLifecycleTest$InsertGroup\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_UPDATE_VALIDATION_GROUP, value = \"\"),","+\t\t\t@Setting(name = BeanValidationIntegrator.APPLY_CONSTRAINTS, value = \"false\"),","+\t})","+\t@DomainModel(annotatedClasses = DualValidatedItem.class)","+\t@SessionFactory","+\t@Test","+\tvoid testInsertFailsWhenPersistPasses(SessionFactoryScope scope) {","+\t\tscope.inTransaction( s -> {","+\t\t\tvar item = new DualValidatedItem();","+\t\t\titem.setPersistField( \"valid\" ); // persist group passes","+\t\t\t// insertField is null -- insert group fails","+\t\t\tassertThatThrownBy( () -> {","+\t\t\t\ts.persist( item );","+\t\t\t\ts.flush();","+\t\t\t} ).isInstanceOf( ConstraintViolationException.class )","+\t\t\t\t\t.satisfies( ex -> {","+\t\t\t\t\t\tvar violations = ((ConstraintViolationException) ex).getConstraintViolations();","+\t\t\t\t\t\tassertThat( violations )","+\t\t\t\t\t\t\t\t.extracting( v -> ((ConstraintViolation<?>) v).getPropertyPath().toString() )","+\t\t\t\t\t\t\t\t.containsExactly( \"insertField\" );","+\t\t\t\t\t} );","+\t\t} );","+\t}","+","+\t/**","+\t * Both remove and delete validation fire on remove+flush,","+\t * each with its own group. Remove fires first.","+\t */","+\t@ServiceRegistry(settings = {","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_VALIDATION_MODE, value = \"callback\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_INSERT_VALIDATION_GROUP, value = \"\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_UPDATE_VALIDATION_GROUP, value = \"\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_REMOVE_VALIDATION_GROUP,","+\t\t\t\t\tvalue = \"org.hibernate.orm.test.annotations.beanvalidation.BeanValidationNewLifecycleTest$RemoveGroup\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_DELETE_VALIDATION_GROUP,","+\t\t\t\t\tvalue = \"org.hibernate.orm.test.annotations.beanvalidation.BeanValidationNewLifecycleTest$DeleteGroup\"),","+\t\t\t@Setting(name = BeanValidationIntegrator.APPLY_CONSTRAINTS, value = \"false\"),","+\t})","+\t@DomainModel(annotatedClasses = DualValidatedItem.class)","+\t@SessionFactory","+\t@Test","+\tvoid testRemoveFailsBeforeDelete(SessionFactoryScope scope) {","+\t\tscope.inTransaction( s -> {","+\t\t\tvar item = new DualValidatedItem();","+\t\t\titem.setRemoveField( \"ab\" );  // too short, violates @Size(min=3) on RemoveGroup","+\t\t\titem.setDeleteField( \"ab\" );  // too short, violates @Size(min=3) on DeleteGroup","+\t\t\ts.persist( item );","+\t\t\ts.flush();","+","+\t\t\t// remove group fires first","+\t\t\tassertThatThrownBy( () -> {","+\t\t\t\ts.remove( item );","+\t\t\t\ts.flush();","+\t\t\t} ).isInstanceOf( ConstraintViolationException.class )","+\t\t\t\t\t.satisfies( ex -> {","+\t\t\t\t\t\tvar violations = ((ConstraintViolationException) ex).getConstraintViolations();","+\t\t\t\t\t\tassertThat( violations )","+\t\t\t\t\t\t\t\t.extracting( v -> ((ConstraintViolation<?>) v).getPropertyPath().toString() )","+\t\t\t\t\t\t\t\t.containsExactly( \"removeField\" );","+\t\t\t\t\t} );","+\t\t} );","+\t}","+","+\t/**","+\t * When remove passes but delete fails, the delete violation is thrown.","+\t */","+\t@ServiceRegistry(settings = {","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_VALIDATION_MODE, value = \"callback\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_INSERT_VALIDATION_GROUP, value = \"\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_UPDATE_VALIDATION_GROUP, value = \"\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_REMOVE_VALIDATION_GROUP,","+\t\t\t\t\tvalue = \"org.hibernate.orm.test.annotations.beanvalidation.BeanValidationNewLifecycleTest$RemoveGroup\"),","+\t\t\t@Setting(name = ValidationSettings.JAKARTA_DELETE_VALIDATION_GROUP,","+\t\t\t\t\tvalue = \"org.hibernate.orm.test.annotations.beanvalidation.BeanValidationNewLifecycleTest$DeleteGroup\"),","+\t\t\t@Setting(name = BeanValidationIntegrator.APPLY_CONSTRAINTS, value = \"false\"),","+\t})","+\t@DomainModel(annotatedClasses = DualValidatedItem.class)","+\t@SessionFactory","+\t@Test","+\tvoid testDeleteFailsWhenRemovePasses(SessionFactoryScope scope) {","+\t\tscope.inTransaction( s -> {","+\t\t\tvar item = new DualValidatedItem();","+\t\t\titem.setRemoveField( \"valid\" ); // long enough, remove group passes","+\t\t\titem.setDeleteField( \"ab\" );    // too short, delete group fails","+\t\t\ts.persist( item );","+\t\t\ts.flush();","+","+\t\t\tassertThatThrownBy( () -> {","+\t\t\t\ts.remove( item );","+\t\t\t\ts.flush();","+\t\t\t} ).isInstanceOf( ConstraintViolationException.class )","+\t\t\t\t\t.satisfies( ex -> {","+\t\t\t\t\t\tvar violations = ((ConstraintViolationException) ex).getConstraintViolations();","+\t\t\t\t\t\tassertThat( violations )","+\t\t\t\t\t\t\t\t.extracting( v -> ((ConstraintViolation<?>) v).getPropertyPath().toString() )","+\t\t\t\t\t\t\t\t.containsExactly( \"deleteField\" );","+\t\t\t\t\t} );","+\t\t} );","+\t}","+}"],"additions":448,"deletions":0,"truncated":false},{"path":"migration-guide.adoc","lines":["@@ -31,6 +31,31 @@ One specific requirement change that is important to call out is the move to fro"," "," See https://hibernate.atlassian.net/browse/HHH-20028[this issue] for more details."," ","+","+[[validation-lifecycle]]","+==== Jakarta Validation lifecycle event changes","+","+Jakarta Persistence 4.0 redefines which lifecycle events trigger automatic bean validation.","+Previously, validation was tied to `pre-persist` and `pre-update` events.","+Now, validation is organized into EntityManager-level events (`pre-persist`, `pre-merge`, `pre-remove`)","+and DB-level events (`pre-insert`, `pre-update`, `pre-upsert`, `pre-delete`),","+each with its own configuration property.","+","+By default, only `pre-insert`, `pre-update`, and `pre-upsert` trigger validation with the `jakarta.validation.groups.Default` group.","+All other events (`pre-persist`, `pre-merge`, `pre-remove`, `pre-delete`) have empty groups and do not validate unless explicitly configured.","+","+The following new configuration properties are available:","+","+- `jakarta.persistence.validation.group.pre-merge`","+- `jakarta.persistence.validation.group.pre-insert`","+- `jakarta.persistence.validation.group.pre-upsert`","+- `jakarta.persistence.validation.group.pre-delete`","+","+*Breaking change*: the property `jakarta.persistence.validation.group.pre-persist` previously was enabled by default."],"additions":21,"deletions":0,"truncated":false}],"additions":573,"deletions":22,"truncated":true,"file_count":7},"error":null,"fetched_at":"2026-05-25T11:37:05.788876+00:00"}