{"id":"e873edd6575efa4337e0277273340db6f44dd1ff","axis":"silent","repo":"cilium/cilium","sha":"e873edd6575efa4337e0277273340db6f44dd1ff","parsed":{"files":[{"path":"bpf/tests/tc_redirect_netdev.h","lines":["@@ -0,0 +1,504 @@","+/* SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause) */","+/* Copyright Authors of Cilium */","+","+#include <bpf/ctx/skb.h>","+#include \"common.h\"","+#include \"pktgen.h\"","+#include \"scapy.h\"","+","+/* We always assume we have BPF Host Routing enabled */","+#define ENABLE_HOST_ROUTING 1","+","+/* Define an endpoint ID that we'll use as index into policy maps. */","+#define TEST_LXC_ID_LOCAL 233","+","+/* Define netdev and LXC interface index. The netdev ifindex (TEST_HOST_IFACE","+ * here) is also what the ctx_get_ingress_ifindex mock returns - this is how we","+ * simulate the kernel-populated skb->ingress_ifindex that","+ * BPF_PROG_TEST_RUN does not set up on its own.","+ */","+#define TEST_HOST_IFACE 24","+#define TEST_LXC_IFACE 25","+","+/* Define mac addresses we expect to see on redirected packet */","+static volatile const __u8 *node_mac = mac_three;","+static volatile const __u8 *ep_mac = mac_four;","+","+/* Counters to record helper usage across tests */","+enum {","+\tRECORD_TAILCALL = 0,","+\tRECORD_REDIRECT,","+\tRECORD_REDIRECT_PEER,","+\tRECORD__MAX","+};","+","+static unsigned int num_calls[RECORD__MAX] = {};","+","+/* Mocked out BPF helpers that we're intending to test usage of. */","+int mock_ctx_redirect(const struct __ctx_buff *ctx __maybe_unused,","+\t\t      int ifindex __maybe_unused,","+\t\t      __u32 flags __maybe_unused)","+{","+\tnum_calls[RECORD_REDIRECT]++;","+\treturn CTX_ACT_REDIRECT;","+}","+","+int mock_ctx_redirect_peer(const struct __ctx_buff *ctx __maybe_unused,","+\t\t\t   int ifindex __maybe_unused,","+\t\t\t   __u32 flags __maybe_unused)","+{","+\tnum_calls[RECORD_REDIRECT_PEER]++;","+\treturn CTX_ACT_REDIRECT;","+}","+","+int mock_tail_policy(struct __ctx_buff *ctx); /* Defined below bpf_host inclusion */","+","+__section_entry","+int mock_handle_policy(struct __ctx_buff *ctx)","+{","+\tnum_calls[RECORD_TAILCALL]++;","+","+\t/* If we've invoked a policy tailcall exactly once, we can proceed to","+\t * a redirect. In the case of bpf_host, we need to call our mock","+\t * policy handling, which will call redirect_ep().","+\t */","+\tif (num_calls[RECORD_TAILCALL] == 1)","+\t\treturn mock_tail_policy(ctx);","+","+\treturn CTX_ACT_DROP;","+}","+","+struct {","+\t__uint(type, BPF_MAP_TYPE_PROG_ARRAY);","+\t__uint(key_size, sizeof(__u32));","+\t__uint(max_entries, 256);","+\t__array(values, int());","+} mock_policy_call_map __section(\".maps\") = {","+\t.values = {","+\t\t[TEST_LXC_ID_LOCAL] = &mock_handle_policy,","+\t},","+};","+","+static __always_inline __maybe_unused void","+mock_tail_call_dynamic(struct __ctx_buff *ctx __maybe_unused,","+\t\t       const void *map __maybe_unused,","+\t\t       __u32 slot __maybe_unused)","+{","+\ttail_call(ctx, &mock_policy_call_map, slot);","+}","+","+#define tail_call_dynamic mock_tail_call_dynamic","+#define ctx_redirect mock_ctx_redirect","+#define ctx_redirect_peer mock_ctx_redirect_peer","+","+/* Override ctx_get_ingress_ifindex so should_redirect_peer() sees a value","+ * that mirrors the real datapath instead of BPF_PROG_TEST_RUN's default","+ * (which leaves __sk_buff->ingress_ifindex at 0 for synthetic skbs).","+ * Each scenario sets this before dispatching:","+ *   TEST_HOST_IFACE - simulates TC ingress on the physical netdev","+ *                     (phys -> local Pod path).","+ *   0               - simulates TC egress after netkit's ns crossing,","+ *                     which the kernel scrubs (Pod -> local Pod path on","+ *                     netkit).","+ */","+static volatile __u32 mock_ingress_ifindex = TEST_HOST_IFACE;","+","+#define ctx_get_ingress_ifindex mock_ctx_get_ingress_ifindex","+static __always_inline __maybe_unused __u32","+mock_ctx_get_ingress_ifindex(const struct __sk_buff *ctx __maybe_unused)","+{","+\treturn mock_ingress_ifindex;","+}","+","+/* Load the appropriate BPF programs. */","+#include \"lib/bpf_host.h\"","+","+/* Mocked out policy function so we can test redirect_ep(). This stands in for","+ * bpf_lxc's tail_ipv{4,6}_policy program: it reads the calling convention","+ * meta that local_delivery_fill_meta() set and calls redirect_ep() with the","+ * value of should_redirect_peer() as the real program would. Unlike the","+ * cil_from_host test we don't gate on from_host=true: this path runs with","+ * from_host=false (we entered via cil_from_netdev).","+ */","+int mock_tail_policy(struct __ctx_buff *ctx)","+{","+\tbool do_redirect = ctx_load_meta(ctx, CB_DELIVERY_FLAGS) & CB_DELIVERY_FLAGS_REDIRECT;","+\tbool from_host = ctx_load_and_clear_meta(ctx, CB_FROM_HOST);","+\tbool from_tunnel = false;","+","+\tif (do_redirect)","+\t\treturn redirect_ep(ctx, CONFIG(interface_ifindex),","+\t\t\t\t   should_redirect_peer(ctx, from_host),","+\t\t\t\t   from_tunnel);","+","+\t/* Failure path */","+\treturn CTX_ACT_DROP;","+}","+","+/* Set our host interface index */","+ASSIGN_CONFIG(__u32, interface_ifindex, TEST_HOST_IFACE)","+","+/* Deal with testing netkit or veth. */","+#ifdef __CONFIG_ENABLE_NETKIT","+#define TEST_DRIVER_NAME \"netkit\"","+ASSIGN_CONFIG(bool, enable_netkit, true)","+#else","+#define TEST_DRIVER_NAME \"veth\"","+ASSIGN_CONFIG(bool, enable_netkit, false)","+#endif","+","+#include \"lib/endpoint.h\"","+#include \"lib/ipcache.h\"","+#include \"lib/lb.h\"","+#include \"lib/policy.h\"","+","+#ifdef ENABLE_IPV4","+","+/* packet defined in ./scapy/tc_redirect_pkt_defs.py (reused from the host","+ * test - same external -> local Pod shape).","+ */","+const __u8 tc_redirect_netdev_ipv4_pre[] = {","+\tSCAPY_BUF_BYTES(tc_redirect_host_ipv4_pre)","+};","+","+const __u8 tc_redirect_netdev_ipv4_post[] = {","+\tSCAPY_BUF_BYTES(tc_redirect_host_ipv4_post)","+};","+","+/* Setup for this test:","+ * +--------External--------+    +----------Pod 1---------+","+ * | v4_ext_one:high-port   | -> | v4_pod_one:tcp_svc_one |","+ * +------------------------+    +------------------------+","+ *","+ * Packet enters via cil_from_netdev (TC ingress on the physical netdev),","+ * not via cil_from_host. With from_host=false and ingress_ifindex > 0 the","+ * datapath must reach the target Pod via ctx_redirect_peer() on both veth","+ * and netkit - that's the behavior the runtime arm of should_redirect_peer","+ * encodes (and what 210b5866e0 inadvertently broke for netkit).","+ */","+PKTGEN(\"tc\", \"tc_redirect_netdev_ipv4\")","+int tc_redirect_netdev_ipv4_pktgen(struct __ctx_buff *ctx)","+{","+\tstruct pktgen builder;","+","+\tpktgen__init(&builder, ctx);","+","+\tscapy_push_data(&builder, tc_redirect_netdev_ipv4_pre,","+\t\t\tsizeof(tc_redirect_netdev_ipv4_pre));","+","+\tpktgen__finish(&builder);","+","+\treturn 0;","+}","+","+SETUP(\"tc\", \"tc_redirect_netdev_ipv4\")","+int tc_redirect_netdev_ipv4_setup(struct __ctx_buff *ctx)","+{","+\t/* Reset counters in case a previous scenario ran in the same .o */","+\tnum_calls[RECORD_TAILCALL] = 0;","+\tnum_calls[RECORD_REDIRECT] = 0;","+\tnum_calls[RECORD_REDIRECT_PEER] = 0;","+","+\t/* phys-netdev TC ingress: kernel sets ingress_ifindex */","+\tmock_ingress_ifindex = TEST_HOST_IFACE;","+","+\t/* Add an IPCache entry for pod 1 */","+\tipcache_v4_add_entry(v4_pod_one, 0, 112233, 0, 0);","+","+\t/* Add endpoint for local LXC */","+\tendpoint_v4_add_entry(v4_pod_one, TEST_LXC_IFACE, TEST_LXC_ID_LOCAL, 0, 0, 0,","+\t\t\t      (const __u8 *)ep_mac, (const __u8 *)node_mac);","+","+\treturn netdev_receive_packet(ctx);","+}","+","+CHECK(\"tc\", \"tc_redirect_netdev_ipv4\")","+int tc_redirect_netdev_ipv4_check(__maybe_unused const struct __ctx_buff *ctx)","+{","+\t/* Both veth and netkit must take the redirect_peer() path here:","+\t * ingress_ifindex > 0 makes the runtime arm true on netkit, and","+\t * !enable_netkit makes the loadtime arm true on veth.","+\t */","+\tconst unsigned int expected[RECORD__MAX] = {1, 0, 1};","+\tvoid *data;","+\tvoid *data_end;","+\t__u32 *status_code;","+","+\ttest_init();","+","+\tendpoint_v4_del_entry(v4_pod_one);","+","+\tdata = (void *)(long)ctx->data;","+\tdata_end = (void *)(long)ctx->data_end;","+","+\tif (data + sizeof(__u32) > data_end)","+\t\ttest_fatal(\"status code out of bounds\");","+","+\tstatus_code = data;","+\tassert(*status_code == CTX_ACT_REDIRECT);","+","+\ttest_log(TEST_DRIVER_NAME \": num_calls %u/%u/%u (tailcall/redirect/redirect_peer)\",","+\t\t num_calls[RECORD_TAILCALL],","+\t\t num_calls[RECORD_REDIRECT],","+\t\t num_calls[RECORD_REDIRECT_PEER]);","+","+\tif (num_calls[RECORD_TAILCALL] != expected[RECORD_TAILCALL])","+\t\ttest_fatal(TEST_DRIVER_NAME \": Incorrect number of tail calls\");","+\tif (num_calls[RECORD_REDIRECT] != expected[RECORD_REDIRECT])","+\t\ttest_fatal(TEST_DRIVER_NAME \": Incorrect number of bpf_redirect() calls\")","+\tif (num_calls[RECORD_REDIRECT_PEER] != expected[RECORD_REDIRECT_PEER])","+\t\ttest_fatal(TEST_DRIVER_NAME \": Incorrect number of bpf_redirect_peer() calls\")","+","+\ttest_finish();","+}","+","+/* Pod -> local Pod simulation:","+ *","+ * In production this enters via bpf_lxc's cil_from_container (a different","+ * compilation unit we can't link in here), but the discriminator the fix","+ * cares about is the value of ctx_get_ingress_ifindex() in","+ * should_redirect_peer(). Reuse cil_from_netdev as the vehicle and force","+ * the mock to return 0, which is what netkit's ns crossing scrubs the","+ * field to on TC egress. On netkit this must NOT take redirect_peer(); on","+ * veth the loadtime !enable_netkit arm still folds true so redirect_peer()","+ * is the right answer (and matches the existing tc_redirect_lxc_veth_*","+ * expectations).","+ */","+PKTGEN(\"tc\", \"tc_redirect_pod_egress_ipv4\")","+int tc_redirect_pod_egress_ipv4_pktgen(struct __ctx_buff *ctx)","+{","+\tstruct pktgen builder;","+","+\tpktgen__init(&builder, ctx);","+","+\tscapy_push_data(&builder, tc_redirect_netdev_ipv4_pre,","+\t\t\tsizeof(tc_redirect_netdev_ipv4_pre));","+","+\tpktgen__finish(&builder);","+","+\treturn 0;","+}","+","+SETUP(\"tc\", \"tc_redirect_pod_egress_ipv4\")","+int tc_redirect_pod_egress_ipv4_setup(struct __ctx_buff *ctx)","+{","+\tnum_calls[RECORD_TAILCALL] = 0;","+\tnum_calls[RECORD_REDIRECT] = 0;","+\tnum_calls[RECORD_REDIRECT_PEER] = 0;","+","+\t/* Pod-egress on netkit: ns crossing scrubs ingress_ifindex to 0 */","+\tmock_ingress_ifindex = 0;","+","+\tipcache_v4_add_entry(v4_pod_one, 0, 112233, 0, 0);","+\tendpoint_v4_add_entry(v4_pod_one, TEST_LXC_IFACE, TEST_LXC_ID_LOCAL, 0, 0, 0,","+\t\t\t      (const __u8 *)ep_mac, (const __u8 *)node_mac);","+","+\treturn netdev_receive_packet(ctx);","+}","+","+CHECK(\"tc\", \"tc_redirect_pod_egress_ipv4\")","+int tc_redirect_pod_egress_ipv4_check(__maybe_unused const struct __ctx_buff *ctx)","+{","+#ifdef __CONFIG_ENABLE_NETKIT","+\t/* netkit + ingress_ifindex==0: predicate is false on both arms,","+\t * so should_redirect_peer() returns false and the tail-called","+\t * mock_tail_policy uses ctx_redirect() (which on netkit lets the","+\t * primary's xmit handle the ns switch).","+\t */","+\tconst unsigned int expected[RECORD__MAX] = {1, 1, 0};","+#else","+\t/* veth + ingress_ifindex==0: !CONFIG(enable_netkit) folds true at","+\t * load time so should_redirect_peer() still returns true. veth Pod","+\t * -> Pod uses redirect_peer() and matches tc_redirect_lxc_veth_*.","+\t */","+\tconst unsigned int expected[RECORD__MAX] = {1, 0, 1};","+#endif","+\tvoid *data;","+\tvoid *data_end;","+\t__u32 *status_code;","+","+\ttest_init();","+","+\tendpoint_v4_del_entry(v4_pod_one);","+","+\tdata = (void *)(long)ctx->data;","+\tdata_end = (void *)(long)ctx->data_end;","+","+\tif (data + sizeof(__u32) > data_end)","+\t\ttest_fatal(\"status code out of bounds\");","+","+\tstatus_code = data;","+\tassert(*status_code == CTX_ACT_REDIRECT);","+","+\ttest_log(TEST_DRIVER_NAME \": pod num %u/%u/%u (tc/r/rp)\",","+\t\t num_calls[RECORD_TAILCALL],","+\t\t num_calls[RECORD_REDIRECT],","+\t\t num_calls[RECORD_REDIRECT_PEER]);","+","+\tif (num_calls[RECORD_TAILCALL] != expected[RECORD_TAILCALL])","+\t\ttest_fatal(TEST_DRIVER_NAME \": pod bad tail count\");","+\tif (num_calls[RECORD_REDIRECT] != expected[RECORD_REDIRECT])","+\t\ttest_fatal(TEST_DRIVER_NAME \": pod bad redirect count\")","+\tif (num_calls[RECORD_REDIRECT_PEER] != expected[RECORD_REDIRECT_PEER])","+\t\ttest_fatal(TEST_DRIVER_NAME \": pod bad redirect_peer count\")","+","+\ttest_finish();","+}","+","+#endif /* ENABLE_IPV4 */","+","+#ifdef ENABLE_IPV6","+","+const __u8 tc_redirect_netdev_ipv6_pre[] = {","+\tSCAPY_BUF_BYTES(tc_redirect_host_ipv6_pre)","+};","+","+const __u8 tc_redirect_netdev_ipv6_post[] = {","+\tSCAPY_BUF_BYTES(tc_redirect_host_ipv6_post)","+};","+","+PKTGEN(\"tc\", \"tc_redirect_netdev_ipv6\")","+int tc_redirect_netdev_ipv6_pktgen(struct __ctx_buff *ctx)","+{","+\tstruct pktgen builder;","+","+\tpktgen__init(&builder, ctx);","+","+\tscapy_push_data(&builder, tc_redirect_netdev_ipv6_pre,","+\t\t\tsizeof(tc_redirect_netdev_ipv6_pre));","+","+\tpktgen__finish(&builder);","+","+\treturn 0;","+}","+","+SETUP(\"tc\", \"tc_redirect_netdev_ipv6\")","+int tc_redirect_netdev_ipv6_setup(struct __ctx_buff *ctx)","+{","+\tconst union v6addr pod_ip = { .addr = v6_pod_one_addr };","+","+\tnum_calls[RECORD_TAILCALL] = 0;","+\tnum_calls[RECORD_REDIRECT] = 0;","+\tnum_calls[RECORD_REDIRECT_PEER] = 0;","+\tmock_ingress_ifindex = TEST_HOST_IFACE;","+","+\tipcache_v6_add_entry(&pod_ip, 0, 112233, 0, 0);","+","+\tendpoint_v6_add_entry(&pod_ip, TEST_LXC_IFACE, TEST_LXC_ID_LOCAL, 0, 0,","+\t\t\t      (const __u8 *)ep_mac, (const __u8 *)node_mac);","+","+\treturn netdev_receive_packet(ctx);","+}","+","+CHECK(\"tc\", \"tc_redirect_netdev_ipv6\")","+int tc_redirect_netdev_ipv6_check(__maybe_unused const struct __ctx_buff *ctx)","+{","+\tconst unsigned int expected[RECORD__MAX] = {1, 0, 1};","+\tconst union v6addr pod_ip = { .addr = v6_pod_one_addr };","+\tvoid *data;","+\tvoid *data_end;","+\t__u32 *status_code;","+","+\ttest_init();","+","+\tendpoint_v6_del_entry(&pod_ip);","+","+\tdata = (void *)(long)ctx->data;","+\tdata_end = (void *)(long)ctx->data_end;","+","+\tif (data + sizeof(__u32) > data_end)","+\t\ttest_fatal(\"status code out of bounds\");","+","+\tstatus_code = data;","+\tassert(*status_code == CTX_ACT_REDIRECT);","+","+\ttest_log(TEST_DRIVER_NAME \": num_calls %u/%u/%u (tailcall/redirect/redirect_peer)\",","+\t\t num_calls[RECORD_TAILCALL],","+\t\t num_calls[RECORD_REDIRECT],","+\t\t num_calls[RECORD_REDIRECT_PEER]);","+","+\tif (num_calls[RECORD_TAILCALL] != expected[RECORD_TAILCALL])","+\t\ttest_fatal(TEST_DRIVER_NAME \": Incorrect number of tail calls\");","+\tif (num_calls[RECORD_REDIRECT] != expected[RECORD_REDIRECT])","+\t\ttest_fatal(TEST_DRIVER_NAME \": Incorrect number of bpf_redirect() calls\")","+\tif (num_calls[RECORD_REDIRECT_PEER] != expected[RECORD_REDIRECT_PEER])","+\t\ttest_fatal(TEST_DRIVER_NAME \": Incorrect number of bpf_redirect_peer() calls\")","+","+\ttest_finish();","+}","+","+/* See the IPv4 sibling for the rationale of this scenario. */","+PKTGEN(\"tc\", \"tc_redirect_pod_egress_ipv6\")","+int tc_redirect_pod_egress_ipv6_pktgen(struct __ctx_buff *ctx)","+{","+\tstruct pktgen builder;","+","+\tpktgen__init(&builder, ctx);","+","+\tscapy_push_data(&builder, tc_redirect_netdev_ipv6_pre,","+\t\t\tsizeof(tc_redirect_netdev_ipv6_pre));","+","+\tpktgen__finish(&builder);","+","+\treturn 0;","+}","+","+SETUP(\"tc\", \"tc_redirect_pod_egress_ipv6\")","+int tc_redirect_pod_egress_ipv6_setup(struct __ctx_buff *ctx)","+{","+\tconst union v6addr pod_ip = { .addr = v6_pod_one_addr };","+","+\tnum_calls[RECORD_TAILCALL] = 0;","+\tnum_calls[RECORD_REDIRECT] = 0;","+\tnum_calls[RECORD_REDIRECT_PEER] = 0;","+\tmock_ingress_ifindex = 0;","+","+\tipcache_v6_add_entry(&pod_ip, 0, 112233, 0, 0);","+\tendpoint_v6_add_entry(&pod_ip, TEST_LXC_IFACE, TEST_LXC_ID_LOCAL, 0, 0,","+\t\t\t      (const __u8 *)ep_mac, (const __u8 *)node_mac);","+","+\treturn netdev_receive_packet(ctx);","+}","+","+CHECK(\"tc\", \"tc_redirect_pod_egress_ipv6\")","+int tc_redirect_pod_egress_ipv6_check(__maybe_unused const struct __ctx_buff *ctx)","+{","+#ifdef __CONFIG_ENABLE_NETKIT","+\tconst unsigned int expected[RECORD__MAX] = {1, 1, 0};","+#else","+\tconst unsigned int expected[RECORD__MAX] = {1, 0, 1};","+#endif","+\tconst union v6addr pod_ip = { .addr = v6_pod_one_addr };","+\tvoid *data;","+\tvoid *data_end;","+\t__u32 *status_code;","+","+\ttest_init();","+","+\tendpoint_v6_del_entry(&pod_ip);","+","+\tdata = (void *)(long)ctx->data;","+\tdata_end = (void *)(long)ctx->data_end;","+","+\tif (data + sizeof(__u32) > data_end)","+\t\ttest_fatal(\"status code out of bounds\");","+","+\tstatus_code = data;","+\tassert(*status_code == CTX_ACT_REDIRECT);","+","+\ttest_log(TEST_DRIVER_NAME \": pod num %u/%u/%u (tc/r/rp)\",","+\t\t num_calls[RECORD_TAILCALL],","+\t\t num_calls[RECORD_REDIRECT],","+\t\t num_calls[RECORD_REDIRECT_PEER]);","+","+\tif (num_calls[RECORD_TAILCALL] != expected[RECORD_TAILCALL])","+\t\ttest_fatal(TEST_DRIVER_NAME \": pod bad tail count\");","+\tif (num_calls[RECORD_REDIRECT] != expected[RECORD_REDIRECT])","+\t\ttest_fatal(TEST_DRIVER_NAME \": pod bad redirect count\")","+\tif (num_calls[RECORD_REDIRECT_PEER] != expected[RECORD_REDIRECT_PEER])","+\t\ttest_fatal(TEST_DRIVER_NAME \": pod bad redirect_peer count\")","+","+\ttest_finish();","+}","+","+#endif /* ENABLE_IPV6 */"],"additions":504,"deletions":0,"truncated":false},{"path":"bpf/tests/tc_redirect_netdev_netkit_ipv4.c","lines":["@@ -0,0 +1,7 @@","+// SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)","+/* Copyright Authors of Cilium */","+","+#define __CONFIG_ENABLE_NETKIT","+#define ENABLE_IPV4 1","+#undef USE_BPF_PROG_FOR_INGRESS_POLICY","+#include \"tc_redirect_netdev.h\""],"additions":7,"deletions":0,"truncated":false},{"path":"bpf/tests/tc_redirect_