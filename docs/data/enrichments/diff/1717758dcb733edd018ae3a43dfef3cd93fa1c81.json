ange: Event<void> = this._onDidCopilotTokenChange.event;","+"," \tprotected fireAuthenticationChange(source: string): void {"," \t\tconst hasSession = !!this.copilotToken;"," \t\tthis._logService.info(`AuthenticationService: firing onDidAuthenticationChange from ${source}. Has token: ${hasSession}`);"," \t\tthis._onDidAuthenticationChange.fire();"," \t}"," ","+\tprotected fireCopilotTokenChange(source: string): void {","+\t\tthis._logService.debug(`AuthenticationService: firing onDidCopilotTokenChange from ${source}.`);","+\t\tthis._onDidCopilotTokenChange.fire();","+\t}","+"," \tprotected readonly _onDidAccessTokenChange = this._register(new Emitter<void>());"," \treadonly onDidAccessTokenChange: Event<void> = this._onDidAccessTokenChange.event;"," ","@@ -265,28 +284,39 @@ export abstract class BaseAuthenticationService extends Disposable implements IA"," \t}"," \tasync getCopilotToken(force?: boolean): Promise<CopilotToken> {"," \t\ttry {","+\t\t\tconst tokenBefore = this._tokenStore.copilotToken;"," \t\t\tconst token = await this._tokenManager.getCopilotToken(force);"," \t\t\tthis._tokenStore.copilotToken = token;"," \t\t\tthis._copilotTokenError = undefined;","+\t\t\tif (tokenBefore?.token !== token.token) {","+\t\t\t\tthis.fireCopilotTokenChange('getCopilotToken');","+\t\t\t}"," \t\t\treturn token;"," \t\t} catch (afterError) {","+\t\t\tconst tokenBefore = this._tokenStore.copilotToken;"," \t\t\tthis._tokenStore.copilotToken = undefined;"," \t\t\tconst beforeError = this._copilotTokenError;"," \t\t\tthis._copilotTokenError = afterError;","-\t\t\t// This handles the case where the user still can't get a Copilot Token,","-\t\t\t// but the error has change. I.e. They go from being not signed in (no copilot token can be minted)","-\t\t\t// to an account that doesn't have a valid subscription (no copilot token can be minted).","-\t\t\t// NOTE: if either error is undefined, this event should be fired elsewhere already.","-\t\t\tif (beforeError && afterError && beforeError.message !== afterError.message) {","-\t\t\t\tthis.fireAuthenticationChange('getCopilotToken error change');","+\t\t\tif (tokenBefore) {","+\t\t\t\t// Had a valid token before, now errored — token value changed to undefined","+\t\t\t\tthis.fireCopilotTokenChange('getCopilotToken token lost');","+\t\t\t} else if (beforeError && afterError && beforeError.message !== afterError.message) {","+\t\t\t\t// Still can't get a Copilot Token, but the error has changed.","+\t\t\t\t// I.e. They go from being not signed in (no copilot token can be minted)","+\t\t\t\t// to an account that doesn't have a valid subscription (no copilot token can be minted).","+\t\t\t\tthis.fireCopilotTokenChange('getCopilotToken error change');"," \t\t\t}"," \t\t\tthrow afterError;"," \t\t}"," \t}"," "," \tresetCopilotToken(httpError?: number): void {","+\t\tconst hadToken = !!this._tokenStore.copilotToken;"," \t\tthis._tokenStore.copilotToken = undefined;"," \t\tthis._tokenManager.resetCopilotToken(httpError);","+\t\tif (hadToken) {","+\t\t\tthis.fireCopilotTokenChange('resetCopilotToken');","+\t\t}"," \t}"," "," \t//#endregion","@@ -303,8 +333,6 @@ export abstract class BaseAuthenticationService extends Disposable implements IA"," \t\tconst anyGitHubSessionBefore = this._anyGitHubSession;"," \t\tconst permissiveGitHubSessionBefore = this._permissiveGitHubSession;"," \t\tconst anyAdoSessionBefore = this._anyAdoSession;","-\t\tconst copilotTokenBefore = this._tokenStore.copilotToken;","-\t\tconst copilotTokenErrorBefore = this._copilotTokenError;"," "," \t\t// Update caches"," \t\tconst resolved = await Promise.allSettled([","@@ -323,14 +351,15 @@ export abstract class BaseAuthenticationService extends Disposable implements IA"," \t\t\tpermissiveGitHubSessionBefore?.accessToken !== this._permissiveGitHubSession?.accessToken"," \t\t) {"," \t\t\tthis._onDidAccessTokenChange.fire();","-\t\t\tthis._logService.debug('Auth state changed, minting a new CopilotToken...');","-\t\t\t// The auth state has