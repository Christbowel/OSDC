y)}`;","+        url.hash = `#/feedback/${postData.id}/${score}/?uuid=${encodeURIComponent(uuid)}&key=${encodeURIComponent(key)}`;","         return url;","     }"," }"],"additions":5,"deletions":2,"truncated":false},{"path":"ghost/core/core/server/services/comments/comments-service-emails.js","lines":["@@ -2,6 +2,7 @@ const moment = require('moment');"," const htmlToPlaintext = require('@tryghost/html-to-plaintext');"," const emailService = require('../email-service');"," const CommentsServiceEmailRenderer = require('./comments-service-email-renderer');","+const toPlain = require('../../lib/common/to-plain');"," const {t} = require('../i18n');"," "," class CommentsServiceEmails {","@@ -25,7 +26,8 @@ class CommentsServiceEmails {","      * @returns {string} The post URL with appropriate comment fragment","      */","     getPostUrl(post, commentId) {","-        const baseUrl = this.urlService.getUrlByResourceId(post.id, {absolute: true});","+        const postData = toPlain(post);","+        const baseUrl = this.urlService.facade.getUrlForResource({...postData, type: 'posts'}, {absolute: true});","         return `${baseUrl}#ghost-comments-${commentId}`;","     }"," "],"additions":3,"deletions":1,"truncated":false},{"path":"ghost/core/core/server/services/indexnow.js","lines":["@@ -84,7 +84,7 @@ async function ping(post) {","     }"," ","     try {","-        const url = urlService.getUrlByResourceId(post.id, {absolute: true});","+        const url = urlService.facade.getUrlForResource({...post, type: 'posts'}, {absolute: true});"," ","         // Get the API key (auto-generated on boot by settings service)","         const key = getApiKey();"],"additions":1,"deletions":1,"truncated":false},{"path":"ghost/core/core/server/services/member-attribution/url-translator.js","lines":["@@ -1,10 +1,18 @@"," /**","  * @typedef {Object} UrlService","  * @prop {(resourceId: string, options) => Object} getResource","- *  @prop {(resourceId: string, options) => string} getUrlByRe