"sm\"","+                    step={0.1}","+                    value={durationGteParam}","+                    w=\"100%\"","+                  >","+                    <NumberInputField placeholder={translate(\"dag:panel.graphFilters.durationGte\")} />","+                  </NumberInputRoot>","+                  <Text color=\"fg.muted\" fontSize=\"xs\">","+                    {translate(\"dag:panel.graphFilters.durationGteHint\")}","+                  </Text>","+                </VStack>","+              </>","+            )}","+","+            {hasActiveFilters ? (","+              <Button onClick={clearAllFilters} size=\"sm\" variant=\"outline\" width=\"100%\">","+                {translate(\"dag:panel.graphFilters.clearFilters\")}","+              </Button>","+            ) : undefined}","+          </Menu.Content>","+        </Menu.Positioner>","+      </Portal>","+    </Menu.Root>","+  );","+};"],"additions":273,"deletions":0,"truncated":false},{"path":"airflow-core/src/airflow/ui/src/constants/searchParams.ts","lines":["@@ -46,6 +46,11 @@ export enum SearchParamsKeys {","   EXECUTOR_CLASS = \"executor_class\",","   FAVORITE = \"favorite\",","   GANTT = \"gantt\",","+  GRAPH_DURATION_GTE = \"graph-duration_gte\",","+  GRAPH_MAP_INDEX = \"graph-map_index\",","+  GRAPH_OPERATOR = \"graph-operator\",","+  GRAPH_TASK_GROUP = \"graph-task_group\",","+  GRAPH_TASK_STATE = \"graph-task_state\",","   HOSTNAME = \"hostname\",","   INCLUDED_EVENTS = \"included_events\",","   JOB_STATE = \"job_state\",","@@ -89,6 +94,7 @@ export enum SearchParamsKeys {","   SUBJECT_SEARCH = \"subject_search\",","   TAGS = \"tags\",","   TAGS_MATCH_MODE = \"tags_match_mode\",","+  TASK_GROUP = \"task_group\",","   TASK_ID = \"task_id\",","   TASK_ID_PATTERN = \"task_id_pattern\",","   TASK_STATE = \"task_state\","],"additions":6,"deletions":0,"truncated":false},{"path":"airflow-core/src/airflow/ui/src/context/groups/Context.ts","lines":["rename from airflow-core/src/airflow/ui/src/context/