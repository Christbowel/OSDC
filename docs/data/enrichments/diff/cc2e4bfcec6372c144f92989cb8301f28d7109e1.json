ntity.PrivilegedPoolProvider","+\t\tidentity.PendingTraitsChangePersistenceProvider"," \t\tsession.ManagementProvider","+\t\tsession.PersistenceProvider"," \t\tconfig.Provider"," "," \t\tHandlerProvider","@@ -74,6 +83,7 @@ type ("," \t\tlogrusx.Provider"," \t\thttpx.WriterProvider"," \t\totelx.Provider","+\t\tx.TransactionPersistenceProvider"," \t}"," \tHookExecutor struct {"," \t\td executorDependencies","@@ -333,6 +343,159 @@ func (e *HookExecutor) PostSettingsHook(ctx context.Context, w http.ResponseWrit"," \treturn nil"," }"," ","+// settingsTypePendingTraitsChange is the settings strategy the verify_new_address","+// hook is allowed to be configured under. The JSON config schema","+// (selfServiceAfterSettingsProfileMethod) only admits verify_new_address inside","+// the profile hook list, so a pending traits change can only ever originate","+// from the profile strategy.","+const settingsTypePendingTraitsChange = \"profile\"","+","+// ErrPendingTraitsChangeSessionInvalid is returned by ApplyPendingTraitsChange","+// when the session that created the pending change is missing, revoked,","+// expired, disabled, or belongs to a different tenant. Callers should treat","+// this as \"the verification attempt is invalid\" — the change is not applied.","+var ErrPendingTraitsChangeSessionInvalid = stderrors.New(\"pending traits change session is no longer valid\")","+","+// ApplyPendingTraitsChange commits a pending traits change to the identity and","+// fires the \"after profile settings, post-persist\" hook chain. It is the","+// single entry point verification strategies use to resolve a pending change","+// created by a settings flow.","+//","+// The originating session is validated inside the same transaction that","+// applies the change, so a session that is revoked between the caller's","+// token/code consumption and this call is still rejected. If validation","+// succeeds, the loaded session is reused for the hook chain — no second","+// GetSession round-trip.","+//","+// Returns ErrPendingTraitsChangeSessionInvalid when the session is not usable.","+// Returns identity.ErrConcurrentModification when the identity's traits have","+// drifted since the change was proposed.","+func (e *HookExecutor) ApplyPendingTraitsChange(","+\tctx context.Context,","+\tw http.ResponseWriter,","+\tr *http.Request,","+\tptc *identity.PendingTraitsChange,","+) (i *identity.Identity, err error) {","+\tctx, span := e.d.Tracer(ctx).Tracer().Start(ctx, \"selfservice.flow.settings.HookExecutor.ApplyPendingTraitsChange\")","+\tdefer otelx.End(span, &err)","+","+\t// Reject PTCs whose FK references were nulled or never written. The","+\t// session FK is ON DELETE SET NULL and the origin-flow FK is ON","+\t// DELETE CASCADE, so a NULL here means either a revoked session or","+\t// a writer that failed to set the link.","+\tif !ptc.SessionID.Valid || !ptc.OriginSettingsFlowID.Valid {","+\t\treturn nil, errors.WithStack(ErrPendingTraitsChangeSessionInvalid)","+\t}","+","+\tvar sess *session.Session","+\terr = e.d.TransactionalPersisterProvider().Transaction(ctx, func(ctx context.Context, _ *pop.Connection) error {","+\t\t// ExpandDefault loads the session's identity in the same query,","+\t\t// so IsActive() below checks the identity's active state and we","+\t\t// avoid a second round-trip to IdentityPool.GetIdentity for the","+\t\t// hash comparison.","+\t\ts, sErr := e.d.SessionPersister().GetSession(ctx, ptc.SessionID.UUID, session.ExpandDefault)","+\t\tif sErr != nil {","+\t\t\tif errors.Is(sErr, sqlcon.ErrNoRows()) {","+\t\t\t\treturn errors.WithStack(ErrPendingTraitsChangeSessionInvalid)","+\t\t\t}","+\t\t\treturn sErr","+\t\t}","+\t\tif s.NID != ptc.NID || !s.IsActive() {","+\t\t\treturn errors.WithStack(ErrPendingTraitsChangeSessionInvalid)","+\t\t}","+\t\t// TODO(jonas): We can likely drop the identity id column entirely, since the session's identity is always loaded and we check the ID matches here. This would simplify the schema and remove a potential source of FK inconsistency.","+\t\tif s.Identity == nil || s.Identity.ID != ptc.IdentityID {","+\t\t\treturn errors.WithStack(ErrPendingTraitsChangeSessionInvalid)","+\t\t}","+\t\tsess = s","+","+\t\tif identity.HashTraits(json.RawMessage(s.Identity.Traits)) != ptc.OriginalTraitsHash {","+\t\t\treturn identity.ErrConcurrentModification","+\t\t}","+","+\t\tif err := e.d.IdentityManager().UpdateTraits(","+\t\t\tctx, ptc.IdentityID, identity.Traits(ptc.ProposedTraits),","+\t\t\tidentity.ManagerAllowWriteProtectedTraits,","+\t\t); err != nil {","+\t\t\treturn err","+\t\t}","+","+\t\t// The PTC Status column is informational only; the real","+\t\t// single-submit guard is the verification flow state machine","+\t\t// (StatePassedChallenge) plus atomic token/code consumption.","+\t\t// We intentionally do not write Status here.","+","+\t\t// Re-read the identity after UpdateTraits so the returned","+\t\t// snapshot reflects the freshly-committed state, including any","+\t\t// VerifiableAddress row UpdateTraits may have created for the","+\t\t// new address.","+\t\tupdated, err := e.d.IdentityPool().GetIdentity(ctx, ptc.IdentityID, identity.ExpandDefault)","+\t\tif err != nil {","+\t\t\treturn err","+\t\t}","+","+\t\tfor idx := range updated.VerifiableAddresses {","+\t\t\ta := &updated.VerifiableAddresses[idx]","+\t\t\tif a.Value == ptc.NewAddressValue && a.Via == ptc.NewAddressVia {","+\t\t\t\ta.Verified = true","+\t\t\t\tverifiedAt := sqlxx.NullTime(time.Now().UTC())","+\t\t\t\ta.VerifiedAt = &verifiedAt","+\t\t\t\ta.Status = identity.VerifiableAddressStatusCompleted","+\t\t\t\tif err := e.d.PrivilegedIdentityPool().UpdateVerifiableAddress(ctx, a, \"verified\", \"verified_at\", \"status\"); err != nil {","+\t\t\t\t\treturn err","+\t\t\t\t}","+\t\t\t\tbreak","+\t\t\t}","+\t\t}","+","+\t\ti = updated","+\t\t// Keep Session.Identity in sync so post-persist webhook templates render the committed traits and the newly-verified address.","+\t\t// TODO: pointer aliasing could cause issues if a downstream hook implementation modifies the identity in-place instead of treating it as immutable. We should either enforce immutability or document this behavior.","+\t\tsess.Identity = updated","+\t\treturn nil","+\t})","+\tif err != nil {","+\t\treturn nil, err","+\t}","+","+\t// Fire the \"profile\" post-persist hooks. Load the originating settings flow","+\t// so the hook chain receives a real Flow (honest ID, type, RequestURL)","+\t// instead of a synthetic one. The FK is ON DELETE CASCADE, so if the flow","+\t// was cleaned up the PTC was already deleted and we would not reach this","+\t// call. Apply has already committed, so a hook error cannot roll the change","+\t// back — we propagate errors so callers can surface them in the","+\t// verification UI.","+\toriginFlow, err := e.d.SettingsFlowPersister().GetSettingsFlow(ctx, ptc.OriginSettingsFlowID.UUID)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\tpostHooks, err := e.d.PostSettingsPostPersistHooks(ctx, settingsTypePendingTraitsChange)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\tfor k, executor := range postHooks {","+\t\tlogFields := logrus.Fields{","+\t\t\t\"executor\":          fmt.Sprintf(\"%T\", executor),","+\t\t\t\"executor_position\": k,","+\t\t\t\"executors\":         PostHookPostPersistExecutorNames(postHooks),","+\t\t\t\"identity_id\":       i.ID,","+\t\t\t\"flow_method\":       settingsTypePendingTraitsChange,","+\t\t}","+\t\tif err := executor.ExecuteSettingsPostPersistHook(w, r, originFlow, i, sess); err != nil {","+\t\t\tif errors.Is(err, ErrHookAbortFlow) {","+\t\t\t\te.d.Logger().WithRequest(r).WithFields(logFields).","+\t\t\t\t\tDebug(\"A post-persist hook aborted the pending-traits-change continuation flow.\")","+\t\t\t\treturn i, nil","+\t\t\t}","+\t\t\treturn nil, err","+\t\t}","+\t\te.d.Logger().WithRequest(r).WithFields(logFields).","+\t\t\tDebug(\"ExecuteSettingsPostPersistHook completed successfully after pending traits change.\")","+\t}","+","+\treturn i, nil","+}","+"," func (e *HookExecutor) PreSettingsHook(ctx context.Context, w http.ResponseWriter, r *http.Request, a *Flow, s *session.Session) (err error) {"," \tctx, span := e.d.Tracer(ctx).Tracer().Start(ctx, \"selfservice.flow.settings.HookExecutor.PreSettingsHook\")"," \tdefer otelx.End(span, &err)"],"additions":165,"deletions":2,"truncated":false},{"path":"selfservice/flow/settings/hook_pending_traits_change_test.go","lines":["@@ -0,0 +1,287 @@","+// Copyright © 2026 Ory Corp","+// SPDX-License-Identifier: Apache-2.0","+","+package settings_test","+","+import (","+\t\"context\"","+\t\"encoding/base64\"","+\t\"encoding/json\"","+\t\"io\"","+\t\"net/http\"","+\t\"net/http/httptest\"","+\t\"testing\"","+\t\"time\"","+","+\t\"github.com/gofrs/uuid\"","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+","+\t\"github.com/ory/kratos/driver\"","+\t\"github.com/ory/kratos/driver/config\"","+\t\"github.com/ory/kratos/identity\"","+\t\"github.com/ory/kratos/pkg\"","+\t\"github.com/ory/kratos/pkg/testhelpers\"","+\t\"github.com/ory/kratos/selfservice/flow\"","+\t\"github.com/ory/kratos/selfservice/flow/settings\"","+\t\"github.com/ory/kratos/selfservice/flow/verification\"","+\t\"github.com/ory/kratos/session\"","+\t\"github.com/ory/kratos/x\"","+\t\"github.com/ory/kratos/x/nosurfx\"","+)","+","+// applyPTCFixture holds a wired-up registry plus a minimal set of persisted","+// objects (identity, session, settings flow, verification flow, PTC) for","+// unit-testing HookExecutor.ApplyPendingTraitsChange. Subtests mutate the","+// PTC before calling ApplyPendingTraitsChange to exercise specific guard paths.","+type applyPTCFixture struct {","+\treg      *driver.RegistryDefault","+\tidentity *identity.Identity","+\tsess     *session.Session","+\tflow     *settings.Flow","+\tptc      *identity.PendingTraitsChange","+}","+","+// newApplyPTCFixture constructs a fresh, isolated fixture for each subtest.","+// All objects are persisted to the SQLite test database.","+func newApplyPTCFixture(t *testing.T) *applyPTCFixture {","+\tt.Helper()","+\tctx := context.Background()","+\tconf, reg := pkg.NewFastRegistryWithMocks(t)","+\ttesthelpers.SetDefaultIdentitySchema(conf, \"file://./stub/identity.schema.json\")","+","+\t// Create an identity whose traits will be the baseline for the PTC.","+\ti := &identity.Identity{","+\t\tID:       x.NewUUID(),","+\t\tTraits:   identity.Traits(`{\"email\":\"original@example.com\"}`),","+\t\tSchemaID: \"default\",","+\t\tState:    identity.StateActive,","+\t}","+\trequire.NoError(t, reg.IdentityManager().Create(ctx, i, identity.ManagerAllowWriteProtectedTraits))","+","+\t// Create an active session linked to the identity.","+\tsess, err := testhelpers.NewActiveSession(","+\t\thttptest.NewRequest(http.MethodGet, \"/\", nil),","+\t\treg, i, time.Now().UTC(),","+\t\tidentity.CredentialsTypePassword, identity.AuthenticatorAssuranceLevel1,","+\t)","+\trequire.NoError(t, err)","+\trequire.NoError(t, reg.SessionPersister().UpsertSession(ctx, sess))","+","+\t// Create a settings flow that acts as the origin for the PTC.","+\tf := &settings.Flow{","+\t\tID:              x.NewUUID(),","+\t\tExpiresAt:       time.Now().UTC().Add(time.Hour),","+\t\tIssuedAt:        time.Now().UTC(),","+\t\tRequestURL:      \"http://localhost/settings\",","+\t\tIdentityID:      i.ID,","+\t\tIdentity:        i,","+\t\tType:            flow.TypeBrowser,","+\t\tState:           flow.StateShowForm,","+\t\tInternalContext: []byte(\"{}\"),","+\t}","+\trequire.NoError(t, reg.SettingsFlowPersister().CreateSettingsFlow(ctx, f))","+","+\t// Create a verification flow — the PTC table has a FK on verification_flow_id","+\t// (ON DELETE CASCADE), so we must persist a real verification flow row.","+\tvf, err := verification.NewFlow(conf, time.Hour, nosurfx.FakeCSRFToken,","+\t\thttptest.NewRequest(http.MethodGet, \"/verification\", nil), nil, flow.TypeBrowser)","+\trequire.NoError(t, err)","+\tvf.State = flow.StateEmailSent","+\trequire.NoError(t, reg.VerificationFlowPersister().CreateVerificationFlow(ctx, vf))","+","+\t// Build a PTC that is valid in every field; subtests nil out individual","+\t// fields to trigger the specific guard under test.","+\tsessID := sess.ID","+\toriginFlowID := f.ID","+\tptc := &identity.PendingTraitsChange{","+\t\tID:                   x.NewUUID(),","+\t\tIdentityID:           i.ID,","+\t\tNewAddressValue:      \"new@example.com\",","+\t\tNewAddressVia:        string(identity.AddressTypeEmail),","+\t\tOriginalTraitsHash:   identity.HashTraits(json.RawMessage(i.Traits)),","+\t\tProposedTraits:       json.RawMessage(`{\"email\":\"new@example.com\"}`),","+\t\tVerificationFlowID:   vf.ID,","+\t\tStatus:               identity.PendingTraitsChangeStatusPending,","+\t\tSessionID:            uuid.NullUUID{UUID: sessID, Valid: true},","+\t\tOriginSettingsFlowID: uuid.NullUUID{UUID: originFlowID, Valid: true},","+\t}","+\trequire.NoError(t, reg.PendingTraitsChangePersister().CreatePendingTraitsChange(ctx, ptc))","+","+\treturn &applyPTCFixture{","+\t\treg:      reg,","+\t\tidentity: i,","+\t\tsess:     sess,","+\t\tflow:     f,","+\t\tptc:      ptc,","+\t}","+}","+","+func TestApplyPendingTraitsChange_NilOriginSettingsFlowID(t *testing.T) {","+\tt.Parallel()","+\tfx := newApplyPTCFixture(t)","+","+\t// Simulate a PTC whose OriginSettingsFlowID was never set (malformed writer)","+\t// or was cleared before the apply call.","+\tfx.ptc.OriginSettingsFlowID = uuid.NullUUID{}","+","+\treq := httptest.NewRequest(http.MethodGet, \"/verify\", nil)","+\trw := httptest.NewRecorder()","+","+\t_, err := fx.reg.SettingsHookExecutor().ApplyPendingTraitsChange(req.Context(), rw, req, fx.ptc)","+\trequire.Error(t, err)","+\tassert.ErrorIs(t, err, settings.ErrPendingTraitsChangeSessionInvalid)","+}","+","+// Ensure the fixture itself is valid: a fully-populated PTC must not be","+// rejected. This guards against regressions in the fixture setup.","+func TestApplyPendingTraitsChange_ValidPTC(t *testing.T) {","+\tt.Parallel()","+\tfx := newApplyPTCFixture(t)","+","+\treq := httptest.NewRequest(http.MethodGet, \"/verify\", nil)","+\trw := httptest.NewRecorder()","+","+\tupdated, err := fx.reg.SettingsHookExecutor().ApplyPendingTraitsChange(req.Context(), rw, req, fx.ptc)","+\trequire.NoError(t, err)","+\trequire.NotNil(t, updated)","+}","+","+func TestApplyPendingTraitsChange_NilSessionID(t *testing.T) {","+\tt.Parallel()","+\tfx := newApplyPTCFixture(t)","+","+\tfx.ptc.SessionID = uuid.NullUUID{}","+","+\treq := httptest.NewRequest(http.MethodGet, \"/verify\", nil)","+\trw := httptest.NewRecorder()","+","+\t_, err := fx.reg.SettingsHookExecutor().ApplyPendingTraitsChange(req.Context(), rw, req, fx.ptc)","+\trequire.Error(t, err)","+\tassert.ErrorIs(t, err, settings.ErrPendingTraitsChangeSessionInvalid)","+}","+","+func TestApplyPendingTraitsChange_NIDMismatch(t *testing.T) {","+\tt.Parallel()","+\tfx := newApplyPTCFixture(t)","+","+\t// Simulate a cross-tenant PTC: the PTC's NID differs from the session's NID.","+\tfx.ptc.NID = uuid.Must(uuid.NewV4())","+","+\treq := httptest.NewRequest(http.MethodGet, \"/verify\", nil)","+\trw := httptest.NewRecorder()","+","+\t_, err := fx.reg.SettingsHookExecutor().ApplyPendingTraitsChange(req.Context(), rw, req, fx.ptc)","+\trequire.Error(t, err)","+\tassert.ErrorIs(t, err, settings.ErrPendingTraitsChangeSessionInvalid)","+}","+","+// TestApplyPendingTraitsChange_WebhookReceivesOriginFlow asserts that the","+// post-persist hook chain is invoked with the originating settings flow","+// (not a synthetic one), so webhook payloads carry the real flow ID,","+// type, and request URL.","+func TestApplyPendingTraitsChange_WebhookReceivesOriginFlow(t *testing.T) {","+\tt.Parallel()","+\tctx := context.Background()","+\tconf, reg := pkg.NewFastRegistryWithMocks(t)","+\ttesthelpers.SetDefaultIdentitySchema(conf, \"file://./stub/identity.schema.json\")","+","+\t// Set up a recording webhook target that captures the raw body.","+\treceivedCh := make(chan []byte, 1)","+\twebhookServer := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {","+\t\tbody, _ := io.ReadAll(r.Body)","+\t\tselect {","+\t\tcase receivedCh <- body:","+\t\tdefault:","+\t\t}","+\t\tw.WriteHeader(http.StatusOK)","+\t}))","+\tt.Cleanup(webhookServer.Close)","+","+\t// Register a web_hook as a settings-profile post-persist hook.","+\t// The jsonnet body template `function(ctx) ctx` forwards the entire context,","+\t// which includes the flow object with its ID, type, and request_url.","+\tconf.MustSet(ctx, config.HookStrategyKey(config.ViperKeySelfServiceSettingsAfter, \"profile\"), []map[string]any{","+\t\t{","+\t\t\t\"hook\": \"web_hook\",","+\t\t\t\"config\": map[string]any{","+\t\t\t\t\"url\":    webhookServer.URL,","+\t\t\t\t\"method\": \"POST\",","+\t\t\t\t\"body\":   \"base64://\" + base64.StdEncoding.EncodeToString([]byte(`function(ctx) ctx`)),","+\t\t\t},","+\t\t},","+\t})","+\tt.Cleanup(func() {","+\t\tconf.MustSet(ctx, config.HookStrategyKey(config.ViperKeySelfServiceSettingsAfter, \"profile\"), []map[string]any{})","+\t})","+","+\ti := &identity.Identity{","+\t\tID:       x.NewUUID(),","+\t\tTraits:   identity.Traits(`{\"email\":\"webhooktest@example.com\"}`),","+\t\tSchemaID: \"default\",","+\t\tState:    identity.StateActive,","+\t}","+\trequire.NoError(t, reg.IdentityManager().Create(ctx, i, identity.ManagerAllowWriteProtectedTraits))","+","+\tsess, err := testhelpers.NewActiveSession(","+\t\thttptest.NewRequest(http.MethodGet, \"/\", nil),","+\t\treg, i, time.Now().UTC(),","+\t\tidentity.CredentialsTypePassword, identity.AuthenticatorAssuranceLevel1,","+\t)","+\trequire.NoError(t, err)","+\trequire.NoError(t, reg.SessionPersister().UpsertSession(ctx, sess))","+","+\toriginFlow := &settings.Flow{","+\t\tID:              x.NewUUID(),","+\t\tExpiresAt:       time.Now().UTC().Add(time.Hour),","+\t\tIssuedAt:        time.Now().UTC(),","+\t\tRequestURL:      \"http://localhost/settings?origin=real\",","+\t\tIdentityID:      i.ID,","+\t\tIdentity:        i,","+\t\tType:            flow.TypeAPI,","+\t\tState:           flow.StateShowForm,","+\t\tInternalContext: []byte(\"{}\"),","+\t}","+\trequire.NoError(t, reg.SettingsFlowPersister().CreateSettingsFlow(ctx, originFlow))","+","+\tvf, err := verification.NewFlow(conf, time.Hour, nosurfx.FakeCSRFToken,","+\t\thttptest.NewRequest(http.MethodGet, \"/verification\", nil), nil, flow.TypeBrowser)","+\trequire.NoError(t, err)","+\tvf.State = flow.StateEmailSent","+\trequire.NoError(t, reg.VerificationFlowPersister().CreateVerificationFlow(ctx, vf))","+","+\tsessID := sess.ID","+\toriginFlowID := originFlow.ID","+\tptc := &identity.PendingTraitsChange{","+\t\tID:                   x.NewUUID(),","+\t\tIdentityID:           i.ID,","+\t\tNewAddressValue:      \"webhooktest-new@example.com\",","+\t\tNewAddressVia:        string(identity.AddressTypeEmail),","+\t\tOriginalTraitsHash:   identity.HashTraits(json.RawMessage(i.Traits)),","+\t\tProposedTraits:       json.RawMessage(`{\"email\":\"webhooktest-new@example.com\"}`),","+\t\tVerificationFlowID:   vf.ID,","+\t\tStatus:               identity.PendingTraitsChangeStatusPending,","+\t\tSessionID:            uuid.NullUUID{UUID: sessID, Valid: true},","+\t\tOriginSettingsFlowID: uuid.NullUUID{UUID: originFlowID, Valid: true},","+\t}","+\trequire.NoError(t, reg.PendingTraitsChangePersister().CreatePendingTraitsChange(ctx, ptc))","+","+\treq := httptest.NewRequest(http.MethodGet, \"/verify\", nil)","+\trw := httptest.NewRecorder()","+\t_, err = reg.SettingsHookExecutor().ApplyPendingTraitsChange(req.Context(), rw, req, ptc)","+\trequire.NoError(t, err)","+","+\tvar receivedBody []byte","+\tselect {","+\tcase receivedBody = <-receivedCh:","+\tcase <-time.After(5 * time.Second):","+\t\tt.Fatal(\"settings post-persist webhook was not invoked after pending traits change applied\")","+\t}","+","+\t// The webhook payload should carry the real origin settings flow's ID and","+\t// request URL — not values from a synthetic flow.","+\tassert.Contains(t, string(receivedBody), originFlow.ID.String(),","+\t\t\"webhook payload should contain the real origin settings flow ID\")","+\tassert.Contains(t, string(receivedBody), \"http://localhost/settings?origin=real\","],"additions":285,"deletions":0,"truncated":false}],"additions":528,"deletions":57,"truncated":true,"file_count":12},"error":null,"fetched_at":"2026-05-20T17:43:03.204234+00:00"}