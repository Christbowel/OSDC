++                // linear memory rather than boxing each byte individually.","++                let ptr = cx.realloc(0, 0, 1, bytes.len())?;","++                cx.as_slice_mut()[ptr..][..bytes.len()].copy_from_slice(bytes);","++                // FIXME(#4311): needs memory64 handling","++                *cx.get(offset + 0) = u32::try_from(ptr).unwrap().to_le_bytes();","++                *cx.get(offset + 4) = u32::try_from(bytes.len()).unwrap().to_le_bytes();","++                Ok(())","++            }","+             (InterfaceType::List(_), _) => unexpected(ty, self),","+             (InterfaceType::Map(ty_idx), Val::Map(values)) => {","+                 let map_ty = &cx.types[ty_idx];","+@@ -690,6 +711,7 @@","+             Val::Float64(_) => \"f64\",","+             Val::Char(_) => \"char\",","+             Val::List(_) => \"list\",","++            Val::Bytes(_) => \"list\",","+             Val::Map(_) => \"map\",","+             Val::String(_) => \"string\",","+             Val::Record(_) => \"record\",","+@@ -765,6 +787,8 @@","+             (Self::String(_), _) => false,","+             (Self::List(l), Self::List(r)) => l == r,","+             (Self::List(_), _) => false,","++            (Self::Bytes(l), Self::Bytes(r)) => l == r,","++            (Self::Bytes(_), _) => false,","+             (Self::Map(l), Self::Map(r)) => l == r,","+             (Self::Map(_), _) => false,","+             (Self::Record(l), Self::Record(r)) => l == r,"],"additions":62,"deletions":0,"truncated":false},{"path":"bazel/wasmtime/val_bytes_wast_fast_path.patch","lines":["@@ -0,0 +1,10 @@","+--- a/src/component.rs","+@@ -291,6 +291,7 @@","+         Val::Stream(..) => \"stream\",","+         Val::ErrorContext(..) => \"error-context\",","+         Val::Map(..) => \"map\",","++        Val::Bytes(..) => \"list\",","+     };","+     bail!(\"expected `{expected}` got `{actual}`\")","+ }"],"additions":9,"deletions":0,"truncated":false},{"path":"bazel/wasmtime/val_bytes_wave_fast_path.patc