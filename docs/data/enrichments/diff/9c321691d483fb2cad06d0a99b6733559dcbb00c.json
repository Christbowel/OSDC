yft/file\"","+\t\"github.com/anchore/syft/syft/format/internal\"","+\t\"github.com/anchore/syft/syft/format/internal/spdxutil/helpers\"","+\t\"github.com/anchore/syft/syft/license\"","+\t\"github.com/anchore/syft/syft/linux\"","+\t\"github.com/anchore/syft/syft/pkg\"","+\t\"github.com/anchore/syft/syft/sbom\"","+\t\"github.com/anchore/syft/syft/source\"","+)","+","+func ToSyftModelV3(doc *spdx.Document) (*sbom.SBOM, error) {","+\tif doc == nil {","+\t\treturn nil, errors.New(\"cannot convert SPDX document to Syft model because document is nil\")","+\t}","+","+\tspdxMap := ptrMap[any]{}","+","+\ts := &sbom.SBOM{","+\t\tSource: v3extractSource(spdxMap, doc),","+\t\tArtifacts: sbom.Artifacts{","+\t\t\tPackages:          pkg.NewCollection(),","+\t\t\tFileMetadata:      map[file.Coordinates]file.Metadata{},","+\t\t\tFileDigests:       map[file.Coordinates][]file.Digest{},","+\t\t\tLinuxDistribution: v3findLinuxReleaseByPURL(doc),","+\t\t},","+\t}","+","+\trelationships := v3relationshipMap(doc)","+","+\tv3collectSyftPackages(s, spdxMap, relationships, doc)","+","+\tv3collectSyftFiles(s, spdxMap, doc)","+","+\ts.Relationships = v3toSyftRelationships(spdxMap, doc)","+","+\treturn s, nil","+}","+","+func v3removePackage(packages spdx.ElementList, remove spdx.AnyPackage) (pkgs spdx.ElementList) {","+\tfor _, p := range packages {","+\t\tif p == remove {","+\t\t\tcontinue","+\t\t}","+\t\tpkgs = append(pkgs, p)","+\t}","+\treturn pkgs","+}","+","+func v3removeRelationships(elements spdx.ElementList, element spdx.AnyElement) (relations spdx.ElementList) {","+\tfor _, e := range elements {","+\t\tif r, ok := e.(spdx.AnyRelationship); ok {","+\t\t\tif r != nil && r.GetFrom() == element {","+\t\t\t\tcontinue","+\t\t\t}","+","+\t\t\tif r != nil {","+\t\t\t\tvar tos spdx.ElementList","+\t\t\t\tfor _, to := range r.GetTo() {","+\t\t\t\t\tif to == element {","+\t\t\t\t\t\tcontinue","+\t\t\t\t\t}","+\t\t\t\t\ttos = append(tos, to)","+\t\t\t\t}","+\t\t\t\tr.SetTo(tos)","+\t\t\t\tif len(r.GetTo()) == 0 {","+\t\t\t\t\tcontinue","+\t\t\t\t}","+\t\t\t}","+","+\t\t\trelations = append(relations, r)","+\t\t} else {","+\t\t\trelations = append(relations, e)","+\t\t}","+\t}","+\treturn relations","+}","+","+func v3findRootPackages(doc spdx.AnyElementCollection) (out spdx.PackageList) {","+\tfor _, p := range doc.GetRootElements().Packages() {","+\t\tout = append(out, p)","+\t}","+\tfor _, s := range doc.GetRootElements().SBOMs() {","+\t\tfor _, p := range s.GetRootElements().Packages() {","+\t\t\tout = append(out, p)","+\t\t}","+\t}","+\treturn","+}","+","+func v3extractSource(spdxMap ptrMap[any], doc *spdx.Document) source.Description {","+\tnamespace := doc.ID","+\tif namespace == \"\" && len(doc.NamespaceMaps) > 0 {","+\t\tnamespace = string(doc.NamespaceMaps[0].GetNamespace())","+\t}","+\tsrc := extractSourceFromNamespace(namespace)","+","+\trootPackages := v3findRootPackages(doc)","+","+\tif len(rootPackages) != 1 {","+\t\treturn src","+\t}","+","+\tp := rootPackages[0]","+","+\tswitch p.GetPrimaryPurpose() {","+\tcase spdx.SoftwarePurpose_Container:","+\t\tsrc = v3containerSource(p)","+\tcase spdx.SoftwarePurpose_File:","+\t\tsrc = v3fileSource(p)","+\tdefault:","+\t\treturn src","+\t}","+","+\tspdxMap.Set(p, src)","+","+\tdoc.Elements = v3removePackage(doc.Elements, p)","+\tdoc.Elements = v3removeRelationships(doc.Elements, p)","+","+\treturn src","+}","+","+func v3containerSource(p spdx.AnyPackage) source.Description {","+\tcontainer := p.GetName()","+\tv := p.GetVersion()","+\tif v != \"\" {","+\t\tcontainer += \":\" + v","+\t}","+","+\tdigest := \"\"","+\tif len(p.GetVerifiedUsing().Hashes()) > 0 {","+\t\th := p.GetVerifiedUsing().Hashes()[0]","+\t\tif h != nil {","+\t\t\tdigest = fmt.Sprintf(\"%s:%s\", v3fromChecksumAlgorithm(h.GetAlgorithm()), h.GetValue())","+\t\t}","+\t}","+","+\tsupplier := \"\"","+\tif p.GetSuppliedBy() != nil {","+\t\tsupplier = v3agentString(p.GetSuppliedBy())","+\t}","+","+\treturn source.Description{","+\t\tID:       p.GetID(),","+\t\tName:     p.GetName(),","+\t\tVersion:  p.GetVersion(),","+\t\tSupplier: supplier,","+\t\tMetadata: source.ImageMetadata{","+\t\t\tUserInput:      container,","+\t\t\tID:             p.GetID(),","+\t\t\tLayers:         nil, // TODO handle formats with nested layer packages like Tern and K8s BOM tool","+\t\t\tManifestDigest: digest,","+\t\t},","+\t}","+}","+","+func v3fileSource(p spdx.AnyPackage) source.Description {","+\ttypeRegex := regexp.MustCompile(\"DocumentRoot-([^-]+)-.*$\")","+\ttypeName := typeRegex.ReplaceAllString(p.GetID(), \"$1\")","+","+\tvar version string","+\tvar metadata any","+\tswitch {","+\tcase typeName == prefixDirectory:","+\t\t// is a Syft SBOM, explicitly a directory source","+\t\tmetadata, version = v3directorySourceMetadata(p)","+\tcase typeName == prefixFile:","+\t\t// is a Syft SBOM, explicitly a file source","+\t\tmetadata, version = v3fileSourceMetadata(p)","+\tcase isDirectory(p.GetName()):","+\t\t// is a non-Syft SBOM, which looks like a directory","+\t\tmetadata, version = v3directorySourceMetadata(p)","+\tdefault:","+\t\t// is a non-Syft SBOM, which is probably a file","+\t\tmetadata, version = v3fileSourceMetadata(p)","+\t}","+","+\tsupplier := \"\"","+\tif p.GetSuppliedBy() != nil {","+\t\tsupplier = p.GetSuppliedBy().GetName()","+\t}","+","+\treturn source.Description{","+\t\tID:       p.GetID(),","+\t\tName:     p.GetName(),","+\t\tVersion:  version,","+\t\tSupplier: supplier,","+\t\tMetadata: metadata,","+\t}","+}","+","+func v3fileSourceMetadata(p spdx.AnyPackage) (any, string) {","+\tversion := p.GetVersion()","+","+\tm := source.FileMetadata{","+\t\tPath: p.GetName(),","+\t}","+\t// if this is a Syft SBOM, we might have output a digest as the version","+\tchecksum := v3toChecksum(p.GetVersion())","+\tfor _, d := range p.GetVerifiedUsing().Hashes() {","+\t\tif checksum != nil && checksum.GetValue() == d.GetValue() {","+\t\t\tversion = \"\"","+\t\t}","+\t\tm.Digests = append(m.Digests, file.Digest{","+\t\t\tAlgorithm: v3fromChecksumAlgorithm(d.GetAlgorithm()),","+\t\t\tValue:     d.GetValue(),","+\t\t})","+\t}","+","+\treturn m, version","+}","+","+func v3directorySourceMetadata(p spdx.AnyPackage) (any, string) {","+\treturn source.DirectoryMetadata{","+\t\tPath: p.GetName(),","+\t\tBase: \"\",","+\t}, p.GetVersion()","+}","+","+func v3findLinuxReleaseByPURL(doc *spdx.Document) *linux.Release {","+\tfor _, p := range doc.Elements.Packages() {","+\t\tpurlValue := v3findPURLValue(p)","+\t\tif purlValue == \"\" {","+\t\t\tcontinue","+\t\t}","+\t\tpurl, err := packageurl.FromString(purlValue)","+\t\tif err != nil {","+\t\t\tlog.Warnf(\"unable to parse purl: %s\", purlValue)","+\t\t\tcontinue","+\t\t}","+\t\tdistro := v3findQualifierValue(purl, pkg.PURLQualifierDistro)","+\t\tif distro != \"\" {","+\t\t\tparts := strings.Split(distro, \"-\")","+\t\t\tname := parts[0]","+\t\t\tversion := \"\"","+\t\t\tif len(parts) > 1 {","+\t\t\t\tversion = parts[1]","+\t\t\t}","+\t\t\treturn &linux.Release{","+\t\t\t\tPrettyName: name,","+\t\t\t\tName:       name,","+\t\t\t\tID:         name,","+\t\t\t\tIDLike:     []string{name},","+\t\t\t\tVersion:    version,","+\t\t\t\tVersionID:  version,","+\t\t\t}","+\t\t}","+\t}","+","+\treturn nil","+}","+","+func v3collectSyftPackages(s *sbom.SBOM, spdxMap ptrMap[any], relationships ptrMap[[]spdx.AnyRelationship], doc *spdx.Document) {","+\tskipIDs := v3packageIDsToSkip(doc)","+\tfound := ptrMap[struct{}]{}","+\t// tools-golang collects all elements from the JSON LD @graph to the root SpdxDocument.Elements property","+\tfor _, elementList := range []spdx.ElementList{doc.Elements, doc.RootElements} {","+\t\tfor _, p := range elementList.Packages() {","+\t\t\tif p == nil || skipIDs.Has(p) || found.Has(p) {","+\t\t\t\tcontinue","+\t\t\t}","+\t\t\tfound.Set(p, struct{}{})","+\t\t\tsyftPkg := v3toSyftPackage(relationships, p)","+\t\t\tspdxMap.Set(p, syftPkg)","+\t\t\ts.Artifacts.Packages.Add(syftPkg)","+\t\t}","+\t}","+}","+","+func v3collectSyftFiles(s *sbom.SBOM, spdxMap ptrMap[any], doc *spdx.Document) {","+\tfound := ptrMap[struct{}]{}","+\tfor _, elementList := range []spdx.ElementList{doc.Elements, doc.RootElements} {","+\t\tfor _, f := range elementList.Files() {","+\t\t\tif found.Has(f) {","+\t\t\t\tcontinue","+\t\t\t}","+\t\t\tfound.Set(f, struct{}{})","+\t\t\tl := v3toSyftLocation(f)","+\t\t\tspdxMap.Set(f, l)","+","+\t\t\ts.Artifacts.FileMetadata[l.Coordinates] = v3toFileMetadata(f)","+\t\t\ts.Artifacts.FileDigests[l.Coordinates] = v3toFileDigests(f)","+\t\t}","+\t}","+}","+","+func v3toFileDigests(f spdx.AnyFile) (digests []file.Digest) {","+\tfor _, h := range f.GetVerifiedUsing().Hashes() {","+\t\tdigests = append(digests, file.Digest{","+\t\t\tAlgorithm: v3fromChecksumAlgorithm(h.GetAlgorithm()),","+\t\t\tValue:     h.GetValue(),","+\t\t})","+\t}","+\treturn digests","+}","+","+func v3fromChecksumAlgorithm(algorithm spdx.HashAlgorithm) string {","+\t// it might be better to have a specific case statement with constants","+\tparts := strings.Split(algorithm.GetID(), \"/\")","+\treturn strings.ToLower(parts[len(parts)-1])","+}","+","+func v3toFileMetadata(f spdx.AnyFile) (meta file.Metadata) {","+\t// FIXME Syft is currently lossy due to the SPDX 2.2.1 spec not supporting arbitrary mimetypes","+\tif f.GetContentType() != \"\" {","+\t\tmeta.MIMEType = f.GetContentType()","+\t}","+\treturn meta","+}","+","+func v3toSyftRelationships(spdxMap ptrMap[any], doc *spdx.Document) []artifact.Relationship {","+\tout := v3collectDocRelationships(spdxMap, doc)","+","+\treturn out","+}","+","+//nolint:gocognit","+func v3collectDocRelationships(spdxMap ptrMap[any], doc *spdx.Document) (out []artifact.Relationship) {","+\tfor _, r := range doc.Elements.Relationships() {","+\t\tfrom := r.GetFrom()","+\t\tif from == nil || from.GetID() == \"\" {","+\t\t\tlog.Debugf(\"ignoring relationship to external document: %+v\", r)","+\t\t\tcontinue","+\t\t}","+\t\ta := spdxMap.Get(from)","+","+\t\tfor _, to := range r.GetTo() {","+\t\t\tb := spdxMap.Get(to)","+\t\t\tfrom, fromOk := a.(pkg.Package)","+\t\t\ttoPackage, toPackageOk := b.(pkg.Package)","+\t\t\ttoLocation, toLocationOk := b.(file.Location)","+\t\t\t//nolint:staticcheck","+\t\t\tif !fromOk || !(toPackageOk || toLocationOk) {","+\t\t\t\tlog.Debugf(\"unable to find valid relationship mapping from SPDX, ignoring: (from: %+v) (to: %+v)\", a, b)","+\t\t\t\tcontinue","+\t\t\t}","+\t\t\tvar to artifact.Identifiable","+\t\t\tvar typ artifact.RelationshipType","+\t\t\tif toLocationOk {","+\t\t\t\tswitch r.GetType() {","+\t\t\t\tcase spdx.RelationshipType_Contains:","+\t\t\t\t\ttyp = artifact.ContainsRelationship","+\t\t\t\t\tto = toLocation","+\t\t\t\tcase spdx.RelationshipType_Other:","+\t\t\t\t\t// Encoding uses a specifically formatted comment...","+\t\t\t\t\tif strings.HasPrefix(r.GetComment(), string(artifact.EvidentByRelationship)) {","+\t\t\t\t\t\ttyp = artifact.EvidentByRelationship","+\t\t\t\t\t\tto = toLocation","+\t\t\t\t\t}","+\t\t\t\t}","+\t\t\t} else {","+\t\t\t\tswitch r.GetType() {","+\t\t\t\tcase spdx.RelationshipType_DependsOn:","+\t\t\t\t\ttyp = artifact.DependencyOfRelationship","+\t\t\t\t\tto = from","+\t\t\t\t\tfrom = toPackage","+\t\t\t\tcase spdx.RelationshipType_Contains:","+\t\t\t\t\ttyp = artifact.ContainsRelationship","+\t\t\t\t\tto = toPackage","+\t\t\t\tcase spdx.RelationshipType_Other:","+\t\t\t\t\t// Encoding uses a specifically formatted comment...","+\t\t\t\t\tif strings.HasPrefix(r.GetComment(), string(artifact.OwnershipByFileOverlapRelationship)) {","+\t\t\t\t\t\ttyp = artifact.OwnershipByFileOverlapRelationship","+\t\t\t\t\t\tto = toPackage","+\t\t\t\t\t}","+\t\t\t\t}","+\t\t\t}","+\t\t\tif typ != \"\" && to != nil {","+\t\t\t\tout = append(out, artifact.Relationship{","+\t\t\t\t\tFrom: from,","+\t\t\t\t\tTo:   to,","+\t\t\t\t\tType: typ,","+\t\t\t\t})","+\t\t\t}","+\t\t}","+\t}","+\treturn out","+}","+","+func v3toSyftCoordinates(f spdx.AnyFile) file.Coordinates {","+\tconst layerIDPrefix = \"layerID: \"","+\tvar fileSystemID string","+\tif strings.HasPrefix(f.GetComment(), layerIDPrefix) {","+\t\tfileSystemID = strings.TrimPrefix(f.GetComment(), layerIDPrefix)","+\t}","+\tif strings.HasPrefix(f.GetID(), layerIDPrefix) {","+\t\tfileSystemID = strings.TrimPrefix(f.GetID(), layerIDPrefix)","+\t}","+\treturn file.Coordinates{","+\t\tRealPath:     f.GetName(),","+\t\tFileSystemID: fileSystemID,","+\t}","+}","+","+func v3toSyftLocation(f spdx.AnyFile) file.Location {","+\tl := file.NewVirtualLocationFromCoordinates(v3toSyftCoordinates(f), f.GetName())","+\treturn l","+}","+","+func v3findQualifierValue(purl packageurl.PackageURL, qualifier string) string {","+\tfor _, q := range purl.Qualifiers {","+\t\tif q.Key == qualifier {","+\t\t\treturn q.Value","+\t\t}","+\t}","+\treturn \"\"","+}","+","+func v3extractPkgInfo(p spdx.AnyPackage) pkgInfo {","+\tpu := v3findPURLValue(p)","+\tpurl, err := packageurl.FromString(pu)","+\tif err != nil {","+\t\treturn pkgInfo{}","+\t}","+\treturn pkgInfo{","+\t\tpurl,","+\t\tpkg.TypeByName(purl.Type),","+\t\tpkg.LanguageByName(purl.Type),","+\t}","+}","+","+func v3toSyftPackage(relationships ptrMap[[]spdx.AnyRelationship], p spdx.AnyPackage) pkg.Package {","+\tinfo := v3extractPkgInfo(p)","+\tsP := &pkg.Package{","+\t\tType:     info.typ,","+\t\tName:     p.GetName(),","+\t\tVersion:  p.GetVersion(),","+\t\tLicenses: pkg.NewLicenseSet(v3parseSPDXLicenses(relationships, p)...),","+\t\tCPEs:     v3extractCPEs(p),","+\t\tPURL:     v3purlValue(info.purl),","+\t\tLanguage: info.lang,","+\t\tMetadata: v3extractMetadata(p, info),","+\t}","+","+\tinternal.Backfill(sP)","+","+\tif p.GetID() != \"\" {","+\t\t// always prefer the IDs from the SBOM over derived IDs","+\t\tsP.OverrideID(artifact.ID(p.GetID()))","+\t} else {","+\t\tsP.SetID()","+\t}","+","+\treturn *sP","+}","+","+func v3purlValue(purl packageurl.PackageURL) string {","+\tval := purl.String()","+\tif _, err := packageurl.FromString(val); err != nil {","+\t\treturn \"\"","+\t}","+\treturn val","+}","+","+func v3parseSPDXLicenses(relationships ptrMap[[]spdx.AnyRelationship], p spdx.AnyPackage) []pkg.License {","+\tlicenses := make([]pkg.License, 0)","+","+\t// licenses are defined with relationships in SPDX 3, see:","+\t// https://github.com/spdx/tools-golang/blob/spdx3/spdx/v3/v3_0/convert.go#L536","+\trels := relationships.Get(p)","+\tfor _, r := range rels {","+\t\tif r.GetType() == spdx.RelationshipType_HasConcludedLicense {","+\t\t\tlicenses = append(licenses, v3toSyftLicenses(license.Concluded, r.GetTo().LicenseInfos()...)...)","+\t\t}","+\t\tif r.GetType() == spdx.RelationshipType_HasDeclaredLicense {","+\t\t\tlicenses = append(licenses, v3toSyftLicenses(license.Declared, r.GetTo().LicenseInfos()...)...)","+\t\t}","+\t}","+","+\treturn licenses","+}","+","+func v3toSyftLicenses(licenseType license.Type, licenses ...spdx.AnyLicenseInfo) []pkg.License {","+\tvar out []pkg.License","+\tfor _, lic := range licenses {","+\t\tif lic == nil {","+\t\t\tcontinue","+\t\t}","+\t\tvalue := v3licenseInfoToExpression(lic)","+\t\tif value == \"\" {","+\t\t\tlog.Debugf(\"skipping SPDX license during import: %#v\", lic)","+\t\t\tcontinue","+\t\t}","+\t\tl := pkg.NewLicense(value)","+\t\tif l.Value != \"\" {","+\t\t\tl.Type = licenseType","+\t\t\tout = append(out, l)","+\t\t}","+\t}","+\treturn out","+}","+","+// v3licenseInfoToExpression recursively converts an SPDX 3.0 license info object to an SPDX expression string.","+func v3licenseInfoToExpression(info spdx.AnyLicenseInfo) string {","+\tswitch li := info.(type) {","+\tcase spdx.AnyLicenseExpression:","+\t\treturn li.GetLicenseExpression()","+\tcase spdx.AnyOrLaterOperator:","+\t\tsubject := v3licenseInfoToExpression(li.GetSubjectLicense())","+\t\tif subject != \"\" && !strings.HasSuffix(subject, \"+\") {","+\t\t\treturn subject + \"+\"","+\t\t}","+\tcase spdx.AnyWithAdditionOperator:","+\t\tsubject := v3licenseInfoToExpression(li.GetSubjectExtendableLicense())","+\t\taddition := li.GetSubjectAddition()","+\t\tif subject != \"\" && addition != nil {","+\t\t\treturn subject + \" WITH \" + addition.GetAdditionText()","+\t\t}","+\tcase spdx.AnyConjunctiveLicenseSet:","+\t\tvar parts []string","+\t\tfor _, m := range li.GetMembers() {","+\t\t\tif e := v3licenseInfoToExpression(m); e != \"\" {","+\t\t\t\tparts = append(parts, e)","+\t\t\t}","+\t\t}","+\t\tif len(parts) > 0 {","+\t\t\treturn strings.Join(parts, \" AND \")","+\t\t}","+\tcase spdx.AnyDisjunctiveLicenseSet:","+\t\tvar parts []string","+\t\tfor _, m := range li.GetMembers() {","+\t\t\tif e := v3licenseInfoToExpression(m); e != \"\" {","+\t\t\t\tparts = append(parts, e)","+\t\t\t}","+\t\t}","+\t\tif len(parts) > 0 {","+\t\t\treturn \"(\" + strings.Join(parts, \" OR \") + \")\"","+\t\t}","+\tcase spdx.AnyListedLicense:","+\t\treturn li.GetName()","+\tcase spdx.AnyCustomLicense:","+\t\tif li.GetID() != \"\" {","+\t\t\treturn li.GetID()","+\t\t}","+\t\treturn li.GetName()","+\t}","+\treturn \"\"","+}","+","+//nolint:funlen","+func v3extractMetadata(p spdx.AnyPackage, info pkgInfo) any {","+\tarch := info.qualifierValue(pkg.PURLQualifierArch)","+\tupstreamValue := info.qualifierValue(pkg.PURLQualifierUpstream)","+\tupstream := strings.SplitN(upstreamValue, \"@\", 2)","+\tupstreamName := upstream[0]","+\tupstreamVersion := \"\"","+\tif len(upstream) > 1 {","+\t\tupstreamVersion = upstream[1]","+\t}","+\tsupplier := \"\"","+\tif p.GetSuppliedBy() != nil {","+\t\tsupplier = v3agentString(p.GetSuppliedBy())","+\t}","+\toriginator := \"\"","+\tif len(p.GetOriginatedBy()) > 0 {","+\t\t// FIXME there could be multiple","+\t\toriginator = v3agentString(p.GetOriginatedBy()[0])","+\t}","+\tswitch info.typ {","+\tcase pkg.ApkPkg:","+\t\treturn pkg.ApkDBEntry{","+\t\t\tPackage:       p.GetName(),","+\t\t\tOriginPackage: upstreamName,","+\t\t\tMaintainer:    supplier,","+\t\t\tVersion:       p.GetVersion(),","+\t\t\tArchitecture:  arch,","+\t\t\tURL:           string(p.GetHomePage()),","+\t\t\tDescription:   p.GetDescription(),","+\t\t}","+\tcase pkg.RpmPkg:","+\t\tconverted, err := strconv.Atoi(info.qualifierValue(pkg.PURLQualifierEpoch))","+\t\tvar epoch *int","+\t\tif err != nil {","+\t\t\tepoch = nil","+\t\t} else {","+\t\t\tepoch = &converted","+\t\t}","+\t\treturn pkg.RpmDBEntry{","+\t\t\tName:      p.GetName(),","+\t\t\tVersion:   p.GetVersion(),","+\t\t\tEpoch:     epoch,","+\t\t\tArch:      arch,","+\t\t\tSourceRpm: upstreamValue,","+\t\t\tVendor:    originator,"],"additions":774,"deletions":0,"truncated":true},{"path":"syft/format/common/spdxhelpers/to_syft_model_v3_test.go","lines":["@@ -0,0 +1,436 @@","+package spdxhelpers","+","+import (","+\t\"testing\"","+","+\tspdx \"github.com/spdx/tools-golang/spdx/v3/v3_0\"","+\t\"github.com/stretchr/testify/assert\"","+\t\"github.com/stretchr/testify/require\"","+","+\t\"github.com/anchore/syft/syft/artifact\"","+\t\"github.com/anchore/syft/syft/file\"","+\t\"github.com/anchore/syft/syft/license\"","+\t\"github.com/anchore/syft/syft/pkg\"","+)","+","+func TestToSyftModelV3_documentConversion(t *testing.T) {","+\t// Build SPDX 3.0 elements","+\tpkg1 := &spdx.Package{","+\t\tID:      \"pkg-1-id\",","+\t\tName:    \"pkg-1\",","+\t\tVersion: \"1.0.0\",","+\t\tExternalIdentifiers: spdx.ExternalIdentifierList{","+\t\t\t&spdx.ExternalIdentifier{","+\t\t\t\tType:               spdx.ExternalIdentifierType_PackageURL,","+\t\t\t\tIdentifier:         \"pkg:npm/pkg-1@1.0.0\",","+\t\t\t\tIdentifierLocators: []spdx.URI{\"pkg:npm/pkg-1@1.0.0\"},","+\t\t\t},","+\t\t},","+\t}","+\tpkg2 := &spdx.Package{","+\t\tID:      \"pkg-2-id\",","+\t\tName:    \"pkg-2\",","+\t\tVersion: \"2.0.0\",","+\t\tExternalIdentifiers: spdx.ExternalIdentifierList{","+\t\t\t&spdx.ExternalIdentifier{","+\t\t\t\tType:               spdx.ExternalIdentifierType_PackageURL,","+\t\t\t\tIdentifier:         \"pkg:npm/pkg-2@2.0.0\",","+\t\t\t\tIdentifierLocators: []spdx.URI{\"pkg:npm/pkg-2@2.0.0\"},","+\t\t\t},","+\t\t},","+\t}","+","+\tfile1 := &spdx.File{","+\t\tID:   \"file-1-id\",","+\t\tName: \"/src/main.go\",","+\t\tVerifiedUsing: spdx.IntegrityMethodList{","+\t\t\t&spdx.Hash{","+\t\t\t\tAlgorithm: spdx.HashAlgorithm_Sha256,","+\t\t\t\tValue:     \"abc123\",","+\t\t\t},","+\t\t},","+\t}","+\tfile2 := &spdx.File{","+\t\tID:   \"file-2-id\",","+\t\tName: \"/src/util.go\",","+\t}","+","+\t// licenses","+\tpkg1ConcludedLicense := &spdx.ListedLicense{Name: \"MIT\"}","+\tpkg1DeclaredLicense := &spdx.DisjunctiveLicenseSet{","+\t\tMembers: spdx.LicenseInfoList{","+\t\t\t&spdx.ListedLicense{Name: \"MIT\"},","+\t\t\t&spdx.ListedLicense{Name: \"Apache-2.0\"},","+\t\t},","+\t}","+\tpkg2ConcludedLicense := &spdx.ConjunctiveLicenseSet{","+\t\tMembers: spdx.LicenseInfoList{","+\t\t\t&spdx.ListedLicense{Name: \"BSD-3-Clause\"},","+\t\t\t&spdx.OrLaterOperator{","+\t\t\t\tSubjectLicense: &spdx.ListedLicense{Name: \"GPL-2.0\"},","+\t\t\t},","+\t\t},","+\t}","+","+\t// relationships","+\tpkg1DependsOnPkg2 := &spdx.Relationship{","+\t\tFrom: pkg1,","+\t\tTo:   spdx.ElementList{pkg2},","+\t\tType: spdx.RelationshipType_DependsOn,","+\t}","+\tpkg1ContainsFile1 := &spdx.Relationship{","+\t\tFrom: pkg1,","+\t\tTo:   spdx.ElementList{file1},","+\t\tType: spdx.RelationshipType_Contains,","+\t}","+\tpkg2ContainsFile2 := &spdx.Relationship{","+\t\tFrom: pkg2,","+\t\tTo:   spdx.ElementList{file2},","+\t\tType: spdx.RelationshipType_Contains,","+\t}","+\tpkg1HasConcludedLicense := &spdx.Relationship{","+\t\tFrom: pkg1,","+\t\tTo:   spdx.ElementList{pkg1ConcludedLicense},","+\t\tType: spdx.RelationshipType_HasConcludedLicense,","+\t}","+\tpkg1HasDeclaredLicense := &spdx.Relationship{","+\t\tFrom: pkg1,","+\t\tTo:   spdx.ElementList{pkg1DeclaredLicense},","+\t\tType: spdx.RelationshipType_HasDeclaredLicense,","+\t}","+\tpkg2HasConcludedLicense := &spdx.Relationship{","+\t\tFrom: pkg2,","+\t\tTo:   spdx.ElementList{pkg2ConcludedLicense},","+\t\tType: spdx.RelationshipType_HasConcludedLicense,","+\t}","+","+\tsbomElement := &spdx.SBOM{","+\t\tRootElements: spdx.ElementList{pkg1},","+\t\tElements: spdx.ElementList{","+\t\t\tpkg1, pkg2,","+\t\t\tfile1, file2,","+\t\t\tpkg1DependsOnPkg2,","+\t\t\tpkg1ContainsFile1,","+\t\t\tpkg2ContainsFile2,","+\t\t\tpkg1HasConcludedLicense,","+\t\t\tpkg1HasDeclaredLicense,","+\t\t\tpkg2HasConcludedLicense,","+\t\t},","+\t}","+","+\tdoc := &spdx.Document{","+\t\tSpdxDocument: spdx.SpdxDocument{","+\t\t\tID:           \"https://example.org/test-doc\",","+\t\t\tName:         \"test-document\",","+\t\t\tRootElements: spdx.ElementList{sbomElement},","+\t\t\tElements: spdx.ElementList{","+\t\t\t\tsbomElement,","+\t\t\t\tpkg1, pkg2,","+\t\t\t\tfile1, file2,","+\t\t\t\tpkg1DependsOnPkg2,","+\t\t\t\tpkg1ContainsFile1,","+\t\t\t\tpkg2ContainsFile2,","+\t\t\t\tpkg1HasConcludedLicense,","+\t\t\t\tpkg1HasDeclaredLicense,","+\t\t\t\tpkg2HasConcludedLicense,","+\t\t\t},","+\t\t},","+\t}","+","+\t// Convert","+\tresult, err := ToSyftModelV3(doc)","+\trequire.NoError(t, err)","+\trequire.NotNil(t, result)","+","+\t// Verify packages","+\tallPkgs := result.Artifacts.Packages.Sorted()","+\trequire.Len(t, allPkgs, 2, \"expected 2 packages\")","+","+\tpkgsByName := map[string]pkg.Package{}","+\tfor _, p := range allPkgs {","+\t\tpkgsByName[p.Name] = p","+\t}","+","+\tsyftPkg1, ok := pkgsByName[\"pkg-1\"]","+\trequire.True(t, ok, \"pkg-1 not found\")","+\tassert.Equal(t, \"1.0.0\", syftPkg1.Version)","+\tassert.Equal(t, \"pkg:npm/pkg-1@1.0.0\", syftPkg1.PURL)","+","+\tsyftPkg2, ok := pkgsByName[\"pkg-2\"]","+\trequire.True(t, ok, \"pkg-2 not found\")","+\tassert.Equal(t, \"2.0.0\", syftPkg2.Version)","+\tassert.Equal(t, \"pkg:npm/pkg-2@2.0.0\", syftPkg2.PURL)","+","+\t// Verify pkg-1 licenses: concluded MIT + declared (MIT OR Apache-2.0)"],"additions":164,"deletions":0,"truncated":false}],"additions":965,"deletions":19,"truncated":true,"file_count":7},"error":null,"fetched_at":"2026-06-23T10:52:38.859618+00:00"}