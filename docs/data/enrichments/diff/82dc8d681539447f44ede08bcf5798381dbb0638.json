tt.Run(\"ondemand-versioned\", func(t *testing.T) {","+\t\texpect := buildExpect(t)","+\t\ts := xds.NewFakeDiscoveryServer(t, xds.FakeOptions{","+\t\t\tKubernetesObjects: []runtime.Object{mkPod(\"pod\", \"sa\", \"127.0.0.1\", \"not-node\")},","+\t\t})","+\t\tads := s.ConnectDeltaADS().WithType(v3.AddressType).WithMetadata(model.NodeMetadata{NodeName: \"node\"})","+\t\tads.Request(&discovery.DeltaDiscoveryRequest{","+\t\t\tResourceNamesSubscribe:   []string{\"*\"},","+\t\t\tResourceNamesUnsubscribe: []string{\"*\"},","+\t\t})","+\t\tads.ExpectEmptyResponse()","+","+\t\t// Subscribe to the pod and record the version the server assigns.","+\t\tresp := ads.RequestResponseAck(&discovery.DeltaDiscoveryRequest{","+\t\t\tResourceNamesSubscribe: []string{\"/127.0.0.1\"},","+\t\t})","+\t\texpect(resp, \"Kubernetes//Pod/default/pod\")","+\t\tpodVersion := resp.Resources[0].Version","+\t\tif podVersion == \"\" {","+\t\t\tt.Fatal(\"resource sent without a version\")","+\t\t}","+\t\tads.Cleanup()","+","+\t\t// Reconnect claiming the retained version. The content is unchanged, so it is not re-sent.","+\t\tads = s.ConnectDeltaADS().WithType(v3.AddressType).WithMetadata(model.NodeMetadata{NodeName: \"node\"})","+\t\tads.Request(&discovery.DeltaDiscoveryRequest{","+\t\t\tResourceNamesSubscribe:   []string{\"*\"},","+\t\t\tResourceNamesUnsubscribe: []string{\"*\"},","+\t\t\tInitialResourceVersions: map[string]string{","+\t\t\t\t\"Kubernetes//Pod/default/pod\": podVersion,","+\t\t\t},","+\t\t})","+\t\tads.ExpectEmptyResponse()","+\t\tads.Cleanup()","+","+\t\t// Reconnect claiming a stale version. The pod must be re-sent.","+\t\tads = s.ConnectDeltaADS().WithType(v3.AddressType).WithMetadata(model.NodeMetadata{NodeName: \"node\"})","+\t\tads.Request(&discovery.DeltaDiscoveryRequest{","+\t\t\tResourceNamesSubscribe:   []string{\"*\"},","+\t\t\tResourceNamesUnsubscribe: []string{\"*\"},","+\t\t\tInitialResourceVersions: map[string]string{","+\t\t\t\t\"Kubernetes//Pod/default/pod\": \"stale\",","+\t\t\t},","+\t\t})","+\t\texpect(ads.ExpectResponse(), \"Kubernetes//Pod/default/pod\")","+\t})","+\tt.Run(\"wildcard-versioned\", func(t *testing.T) {","+\t\texpectAddedAndRemoved := buildExpectAddedAndRemoved(t)","+\t\ts := xds.NewFakeDiscoveryServer(t, xds.FakeOptions{","+\t\t\tKubernetesObjects: []runtime.Object{","+\t\t\t\tmkPod(\"pod\", \"sa\", \"127.0.0.1\", \"not-node\"),","+\t\t\t\tmkPod(\"pod2\", \"sa\", \"127.0.0.2\", \"node\"),","+\t\t\t},","+\t\t})","+\t\tads := s.ConnectDeltaADS().WithType(v3.AddressType).WithMetadata(model.NodeMetadata{NodeName: \"node\"})","+","+\t\t// Subscribe to everything and record the versions the server assigns.","+\t\tresp := ads.RequestResponseAck(&discovery.DeltaDiscoveryRequest{})","+\t\tretained := map[string]string{}","+\t\tfor _, r := range resp.Resources {","+\t\t\tif r.Version == \"\" {","+\t\t\t\tt.Fatalf(\"resource %v sent without a version\", r.Name)","+\t\t\t}","+\t\t\tretained[r.Name] = r.Version","+\t\t}","+\t\tassert.Equal(t, len(retained), 2)","+\t\tads.Cleanup()","+","+\t\t// While disconnected, delete pod2 and create pod3.","+\t\tdeletePod(s, \"pod2\")","+\t\tassert.EventuallyEqual(t, func() int {","+\t\t\treturn len(s.AmbientIndex.All())","+\t\t}, 1)","+\t\tcreatePod(s, \"pod3\", \"sa\", \"127.0.0.3\", \"node\")","+\t\tassert.EventuallyEqual(t, func() int {","+\t\t\treturn len(s.AmbientIndex.All())","+\t\t}, 2)","+","+\t\t// Reconnect with the retained versions: the unchanged pod is skipped, pod3 is sent, and","+\t\t// pod2 is removed.","+\t\tads = s.ConnectDeltaADS().WithType(v3.AddressType).WithMetadata(model.NodeMetadata{NodeName: \"node\"})","+\t\tads.Request(&discovery.DeltaDiscoveryRequest{InitialResourceVersions: retained})","+\t\tresp = ads.ExpectResponse()","+\t\texpectAddedAndRemoved(resp, []string{\"Kubernetes//Pod/default/pod3\"}, []string{\"Kubernetes//Pod/default/pod2\"})","+\t\tpod3Version := resp.Resources[0].Version","+\t\tads.Cleanup()","+","+\t\t// Reconnect claiming a stale version for the pod: it must be re-sent.","+\t\tads = s.ConnectDeltaADS().WithType(v3.AddressType).WithMetadata(model.NodeMetadata{NodeName: \"node\"})","+\t\tads.Request(&discovery.DeltaDiscoveryRequest{InitialResourceVersions: map[string]string{","+\t\t\t\"Kubernetes//Pod/default/pod\":  \"stale\",","+\t\t\t\"Kubernetes//Pod/default/pod3\": pod3Version,","+\t\t}})","+\t\texpectAddedAndRemoved(ads.ExpectResponse(), []string{\"Kubernetes//Pod/default/pod\"}, nil)","+\t})"," }"," "," func TestWorkload(t *testing.T) {"],"additions":95,"deletions":0,"truncated":false},{"path":"pkg/xds/server.go","lines":["@@ -36,6 +36,11 @@ type ResourceDelta struct {"," \tSubscribed sets.String"," \t// Unsubscribed indicates the client no longer requires these resources"," \tUnsubscribed sets.String","+\t// InitialResourceVersions, sent by a client on stream (re)establishment, maps the resources","+\t// the client already retains to their versions. Generators that assign content-based versions","+\t// (WDS) use it to skip re-sending resources the client already has. Every name in it is also","+\t// present in Subscribed.","+\tInitialResourceVersions map[string]string"," }"," "," var emptyResourceDelta = ResourceDelta{}"],"additions":5,"deletions":0,"truncated":false},{"path":"releasenotes/notes/wds-reconnect-version-skip.yaml","lines":["@@ -0,0 +1,30 @@","+apiVersion: release-notes/v2","+kind: bug-fix","+area: traffic-management","+","+issue:","+  - https://github.com/istio/ztunnel/issues/1966","+","+releaseNotes:","+  - |","+    **Fixed** a bug where a ztunnel reconnect (such as the periodic connection recycle","+    from `keepaliveMaxServerConnectionAge`) triggered a full workload (WDS) push. Istiod now","+    assigns each WDS resource a content-based version and, when a reconnecting client","+    reports the versions it already holds via `initial_resource_versions`, re-sends only","+    resources that changed while the client was disconnected. Older ztunnel versions that","+    do not report versions continue to receive the full set.","+","+upgradeNotes:","+  - title: WDS reconnect requests are larger in big ambient meshes","+    content: |","+      On reconnect, ztunnel reports the name and version of every workload (WDS) resource it","+      holds. This request can exceed istiod's default 4MiB gRPC receive limit, leaving ztunnel","+      in a reconnect loop with `ResourceExhausted: grpc: received message larger than max`","+      errors. Meshes could already hit the limit at roughly 55,000 workloads, since resource","+      names were reported before this change; the added versions grow the request by about a","+      third, lowering the trigger point to roughly 40,000 workloads (sooner with long resource","+      names or many services). If your mesh is near this scale, raise","+      `ISTIO_GPRC_MAXRECVMSGSIZE` on istiod — budget roughly 1MiB per 10,000 workloads and","+      services; for example, `--set pilot.env.ISTIO_GPRC_MAXRECVMSGSIZE=33554432` (32MiB)","+      covers meshes well past 300,000 resources — and watch istiod logs for the error above","+      after upgrading.",""],"additions":30,"deletions":0,"truncated":false}],"additions":178,"deletions":25,"truncated":false,"file_count":9},"error":null,"fetched_at":"2026-07-21T10:13:22.093853+00:00"}