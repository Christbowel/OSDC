iguration.LunchFlow.ValidateConfig(),","+\t\t\t); err != nil {","+\t\t\t\treturn errors.Wrap(err, \"there are configuration problems\")","+\t\t\t}","+","+\t\t\t// TODO Move this to a configuration validation function"," \t\t\tif configuration.ReCAPTCHA.Enabled {"," \t\t\t\tlog.Warn(\"DEPRECATION WARNING: ReCAPTCHA will be removed in a future release. If you are currently using it then please comment on the issue on GitHub. It is recommended to instead rate limit monetr authentication endpoints instead of using a captcha at this time.\","," \t\t\t\t\t\"issueUrl\", \"https://github.com/monetr/monetr/issues/2979\","],"additions":15,"deletions":0,"truncated":false},{"path":"server/config/configuration.go","lines":["@@ -340,6 +340,7 @@ func setupDefaults(v *viper.Viper) {"," \tv.SetDefault(\"Logging.Level\", LogLevel) // Info"," \t// Lunch Flow is enabled by default for self-hosted deployments!"," \tv.SetDefault(\"LunchFlow.Enabled\", true)","+\tv.SetDefault(\"LunchFlow.AllowedApiUrls\", []string{DefaultLunchFlowAPIURL})"," \tv.SetDefault(\"KeyManagement.Provider\", \"plaintext\")"," \tv.SetDefault(\"Plaid.Enabled\", true)"," \tv.SetDefault(\"Plaid.CountryCodes\", []plaid.CountryCode{plaid.COUNTRYCODE_US})"],"additions":1,"deletions":0,"truncated":false},{"path":"server/config/lunch_flow.go","lines":["@@ -1,8 +1,87 @@"," package config"," ","+import (","+\t\"net/url\"","+\t\"strings\"","+","+\t\"github.com/pkg/errors\"","+)","+","+const DefaultLunchFlowAPIURL = \"https://lunchflow.app/api/v1\"","+"," type LunchFlow struct {"," \t// Enabled just determines whether or not Lunch Flow will be an option to"," \t// configure in the UI. This defaults to true as it requires no additional"," \t// configuration here for self-hosted users."," \tEnabled bool `yaml:\"enabled\"`","+\t// AllowedApiUrls is the set of Lunch Flow API URLs this deployment is","+\t// permitted to contact. Comparison is exact-string.","+\tAllowedApiUrls []string `yaml:\"allowedApiUrls\"`","+}","+","+// ValidateConfig can be called at startup in order to catch problems with the","+// configuration early on. If lunch flow is not enabled then this is a no-op, if","+// lunch flow is enabled and there are allowed URLs specified; then this will","+// validate that those URLs specified are all valid.","+func (l LunchFlow) ValidateConfig() error {","+\tif !l.IsEnabled() {","+\t\treturn nil","+\t}","+\tfor _, allowed := range l.AllowedApiUrls {","+\t\tparsed, err := url.Parse(allowed)","+\t\tif err != nil {","+\t\t\treturn errors.Wrapf(err, \"configured Lunch Flow url (%s) is not valid\", allowed)","+\t\t}","+","+\t\t// Do not allow query parameters in the URL as these will be removed when","+\t\t// requests are made!","+\t\tif len(parsed.Query()) > 0 {","+\t\t\treturn errors.Errorf(\"Lunch Flow url (%s) cannot contain query parameters\", allowed)","+\t\t}","+","+\t\t// Require a scheme to be specified","+\t\tswitch strings.ToLower(parsed.Scheme) {","+\t\tcase \"http\", \"https\":","+\t\t\t// These are considered valid!","+\t\tdefault:","+\t\t\t// Any other scheme is not considered valid here!","+\t\t\treturn errors.Errorf(\"Lunch Flow url (%s) must use an http or https scheme\", allowed)","+\t\t}","+\t}","+","+\treturn nil","+}","+","+// IsEnabled only returns true if the lunch flow integration is enabled AND when","+// there is at least one allowed API URLs configured.","+func (l LunchFlow) IsEnabled() bool {","+\treturn l.Enabled && len(l.AllowedApiUrls) > 0","+}","+","+// IsAllowedApiUrl returns true when the provided URL matches one of the","+// configured allowed Lunch Flow API URLs. Matching is done after both the input","+// URL and the allowed URLs are parsed via [url.Parse] in order to ensure","+// correctness.","+func (l LunchFlow) IsAllowedApiUrl(input string) bool {","+\tinputUrl, err := url.Parse(input)","+\tif err != nil {","+\t\treturn false","+\t}","+","+\tfor _, allowed := range l.AllowedApiUrls {","+\t\tallowedUrl, err := url.Parse(allowed)","+\t\tif err != nil {","+\t\t\t// If an allowed URL in the configuration is not even considered a valid","+\t\t\t// url then discard it. It will not be considered valid in the http client","+\t\t\t// anyway.","+\t\t\tcontinue","+\t\t}","+\t\t// Urls must be equal AFTER parsing, the [url.Parse] function does some","+\t\t// transformations here that are considered reasonable. Such as converting","+\t\t// the scheme to be lowercase.","+\t\tif allowedUrl.String() == inputUrl.String() {","+\t\t\treturn true","+\t\t}","+\t}","+\treturn false"," }"],"additions":79,"deletions":0,"truncated":false},{"path":"server/config/lunch_flow_test.go","lines":["@@ -0,0 +1,96 @@","+package config_test","+","+import (","+\t\"testing\"","+","+\t\"github.com/monetr/monetr/server/config\"","+\t\"github.com/stretchr/testify/assert\"","+)","+","+func TestLunchFlow_ValidateConfig(t *testing.T) {","+\tt.Run(\"disabled is a no-op\", func(t *testing.T) {","+\t\tconfiguration := config.LunchFlow{","+\t\t\tEnabled:        false,","+\t\t\tAllowedApiUrls: []string{\"not a valid url\"},","+\t\t}","+\t\tassert.NoError(t, configuration.ValidateConfig())","+\t})","+","+\tt.Run(\"no allowed urls is a no-op\", func(t *testing.T) {","+\t\tconfiguration := config.LunchFlow{","+\t\t\tEnabled: true,","+\t\t}","+\t\tassert.NoError(t, configuration.ValidateConfig())","+\t})","+","+\tt.Run(\"valid urls are accepted\", func(t *testing.T) {","+\t\tconfiguration := config.LunchFlow{","+\t\t\tEnabled: true,","+\t\t\tAllowedApiUrls: []string{","+\t\t\t\t\"https://lunchflow.app/api/v1\",","+\t\t\t\t\"http://lunchflow.app/api/v1\",","+\t\t\t},","+\t\t}","+\t\tassert.NoError(t, configuration.ValidateConfig())","+\t})","+","+\tt.Run(\"unparseable url is rejected\", func(t *testing.T) {","+\t\tconfiguration := config.LunchFlow{","+\t\t\tEnabled:        true,","+\t\t\tAllowedApiUrls: []string{\"https://lunchflow.app/%zz\"},","+\t\t}","+\t\tassert.EqualError(t, configuration.ValidateConfig(), `configured Lunch Flow url (https://lunchflow.app/%zz) is not valid: parse \"https://lunchflow.app/%zz\": invalid URL escape \"%zz\"`)","+\t})","+","+\tt.Run(\"url with query parameters is rejected\", func(t *testing.T) {","+\t\tconfiguration := config.LunchFlow{","+\t\t\tEnabled:        true,","+\t\t\tAllowedApiUrls: []string{\"https://lunchflow.app/api/v1?token=secret\"},","+\t\t}","+\t\tassert.EqualError(t, configuration.ValidateConfig(), \"Lunch Flow url (https://lunchflow.app/api/v1?token=secret) cannot contain query parameters\")","+\t})","+","+\tt.Run(\"invalid url in config\", func(t *testing.T) {","+\t\tconfiguration := config.LunchFlow{","+\t\t\tEnabled:        true,","+\t\t\tAllowedApiUrls: []string{\"example.com\"},","+\t\t}","+\t\tassert.EqualError(t, configuration.ValidateConfig(), \"Lunch Flow url (example.com) must use an http or https scheme\")","+\t})","+}","+","+func TestLunchFlow_IsAllowedApiUrl(t *testing.T) {","+\tt.Run(\"exact match is allowed\", func(t *testing.T) {","+\t\tconfiguration := config.LunchFlow{","+\t\t\tAllowedApiUrls: []string{\"https://lunchflow.app/api/v1\"},","+\t\t}","+\t\tassert.True(t, configuration.IsAllowedApiUrl(\"https://lunchflow.app/api/v1\"))","+\t})","+","+\tt.Run(\"mismatch is rejected\", func(t *testing.T) {","+\t\tconfiguration := config.LunchFlow{","+\t\t\tAllowedApiUrls: []string{\"https://lunchflow.app/api/v1\"},","+\t\t}","+\t\tassert.False(t, configuration.IsAllowedApiUrl(\"http://169.254.169.254/latest/meta-data\"))","+\t\tassert.False(t, configuration.IsAllowedApiUrl(\"http://127.0.0.1\"))","+\t\tassert.False(t, configuration.IsAllowedApiUrl(\"https://lunchflow.app/api/v2\"))","+\t})","+","+\tt.Run(\"empty list rejects everything\", func(t *testing.T) {","+\t\tconfiguration := config.LunchFlow{}","+\t\tassert.False(t, configuration.IsAllowedApiUrl(\"https://lunchflow.app/api/v1\"))","+\t\tassert.False(t, configuration.IsAllowedApiUrl(\"\"))","+\t})","+","+\tt.Run(\"multiple entries match any of them\", func(t *testing.T) {","+\t\tconfiguration := config.LunchFlow{","+\t\t\tAllowedApiUrls: []string{","+\t\t\t\t\"https://lunchflow.app/api/v1\",","+\t\t\t\t\"https://lunchflow.compatible.app/api/v1\",","+\t\t\t},","+\t\t}","+\t\tassert.True(t, configuration.IsAllowedApiUrl(\"https://lunchflow.app/api/v1\"))","+\t\tassert.True(t, configuration.IsAllowedApiUrl(\"https://lunchflow.compatible.app/api/v1\"))","+\t\tassert.False(t, configuration.IsAllowedApiUrl(\"https://other.lunchflow.app/api/v1\"))","+\t})","+}"],"additions":96,"deletions":0,"truncated":false},{"path":"server/controller/config.go","lines":["@@ -5,7 +5,6 @@ import ("," "," \t\"github.com/labstack/echo/v4\""," \t\"github.com/monetr/monetr/server/build\"","-\t\"github.com/monetr/monetr/server/datasources/lunch_flow\""," \t\"github.com/monetr/monetr/server/icons\""," )"," ","@@ -14,29 +13,29 @@ func (c *Controller) configEndpoint(ctx echo.Context) error {"," \t\tPrice int64 `json:\"price\"`"," \t}"," \tvar configuration struct {","-\t\tRequireLegalName       bool         `json:\"requireLegalName\"`","-\t\tRequirePhoneNumber     bool         `json:\"requirePhoneNumber\"`","-\t\tVerifyLogin            bool         `json:\"verifyLogin\"`","-\t\tVerifyRegister         bool         `json:\"verifyRegister\"`","-\t\tVerifyEmailAddress     bool         `json:\"verifyEmailAddress\"`","-\t\tVerifyForgotPassword   bool         `json:\"verifyForgotPassword\"`","-\t\tReCAPTCHAKey           string       `json:\"ReCAPTCHAKey,omitempty\"`","-\t\tAllowSignUp            bool         `json:\"allowSignUp\"`","-\t\tAllowForgotPassword    bool         `json:\"allowForgotPassword\"`","-\t\tLongPollPlaidSetup     bool         `json:\"longPollPlaidSetup\"`","-\t\tRequireBetaCode        bool         `json:\"requireBetaCode\"`","-\t\tInitialPlan            *InitialPlan `json:\"initialPlan\"`","-\t\tBillingEnabled         bool         `json:\"billingEnabled\"`","-\t\tIconsEnabled           bool         `json:\"iconsEnabled\"`","-\t\tPlaidEnabled           bool         `json:\"plaidEnab