n nil"," }"," ","@@ -202,3 +249,110 @@ func isWaitPolicyLockConflict(err error) bool {"," \t}"," \treturn wi.Reason == kvpb.WriteIntentError_REASON_WAIT_POLICY"," }","+","+// HeldLockInfo represents information about a held advisory lock.","+type HeldLockInfo struct {","+\tKey  LockKey","+\tMode LockMode","+}","+","+// GetHeldLocks returns a copy of the effective per-key lock modes derived from","+// the acquisition stack (max strength per key). Safe for concurrent callers.","+func (m *Manager) GetHeldLocks() []HeldLockInfo {","+\tm.mu.Lock()","+\tdefer m.mu.Unlock()","+\t// Gather all the modes that locks are uniquely held in.","+\tsharedLocks := make(map[LockKey]struct{})","+\texclusiveLocks := make(map[LockKey]struct{})","+\tfor _, acq := range m.mu.stack {","+\t\tswitch acq.mode {","+\t\tcase LockModeShare:","+\t\t\tsharedLocks[acq.key] = struct{}{}","+\t\tcase LockModeExclusive:","+\t\t\texclusiveLocks[acq.key] = struct{}{}","+\t\t}","+\t}","+\theldInfo := make([]HeldLockInfo, 0, len(sharedLocks)+len(exclusiveLocks))","+\tfor key := range sharedLocks {","+\t\theldInfo = append(heldInfo, HeldLockInfo{key, LockModeShare})","+\t}","+\tfor key := range exclusiveLocks {","+\t\theldInfo = append(heldInfo, HeldLockInfo{key, LockModeExclusive})","+\t}","+\treturn heldInfo","+}","+","+// OnSQLSavepointCreated records the current acquisition stack depth for a new","+// SQL savepoint. Call after pushing the SQL savepoint.","+func (m *Manager) OnSQLSavepointCreated() {","+\tm.mu.Lock()","+\tdefer m.mu.Unlock()","+\tm.mu.savepointMarkers = append(m.mu.savepointMarkers, len(m.mu.stack))","+}","+","+// OnSQLRollbackToSavepoint rolls back the acquisition stack to the depth at","+// SQL savepoint index targetIdx. Call only after txn.RollbackToSavepoint succeeds.","+func (m *Manager) OnSQLRollbackToSavepoint(targetIdx int) error {","+\tm.mu.Lock()","+\tdefer m.mu.Unlock()","+\tif targetIdx < 0 || targetIdx >= len(m.mu.savepointMarkers) {","+\t\treturn errors.AssertionFailedf(\"i