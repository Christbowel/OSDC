ions = $service->encryptPasswords(['password' => 'my-secret-password']);","+\t\t$this->assertArrayHasKey('password_encrypted', $options);","+\t\t$this->assertSame('', $options['password']);","+","+\t\t$decrypted = $service->decryptPasswords(['password_encrypted' => $options['password_encrypted']]);","+\t\t$this->assertSame('my-secret-password', $decrypted['password']);","+\t\t$this->assertArrayNotHasKey('password_encrypted', $decrypted);","+\t}","+","+\t/**","+\t * Ciphertexts written with phpseclib v2 must remain decryptable after the","+\t * upgrade to phpseclib v3. v2 accepted arbitrary-length keys and normalized","+\t * them (round up to 16/24/32 bytes, read whole 4-byte words only, zero-pad","+\t * missing high words). Here we recreate such a ciphertext with OpenSSL — an","+\t * independent AES implementation — using that exact effective key.","+\t */","+\t#[\\PHPUnit\\Framework\\Attributes\\DataProvider('saltProvider')]","+\tpublic function testDecryptsLegacyPhpseclibV2Ciphertext(string $passwordSalt): void {","+\t\t$plaintext = 'legacy-external-storage-password';","+","+\t\t// Reproduce the phpseclib v2 effective AES key","+\t\t$length = strlen($passwordSalt);","+\t\t$keyLength = $length <= 16 ? 16 : ($length <= 24 ? 24 : 32);","+\t\t$effectiveKey = substr(str_pad(substr($passwordSalt, 0, intdiv($length, 4) * 4), $keyLength, \"\\0\"), 0, $keyLength);","+","+\t\t$iv = str_repeat(\"\\x22\", 16);","+\t\t$rawCiphertext = openssl_encrypt($plaintext, 'aes-' . ($keyLength * 8) . '-cbc', $effectiveKey, OPENSSL_RAW_DATA, $iv);","+\t\t$stored = base64_encode($iv . $rawCiphertext);","+","+\t\t$service = $this->service($passwordSalt);","+\t\t$decrypted = $service->decryptPasswords(['password_encrypted' => $stored]);","+\t\t$this->assertSame($plaintext, $decrypted['password']);","+\t}","+}"],"additions":82,"deletions":0,"truncated":false},{"path":"build/psalm-baseline.xml","lines":["@@ -1603,12 +1603,6 @@","     <DeprecatedMethod>","       <code><![CDATA[generate]]></code