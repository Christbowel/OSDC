te function decryptPassword(string $encryptedPassword): string {"," \t * Returns the encryption cipher"," \t */"," \tprivate function getCipher(): AES {","-\t\t$cipher = new AES(AES::MODE_CBC);","-\t\t$cipher->setKey($this->config->getSystemValue('passwordsalt', null));","+\t\t$cipher = new AES('cbc');","+\t\t$cipher->setKey($this->normalizeKey((string)$this->config->getSystemValue('passwordsalt', '')));"," \t\treturn $cipher;"," \t}","+","+\t/**","+\t * Normalize the configured `passwordsalt` into a valid AES key.","+\t *","+\t * Note: phpseclib v2 accepted keys of any length and silently normalized them:","+\t * the key length was rounded up to the next valid AES size (16, 24 or 32","+\t * bytes), the key was read in whole 4-byte words (trailing bytes that did","+\t * not form a full word were dropped) and any missing high words were","+\t * treated as zero. phpseclib v3 rejects keys that are not exactly 16, 24 or","+\t * 32 bytes, so we reproduce the v2 behaviour here to keep previously stored","+\t * passwords decryptable.","+\t */","+\tprivate function normalizeKey(string $key): string {","+\t\t$length = strlen($key);","+\t\t$keyLength = $length <= 16 ? 16 : ($length <= 24 ? 24 : 32);","+\t\t// Drop trailing bytes that do not form a full 4-byte word (phpseclib v2 used unpack('N*'))","+\t\t$key = substr($key, 0, intdiv($length, 4) * 4);","+\t\t// Zero-pad missing high words and truncate to the target key length","+\t\treturn substr(str_pad($key, $keyLength, \"\\0\"), 0, $keyLength);","+\t}"," }"],"additions":23,"deletions":3,"truncated":false},{"path":"apps/files_external/tests/Controller/AjaxControllerTest.php","lines":["@@ -21,6 +21,7 @@"," use OCP\\IUser;"," use OCP\\IUserManager;"," use OCP\\IUserSession;","+use phpseclib3\\Crypt\\RSA as CryptRSA;"," use PHPUnit\\Framework\\MockObject\\MockObject;"," use Test\\TestCase;"," ","@@ -37,8 +38,12 @@ class AjaxControllerTest extends TestCase {"," "," \tprotected function setUp(): void {"," \t\t$this->request = $th