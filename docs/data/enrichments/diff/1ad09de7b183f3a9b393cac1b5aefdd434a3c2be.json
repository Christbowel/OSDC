","+// findModelNameCollisions returns the names of LLMISVCs whose model-routing","+// header values overlap with self's. Compares self's effective model names","+// (from post-merge spec) against each peer's status.addresses[].models[].name","+// which reflects the peer's resolved state including baseRef overrides.","+// Falls back to spec.model.name for peers not yet reconciled (empty status).","+func findModelNameCollisions(self *v1alpha2.LLMInferenceService, others []v1alpha2.LLMInferenceService) []string {","+\tselfModels := modelRoutingNames(self)","+\tif len(selfModels) == 0 {","+\t\treturn nil","+\t}","+","+\tvar collisions []string","+\tfor i := range others {","+\t\tother := &others[i]","+\t\tif other.Name == self.Name ||","+\t\t\tother.DeletionTimestamp != nil ||","+\t\t\tsameRoutingGroup(self, other) {","+\t\t\tcontinue","+\t\t}","+\t\tif otherModelNamesOverlap(selfModels, other) {","+\t\t\tcollisions = append(collisions, other.Name)","+\t\t}","+\t}","+","+\tslices.Sort(collisions)","+","+\treturn collisions","+}","+","+func otherModelNamesOverlap(selfModels map[string]struct{}, other *v1alpha2.LLMInferenceService) bool {","+\tfor _, addr := range other.Status.Addresses {","+\t\tfor _, m := range addr.Models {","+\t\t\tif _, ok := selfModels[m.Name]; ok {","+\t\t\t\treturn true","+\t\t\t}","+\t\t}","+\t}","+\t// Fallback: peer not yet reconciled (empty status) - check spec directly.","+\tif len(other.Status.Addresses) == 0 {","+\t\tfor name := range modelRoutingNames(other) {","+\t\t\tif _, ok := selfModels[name]; ok {","+\t\t\t\treturn true","+\t\t\t}","+\t\t}","+\t}","+","+\treturn false","+}","+","+func modelRoutingNames(svc *v1alpha2.LLMInferenceService) map[string]struct{} {","+\tbaseName := ptr.Deref(svc.Spec.Model.Name, svc.Name)","+\tnames := map[string]struct{}{","+\t\tfullyQualifiedModelName(svc.Namespace, baseName): {},","+\t}","+\tif svc.Spec.Model.LoRA != nil {","+\t\tfor _, adapter := range svc.Spec.Model.LoRA.Adapters {","+\t\t\tif adapter.Name != nil {","+\t\t\t\tnames[fullyQualifiedModelName(svc.Namespace, *adapter.Name)] = struct{}{}","+\t\t\t}","+\t\t}","+\t}","+","+\treturn names","+}","+","+func sameRoutingGroup(a, b *v1alpha2.LLMInferenceService) bool {","+\treturn a.Spec.Router.HasGroup() && b.Spec.Router.HasGroup() &&","+\t\t*a.Spec.Router.Group() == *b.Spec.Router.Group()","+}"],"additions":72,"deletions":0,"truncated":false},{"path":"pkg/controller/v1alpha2/llmisvc/router_validation_internal_test.go","lines":["@@ -0,0 +1,244 @@","+/*","+Copyright 2026 The KServe Authors.","+","+Licensed under the Apache License, Version 2.0 (the \"License\");","+you may not use this file except in compliance with the License.","+You may obtain a copy of the License at","+","+    http://www.apache.org/licenses/LICENSE-2.0","+","+Unless required by applicable law or agreed to in writing, software","+distributed under the License is distributed on an \"AS IS\" BASIS,","+WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.","+See the License for the specific language governing permissions and","+limitations under the License.","+*/","+","+package llmisvc","+","+import (","+\t\"slices\"","+\t\"testing\"","+","+\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"","+\t\"k8s.io/utils/ptr\"","+","+\t\"github.com/kserve/kserve/pkg/apis/serving/v1alpha2\"","+)","+","+func newLLMISVC(name string, opts ...func(*v1alpha2.LLMInferenceService)) v1alpha2.LLMInferenceService {","+\tsvc := v1alpha2.LLMInferenceService{","+\t\tObjectMeta: metav1.ObjectMeta{Name: name, Namespace: \"default\"},","+\t}","+\tfor _, o := range opts {","+\t\to(&svc)","+\t}","+","+\treturn svc","+}","+","+func withModelName(name string) func(*v1alpha2.LLMInferenceService) {","+\treturn func(svc *v1alpha2.LLMInferenceService) {","+\t\tsvc.Spec.Model.Name = ptr.To(name)","+\t}","+}","+","+func withLoRAAdapter(names ...string) func(*v1alpha2.LLMInferenceService) {","+\treturn func(svc *v1alpha2.LLMInferenceService) {","+\t\tif svc.Spe