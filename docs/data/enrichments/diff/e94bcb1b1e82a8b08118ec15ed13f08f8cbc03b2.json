o-workflows/v4/workflow/artifactrepositories\"","@@ -68,6 +71,222 @@ func (a *ArtifactServer) GetInputArtifact(w http.ResponseWriter, r *http.Request"," \ta.getArtifact(w, r, true)"," }"," ","+// UploadInputArtifact handles file uploads for workflow input artifacts","+// Path: /upload-artifacts/{namespace}/{workflowTemplateName}/{artifactName}","+// Method: POST","+// Body: multipart/form-data with \"file\" field","+// Response: JSON with artifact location information","+//","+//nolint:contextcheck","+func (a *ArtifactServer) UploadInputArtifact(w http.ResponseWriter, r *http.Request) {","+\tif r.Method != http.MethodPost {","+\t\thttp.Error(w, \"Method not allowed\", http.StatusMethodNotAllowed)","+\t\treturn","+\t}","+","+\t// Parse path: /upload-artifacts/{namespace}/{workflowTemplateName}/{artifactName}","+\trequestPath := strings.SplitN(r.URL.Path, \"/\", 5)","+\tif len(requestPath) < 5 {","+\t\thttp.Error(w, \"Invalid path. Expected: /upload-artifacts/{namespace}/{workflowTemplateName}/{artifactName}\", http.StatusBadRequest)","+\t\treturn","+\t}","+\tnamespace := requestPath[2]","+\tworkflowTemplateName := requestPath[3]","+\tartifactName := requestPath[4]","+","+\t// Authenticate and authorize","+\tctx, err := a.gateKeeping(r, types.NamespaceHolder(namespace))","+\tif err != nil {","+\t\ta.unauthorizedError(w)","+\t\treturn","+\t}","+","+\ta.logger.WithFields(logging.Fields{","+\t\t\"namespace\":            namespace,","+\t\t\"workflowTemplateName\": workflowTemplateName,","+\t\t\"artifactName\":         artifactName,","+\t}).Info(ctx, \"Upload artifact\")","+","+\t// Authorize before reading the request body, so an unprivileged caller","+\t// cannot force the server to buffer a large upload just to be rejected.","+\tallowed, err := auth.CanI(ctx, \"get\", \"workflowtemplates\", namespace, workflowTemplateName)","+\tif err != nil {","+\t\ta.serverInternalError(ctx, err, w)","+\t\treturn","+\t}","+\tif !allowed {","+\t\thttp.Error(w, http.StatusText(http.StatusForbidden), http.StatusForbidden)","+\t\treturn","+\t}","+\tallowed, err = auth.CanI(ctx, \"create\", \"workflows\", namespace, \"\")","+\tif err != nil {","+\t\ta.serverInternalError(ctx, err, w)","+\t\treturn","+\t}","+\tif !allowed {","+\t\thttp.Error(w, http.StatusText(http.StatusForbidden), http.StatusForbidden)","+\t\treturn","+\t}","+","+\t// Get WorkflowTemplate to find artifact configuration","+\twfClient := auth.GetWfClient(ctx)","+\twfTemplate, err := wfClient.ArgoprojV1alpha1().WorkflowTemplates(namespace).Get(ctx, workflowTemplateName, metav1.GetOptions{})","+\tif err != nil {","+\t\thttp.Error(w, fmt.Sprintf(\"Failed to get WorkflowTemplate %s/%s: %v\", namespace, workflowTemplateName, err), http.StatusNotFound)","+\t\treturn","+\t}","+\tif validateErr := a.instanceIDService.Validate(wfTemplate); validateErr != nil {","+\t\thttp.Error(w, http.StatusText(http.StatusNotFound), http.StatusNotFound)","+\t\treturn","+\t}","+","+\t// Enforce a hard cap on the total request body size before buffering any","+\t// of it, so a caller cannot exhaust server disk/memory with an oversized upload.","+\tmaxUploadBytes, err := env.GetInt(\"ARGO_SERVER_MAX_ARTIFACT_UPLOAD_BYTES\", 1<<30)","+\tif err != nil {","+\t\ta.serverInternalError(ctx, err, w)","+\t\treturn","+\t}","+\tr.Body = http.MaxBytesReader(w, r.Body, int64(maxUploadBytes))","+","+\t// mime/multipart.ReadForm already removes temp files on parse error, but","+\t// registering cleanup here makes the handler's correctness independent of","+\t// that stdlib internal — any future error return still frees temp files.","+\tdefer func() {","+\t\tif r.MultipartForm != nil {","+\t\t\t_ = r.MultipartForm.RemoveAll()","+\t\t}","+\t}()","+","+\t// Parse multipart form (max 32MB in memory, rest on disk)","+\tif parseErr := r.ParseMultipartForm(32 << 20); parseErr != nil {","+\t\tvar maxBytesErr *http.MaxBytesError","+\t\tif errors.As(parseErr, &maxBytesErr) {","+\t\t\thttp.Error(w, http.StatusText(http.StatusRequestEntityTooLarge), http.StatusRequestEntityTooLarge)","+\t\t\treturn","+\t\t}","+\t\thttp.Error(w, \"Failed to parse multipart form: \"+parseErr.Error(), http.StatusBadRequest)","+\t\treturn","+\t}","+","+\tfile, header, err := r.FormFile(\"file\")","+\tif err != nil {","+\t\thttp.Error(w, \"Failed to get file from form: \"+err.Error(), http.StatusBadRequest)","+\t\treturn","+\t}","+\tdefer file.Close()","+","+\ta.logger.WithFields(logging.Fields{","+\t\t\"filename\": header.Filename,","+\t\t\"size\":     header.Size,","+\t}).Info(ctx, \"Received file for upload\")","+","+\t// Find the artifact in the WorkflowTemplate's arguments.artifacts","+\tvar templateArtifact *wfv1.Artifact","+\tif wfTemplate.Spec.Arguments.Artifacts != nil {","+\t\tfor i := range wfTemplate.Spec.Arguments.Artifacts {","+\t\t\tif wfTemplate.Spec.Arguments.Artifacts[i].Name == artifactName {","+\t\t\t\ttemplateArtifact = &wfTemplate.Spec.Arguments.Artifacts[i]","+\t\t\t\tbreak","+\t\t\t}","+\t\t}","+\t}","+","+\tif templateArtifact == nil {","+\t\thttp.Error(w, fmt.Sprintf(\"Artifact '%s' not found in WorkflowTemplate %s/%s arguments.artifacts\", artifactName, namespace, workflowTemplateName), http.StatusNotFound)","+\t\treturn","+\t}","+","+\t// Create a deep copy to avoid modifying the original template artifact","+\tartifactCopy := templateArtifact.DeepCopy()","+","+\t// If the artifact doesn't have a full location, try to resolve from default artifact repository.","+\t// This handles cases where:","+\t// 1. WorkflowTemplate specifies artifactRepositoryRef explicitly","+\t// 2. Namespace has artifact-repositories ConfigMap","+\t// 3. workflow-controller-configmap has default artifactRepository","+\t// We don't use Relocate() because it requires an existing key, but for uploads we generate a new key anyway.","+\tif !artifactCopy.HasLocation() {","+\t\tarchiveLocation, resolveErr := sutils.ResolveArtifactLocation(ctx, a.artifactRepositories, wfTemplate.Spec.ArtifactRepositoryRef, namespace)","+\t\tif resolveErr != nil {","+\t\t\ta.logger.WithError(resolveErr).Debug(ctx, \"Failed to resolve artifact repository, will check if artifact has location anyway\")","+\t\t} else if archiveLocation != nil && archiveLocation.HasLocation() {","+\t\t\t// Copy the location settings (bucket, endpoint, etc.) to our artifact","+\t\t\tartifactCopy.ArtifactLocation = *archiveLocation.DeepCopy()","+\t\t\ta.logger.WithFields(logging.Fields{","+\t\t\t\t\"artifactName\": artifactName,","+\t\t\t}).Info(ctx, \"Resolved artifact location from default repository\")","+\t\t}","+\t}","+","+\t// Check if the artifact has a location configured (S3, GCS, etc.)","+\tif !artifactCopy.HasLocation() {","+\t\thttp.Error(w, fmt.Sprintf(\"Artifact '%s' does not have a storage location configured (s3, gcs, azure, oss). Please configure a storage location in the WorkflowTemplate or set up a default artifact repository.\", artifactName), http.StatusBadRequest)","+\t\treturn","+\t}","+","+\t// Generate unique key for the artifact","+\tuploadUUID := uuid.NewString()","+\toriginalKey, _ := artifactCopy.GetKey()","+\t// Sanitize filename to prevent path traversal attacks. path.Base only","+\t// recognises '/' as a separator, so normalise Windows-style '\\' first.","+\tsanitizedFilename := path.Base(strings.ReplaceAll(header.Filename, \"\\\\\", \"/\"))","+\tif sanitizedFilename == \".\" || sanitizedFilename == \"/\" || sanitizedFilename == \"\" {","+\t\thttp.Error(w, \"Invalid filename\", http.StatusBadRequest)","+\t\treturn","+\t}","+\t// Replace the key with uploaded file path under uploads/","+\tnewKey := fmt.Sprintf(\"uploads/%s/%s/%s\", namespace, uploadUUID, sanitizedFilename)","+\tif validateErr := sutils.ValidateUploadedArtifactKey(namespace, newKey); validateErr != nil {","+\t\ta.serverInternalError(ctx, fmt.Errorf(\"generated artifact key failed self-validation: %w\", validateErr), w)","+\t\treturn","+\t}","+","+\t// Create a copy of the artifact for uploading (using artifactCopy which has resolved location)","+\toutputArtifact := artifactCopy.DeepCopy()","+\tif setErr := outputArtifact.SetKey(newKey); setErr != nil {","+\t\thttp.Error(w, fmt.Sprintf(\"Failed to set artifact key: %v\", setErr), http.StatusInternalServerError)","+\t\treturn","+\t}","+","+\ta.logger.WithFields(logging.Fields{","+\t\t\"originalKey\": originalKey,","+\t\t\"newKey\":      newKey,","+\t}).Info(ctx, \"Uploading artifact with new key\")","+","+\t// Get the driver for the artifact","+\tkubeClient := auth.GetKubeClient(ctx)","+\tdriver, err := a.artDriverFactory(ctx, outputArtifact, resources{kubeClient, namespace})"],"additions":189,"deletions":0,"truncated":false}],"additions":421,"deletions":3,"truncated":true,"file_count":18},"error":null,"fetched_at":"2026-07-17T09:47:44.357055+00:00"}