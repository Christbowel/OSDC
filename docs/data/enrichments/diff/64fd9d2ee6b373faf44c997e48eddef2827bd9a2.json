{"id":"64fd9d2ee6b373faf44c997e48eddef2827bd9a2","axis":"silent","repo":"aws/aws-sdk-js-v3","sha":"64fd9d2ee6b373faf44c997e48eddef2827bd9a2","parsed":{"files":[{"path":"Makefile","lines":["@@ -1,7 +1,7 @@"," # This is the public Makefile containing some build commands."," # You can implement some additional personal commands such as login and sync in Makefile.private.mk (unversioned)."," ","-.PHONY: login sync bundles test-unit test-types test-indices test-protocols test-schema test-integration test-endpoints test-e2e build-s3-browser-bundle build-signature-v4-multi-region-browser-bundle clean-nested link-smithy unlink-smithy copy-smithy gen-auth b-auth tpk unbuilt turbo-clean server-protocols nested-clients clients","+.PHONY: login sync bundles test-unit test-types test-indices test-protocols test-schema test-integration test-endpoints test-e2e build-s3-browser-bundle build-signature-v4-multi-region-browser-bundle clean-nested link-smithy unlink-smithy copy-smithy gen-auth b-auth tpk unbuilt turbo-clean server-protocols nested-clients clients static-analysis"," "," # fetch AWS testing credentials"," login:","@@ -56,8 +56,7 @@ test-schema: bundles"," # run public API tests (no network requests)."," test-integration: bundles"," \trm -rf ./clients/client-sso/node_modules/\\@smithy # todo(yarn) incompatible redundant nesting.","-\tnode ./scripts/validation/no-generic-byte-arrays.js","-\tmake api-snapshot","+\tmake static-analysis"," \tnode ./scripts/compilation/Inliner.spec.js"," \tyarn g:vitest run -c vitest.config.integ.mts"," \tmake test-protocols","@@ -137,6 +136,11 @@ tpk:"," unbuilt:"," \tnode scripts/build-only-unbuilt.js"," ","+static-analysis:","+\tnode ./scripts/validation/no-generic-byte-arrays.js","+\tnode ./scripts/validation/validate-all.js --all;","+\tmake api-snapshot","+"," # Clears the Turborepo local build cache"," turbo-clean:"," \t@read -p \"Are you sure you want to delete your local cache? [y/N]: \" ans && [ $${ans:-N} = y ]"],"additions":7,"delet