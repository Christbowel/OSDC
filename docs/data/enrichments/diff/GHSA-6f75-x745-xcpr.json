                'merge_into_id' => $target->id,","+            ])","+            ->assertRedirect(route('users.index'))","+            ->assertSessionHas('success');","+","+        $this->assertSoftDeleted($source);","+        $this->assertEquals($target->id, $asset->fresh()->assigned_to);","+    }","+","+    public function test_merge_does_not_transfer_assets_when_source_is_protected()","+    {","+        $actor = User::factory()->deleteUsers()->create();","+        $admin = User::factory()->admin()->create();","+        $asset = Asset::factory()->assignedToUser($admin)->create();","+","+        $this->actingAs($actor)","+            ->post(route('users.merge.save'), [","+                'ids_to_merge' => [$admin->id],","+                'merge_into_id' => $actor->id,","+            ])","+            ->assertRedirect(route('users.index'))","+            ->assertSessionHas('error');","+","+        $this->assertEquals($admin->id, $asset->fresh()->assigned_to);","+    }","+}",""],"additions":109,"deletions":0,"truncated":false}],"additions":255,"deletions":8,"truncated":false,"file_count":5},"error":null,"fetched_at":"2026-06-24T10:41:06.712588+00:00"}