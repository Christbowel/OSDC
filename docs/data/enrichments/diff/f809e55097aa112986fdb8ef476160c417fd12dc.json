{"id":"f809e55097aa112986fdb8ef476160c417fd12dc","axis":"silent","repo":"TryGhost/Ghost","sha":"f809e55097aa112986fdb8ef476160c417fd12dc","parsed":{"files":[{"path":"apps/announcement-bar/README.md","lines":["@@ -11,6 +11,24 @@"," "," You can automatically start the announcement-bar dev server when developing Ghost by running Ghost (in root folder) via `yarn dev --announcementbar`."," ","+## Release","+","+A patch release can be rolled out instantly in production, whereas a minor/major release requires the Ghost monorepo to be updated and released.","+In either case, you need sufficient permissions to release `@tryghost` packages on NPM.","+","+### Patch release","+","+1. Run `yarn ship` and select a patch version when prompted","+2. Merge the release commit to `main`","+","+### Minor / major release","+","+1. Run `yarn ship` and select a minor or major version when prompted","+2. Merge the release commit to `main`","+3. Wait until a new version of Ghost is released","+","+To use the new version of signup form in Ghost, update the version in Ghost core's default configuration (currently at `core/shared/config/default.json`)","+"," # Copyright & License "," "," Copyright (c) 2013-2025 Ghost Foundation - Released under the [MIT license](LICENSE)."],"additions":18,"deletions":0,"truncated":false},{"path":"apps/announcement-bar/package.json","lines":["@@ -1,6 +1,6 @@"," {","   \"name\": \"@tryghost/announcement-bar\",","-  \"version\": \"1.1.11\",","+  \"version\": \"1.1.12\",","   \"license\": \"MIT\",","   \"repository\": {","     \"type\": \"git\",","@@ -50,7 +50,12 @@","       \"ghost\"","     ],","     \"rules\": {","-      \"react/prop-types\": \"off\"","+      \"react/prop-types\": \"off\",","+      \"ghost/filenames/match-regex\": [","+        \"error\",","+        \"^[a-z0-9.-]+$\",","+        false","+      ]","     },","     \"settings\": {","       \"react\": {"],"additions":7,"deletions":2,"truncated":false},{"path":"apps/announcement-bar/src/app.js","lines