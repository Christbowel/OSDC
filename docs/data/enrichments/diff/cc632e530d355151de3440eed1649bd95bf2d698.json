unction createSignatureData(","-\t\tarray $hashes,","-\t\tarray $certificate,","-\t\tRSA $privateKey,","-\t\tX509 $x509","-\t) {","-\t\t\\ksort($hashes);","-","-\t\t$privateKey = $privateKey","-\t\t\t->withMGFHash('sha512')","-\t\t\t->withSaltLength(0)","-\t\t\t->withPadding(RSA::SIGNATURE_PSS);","-","-\t\t$signature = $privateKey->sign(\\json_encode($hashes));","-","-\t\treturn [","-\t\t\t\t'hashes' => $hashes,","-\t\t\t\t'signature' => \\base64_encode($signature),","-\t\t\t\t'certificate' => $x509->saveX509($certificate),","-\t\t\t];","-\t}","-","-\t/**","-\t * Write the signature of the app in the specified folder","-\t *","-\t * @param string $path","-\t * @param array $certificate","-\t * @param X509 $x509","-\t * @param RSA $privateKey","-\t * @throws \\Exception","-\t */","-\tpublic function writeAppSignature(","-\t\tstring $path,","-\t\tarray $certificate,","-\t\tX509 $x509,","-\t\tRSA $privateKey","-\t) {","-\t\t$appInfoDir = $path . '/appinfo';","-\t\t$this->fileAccessHelper->assertDirectoryExists($path);","-\t\t$this->fileAccessHelper->assertDirectoryExists($appInfoDir);","-","-\t\t$iterator = $this->getFolderIterator($path);","-\t\t$hashes = $this->generateHashes($iterator, $path);","-\t\t$signature = $this->createSignatureData($hashes, $certificate, $privateKey, $x509);","-\t\ttry {","-\t\t\t$this->fileAccessHelper->file_put_contents(","-\t\t\t\t$appInfoDir . '/signature.json',","-\t\t\t\t\\json_encode($signature, JSON_PRETTY_PRINT)","-\t\t\t);","-\t\t} catch (\\Exception $e) {","-\t\t\tif (!$this->fileAccessHelper->is_writeable($appInfoDir)) {","-\t\t\t\tthrow new \\Exception($appInfoDir . ' is not writable');","-\t\t\t}","-\t\t\tthrow $e;","-\t\t}","-\t}","-","-\t/**","-\t * Write the signature of core","-\t *","-\t * @param string $path","-\t * @param array $certificate","-\t * @param X509 $x509","-\t * @param RSA $privateKey","-\t * @throws \\Exception","-\t */","-\tpublic function writeCoreSignature(","-\t\tstring $path,","-\t\tarray $certificate,"