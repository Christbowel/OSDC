{"id":"b0bb8c90c7e50f96616fffa24cdee55ee21491a6","axis":"silent","repo":"duckdb/duckdb","sha":"b0bb8c90c7e50f96616fffa24cdee55ee21491a6","parsed":{"files":[{"path":"src/function/table/system/CMakeLists.txt","lines":["@@ -12,6 +12,7 @@ add_library_unity(","   duckdb_extensions.cpp","   duckdb_external_file_cache.cpp","   external_resource_types.cpp","+  external_resources.cpp","   duckdb_functions.cpp","   duckdb_keywords.cpp","   duckdb_log.cpp"],"additions":1,"deletions":0,"truncated":false},{"path":"src/function/table/system/create_external_resource.cpp","lines":["@@ -1,8 +1,7 @@"," #include \"duckdb/function/table/system_functions.hpp\""," #include \"duckdb/catalog/catalog.hpp\""," #include \"duckdb/catalog/catalog_entry/schema_catalog_entry.hpp\"","-#include \"duckdb/catalog/entry_lookup_info.hpp\"","-#include \"duckdb/common/enums/on_entry_not_found.hpp\"","+#include \"duckdb/common/error_data.hpp\""," #include \"duckdb/common/exception.hpp\""," #include \"duckdb/common/string_util.hpp\""," #include \"duckdb/common/types/value.hpp\"","@@ -10,6 +9,9 @@"," #include \"duckdb/main/connection.hpp\""," #include \"duckdb/main/database.hpp\""," #include \"duckdb/main/external_resource_type_registry.hpp\"","+#include \"duckdb/main/external_resources_manager.hpp\"","+#include \"duckdb/logging/log_type.hpp\"","+#include \"duckdb/logging/logger.hpp\""," #include \"duckdb/parser/qualified_name.hpp\""," "," #include <chrono>","@@ -17,6 +19,24 @@"," "," namespace duckdb {"," ","+//! Empty `extra_info` map for an ExternalResource log entry.","+static Value NoExtraInfo() {","+\treturn Value::MAP(LogicalType::VARCHAR, LogicalType::VARCHAR, vector<Value>(), vector<Value>());","+}","+","+//! Single-entry `extra_info` map for an ExternalResource log entry.","+static Value ExtraInfo(const string &key, const string &value) {","+\treturn Value::MAP(LogicalType::VARCHAR, LogicalType::VARCHAR, {Value(key)}, {Value(value)});","+}","+","+//! Log one recipe callback invocation (on response). `resource_type` may be empty (rendered NULL) when","+//! the callsite does not know it; `error` is empty on success.","+static void LogExternalResourceOperation(ClientContext &context, const string &resource_type,","+                                         const string &resource_name, const char *operation, const string &error,","+                                         const Value &extra_info) {","+\tDUCKDB_LOG(context, ExternalResourceLogType, resource_type, resource_name, string(operation), error, extra_info);","+}","+"," //! Defaults for the readiness poll loop, both overridable per call via named parameters. A timeout of 0"," //! means wait indefinitely (rely on a terminal status or query cancellation)."," static constexpr int64_t DEFAULT_READINESS_TIMEOUT_SECONDS = 300;","@@ -55,22 +75,6 @@ static Value RequireResourceMap(const Value &value, const string &function_name,"," \treturn value.DefaultCastAs(LogicalType::MAP(LogicalType::VARCHAR, LogicalType::VARCHAR));"," }"," ","-//! Resolve a table-producing callback (a table function or table macro) to its fully-qualified","-//! `catalog.schema.name` in `context`'s search path, so the returned deleter stays resolvable from any other","-//! connection later (e.g. when DETACH fires it). Returns empty if the callback can't be resolved.","-static string QualifyTableCallback(ClientContext &context, const string &name) {","-\tEntryLookupInfo table_fn(CatalogType::TABLE_FUNCTION_ENTRY, QualifiedName::Parse(name));","-\tauto entry = Catalog::GetEntry(context, table_fn, OnEntryNotFound::RETURN_NULL);","-\tif (!entry) {","-\t\tEntryLookupInfo table_macro(CatalogType::TABLE_MACRO_ENTRY, QualifiedName::Parse(name));","-\t\tentry = Catalog::GetEntry(context, table_macro, OnEntryNotFound::RETURN_NULL);","-\t}","-\tif (!entry) {","-\t\treturn string();","-\t}","-\treturn QualifiedName(entry->ParentCatalog().GetName(), entry->ParentSchema().name, entry->name).ToString();","-}","-"," //===--------------------------------------------------------------------===//"," // create_external_resource(type_name [, params := MAP])"," //","@@ -94,7 +98,10 @@ static int64_t ReadSecondsParameter(const string &key, const Value &value, int64"," "," struct CreateExternalResourceBindData : public TableFunctionData {"," \tstring type_name;","+\tstring resource_name;"," \tValue params;","+\t//! When set (non-NULL), adopt this existing handle instead of calling `create` to provision a new one.","+\tValue adopt_handle;"," \tbool teardown_on_failure = true;"," \tint64_t timeout_seconds = DEFAULT_READINESS_TIMEOUT_SECONDS;"," \tint64_t poll_interval_seconds = DEFAULT_POLL_INTERVAL_SECONDS;","@@ -116,6 +123,10 @@ static unique_ptr<FunctionData> CreateExternalResourceBind(ClientContext &contex"," \t\tauto key = StringUtil::Lower(np.first.GetIdentifierName());"," \t\tif (key == \"params\" && !np.second.IsNull()) {"," \t\t\tresult->params = np.second;","+\t\t} else if (key == \"resource_name\" && !np.second.IsNull()) {","+\t\t\tresult->resource_name = StringValue::Get(np.second);","+\t\t} else if (key == \"handle\" && !np.second.IsNull()) {","+\t\t\tresult->adopt_handle = np.second;"," \t\t} else if (key == \"teardown_on_failure\" && !np.second.IsNull()) {"," \t\t\tresult->teardown_on_failure = BooleanValue::Get(np.second);"," \t\t} else if (key == \"timeout_seconds\" && !np.second.IsNull()) {","@@ -160,11 +171,6 @@ static void CreateExternalResourceFunction(ClientContext &context, TableFunction"," \tif (!type) {"," \t\tthrow InvalidInputException(\"create_external_resource: unknown resource type \\\"%s\\\"\", bind_data.type_name);"," \t}","-\tif (type->create_function.empty()) {","-\t\tthrow InvalidInputException(\"create_external_resource: resource type \\\"%s\\\" has no create function\",","-\t\t                            bind_data.type_name);","-\t}","-"," \t// Separate internal connection: the current connection's context lock is held here."," \tConnection con(DatabaseInstance::GetDatabase(context));"," \t// Resolve the callbacks in the search path captured at registration, so unqualified names in a non-default","@@ -177,26 +183,53 @@ static void CreateExternalResourceFunction(ClientContext &context, TableFunction"," \t\t\t    bind_data.type_name, type->search_path, set_res->GetError());"," \t\t}"," \t}","-\tauto sql = \"SELECT * FROM \" + QualifiedName::Parse(type->create_function).ToString() + \"(\" +","-\t           bind_data.params.ToSQLString() + \")\";","-\tauto result = con.Query(sql);","-\tif (result->HasError()) {","-\t\tthrow IOException(\"create_external_resource: create function \\\"%s\\\" failed: %s\", type->create_function,","-\t\t                  result->GetError());","-\t}","-\tif (result->RowCount() == 0) {","-\t\tthrow InvalidInputException(\"create_external_resource: create function \\\"%s\\\" returned no rows\",","-\t\t                            type->create_function);","+","+\t// Provision (call `create`) or adopt (use the caller-supplied handle). A `create` returns a single","+\t// 'handle' column (a MAP; opaque to us, passed back to status/destroy).","+\tconst bool adopting = !bind_data.adopt_handle.IsNull();","+\tValue handle;","+\tif (adopting) {","+\t\thandle = RequireResourceMap(bind_data.adopt_handle, bind_data.type_name, \"handle\");","+\t} else {","+\t\tif (type->create_function.empty()) {","+\t\t\tthrow InvalidInputException(\"create_external_resource: resource type \\\"%s\\\" has no create function\",","+\t\t\t                            bind_data.type_name);","+\t\t}","+\t\tauto sql = \"SELECT * FROM \" + QualifiedName::Parse(type->create_function).ToString() + \"(\" +","+\t\t           bind_data.params.ToSQLString() + \")\";","+\t\t// Log the operation's real outcome: the callback query returning without error is not yet success, the","+\t\t// result still has to satisfy the contract below. Logging from the catch also covers throws added later.","+\t\ttry {","+\t\t\tauto result = con.Query(sql);","+\t\t\tif (result->HasError()) {","+\t\t\t\tthrow IOException(\"create_external_resource: create function \\\"%s\\\" failed: %s\", type->create_function,","+\t\t\t\t                  result->GetError());","+\t\t\t}","+\t\t\tif (result->RowCount() == 0) {","+\t\t\t\tthrow InvalidInputException(\"create_external_resource: create function \\\"%s\\\" returned no rows\",","+\t\t\t\t                            type->create_function);","+\t\t\t}","+\t\t\thandle = RequireResourceMap(result->GetValue(0, 0), type->create_function, \"handle\");","+\t\t\tLogExternalResourceOperation(context, bind_data.type_name, bind_data.resource_name, \"create\", string(),","+\t\t\t                             NoExtraInfo());","+\t\t} catch (std::exception &ex) {","+\t\t\tLogExternalResourceOperation(context, bind_data.type_name, bind_data.resource_name, \"create\",","+\t\t\t                             ErrorData(ex).RawMessage(), NoExtraInfo());","+\t\t\tthrow;","+\t\t}"," \t}","-\t// Contract: `create` returns a single 'handle' column (a MAP; opaque to us, passed back to status/destroy).","-\tauto handle = RequireResourceMap(result->GetValue(0, 0), type->create_function, \"handle\");"," ","-\t// Ownership: the resource now exists. We own its teardown until we successfully hand back the deleter","-\t// binding below; on any failure in between (status 'failed', timeout, cancellation, malformed result,","-\t// baseline violation) tear it down best-effort — unless teardown_on_failure is disabled, e.g. to inspect","-\t// a rolled-back resource. This guard runs the destroy on every exit path, including exception unwinding.","+\t// Ownership: when we provisioned the resource, we own its teardown until we successfully hand back the","+\t// deleter binding below; on any failure in between (status 'failed', timeout, cancellation, malformed","+\t// result, baseline violation) tear it down best-effort. When a handle was supplied the resource","+\t// already existed and is not ours to destroy on failure, so the guard stays disarmed regardless of","+\t// teardown_on_failure.","+\tbool teardown_on_failure = !adopting && bind_data.teardown_on_failure;"," \tbool deleter_returned = false;"," \tstruct TeardownGuard {","+\t\tClientContext &context;","+\t\tconst string &resource_type;","+\t\tconst string &resource_name;"," \t\tConnection &con;"," \t\tconst string &destroy_function;"," \t\tconst Value &handle;","@@ -207,12 +240,24 @@ static void CreateExternalResourceFunction(ClientContext &context, TableFunction"," \t\t\t\treturn;"," \t\t\t}"," \t\t\ttry {","-\t\t\t\tcon.Query(\"SELECT * FROM \" + QualifiedName::Parse(destroy_function).ToString() + \"(\" +","-\t\t\t\t          handle.ToSQLString() + \")\");","-\t\t\t} catch (...) { // best-effort: never mask the original failure with a teardown error","+\t\t\t\tauto sql = \"SELECT * FROM \" + QualifiedName::Parse(destroy_function).ToString() + \"(\" +","+\t\t\t\t           handle.ToSQLString() + \")\";","+\t\t\t\tauto res = con.Query(sql);","+\t\t\t\tLogExternalResourceOperation(context, resource_type, resource_name, \"destroy\",","+\t\t\t\t                             res->HasError() ? res->GetError() : string(), NoExtraInfo());","+\t\t\t} catch (std::exception &ex) {","+\t\t\t\t// best-effort: never mask the original failure with a teardown error, but do record it - a","+\t\t\t\t// throwing Query() would otherwise leave the failed teardown invisible.","+\t\t\t\ttry {","+\t\t\t\t\tLogExternalResourceOperation(context, resource_type, resource_name, \"destroy\",","+\t\t\t\t\t                             ErrorData(ex).RawMessage(), NoExtraInfo());","+\t\t\t\t} catch (...) { // logging must not throw out of a destructor","+\t\t\t\t}","+\t\t\t} catch (...) {"," \t\t\t}"," \t\t}","-\t} teardown_guard {con, type->destroy_function, handle, bind_data.teardown_on_failure, deleter_returned};","+\t} teardown_guard {context, bind_data.type_name, bind_data.resource_name, con, type->destroy_function,","+\t                  handle,  teardown_on_failure, deleter_returned};"," "," \tif (type->status_function.empty()) {"," \t\tthrow InvalidInputException(","@@ -231,28 +276,42 @@ static void CreateExternalResourceFunction(ClientContext &context, TableFunction"," \t\tcontext.InterruptCheck();"," \t\tauto status_sql = \"SELECT state, result FROM \" + QualifiedName::Parse(type->status_function).ToString() + \"(\" +"," \t\t                  handle.ToSQLString() + \")\";","-\t\tauto sres = con.Query(status_sql);","-\t\tif (sres->HasError()) {","-\t\t\tthrow IOException(\"create_external_resource: status function \\\"%s\\\" failed: %s\", type->status_function,","-\t\t\t                  sres->GetError());","-\t\t}","-\t\tif (sres->RowCount() == 0) {","-\t\t\tthrow InvalidInputException(\"create_external_resource: status function \\\"%s\\\" returned no rows\",","-\t\t\t                            type->status_function);","+\t\t// One log entry per poll, written once the poll's outcome is known, so a poll is never recorded as 'ok'","+\t\t// only to fail validation a few lines later. The catch also covers the 'failed' and timeout throws.","+\t\tbool ready = false;","+\t\ttry {","+\t\t\tauto sres = con.Query(status_sql);","+\t\t\tif (sres->HasError()) {","+\t\t\t\tthrow IOException(\"create_external_resource: status function \\\"%s\\\" failed: %s\", type->status_function,","+\t\t\t\t                  sres->GetError());","+\t\t\t}","+\t\t\tif (sres->RowCount() == 0) {","+\t\t\t\tthrow InvalidInputException(\"create_external_resource: status function \\\"%s\\\" returned no rows\",","+\t\t\t\t                            type->status_function);","+\t\t\t}","+\t\t\tauto state_val = sres->GetValue(0, 0);","+\t\t\tauto status_state = state_val.IsNull() ? string() : state_val.ToString();","+\t\t\tif (status_state == \"failed\") {","+\t\t\t\tthrow IOException(\"create_external_resource: resource \\\"%s\\\" reported state 'failed'\",","+\t\t\t\t                  bind_data.type_name);","+\t\t\t}","+\t\t\tif (status_state == \"ready\") {","+\t\t\t\tstatus_result = RequireResourceMap(sres->GetValue(1, 0), type->status_function, \"result\");","+\t\t\t\tready = true;","+\t\t\t} else if (has_deadline && std::chrono::steady_clock::now() >= deadline) {","+\t\t\t\tthrow IOException(\"create_external_resource: timed out awaiting readiness for \\\"%s\\\" (last state '%s')\",","+\t\t\t\t                  bind_data.type_name, status_state);","+\t\t\t}","+\t\t\tLogExternalResourceOperation(context, bind_data.type_name, bind_data.resource_name, \"status\", string(),","+\t\t\t                             status_state.empty() ? NoExtraInfo() : ExtraInfo(\"state\", status_state));","+\t\t} catch (std::exception &ex) {","+\t\t\tLogExternalResourceOperation(context, bind_data.type_name, bind_data.resource_name, \"status\",","+\t\t\t                             ErrorData(ex).RawMessage(), NoExtraInfo());","+\t\t\tthrow;"," \t\t}","-\t\tauto state_val = sres->GetValue(0, 0);","-\t\tauto status_state = state_val.IsNull() ? string() : state_val.ToString();","-\t\tif (status_state == \"ready\") {","-\t\t\tstatus_result = RequireResourceMap(sres->GetValue(1, 0), type->status_function, \"result\");","+\t\tif (ready) {"," \t\t\tbreak;"," \t\t}","-\t\tif (status_state == \"failed\") {","-\t\t\tthrow IOException(\"create_external_resource: resource \\\"%s\\\" reported state 'failed'\", bind_data.type_name);","-\t\t}","-\t\tif (has_deadline && std::chrono::steady_clock::now() >= deadline) {","-\t\t\tthrow IOException(\"create_external_resource: timed out awaiting readiness for \\\"%s\\\" (last state '%s')\",","-\t\t\t                  bind_data.type_name, status_state);","-\t\t}"," \t\t// Interruptible wait: sleep the poll interval in short slices, checking for cancellation between them."," \t\t// The slice is small so InterruptCheck() is called often enough to honor max_execution_time promptly"," \t\t// (its deadline check is throttled to run every Nth call).","@@ -309,6 +368,8 @@ void CreateExternalResourceFun::RegisterFunction(BuiltinFunctions &set) {"," \tTableFunction fn(\"create_external_resource\", {LogicalType::VARCHAR}, CreateExternalResourceFunction,"," \t                 CreateExternalResourceBind, CreateExternalResourceInit);"," \tfn.named_parameters[\"params\"] = LogicalType::MAP(LogicalType::VARCHAR, LogicalType::VARCHAR);","+\tfn.named_parameters[\"resource_name\"] = LogicalType::VARCHAR;","+\tfn.named_parameters[\"handle\"] = LogicalType::MAP(LogicalType::VARCHAR, LogicalType::VARCHAR);"," \tfn.named_parameters[\"teardown_on_failure\"] = LogicalType::BOOLEAN;"," \tfn.named_parameters[\"timeout_seconds\"] = LogicalType::BIGINT;"," \tfn.named_parameters[\"poll_interval_seconds\"] = LogicalType::BIGINT;","@@ -361,10 +422,17 @@ static void DestroyExternalResourceFunction(ClientContext &context, TableFunctio"," \tConnection con(DatabaseInstance::GetDatabase(context));"," \tauto sql = \"SELECT * FROM \" + QualifiedName::Parse(bind_data.deleter_function).ToString() + \"(\" +"," \t           bind_data.deleter_payload.ToSQLString() + \")\";","-\tauto result = con.Query(sql);","-\tif (result->HasError()) {","-\t\tthrow IOException(\"destroy_external_resource: deleter function \\\"%s\\\" failed: %s\", bind_data.deleter_function,","-\t\t                  result->GetError());","+\t// resource_type/name are unknown at this callsite (the deleter binding does not carry them).","+\ttry {","+\t\tauto result = con.Query(sql);","+\t\tif (result->HasError()) {","+\t\t\tthrow IOException(\"destroy_external_resource: deleter function \\\"%s\\\" failed: %s\",","+\t\t\t                  bind_data.deleter_function, result->GetError());","+\t\t}","+\t\tLogExternalResourceOperation(context, string(), string(), \"destroy\", string(), NoExtraInfo());","+\t} catch (std::exception &ex) {","+\t\tLogExternalResourceOperation(context, string(), string(), \"destroy\", ErrorData(ex).RawMessage(), NoExtraInfo());","+\t\tthrow;"," \t}"," \toutput.data[0].Append(Value::BOOLEAN(true));"," \tstate.done = true;"],"additions":134,"deletions":66,"truncated":false},{"path":"src/function/table/system/external_resources.cpp","lines":["@@ -0,0 +1,223 @@","+#include \"duckdb/function/table/system_functions.hpp\"","+","+#include \"duckdb/common/exception.hpp\"","+#include \"duckdb/common/types/value.hpp\"","+#include \"duckdb/main/external_resources_manager.hpp\"","+","+namespace duckdb {","+","+//===--------------------------------------------------------------------===//","+// duckdb_external_resources()","+//","+// Lists the external resources locally registered in this instance's ExternalResourcesManager","+// (managed = true).","+//===--------------------------------------------------------------------===//","+","+struct ExternalResourceRow {","+\tstring name;","+\tstring type;","+\tValue handle;","+\tstring uri;","+\tstring attached_db_type;","+\tbool managed;","+};","+","+struct ExternalResourcesGlobalState : public GlobalTableFunctionState {","+\tExternalResourcesGlobalState() : offset(0) {","+\t}","+\tvector<ExternalResourceRow> rows;","+\tidx_t offset;","+};","+","+static unique_ptr<FunctionData> ExternalResourcesBind(ClientContext &context, TableFunctionBindInput &input,","+                                                      vector<LogicalType> &return_types, vector<string> &names) {","+\tnames.emplace_back(\"name\");","+\treturn_types.emplace_back(LogicalType::VARCHAR);","+\tnames.emplace_back(\"type\");","+\treturn_types.emplace_back(LogicalType::VARCHAR);","+\tnames.emplace_back(\"managed\");","+\treturn_types.emplace_back(LogicalType::BOOLEAN);","+\tnames.emplace_back(\"uri\");","+\treturn_types.emplace_back(LogicalType::VARCHAR);","+\tnames.emplace_back(\"attached_db_type\");","+\treturn_types.emplace_back(LogicalType::VARCHAR);","+\tnames.emplace_back(\"handle\");","+\treturn_types.emplace_back(LogicalType::MAP(LogicalType::VARCHAR, LogicalType::VARCHAR));","+\treturn nullptr;","+}","+","+static unique_ptr<GlobalTableFunctionState> ExternalResourcesInit(ClientContext &context,","+                                                                  TableFunctionInitInput &input) {","+\tauto result = make_uniq<ExternalResourcesGlobalState>();","+\t// Locally registered resources — always shown (managed = true).","+\tfor (auto &instance : ExternalResourcesManager::Get(context).List()) {","+\t\tExternalResourceRow row;","+\t\trow.name = instance.name;","+\t\trow.type = instance.type;","+\t\trow.handle = instance.handle;","+\t\trow.uri = instance.uri;","+\t\trow.attached_db_type = instance.attached_db_type;","+\t\trow.managed = true;","+\t\tresult->rows.push_back(std::move(row));","+\t}","+\treturn std::move(result);","+}","+","+static Value NullableString(const string &s) {","+\treturn s.empty() ? Value(LogicalType::VARCHAR) : Value(s);","+}","+","+static void ExternalResourcesFunction(ClientContext &context, TableFunctionInput &data_p, DataChunk &output) {","+\tauto &state = data_p.global_state->Cast<ExternalResourcesGlobalState>();","+\tauto empty_handle = Value(LogicalType::MAP(LogicalType::VARCHAR, LogicalType::VARCHAR));","+\tidx_t count = 0;","+\twhile (state.offset < state.rows.size() && count < STANDARD_VECTOR_SIZE) {","+\t\tauto &r = state.rows[state.offset++];","+\t\toutput.data[0].Append(NullableString(r.name));","+\t\toutput.data[1].Append(Value(r.type));","+\t\toutput.data[2].Append(Value::BOOLEAN(r.managed));","+\t\toutput.data[3].Append(NullableString(r.uri));","+\t\toutput.data[4].Append(NullableString(r.attached_db_type));","+\t\toutput.data[5].Append(r.handle.IsNull() ? empty_handle : r.handle);","+\t\tcount++;","+\t}","+}","+","+void DuckDBExternalResourcesFun::RegisterFunction(BuiltinFunctions &set) {","+\tset.AddFunction(TableFunction(\"duckdb_external_resources\", {}, ExternalResourcesFunction, ExternalResourcesBind,","+\t                              ExternalResourcesInit));","+}","+","+//===--------------------------------------------------------------------===//","+// register_external_resource(type, name, handle, uri := , attached_db_type := , deleter_function := )","+//","+// Registry write: record an already-provisioned resource in this instance's ExternalResourcesManager under","+// `name`, so it shows up in duckdb_external_resources() and can be torn down later. Pure — it provisions","+// nothing; feed it the result of create_external_resource(). The durable identity is (type, handle).","+//===--------------------------------------------------------------------===//","+","+struct RegisterExternalResourceBindData : public TableFunctionData {","+\tExternalResource resource;","+};","+","+struct RegisterExternalResourceState : public GlobalTableFunctionState {","+\tbool done = false;","+};","+","+static unique_ptr<FunctionData> RegisterExternalResourceBind(ClientContext &context, TableFunctionBindInput &input,","+                                                             vector<LogicalType> &return_types, vector<string> &names) {","+\tauto result = make_uniq<RegisterExternalResourceBindData>();","+\tauto &resource = result->resource;","+\tif (input.inputs[0].IsNull() || input.inputs[1].IsNull()) {","+\t\tthrow InvalidInputException(\"register_external_resource: the type and name must not be NULL\");","+\t}","+\tresource.type = StringValue::Get(input.inputs[0]);","+\tresource.name = StringValue::Get(input.inputs[1]);","+\t// The handle is the durable identity and doubles as the deleter payload.","+\tresource.handle = input.inputs[2];","+\tresource.deleter_payload = input.inputs[2];","+\tfor (auto &np : input.named_parameters) {","+\t\tauto key = StringUtil::Lower(np.first.GetIdentifierName());","+\t\tif (np.second.IsNull()) {","+\t\t\tcontinue;","+\t\t}","+\t\tif (key == \"uri\") {","+\t\t\tresource.uri = StringValue::Get(np.second);","+\t\t} else if (key == \"attached_db_type\") {","+\t\t\tresource.attached_db_type = StringValue::Get(np.second);","+\t\t} else if (key == \"deleter_function\") {","+\t\t\t// Qualify against the registering connection's search path: teardown runs the deleter on a separate","+\t\t\t// internal connection. Fall back to the name as given when it does not resolve (yet) - the defining","+\t\t\t// extension may not be loaded at registration time.","+\t\t\tauto deleter = StringValue::Get(np.second);","+\t\t\tauto qualified = QualifyTableCallback(context, deleter);","+\t\t\tresource.deleter_function = qualified.empty() ? deleter : qualified;","+\t\t}","+\t}","+\treturn_types.emplace_back(LogicalType::BOOLEAN);","+\tnames.emplace_back(\"Success\");","+\treturn std::move(result);","+}","+","+static unique_ptr<GlobalTableFunctionState> RegisterExternalResourceInit(ClientContext &context,","+                                                                         TableFunctionInitInput &input) {","+\treturn make_uniq<RegisterExternalResourceState>();","+}","+","+static void RegisterExternalResourceFunction(ClientContext &context, TableFunctionInput &data_p, DataChunk &output) {","+\tauto &state = data_p.global_state->Cast<RegisterExternalResourceState>();","+\tif (state.done) {","+\t\treturn;","+\t}","+\tauto &bind_data = data_p.bind_data->Cast<RegisterExternalResourceBindData>();","+\t// Add() validates name/type are non-empty and rejects a duplicate name.","+\tExternalResourcesManager::Get(context).Add(bind_data.resource);","+\toutput.data[0].Append(Value::BOOLEAN(true));","+\tstate.done = true;","+}","+","+void RegisterExternalResourceFun::RegisterFunction(BuiltinFunctions &set) {","+\tTableFunction fn(","+\t    \"register_external_resource\",","+\t    {LogicalType::VARCHAR, LogicalType::VARCHAR, LogicalType::MAP(LogicalType::VARCHAR, LogicalType::VARCHAR)},","+\t    RegisterExternalResourceFunction, RegisterExternalResourceBind, RegisterExternalResourceInit);","+\tfn.named_parameters[\"uri\"] = LogicalType::VARCHAR;","+\tfn.named_parameters[\"attached_db_type\"] = LogicalType::VARCHAR;","+\tfn.named_parameters[\"deleter_function\"] = LogicalType::VARCHAR;","+\tset.AddFunction(fn);","+}","+","+//===--------------------------