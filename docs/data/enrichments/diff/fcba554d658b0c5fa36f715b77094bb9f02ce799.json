der{}","+\ts := &Server{","+\t\tlogger:                    zap.NewNop(),","+\t\tExpectedUnderscoreHeaders: []string{\"user_id\"},","+\t\tprimaryHandlerChain: HandlerFunc(func(w http.ResponseWriter, r *http.Request) error {","+\t\t\t*got = r.Header.Clone()","+\t\t\treturn nil","+\t\t}),","+\t}","+\trequire.NoError(t, s.provisionUnderscoreHeaders())","+","+\treq := httptest.NewRequest(http.MethodGet, \"http://example.com/\", nil)","+\treq.Header.Set(\"X-Real-Header\", \"ok\")","+\treq.Header.Set(\"Content-Type\", \"text/plain\")","+","+\trequire.NoError(t, s.serveHTTP(httptest.NewRecorder(), req))","+\tassert.Equal(t, \"ok\", got.Get(\"X-Real-Header\"))","+\tassert.Equal(t, \"text/plain\", got.Get(\"Content-Type\"))","+}","+","+// --- Allowlist: mixed underscore/hyphen entry ---","+","+func TestServer_serveHTTP_MixedEntryKeepsOriginal(t *testing.T) {","+\tgot := &http.Header{}","+\ts := &Server{","+\t\tlogger:                    zap.NewNop(),","+\t\tExpectedUnderscoreHeaders: []string{\"__user-id\"},","+\t\tprimaryHandlerChain: HandlerFunc(func(w http.ResponseWriter, r *http.Request) error {","+\t\t\t*got = r.Header.Clone()","+\t\t\treturn nil","+\t\t}),","+\t}","+\trequire.NoError(t, s.provisionUnderscoreHeaders())","+","+\treq := httptest.NewRequest(http.MethodGet, \"http://example.com/\", nil)","+\treq.Header[\"__user-Id\"] = []string{\"zeus\"} // canonical form of __user-id","+","+\trequire.NoError(t, s.serveHTTP(httptest.NewRecorder(), req))","+\tassert.Equal(t, \"zeus\", got.Get(\"__user-Id\"))","+}","+","+func TestServer_serveHTTP_MixedEntryDropsFullyHyphenated(t *testing.T) {","+\tgot := &http.Header{}","+\ts := &Server{","+\t\tlogger:                    zap.NewNop(),","+\t\tExpectedUnderscoreHeaders: []string{\"__user-id\"},","+\t\tprimaryHandlerChain: HandlerFunc(func(w http.ResponseWriter, r *http.Request) error {","+\t\t\t*got = r.Header.Clone()","+\t\t\treturn nil","+\t\t}),","+\t}","+\trequire.NoError(t, s.provisionUnderscoreHeaders())","+","+\treq := ht