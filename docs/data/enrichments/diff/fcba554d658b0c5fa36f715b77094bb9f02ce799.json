full_duplex,omitempty\"`"," ","+\t// A list of header field names containing underscores that should","+\t// be preserved instead of being dropped. By default, Caddy drops","+\t// ALL headers with underscores to prevent ambiguity with","+\t// CGI/FastCGI backends that map hyphens to underscores","+\t// (GHSA-f59h-q822-g45g). When this list is configured, only the","+\t// specified headers are kept; their hyphenated variants are","+\t// actively dropped to prevent confusion. Entries are","+\t// case-insensitive. A trailing \"*\" acts as a prefix glob","+\t// (e.g., \"webhook_*\" matches any header starting with","+\t// \"webhook_\"). If an allowlisted header arrives with","+\t// multiple values (repeated field), all values are dropped","+\t// as a safeguard against header injection.","+\t//","+\t// TODO: This is an EXPERIMENTAL feature. Subject to change or removal.","+\tExpectedUnderscoreHeaders []string `json:\"expected_underscore_headers,omitempty\"`","+"," \t// Routes describes how this server will handle requests."," \t// Routes are executed sequentially. First a route's matchers"," \t// are evaluated, then its grouping. If it matches and has","@@ -293,6 +309,11 @@ type Server struct {"," "," \tshutdownAt atomic.Pointer[time.Time]"," ","+\t// precomputed underscore header allowlist (built during provisioning)","+\tunderscoreExactAllow  map[string]struct{}","+\tunderscoreExactDrop   map[string]struct{}","+\tunderscorePrefixRules []underscoreRule","+"," \t// registered callback functions"," \tconnStateFuncs   []func(net.Conn, http.ConnState)"," \tconnContextFuncs []func(ctx context.Context, c net.Conn) context.Context","@@ -300,6 +321,95 @@ type Server struct {"," \tonStopFuncs      []func(context.Context) error // TODO: Experimental (Nov. 2023)"," }"," ","+// underscoreRule pairs a canonical underscore prefix with its hyphenated","+// counterpart. Used for prefix-glob matching in the allowlist.","+type underscoreRule struct {","+\tallow string // canonical underscore form, e.g. \"Webhook_\"","+\tdrop  string // canonical hyphenated form, e.g. \"Webhook-\"","+}","+","+// provisionUnderscoreHeaders validates the ExpectedUnderscoreHeaders","+// entries and builds the precomputed maps and prefix rules used by","+// the hot-path filter in serveHTTP.","+func (s *Server) provisionUnderscoreHeaders() error {","+\tif len(s.ExpectedUnderscoreHeaders) == 0 {","+\t\treturn nil","+\t}","+","+\ts.underscoreExactAllow = make(map[string]struct{}, len(s.ExpectedUnderscoreHeaders))","+\ts.underscoreExactDrop = make(map[string]struct{}, len(s.ExpectedUnderscoreHeaders))","+","+\tfor _, entry := range s.ExpectedUnderscoreHeaders {","+\t\t// Reject non-ASCII bytes: Go's HTTP parser returns 400 for","+\t\t// non-ASCII header names, so such entries can never match.","+\t\tfor i := 0; i < len(entry); i++ {","+\t\t\tif entry[i] >= 0x80 {","+\t\t\t\treturn fmt.Errorf(\"expected_underscore_headers: entry %q contains non-ASCII characters\", entry)","+\t\t\t}","+\t\t}","+","+\t\tisGlob := strings.HasSuffix(entry, \"*\")","+\t\tname := entry","+\t\tif isGlob {","+\t\t\tname = strings.TrimSuffix(entry, \"*\")","+\t\t}","+","+\t\t// Reject entries with '*' not at the trailing position.","+\t\tif strings.ContainsRune(name, '*') {","+\t\t\treturn fmt.Errorf(\"expected_underscore_headers: entry %q has '*' in an invalid position (only a trailing '*' is allowed)\", entry)","+\t\t}","+","+\t\t// The name (without trailing '*') must contain at least one underscore.","+\t\tif !strings.ContainsRune(name, '_') {","+\t\t\treturn fmt.Errorf(\"expected_underscore_headers: entry %q does not contain an underscore\", entry)","+\t\t}","+","+\t\tcanonAllow := http.CanonicalHeaderKey(name)","+\t\tcanonDrop := http.CanonicalHeaderKey(strings.ReplaceAll(name, \"_\", \"-\"))","+","+\t\tif isGlob {","+\t\t\ts.underscorePrefixRules = append(s.underscorePrefixRules, underscoreRule{","+\t\t\t\tallow: canonAllow,","+\t\t\t\tdrop:  canonDrop,","+\t\t\t})","+\t\t} else {","+\t\t\ts.underscoreExactAllow[canonAllow] = struct{}{}","+\t\t\ts.underscoreExactDrop[canonDrop] = struct{}{}","+\t\t}","+\t}","+","+\treturn nil","+}","+","+// isAllowedUnderscoreHeader reports whether key (a canonical header","+// name containing an underscore) is permitted by the allowlist.","+func (s *Server) isAllowedUnderscoreHeader(key string) bool {","+\tif _, ok := s.underscoreExactAllow[key]; ok {","+\t\treturn true","+\t}","+\tfor _, rule := range s.underscorePrefixRules {","+\t\tif strings.HasPrefix(key, rule.allow) {","+\t\t\treturn true","+\t\t}","+\t}","+\treturn false","+}","+","+// isHyphenatedVariant reports whether key (a canonical header name","+// without underscores) is the hyphenated variant of an allowlisted","+// underscore header and should therefore be dropped.","+func (s *Server) isHyphenatedVariant(key string) bool {","+\tif _, ok := s.underscoreExactDrop[key]; ok {","+\t\treturn true","+\t}","+\tfor _, rule := range s.underscorePrefixRules {","+\t\tif strings.HasPrefix(key, rule.drop) {","+\t\t\treturn true","+\t\t}","+\t}","+\treturn false","+}","+"," var defaultProtocols = []string{\"h1\", \"h2\", \"h3\"}"," "," var (","@@ -497,12 +607,41 @@ func (s *Server) serveHTTP(w http.ResponseWriter, r *http.Request) error {"," \t// Drop headers whose names contain `_`: once FastCGI/CGI/FrankenPHP etc. rewrites `-` to"," \t// `_`, an underscore alias collides with the legitimate hyphenated header"," \t// and can bypass `forward_auth copy_headers` (GHSA-f59h-q822-g45g).","-\tfor k := range r.Header {","-\t\tif strings.ContainsRune(k, '_') {","-\t\t\tdelete(r.Header, k)","+\t//","+\t// When an allowlist is configured, only the listed headers are kept and","+\t// their hyphenated variants are actively dropped to prevent ambiguity.","+\tif len(s.ExpectedUnderscoreHeaders) == 0 {","+\t\tfor k := range r.Header {","+\t\t\tif strings.ContainsRune(k, '_') {","+\t\t\t\tdelete(r.Header, k)","+","+\t\t\t\tif c := s.logger.Check(zapcore.DebugLevel, \"dropping header