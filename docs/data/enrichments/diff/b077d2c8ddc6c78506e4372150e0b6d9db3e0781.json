":false},{"path":"tests/Fixtures/PrintInlineFailures/features/bootstrap/FeatureContext.php","lines":["@@ -0,0 +1,25 @@","+<?php","+","+use Behat\\Behat\\Context\\Context;","+use Behat\\Behat\\Tester\\Exception\\PendingException;","+use Behat\\Step\\Given;","+","+class FeatureContext implements Context","+{","+    #[Given('a passing step')]","+    public function aPassingStep(): void","+    {","+    }","+","+    #[Given('a failing step')]","+    public function aFailingStep(): void","+    {","+        throw new RuntimeException('step failed as supposed');","+    }","+","+    #[Given('a pending step')]","+    public function aPendingStep(): void","+    {","+        throw new PendingException();","+    }","+}"],"additions":25,"deletions":0,"truncated":false},{"path":"tests/Fixtures/PrintInlineFailures/features/inline.feature","lines":["@@ -0,0 +1,11 @@","+Feature: Inline failures","+","+  Scenario: Passing then failing","+    Given a passing step","+    And a failing step","+","+  Scenario: Pending","+    Given a pending step","+","+  Scenario: Undefined","+    Given an undefined step",""],"additions":11,"deletions":0,"truncated":false}],"additions":311,"deletions":16,"truncated":false,"file_count":10},"error":null,"fetched_at":"2026-07-10T10:53:39.763971+00:00"}