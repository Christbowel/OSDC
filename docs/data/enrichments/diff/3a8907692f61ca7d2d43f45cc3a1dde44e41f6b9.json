ounting for rate limiters. The caller must call","+// (batchThrottleCallback).performAccounting with the BatchResponse after the","+// evaluation completes."," //"," // Of note is that request throttling is all performed above evaluation and"," // before a request acquires latches on a range. Otherwise, the request could"," // inadvertently block others while being throttled."," func (s *Store) maybeThrottleBatch("," \tctx context.Context, ba *kvpb.BatchRequest,","-) (limit.Reservation, error) {","+) (batchThrottleCallback, error) {"," \tif !ba.IsSingleRequest() {","-\t\treturn nil, nil","+\t\treturn batchThrottleCallback{}, nil"," \t}"," ","-\tswitch t := ba.Requests[0].GetInner().(type) {","-\tcase *kvpb.AddSSTableRequest:","+\tif t := ba.Requests[0].GetAddSstable(); t != nil {"," \t\tlimiter := s.limiters.ConcurrentAddSSTableRequests"," \t\tif t.IngestAsWrites {"," \t\t\tlimiter = s.limiters.ConcurrentAddSSTableAsWritesRequests","@@ -337,7 +352,7 @@ func (s *Store) maybeThrottleBatch("," \t\tbefore := timeutil.Now()"," \t\tres, err := limiter.Begin(ctx)"," \t\tif err != nil {","-\t\t\treturn nil, err","+\t\t\treturn batchThrottleCallback{}, err"," \t\t}"," \t\twaited := timeutil.Since(before)"," ","@@ -345,27 +360,81 @@ func (s *Store) maybeThrottleBatch("," \t\tif waited > time.Second {"," \t\t\tlog.KvExec.Infof(ctx, \"SST ingestion was delayed by %v\", waited)"," \t\t}","-\t\treturn res, nil","+\t\treturn batchThrottleCallback{reservation: res}, nil","+\t}"," ","-\tcase *kvpb.ExportRequest:","-\t\t// Limit the number of concurrent Export requests, as these often scan and","-\t\t// entire Range at a time and place significant read load on a Store.","+\tif ba.IsBulkLowPriorityRead() {"," \t\tbefore := timeutil.Now()","-\t\tres, err := s.limiters.ConcurrentExportRequests.Begin(ctx)","+","+\t\t// Throttle based on concurrent requests limiter first.","+\t\tres, err := s.limiters.ConcurrentBulkReadRequests.Begin(ctx)"," \t\tif err != nil {","-\t\t\treturn nil, err","+\t\t\treturn batchThrottleCallback{}, err","+\t\t}","+","+\t\t// Helper function to try to obtain tokens from this bucket under","+\t\t// the lock.","+\t\tobtainTokens := func() (bool, time.Duration) {","+\t\t\ts.limiters.BulkIOReadRate.Lock()","+\t\t\tdefer s.limiters.BulkIOReadRate.Unlock()","+\t\t\treturn s.limiters.BulkIOReadRate.TryToFulfill(1)","+\t\t}","+","+\t\t// Throttle based on rate-limiter token bucket. If the context is","+\t\t// canceled then we need to release the reservation.","+\t\tok, delay := obtainTokens()","+\t\tvar timer timeutil.Timer","+\t\tdefer timer.Stop()","+\t\tfor !ok {","+\t\t\ttimer.Reset(delay)","+\t\t\tselect {","+\t\t\tcase <-ctx.Done():","+\t\t\t\tres.Release()","+\t\t\t\treturn batchThrottleCallback{}, errors.Wrap(ctx.Err(), \"context ended while throttling bulk read request\")","+\t\t\tcase <-timer.C:","+\t\t\t\ttimer.Read = true","+\t\t\t\tok, delay = obtainTokens()","+\t\t\t}"," \t\t}"," "," \t\twaited := timeutil.Since(before)","-\t\ts.metrics.ExportRequestProposalTotalDelay.Inc(waited.Nanoseconds())","+\t\ts.metrics.BulkLowPriReadRequestTotalDelay.Inc(waited.Nanoseconds())"," \t\tif waited > time.Second {","-\t\t\tlog.VEventf(ctx, 1, \"export request was delayed by %v\", waited)","+\t\t\tlog.KvExec.Infof(ctx, \"bulk low-priority read operation was delayed by %v\", waited)"," \t\t}","-\t\treturn res, nil"," ","-\tdefault:","-\t\treturn nil, nil","+\t\treturn batchThrottleCallback{reservation: res, limiters: &s.limiters}, nil"," \t}","+","+\treturn batchThrottleCallback{}, nil","+}","+","+// performAccounting must be called after maybeThrottleBatch with the returned","+// batchThrottleCallback and the BatchResponse.","+func (b batchThrottleCallback) performAccounting(br *kvpb.BatchResponse) {","+\tif b.reservation != nil {","+\t\tb.reservation.Release()","+\t}","+\tif b.limiters == nil {","+\t\treturn","+\t}","+","+\t// Calculate the actual token adjustment needed from the BatchResponse. We","+\t// get the number of bytes that were read, and then deduct them (less one,","+\t// for the token we already got) from the bucket. We don't care about the","+\t// token bucket falling too much into -ve, because we have pagination in the","+\t// TTL layer and also a ConcurrentRequestLimiter to ensure the bucket","+\t// doesn't fall arbitrarily into debt.","+\tvar bytesRead int64","+\tif br != nil {","+\t\tfor _, resp := range br.Responses {","+\t\t\tbytesRead += resp.GetInner().Header().NumBytes","+\t\t}","+\t}","+","+\tb.limiters.BulkIOReadRate.Lock()","+\tdefer b.limiters.BulkIOReadRate.Unlock()","+\tb.limiters.BulkIOReadRate.Adjust(1 - tokenbucket.Tokens(bytesRead))"," }"," "," // executeServerSideBoundedStalenessNegotiation performs the server-side"],"additions":90,"deletions":21,"truncated":false},{"path":"pkg/roachprod/agents/opentelemetry/files/cockroachdb_metrics.yaml","lines":["@@ -1105,7 +1105,6 @@ exec_latency_bucket: exec.latency.bucket"," exec_latency_count: exec.latency.count"," exec_latency_sum: exec.latency.sum"," exec_success: exec.success","-exportrequest_delay_total: exportrequest.delay.total"," follower_reads_success_count: follower_reads.success_count"," gcbytesage: gcbytesage"," go_scheduler_latency: go.scheduler_latency","@@ -1524,6 +1523,7 @@ kv_allocator_load_based_replica_rebalancing_delta_not_significant: kv.allocator."," kv_allocator_load_based_replica_rebalancing_existing_not_overfull: kv.allocator.load_based_replica_rebalancing.existing_not_overfull"," kv_allocator_load_based_replica_rebalancing_missing_stats_for_existing_store: kv.allocator.load_based_replica_rebalancing.missing_stats_for_existing_store"," kv_allocator_load_based_replica_rebalancing_should_transfer: kv.allocator.load_based_replica_rebalancing.should_transfer","+kv_bulk_low_pri_read_delay_total: kv.bulk_low_pri_read.delay.total"," kv_closed_timestamp_max_behind_nanos: kv.closed_timestamp.max_behind_nanos"," kv_closed_timestamp_policy_change: kv.closed_timestamp.policy_change"," kv_closed_timestamp_po