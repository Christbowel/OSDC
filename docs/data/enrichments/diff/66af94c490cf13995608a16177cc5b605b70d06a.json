           if (!id.endsWith('gl-matrix/index.d.ts')) return null;","+            const code = fs.readFileSync(id, 'utf8');","+            return code.replace(/declare module \"gl-matrix\" \\{/, '').replace(/\\}\\s*$/, '');","+        }","+    };","+}","+","+function dtsConfig(input: string, file: string, umd: boolean): RollupOptions {","+    return {","+        input,","+        output: {","+            file,","+            format: 'es',","+            // The UMD entry declares a global `mapboxgl` namespace for script-tag users.","+            footer: umd ? 'export as namespace mapboxgl;' : undefined,","+        },","+        external,","+        plugins: [","+            unwrapGlMatrix(),","+            dts({respectExternal: true, tsconfig: './tsconfig.browser.json'}),","+        ],","+    };","+}","+","+export default (): RollupOptions[] => [","+    dtsConfig('src/index.ts', 'dist/mapbox-gl.d.ts', true),","+    dtsConfig('src/index.esm.ts', 'dist/esm/mapbox-gl.d.ts', false),","+];"],"additions":66,"deletions":0,"truncated":false},{"path":"src/data/mrt/mrt.esm.d.ts","lines":["@@ -1,6 +1,6 @@"," /**","  * We need to keep TypeScript definitions of the `mrt.esm.js` in a separate file","- * because `dts-bundle-generator` does not support referencing types from JavaScript files.","+ * because the `.d.ts` bundler does not support referencing types from JavaScript files.","  *","  * To generate the TypeScript definitions, run:","  * npx tsc --allowJs --declaration --emitDeclarationOnly --outDir . --removeComments mrt.esm.js"],"additions":1,"deletions":1,"truncated":false},{"path":"src/style-spec/package.json","lines":["@@ -32,7 +32,7 @@","     \"pretest\": \"npm run build\",","     \"test\": \"node ./test.js\",","     \"build\": \"npm run build-spec && npm run build-dts\",","-    \"build-dts\": \"dts-bundle-generator --no-banner --export-referenced-types=false --project ../../tsconfig.browser.json -o ./dist/index.d.ts ./style-spec.ts\",","+    \"build-dts\": \"rollup -c r