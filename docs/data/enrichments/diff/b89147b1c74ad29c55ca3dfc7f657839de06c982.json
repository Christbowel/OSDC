\"","+    },","+    \"default_import_callable_at_runtime\": {","+      \"args\": \"run main.ts\",","+      \"output\": \"run.out\"","+    }","+  }","+}"],"additions":12,"deletions":0,"truncated":false},{"path":"tests/specs/check/npm_esm_shared_default_types/main.out","lines":["@@ -0,0 +1 @@","+[WILDCARD]Check [WILDCARD]main.ts"],"additions":1,"deletions":0,"truncated":false},{"path":"tests/specs/check/npm_esm_shared_default_types/main.ts","lines":["@@ -0,0 +1,11 @@","+// Regression test for https://github.com/denoland/deno/issues/28071.","+//","+// The npm package mimics `@rollup/plugin-replace`: its `exports` map has a","+// shared bare `types` condition that resolves to a `.d.ts` file using","+// `export default function`, with an `import` condition pointing at an","+// ESM-mode `.js` file. The default import should resolve to the function","+// type, not the module namespace.","+import replace from \"npm:@denotest/esm-shared-default-types\";","+","+const result: string = replace({ delimiters: [\"<\", \">\"] });","+console.log(result);"],"additions":11,"deletions":0,"truncated":false},{"path":"tests/specs/check/npm_esm_shared_default_types/run.out","lines":["@@ -0,0 +1 @@","+[WILDCARD]replaced"],"additions":1,"deletions":0,"truncated":false},{"path":"tests/specs/check/npm_mixed_cjs_main_esm_subpath/__test__.jsonc","lines":["@@ -0,0 +1,8 @@","+{","+  \"tests\": {","+    \"package_global_scan_flips_cjs_main_to_esm\": {","+      \"args\": \"check main.ts\",","+      \"output\": \"main.out\"","+    }","+  }","+}"],"additions":8,"deletions":0,"truncated":false},{"path":"tests/specs/check/npm_mixed_cjs_main_esm_subpath/main.out","lines":["@@ -0,0 +1 @@","+[WILDCARD]Check [WILDCARD]main.ts"],"additions":1,"deletions":0,"truncated":false},{"path":"tests/specs/check/npm_mixed_cjs_main_esm_subpath/main.ts","lines":["@@ -0,0 +1,10 @@","+// Pins the chosen behavior of `exports_has_import_condition`: because the","+// `./esm` subpath declares an `import` condition, the package