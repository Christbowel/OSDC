{"id":"7f181ecc067b0ba6ba30d4ca714675b085d7145b","axis":"silent","repo":"grafana/grafana","sha":"7f181ecc067b0ba6ba30d4ca714675b085d7145b","parsed":{"files":[{"path":"conf/defaults.ini","lines":["@@ -155,6 +155,21 @@ cluster_port = 6222"," # Advertise address for peer discovery. If empty, listen_address is used."," advertise_address ="," ","+# Transport security for client connections.","+tls_enabled = false","+tls_ca_cert_path =","+tls_cert_path =","+tls_key_path =","+tls_server_name =","+# For testing only; never enable in production.","+tls_insecure_skip_verify = false","+","+# Connection identity. token is the simplest form; credentials_file points to a NATS .creds file (JWT + NKEY).","+# A per-role publisher file lets the publisher present a least-privilege identity; it falls back to credentials_file.","+token =","+credentials_file =","+publisher_credentials_file =","+"," #################################### Grafana API server (Kubernetes-style APIs) #########################"," [grafana-apiserver]"," # Comma-separated list of group/version entries. For each entry, discovery uses that version as the"],"additions":15,"deletions":0,"truncated":false},{"path":"go.mod","lines":["@@ -719,7 +719,7 @@ require ("," "," require ("," \tgithub.com/nats-io/nats-server/v2 v2.14.0 // @grafana/grafana-search-and-storage","-\tgithub.com/nats-io/nats.go v1.52.0 // indirect; @grafana/grafana-search-and-storage","+\tgithub.com/nats-io/nats.go v1.52.0 // @grafana/grafana-search-and-storage"," )"," "," require ("],"additions":1,"deletions":1,"truncated":false},{"path":"pkg/infra/nats/config.go","lines":["@@ -0,0 +1,57 @@","+package nats","+","+import (","+\tnatsclient \"github.com/nats-io/nats.go\"","+","+\t\"github.com/grafana/grafana/pkg/setting\"","+)","+","+// Config is the runtime configuration a connection needs to dial NATS. It","+// resolves URLs and dial options based on deployment mode (embedded or","+// external). Its exported methods form the contract consumed by connection.","+type Config struct {","+\tcfg  setting.NATSSettings","+\turls []string","+","+\tserver *Server","+}","+","+func newConfig(cfg setting.NATSSettings, server *Server) *Config {","+\treturn &Config{","+\t\tcfg:    cfg,","+\t\turls:   append([]string(nil), cfg.ClientURLs...),","+\t\tserver: server,","+\t}","+}","+","+// ProvideNATSConfig builds the shared connection config from configuration and","+// the Server that owns the embedded NATS lifecycle.","+func ProvideNATSConfig(cfg *setting.Cfg, server *Server) *Config {","+\treturn newConfig(cfg.NATS, server)","+}","+","+// Enabled reports whether NATS is turned on at all.","+func (c *Config) Enabled() bool { return c.cfg.Enabled }","+","+// TLS returns the client TLS configuration.","+func (c *Config) TLS() setting.NATSTLSSettings { return c.cfg.TLS }","+","+// Token returns the shared auth token, if any.","+func (c *Config) Token() string { return c.cfg.Auth.Token }","+","+// URLs returns the client URLs known so far. In embedded mode the running","+// server's local URL is prepended ahead of the configured peers. Safe for","+// concurrent use.","+func (c *Config) URLs() []string {","+\tif local := c.server.clientURL(); local != \"\" {","+\t\treturn append([]string{local}, c.urls...)","+\t}","+\treturn append([]string(nil), c.urls...)","+}","+","+// DialOptions returns extra dial options. In embedded mode this carries the","+// in-process server hop so the local connection bypasses TCP/TLS. Safe for","+// concurrent use.","+func (c *Config) DialOptions() []natsclient.Option {","+\treturn c.server.dialOptions()","+}"],"additions":57,"deletions":0,"truncated":false},{"path":"pkg/infra/nats/config_test.go","lines":["@@ -0,0 +1,102 @@","+package nats","+","+import (","+\t\"sync\"","+\t\"testing\"","+","+\t\"github.com/stretchr/testify/require\"","+","+\t\"github.com/grafana/grafana/pkg/setting\"","+)","+","+func TestConfig(t *testing.T) {","+\tt.Run(\"ProvideNATSConfig exposes the configured urls\", func(t *testing.T) {","+\t\tcfg := setting.NewCfg()","+\t\tcfg.NATS = setting.NATSSettings{ClientURLs: []string{\"nats://a:4222\", \"nats://b:4222\"}}","+","+\t\tc := ProvideNATSConfig(cfg, nil)","+","+\t\trequire.Equal(t, []string{\"nats://a:4222\", \"nats://b:4222\"}, c.URLs())","+\t\trequire.Empty(t, c.DialOptions())","+\t})","+","+\tt.Run(\"no configured urls\", func(t *testing.T) {","+\t\tc := newConfig(setting.NATSSettings{}, nil)","+\t\trequire.Empty(t, c.URLs())","+\t\trequire.Empty(t, c.DialOptions())","+\t})","+","+\tt.Run(\"URLs returns a defensive copy\", func(t *testing.T) {","+\t\tc := newConfig(setting.NATSSettings{ClientURLs: []string{\"nats://a:4222\"}}, nil)","+","+\t\t// Mutating the returned slice must not affect the config's internal state.","+\t\tgot := c.URLs()","+\t\tgot[0] = \"nats://tampered:4222\"","+","+\t\trequire.Equal(t, []string{\"nats://a:4222\"}, c.URLs())","+\t})","+","+\tt.Run(\"decoupled from the config slice\", func(t *testing.T) {","+\t\tconfigured := []string{\"nats://a:4222\"}","+\t\tc := newConfig(setting.NATSSettings{ClientURLs: configured}, nil)","+","+\t\t// Mutating the original config slice must not leak into the Config.","+\t\tconfigured[0] = \"nats://tampered:4222\"","+","+\t\trequire.Equal(t, []string{\"nats://a:4222\"}, c.URLs())","+\t})","+","+\tt.Run(\"DialOptions returns a defensive copy\", func(t *testing.T) {","+\t\tc := newConfig(setting.NATSSettings{}, &Server{server: startTestServer(t)})","+","+\t\topts := c.DialOptions()","+\t\trequire.Len(t, opts, 1)","+","+\t\t// Mutating the returned slice must not affect the config's internal state.","+\t\topts[0] = nil","+\t\trequire.NotNil(t, c.DialOptions()[0])","+\t})","+","+\tt.Run(\"embedded server url is prepended ahead of peers\", func(t *testing.T) {","+\t\tsrv := startTestServer(t)","+\t\tc := newConfig(setting.NATSSettings{ClientURLs: []string{\"nats://peer:4222\"}}, &Server{server: srv})","+","+\t\t// The embedded server's local URL is prepended ahead of the configured peers.","+\t\trequire.Equal(t, []string{srv.ClientURL(), \"nats://peer:4222\"}, c.URLs())","+\t\t// The in-process dial option is published so the local hop bypasses TCP/TLS.","+\t\trequire.Len(t, c.DialOptions(), 1)","+\t})","+","+\tt.Run(\"embedded server without peers\", func(t *testing.T) {","+\t\tsrv := startTestServer(t)","+\t\tc := newConfig(setting.NATSSettings{}, &Server{server: srv})","+","+\t\trequire.Equal(t, []string{srv.ClientURL()}, c.URLs())","+\t\trequire.Len(t, c.DialOptions(), 1)","+\t})","+","+\tt.Run(\"external mode without an embedded server\", func(t *testing.T) {","+\t\t// A Server that never started (external mode) exposes no embedded server, so","+\t\t// the config falls back to the configured client URLs.","+\t\tc := newConfig(setting.NATSSettings{ClientURLs: []string{\"nats://peer:4222\"}}, &Server{})","+","+\t\trequire.Equal(t, []string{\"nats://peer:4222\"}, c.URLs())","+\t\trequire.Empty(t, c.DialOptions())","+\t})","+","+\tt.Run(\"concurrent access is race-free\", func(t *testing.T) {","+\t\tsrv := startTestServer(t)","+\t\tc := newConfig(setting.NATSSettings{ClientURLs: []string{\"nats://a:4222\"}}, &Server{server: srv})","+","+\t\tvar wg sync.WaitGroup","+\t\tfor i := 0; i < 50; i++ {","+\t\t\twg.Add(2)","+\t\t\tgo func() { defer wg.Done(); _ = c.URLs() }()","+\t\t\tgo func() { defer wg.Done(); _ = c.DialOptions() }()","+\t\t}","+\t\twg.Wait()","+","+\t\trequire.Equal(t, []string{srv.ClientURL(), \"nats://a:4222\"}, c.URLs())","+\t\trequire.Len(t, c.DialOptions(), 1)","+\t})","+}"],"additions":102,"deletions":0,"truncated":false},{"path":"pkg/infra/nats/connection.go","lines":["@@ -0,0 +1,215 @@","+package nats","+","+import (","+\t\"context\"","+\t\"fmt\"","+\t\"strings\"","+\t\"sync\"","+\t\"time\"","+","+\tnatsclient \"github.com/nats-io/nats.go\"","+","+\t\"github.com/grafana/grafana/pkg/infra/log\"","+)","+","+type connRole string","+","+const rolePublisher connRole = \"publisher\"","+","+// drainTimeout bounds how long close() waits for in-flight work to flush, so a","+// broker that has gone away cannot stall shutdown for the nats.go default of 30s.","+const drainTimeout = 10 * time.Second","+","+// connection lazily establishes and reuses a single NATS connection per role for least-privilege credentials.","+type connection struct {","+\tlog         log.Logger","+\tmetrics     *clientMetrics","+\trole        connRole","+\tconfig      *Config","+\tcredentials func() string","+","+\tmu     sync.Mutex","+\tconn   *natsclient.Conn","+\tclosed bool","+}","+","+func newConnection(role connRole, logger log.Logger, m *clientMetrics, config *Config, credentials func() string) *connection {","+\treturn &connection{","+\t\tlog:         logger,","+\t\tmetrics:     m,","+\t\trole:        role,","+\t\tconfig:      config,","+\t\tcredentials: credentials,","+\t}","+}","+","+func (c *connection) Enabled() bool { return c.config.Enabled() }","+","+func (c *connection) get(ctx context.Context) (*natsclient.Conn, error) {","+\tif !c.Enabled() {","+\t\treturn nil, ErrDisabled","+\t}","+\t// Honour cancellation even on the warm path, where no dial happens.","+\tif err := ctx.Err(); err != nil {","+\t\treturn nil, err","+\t}","+\tc.mu.Lock()","+\tdefer c.mu.Unlock()","+\tif c.closed {","+\t\treturn nil, ErrClosed","+\t}","+\tif c.conn != nil && !c.conn.IsClosed() {","+\t\treturn c.conn, nil","+\t}","+\tnc, err := c.connect(ctx)","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\tc.conn = nc","+\treturn nc, nil","+}","+","+func (c *connection) connect(ctx context.Context) (*natsclient.Conn, error) {","+\turls := c.config.URLs()","+\tif len(urls) == 0 {","+\t\treturn nil, fmt.Errorf(\"no nats client urls configured\")","+\t}","+","+\toptions, err := c.connectOptions()","+\tif err != nil {","+\t\treturn nil, err","+\t}","+\toptions = append(options, c.config.DialOptions()...)","+","+\t// nats.Connect blocks on the initial dial; honour ctx cancellation.","+\ttype result struct {","+\t\tconn *natsclient.Conn","+\t\terr  error","+\t}","+\tch := make(chan result, 1)","+\tgo func() {","+\t\tnc, err := natsclient.Connect(strings.Join(urls, \",\"), options...)","+\t\tch <- result{conn: nc, err: err}","+\t}()","+","+\tselect {","+\tcase <-ctx.Done():","+\t\t// The dial goroutine may still be in flight. Drain its result and close","+\t\t// any connection it produces, otherwise it is orphaned and would reconnect","+\t\t// forever in the background (MaxReconnects(-1)).","+\t\tgo func() {","+\t\t\tif res := <-ch; res.conn != nil {","+\t\t\t\tres.conn.Close()","+\t\t\t}","+\t\t}()","+\t\treturn nil, ctx.Err()","+\tcase res := <-ch:","+\t\tif res.err != nil {","+\t\t\tc.metrics.connectionErrors.WithLabelValues(string(c.role)).Inc()","+\t\t\treturn nil, fmt.Errorf(\"connect nats %s: %w\", c.role, res.err)","+\t\t}","+\t\t// connectionStatus is driven solely by the connect/reconnect/disconnect","+\t\t// handlers: with RetryOnFailedConnect the conn returned here may still be","+\t\t// dialing in the background, so setting it to 1 now would report a healthy","+\t\t// connection that is not yet established.","+\t\treturn res.conn, nil","+\t}","+}","+","+func (c *connection) connectOptions() ([]natsclient.Option, error) {","+\troleStr := string(c.role)","+\toptions := []natsclient.Option{","+\t\tnatsclient.Name(\"grafana-nats-\" + roleStr),","+\t\tnatsclient.Timeout(5 * time.Second),","+\t\tnatsclient.RetryOnFailedConnect(true),","+\t\tnatsclient.MaxReconnects(-1),","+\t\tnatsclient.ReconnectWait(2 * time.Second),","+\t\tnatsclient.ReconnectJitter(100*time.Millisecond, time.Second),","+\t\tnatsclient.PingInterval(20 * time.Second),","+\t\tnatsclient.MaxPingsOutstanding(3),","+\t\tnatsclient.DrainTimeout(drainTimeout),","+\t\t// Disable the reconnect buffer: rather than silently buffering up to the","+\t\t// 8MB default during an outage fail publishes fast.","+\t\tnatsclient.ReconnectBufSize(-1),","+\t\tnatsclient.ConnectHandler(func(nc *natsclient.Conn) {","+\t\t\tc.metrics.connectionStatus.WithLabelValues(roleStr).Set(1)","+\t\t\tc.log.Info(\"nats connected\", \"role\", roleStr, \"url\", nc.ConnectedUrl())","+\t\t}),","+\t\tnatsclient.DisconnectErrHandler(func(_ *natsclient.Conn, err error) {","+\t\t\tc.metrics.connectionStatus.WithLabelValues(roleStr).Set(0)","+\t\t\tc.metrics.disconnects.WithLabelValues(roleStr).Inc()","+\t\t\tif err != nil {","+\t\t\t\tc.log.Warn(\"nats disconnected\", \"role\", roleStr, \"err\", err)","+\t\t\t}","+\t\t}),","+\t\tnatsclient.ReconnectHandler(func(nc *natsclient.Conn) {","+\t\t\tc.metrics.connectionStatus.WithLabelValues(roleStr).Set(1)","+\t\t\tc.metrics.reconnects.WithLabelValues(roleStr).Inc()","+\t\t\tc.log.Info(\"nats reconnected\", \"role\", roleStr, \"url\", nc.ConnectedUrl())","+\t\t}),","+\t\tnatsclient.ClosedHandler(func(nc *natsclient.Conn) {","+\t\t\tc.metrics.connectionStatus.WithLabelValues(roleStr).Set(0)","+\t\t\tc.log.Info(\"nats connection closed\", \"role\", roleStr, \"last_err\", nc.LastError())","+\t\t}),","+\t\tnatsclient.ErrorHandler(func(_ *natsclient.Conn, sub *natsclient.Subscription, err error) {","+\t\t\tsubject := \"\"","+\t\t\tif sub != nil {","+\t\t\t\tsubject = sub.Subject","+\t\t\t}","+\t\t\tc.log.Warn(\"nats async error\", \"role\", roleStr, \"subject\", subject, \"err\", err)","+\t\t}),","+\t}","+","+\tif tls := c.config.TLS(); tls.Enabled {","+\t\ttc, err := buildTLSConfig(tls)","+\t\tif err != nil {","+\t\t\treturn nil, err","+\t\t}","+\t\toptions = append(options, natsclient.Secure(tc))","+\t}","+","+\t// Precedence: per-role creds file > shared creds file > token.","+\tswitch creds := c.credentials(); {","+\tcase creds != \"\":","+\t\toptions = append(options, natsclient.UserCredentials(creds))","+\tcase c.config.Token() != \"\":","+\t\toptions = append(options, natsclient.Token(c.config.Token()))","+\t}","+","+\treturn options, nil","+}","+","+// healthy reports whether the connection is usable. It tolerates the lazy state","+// before first use (conn == nil): an idle service that has never published is","+// not a failure. Once a connection exists, it must actually be connected.","+func (c *connection) healthy() error {","+\tif !c.Enabled() {","+\t\treturn ErrDisabled","+\t}","+\tc.mu.Lock()","+\tdefer c.mu.Unlock()","+\tif c.closed {","+\t\treturn ErrClosed","+\t}","+\tif c.conn == nil {","+\t\treturn nil","+\t}","+\tif !c.conn.IsConnected() {","+\t\treturn fmt.Errorf(\"nats %s connection is not connected (status=%s)\", c.role, c.conn.Status())","+\t}","+\treturn nil","+}","+","+// close drains the connection so in-flight work flushes before shutdown. It is","+// terminal: once closed, get() refuses to reopen a connection.","+func (c *connection) close() {","+\tc.mu.Lock()","+\tdefer c.mu.Unlock()","+\tc.closed = true","+\tif c.conn != nil && !c.conn.IsClosed() {","+\t\tif err := c.conn.Drain(); err != nil {","+\t\t\tc.log.Warn(\"failed to drain nats connection\", \"role\", c.role, \"err\", err)","+\t\t}","+\t}","+\tc.conn = nil","+}"],"additions":215,"deletions":0,"truncated":false},{"path":"pkg/infra/nats/connection_test.go","lines":["@@ -0,0 +1,188 @@","+package nats","+","+import (","+\t\"context\"","+\t\"sync\"","+\t\"testing\"","+\t\"time\"","+","+\tnatsclient \"github.com/nats-io/nats.go\"","+\t\"github.com/prometheus/client_golang/prometheus\"","+\t\"github.com/prometheus/client_golang/prometheus/testutil\"","+\t\"github.com/stretchr/testify/require\"","+","+\t\"github.com/grafana/grafana/pkg/infra/log\"","+\t\"github.com/grafana/grafana/pkg/setting\"","+)","+","+// newDisabledConnection builds a connection with NATS turned off, for the paths","+// that must short-circuit before any dial.","+func newDisabledConnection() *connection {","+\tcfg := setting.NATSSettings{Enabled: false}","+\treturn newConnection(rolePublisher, log.NewNopLogger(), newClientMetrics(prometheus.NewRegistry()), newConfig(cfg, nil), func() string { return \"\" })","+}","+","+func TestConnection(t *testing.T) {","+\tt.Run(\"Enabled reflects config\", func(t *testing.T) {","+\t\trequire.False(t, newDisabledConnection().Enabled())","+","+\t\tcfg := setting.NATSSettings{Enabled: true}","+\t\tenabled := newConnection(rolePublisher, log.NewNopLogger(), newClientMetrics(prometheus.NewRegistry()), newConfig(cfg, nil), func() string { return \"\" })","+\t\trequire.True(t, enabled.Enabled())","+\t})","+","+\tt.Run(\"get returns ErrDisabled when disabled\", func(t *testing.T) {","+\t\t_, err := newDisabledConnection().get(context.Background())","+\t\trequire.ErrorIs(t, err, ErrDisabled)","+\t})","+","+\tt.Run(\"get errors when no urls configured\", func(t *testing.T) {","+\t\tcfg := setting.NATSSettings{Enabled: true}","+\t\tc := newConnection(rolePublisher, log.NewNopLogger(), newClientMetrics(prometheus.NewRegistry()), newConfig(cfg, nil), func() string { return \"\" })","+","+\t\t_, err := c.get(context.Background())","+\t\trequire.ErrorContains(t, err, \"no nats client urls configured\")","+\t})","+","+\tt.Run(\"get reuses the established connection\", func(t *testing.T) {","+\t\tc := newTestConnection(t, startTestServer(t))","+","+\t\tfirst, err := c.get(context.Background())","+\t\trequire.NoError(t, err)","+\t\trequire.NotNil(t, first)","+","+\t\tsecond, err := c.get(context.Background())","+\t\trequire.NoError(t, err)","+\t\t// The warm path returns the same connection rather than redialing.","+\t\trequire.Same(t, first, second)","+\t})","+","+\tt.Run(\"get sets the connection status metric\", func(t *testing.T) {","+\t\tsrv := startTestServer(t)","+\t\tcfg := setting.NATSSettings{Enabled: true}","+\t\tm := newClientMetrics(prometheus.NewRegistry())","+\t\tc := newConnection(rolePublisher, log.NewNopLogger(), m, newTestConfig(srv, cfg), func() string { return \"\" })","+\t\tt.Cleanup(c.close)","+","+\t\t_, err := c.get(context.Background())","+\t\trequire.NoError(t, err)","+","+\t\t// The ConnectHandler fires asynchronously; wait for it to mark the role healthy.","+\t\trequire.Eventually(t, func() bool {","+\t\t\treturn testutil.ToFloat64(m.connectionStatus.WithLabelValues(string(rolePublisher))) == 1","+\t\t}, 5*time.Second, 10*time.Millisecond)","+\t})","+","+\tt.Run(\"get honours a cancelled context on the warm path\", func(t *testing.T) {","+\t\tc := newTestConnection(t, startTestServer(t))","+","+\t\t// Warm the connection so cancellation is observed by the explicit ctx.Err()","+\t\t// check rather than during the dial.","+\t\t_, err := c.get(context.Background())","+\t\trequire.NoError(t, err)","+","+\t\tctx, cancel := context.WithCancel(context.Background())","+\t\tcancel()","+\t\t_, err = c.get(ctx)","+\t\trequire.ErrorIs(t, err, context.Canceled)","+\t})","+","+\tt.Run(\"get returns ErrClosed after close\", func(t *testing.T) {","+\t\tc := newTestConnection(t, startTestServer(t))","+","+\t\t_, err := c.get(context.Background())","+\t\trequire.NoError(t, err)","+","+\t\tc.close()","+\t\t_, err = c.get(context.Background())","+\t\trequire.ErrorIs(t, err, ErrClosed)","+\t})","+","+\tt.Run(\"get is safe for concurrent callers\", func(t *testing.T) {","+\t\tc := newTestConnection(t, startTestServer(t))","+","+\t\tvar (","+\t\t\twg    sync.WaitGroup","+\t\t\tmu    sync.Mutex","+\t\t\tconns = map[*natsclient.Conn]struct{}{}","+\t\t)","+\t\tfor i := 0; i < 50; i++ {","+\t\t\twg.Add(1)","+\t\t\tgo func() {","+\t\t\t\tdefer wg.Done()","+\t\t\t\tnc, err := c.get(context.Background())","+\t\t\t\trequire.NoError(t, err)","+\t\t\t\tmu.Lock()","+\t\t\t\tconns[nc] = struct{}{}","+\t\t\t\tmu.Unlock()","+\t\t\t}()","+\t\t}","+\t\twg.Wait()","+","+\t\t// Concurrent callers must all share the single lazily-established connection.","+\t\trequire.Len(t, conns, 1)","+\t})","+","+\tt.Run(\"healthy\", func(t *testing.T) {","+\t\tt.Run(\"disabled\", func(t *testing.T) {","+\t\t\trequire.ErrorIs(t, newDisabledConnection().healthy(), ErrDisabled)","+\t\t})","+","+\t\tt.Run(\"lazy before first use\", func(t *testing.T) {","+\t\t\tc := newTestConnection(t, startTestServer(t))","+\t\t\t// An idle service that has never connected is not a failure.","+\t\t\trequire.NoError(t, c.healthy())","+\t\t})","+","+\t\tt.Run(\"connected\", func(t *testing.T) {","+\t\t\tc := newTestConnection(t, startTestServer(t))","+\t\t\t_, err := c.get(context.Background())","+\t\t\trequire.NoError(t, err)","+\t\t\trequire.NoError(t, c.healthy())","+\t\t})","+","+\t\tt.Run(\"closed\", func(t *testing.T) {","+\t\t\tc := newTestConnection(t, startTestServer(t))","+\t\t\tc.close()","+\t\t\trequire.ErrorIs(t, c.healthy(), ErrClosed)","+\t\t})","+\t})","+","+\tt.Run(\"close\", func(t *testing.T) {","+\t\tt.Run(\"is idempotent\", func(t *testing.T) {","+\t\t\tc := newTestConnection(t, startTestServer(t))","+\t\t\t_, err := c.get(context.Background())","+\t\t\trequire.NoError(t, err)","+","+\t\t\trequire.NotPanics(t, func() {","+\t\t\t\tc.close()","+\t\t\t\tc.close()","+\t\t\t})","+\t\t})","+","+\t\tt.Run(\"is safe and terminal without a connection\", func(t *testing.T) {","+\t\t\tc := newTestConnection(t, startTestServer(t))","+\t\t\trequire.NotPanics(t, c.close)","+\t\t\trequire.ErrorIs(t, c.healthy(), ErrClosed)","+\t\t})","+\t})","+","+\tt.Run(\"connectOptions\", func(t *testing.T) {","+\t\tt.Run(\"builds base options without auth\", func(t *testing.T) {","+\t\t\tcfg := setting.NATSSettings{Enabled: true}","+\t\t\tc := newConnection(rolePublisher, log.NewNopLogger(), newClientMetrics(prometheus.NewRegistry()), newConfig(cfg, nil), func() string { return \"\" })","+","+\t\t\topts, err := c.connectOptions()","+\t\t\trequire.NoError(t, err)","+\t\t\trequire.NotEmpty(t, opts)","+\t\t})","+","+\t\tt.Run(\"propagates invalid TLS config\", func(t *testing.T) {","+\t\t\tcfg := setting.NATSSettings{Enabled: true, TLS: setting.NATSTLSSettings{Enabled: true, CACertPath: \"/does/not/exist.pem\"}}","+\t\t\tc := newConnection(rolePublisher, log.NewNopLogger(), newClientMetrics(prometheus.NewRegistry()), newConfig(cfg, nil), func() string { return \"\" })","+","+\t\t\t_, err := c.connectOptions()","+\t\t\