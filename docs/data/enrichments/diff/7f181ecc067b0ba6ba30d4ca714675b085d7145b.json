ing{roleLabel}),","+\t\treconnects: prometheus.NewCounterVec(prometheus.CounterOpts{","+\t\t\tNamespace: metricsNamespace,","+\t\t\tSubsystem: metricsSubsystem,","+\t\t\tName:      \"reconnects_total\",","+\t\t\tHelp:      \"Total number of NATS reconnections per role.\",","+\t\t}, []string{roleLabel}),","+\t\tdisconnects: prometheus.NewCounterVec(prometheus.CounterOpts{","+\t\t\tNamespace: metricsNamespace,","+\t\t\tSubsystem: metricsSubsystem,","+\t\t\tName:      \"disconnects_total\",","+\t\t\tHelp:      \"Total number of NATS disconnections per role.\",","+\t\t}, []string{roleLabel}),","+\t\tconnectionErrors: prometheus.NewCounterVec(prometheus.CounterOpts{","+\t\t\tNamespace: metricsNamespace,","+\t\t\tSubsystem: metricsSubsystem,","+\t\t\tName:      \"connection_errors_total\",","+\t\t\tHelp:      \"Total number of NATS asynchronous connection errors per role.\",","+\t\t}, []string{roleLabel}),","+\t\tmessagesPub: prometheus.NewCounterVec(prometheus.CounterOpts{","+\t\t\tNamespace: metricsNamespace,","+\t\t\tSubsystem: metricsSubsystem,","+\t\t\tName:      \"messages_published_total\",","+\t\t\tHelp:      \"Total number of messages published to NATS per role.\",","+\t\t}, []string{roleLabel}),","+\t\tpublishErrors: prometheus.NewCounterVec(prometheus.CounterOpts{","+\t\t\tNamespace: metricsNamespace,","+\t\t\tSubsystem: metricsSubsystem,","+\t\t\tName:      \"publish_errors_total\",","+\t\t\tHelp:      \"Total number of NATS publish errors per role.\",","+\t\t}, []string{roleLabel}),","+\t}","+","+\treg.MustRegister(","+\t\tm.connectionStatus,","+\t\tm.reconnects,","+\t\tm.disconnects,","+\t\tm.connectionErrors,","+\t\tm.messagesPub,","+\t\tm.publishErrors,","+\t)","+","+\treturn m","+}","+","+// serverMetrics covers the embedded NATS server. It is registered only in","+// environments that actually run the embedded server, so external/Cloud","+// deployments never export a misleading `embedded_server_up 0`.","+type serverMetrics struct {"," \tembeddedServerUp