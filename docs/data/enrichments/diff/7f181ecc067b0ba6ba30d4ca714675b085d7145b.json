erService {","+\treturn newPublisher(log.New(\"infra.nats.publisher\"), m, config, cfg.NATS.Auth.PublisherCredentials)","+}","+","+func (p *PublisherService) IsDisabled() bool {","+\treturn !p.Enabled()","+}","+","+// Run bridges the dskit service into the monolith background-service contract.","+func (p *PublisherService) Run(ctx context.Context) error {","+\tif err := p.StartAsync(ctx); err != nil {","+\t\treturn err","+\t}","+\treturn p.AwaitTerminated(ctx)","+}","+","+func (p *PublisherService) running(ctx context.Context) error {","+\t<-ctx.Done()","+\treturn nil","+}","+","+func (p *PublisherService) stopping(_ error) error {","+\tp.close()","+\treturn nil","+}","+","+func (p *PublisherService) Health(_ context.Context) error {","+\treturn p.healthy()","+}","+","+func (p *PublisherService) Publish(ctx context.Context, subject string, data []byte) error {","+\tnc, err := p.get(ctx)","+\tif err != nil {","+\t\treturn err","+\t}","+\trole := string(p.role)","+\tif err := nc.Publish(subject, data); err != nil {","+\t\tp.metrics.publishErrors.WithLabelValues(role).Inc()","+\t\treturn fmt.Errorf(\"publish to %q: %w\", subject, err)","+\t}","+\tp.metrics.messagesPub.WithLabelValues(role).Inc()","+\treturn nil","+}"],"additions":78,"deletions":0,"truncated":false},{"path":"pkg/infra/nats/publisher_test.go","lines":["@@ -0,0 +1,48 @@","+package nats","+","+import (","+\t\"context\"","+\t\"testing\"","+","+\t\"github.com/prometheus/client_golang/prometheus\"","+\t\"github.com/stretchr/testify/require\"","+","+\t\"github.com/grafana/grafana/pkg/infra/log\"","+\t\"github.com/grafana/grafana/pkg/setting\"","+)","+","+func TestPublisher(t *testing.T) {","+\tt.Run(\"is disabled when NATS is off\", func(t *testing.T) {","+\t\tcfg := setting.NATSSettings{Enabled: false}","+\t\tp := newPublisher(log.NewNopLogger(), newClientMetrics(prometheus.NewRegistry()), newConfig(cfg, nil), func() string { return \"\" })","+","+\t\trequire.False(t, p.Enabled())","+\t\trequire.True(t, p.IsD