"lines":["@@ -8,6 +8,7 @@ import ("," \t\"net/http\""," \t\"testing\""," ","+\tauth_model \"gitea.dev/models/auth\""," \t\"gitea.dev/tests\""," "," \t\"github.com/stretchr/testify/assert\"","@@ -33,3 +34,41 @@ func TestFeedRepo(t *testing.T) {"," \t\tassert.NotEmpty(t, rss.Channel.Items[0].PubDate)"," \t})"," }","+","+// TestFeedRepoContentTokenScopes ensures repository feed endpoints enforce the","+// repository token scope, so a PAT without repository scope cannot read private","+// repository commit/activity data through RSS/Atom feeds.","+func TestFeedRepoContentTokenScopes(t *testing.T) {","+\tdefer tests.PrepareTestEnv(t)()","+","+\t// user2/repo2 is a private repository owned by user2","+\townerReadToken := getUserToken(t, \"user2\", auth_model.AccessTokenScopeReadRepository)","+\tmiscToken := getUserToken(t, \"user2\", auth_model.AccessTokenScopeReadMisc)","+","+\turls := []string{","+\t\t\"/user2/repo2.rss\",","+\t\t\"/user2/repo2.atom\",","+\t\t\"/user2/repo2/rss/branch/master\",","+\t\t\"/user2/repo2/atom/branch/master\",","+\t\t\"/user2/repo2/rss/branch/master/README.md\",","+\t\t\"/user2/repo2/tags.rss\",","+\t\t\"/user2/repo2/tags.atom\",","+\t\t\"/user2/repo2/releases.rss\",","+\t\t\"/user2/repo2/releases.atom\",","+\t}","+","+\tfor _, url := range urls {","+\t\tt.Run(url, func(t *testing.T) {","+\t\t\t// feed routes only accept basic auth, so authenticate as the advisory PoC does (user:token)","+\t\t\treqDenied := NewRequest(t, \"GET\", url)","+\t\t\treqDenied.SetBasicAuth(\"user2\", miscToken)","+\t\t\t// a token without repository scope must be denied","+\t\t\tMakeRequest(t, reqDenied, http.StatusForbidden)","+","+\t\t\treqAllowed := NewRequest(t, \"GET\", url)","+\t\t\treqAllowed.SetBasicAuth(\"user2\", ownerReadToken)","+\t\t\t// a token with repository read scope is allowed","+\t\t\tMakeRequest(t, reqAllowed, http.StatusOK)","+\t\t})","+\t}","+}",""],"additions":39,"deletions":0,"truncated":false}],"additions":132,"deletions":13,"truncated":fals