+\t\tconst fs = await import('fs/promises');","+\t\tconst dir = await initRepoWithFiles({ 'a.txt': 'original' });","+\t\tawait fs.writeFile(join(dir, 'a.txt'), 'changed');","+\t\tcp.execFileSync('git', ['add', 'a.txt'], { cwd: dir, env, stdio: 'pipe' });","+","+\t\tawait svc!.restore(URI.file(dir), ['a.txt'], { staged: true });","+","+\t\tconst stagedDiff = cp.execFileSync('git', ['diff', '--cached', '--name-only'], { cwd: dir, env, encoding: 'utf8' }).trim();","+\t\tconst workingTree = await fs.readFile(join(dir, 'a.txt'), 'utf8');","+\t\tassert.deepStrictEqual({ stagedDiff, workingTree }, { stagedDiff: '', workingTree: 'changed' });","+\t});","+","+\t(hasGit ? test : test.skip)('with `ref` restores content from a specific commit', async () => {","+\t\tconst fs = await import('fs/promises');","+\t\tconst dir = await initRepoWithFiles({ 'a.txt': 'v1' });","+\t\tconst v1Sha = cp.execFileSync('git', ['rev-parse', 'HEAD'], { cwd: dir, env, encoding: 'utf8' }).trim();","+\t\tawait fs.writeFile(join(dir, 'a.txt'), 'v2');","+\t\tcp.execFileSync('git', ['commit', '-q', '-am', 'v2'], { cwd: dir, env, stdio: 'pipe' });","+","+\t\tawait svc!.restore(URI.file(dir), ['a.txt'], { ref: v1Sha });","+","+\t\tassert.strictEqual(await fs.readFile(join(dir, 'a.txt'), 'utf8'), 'v1');","+\t});","+","+\t(hasGit ? test : test.skip)('with no paths restores every modified file in the working tree', async () => {","+\t\tconst fs = await import('fs/promises');","+\t\tconst dir = await initRepoWithFiles({ 'a.txt': 'one', 'b.txt': 'two' });","+\t\tawait fs.writeFile(join(dir, 'a.txt'), 'mutated-a');","+\t\tawait fs.writeFile(join(dir, 'b.txt'), 'mutated-b');","+","+\t\tawait svc!.restore(URI.file(dir), []);","+","+\t\tconst [a, b] = await Promise.all([","+\t\t\tfs.readFile(join(dir, 'a.txt'), 'utf8'),","+\t\t\tfs.readFile(join(dir, 'b.txt'), 'utf8'),","+\t\t]);","+\t\tassert.deepStrictEqual({ a, b }, { a: 'one', b: 'two' });","+\t});","+","+\t(hasGit ? test : test.skip)('rejects when run against a non-git directory', async () => {","+\t\tconst dir = mkdtempSync(join(tmpdir(), 'agent-host-nongit-restore-'));"],"additions":86,"deletions":0,"truncated":false}],"additions":550,"deletions":2,"truncated":true,"file_count":9},"error":null,"fetched_at":"2026-06-17T12:13:48.620243+00:00"}