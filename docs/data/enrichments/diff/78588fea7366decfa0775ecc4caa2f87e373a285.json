ChangesetService.js';","+import { ChangesetKind, parseChangesetUri } from '../common/changesetUri.js';","+import { type IChangesetOperationHandler } from '../common/changesetOperation.js';","+import { ChangesetOperationTargetKind, type InvokeChangesetOperationParams, type InvokeChangesetOperationResult } from '../common/state/protocol/channels-changeset/commands.js';","+import { AHP_SESSION_NOT_FOUND, JsonRpcErrorCodes, ProtocolError } from '../common/state/sessionProtocol.js';","+import { type SessionState } from '../common/state/sessionState.js';","+import { ILogService } from '../../log/common/log.js';","+import { IAgentHostGitService } from './agentHostGitService.js';","+","+export class AgentHostDiscardChangesOperationHandler implements IChangesetOperationHandler {","+","+\tpublic static readonly OPERATION_DISCARD_CHANGES = 'discard-changes';","+","+\tconstructor(","+\t\tprivate readonly _getSessionState: (sessionKey: string) => SessionState | undefined,","+\t\t@IAgentHostChangesetService private readonly _changesets: IAgentHostChangesetService,","+\t\t@IAgentHostGitService private readonly _agentHostGitService: IAgentHostGitService,","+\t\t@ILogService private readonly _logService: ILogService,","+\t) { }","+","+\tasync invoke(params: InvokeChangesetOperationParams, token: CancellationToken): Promise<InvokeChangesetOperationResult> {","+\t\tconst abortController = new AbortController();","+\t\tif (token.isCancellationRequested) {","+\t\t\tabortController.abort();","+\t\t}","+\t\tconst cancellationListener = token.onCancellationRequested(() => abortController.abort());","+\t\ttry {","+\t\t\treturn await this._invoke(params, token, abortController.signal);","+\t\t} finally {","+\t\t\tcancellationListener.dispose();","+\t\t}","+\t}","+","+\tprivate async _invoke(params: InvokeChangesetOperationParams, token: CancellationToken, _signal: AbortSignal): Promise<InvokeChangesetOperationResult> {","+\t\tconst parsed = parseChangesetUri(params.channel);","+\t\tif (!parsed || parsed.kind !== ChangesetKind.Uncommitted) {","+\t\t\tthrow new ProtocolError(JsonRpcErrorCodes.InvalidParams, `Not an uncommitted changeset URI: ${params.channel}`);","+\t\t}","+\t\tthis._throwIfCancelled(token);","+","+\t\tconst sessionUri = parsed.sessionUri;","+\t\tconst sessionState = this._getSessionState(sessionUri);","+\t\tif (!sessionState) {","+\t\t\tthrow new ProtocolError(AHP_SESSION_NOT_FOUND, `Session not found: ${sessionUri}`);","+\t\t}","+","+\t\tif (params.target?.kind !== ChangesetOperationTargetKind.Resource) {","+\t\t\tthrow new ProtocolError(","+\t\t\t\tJsonRpcErrorCodes.InvalidParams,","+\t\t\t\t`Operation '${AgentHostDiscardChangesOperationHandler.OPERATION_DISCARD_CHANGES}' requires a resource target.`);","+\t\t}","+","+\t\tconst workingDirectoryStr = sessionState.summary.workingDirectory;","+\t\tif (!workingDirectoryStr) {","+\t\t\tthrow new ProtocolError(JsonRpcErrorCodes.InternalError, `Session has no working directory: ${sessionUri}`);","+\t\t}","+","+\t\tconst workingDirectory = URI.parse(workingDirectoryStr);","+\t\tconst resource = URI.parse(params.target.resource);","+","+\t\tthis._logService.info(`[AgentHostDiscardChangesOperationHandler] Restoring '${resource.fsPath}' for session ${sessionUri}`);","+","+\t\ttry {","+\t\t\tawait this._agentHostGitService.restore(workingDirectory, [resource.fsPath]);","+\t\t} catch (err) {","+\t\t\tthis._throwIfCancelled(token);","+\t\t\tthrow new ProtocolError(","+\t\t\t\tJsonRpcErrorCodes.InternalError,","+\t\t\t\t`Failed to discard changes: ${err instanceof Error ? err.message : String(err)}`);","+\t\t}","+","+\t\t// Re-compute the uncommitted changeset for the session","+\t\tvoid this._changesets.computeUncommittedChangeset(sessionUri);","+","+\t\treturn { message: { markdown: localize('agentHost.changeset.discardChanges.discarded', \"Discarded changes to `{0}`.\", basename(resource)) } };","+\t}","+","+\tprivate _throwIfCancelled(token: CancellationToken): void {","+\t\tif (token.isCancellationRequested) {","+\t\t\tthrow new ProtocolError(JsonRpcErrorCodes.InternalError, localize('agentHost.changeset.discardChanges.cancelled', \"Discard changes operation was cancelled.\"));","+\t\t}","+\t}","+}"],"additions":92,"deletions":0,"truncated":false},{"path":"src/vs/platform/agentHost/node/agentHostDiscardChangesOperationProvider.ts","lines":["@@ -0,0 +1,47 @@","+/*---------------------------------------------------------------------------------------------","+ *  Copyright (c) Microsoft Corporation. All rights reserved.","+ *  Licensed under the MIT License. See License.txt in the project root for license information.","+ *--------------------------------------------------------------------------------------------*/","+","+import { Disposable, DisposableStore, IDisposable } from '../../../base/common/lifecycle.js';","+import { localize } from '../../../nls.js';","+import { IInstantiationService } from '../../instantiation/common/instantiation.js';","+import { ChangesetKind } from '../common/changesetUri.js';","+import type { IChangesetOperationContribution, IChangesetOperationContext, IChangesetOperationRegistry } from '../common/changesetOperation.js';","+import { ChangesetOperationScope, ChangesetOperationStatus, type ChangesetOperation } from '../common/state/sessionState.js';","+import { AgentHostDiscardChangesOperationHandler } from './agentHostDiscardChangesOperationHandler.js';","+import { AgentHostStateManager } from './agentHostStateManager.js';","+","+export class AgentHostDiscardChangesOperationContribution extends Disposable implements IChangesetOperationContribution {","+","+\tconstructor(","+\t\tprivate readonly _stateManager: AgentHostStateManager,","+\t\t@IInstantiationService private readonly _instantiationService: IInstantiationService,","+\t) {","+\t\tsuper();","+\t}","+","+\tregisterHandlers(registry: IChangesetOperationRegistry): IDisposable {","+\t\tconst store = new DisposableStore();","+\t\tconst getSessionState = (sessionKey: string) => this._stateManager.getSessionState(sessionKey);","+\t\tconst handler = this._instantiationService.createInstance(AgentHostDiscardChangesOperationHandler, getSessionState);","+\t\tstore.add(registry.registerChangesetOperationHandler(AgentHostDiscardChangesOperationHandler.OPERATION_DISCARD_CHANGES, handler));","+","+\t\treturn store;","+\t}","+","+\tgetOperations({ changesetKind, gitState }: IChangesetOperationContext): ChangesetOperation[] | undefined {","+\t\tif (changesetKind !== ChangesetKind.Uncommitted || (gitState.uncommittedChanges ?? 0) <= 0) {","+\t\t\treturn undefined;","+\t\t}","+","+\t\treturn [{","+\t\t\tid: AgentHostDiscardChangesOperationHandler.OPERATION_DISCARD_CHANGES,","+\t\t\tlabel: localize('agentHost.changeset.discardChanges', \"Discard Changes\"),","+\t\t\tconfirmation: localize('agentHost.changeset.discardChanges.confirmation', \"Are you sure you want to discard the changes in \\'{0}\\'? This action cannot be undone.\"),","+\t\t\ticon: 'discard',","+\t\t\tscopes: [ChangesetOperationScope.Resource],","+\t\t\tstatus: ChangesetOperationStatus.Idle,","+\t\t} satisfies ChangesetOperation];","+\t}","+}"],"additions":47,"deletions":0,"truncated":false},{"path":"src/vs/platform/agentHost/node/agentHostGitService.ts","lines":["@@ -54,6 +54,15 @@ export interface IAgentHostGitService {"," \t */"," \tcommitAll(workingDirectory: URI, message: string): Promise<void>;"," ","+\t/**","+\t * Restores files in the working tree via `git restore`. When","+\t * {@link options.staged} is true, restores the index instead of the","+\t * working tree. When {@link options.ref} is provided, the contents are","+\t * taken from that ref (`--source`). An empty {@link paths} array","+\t * restores everything (`.`).","+\t */","+\trestore(workingDirectory: URI, paths: readonly string[], options?: { readonly staged?: boolean; readonly ref?: string }): Promise<void>;","+"," \t/**"," \t * Returns true when the named branch has an upstream tracking ref"," \t * (i.e. `<branch>@{upstream}` resolves). Used before {@link pushBranch}","@@ -301,6 +310,24 @@ export class AgentHostGitService implements IAgentHostGitService {"," \t\tawait this._runGit(workingDirectory, ['commit', '--no-verify', '--no-gpg-sign', '-m', message], { timeout: 60_000, throwOnError: true });"," \t}"," ","+\tasync restore(workingDirectory: URI, paths: readonly string[], options?: { readonly staged?: boolean; readonly ref?: string }): Promise<void> {","+\t\tconst args = ['restore'];","+","+\t\tif (options?.staged) {","+\t\t\targs.push('--staged');","+\t\t}","+","+\t\tif (options?.ref) {","+\t\t\targs.push('--source', options.ref);","+\t\t}","+","+\t\tif (paths.length === 0) {","+\t\t\tpaths = ['.'];","+\t\t}","+","+\t\tawait this._runGit(workingDirectory, [...args, '--', ...paths], { throwOnError: true });","+\t}","+"," \tasync hasUpstream(workingDirectory: URI, branchName: string): Promise<boolean> {"," \t\tconst output = await this._runGit(workingDirectory, ['rev-parse', '--abbrev-ref', `${branchName}@{upstream}`]);"," \t\treturn output !== undefined && output.trim().length > 0;"],"additions":27,"deletions":0,"truncated":false},{"path":"src/vs/platform/agentHost/test/common/sessionTestHelpers.ts","lines":["@@ -186,6 +186,7 @@ export function createNoopGitService(): import('../../node/agentHostGitService.j"," \t\tbranchExists: async () => false,"," \t\thasUncommittedChanges: async () => false,"," \t\tcommitAll: async () => { },","+\t\trestore: async () => { },"," \t\thasUpstream: async () => false,"," \t\tpushBranch: async () => { },"," \t\tgetSessionGitState: async () => undefined,"],"additions":1,"deletions":0,"truncated":false},{"path":"src/vs/platform/agentHost/test/node/agentHostCommitOperationHandler.test.ts","lines":["@@ -50,6 +50,7 @@ class TestGitService implements IAgentHostGitService {"," \t\tthis.calls.push(`commitAll:${message}`);"," \t\tthis.uncommitted = false;"," \t}","+\tasync restore(): Promise<void> { }"," \tasync hasUpstream(): Promise<boolean> { r