Manager(new NullLogService()));","+\tconst session = URI.parse('agent:/session');","+\tif (opts?.registerSession !== false) {","+\t\tstateManager.createSession({","+\t\t\tresource: session.toString(),","+\t\t\tprovider: 'copilot',","+\t\t\ttitle: 'Session',","+\t\t\tstatus: SessionStatus.Idle,","+\t\t\tcreatedAt: 1,","+\t\t\tmodifiedAt: 1,","+\t\t\tworkingDirectory: opts?.withWorkingDirectory === false ? undefined : URI.file('/repo').toString(),","+\t\t});","+\t}","+\tconst handler = new AgentHostDiscardChangesOperationHandler(","+\t\tsessionKey => stateManager.getSessionState(sessionKey),","+\t\tchangesets,","+\t\tgitService,","+\t\tnew NullLogService(),","+\t);","+\treturn { handler, gitService, changesets, session };","+}","+","+function makeResourceTarget(resource: URI): InvokeChangesetOperationParams['target'] {","+\t// `ChangesetOperationTarget.resource` is typed as the protocol `URI` (a","+\t// branded string), not the workbench `URI` class.","+\treturn { kind: ChangesetOperationTargetKind.Resource, resource: resource.toString() as unknown as InvokeChangesetOperationParams['channel'] };","+}","+","+suite('AgentHostDiscardChangesOperationHandler', () => {","+\tconst disposables = ensureNoDisposablesAreLeakedInTestSuite();","+","+\ttest('restores the targeted file and recomputes the uncommitted changeset on success', async () => {","+\t\tconst { handler, gitService, changesets, session } = setup(disposables);","+\t\tconst target = URI.file('/repo/src/file.ts');","+","+\t\tconst result = await handler.invoke({","+\t\t\tchannel: buildUncommittedChangesetUri(session.toString()),","+\t\t\toperationId: AgentHostDiscardChangesOperationHandler.OPERATION_DISCARD_CHANGES,","+\t\t\ttarget: makeResourceTarget(target),","+\t\t}, CancellationToken.None);","+","+\t\tassert.deepStrictEqual({","+\t\t\trestoreCalls: gitService.restoreCalls,","+\t\t\tchangesetCalls: changesets.calls,","+\t\t\tmessage: result.message,","+\t\t}, {","+\t\t\trestoreCalls: [{ workingDirectory: URI.fi