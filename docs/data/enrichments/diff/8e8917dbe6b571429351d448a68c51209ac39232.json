derer), so PLAN.query.sql is HTML","         var sql = (PLAN.query && PLAN.query.sql) ? PLAN.query.sql : \"\";","         var chip = document.getElementById(\"sql-chip\");","         if (!sql.trim()) { chip.style.display = \"none\"; return; }","-        // duckdb_format_sql already pretty-prints (multi-line); only apply our light formatter to a raw one-liner","-        document.getElementById(\"sql-body\").innerHTML = sql.indexOf(\"\\n\") >= 0 ? highlightSQL(sql) : highlightSQL(formatSQL(sql));","+        document.getElementById(\"sql-body\").innerHTML = sql;","         var panel = document.getElementById(\"sql-panel\");","         chip.addEventListener(\"click\", function () { panel.classList.toggle(\"show\"); });","         document.getElementById(\"sql-close\").addEventListener(\"click\", function () { panel.classList.remove(\"show\"); });"],"additions":3,"deletions":19,"truncated":false},{"path":"src/common/tree_renderer/html_tree_renderer.cpp","lines":["@@ -3,6 +3,7 @@"," #include \"duckdb/common/string_util.hpp\""," #include \"duckdb/common/json_document.hpp\""," #include \"duckdb/common/tree_renderer/html_template.hpp\"","+#include \"duckdb/parser/parser.hpp\""," "," #include <cstdlib>"," ","@@ -200,13 +201,101 @@ void HTMLTreeRenderer::ToStreamInternal(RenderTree &root, BaseTreeRenderer &ss)"," \tss << html;"," }"," ","+// HTML-escape text for safe embedding in the generated page (matches the viewer's escHtml: & < >).","+static void AppendEscapedHTML(string &out, const char *data, idx_t len) {","+\tfor (idx_t i = 0; i < len; i++) {","+\t\tchar c = data[i];","+\t\tswitch (c) {","+\t\tcase '&':","+\t\t\tout += \"&amp;\";","+\t\t\tbreak;","+\t\tcase '<':","+\t\t\tout += \"&lt;\";","+\t\t\tbreak;","+\t\tcase '>':","+\t\t\tout += \"&gt;\";","+\t\t\tbreak;","+\t\tdefault:","+\t\t\tout += c;","+\t\t}","+\t}","+}","+","+// Render the query SQL as highlighted HTML using the DuckDB tokenizer (keyword/constant/comment spans). Highlighting is","+// done here, at generation time, so the viewer does not need its own SQL highlighter.","+static string HighlightSQL(const string &sql) {","+\tif (sql.empty()) {","+\t\treturn string();","+\t}","+\tvector<SimplifiedToken> tokens;","+\ttry {","+\t\ttokens = Parser::Tokenize(sql);","+\t} catch (...) {","+\t\t// tokenization can throw on invalid SQL - fall back to escaped plain text","+\t\tstring fallback;","+\t\tAppendEscapedHTML(fallback, sql.c_str(), sql.size());","+\t\treturn fallback;","+\t}","+\tstring out;","+\tidx_t pos = 0;","+\tfor (idx_t i = 0; i < tokens.size(); i++) {","+\t\tidx_t start = tokens[i].start;","+\t\tif (start > sql.size()) {","+\t\t\tbreak;","+\t\t}","+\t\tidx_t end = i + 1 == tokens.size() ? sql.size() : tokens[i + 1].start;","+\t\tif (end > sql.size()) {","+\t\t\tend = sql.size();","+\t\t}","+\t\t// emit any text before this token (e.g. leading whitespace) unhighlighted","+\t\tif (start > pos) {","+\t\t\tAppendEscapedHTML(out, sql.c_str() + pos, start - pos);","+\t\t}","+\t\tif (end <= start) {","+\t\t\tpos = start;","+\t\t\tcontinue;","+\t\t}","+\t\tconst char *cls = nullptr;","+\t\tswitch (tokens[i].type) {","+\t\tcase SimplifiedTokenType::SIMPLIFIED_TOKEN_KEYWORD:","+\t\t\tcls = \"sql-kw\";","+\t\t\tbreak;","+\t\tcase SimplifiedTokenType::SIMPLIFIED_TOKEN_NUMERIC_CONSTANT:","+\t\t\tcls = \"sql-num\";","+\t\t\tbreak;","+\t\tcase SimplifiedTokenType::SIMPLIFIED_TOKEN_STRING_CONSTANT:","+\t\t\tcls = \"sql-str\";","+\t\t\tbreak;","+\t\tcase SimplifiedTokenType::SIMPLIFIED_TOKEN_COMMENT:","+\t\t\tcls = \"sql-comment\";","+\t\t\tbreak;","+\t\tdefault:","+\t\t\tbreak;","+\t\t}","+\t\tif (cls) {","+\t\t\tout += \"<span class=\\\"\";","+\t\t\tout += cls;","+\t\t\tout += \"\\\">\";","+\t\t\tAppendEscapedHTML(out, sql.c_str() + start, end - start);","+\t\t\tout += \"</span>\";","+\t\t} else {","+\t\t\tAppendEscapedHTML(out, sql.c_str() + start, end - start);","+\t\t}","+\t\tpos = end;","+\t}","+\tif (pos < sql.size()) {","+\t\tAppendEscapedHTML(out, sql.c_str() + pos, sql.size() - pos);","+\t}","+\treturn out;","+}","+"," void HTMLTreeRenderer::RenderProfiler(const QueryProfiler &profiler, BaseTreeRenderer &ss) {"," \tauto &qm = profiler.GetQueryMetrics();"," \tquery_real_time = qm.GetStringMetricInSeconds(\"query.total_time\");"," \tquery_cpu_time = qm.GetStringMetricInSeconds(\"query.cpu_time\");"," \tquery_bytes_read = qm.GetBytesRead();"," \tquery_bytes_written = qm.GetBytesWritten();","-\tquery_sql = profiler.GetFormattedSQL();","+\tquery_sql = HighlightSQL(FormatSQL(profiler.GetQuerySQL()));"," \tquery_timings.clear();"," \tfor (auto &entry : qm.GetMetricTimings()) {"," \t\tquery_timings.emplace_back(entry.first, static_cast<double>(entry.second) / 1e9);"],"additions":90,"deletions":1,"truncated":false},{"path":"src/include/duckdb/common/tree_renderer/html_template.hpp","lines":["@@ -1054,2581 +1054,2520 @@ static const unsigned char HTML_TEMPLATE[] = {","     58, 32, 35, 48, 48, 55, 48, 100, 50, 59, 32, 125, 10, 46, 115, 113, 108, 45, 115, 116,","     114, 32, 123, 32, 99, 111, 108, 111, 114, 58, 32, 35, 48, 48, 97, 51, 54, 99, 59, 32,","     125, 10, 46, 115, 113, 108, 45, 110, 117, 109, 32, 123, 32, 99, 111, 108, 111, 114, 58, 32,","-    35, 100, 50, 54, 57, 49, 101, 59, 32, 125, 10, 10, 47, 42, 32, 110, 111, 100, 101, 115,","-    32, 104, 105, 103, 104, 108, 105, 103, 104, 116, 101, 100, 32, 98, 121, 32, 97, 32, 115, 101,","-    108, 101, 99, 116, 101, 100, 32, 112, 105, 101, 32, 115, 108, 105, 99, 101, 32, 42, 47, 10,","-    46, 110, 111, 100, 101, 46, 107, 105, 110, 100, 45, 100, 105, 109, 32, 123, 32, 111, 112, 97,","-    99, 105, 116, 121, 58, 32, 46, 50, 50, 59, 32, 125, 10, 46, 110, 111, 100, 101, 46, 107,","-    105, 110, 100, 45, 115, 101, 108, 32, 123, 32, 98, 111, 114, 100, 101, 114, 45, 99, 111, 108,","-    111, 114, 58, 32, 118, 97, 114, 40, 45, 45, 107, 45, 99, 111, 108, 111, 114, 44, 32, 118,","-    97, 114, 40, 45, 45, 97, 99, 99, 101, 110, 116, 41, 41, 59, 32, 98, 111, 120, 45, 115,","-    104, 97, 100, 111,