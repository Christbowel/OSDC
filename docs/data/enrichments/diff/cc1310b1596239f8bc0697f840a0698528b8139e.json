 *testing.T) {","+\tctx := identity.WithServiceIdentityContext(t.Context(), 1)","+\tallowAll := &fakeAccessClient{fn: func(authtypes.BatchCheckItem) bool { return true }}","+","+\t// run drives the handler against the given adapter and decodes the response body","+\t// (the created Annotation) when the call succeeds.","+\trun := func(t *testing.T, adapter *k8sRESTAdapter, body string) (annotationV0.Annotation, error) {","+\t\tt.Helper()","+\t\thandler := newGraphiteHandler(adapter, tracing.InitializeTracerForTest(), ProvideMetrics(nil), log.NewNopLogger())","+\t\twriter := &mockResponseWriter{header: make(http.Header), body: &bytes.Buffer{}}","+\t\terr := handler(ctx, writer, newGraphiteRequest(body))","+\t\tvar resp annotationV0.Annotation","+\t\tif err == nil {","+\t\t\trequire.NoError(t, json.Unmarshal(writer.body.Bytes(), &resp))","+\t\t}","+\t\treturn resp, err","+\t}","+","+\tt.Run(\"creates an annotation from the graphite format\", func(t *testing.T) {","+\t\tresp, err := run(t, newTestAdapter(NewMemoryStore(), allowAll), `{\"what\":\"deploy\",\"when\":1700000000,\"data\":\"v1.2.3\",\"tags\":[\"release\",\"prod\"]}`)","+\t\trequire.NoError(t, err)","+\t\tassert.Equal(t, \"deploy\\nv1.2.3\", resp.Spec.Text)","+\t\tassert.Equal(t, int64(1700000000000), resp.Spec.Time)","+\t\tassert.Equal(t, []string{\"release\", \"prod\"}, resp.Spec.Tags)","+\t\tassert.Equal(t, metav1.NamespaceDefault, resp.GetNamespace())","+\t\tassert.NotEmpty(t, resp.GetName())","+\t\tassert.Equal(t, \"Annotation\", resp.Kind)","+\t\tassert.Equal(t, \"annotation.grafana.app/v0alpha1\", resp.APIVersion)","+\t})","+","+\tt.Run(\"text is just what when data is empty\", func(t *testing.T) {","+\t\tresp, err := run(t, newTestAdapter(NewMemoryStore(), allowAll), `{\"what\":\"deploy\",\"tags\":[]}`)","+\t\trequire.NoError(t, err)","+\t\tassert.Equal(t, \"deploy\", resp.Spec.Text)","+\t})","+","+\tt.Run(\"parses tags as space-separated string\", func(t *testing.T) {","+\t\tresp, err := run(t, newTestAdapter(NewMemoryStore(), allowAll), `{\"what\":\"deploy\",\"tags\":\"release prod\"}`)","+\t\trequire.NoError(t, err)","+\t\tassert.Equal(t, []string{\"release\", \"prod\"}, resp.Spec.Tags)","+\t})","+","+\tt.Run(\"empty tags string yields no tags\", func(t *testing.T) {","+\t\tresp, err := run(t, newTestAdapter(NewMemoryStore(), allowAll), `{\"what\":\"deploy\",\"tags\":\"\"}`)","+\t\trequire.NoError(t, err)","+\t\tassert.Empty(t, resp.Spec.Tags)","+\t})","+","+\tt.Run(\"when defaults to now when omitted\", func(t *testing.T) {","+\t\tbefore := time.Now().UnixMilli()","+\t\tresp, err := run(t, newTestAdapter(NewMemoryStore(), allowAll), `{\"what\":\"deploy\",\"tags\":[]}`)","+\t\tafter := time.Now().UnixMilli()","+\t\trequire.NoError(t, err)","+\t\tassert.GreaterOrEqual(t, resp.Spec.Time, before)","+\t\tassert.LessOrEqual(t, resp.Spec.Time, after)","+\t})","+","+\tt.Run(\"rejects empty what\", func(t *testing.T) {","+\t\t_, err := run(t, newTestAdapter(NewMemoryStore(), allowAll), `{\"what\":\"\"}`)","+\t\trequire.Error(t, err)","+\t\tassert.True(t, apierrors.IsBadRequest(err))","+\t})","+","+\tt.Run(\"rejects malformed json\", func(t *testing.T) {","+\t\t_, err := run(t, newTestAdapter(NewMemoryStore(), allowAll), `not json`)","+\t\trequire.Error(t, err)","+\t\tassert.True(t, apierrors.IsBadRequest(err))","+\t})","+","+\tt.Run(\"rejects non-string tag in array\", func(t *testing.T) {","+\t\t_, err := run(t, newTestAdapter(NewMemoryStore(), allowAll), `{\"what\":\"deploy\",\"tags\":[\"ok\",123]}`)","+\t\trequire.Error(t, err)","+\t\tassert.True(t, apierrors.IsBadRequest(err))","+\t})","+","+\tt.Run(\"rejects missing tags\", func(t *testing.T) {","+\t\t_, err := run(t, newTestAdapter(NewMemoryStore(), allowAll), `{\"what\":\"deploy\"}`)","+\t\trequire.Error(t, err)","+\t\tassert.True(t, apierrors.IsBadRequest(err))","+\t})","+","+\tt.Run(\"propagates the adapter's error when unauthorized\", func(t *testing.T) {","+\t\tdenyAll := &fakeAccessClient{fn: func(authtypes.BatchCheckItem) bool { return false }}","+\t\t_, err := run(t, newTestAdapter(NewMemoryStore(), denyAll), `{\"what\":\"deploy\",\"tags\":[]}`)","+\t\trequire.Error(t, err)","+\t\tassert.True(t, apierrors.IsForbidden(err))","+\t})","+}","+","+func newGraphiteRequest(body string) *app.CustomRouteRequest {","+\treturn &app.CustomRouteRequest{","+\t\tResourceIdentifier: resource.FullIdentifier{Namespace: metav1.NamespaceDefault},","+\t\tMethod:             http.MethodPost,","+\t\tBody:               io.NopCloser(strings.NewReader(body)),","+\t}","+}"],"additions":121,"deletions":0,"truncated":false},{"path":"pkg/registry/apps/annotation/register.go","lines":["@@ -141,14 +141,18 @@ func NewAppInstaller("," \t// Create the search handler"," \tsearchHandler := newSearchHandler(instrumentedStore, accessClient, folderResolver, installer.tracer, installer.metrics, logger)"," ","+\t// Create the graphite handler"],"additions":1,"deletions":0,"truncated":false}],"additions":709,"deletions":3,"truncated":true,"file_count":11},"error":null,"fetched_at":"2026-07-03T10:25:37.435611+00:00"}