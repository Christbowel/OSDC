519 calls sodium directly: JWT::sign runs the key through","+\t * `validateEdDSAKey` which base64url-decodes it first, which mangles raw","+\t * sodium bytes.","+\t *","+\t * @throws SignatureException","+\t */","+\tpublic static function sign(string $signatureBase, string $privateKey, string $algorithm): string {","+\t\t$normalized = self::normalize($algorithm);","+","+\t\tif ($normalized === 'ed25519') {","+\t\t\tif (strlen($privateKey) !== SODIUM_CRYPTO_SIGN_SECRETKEYBYTES) {","+\t\t\t\tthrow new SignatureException('Ed25519 secret key must be ' . SODIUM_CRYPTO_SIGN_SECRETKEYBYTES . ' bytes');","+\t\t\t}","+\t\t\treturn sodium_crypto_sign_detached($signatureBase, $privateKey);","+\t\t}","+","+\t\ttry {","+\t\t\treturn JWT::sign($signatureBase, $privateKey, self::nativeToJose($normalized));","+\t\t} catch (Throwable $e) {","+\t\t\tthrow new SignatureException('signing failed for ' . $normalized . ': ' . $e->getMessage(), 0, $e);","+\t\t}","+\t}","+","+\t/**","+\t * @param string $signature raw signature bytes (already base64-decoded)","+\t * @param string|null $algorithm algorithm hint from Signature-Input `alg=`","+\t * @throws SignatureException","+\t */","+\tpublic static function verify(string $signatureBase, string $signature, Key $key, ?string $algorithm): bool {","+\t\t$resolved = self::normalize($key->getAlgorithm());","+","+\t\tif ($algorithm !== null && $algorithm !== '') {","+\t\t\t$hintNative = self::normalize($algorithm);","+\t\t\tif ($hintNative !== $resolved) {","+\t\t\t\tthrow new SignatureException(","+\t\t\t\t\t'algorithm sources disagree: Signature-Input alg says ' . $hintNative . ', JWK alg says ' . $resolved","+\t\t\t\t);","+\t\t\t}","+\t\t}","+","+\t\t$material = $key->getKeyMaterial();","+","+\t\tif ($resolved === 'ed25519') {","+\t\t\tif (strlen($signature) !== SODIUM_CRYPTO_SIGN_BYTES) {","+\t\t\t\treturn false;","+\t\t\t}","+\t\t\t// parseKey hands OKP material as plain base64 of the 32 raw bytes.","+\t\t\t$rawPublic = base64_decode((string)$material, true);","+\t\t\tif ($rawPublic === false || strlen($rawPublic) !== SODIUM_CRYPTO_SIGN_PUBLICKEYBYTES) {","+\t\t\t\treturn false;","+\t\t\t}","+\t\t\treturn sodium_crypto_sign_verify_detached($signature, $signatureBase, $rawPublic);","+\t\t}","+","+\t\t[$opensslAlgo, $encoding] = self::opensslParametersForAlgorithm($resolved);","+","+\t\tif ($encoding === 'ecdsa') {","+\t\t\t$signature = self::ecdsaRawToDer($signature, self::ecdsaCoordinateSize($resolved));","+\t\t\tif ($signature === null) {","+\t\t\t\treturn false;","+\t\t\t}","+\t\t}","+","+\t\treturn openssl_verify($signatureBase, $signature, $material, $opensslAlgo) === 1;","+\t}","+","+\t/**","+\t * Map a JOSE alg (RFC 7518/8037) to the RFC 9421 native identifier.","+\t * Pass-through if already native.","+\t *","+\t * @throws SignatureException","+\t */","+\tpublic static function normalize(string $algorithm): string {","+\t\t$lower = strtolower($algorithm);","+\t\tif (in_array($lower, self::NATIVE, true)) {","+\t\t\treturn $lower;","+\t\t}","+\t\treturn match ($algorithm) {","+\t\t\t'EdDSA' => 'ed25519',","+\t\t\t'ES256' => 'ecdsa-p256-sha256',","+\t\t\t'ES384' => 'ecdsa-p384-sha384',","+\t\t\t'RS256' => 'rsa-v1_5-sha256',","+\t\t\t'RS384' => 'rsa-v1_5-sha384',","+\t\t\t'RS512' => 'rsa-v1_5-sha512',","+\t\t\tdefault => throw new SignatureException('unsupported signature algorithm: ' . $algorithm),","+\t\t};","+\t}","+","+\t/**","+\t * Default JOSE alg for {@see \\Firebase\\JWT\\JWK::parseKey} when the JWK has","+\t * no `alg` (RFC 7517 leaves it optional). Null if kty/crv don't pin one","+\t * down (e.g. RSA, where the hash isn't determined).","+\t *","+\t * @param array<string, mixed> $jwk","+\t */","+\tpublic static function deriveJoseAlgFromJwk(array $jwk): ?string {","+\t\treturn match ($jwk['kty'] ?? '') {","+\t\t\t'OKP' => match ($jwk['crv'] ?? '') {","+\t\t\t\t'Ed25519' => 'EdDSA',","+\t\t\t\tdefault => null,","+\t\t\t},","+\t\t\t'EC' => match ($jwk['crv'] ?? '') {","+\t\t\t\t'P-256' => 'ES256',","+\t\t\t\t'P-384' => 'ES384',","+\t\t\t\tdefault => null,","+\t\t\t},","+\t\t\tdefault => null,","+\t\t};","+\t}","+","+\tprivate static function nativeToJose(string $native): string {","+\t\treturn match ($native) {","+\t\t\t'ed25519' => 'EdDSA',","+\t\t\t'ecdsa-p256-sha256' => 'ES256',","+\t\t\t'ecdsa-p384-sha384' => 'ES384',","+\t\t\t'rsa-v1_5-sha256' => 'RS256',","+\t\t\t'rsa-v1_5-sha384' => 'RS384',","+\t\t\t'rsa-v1_5-sha512' => 'RS512',","+\t\t\tdefault => throw new SignatureException('unsupported signature algorithm: ' . $native),","+\t\t};","+\t}","+","+\t/**","+\t * @return array{0: int, 1: string} [openssl digest, wire encoding]","+\t */","+\tprivate static function opensslParametersForAlgorithm(string $native): array {","+\t\treturn match ($native) {","+\t\t\t'rsa-v1_5-sha256' => [OPENSSL_ALGO_SHA256, 'raw'],","+\t\t\t'rsa-v1_5-sha384' => [OPENSSL_ALGO_SHA384, 'raw'],","+\t\t\t'rsa-v1_5-sha512' => [OPENSSL_ALGO_SHA512, 'raw'],","+\t\t\t'ecdsa-p256-sha256' => [OPENSSL_ALGO_SHA256, 'ecdsa'],","+\t\t\t'ecdsa-p384-sha384' => [OPENSSL_ALGO_SHA384, 'ecdsa'],","+\t\t\tdefault => throw new SignatureException('unsupported signature algorithm: ' . $native),","+\t\t};","+\t}","+","+\tprivate static function ecdsaCoordinateSize(string $native): int {","+\t\treturn match ($native) {","+\t\t\t'ecdsa-p256-sha256' => 32,","+\t\t\t'ecdsa-p384-sha384' => 48,","+\t\t\tdefault => throw new InvalidArgumentException('not an ECDSA algorithm: ' . $native),","+\t\t};","+\t}","+","+\t/**","+\t * Raw R||S (RFC 9421 §3.3.4 wire form) to DER for openssl_verify.","+\t * firebase/php-jwt has the inverse but keeps it private.","+\t */","+\tpublic static function ecdsaRawToDer(string $raw, int $coordinateSize): ?string {","+\t\tif (strlen($raw) !== $coordinateSize * 2) {","+\t\t\treturn null;","+\t\t}","+\t\t$r = ltrim(substr($raw, 0, $coordinateSize), \"\\x00\");","+\t\t$s = ltrim(substr($raw, $coordinateSize), \"\\x00\");","+\t\t// DER INTEGER must be positive; pad if high bit is set.","+\t\tif ($r === '' || (ord($r[0]) & 0x80) !== 0) {","+\t\t\t$r = \"\\x00\" . $r;","+\t\t}","+\t\tif ($s === '' || (ord($s[0]) & 0x80) !== 0) {","+\t\t\t$s = \"\\x00\" . $s;","+\t\t}","+\t\t$rEncoded = \"\\x02\" . self::derLength(strlen($r)) . $r;","+\t\t$sEncoded = \"\\x02\" . self::derLength(strlen($s)) . $s;","+\t\t$body = $rEncoded . $sEncoded;","+\t\treturn \"\\x30\" . self::derLength(strlen($body)) . $body;","+\t}","+","+\tprivate static function derLength(int $length): string {","+\t\tif ($length < 0x80) {","+\t\t\treturn chr($length);","+\t\t}","+\t\t$bytes = '';","+\t\twhile ($length > 0) {","+\t\t\t$bytes = chr($length & 0xff) . $bytes;","+\t\t\t$length >>= 8;","+\t\t}","+\t\treturn chr(0x80 | strlen($bytes)) . $bytes;","+\t}","+}"],"additions":221,"deletions":0,"truncated":false},{"path":"lib/private/Security/Signature/Rfc9421/ContentDigest.php","lines":["@@ -0,0 +1,72 @@","+<?php","+","+declare(strict_types=1);","+","+/**","+ * SPDX-FileCopyrightText: 2026 Nextcloud GmbH and Nextcloud contributors","+ * SPDX-License-Identifier: AGPL-3.0-or-later","+ */","+","+namespace OC\\Security\\Signature\\Rfc9421;","+","+use InvalidArgumentException;","+","+/** RFC 9530 `Content-Digest` helpers; covered by RFC 9421 §7.2.5 in OCM signatures. */","+final class ContentDigest {","+\tpublic const ALGO_SHA256 = 'sha-256';","+\tpublic const ALGO_SHA512 = 'sha-512';","+","+\tpublic static function compute(string $body, string $algorithm = self::ALGO_SHA256): string {","+\t\t$hashAlgorithm = self::hashAlgorithmFor($algorithm);","+\t\treturn $algorithm . '=:' . base64_encode(hash($hashAlgorithm, $body, true)) . ':';","+\t}","+","+\t/**","+\t * True iff at least one recognised algorithm matches and none mismatch."],"additions":25,"deletions":0,"truncated":false}],"additions":921,"deletions":0,"truncated":true,"file_count":4},"error":null,"fetched_at":"2026-05-28T11:21:10.783070+00:00"}