ureAlgorithm $algorithm): self {","+\t\t$this->algorithm = $algorithm;","+\t\treturn $this;","+\t}","+","+\t#[\\Override]","+\tpublic function getAlgorithm(): SignatureAlgorithm {","+\t\treturn $this->algorithm;","+\t}","+","+\t/** RFC 9421 alg name (e.g. `ed25519`). Distinct from cavage's {@see getAlgorithm()}. */","+\tpublic function getSigningAlgorithm(): string {","+\t\treturn $this->signingAlgorithm;","+\t}","+","+\tpublic function getSignatureBaseString(): string {","+\t\treturn $this->signatureBaseString;","+\t}","+","+\t#[\\Override]","+\tpublic function sign(): self {","+\t\t$privateKey = $this->getSignatory()->getPrivateKey();","+\t\tif ($privateKey === '') {","+\t\t\tthrow new SignatoryException('empty private key');","+\t\t}","+","+\t\t$rawSignature = Algorithm::sign(","+\t\t\t$this->signatureBaseString,","+\t\t\t$privateKey,","+\t\t\t$this->signingAlgorithm,","+\t\t);","+\t\t$this->setSignature(base64_encode($rawSignature));","+","+\t\t$paramsLine = SignatureBase::serializeSignatureParams($this->headerList, $this->signatureParams);","+\t\t$this->addHeader('Signature-Input', 'ocm=' . $paramsLine);","+\t\t$this->addHeader('Signature', 'ocm=:' . base64_encode($rawSignature) . ':');","+","+\t\t$this->setSigningElements([","+\t\t\t'label' => 'ocm',","+\t\t\t'components' => implode(' ', $this->headerList),","+\t\t\t'params' => $paramsLine,","+\t\t\t'signature' => $this->getSignature(),","+\t\t]);","+","+\t\treturn $this;","+\t}","+","+\t/**","+\t * @return array<string, string>","+\t */","+\tprivate function headersByLowercaseName(): array {","+\t\t$out = [];","+\t\tforeach ($this->headers as $name => $value) {","+\t\t\t$out[strtolower($name)] = (string)$value;","+\t\t}","+\t\treturn $out;","+\t}","+","+\t/**","+\t * @throws SignatoryNotFoundException","+\t */","+\t#[\\Override]","+\tpublic function jsonSerialize(): array {","+\t\treturn array_merge(","+\t\t\tparent::jsonSerialize(),","+\t\t\t[","+\t\t\t\t'host' => $this->host,","+\t\t\t\t'headers' => $this->