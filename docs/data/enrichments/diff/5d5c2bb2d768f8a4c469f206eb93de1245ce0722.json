Test : public AggregationContextFixture {","+protected:","+    DocumentSourceInternalDocumentResultsAndMetadata* parse(const BSONObj& bson) {","+        auto specElem = bson.firstElement();","+        auto specObj = specElem.embeddedObject().getOwned();","+        auto spec =","+            DocumentSourceResultsAndMetadataSpec::parse(specObj, IDLParserContext(kStageName));","+        InternalDocumentResultsAndMetadataStageParams params(std::move(spec));","+        _stages = DocumentSourceInternalDocumentResultsAndMetadata::createFromStageParams(","+            params, getExpCtx());","+        ASSERT_EQ(_stages.size(), 1u);","+        auto* docResultsAndMetadata =","+            dynamic_cast<DocumentSourceInternalDocumentResultsAndMetadata*>(_stages.front().get());","+        ASSERT(docResultsAndMetadata);","+        return docResultsAndMetadata;","+    }","+","+private:","+    DocumentSourceContainer _stages;","+};","+","+TEST_F(DocumentSourceInternalDocumentResultsAndMetadataTest, ParsesFullSpec) {","+    auto* stage = parse(BSON(kStageName << kFullSpec));","+    ASSERT_EQ(stage->getSourceStage()->getSourceName(), StringData(\"$collStats\"));","+    ASSERT(stage->getMetadata().has_value());","+    ASSERT_EQ(stage->getMetadata()->getAs(), \"SEARCH_META\");","+    ASSERT_TRUE(stage->getReturnCursor());","+}","+","+TEST_F(DocumentSourceInternalDocumentResultsAndMetadataTest, ParsesSpecWithoutMetadata) {","+    auto* stage = parse(BSON(kStageName << kSourceOnly));","+    ASSERT_FALSE(stage->getMetadata().has_value());","+    ASSERT_FALSE(stage->getReturnCursor());","+}","+","+using DocumentSourceInternalDocumentResultsAndMetadataDeathTest =","+    DocumentSourceInternalDocumentResultsAndMetadataTest;","+","+DEATH_TEST_F(DocumentSourceInternalDocumentResultsAndMetadataDeathTest,","+             RejectsSourceThatRequiresInputDocSource,","+             \"12615004\") {","+    parse(BSON(kStageName << BSON(\"source\" << BSON(\"$limit\" << 1))));","+}","+","+DEATH_TEST_F(Doc