e: (document.body.classList.contains('vscode-dark') || document.body.classList.contains('vscode-high-contrast')","-\t\t\t? extConfig.darkModeTheme","-\t\t\t: extConfig.lightModeTheme) as MermaidConfig['theme'],"," \t};"," "," \tmermaid.initialize(config);"],"additions":8,"deletions":5,"truncated":false},{"path":"extensions/mermaid-markdown-features/preview-src/shared/index.ts","lines":["@@ -8,6 +8,7 @@ import zenuml from '@mermaid-js/mermaid-zenuml';"," import mermaid, { MermaidConfig } from 'mermaid';"," import { iconPacks } from './iconPackConfig';"," import { ClickDragMode, MermaidExtensionConfig, ShowControlsMode } from './config';","+import { vsCodeMermaidTheme, VsCodeMermaidThemeTracker } from './vsCodeTheme';"," "," /**","  * Creates the `<pre class=\"mermaid-error\">` node shown when a diagram fails to render.","@@ -132,9 +133,9 @@ export async function registerMermaidAddons() {"," \tawait mermaid.registerExternalDiagrams([zenuml]);"," }"," ","-const defaultConfig: MermaidExtensionConfig = {","-\tdarkModeTheme: 'dark',","-\tlightModeTheme: 'default',","+export const defaultExtensionConfig: MermaidExtensionConfig = {","+\tdarkModeTheme: vsCodeMermaidTheme,","+\tlightModeTheme: vsCodeMermaidTheme,"," \tmaxTextSize: 50000,"," \tclickDrag: ClickDragMode.Alt,"," \tshowControls: ShowControlsMode.OnHoverOrFocus,","@@ -146,23 +147,23 @@ export function loadExtensionConfig(): MermaidExtensionConfig {"," \tconst configSpan = document.getElementById('markdown-mermaid');"," \tconst configAttr = configSpan?.dataset.config;"," \tif (!configAttr) {","-\t\treturn defaultConfig;","+\t\treturn defaultExtensionConfig;"," \t}"," "," \ttry {","-\t\treturn { ...defaultConfig, ...JSON.parse(configAttr) };","+\t\treturn { ...defaultExtensionConfig, ...JSON.parse(configAttr) };"," \t} catch {","-\t\treturn defaultConfig;","+\t\treturn defaultExtensionConfig;"," \t}"," }"," ","-export function loadMermaidConfig(): MermaidConfig {","-\tconst config = loadExtensionConfig();","+export function buildMermaidConfig(","+\textensionConfig: MermaidExtensionConfig,","+\tvsCodeThemeTracker: VsCodeMermaidThemeTracker,","+): MermaidConfig {"," \treturn {"," \t\tstartOnLoad: false,","-\t\ttheme: (document.body.classList.contains('vscode-dark') || document.body.classList.contains('vscode-high-contrast')","-\t\t\t? config.darkModeTheme","-\t\t\t: config.lightModeTheme) as MermaidConfig['theme'],","+\t\t...vsCodeThemeTracker.resolveMermaidTheme(extensionConfig),"," \t};"," }"," "],"additions":12,"deletions":11,"truncated":false},{"path":"extensions/mermaid-markdown-features/preview-src/shared/vsCodeTheme.ts","lines":["@@ -0,0 +1,247 @@","+/*---------------------------------------------------------------------------------------------","+ *  Copyright (c) Microsoft Corporation. All rights reserved.","+ *  Licensed under the MIT License. See License.txt in the project root for license information.","+ *--------------------------------------------------------------------------------------------*/","+","+import { MermaidConfig } from 'mermaid';","+import { MermaidExtensionConfig } from './config';","+import { IDisposable } from './disposable';","+","+/**","+ * Identifier for the custom Mermaid theme that is derived from the current VS Code color theme.","+ */","+export const vsCodeMermaidTheme = 'vscode';","+","+/**","+ * Returns `true` when the active VS Code theme is a dark (or non-light high contrast) theme.","+ */","+function isDarkVsCodeTheme(): boolean {","+\treturn document.body.classList.contains('vscode-dark')","+\t\t|| (document.body.classList.contains('vscode-high-contrast') && !document.body.classList.contains('vscode-high-contrast-light'));","+}","+","+/**","+ * Resolves a CSS color value (such as `var(--vscode-editor-background)`) to a hex color string","+ * by letting the browser compute it on a temporary element.","+ */","+function resolveCssColor(cssValue: string): string | undefined {","+\tconst probe = document.createElement('span');","+\tprobe.style.display = 'none';","+\tprobe.style.color = cssValue;","+\tdocument.body.appendChild(probe);","+\ttry {","+\t\treturn rgbStringToHex(getComputedStyle(probe).color);","+\t} finally {","+\t\tprobe.remove();","+\t}","+}","+","+function rgbStringToHex(value: string): string | undefined {","+\tconst match = value.match(/^rgba?\\(\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)\\s*(?:,\\s*([\\d.]+)\\s*)?\\)$/);","+\tif (!match) {","+\t\treturn undefined;","+\t}","+\tconst r = parseInt(match[1], 10);","+\tconst g = parseInt(match[2], 10);","+\tconst b = parseInt(match[3], 10);","+\tconst a = match[4] !== undefined ? Math.round(parseFloat(match[4]) * 255) : 255;","+\tconst hex = (n: number) => Math.max(0, Math.min(255, n)).toString(16).padStart(2, '0');","+\treturn a < 255","+\t\t? `#${hex(r)}${hex(g)}${hex(b)}${hex(a)}`","+\t\t: `#${hex(r)}${hex(g)}${hex(b)}`;","+}","+","+function pickColor(...varNames: string[]): string | undefined {","+\tfor (const name of varNames) {","+\t\tconst hex = resolveCssColor(`var(${name})`);","+\t\tif (hex) {","+\t\t\treturn hex;","+\t\t}","+\t}","+\treturn undefined;","+}","+","+function readCssVar(name: string): string {","+\treturn getComputedStyle(document.body).getPropertyValue(name).trim();","+}","+","+/**","+ * The Mermaid `themeVariables` derived from the active VS Code color theme, plus a string","+ * fingerprint that changes whenever any of the resolved colors change.","+ */","+export interface VsCodeMermaidThemeVariables {","+\treadonly variables: Record<string, string | boolean>;","+\treadonly fingerprint: string;","+}","+","+/**","+ * Resolves and caches Mermaid `themeVariables` derived from the active VS Code color theme.","+ *","+ * Each consumer should construct one tracker, read {@link value} when initializing mermaid, and","+ * subscribe to {@link onDidChange} (or call {@link refresh} after a theme-change signal) to keep","+ * its rendered diagrams in sync with theme switches.","+ */","+export class VsCodeMermaidThemeTracker {","+","+\tprivate _value: VsCodeMermaidThemeVariables | undefined;","+\tprivate readonly _listeners = new Set<() => void>();","+","+\t/**","+\t * The Mermaid theme variables derived from the active VS Code theme. Computed lazily on","+\t * first access and memoized until {@link refresh} or {@link invalidate} is called.","+\t */","+\tget value(): VsCodeMermaidThemeVariables {","+\t\treturn this._value ??= computeVsCodeMermaidThemeVariables();","+\t}","+","+\t/**","+\t * Recomputes the theme variables from the live CSS variables and fires {@link onDidChange}","+\t * listeners when the resolved colors actually changed. Returns `true` when listeners fired.","+\t */","+\trefresh(): boolean {","+\t\tconst next = computeVsCodeMermaidThemeVariables();","+\t\tif (next.fingerprint === this._value?.fingerprint) {","+\t\t\treturn false;","+\t\t}","+","+\t\tthis._value = next;","+\t\tfor (const listener of this._listeners) {","+\t\t\tlistener();","+\t\t}","+\t\treturn true;","+\t}","+","+\t/**","+\t * Drops the cached value without firing listeners. The next read of {@link value} will","+\t * recompute from the live CSS variables.","+\t */","+\tinvalidate(): void {","+\t\tthis._value = undefined;","+\t}","+","+\t/**","+\t * Subscribes to changes. The listener fires when {@link refresh} detects that the resolved","+\t * theme variables have changed; read {@link value} to get the new variables.","+\t */","+\tonDidChange(listener: () => void): IDisposable {","+\t\tthis._listeners.add(listener);","+\t\treturn { dispose: () => this._listeners.delete(listener) };","+\t}","+","+\t/**","+\t * Resolves the Mermaid `theme` / `themeVariables` pair for the given extension config,","+\t * picking the dark or light slot based on the active VS Code theme and translating the","+\t * `'vscode'` sentinel into mermaid's `base` theme plus VS Code-derived variables.","+\t */","+\tresolveMermaidTheme(extensionConfig: MermaidExtensionConfig): Pick<MermaidConfig, 'theme' | 'themeVariables'> {","+\t\tconst themeName = isDarkVsCodeTheme()","+\t\t\t? extensionConfig.darkModeTheme","+\t\t\t: extensionConfig.lightModeTheme;","+","+\t\tif (themeName === vsCodeMermaidTheme) {","+\t\t\treturn {","+\t\t\t\ttheme: 'base',","+\t\t\t\tthemeVariables: this.value.variables,","+\t\t\t};","+\t\t}","+","+\t\treturn {","+\t\t\ttheme: themeName as MermaidConfig['theme'],","+\t\t\t// Reset theme variables in case mermaid.initialize was previously called with the","+\t\t\t// vscode theme: mermaid merges configs and stale variables would otherwise leak through.","+\t\t\tthemeVariables: {},","+\t\t};","+\t}","+","+\t/**","+\t * Starts a {@link MutationObserver} on the body and document element so that theme switches","+\t * (class/data-attribute changes on `body`, CSS variable updates on `documentElement.style`)","+\t * trigger a {@link refresh}. Returns a disposable that stops observing.","+\t */","+\tobserveDomChanges(): IDisposable {","+\t\tconst observer = new MutationObserver(() => this.refresh());","+\t\tobserver.observe(document.body, { attributes: true, attributeFilter: ['class', 'data-vscode-theme-id', 'data-vscode-theme-kind'] });","+\t\tobserver.observe(document.documentElement, { attributes: true, attributeFilter: ['style'] });","+\t\treturn { dispose: () => observer.disconnect() };","+\t}","+}","+","+function computeVsCodeMermaidThemeVariables(): VsCodeMermaidThemeVariables {","+\tconst variables: Record<string, string | boolean> = {","+\t\tdarkMode: isDarkVsCodeTheme(),","+\t};","+","+\tconst set = (key: string, ...varNames: string[]) => {","+\t\tconst color = pickColor(...varNames);","+\t\tif (color) {","+\t\t\tvariables[key] = color;","+\t\t}","+\t};","+","+\t// Canvas / text","+\tset('background', '--vscode-editor-background');","+\tset('textColor', '--vscode-charts-foreground', '--vscode-editor-foreground', '--vscode-foreground');","+\tset('lineColor', '--vscode-chart-line', '--vscode-charts-lines', '--vscode-editor-foreground', '--vscode-foreground');","+","+\t// Primary (default node) colors","+\tset('primaryColor', '--vscode-editorWidget-background');","+\tset('primaryTextColor', '--vscode-charts-foreground', '--vscode-editor-foreground', '--vscode-foreground');","+\tset('primaryBorderColor', '--vscode-chart-line', '--vscode-editorWidget-border', '--vscode-focusBorder');","+\tset('mainBkg', '--vscode-editorWidget-background');","+\tset('nodeBorder', '--vscode-chart-line', '--vscode-editorWidget-border', '--vscode-focusBorder');","+","+\t// Secondary colors","+\tset('secondaryColor', '--vscode-input-background', '--vscode-editorWidget-background');","+\tset('secondaryTextColor', '--vscode-input-foreground', '--vscode-foreground');","+\tset('secondaryBorderColor', '--vscode-input-border', '--vscode-editorWidget-border');","+","+\t// Tertiary / subgraph (cluster) colors","+\tset('tertiaryColor', '--vscode-textBlockQuote-background', '--vscode-input-background');","+\tset('tertiaryTextColor', '--vscode-foreground');","+\tset('tertiaryBorderColor', '--vscode-textBlockQuote-border', '--vscode-editorWidget-border');","+\tset('clusterBkg', '--vscode-textBlockQuote-background', '--vscode-input-background');","+\tset('clusterBorder', '--vscode-textBlockQuote-border', '--vscode-editorWidget-border');","+","+\t// Notes","+\tset('noteBkgColor', '--vscode-textBlockQuote-background', '--vscode-editorWidget-background');","+\tset('noteTextColor', '--vscode-foreground');","+\tset('noteBorderColor', '--vscode-textBlockQuote-border', '--vscode-editorWidget-border');","+","+\t// Errors","+\tset('errorBkgColor', '--vscode-inputValidation-errorBackground', '--vscode-editorError-background');","+\tset('errorTextColor', '--vscode-editorError-foreground', '--vscode-foreground');","+","+\t// Misc","+\tset('titleColor', '--vscode-charts-foreground', '--vscode-editor-foreground', '--vscode-foreground');","+\tset('edgeLabelBackground', '--vscode-editor-background');","+","+\t// Pie / palette slots — mermaid uses pie1..pie12 for pie chart slices and cScale0..