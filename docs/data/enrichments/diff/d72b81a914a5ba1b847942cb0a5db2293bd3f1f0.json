","+\ttest('does not create the watcher until a managed-settings policy definition is registered', async () => {","+\t\tlet watcherCreated = false;","+\t\tconst watcherFactory: CopilotPolicyWatcherFactory = () => {","+\t\t\twatcherCreated = true;","+\t\t\treturn Disposable.None;","+\t\t};","+","+\t\tconst service = disposables.add(new CopilotManagedSettingsService(new NullLogService(), 'com.github.copilot', undefined, watcherFactory));","+\t\tawait service.updatePolicyDefinitions({ OtherPolicy: { type: 'boolean' } });","+","+\t\tassert.strictEqual(watcherCreated, false);","+\t});","+","+\ttest('clears stale watcher values when managed-settings definitions are removed', async () => {","+\t\tlet onDidChange: ((update: Record<string, PolicyValue | undefined>) => void) | undefined;","+\t\tlet disposeCount = 0;","+\t\tconst watcherFactory: CopilotPolicyWatcherFactory = (_productName, _policies, callback) => {","+\t\t\tonDidChange = callback;","+\t\t\tcallback({});","+\t\t\treturn { dispose: () => disposeCount++ };","+\t\t};","+","+\t\tconst service = disposables.add(new CopilotManagedSettingsService(new NullLogService(), 'com.github.copilot', undefined, watcherFactory));","+\t\tawait service.updatePolicyDefinitions({","+\t\t\t[policyName]: {","+\t\t\t\ttype: 'boolean',","+\t\t\t\tmanagedSettings: {","+\t\t\t\t\t[COPILOT_DISABLE_BYPASS_PERMISSIONS_MODE_KEY]: { type: 'string' },","+\t\t\t\t}","+\t\t\t}","+\t\t});","+","+\t\tonDidChange?.({ [COPILOT_DISABLE_BYPASS_PERMISSIONS_MODE_KEY]: 'disable' });","+\t\tawait service.updatePolicyDefinitions({});","+","+\t\tassert.deepStrictEqual({ managedSettings: service.managedSettings, disposeCount }, { managedSettings: {}, disposeCount: 1 });","+\t});","+","+\ttest('keeps raw managed settings while definitions are unchanged', async () => {","+\t\tlet onDidChange: ((update: Record<string, PolicyValue | undefined>) => void) | undefined;","+\t\tlet watcherCreateCount = 0;","+\t\tconst watcherFactory: CopilotPolicyWatcherFactory = (_pro