ICopilotManagedSettingsService = createDecorator<ICopilotManagedSettingsService>('copilotManagedSettingsService');","+","+export interface ICopilotManagedSettingsService {","+\treadonly _serviceBrand: undefined;","+\treadonly managedSettings: ManagedSettingsData;","+\treadonly onDidChangeManagedSettings: Event<ManagedSettingsData>;","+\tupdatePolicyDefinitions(policyDefinitions: IStringDictionary<PolicyDefinition>): Promise<ManagedSettingsData>;","+}","+","+export class NullCopilotManagedSettingsService implements ICopilotManagedSettingsService {","+\treadonly _serviceBrand: undefined;","+\treadonly managedSettings: ManagedSettingsData = {};","+\treadonly onDidChangeManagedSettings = Event.None;","+","+\tasync updatePolicyDefinitions(): Promise<ManagedSettingsData> { return this.managedSettings; }","+}","+","+export function flattenManagedSettings(object: unknown): Record<string, string | number | boolean> {","+\tconst result: Record<string, string | number | boolean> = {};","+\tflattenManagedSettingsValue(object, undefined, result);","+\treturn result;","+}","+","+function flattenManagedSettingsValue(value: unknown, prefix: string | undefined, result: Record<string, string | number | boolean>): void {","+\tif (typeof value === 'string' || typeof value === 'number' || typeof value === 'boolean') {","+\t\tif (prefix !== undefined) {","+\t\t\tresult[prefix] = value;","+\t\t}","+\t\treturn;","+\t}","+","+\tif (!isManagedSettingsObject(value)) {","+\t\treturn;","+\t}","+","+\tfor (const key in value) {","+\t\tflattenManagedSettingsValue(value[key], prefix ? `${prefix}.${key}` : key, result);","+\t}","+}","+","+function isManagedSettingsObject(value: unknown): value is Record<string, unknown> {","+\treturn typeof value === 'object' && value !== null && !Array.isArray(value);","+}"],"additions":68,"deletions":0,"truncated":false},{"path":"src/vs/platform/policy/common/copilotManagedSettingsIpc.ts","lines":["@@ -0,0 +1,88 @@","+/*---------------------------------------------------------------------------------------------","+ *  Copyright (c) Microsoft Corporation. All rights reserved.","+ *  Licensed under the MIT License. See License.txt in the project root for license information.","+ *--------------------------------------------------------------------------------------------*/","+","+import { Emitter, Event } from '../../../base/common/event.js';","+import { IStringDictionary } from '../../../base/common/collections.js';","+import { Disposable, DisposableStore } from '../../../base/common/lifecycle.js';","+import { IChannel, IServerChannel } from '../../../base/parts/ipc/common/ipc.js';","+import { ICopilotManagedSettingsService, ManagedSettingsData } from './copilotManagedSettings.js';","+import { PolicyDefinition } from './policy.js';","+","+export class CopilotManagedSettingsChannel implements IServerChannel {","+","+\tprivate readonly disposables = new DisposableStore();","+","+\tconstructor(private readonly service: ICopilotManagedSettingsService) { }","+","+\tlisten<T>(_: unknown, event: string): Event<T> {","+\t\tswitch (event) {","+\t\t\tcase 'onDidChangeManagedSettings': return this.service.onDidChangeManagedSettings as Event<T>;","+\t\t}","+","+\t\tthrow new Error(`Event not found: ${event}`);","+\t}","+","+\tcall<T>(_: unknown, command: string, arg?: unknown): Promise<T> {","+\t\tswitch (command) {","+\t\t\tcase 'getManagedSettings': return Promise.resolve(this.service.managedSettings as T);","+\t\t\tcase 'updatePolicyDefinitions': return this.service.updatePolicyDefinitions(arg as IStringDictionary<PolicyDefinition>) as Promise<T>;","+\t\t}","+","+\t\tthrow new Error(`Call not found: ${command}`);","+\t}","+","+\tdispose(): void {","+\t\tthis.disposables.dispose();","+\t}","+}","+","+export class CopilotManagedSettingsChannelClient extends Disposable implements ICopilotManagedSettingsService {","+","+\treadonly _serviceBrand: undefined;","+","+\tprivate _managedSettings: ManagedSettingsData = {};","+\tget managedSettings(): ManagedSettingsData { return this._managedSettings; }","+\tprivate hasReceivedManagedSettings = false;","+","+\tprivate readonly _onDidChangeManagedSettings = this._register(new Emitter<ManagedSettingsData>());","+\treadonly onDidChangeManagedSettings = this._onDidChangeManagedSettings.event;","+","+\tconstructor(private readonly channel: IChannel) {","+\t\tsuper();","+\t\tthis._register(this.channel.listen<ManagedSettingsData>('onDidChangeManagedSettings')(managedSettings => this.updateManagedSettings(managedSettings, true)));","+\t\tthis.channel.call<ManagedSettingsData>('getManagedSettings').then(managedSettings => {","+\t\t\tif (!this.hasReceivedManagedSettings) {","+\t\t\t\tthis.updateManagedSettings(managedSettings, true);","+\t\t\t}","+\t\t});","+\t}","+","+\tasync updatePolicyDefinitions(policyDefinitions: IStringDictionary<PolicyDefinition>): Promise<ManagedSettingsData> {","+\t\tthis.updateManagedSettings(await this.channel.call<ManagedSettingsData>('updatePolicyDefinitions', policyDefinitions), false);","+\t\treturn this._managedSettings;","+\t}","+","+\tprivate updateManagedSettings(managedSettings: ManagedSettingsData, fireEvent: boolean): void {","+\t\tthis.hasReceivedManagedSettings = true;","+\t\tif (areManagedSettingsEqual(this._managedSettings, managedSettings)) {","+\t\t\treturn;","+\t\t}","+","+\t\tthis._managedSettings = managedSettings;","+\t\tif (fireEvent) {","+\t\t\tthis._onDidChangeManagedSettings.fire(this._managedSettings);","+\t\t}","+\t}","+}","+","+function areManagedSettingsEqual(a: ManagedSettingsData, b: ManagedSettingsData): boolean {","+\tconst aKeys = Object.keys(a);","+\tconst bKeys = Object.keys(b);","+\tif (aKeys.length !== bKeys.length) {","+\t\treturn false;","+\t}","+","+\treturn aKeys.every(key => a[key] === b[key]);","+}"],"additions":88,"deletions":0,"truncated":false},{"path":"src/vs/platform/policy/common/multiplexPolicyService.ts","lines":["rename from src/vs/workbench/services/policies/common/multiplexPolicyService.ts","rename to src/vs/platform/policy/common/multiplexPolicyService.ts","@@ -3,11 +3,11 @@","  *  Licensed under the MIT License. See License.txt in the project root for license information.","  *--------------------------------------------------------------------------------------------*/"," ","-import { IStringDictionary } from '../../../../base/common/collections.js';","-import { Iterable } from '../../../../base/common/iterator.js';","-import { Event } from '../../../../base/common/event.js';","-import { ILogService } from '../../../../platform/log/common/log.js';","-import { AbstractPolicyService, IPolicyService, PolicyDefinition, PolicyValue } from '../../../../platform/policy/common/policy.js';","+import { IStringDictionary } from '../../../base/common/collections.js';","+import { Event } from '../../../base/common/event.js';","+import { Iterable } from '../../../base/common/iterator.js';","+import { ILogService } from '../../log/common/log.js';","+import { AbstractPolicyService, IPolicyService, PolicyDefinition, PolicyValue } from './policy.js';"," "," export class MultiplexPolicyService extends AbstractPolicyService implements IPolicyService {"," "],"additions":5,"deletions":5,"truncated":false},{"path":"src/vs/platform/policy/common/policy.ts","lines":["@@ -8,13 +8,14 @@ import { IPolicyData } from '../../../base/common/defaultAccount.js';"," import { Emitter, Event } from '../../../base/common/event.js';"," import { Iterable } from '../../../base/common/iterator.js';"," import { Disposable } from '../../../base/common/lifecycle.js';","-import { PolicyName } from '../../../base/common/policy.js';","+import { IManagedSettingsPolicyDefinitions, PolicyName } from '../../../base/common/policy.js';"," import { createDecorator } from '../../instantiation/common/instantiation.js';"," "," export type PolicyValue = string | number | boolean;"," export type PolicyDefinition = {"," \ttype: 'string' | 'number' | 'boolean';"," \tvalue?: (policyData: IPolicyData) => string | number | boolean | undefined;","+\tmanagedSettings?: IManagedSettingsPolicyDefinitions;"," \trestrictedValue?: PolicyValue;"," };"," "],"additions":2,"deletions":1,"truncated":false},{"path":"src/vs/platform/policy/node/copilotManagedSettingsService.ts","lines":["@@ -0,0 +1,151 @@","+/*---------------------------------------------------------------------------------------------","+ *  Copyright (c) Microsoft Corporation. All rights reserved.","+ *  Licensed under the MIT License. See License.txt in the project root for license information.","+ *--------------------------------------------------------------------------------------------*/","+","+import { Throttler } from '../../../base/common/async.js';","+import { IStringDictionary } from '../../../base/common/collections.js';","+import { Emitter } from '../../../base/common/event.js';","+import { Disposable, MutableDisposable } from '../../../base/common/lifecycle.js';","+import { IManagedSettingPolicyDefinition, ManagedSettingsData } from '../../../base/common/policy.js';","+import { ILogService } from '../../log/common/log.js';","+import { ICopilotManagedSettingsService } from '../common/copilotManagedSettings.js';","+import { PolicyDefinition, PolicyValue } from '../common/policy.js';","+import type { Watcher } from '@vscode/policy-watcher';","+","+export interface ICopilotPolicyWatcherOptions {","+\treadonly registryPath?: string;","+}","+","+export type CopilotPolicyWatcherFactory = (","+\tproductName: string,","+\tpolicies: Record<string, { type: 'string' | 'number' | 'boolean' }>,","+\tonDidChange: (update: Record<string, PolicyValue | undefined>) => void,","+\toptions?: ICopilotPolicyWatcherOptions,","+) => Watcher;","+","+export class CopilotManagedSettingsService extends Disposable implements ICopilotManagedSettingsService {","+","+\treadonly _serviceBrand: undefined;","+","+\tprivate readonly throttler = this._register(new Throttler());","+\tprivate readonly watcher = this._register(new MutableDisposable<Watcher>());","+\tprivate readonly managedSettingsValues = new Map<string, PolicyValue>();","+\tprivate watchedSettings: Record<string, IManagedSettingPolicyDefinition> = {};","+","+\tprivate readonly _onDidChangeManagedSettings = this._register(new Emitter<ManagedSettingsData>());","+\treadonly onDidChangeManagedSettings = this._onDidChangeManagedSettings.event;","+","+\tget managedSettings(): ManagedSettingsData {","+\t\treturn Object.fromEntries(this.managedSettingsValues);","+\t}","+","+\tconstructor(","+\t\t@ILogService private readonly logService: ILogService,","+\t\tprivate readonly productName: string,","+\t\tprivate readonly watcherOptions?: ICopilotPolicyWatcherOptions,","+\t\tprivate readonly watcherFactory?: CopilotPolicyWatcherFactory,","+\t) {","+\t\tsuper();","+\t}","+","+\tasync updatePolicyDefinitions(policyDefinitions: IStringDictionary<PolicyDefinition>): Promise<ManagedSettingsData> {","+\t\tconst managedSettings: Record<string, IManagedSettingPolicyDefinition> = {};","+\t\tfor (const policyName in policyDefinitions) {","+\t\t\tconst policyManagedSettings = policyDefinitions[policyName].managedSettings;","+\t\t\tif (policyManagedSettings) {","+\t\t\t\tfor (const key in policyManagedSettings) {","+\t\t\t\t\tmanagedSettings[key] = policyManagedSettings[key];","+\t\t\t\t}","+\t\t\t}","+\t\t}","+","+\t\tif (areManagedSettingDefinitionsEqual(this.watchedSettings, managedSettings)) {","+\t\t\treturn this.managedSettings;","+\t\t}","+","+\t\tthis.watchedSettings = managedSettings;","+\t\tconst changed = this.pruneManagedSettingsValues();","+\t\tawait this.updateWatcher();","+\t\tif (changed) {","+\t\t\tthis._onDidChangeManagedSettings.fire(this.managedSettings);","+\t\t}","+\t\treturn this.managedSettings;","+\t}","+","+\tprivate pruneManagedSettingsValues(): boolean {","+\t\tlet changed = false;","+\t\tfor (const key of this.managedSettingsValues.keys()) {","+\t\t\tif (!this.watchedSettings[key]) {","+\t\t\t\tthis.managedSettingsValues.delete(key);","+\t\t\t\tchanged = true;","+\t\t\t}","+\t\t}","+\t\treturn changed;","+\t}","+","+\tprivate async updateWatcher(): Promise<void> {","+\t\tconst managedSettingDefinitions = this.getManagedSettingDefinitions();","+\t\tthis.logService.trace(`CopilotManagedSettingsService#updateWatcher - Found ${Object.keys(managedSettingDefinitions).length} managed-settings definitions`);","+\t\tif (Object.keys(managedSettingDefinitions).length === 0) {","+\t\t\tthis.watcher.clear();","+\t\t\tconst hadManagedSettings = this.managedSettingsValues.size > 0;","+\t\t\tthis.managedSettingsValues.clear();","+\t\t\tif (hadManagedSettings) {","+\t\t\t\tthis._onDidChangeManagedSettings.fire(this.managedSettings);","+\t\t\t}","+\t\t\treturn;","+\t\t}","+","+\t\tconst { createWatcher } = this.watcherFactory ? { createWatcher: this.watcherFactory } : (await import('@vscode/policy-watcher') as { createWatcher: CopilotPolicyWatcherFactory });","+\t\tawait this.throttler.queue(() => new Promise<void>((c, e) => {","+\t\t\ttry {","+\t\t\t\tthis.logService.trace(`Creating Copilot managed-settings watcher for productName ${this.productName}`);","+\t\t\t\tthis.watcher.value = createWatcher(this.productName, managedSettingDefinitions, update => {","+\t\t\t\t\tthis._onDidManagedSettingsChange(update as Record<string, PolicyValue | undefined>);","+\t\t\t\t\tc();","+\t\t\t\t}, this.watcherOptions);","+\t\t\t} catch (err) {","+\t\t\t\tthis.logService.error(`CopilotManagedSettingsService#updateWatcher - Error creating watcher:`, err);","+\t\t\t\te(err);","+\t\t\t}","+\t\t}));","+\t}","+","+\tprivate getManagedSettingDefinitions(): Record<string, { type: 'string' | 'number' | 'boolean' }> {","+\t\tconst definitions: Record<string, { type: 'string' | 'number' | 'boolean' }> = {};","+\t\tfor (const key in this.watchedSettings) {","+\t\t\tdefinitions[key] = { type: this.watchedSettings[key].type };","+\t\t}","+\t\treturn definitions;","+\t}","+","+\tprivate _onDidManagedSettingsChange(update: Record<string, PolicyValue | undefined>): void {","+\t\tthis.logService.trace(`CopilotManagedSettingsService#_onDidManagedSettingsChange - Updated managed-settings values: ${JSON.stringify(update)}`);","+","+\t\tlet changed = false;","+\t\tfor (const [key, value] of Object.entries(update)) {","+\t\t\tif (value === undefined) {","+\t\t\t\tchanged = this.managedSettingsValues.delete(key) || changed;","+\t\t\t} else {","+\t\t\t\tif (this.managedSettingsValues.get(key) !== value) {","+\t\t\t\t\tthis.managedSettingsValues.set(key, value);","+\t\t\t\t\tchanged = true;","+\t\t\t\t}","+\t\t\t}","+\t\t}","+\t\tif (changed) {","+\t\t\tthis._onDidChangeManagedSettings.fire(this.managedSettings);","+\t\t}","+\t}","+}","+","+function areManagedSettingDefinitionsEqual(a: Record<string, IManagedSettingPolicyDefinition>, b: Record<string, IManagedSettingPolicyDefinition>): boolean {","+\tconst aKeys = Object.keys(a);","+\tconst bKeys = Object.keys(b);","+\tif (aKeys.length !== bKeys.length) {","+\t\treturn false;","+\t}","+","+\treturn aKeys.every(key => a[key]?.type === b[key]?.type);","+}"],"additions":151,"deletions":0,"truncated":false},{"path":"src/vs/platform/policy/test/node/copilotManagedSettingsService.test.ts","lines":["@@ -0,0 +1,217 @@","+/*---------------------------------------------------------------------------------------------","+ *  Copyright (c) Microsoft Corporation. All rights reserved.","+ *  Licensed under the MIT License. See License.txt in the project root for license information.","+ *--------------------------------------------------------------------------------------------*/","+","+import assert from 'assert';","+import { Emitter, Event } from '../../../../base/common/event.js';","+import { Disposable } from '../../../../base/common/lifecycle.js';","+import { ManagedSettingsData } from '../../../../base/common/policy.js';","+import { IChannel } from '../../../../base/parts/ipc/common/ipc.js';","+import { ensureNoDisposablesAreLeakedInTestSuite } from '../../../