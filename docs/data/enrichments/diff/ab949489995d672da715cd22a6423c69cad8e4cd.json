ortBinds(binds []bindResult) []bindResult {","+\tsort.Slice(binds, func(i, j int) bool { return binds[i].key < binds[j].key })","+\treturn binds","+}","+","+// TestBuildBindsFromGateway verifies bind generation, with an emphasis on the","+// fact that different gateways may share a port as long as each gateway gets its","+// own bind keyed by \"port/namespace/name\". This means two gateways can bind the","+// same port with different protocols or different tunnel protocols.","+func TestBuildBindsFromGateway(t *testing.T) {","+\tc := &Controller{}","+\ttests := []struct {","+\t\tname string","+\t\t// each entry is the set of listeners belonging to a single parent","+\t\t// gateway; buildBindsFromGateway is called once per group, mirroring how","+\t\t// the controller groups listeners by parent gateway.","+\t\tgateways [][]*GatewayListener","+\t\twant     []bindResult","+\t}{","+\t\t{","+\t\t\tname:     \"no listeners produces no binds\",","+\t\t\tgateways: [][]*GatewayListener{{}},","+\t\t\twant:     nil,","+\t\t},","+\t\t{","+\t\t\tname: \"different gateways share a port with different protocols\",","+\t\t\tgateways: [][]*GatewayListener{","+\t\t\t\t{agwBindListener(\"gateway-http\", 8080, gatewayv1.HTTPProtocolType, constants.AgentgatewayClassName, \"\")},","+\t\t\t\t{agwBindListener(\"gateway-https\", 8080, gatewayv1.HTTPSProtocolType, constants.AgentgatewayClassName, \"\")},","+\t\t\t},","+\t\t\twant: []bindResult{","+\t\t\t\t{key: \"8080/default/gateway-http\", gateway: \"default/gateway-http\", port: 8080, protocol: api.Bind_HTTP, tunnel: api.Bind_DIRECT},","+\t\t\t\t{key: \"8080/default/gateway-https\", gateway: \"default/gateway-https\", port: 8080, protocol: api.Bind_TLS, tunnel: api.Bind_DIRECT},","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname: \"different gateways share a port with different tunnel protocols\",","+\t\t\tgateways: [][]*GatewayListener{","+\t\t\t\t{agwBindListener(\"waypoint\", 15008, hboneProtocol, constants.AgentgatewayWaypointClassName, \"\")},","+\t\t\t\t{agwBindListener(\"gateway\", 15008, hboneProtocol, constants.AgentgatewayClassName, \"\")},","+\t\t\t},","+\t\t\twant: []bindResult{","+\t\t\t\t{key: \"15008/default/waypoint\", gateway: \"default/waypoint\", port: 15008, protocol: api.Bind_HTTP, tunnel: api.Bind_HBONE_WAYPOINT},","+\t\t\t\t{key: \"15008/default/gateway\", gateway: \"default/gateway\", port: 15008, protocol: api.Bind_HTTP, tunnel: api.Bind_HBONE_GATEWAY},","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname: \"single gateway multiple non-conflicting listeners on the same port collapse to one bind\",","+\t\t\tgateways: [][]*GatewayListener{","+\t\t\t\t{","+\t\t\t\t\tagwBindListener(\"gw\", 8080, gatewayv1.HTTPProtocolType, constants.AgentgatewayClassName, \"\"),","+\t\t\t\t\tagwBindListener(\"gw\", 8080, gatewayv1.HTTPProtocolType, constants.AgentgatewayClassName, \"\"),","+\t\t\t\t\tagwBindListener(\"gw\", 443, gatewayv1.HTTPSProtocolType, constants.AgentgatewayClassName, \"\"),","+\t\t\t\t},","+\t\t\t},","+\t\t\twant: []bindResult{","+\t\t\t\t{key: \"8080/default/gw\", gateway: \"default/gw\", port: 8080, protocol: api.Bind_HTTP, tunnel: api.Bind_DIRECT},","+\t\t\t\t{key: \"443/default/gw\", gateway: \"default/gw\", port: 443, protocol: api.Bind_TLS, tunnel: api.Bind_DIRECT},","+\t\t\t},","+\t\t},","+\t\t{","+\t\t\tname: \"conflicting listener does not determine the bind protocol\",","+\t\t\tgateways: [][]*GatewayListener{","+\t\t\t\t{","+\t\t\t\t\tagwBindListener(\"gw\", 8080, gatewayv1.HTTPProtocolType, constants.AgentgatewayClassName, \"\"),","+\t\t\t\t\tagwBindListener(\"gw\", 8080, gatewayv1.HTTPSProtocolType, constants.AgentgatewayClassName, ListenerConflictProtocol),","+\t\t\t\t},","+\t\t\t},","+\t\t\twant: []bindResult{","+\t\t\t\t{key: \"8080/default/gw\", gateway: \"default/gw\", port: 8080, protocol: api.Bind_HTTP, tunnel: api.Bind_DIRECT},","+\t\t\t},","+\t\t},","+\t}","+\tfor _, tt := range tests {","+\t\tt.Run(tt.name, func(t *testing.T) {","+\t\t\tvar got []bindResult","+\t\t