turn allAgwResources, routeAttachments"," }"," ","+// buildBindsFromGateway creates a bind resources from a list of gateway listeners belonging to the same parent gateway","+func (c *Controller) buildBindsFromGateway(listeners []*GatewayListener) []AgwResource {","+\tif len(listeners) == 0 {","+\t\treturn nil","+\t}","+\tparentGateway := listeners[0].ParentGateway","+","+\ttype bindInfo struct {","+\t\tprotocol       api.Bind_Protocol","+\t\ttunnelProtocol api.Bind_TunnelProtocol","+\t}","+\tbyPort := map[uint32]*bindInfo{}","+\tfor _, listener := range listeners {","+\t\tport := uint32(listener.ParentInfo.Port) //nolint:gosec // G115: port is always in valid port range","+\t\tbi, ok := byPort[port]","+\t\tif !ok {","+\t\t\t// Initialize bindInfo with default zero values of protocol and tunnelProtocol enums","+\t\t\tbi = &bindInfo{}","+\t\t\tbyPort[port] = bi","+\t\t}","+\t\t// If a single gateway has GatewayListeners with the same port, the \"winner\" is the one without a conflict","+\t\t// There may be multiple valid GatewayListeners with the same port, as long as the hostnames are","+\t\t// non-overlapping. This case doesn't need to be handled here since the generated bind is independent of","+\t\t// hostname","+\t\tif listener.Conflict == \"\" {","+\t\t\tbi.protocol = c.getBindProtocol(listener)","+\t\t\tif tp := c.getTunnelProtocol(listener); tp != api.Bind_DIRECT {","+\t\t\t\tbi.tunnelProtocol = tp","+\t\t\t}","+\t\t}","+\t}","+","+\tbinds := make([]AgwResource, 0, len(byPort))","+\tfor _, port := range slices.Sort(maps.Keys(byPort)) { // sorted for deterministic output","+\t\tbi := byPort[port]","+\t\tbind := AgwBind{","+\t\t\tBind: &api.Bind{","+\t\t\t\tKey:            fmt.Sprint(port) + \"/\" + parentGateway.String(),","+\t\t\t\tPort:           port,","+\t\t\t\tProtocol:       bi.protocol,","+\t\t\t\tTunnelProtocol: bi.tunnelProtocol,","+\t\t\t},","+\t\t}","+\t\tbinds = append(binds, ToResourceForGateway(parentGateway, bind))","+\t}","+\treturn binds","+}","+"," func listenerName(listener *GatewayListener) *api.ListenerName {"," \tgatewayName := listener.ParentGateway.Name"," \tgatewayNamespace := listener.ParentGateway.Namespace","@@ -773,6 +892,8 @@ func (c *Controller) getProtocolAndTLSConfig(obj *GatewayListener) (api.Protocol"," \t\treturn api.Protocol_TLS, tlsConfig, true"," \tcase gatewayv1.TCPProtocolType:"," \t\treturn api.Protocol_TCP, nil, true","+\tcase gatewayv1.ProtocolType(protocol.HBONE):","+\t\treturn api.Protocol_HBONE, nil, true"," \tdefault:"," \t\treturn api.Protocol_HTTP, nil, false // Unsupported protocol"," \t}","@@ -789,7 +910,29 @@ func (c *Controller) getBindProtocol(obj *GatewayListener) api.Bind_Protocol {"," \t\treturn api.Bind_TLS"," \tcase gatewayv1.TCPProtocolType:"," \t\treturn api.Bind_TCP","+\tcase gatewayv1.ProtocolType(protocol.HBONE):","+\t\t// The bind protocol is not used for HBONE_GATEWAY in the data plane;","+\t\t// the actual inner protocol is determined at runtime from the other","+\t\t// listeners on the same port. Return HTTP as a placeholder.","+\t\treturn api.Bind_HTTP"," \tdefault:"," \t\treturn api.Bind_HTTP"," \t}"," }","+","+// getTunnelProtocol maps a Gateway listener protocol to its tunnel protocol.","+// HBONE listeners use HBONE_GATEWAY mode when agw is a gateway: the proxy terminates inbound HBONE","+// and routes CONNECT requests to local binds.","+// HBONE listeners use HBONE_WAYPOINT mode when agw is a waypoint: the proxy terminates inbound HBONE","+// and routes CONNECT requests to the waypoint.","+func (c *Controller) getTunnelProtocol(obj *GatewayListener) api.Bind_TunnelProtocol {","+\tswitch obj.ParentInfo.Protocol {","+\tcase gatewayv1.ProtocolType(protocol.HBONE):","+\t\tif obj.ParentInfo.IsWaypoint() {","+\t\t\treturn api.Bind_HBONE_WAYPOINT","+\t\t}","+\t\treturn api.Bind_HBONE_GATEWAY","+\tdefault:","+\t\treturn api.Bind_DIRECT","+\t}","+}"],"additions":183,"deletions":40,"truncated":false},{"path":"pilot/pkg/config/kube/agentgateway/agentgateway_c