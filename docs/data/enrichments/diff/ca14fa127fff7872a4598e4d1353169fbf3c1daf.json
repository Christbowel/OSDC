../../platform/log/common/logService';","+import { raceCancellation, raceTimeout } from '../../../../util/vs/base/common/async';","+import { Event } from '../../../../util/vs/base/common/event';","+import { DisposableStore } from '../../../../util/vs/base/common/lifecycle';","+import { CLAUDE_SDK_EXTENSION_ID, IClaudeAgentSdkLoaderService } from '../common/claudeAgentSdkLoaderService';","+","+type SDKActivation =","+\t| { sdk: typeof AgentSdk; error: null }","+\t| { sdk: null; error: Error };","+","+class SdkExtensionNotInstalledError extends Error {","+\tconstructor() {","+\t\tsuper('The ms-vscode.vscode-claude-sdk extension is not installed.');","+\t\tthis.name = 'SdkExtensionNotInstalledError';","+\t}","+}","+","+export class VsCodeClaudeAgentSdkLoaderService implements IClaudeAgentSdkLoaderService {","+\treadonly _serviceBrand: undefined;","+","+\t// Cached on success; reset to undefined on failure so the next call retries.","+\tprivate _sdk: Promise<typeof AgentSdk> | undefined;","+","+\tconstructor(","+\t\t@IConfigurationService private readonly _configurationService: IConfigurationService,","+\t\t@ILogService private readonly _logService: ILogService,","+\t) { }","+","+\tget isAvailable(): boolean {","+\t\treturn vscode.extensions.getExtension(CLAUDE_SDK_EXTENSION_ID) !== undefined;","+\t}","+","+\tasync install(token: vscode.CancellationToken): Promise<boolean> {","+\t\tif (token.isCancellationRequested) {","+\t\t\treturn false;","+\t\t}","+","+\t\ttry {","+\t\t\tawait vscode.commands.executeCommand('workbench.extensions.installExtension', CLAUDE_SDK_EXTENSION_ID);","+\t\t} catch (err) {","+\t\t\t// May throw if already installing or on network error; check availability below.","+\t\t\tthis._logService.warn(`[ClaudeAgentSdkLoader] installExtension command failed for ${CLAUDE_SDK_EXTENSION_ID}: ${err}`);","+\t\t}","+","+\t\tif (this.isAvailable) {","+\t\t\treturn true;","+\t\t}","+","+\t\t// The install command may return before the extension is activated — wait for onDidChange.","+\t\tconst store = new DisposableStore();","+\t\ttry {","+\t\t\tconst onDidChange: Event<void> = listener => vscode.extensions.onDidChange(listener);","+\t\t\tconst ready = Event.toPromise(Event.onceIf(onDidChange, () => this.isAvailable), store);","+\t\t\t// Re-check after registering the listener: the extension may have become available","+\t\t\t// between the pre-check above and the listener hookup, in which case onDidChange","+\t\t\t// will never fire again and we would otherwise hang until the timeout.","+\t\t\tif (this.isAvailable) {","+\t\t\t\treturn true;","+\t\t\t}","+\t\t\tconst timeoutMs = this._configurationService.getConfig(ConfigKey.ClaudeAgentSdkExtensionInstallTimeout);","+\t\t\tawait raceCancellation(raceTimeout(ready, timeoutMs), token);","+\t\t\treturn this.isAvailable;","+\t\t} finally {","+\t\t\tstore.dispose();","+\t\t}","+\t}","+","+\tload(): Promise<typeof AgentSdk> {","+\t\tif (!this._sdk) {","+\t\t\tconst attempt = this._doLoad();","+\t\t\t// Only cache on success — reset on failure so the next call retries.","+\t\t\tthis._sdk = attempt.then(","+\t\t\t\tsdk => { this._sdk = Promise.resolve(sdk); return sdk; },","+\t\t\t\terr => { this._sdk = undefined; throw err; }","+\t\t\t);","+\t\t}","+\t\treturn this._sdk;","+\t}","+","+\tprivate async _doLoad(): Promise<typeof AgentSdk> {","+\t\tconst ext = vscode.extensions.getExtension<SDKActivation>(CLAUDE_SDK_EXTENSION_ID);","+\t\tif (!ext) {","+\t\t\tthrow new SdkExtensionNotInstalledError();","+\t\t}","+\t\tconst result = await ext.activate();","+\t\tif (result.error) {","+\t\t\tthrow result.error;","+\t\t}","+\t\treturn result.sdk!;","+\t}","+}"],"additions":99,"deletions":0,"truncated":false},{"path":"extensions/copilot/src/extension/chatSessions/claude/vscode-node/routingClaudeAgentSdkLoaderService.ts","lines":["@@ -0,0 +1,47 @@","+/*---------------------------------------------------------------------------------------------","+ *  Copyright (c) Microsoft Corporation. All rights reserved.","+ *  Licensed under the MIT License. See License.txt in the project root for license information.","+ *--------------------------------------------------------------------------------------------*/","+","+import type * as AgentSdk from '@anthropic-ai/claude-agent-sdk';","+import type * as vscode from 'vscode';","+import { ConfigKey, IConfigurationService } from '../../../../platform/configuration/common/configurationService';","+import { IExperimentationService } from '../../../../platform/telemetry/common/nullExperimentationService';","+import { IInstantiationService } from '../../../../util/vs/platform/instantiation/common/instantiation';","+import { IClaudeAgentSdkLoaderService } from '../common/claudeAgentSdkLoaderService';","+import { BundledClaudeAgentSdkLoaderService } from '../node/bundledClaudeAgentSdkLoaderService';","+import { VsCodeClaudeAgentSdkLoaderService } from './claudeAgentSdkLoaderService';","+","+/**","+ * Routes SDK loading to either the bundled SDK or the ms-vscode.vscode-claude-sdk","+ * extension, based on the `chat.claudeAgent.useSdkExtension` setting. The choice","+ * is captured once at construction; flipping the setting takes effect on reload.","+ */","+export class RoutingClaudeAgentSdkLoaderService implements IClaudeAgentSdkLoaderService {","+\treadonly _serviceBrand: undefined;","+","+\treadonly inner: IClaudeAgentSdkLoaderService;","+","+\tconstructor(","+\t\t@IConfigurationService configurationService: IConfigurationService,","+\t\t@IExperimentationService experimentationService: IExperimentationService,","+\t\t@IInstantiationService instantiationService: IInstantiationService,","+\t) {","+\t\tconst useExtension = configurationService.getExperimentBasedConfig(ConfigKey.ClaudeAgentUseSdkExtension, experimentationService);","+\t\tthis.inner = useExtension","+\t\t\t? instantiationService.createInstance(VsCodeClaudeAgentSdkLoaderService)","+\t\t\t: instantiationService.createInstance(BundledClaudeAgentSdkLoaderService);","+\t}","+","+\tget isAvailable(): boolean {","+\t\treturn this.inner.isAvailable;","+\t}","+","+\tinstall(token: vscode.CancellationToken): Promise<boolean> {","+\t\treturn this.inner.install(token);","+\t}","+","+\tload(): Promise<typeof AgentSdk> {","+\t\treturn this.inner.load();","+\t}","+}"],"additions":47,"deletions":0,"truncated":false},{"path":"extensions/copilot/src/extension/chatSessions/claude/vscode-node/test/claudeAgentSdkLoaderService.spec.ts","lines":["@@ -0,0 +1,196 @@","+/*---------------------------------------------------------------------------------------------","+ *  Copyright (c) Microsoft Corporation. All rights reserved.","+ *  Licensed under the MIT License. See License.txt in the project root for license information.","+ *--------------------------------------------------------------------------------------------*/","+","+import { beforeEach, describe, expect, it, vi } from 'vitest';","+","+const { mockState } = vi.hoisted(() => ({","+\tmockState: {","+\t\textension: null as { id: string } | null,","+\t\tgetExtensionImpl: null as (() => { id: string } | undefined) | null,","+\t\texecuteCommand: vi.fn<(command: string, ...args: unknown[]) => Promise<unknown>>().mockResolvedValue(undefined),","+\t\tchangeListeners: [] as Array<() => void>,","+\t},","+}));","+","+vi.mock('vscode', async (importOriginal) => {","+\tconst actual = await importOriginal() as Record<string, unknown>;","+\treturn {","+\t\t...actual,","+\t\tcommands: {","+\t\t\texecuteCommand: (command: string, ...args: unknown[]) => mockState.executeCommand(command, ...args),","+\t\t},","+\t\textensions: {","+\t\t\tgetExtension: (_id: string) => mockState.getExtensionImpl ? mockState.getExtensionImpl() : (mockState.extension ?? undefined),","+\t\t\tonDidChange: (listener: () => void) => {","+\t\t\t\tmockState.changeListeners.push(listener);","+\t\t\t\treturn { dispose: () => { const i = mockState.changeListeners.indexOf(listener); if (i >= 0) { mockState.changeListeners.splice(i, 1); } } };","+\t\t\t},","+\t\t},","+\t};","+});","+","+import { ConfigKey, IConfigurationService } from '../../../../../platform/configuration/common/configurationService';","+import { DefaultsOnlyConfigurationService } from '../../../../../platform/configuration/common/defaultsOnlyConfigurationService';","+import { InMemoryConfigurationService } from '../../../../../platform/configuration/test/common/inMemoryConfigurationService';","+import { ILogService, LogServiceImpl } from '../../../../../platform/log/common/logService';","+import { CancellationTokenSource } from '../../../../../util/vs/base/common/cancellation';","+import { CLAUDE_SDK_EXTENSION_ID } from '../../common/claudeAgentSdkLoaderService';","+import { VsCodeClaudeAgentSdkLoaderService } from '../claudeAgentSdkLoaderService';","+","+function fireOnDidChange(): void {","+\tfor (const listener of mockState.changeListeners.slice()) {","+\t\tlistener();","+\t}","+}","+","+async function waitForListener(): Promise<void> {","+\tfor (let i = 0; i < 50; i++) {","+\t\tif (mockState.changeListeners.length > 0) { return; }","+\t\tawait new Promise(resolve => setTimeout(resolve, 0));","+\t}","+\tthrow new Error('listener was never registered');","+}","+","+describe('VsCodeClaudeAgentSdkLoaderService', () => {","+\tlet configurationService: InMemoryConfigurationService;","+\tlet loader: VsCodeClaudeAgentSdkLoaderService;","+","+\tbeforeEach(async () => {","+\t\tmockState.extension = null;","+\t\tmockState.getExtensionImpl = null;","+\t\tmockState.executeCommand.mockReset().mockResolvedValue(undefined);","+\t\tmockState.changeListeners.length = 0;","+","+\t\tconfigurationService = new InMemoryConfigurationService(new DefaultsOnlyConfigurationService());","+\t\tawait configurationService.setConfig(ConfigKey.ClaudeAgentSdkExtensionInstallTimeout, 50);","+","+\t\tloader = new VsCodeClaudeAgentSdkLoaderService(configurationService as IConfigurationService, new LogServiceImpl([]) as ILogService);","+\t});","+","+\tdescribe('isAvailable', () => {","+\t\tit('returns false when the SDK extension is not installed', () => {","+\t\t\texpect(loader.isAvailable).toBe(false);","+\t\t});","+","+\t\tit('returns true when the SDK extension is present', () => {","+\t\t\tmockState.extension = { id: CLAUDE_SDK_EXTENSION_ID };","+\t\t\texpect(loader.isAvailable).toBe(true);","+\t\t});","+\t});","+","+\tdescribe('install', () => {","+\t\tit('returns true immediately when the extension is already available after the install command', async () => {","+\t\t\tmockState.executeCommand.mockImplementation(async () => {","+\t\t\t\tmockState.extension = { id: CLAUDE_SDK_EXTENSION_ID };","+\t\t\t});","+","+\t\t\tconst cts = new CancellationTokenSource();","+\t\t\tconst result = await loader.install(cts.token);","+","+\t\t\texpect(result).toBe(true);","+\t\t\texpect(mockState.executeCommand).toHaveBeenCalledWith('workbench.extensions.installExtension', CLAUDE_SDK_EXTENSION_ID);","+\t\t});","+","+\t\tit('resolves true when onDidChange fires with the extension present', async () => {","+\t\t\tconst cts = new CancellationTokenSource();","+\t\t\tconst installPromise = loader.install(cts.token);","+","+\t\t\tawait waitForListener();","+\t\t\tmockState.extension = { id: CLAUDE_SDK_EXTENSION_ID };","+\t\t\tfireOnDidChange();","+","+\t\t\texpect(await installPromise).toBe(true);","+\t\t\texpect(mockState.changeListeners).toHaveLength(0);","+\t\t});","+","+\t\tit('ignores onDidChange events while the extension is still missing', async () => {","+\t\t\tconst cts = new CancellationTokenSource();","+\t\t\tconst installPromise = loader.install(cts.token);","+","+\t\t\tawait waitForListener();","+\t\t\tfireOnDidChange();","+\t\t\tfireOnDidChange();","+","+\t\t\tconst result = await installPromise;","+\t\t\texpect(result).toBe(false);","+\t\t\texpect(mockState.changeListeners).toHaveLength(0);","+\t\t});","+","+\t\tit('returns false when the configured timeout elapses before the extension appears', async () => {","+\t\t\tconst cts = new CancellationTokenSource();","+\t\t\tconst result = await loader.install(cts.token);","+","+\t\t\texpect(result).toBe(false);","+\t\t\texpect(mockState.changeListeners).toHaveLength(0);","+\t\t});","+","+\t\tit('uses the configured timeout from ClaudeAgentSdkExtensionInstallTimeout', async () => {","+\t\t\tawait configurationService.setConfig(ConfigKey.ClaudeAgentSdkExtensionInstallTimeout, 10);","+\t\t\tconst cts = new CancellationTokenSource();","+\t\t\tconst start = Date.now();","+\t\t\tconst result = await loader.install(cts.token);","+","+\t\t\texpect(result).toBe(false);","+\t\t\texpect(Date.now() - start).toBeLessThan(2000);","+\t\t});","+","+\t\tit('returns false and stops waiting when the cancellation token fires', async () => {","+\t\t\tawait configurationService.setConfig(ConfigKey.ClaudeAgentSdkExtensionInstallTimeout, 60_000);","+\t\t\tconst cts = new CancellationTokenSource();","+\t\t\tconst installPromise = loader.install(cts.token);","+","+\t\t\tawait waitForListener();","+\t\t\tcts.cancel();","+","+\t\t\tconst result = await installPromise;","+\t\t\texpect(result).toBe(false);","+\t\t\texpect(mockState.changeListeners).toHaveLength(0);","+\t\t});","+","+\t\tit('swallows errors from the install command and still waits for the extension', async () => {","+\t\t\tmockState.executeCommand.mockRejectedValue(new Error('install failed'));","+\t\t\tconst cts = new CancellationTokenSource();","+\t\t\tconst installPromise = loader.install(cts.token);","+","+\t\t\tawait waitForListener();","+\t\t\tmockState.extension = { id: CLAUDE_SDK_EXTENSION_ID };","+\t\t\tfireOnDidChange();","+","+\t\t\texpect(await installPromise).toBe(true);","+\t\t});","+","+\t\tit('returns false without invoking the install command when the token is already cancelled', async () => {","+\t\t\tconst cts = new CancellationTokenSource();","+\t\t\tcts.cancel();","+","+\t\t\tconst result = await loader.install(cts.token);","+","+\t\t\texpect(result).toBe(false);","+\t\t\texpect(mockState.executeCommand).not.toHaveBeenCalled();","+\t\t\texpect(mockState.changeListeners).toHaveLength(0);","+\t\t});","+","+\t\tit('returns true without waiting when the extension becomes available between the pre-check and listener registration', async () => {","+\t\t\tawait configurationService.setConfig(ConfigKey.ClaudeAgentSdkExtensionInstallTimeout, 60_000);","+\t\t\t// First isAvailable check (line 46) sees no extension. By the time the","+\t\t\t// listener is hooked up and the post-registration re-check runs, the","+\t\t\t// extension has appeared — but no onDidChange event will fire to wake","+\t\t\t// the waiter. The post-registration re-check must catch it.","+\t\t\tlet lookupCount = 0;","+\t\t\tmockState.getExtensionImpl = () => {","+\t\t\t\tlookupCount++;","+\t\t\t\treturn lookupCount <= 1 ? undefined : { id: CLAUDE_SDK_EXTENSION_ID };","+\t\t\t};","+","+\t\t\tconst cts = new CancellationTokenSource();","+\t\t\tconst start = Date.now();","+\t\t\tconst result = await loader.install(cts.token);","+","+\t\t\texpect(result).toBe(true);","+\t\t\texpect(Date.now() - start).toBeLessThan(2000);","+\t\t\texpect(mockState.changeListeners).toHaveLength(0);","+\t\t});","+\t});","+});"],"additions":196,"deletions":0,"truncated":false},{"path":"extensions/copilot/src/extension/chatSessions/claude/vscode-node/test/routingClaudeAgentSdkLoaderService.spec.ts","lines":["@@ -0,0 +1,56 @@","+/*---------------------------------------------------------------------------------------------","+ *  Copyright (c) Microsoft Corporation. All rights reserved.","+ *  Licensed under the MIT License. See License.txt in the project root for license information.","+ *--------------------------------------------------------------------------------------------*/"],"additions":4,"deletions":0,"truncated":false}],"additions":467,"deletions":10,"truncated":true,"file_count":17},"error":null,"fetched_at":"2026-06-01T13:15:19.938399+00:00"}