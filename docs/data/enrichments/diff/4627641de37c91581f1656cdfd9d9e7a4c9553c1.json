 options pattern for the factory."," \tClient *http.Client","+","+\t// replayCache is the process-wide webhook replay cache. It lives on","+\t// the factory so a single instance is shared across every per-request","+\t// githubWebhookRepository the factory ultimately produces.","+\treplayCache *replayCache"," }"," "," func ProvideFactory() *Factory {","-\treturn &Factory{}","+\treturn &Factory{","+\t\treplayCache: newReplayCache(defaultReplayCacheTTL),","+\t}"," }"," "," func (r *Factory) New(ctx context.Context, ghToken common.RawSecureValue) Client {"],"additions":8,"deletions":1,"truncated":false},{"path":"apps/provisioning/pkg/repository/github/webhook.go","lines":["@@ -41,6 +41,7 @@ type githubWebhookRepository struct {"," \tgh                Client"," \twebhookURL        string"," \tincrementalPolicy repository.IncrementalSyncPolicy","+\treplayCache       *replayCache"," }"," "," func NewGithubWebhookRepository(","@@ -48,7 +49,13 @@ func NewGithubWebhookRepository("," \twebhookURL string,"," \tsecret common.RawSecureValue,"," \tincrementalPolicy repository.IncrementalSyncPolicy,","+\treplay *replayCache,"," ) GithubWebhookRepository {","+\t// Defensive: callers should pass the factory-owned cache, but never leave","+\t// Webhook with a nil cache to dereference.","+\tif replay == nil {","+\t\treplay = newReplayCache(defaultReplayCacheTTL)","+\t}"," \treturn &githubWebhookRepository{"," \t\tGithubRepository:  basic,"," \t\tconfig:            basic.Config(),","@@ -58,6 +65,7 @@ func NewGithubWebhookRepository("," \t\twebhookURL:        webhookURL,"," \t\tsecret:            secret,"," \t\tincrementalPolicy: incrementalPolicy,","+\t\treplayCache:       replay,"," \t}"," }"," ","@@ -76,6 +84,27 @@ func (r *githubWebhookRepository) Webhook(ctx context.Context, req *http.Request"," \t\treturn nil, apierrors.NewUnauthorized(\"invalid signature\")"," \t}"," ","+\t// Replay protection: key on the validated signature, not the","+\t// X-GitHub-Delivery header. GitHub computes the HMAC over the request body","+\t// only, so the delivery ID is unauthenticated — an attacker replaying a","+\t// captured (body, signature) could simply pick a fresh delivery ID and","+\t// slip past a delivery-ID cache. The signature, by contrast, is bound to","+\t// both the signed body and the repository's unique secret, so it cannot be","+\t// forged or collided across repositories.","+\t//","+\t// Silently drop a request whose signature we have already processed within","+\t// the cache TTL — returning a generic 200 avoids confirming to a replay","+\t// attacker that the captured payload was a real previously-processed","+\t// delivery.","+\tsignature := req.Header.Get(github.SHA256SignatureHeader)","+\tif signature == \"\" {","+\t\tsignature = req.Header.Get(github.SHA1SignatureHeader)","+\t}","+\tif r.replayCache.seenOrAdd(signature) {","+\t\tlogging.FromContext(ctx).Debug(\"dropping replayed webhook delivery\", \"delivery_id\", github.DeliveryID(req))","+\t\treturn &provisioning.WebhookResponse{Code: http.StatusOK, Message: \"ok\"}, nil","+\t}","+"," \treturn r.parseWebhook(ctx, github.WebHookType(req), payload)"," }"," "],"additions":29,"deletions":0,"truncated":false},{"path":"apps/provisioning/pkg/repository/github/webhook_replay.go","lines":["@@ -0,0 +1,58 @@","+package github","+","+import (","+\t\"sync\"","+\t\"time\"","+","+\t\"github.com/hashicorp/golang-lru/v2/expirable\"","+)","+","+// defaultReplayCacheTTL is the lifetime of a recorded webhook replay key. It","+// must comfortably exceed GitHub's webhook retry window so that a replayed","+// request is still considered a duplicate.","+const defaultReplayCacheTTL = time.Hour","+","+// maxReplayCacheEntries bounds the cache memory footprint. Provisioning webhook","+// volume per instance is low, so an attacker would need an implausible burst to","+// evict a still-live entry within the TTL — and the worst case of an","+// evicted-then-replayed delivery is a single idempotent sync job.","+const maxReplayCacheEntries = 10000","+","+// replayCache tracks recently-seen webhook replay keys so the webhook handler","+// can reject replayed requests. The key is the validated HMAC signature","+// (X-Hub-Signature-256), which binds the entry to the signed request body and","+// the repository's unique secret — see Webhook for why the unauthenticated","+// X-GitHub-Delivery header is not used as the key.","+type replayCache struct {","+\t// expirable.LRU is internally locked, but seenOrAdd's Get-then-Add is two","+\t// calls; this mutex makes the check-and-set atomic so concurrent identical","+\t// requests register exactly one as new.","+\tmu  sync.Mutex","+\tlru *expirable.LRU[string, struct{}]","+}","+","+func newReplayCache(ttl time.Duration) *replayCache {","+\treturn &replayCache{","+\t\tlru: expirable.NewLRU[string, struct{}](maxReplayCacheEntries, nil, ttl),","+\t}","+}","+","+// seenOrAdd returns true if key has been recorded within the TTL window.","+// Otherwise it records key and returns false. An empty key is never considered","+// a duplicate so callers can decide how to handle missing values.","+func (c *replayCache) seenOrAdd(key string) bool {","+\tif key == \"\" {","+\t\treturn false","+\t}","+","+\tc.mu.Lock()","+\tdefer c.mu.Unlock()","+","+\t// Get honors per-entry expiry on read; Contains only checks map membership","+\t// and would report an expired-but-unswept entry as still present.","+\tif _, ok := c.lru.Get(key); ok {","+\t\treturn true","+\t}","+\tc.lru.Add(key, struct{}{})","+\treturn false","+}"],"additions":58,"deletions":0,"truncated":false},{"path":"apps/provisioning/pkg/repository/github/webhook_replay_test.go","lines":["@@ -0,0 +1,60 @@","+package github","+","+import (","+\t\"sync\"","+\t\"testing\"","+\t\"time\"","+","+\t\"github.com/stretchr/testify/require\"","+)","+","+func TestReplayCache(t *testing.T) {","+\tt.Run(\"first add returns false, duplicate returns true\", func(t *testing.T) {","+\t\tc := newReplayCache(time.Hour)","+\t\trequire.False(t, c.seenOrAdd(\"abc\"))","+\t\trequire.True(t, c.seenOrAdd(\"abc\"))","+\t})","+","+\tt.Run(\"empty key is never considered seen\", func(t *testing.T) {","+\t\tc := newReplayCache(time.Hour)","+\t\trequire.False(t, c.seenOrAdd(\"\"))","+\t\trequire.False(t, c.seenOrAdd(\"\"))","+\t})","+","+\tt.Run(\"entries expire after ttl\", func(t *testing.T) {","+\t\tconst ttl = 50 * time.Millisecond","+\t\tc := newReplayCache(ttl)","+","+\t\trequire.False(t, c.seenOrAdd(\"abc\"))","+\t\trequire.True(t, c.seenOrAdd(\"abc\"))","+","+\t\t// Get honors expiry on read, so sleeping past the TTL makes the entry","+\t\t// look absent without depending on the background sweeper.","+\t\ttime.Sleep(ttl + 20*time.Millisecond)","+\t\trequire.False(t, c.seenOrAdd(\"abc\"))","+\t})","+","+\tt.Run(\"concurrent adds of the same key register exactly one as new\", func(t *testing.T) {","+\t\tc := newReplayCache(time.Hour)","+","+\t\tconst goroutines = 64","+\t\tvar wg sync.WaitGroup","+\t\twg.Add(goroutines)","+","+\t\tvar newCount int64","+\t\tvar mu sync.Mutex","+\t\tfor i := 0; i < goroutines; i++ {","+\t\t\tgo func() {","+\t\t\t\tdefer wg.Done()","+\t\t\t\tif !c.seenOrAdd(\"same\") {","+\t\t\t\t\tmu.Lock()","+\t\t\t\t\tnewCount++","+\t\t\t\t\tmu.Unlock()","+\t\t\t\t}","+\t\t\t}()","+\t\t}","+\t\twg.Wait()","+","+\t\trequire.Equal(t, int64(1), newCount)","+\t})","+}"],"additions":60,"deletions":0,"truncated":false},{"path":"apps/provisioning/pkg/repository/github/webhook_test.go","lines":["@@ -13,6 +13,7 @@ import ("," \t\"slices\""," \t\"strings\""," \t\"testing\"","+\t\"time\""," "," \t\"github.com/google/uuid\""," \t\"github.com/stretchr/testify/mock\"","@@ -176,6 +177,183 @@ func TestParsePushEvent_LargeDiffForcesFullSync(t *testing.T) {"," \trequire.False(t, rsp.Job.Pull.Incremental, \"large diff should force full sync when above threshold\")"," }"," ","+func TestGitHubRepository_Webhook_ReplayProtection(t *testing.T) {","+\tpushPayload := `{","+\t\t\"ref\": \"refs/heads/main\",","+\t\t\"repository\": {","+\t\t\t\"full_name\": \"grafana/grafana\"","+\t\t}","+\t}`","+\t// A byte-different but still valid push payload — produces a different","+\t// HMAC signature, so it is a distinct (non-replayed) request.","+\totherPayload := `{","+\t\t\"ref\": \"refs/heads/main\",","+\t\t\"after\": \"deadbeef\",","+\t\t\"repository\": {","+\t\t\t\"full_name\": \"grafana/grafana\"","+\t\t}","+\t}`","+","+\tconst defaultSecret = \"webhook-secret\"","+","+\t// newSignedRequest signs payload with secret and sets the headers GitHub","+\t// sends. deliveryID populates X-GitHub-Delivery; it is intentionally","+\t// independent of the signature so tests can vary it freely.","+\tnewSignedRequest := func(payload, deliveryID, secret string) *http.Request {","+\t\treq, _ := http.NewRequest(\"POST\", \"/webhook\", strings.NewReader(payload))","+\t\treq.Header.Set(\"X-GitHub-Event\", \"push\")","+\t\treq.Header.Set(\"Content-Type\", \"application/json\")","+\t\tif deliveryID != \"\" {","+\t\t\treq.Header.Set(\"X-GitHub-Delivery\", deliveryID)","+\t\t}","+","+\t\tmac := hmac.New(sha256.New, []byte(secret))","+\t\tmac.Write([]byte(payload))","+\t\tsignature := hex.EncodeToString(mac.Sum(nil))","+\t\treq.Header.Set(\"X-Hub-Signature-256\", \"sha256=\"+signature)","+","+\t\treturn req","+\t}","+","+\tnewRepo := func(cache *replayCache, secret string) *githubWebhookRepository {","+\t\treturn &githubWebhookRepository{","+\t\t\tconfig: &provisioning.Repository{","+\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"test-repo\"},","+\t\t\t\tSpec: provisioning.RepositorySpec{","+\t\t\t\t\tGitHub: &provisioning.GitHubRepositoryConfig{Branch: \"main\"},","+\t\t\t\t\tSync:   provisioning.SyncOptions{Enabled: true},","+\t\t\t\t},","+\t\t\t\tStatus: provisioning.RepositoryStatus{","+\t\t\t\t\tWebhook: &provisioning.WebhookStatus{},","+\t\t\t\t},","+\t\t\t},","+\t\t\towner:       \"grafana\",","+\t\t\trepo:        \"grafana\",","+\t\t\tsecret:      common.RawSecureValue(secret),","+\t\t\treplayCache: cache,","+\t\t}","+\t}","+","+\tt.Run(\"first delivery is accepted\", func(t *testing.T) {","+\t\tgh := newRepo(newReplayCache(time.Hour), defaultSecret)","+","+\t\trsp, err := gh.Webhook(context.Background(), newSignedRequest(pushPayload, \"delivery-1\", defaultSecret))","+\t\trequire.NoError(t, err)","+\t\trequire.Equal(t, http.StatusAccepted, rsp.Code)","+\t})","+","+\tt.Run(\"replayed request is silently dropped\", func(t *testing.T) {","+\t\tgh := newRepo(newReplayCache(time.Hour), defaultSecret)","+","+\t\t// First delivery succeeds with the normal accepted-job response.","+\t\tfirst, err := gh.Webhook(context.Background(), newSignedRequest(pushPayload, \"delivery-dup\", defaultSecret))","+\t\trequire.NoError(t, err)","+\t\trequire.Equal(t, http.StatusAccepted, first.Code)","+","+\t\t// Replaying the same signed request returns a generic 200 OK — same","+\t\t// shape as other no-op paths so an attacker can't tell from the","+\t\t// response whether the payload was previously processed.","+\t\tdup, err := gh.Webhook(context.Background(), newSignedRequest(pushPayload, \"delivery-dup\", defaultSecret))","+\t\trequire.NoError(t, err)","+\t\trequire.Equal(t, http.StatusOK, dup.Code)","+\t\trequire.Equal(t, \"ok\", dup.Message)","+\t\trequire.Nil(t, dup.Job, \"replay must not enqueue a job\")","+\t})","+","+\tt.Run(\"replay with a fresh delivery id is still dropped\", func(t *testing.T) {","+\t\t// Regression: the X-GitHub-Delivery header is not covered by the HMAC,","+\t\t// so an attacker can replay a captured (body, signature) under a new","+\t\t// delivery ID. Keying on the signature must still catch it.","+\t\tgh := newRepo(newReplayCache(time.Hour), defaultSecret)","+","+\t\t_, err := gh.Webhook(context.Background(), newSignedRequest(pushPayload, \"delivery-A\", defaultSecret))","+\t\trequire.NoError(t, err)","+","+\t\tdup, err := gh.Webhook(context.Background(), newSignedRequest(pushPayload, \"delivery-B\", defaultSecret))","+\t\trequire.NoError(t, err)","+\t\trequire.Equal(t, http.StatusOK, dup.Code, \"same signed body under a different delivery id is still a replay\")","+\t\trequire.Nil(t, dup.Job)","+\t})","+","+\tt.Run(\"distinct payloads are independent\", func(t *testing.T) {","+\t\tgh := newRepo(newReplayCache(time.Hour), defaultSecret)","+","+\t\t_, err := gh.Webhook(context.Background(), newSignedRequest(pushPayload, \"delivery-A\", defaultSecret))","+\t\trequire.NoError(t, err)","+","+\t\t// A different body yields a different signature, so it is processed.","+\t\trsp, err := gh.Webhook(context.Background(), newSignedRequest(otherPayload, \"delivery-B\", defaultSecret))","+\t\trequire.NoError(t, err)","+\t\trequire.Equal(t, http.StatusAccepted, rsp.Code)","+\t})","+","+\tt.Run(\"identical body under different secrets does not collide\", func(t *testing.T) {","+\t\t// The shared cache is consulted by every repository. Two repos with","+\t\t// distinct webhook secrets produce distinct signatures for the same","+\t\t// body, so one repo's delivery must not shadow another's.","+\t\tcache := newReplayCache(time.Hour)","+\t\trepoA := newRepo(cache, \"secret-a\")","+\t\trepoB := newRepo(cache, \"secret-b\")","+","+\t\t_, err := repoA.Webhook(context.Background(), newSignedRequest(pushPayload, \"delivery-A\", \"secret-a\"))","+\t\trequire.NoError(t, err)","+","+\t\trsp, err := repoB.Webhook(context.Background(), newSignedRequest(pushPayload, \"delivery-B\", \"secret-b\"))","+\t\trequire.NoError(t, err)","+\t\trequire.Equal(t, http.StatusAccepted, rsp.Code)","+\t})","+","+\tt.Run(\"repositories sharing a cache silently drop cross-instance replays\", func(t *testing.T) {","+\t\t// Mirrors production: extras.Build rebuilds a repository per request","+\t\t// but threads the factory's single cache through each instance.","+\t\tcache := newReplayCache(time.Hour)","+\t\tfirst := newRepo(cache, defaultSecret)","+\t\tsecond := newRepo(cache, defaultSecret)","+","+\t\t_, err := first.Webhook(context.Background(), newSignedRequest(pushPayload, \"delivery-1\", defaultSecret))","+\t\trequire.NoError(t, err)","+","+\t\tdup, err := second.Webhook(context.Background(), newSignedRequest(pushPayload, \"delivery-2\", defaultSecret))","+\t\trequire.NoError(t, err)","+\t\trequire.Equal(t, http.StatusOK, dup.Code)","+\t\trequire.Equal(t, \"ok\", dup.Message)","+\t\trequire.Nil(t, dup.Job)","+\t})","+","+\tt.Run(\"expired entry is accepted again\", func(t *testing.T) {","+\t\tconst ttl = 50 * time.Millisecond","+\t\tgh := newRepo(newReplayCache(ttl), defaultSecret)","+","+\t\t_, err := gh.Webhook(context.Background(), newSignedRequest(pushPayload, \"delivery-X\", defaultSecret))","+\t\trequire.NoError(t, err)","+","+\t\t// Once the entry expires, the same signed request is processed again.","+\t\ttime.Sleep(ttl + 20*time.Millisecond)","+\t\trsp, err := gh.Webhook(context.Background(), newSignedRequest(pushPayload, \"delivery-X\", defaultSecret))","+\t\trequire.NoError(t, err)","+\t\trequire.Equal(t, http.StatusAccepted, rsp.Code)","+\t})","+","+\tt.Run(\"invalid signature is rejected before the replay check\", func(t *testing.T) {","+\t\tgh := newRepo(newReplayCache(time.Hour), defaultSecret)","+","+\t\treq, _ := http.NewRequest(\"POST\", \"/webhook\", strings.NewReader(pushPayload))","+\t\treq.Header.Set(\"X-GitHub-Event\", \"push\")","+\t\treq.Header.Set(\"Content-Type\", \"application/json\")","+\t\treq.Header.Set(\"X-GitHub-Delivery\", \"delivery-bad-sig\")","+\t\treq.Header.Set(\"X-Hub-Signature-256\", \"sha256=deadbeef\")","+","+\t\t_, err := gh.Webhook(context.Background(), req)","+\t\trequire.Error(t, err)","+","+\t\t// A subsequent valid request must still succeed — a failed signature","+\t\t// must not poison the replay cache.","+\t\trsp, err := gh.Webhook(context.Background(), newSignedRequest(pushPayload, \"delivery-good\", defaultSecret))","+\t\trequire.NoError(t, err)","+\t\trequire.Equal(t, http.StatusAccepted, rsp.Code)","+\t})","+}","+"," func TestGitHubRepository_Webhook(t *testing.T) {"," \ttests := []struct {"," \t\tname          string","@@ -932,12 +1110,14 @@ func TestGitHubRepository_Webhook(t *testing.T) {"," "," \tfor _, tt := range tests {"," \t\tt.Run(tt.name, func(t *testing.T) {","-\t\t\t// Create a GitHub repository with the test config","+\t\t\t// Create a GitHub repository with the test config. A fresh cache","+\t\t\t// per subtest keeps replay state from leaking across cases."," \t\t\trepo := &githubWebhookRepository{","-\t\t\t\tconfig: tt.config,","-\t\t\t\towner:  \"grafana\",","-\t\t\t\trepo:   \"grafana\",","-\t\t\t\tsecret: common.RawSecureValue(\"webhook-secret\"),","+\t\t\t\tconfig:      tt.config,","+\t\t\t\towner:       \"grafana\",","+\t\t\t\trepo:        \"grafana\",","+\t\t\t\tsecret:      common.RawSecureValue(\"webhook-secret\"),","+\t\t\t\treplayCache: newReplayCache(time.Hour),"," \t\t\t}"," "," \t\t\t// Call the Webhook method",""],"additions":185,"deletions":5,"truncated":false}],"additions":342,"deletions":8,"truncated":false,"file_count":7},"error":null,"fetched_at":"2026-05-30T09:34:57.478673+00:00"}