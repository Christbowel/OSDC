[121.5,25],[100.5,13.8],[101.7,3.1],[103.8,1.3],[106.8,-6.2],[120.9,14.6],[106.7,10.8],[105.8,21],[96.1,16.8],[104.9,11.5],
[151.2,-33.8],[145,-37.8],[153,-27.5],[115.8,-31.9],[174.8,-36.8],[172.6,-43.5]
];
function proj(lon,lat){return[(lon+180)/360*W,(90-lat)/180*H]}
var pts=cities.map(function(c){return proj(c[0],c[1])});
var n=pts.length;
var activeCount=14;
var active=[];
while(active.length<activeCount){var r=Math.floor(Math.random()*n);if(active.indexOf(r)<0)active.push(r)}
var rings=active.map(function(i){return{idx:i,r:0,maxR:35+Math.random()*15,speed:.35+Math.random()*.3,alpha:.7,phase:Math.random()*120}});
var conns=[];
for(var i=0;i<18;i++){
var a=active[Math.floor(Math.random()*active.length)];
var b=active[Math.floor(Math.random()*active.length)];
if(a!==b)conns.push({a:a,b:b,t:Math.random(),speed:.002+Math.random()*.003});
}
var frame=0;
function draw(){
W=canvas.width;H=canvas.height;
ctx.clearRect(0,0,W,H);
// Grid - more visible
ctx.strokeStyle='rgba(40,90,165,.55)';ctx.lineWidth=.6;
var gridX=W/16,gridY=H/8;
for(var x=0;x<W;x+=gridX){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke()}
for(var y=0;y<H;y+=gridY){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke()}
// City dots - bright and visible
pts.forEach(function(p){ctx.beginPath();ctx.arc(p[0],p[1],1.5,0,Math.PI*2);ctx.fillStyle='rgba(100,175,245,.82)';ctx.fill()});
conns.forEach(function(c){
var ap=pts[c.a],bp=pts[c.b];
var ex=ap[0]+(bp[0]-ap[0])*c.t,ey=ap[1]+(bp[1]-ap[1])*c.t;
ctx.beginPath();ctx.moveTo(ap[0],ap[1]);ctx.lineTo(ex,ey);
ctx.strokeStyle='rgba(5,216,240,.5)';ctx.lineWidth=.9;ctx.stroke();
ctx.beginPath();ctx.arc(ex,ey,2.2,0,Math.PI*2);ctx.fillStyle='rgba(5,216,240,.95)';ctx.fill();
c.t+=c.speed;if(c.t>1)c.t=0;
});
// Active nodes - use multiple colors like Shodan
var nodeColors=['#05d8f0','#f43f5e','#a78bfa','#fbbf24','#34d399','#fb923c'];
active.forEach(function(i,idx){
var p=pts[i];var nc=nodeColors[idx%nodeColors.length];
ctx.shadowBlur=16;ctx.shadowColor=nc;
ctx.beginPath();ctx.arc(p[0],p[1],3,0,Math.PI*2);ctx.fillStyle=nc;ctx.fill();
ctx.shadowBlur=0;
});
rings.forEach(function(ring){
if(frame<ring.phase)return;
var p=pts[ring.idx];var nc=nodeColors[active.indexOf(ring.idx)%nodeColors.length]||'#05d8f0';
var a=ring.alpha*(1-ring.r/ring.maxR);
ctx.beginPath();ctx.arc(p[0],p[1],ring.r,0,Math.PI*2);
ctx.strokeStyle=nc.replace(')',','+a+')').replace('rgb(','rgba(').replace('#','').replace(/^([0-9a-f]{6})(.*)$/,'rgba('+parseInt('$1'.substring(0,2),16)+','+parseInt('$1'.substring(2,4),16)+','+parseInt('$1'.substring(4,6),16)+','+a+')');
// simpler: just use with fixed opacity approach
ctx.strokeStyle='rgba(5,216,240,'+a+')';ctx.lineWidth=1.2;ctx.stroke();
ring.r+=ring.speed;
if(ring.r>ring.maxR){ring.r=0;ring.phase=0;ring.maxR=28+Math.random()*22;}
});
// Lighter vignette so map stays visible
var g=ctx.createRadialGradient(W*.15,H*.5,0,W*.5,H*.5,W*.7);
g.addColorStop(0,'rgba(7,16,30,0)');g.addColorStop(.5,'rgba(7,16,30,.05)');g.addColorStop(1,'rgba(7,16,30,.65)');
ctx.fillStyle=g;ctx.fillRect(0,0,W,H);
frame++;requestAnimationFrame(draw);
}
draw();
window.addEventListener('resize',function(){resize();W=canvas.width;H=canvas.height;pts=cities.map(function(c){return proj(c[0],c[1])})});
})();

function toggleCard(btn){var h=btn.closest('.card').querySelector('.hidden');if(h){h.classList.toggle('hidden');btn.textContent=h.classList.contains('hidden')?'Details':'Collapse'}}
(function(){
var cards=document.querySelectorAll('.card');
var si=document.getElementById('searchInput'),sf=document.getElementById('severityFilter'),lf=document.getElementById('languageFilter'),rc=document.getElementById('resultCount');
var patterns={},langs={},dates={},ecos={},sevs={CRITICAL:0,HIGH:0,MODERATE:0,LOW:0},langSet=new Set();
cards.forEach(function(c){
var p=c.dataset.pattern,l=c.dataset.language,d=c.dataset.date,s=c.dataset.severity;
patterns[p]=(patterns[p]||0)+1;langs[l]=(langs[l]||0)+1;dates[d]=(dates[d]||0)+1;
if(sevs[s]!==undefined)sevs[s]++;langSet.add(l);
var em=c.dataset.searchable.match(/npm|pypi|maven|go|crates|packagist|nuget|rubygems/i);
if(em)ecos[em[0].toLowerCase()]=(ecos[em[0].toLowerCase()]||0)+1;
});
document.getElementById('statLang').textContent=langSet.size;
document.getElementById('statCrit').textContent=sevs.CRITICAL;
Array.from(langSet).sort().forEach(function(l){var o=document.createElement('option');o.value=l;o.textContent=l;lf.appendChild(o)});
var gc='rgba(25,60,100,.5)',tc='#628aaf';
function makeBars(id,data,max){
var el=document.getElementById(id);
el.innerHTML=Object.entries(data).sort(function(a,b){return b[1]-a[1]}).slice(0,8).map(function(item,i){
return'<li class="bar-item" style="animation:fadeIn .4s ease '+(i*.05)+'s both"><span class="bar-label">'+item[0]+'</span><span class="bar-track"><span class="bar-fill" style="width:'+(Math.round(item[1]/max*100))+'%"></span></span><span class="bar-count">'+item[1]+'</span></li>';
}).join('');
}
makeBars('patternBars',patterns,Math.max.apply(null,Object.values(patterns).concat([1])));
makeBars('langBars',langs,Math.max.apply(null,Object.values(langs).concat([1])));
var sd=Object.keys(dates).sort(),dv=sd.map(function(d){return dates[d]});
Chart.defaults.font.family="'JetBrains Mono',monospace";Chart.defaults.font.size=10;
new Chart(document.getElementById('timelineChart').getContext('2d'),{type:'bar',data:{labels:sd,datasets:[{data:dv,backgroundColor:'rgba(5,216,240,.18)',borderColor:'rgba(5,216,240,.55)',borderWidth:1,borderRadius:3}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{ticks:{color:tc,maxRotation:45},grid:{color:gc}},y:{ticks:{color:tc,stepSize:1},grid:{color:gc}}}}});
var sc=['#f43f5e','#fb923c','#fbbf24','#34d399'];
new Chart(document.getElementById('severityChart').getContext('2d'),{type:'doughnut',data:{labels:Object.keys(sevs),datasets:[{data:Object.values(sevs),backgroundColor:sc,borderColor:'#07101e',borderWidth:2}]},options:{responsive:true,maintainAspectRatio:false,cutout:'68%',plugins:{legend:{position:'right',labels:{color:'#6a8daf',font:{size:10},padding:10,usePointStyle:true,pointStyle:'circle'}}}}});
var ec=['#05d8f0','#8b5cf6','#ec4899','#14b8a6','#f59e0b','#6366f1','#10b981'];
new Chart(document.getElementById('ecosystemChart').getContext('2d'),{type:'doughnut',data:{labels:Object.keys(ecos),datasets:[{data:Object.values(ecos),backgroundColor:ec.slice(0,Object.keys(ecos).length),borderColor:'#07101e',borderWidth:2}]},options:{responsive:true,maintainAspectRatio:false,cutout:'68%',plugins:{legend:{position:'right',labels:{color:'#6a8daf',font:{size:10},padding:10,usePointStyle:true,pointStyle:'circle'}}}}});
function filterCards(){var q=si.value.toLowerCase(),s=sf.value,l=lf.value,v=0;
cards.forEach(function(c){var ms=!q||c.dataset.searchable.toLowerCase().includes(q),mv=!s||c.dataset.severity===s,ml=!l||c.dataset.language===l,sh=ms&&mv&&ml;c.style.display=sh?'':'none';if(sh)v++});
rc.textContent=v+' / '+cards.length}
si.addEventListener('input',filterCards);sf.addEventListener('change',filterCards);lf.addEventListener('change',filterCards);filterCards();
document.querySelectorAll('.diff').forEach(function(b){var h=b.innerHTML;h=h.replace(/^(-.*)$/gm,'<span class="del">$1</span>');h=h.replace(/^(\+.*)$/gm,'<span class="add">$1</span>');b.innerHTML=h});
})();
</script>
</body>
</html>
