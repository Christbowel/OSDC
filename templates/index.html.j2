[-17.4,14.7],[36.8,3],[36.8,3],[-1.6,12.4],[2.4,6.4],[15.3,4.3],[28.9,-1.9],
[72.8,19],[77.2,28.6],[77.6,13],[88.4,22.6],[80.3,13.1],[67,24.9],[74.3,31.5],[90.4,23.7],[79.9,6.9],[85.3,27.7],
[116.4,39.9],[121.4,31.2],[113.2,23.1],[114.1,22.5],[104.1,30.6],[108.9,34.3],[126.6,45.8],[117.3,39.2],[106.6,29.6],
