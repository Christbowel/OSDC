<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OSDC · Open Source Daily Catch</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#0a0a0f;--card:#12121a;--card-hover:#1a1a25;--text:#e2e2e8;--muted:#8888a0;--accent:#6c8cff;--accent-dim:#3a4a7a;--border:#1e1e2e;--critical:#ff4757;--high:#ff8c42;--moderate:#ffd166;--low:#06d6a0;--code-bg:#1a1a28;--nav-bg:#0e0e16;--font:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;--mono:"SF Mono","Fira Code","Fira Mono",Menlo,monospace}
[data-theme="light"]{--bg:#f5f5f7;--card:#fff;--text:#1a1a2e;--muted:#6c757d;--accent:#3b5bdb;--accent-dim:#d0d7ff;--border:#dee2e6;--critical:#dc3545;--high:#e8590c;--moderate:#e67700;--low:#2b8a3e;--code-bg:#f1f3f5;--nav-bg:#fff}
body{font-family:var(--font);background:var(--bg);color:var(--text);line-height:1.6;-webkit-font-smoothing:antialiased;transition:background .2s,color .2s}
nav{background:var(--nav-bg);border-bottom:1px solid var(--border);padding:0 1.5rem;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.nav-left{display:flex;align-items:center;gap:0}
.nav-brand{font-family:var(--mono);font-size:.9rem;font-weight:600;color:var(--accent);padding:.75rem 1rem .75rem 0;text-decoration:none;border-right:1px solid var(--border);margin-right:0}
.nav-tab{padding:.75rem 1rem;font-size:.8rem;font-family:var(--mono);color:var(--muted);text-decoration:none;border-bottom:2px solid transparent;transition:color .2s,border .2s}
.nav-tab:hover{color:var(--text)}
.nav-tab.active{color:var(--accent);border-bottom-color:var(--accent)}
.theme-toggle{background:none;border:1px solid var(--border);border-radius:4px;padding:4px 8px;font-size:.75rem;font-family:var(--mono);color:var(--muted);cursor:pointer;transition:border-color .2s}
.theme-toggle:hover{border-color:var(--accent);color:var(--text)}
.container{max-width:1080px;margin:0 auto;padding:0 1.5rem}
header{padding:2rem 0;border-bottom:1px solid var(--border)}
header h1{font-size:1.25rem;font-weight:600;letter-spacing:-.02em;font-family:var(--mono)}
header h1 span{color:var(--accent)}
.header-meta{display:flex;gap:2rem;margin-top:.75rem;font-size:.8rem;color:var(--muted);font-family:var(--mono)}
.header-meta span::before{content:"›";margin-right:.5rem;color:var(--accent-dim)}
.dashboard{display:grid;grid-template-columns:1fr 1fr;gap:1rem;padding:1.5rem 0;border-bottom:1px solid var(--border)}
.dash-card{background:var(--card);border:1px solid var(--border);border-radius:6px;padding:1rem}
.dash-card h3{font-size:.7rem;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);font-family:var(--mono);margin-bottom:.75rem}
.dash-card.full{grid-column:1/-1}
.stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:.75rem}
.stat-box{text-align:center;padding:.5rem}
.stat-val{font-size:1.5rem;font-weight:700;font-family:var(--mono);color:var(--accent)}
.stat-label{font-size:.65rem;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);font-family:var(--mono);margin-top:.15rem}
.bar-list{list-style:none}
.bar-item{display:flex;align-items:center;gap:.5rem;margin-bottom:.5rem;font-size:.8rem;font-family:var(--mono)}
.bar-label{min-width:120px;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bar-track{flex:1;height:6px;background:var(--border);border-radius:3px;overflow:hidden}
.bar-fill{height:100%;border-radius:3px;background:var(--accent);transition:width .3s}
.bar-count{min-width:30px;text-align:right;color:var(--muted);font-size:.75rem}
.controls{padding:1.25rem 0;display:flex;gap:.75rem;flex-wrap:wrap;align-items:center}
.search{flex:1;min-width:200px;padding:.5rem .75rem;border:1px solid var(--border);border-radius:4px;font-size:.85rem;font-family:var(--mono);background:var(--card);color:var(--text);outline:none;transition:border .2s}
.search:focus{border-color:var(--accent)}
.search::placeholder{color:var(--muted)}
select{padding:.5rem;border:1px solid var(--border);border-radius:4px;font-size:.8rem;font-family:var(--mono);background:var(--card);color:var(--text);outline:none;cursor:pointer}
select option{background:var(--card);color:var(--text)}
.count{color:var(--muted);font-size:.75rem;font-family:var(--mono);margin-left:auto}
.card{background:var(--card);border:1px solid var(--border);border-radius:6px;margin-bottom:.75rem;overflow:hidden;transition:border-color .2s}
.card:hover{border-color:var(--accent-dim)}
.card-top{display:flex;justify-content:space-between;align-items:center;padding:.75rem 1rem;border-bottom:1px solid var(--border);flex-wrap:wrap;gap:.5rem}
.card-id{font-weight:600;color:var(--accent);text-decoration:none;font-size:.85rem;font-family:var(--mono)}
.card-id:hover{text-decoration:underline}
.sev{padding:2px 8px;border-radius:3px;font-size:.7rem;font-weight:700;font-family:var(--mono);text-transform:uppercase;letter-spacing:.03em}
.sev-critical{background:rgba(255,71,87,.15);color:var(--critical);border:1px solid rgba(255,71,87,.3)}
.sev-high{background:rgba(255,140,66,.12);color:var(--high);border:1px solid rgba(255,140,66,.25)}
.sev-moderate,.sev-medium{background:rgba(255,209,102,.1);color:var(--moderate);border:1px solid rgba(255,209,102,.2)}
.sev-low{background:rgba(6,214,160,.1);color:var(--low);border:1px solid rgba(6,214,160,.2)}
.pattern{font-family:var(--mono);font-size:.75rem;color:var(--accent);background:rgba(108,140,255,.08);padding:2px 8px;border-radius:3px;border:1px solid rgba(108,140,255,.15)}
.lang{font-family:var(--mono);font-size:.7rem;color:var(--muted);padding:2px 6px;border:1px solid var(--border);border-radius:3px}
.card-body{padding:1rem}
.field{margin-bottom:.75rem}
.field-label{font-size:.65rem;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);margin-bottom:.25rem;font-family:var(--mono)}
.field-value{font-size:.85rem;color:var(--text);line-height:1.5}
.diff-block{background:var(--code-bg);border:1px solid var(--border);border-radius:4px;padding:.75rem;margin-top:.25rem;font-family:var(--mono);font-size:.78rem;line-height:1.6;overflow-x:auto;white-space:pre-wrap;word-break:break-all}
.diff-block .del{color:#ff6b7a;opacity:.9}
.diff-block .add{color:#69db7c;opacity:.9}
.card-footer{display:flex;gap:1rem;padding:.5rem 1rem;border-top:1px solid var(--border);font-size:.75rem;font-family:var(--mono)}
.card-footer a{color:var(--accent);text-decoration:none}
.card-footer a:hover{text-decoration:underline}
.card-footer span{color:var(--muted)}
.toggle-detail{cursor:pointer;color:var(--accent);font-size:.75rem;font-family:var(--mono);background:none;border:none;padding:0}
.toggle-detail:hover{text-decoration:underline}
.detail-hidden{display:none}
.chart-wrap{position:relative;height:200px}
footer{text-align:center;padding:2rem 0;color:var(--muted);font-size:.75rem;font-family:var(--mono);border-top:1px solid var(--border)}
footer a{color:var(--accent)}
@media(max-width:700px){.dashboard{grid-template-columns:1fr}.stat-grid{grid-template-columns:repeat(2,1fr)}.controls{flex-direction:column}.card-top{flex-direction:column;align-items:flex-start}}
</style>
</head>
<body>
<nav>
<div class="nav-left">
<a class="nav-brand" href="./">OSDC</a>
<a class="nav-tab active" href="./">advisories</a>
<a class="nav-tab" href="./silent.html">silent patches</a>
</div>
<button class="theme-toggle" onclick="toggleTheme()">light/dark</button>
</nav>
<div class="container">
<header>
<h1><span>OSDC</span> · Open Source Daily Catch</h1>
<div class="header-meta">
<span>{{ stats.total_advisories }} advisories</span>
<span>{{ stats.total_patterns }} patterns</span>
<span>{{ today }}</span>
</div>
</header>
<div class="dashboard">
<div class="dash-card" style="grid-column:1/-1">
<h3>overview</h3>
<div class="stat-grid">
<div class="stat-box"><div class="stat-val">{{ stats.total_advisories }}</div><div class="stat-label">advisories</div></div>
<div class="stat-box"><div class="stat-val">{{ stats.total_patterns }}</div><div class="stat-label">patterns</div></div>
<div class="stat-box"><div class="stat-val" id="langCount">0</div><div class="stat-label">languages</div></div>
<div class="stat-box"><div class="stat-val" id="critCount">0</div><div class="stat-label">critical</div></div>
</div>
</div>
<div class="dash-card">
<h3>top recurring patterns</h3>
<ul class="bar-list" id="patternBars"></ul>
</div>
<div class="dash-card">
<h3>language breakdown</h3>
<ul class="bar-list" id="langBars"></ul>
</div>
<div class="dash-card full">
<h3>advisory volume by date</h3>
<div class="chart-wrap"><canvas id="timelineChart"></canvas></div>
</div>
<div class="dash-card full">
<h3>severity distribution</h3>
<div class="chart-wrap"><canvas id="severityChart"></canvas></div>
</div>
</div>
<div class="controls">
<input type="text" class="search" id="searchInput" placeholder="search advisories, patterns, packages...">
<select id="severityFilter">
<option value="">all severities</option>
<option value="CRITICAL">critical</option>
<option value="HIGH">high</option>
<option value="MODERATE">moderate</option>
<option value="LOW">low</option>
</select>
<select id="languageFilter">
<option value="">all languages</option>
</select>
<span class="count" id="resultCount"></span>
</div>
<div id="advisoryList">
{% for adv in advisories %}
<div class="card" data-severity="{{ adv.severity }}" data-language="{{ adv.language }}" data-date="{{ adv.date }}" data-pattern="{{ adv.pattern_id }}" data-searchable="{{ adv.id }} {{ adv.repo }} {{ adv.package_name }} {{ adv.pattern_id }} {{ adv.vuln_type }} {{ adv.language }} {{ adv.root_cause | e }}">
<div class="card-top">
<div style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap">
<a class="card-id" href="https://github.com/advisories/{{ adv.id }}" target="_blank" rel="noopener">{{ adv.id }}</a>
<span class="sev sev-{{ adv.severity | lower }}">{{ adv.severity }} {{ adv.cvss_score }}</span>
<span class="pattern">{{ adv.pattern_id }}</span>
<span class="lang">{{ adv.language }}</span>
</div>
<button class="toggle-detail" onclick="toggleCard(this)">expand</button>
</div>
<div class="card-body">
<div class="field">
<div class="field-label">package</div>
<div class="field-value" style="font-family:var(--mono)">{{ adv.package_name }} · {{ adv.repo }}</div>
</div>
<div class="field">
<div class="field-label">root cause</div>
<div class="field-value">{{ adv.root_cause | e }}</div>
</div>
<div class="detail-hidden">
<div class="field">
<div class="field-label">impact</div>
<div class="field-value">{{ adv.impact | e }}</div>
</div>
{% if adv.key_diff %}
<div class="field">
<div class="field-label">key diff</div>
<div class="diff-block">{{ adv.key_diff | e }}</div>
</div>
{% endif %}
<div class="field">
<div class="field-label">fix</div>
<div class="field-value">{{ adv.fix_summary | e }}</div>
</div>
</div>
</div>
<div class="card-footer">
<span>{{ adv.date }}</span>
<span>{{ adv.vuln_type }}</span>
<a href="{{ adv.commit_url }}" target="_blank" rel="noopener">view commit</a>
<a href="https://github.com/advisories/{{ adv.id }}" target="_blank" rel="noopener">advisory</a>
</div>
</div>
{% endfor %}
</div>
</div>
<footer>
<p><a href="https://christbowel.com">christbowel</a> · <a href="https://github.com/christbowel/osdc">source</a></p>
</footer>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
function toggleCard(btn){var h=btn.closest('.card').querySelector('.detail-hidden');if(h){h.classList.toggle('detail-hidden');btn.textContent=h.classList.contains('detail-hidden')?'expand':'collapse'}}
function toggleTheme(){var t=document.documentElement.getAttribute('data-theme');document.documentElement.setAttribute('data-theme',t==='light'?'':'light');localStorage.setItem('osdc-theme',t==='light'?'dark':'light')}
(function(){
var saved=localStorage.getItem('osdc-theme');
if(saved==='light')document.documentElement.setAttribute('data-theme','light');
var cards=document.querySelectorAll('.card');
var si=document.getElementById('searchInput');
var sf=document.getElementById('severityFilter');
var lf=document.getElementById('languageFilter');
var rc=document.getElementById('resultCount');
var patterns={},langs={},dates={},sevs={CRITICAL:0,HIGH:0,MODERATE:0,LOW:0};
var langSet=new Set();
cards.forEach(function(c){var p=c.dataset.pattern;var l=c.dataset.language;var d=c.dataset.date;var s=c.dataset.severity;patterns[p]=(patterns[p]||0)+1;langs[l]=(langs[l]||0)+1;dates[d]=(dates[d]||0)+1;if(sevs[s]!==undefined)sevs[s]++;langSet.add(l)});
document.getElementById('langCount').textContent=langSet.size;
document.getElementById('critCount').textContent=sevs.CRITICAL;
Array.from(langSet).sort().forEach(function(l){var o=document.createElement('option');o.value=l;o.textContent=l.toLowerCase();lf.appendChild(o)});
function makeBars(id,data,max){var el=document.getElementById(id);var sorted=Object.entries(data).sort(function(a,b){return b[1]-a[1]}).slice(0,8);var html='';sorted.forEach(function(item){var pct=Math.round(item[1]/max*100);html+='<li class="bar-item"><span class="bar-label">'+item[0]+'</span><span class="bar-track"><span class="bar-fill" style="width:'+pct+'%"></span></span><span class="bar-count">'+item[1]+'</span></li>'});el.innerHTML=html}
var maxP=Math.max.apply(null,Object.values(patterns));
var maxL=Math.max.apply(null,Object.values(langs));
makeBars('patternBars',patterns,maxP);
makeBars('langBars',langs,maxL);
var sortedDates=Object.keys(dates).sort();
var dateVals=sortedDates.map(function(d){return dates[d]});
var isDark=!document.documentElement.getAttribute('data-theme');
var gridColor=isDark?'#1e1e2e':'#dee2e6';
var tickColor=isDark?'#8888a0':'#6c757d';
var ctx1=document.getElementById('timelineChart').getContext('2d');
new Chart(ctx1,{type:'bar',data:{labels:sortedDates,datasets:[{data:dateVals,backgroundColor:'rgba(108,140,255,0.4)',borderColor:'rgba(108,140,255,0.8)',borderWidth:1,borderRadius:3}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{ticks:{color:tickColor,font:{family:'"SF Mono",monospace',size:10}},grid:{color:gridColor}},y:{ticks:{color:tickColor,font:{family:'"SF Mono",monospace',size:10},stepSize:1},grid:{color:gridColor}}}}});
var sevLabels=Object.keys(sevs);var sevVals=Object.values(sevs);var sevColors=['#ff4757','#ff8c42','#ffd166','#06d6a0'];
var ctx2=document.getElementById('severityChart').getContext('2d');
new Chart(ctx2,{type:'doughnut',data:{labels:sevLabels,datasets:[{data:sevVals,backgroundColor:sevColors,borderColor:isDark?'#12121a':'#fff',borderWidth:2}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'right',labels:{color:isDark?'#e2e2e8':'#1a1a2e',font:{family:'"SF Mono",monospace',size:11},padding:12,usePointStyle:true,pointStyle:'circle'}}}}});
function filterCards(){var q=si.value.toLowerCase(),s=sf.value,l=lf.value,v=0;cards.forEach(function(c){var ms=!q||c.dataset.searchable.toLowerCase().indexOf(q)!==-1;var mv=!s||c.dataset.severity===s;var ml=!l||c.dataset.language===l;var sh=ms&&mv&&ml;c.style.display=sh?'':'none';if(sh)v++});rc.textContent=v+'/'+cards.length}
si.addEventListener('input',filterCards);sf.addEventListener('change',filterCards);lf.addEventListener('change',filterCards);filterCards();
document.querySelectorAll('.diff-block').forEach(function(b){var h=b.innerHTML;h=h.replace(/^(-.*)$/gm,'<span class="del">$1</span>');h=h.replace(/^(\+.*)$/gm,'<span class="add">$1</span>');b.innerHTML=h});
})();
</script>
</body>
</html>