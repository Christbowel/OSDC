<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OSDC · Silent Patch Detection</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#0a0a0f;--card:#12121a;--text:#e2e2e8;--muted:#8888a0;--accent:#6c8cff;--accent-dim:#3a4a7a;--border:#1e1e2e;--critical:#ff4757;--high:#ff8c42;--moderate:#ffd166;--low:#06d6a0;--code-bg:#1a1a28;--nav-bg:#0e0e16;--font:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;--mono:"SF Mono","Fira Code","Fira Mono",Menlo,monospace}
[data-theme="light"]{--bg:#f5f5f7;--card:#fff;--text:#1a1a2e;--muted:#6c757d;--accent:#3b5bdb;--accent-dim:#d0d7ff;--border:#dee2e6;--critical:#dc3545;--high:#e8590c;--moderate:#e67700;--low:#2b8a3e;--code-bg:#f1f3f5;--nav-bg:#fff}
body{font-family:var(--font);background:var(--bg);color:var(--text);line-height:1.6;-webkit-font-smoothing:antialiased;transition:background .2s,color .2s}
nav{background:var(--nav-bg);border-bottom:1px solid var(--border);padding:0 1.5rem;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.nav-left{display:flex;align-items:center;gap:0}
.nav-brand{font-family:var(--mono);font-size:.9rem;font-weight:600;color:var(--accent);padding:.75rem 1rem .75rem 0;text-decoration:none;border-right:1px solid var(--border);margin-right:0}
.nav-tab{padding:.75rem 1rem;font-size:.8rem;font-family:var(--mono);color:var(--muted);text-decoration:none;border-bottom:2px solid transparent;transition:color .2s,border .2s}
.nav-tab:hover{color:var(--text)}
.nav-tab.active{color:var(--accent);border-bottom-color:var(--accent)}
.theme-toggle{background:none;border:1px solid var(--border);border-radius:4px;padding:4px 8px;font-size:.75rem;font-family:var(--mono);color:var(--muted);cursor:pointer;transition:border-color .2s}
.theme-toggle:hover{border-color:var(--accent);color:var(--text)}
.container{max-width:1080px;margin:0 auto;padding:0 1.5rem}
header{padding:2rem 0;border-bottom:1px solid var(--border)}
header h1{font-size:1.1rem;font-weight:600;font-family:var(--mono)}
header h1 span{color:var(--accent)}
.header-meta{display:flex;gap:2rem;margin-top:.5rem;font-size:.8rem;color:var(--muted);font-family:var(--mono)}
.header-meta span::before{content:"›";margin-right:.5rem;color:var(--accent-dim)}
.explainer{padding:1rem 0;font-size:.85rem;color:var(--muted);border-bottom:1px solid var(--border)}
.controls{padding:1rem 0;display:flex;gap:.75rem;flex-wrap:wrap;align-items:center}
.search{flex:1;min-width:200px;padding:.5rem .75rem;border:1px solid var(--border);border-radius:4px;font-size:.85rem;font-family:var(--mono);background:var(--card);color:var(--text);outline:none}
.search:focus{border-color:var(--accent)}
.search::placeholder{color:var(--muted)}
select{padding:.5rem;border:1px solid var(--border);border-radius:4px;font-size:.8rem;font-family:var(--mono);background:var(--card);color:var(--text);outline:none;cursor:pointer}
select option{background:var(--card);color:var(--text)}
.count{color:var(--muted);font-size:.75rem;font-family:var(--mono);margin-left:auto}
.card{background:var(--card);border:1px solid var(--border);border-radius:6px;margin-bottom:.75rem;overflow:hidden;transition:border-color .2s}
.card:hover{border-color:var(--accent-dim)}
.card-top{display:flex;justify-content:space-between;align-items:center;padding:.75rem 1rem;border-bottom:1px solid var(--border);flex-wrap:wrap;gap:.5rem}
.commit-link{font-weight:600;color:var(--accent);text-decoration:none;font-size:.8rem;font-family:var(--mono)}
.commit-link:hover{text-decoration:underline}
.score-badge{padding:3px 10px;border-radius:12px;font-size:.75rem;font-weight:700;font-family:var(--mono)}
.score-high{background:rgba(255,71,87,.15);color:var(--critical);border:1px solid rgba(255,71,87,.3)}
.score-med{background:rgba(255,140,66,.12);color:var(--high);border:1px solid rgba(255,140,66,.25)}
.score-low{background:rgba(255,209,102,.1);color:var(--moderate);border:1px solid rgba(255,209,102,.2)}
.fp-tag{font-family:var(--mono);font-size:.7rem;color:var(--accent);background:rgba(108,140,255,.08);padding:2px 8px;border-radius:3px;border:1px solid rgba(108,140,255,.15)}
.card-body{padding:1rem}
.field{margin-bottom:.75rem}
.field-label{font-size:.65rem;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);margin-bottom:.25rem;font-family:var(--mono)}
.field-value{font-size:.85rem;color:var(--text);line-height:1.5}
.score-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:.5rem;margin-top:.5rem}
.score-item{display:flex;justify-content:space-between;align-items:center;padding:.25rem .5rem;background:var(--code-bg);border-radius:3px;font-size:.75rem;font-family:var(--mono)}
.score-item .label{color:var(--muted)}
.score-item .value{color:var(--accent);font-weight:600}
.diff-block{background:var(--code-bg);border:1px solid var(--border);border-radius:4px;padding:.75rem;margin-top:.25rem;font-family:var(--mono);font-size:.75rem;line-height:1.5;overflow-x:auto;white-space:pre-wrap;word-break:break-all;max-height:300px;overflow-y:auto}
.diff-block .del{color:#ff6b7a}
.diff-block .add{color:#69db7c}
.signals{display:flex;flex-wrap:wrap;gap:.25rem;margin-top:.25rem}
.signal{font-family:var(--mono);font-size:.65rem;padding:1px 6px;border-radius:3px;background:var(--code-bg);color:var(--muted);border:1px solid var(--border)}
.detail-hidden{display:none}
.toggle-detail{cursor:pointer;color:var(--accent);font-size:.75rem;font-family:var(--mono);background:none;border:none;padding:0}
.toggle-detail:hover{text-decoration:underline}
.card-footer{display:flex;gap:1rem;padding:.5rem 1rem;border-top:1px solid var(--border);font-size:.75rem;font-family:var(--mono)}
.card-footer a{color:var(--accent);text-decoration:none}
.card-footer a:hover{text-decoration:underline}
.card-footer span{color:var(--muted)}
footer{text-align:center;padding:2rem 0;color:var(--muted);font-size:.75rem;font-family:var(--mono);border-top:1px solid var(--border)}
footer a{color:var(--accent)}
@media(max-width:600px){.header-meta{flex-direction:column;gap:.25rem}.controls{flex-direction:column}.card-top{flex-direction:column;align-items:flex-start}.score-grid{grid-template-columns:1fr}}
</style>
</head>
<body>
<nav>
<div class="nav-left">
<a class="nav-brand" href="./">OSDC</a>
<a class="nav-tab" href="./">advisories</a>
<a class="nav-tab active" href="./silent.html">silent patches</a>
</div>
<button class="theme-toggle" onclick="toggleTheme()">light/dark</button>
</nav>
<div class="container">
<header>
<h1><span>Silent patch</span> detection</h1>
<div class="header-meta">
<span>{{ suspects | length }} suspects</span>
<span>{{ stats.total_scanned }} commits scanned</span>
<span>{{ stats.last_scan_at[:10] }}</span>
</div>
</header>
<div class="explainer">
Commits from {{ stats.watchlist_count }} high-value repos scored by structural heuristics (file paths, code patterns, unsafe-to-safe replacements) and matched against 12K+ vulnerability fingerprints from PatchDB. No LLM involved. Higher score = higher probability of unreported security fix.
</div>
<div class="controls">
<input type="text" class="search" id="searchInput" placeholder="search repos, files, patterns...">
<select id="scoreFilter">
<option value="">all scores</option>
<option value="20">score >= 20</option>
<option value="15">score >= 15</option>
<option value="10">score >= 10</option>
</select>
<span class="count" id="resultCount"></span>
</div>
<div id="suspectList">
{% for s in suspects %}
<div class="card" data-score="{{ s.combined_score }}" data-searchable="{{ s.repo }} {{ s.top_file }} {{ s.message }} {{ s.fingerprint_match or '' }} {{ s.commit_sha }}">
<div class="card-top">
<div style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap">
<a class="commit-link" href="{{ s.commit_url }}" target="_blank" rel="noopener">{{ s.commit_sha[:8] }}</a>
<span class="score-badge {% if s.combined_score >= 20 %}score-high{% elif s.combined_score >= 15 %}score-med{% else %}score-low{% endif %}">{{ s.combined_score }}</span>
{% if s.fingerprint_match %}
<span class="fp-tag">{{ s.fingerprint_match }}</span>
{% endif %}
<span style="font-family:var(--mono);font-size:.75rem;color:var(--muted)">{{ s.repo }}</span>
</div>
<button class="toggle-detail" onclick="toggleCard(this)">expand</button>
</div>
<div class="card-body">
<div class="field">
<div class="field-label">commit message</div>
<div class="field-value" style="font-family:var(--mono);font-size:.8rem">{{ s.message | e }}</div>
</div>
<div class="field">
<div class="field-label">primary suspect file</div>
<div class="field-value" style="font-family:var(--mono);font-size:.8rem">{{ s.top_file }} (file score: {{ s.top_file_score }})</div>
</div>
<div class="field">
<div class="field-label">detection signals</div>
<div class="signals">
{% for sig in s.top_file_signals %}
<span class="signal">{{ sig }}</span>
{% endfor %}
</div>
</div>
<div class="detail-hidden">
<div class="field">
<div class="field-label">score breakdown</div>
<div class="score-grid">
<div class="score-item"><span class="label">heuristic</span><span class="value">{{ s.heuristic_score }}</span></div>
<div class="score-item"><span class="label">fingerprint</span><span class="value">{{ '%.1f' | format(s.fingerprint_score * 20) }}</span></div>
<div class="score-item"><span class="label">combined</span><span class="value">{{ s.combined_score }}</span></div>
<div class="score-item"><span class="label">files changed</span><span class="value">{{ s.files_changed }}</span></div>
</div>
</div>
{% if s.fingerprint_match %}
<div class="field">
<div class="field-label">fingerprint match</div>
<div class="field-value" style="font-family:var(--mono);font-size:.8rem">{{ s.fingerprint_match }} (similarity: {{ '%.2f' | format(s.fingerprint_score) }})</div>
<div class="signals" style="margin-top:.25rem">
{% for t in s.fingerprint_matched_tokens %}
<span class="signal">{{ t }}</span>
{% endfor %}
</div>
</div>
{% endif %}
{% if s.removed_sample %}
<div class="field">
<div class="field-label">removed code (sample)</div>
<div class="diff-block">{{ s.removed_sample | e }}</div>
</div>
{% endif %}
{% if s.added_sample %}
<div class="field">
<div class="field-label">added code (sample)</div>
<div class="diff-block">{{ s.added_sample | e }}</div>
</div>
{% endif %}
</div>
</div>
<div class="card-footer">
<span>{{ s.date[:10] if s.date else 'N/A' }}</span>
<span>{{ s.author }}</span>
<a href="{{ s.commit_url }}" target="_blank" rel="noopener">view commit</a>
</div>
</div>
{% endfor %}
</div>
</div>
<footer>
<p><a href="https://christbowel.com">christbowel</a> · <a href="https://github.com/christbowel/osdc">source</a></p>
</footer>
<script>
function toggleCard(btn){var h=btn.closest('.card').querySelector('.detail-hidden');if(h){h.classList.toggle('detail-hidden');btn.textContent=h.classList.contains('detail-hidden')?'expand':'collapse'}}
function toggleTheme(){var t=document.documentElement.getAttribute('data-theme');document.documentElement.setAttribute('data-theme',t==='light'?'':'light');localStorage.setItem('osdc-theme',t==='light'?'dark':'light')}
(function(){
var saved=localStorage.getItem('osdc-theme');
if(saved==='light')document.documentElement.setAttribute('data-theme','light');
var cards=document.querySelectorAll('.card');
var si=document.getElementById('searchInput');
var sf=document.getElementById('scoreFilter');
var rc=document.getElementById('resultCount');
function f(){var q=si.value.toLowerCase(),ms=parseFloat(sf.value)||0,v=0;
cards.forEach(function(c){var s=!q||c.dataset.searchable.toLowerCase().indexOf(q)!==-1;var sc=parseFloat(c.dataset.score)>=ms;var sh=s&&sc;c.style.display=sh?'':'none';if(sh)v++});
rc.textContent=v+'/'+cards.length}
si.addEventListener('input',f);sf.addEventListener('change',f);f();
document.querySelectorAll('.diff-block').forEach(function(b){
var h=b.innerHTML;
h=h.replace(/^(-.*)$/gm,'<span class="del">$1</span>');
h=h.replace(/^(\+.*)$/gm,'<span class="add">$1</span>');
b.innerHTML=h});
})();
</script>
</body>
</html>