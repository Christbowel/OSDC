<script>
(function(){
const SEV_KIND = {CRITICAL:'crit',HIGH:'high',MODERATE:'mod',MEDIUM:'mod',LOW:'low'};
const SEV_TONE_CLASS = {CRITICAL:'crit',HIGH:'high',MODERATE:'mod',MEDIUM:'mod',LOW:'low'};
const BLAST_KIND = {CRITICAL:'blast-crit',HIGH:'blast-high',MEDIUM:'blast-med',LOW:'blast-low'};
const BLAST_DESC = {
  CRITICAL: 'Massive global reach — millions of downstream consumers. Patch is mandatory.',
  HIGH: 'Significant ecosystem footprint. Prioritize patching across affected services.',
  MEDIUM: 'Moderate dependency surface. Address in next maintenance window.',
  LOW: 'Limited reach. Patch when convenient.',
  UNKNOWN: 'Reach data not yet available for this package.'
};
const FACTOR_LABEL = {
  no_advisory: 'No public advisory',
  silent_patch: 'Silent patch detection',
  high_blast: 'High blast radius',
  active_pkg: 'Active package',
  many_dependents: 'High dependent count',
  popular_dl: 'High download volume',
  transitive_amplifier: 'Transitive amplifier'
};
const PKG_REGISTRY = {
  JavaScript: ['npm', l => 'https://www.npmjs.com/package/' + encodeURIComponent(l)],
  TypeScript: ['npm', l => 'https://www.npmjs.com/package/' + encodeURIComponent(l)],
  Python: ['PyPI', l => 'https://pypi.org/project/' + encodeURIComponent(l) + '/'],
  Go: ['pkg.go.dev', l => 'https://pkg.go.dev/' + encodeURIComponent(l)],
  Rust: ['crates.io', l => 'https://crates.io/crates/' + encodeURIComponent(l)],
  RUST: ['crates.io', l => 'https://crates.io/crates/' + encodeURIComponent(l)],
  Ruby: ['rubygems', l => 'https://rubygems.org/gems/' + encodeURIComponent(l)],
  Java: ['Maven', l => 'https://central.sonatype.com/artifact/' + encodeURIComponent(l)],
  'C#': ['NuGet', l => 'https://www.nuget.org/packages/' + encodeURIComponent(l)],
  PHP: ['Packagist', l => 'https://packagist.org/packages/' + encodeURIComponent(l)],
  Erlang: ['hex.pm', l => 'https://hex.pm/packages/' + encodeURIComponent(l)],
};

function escapeHtml(s){return String(s==null?'':s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]);}
function fmtNum(n){if(n==null||!isFinite(n))return '—';if(n===0)return '0';if(n>=1e9)return (n/1e9).toFixed(1)+'B';if(n>=1e6)return (n/1e6).toFixed(1)+'M';if(n>=1e3)return (n/1e3).toFixed(1)+'K';return ''+Math.round(n);}
function getParam(k){return new URLSearchParams(location.search).get(k)||'';}
function scoreTone(score){if(score>=60||score>=7)return 'crit';if(score>=30||score>=4)return 'high';if(score>=15||score>=2)return 'mod';return 'low';}
function cvssTone(s){if(s>=9)return 'crit';if(s>=7)return 'high';if(s>=4)return 'mod';return 'low';}
function silentScoreTone(s){if(s>=60)return 'crit';if(s>=40)return 'high';if(s>=20)return 'mod';return 'low';}

async function fetchJSON(url){
  try { const r = await fetch(url); if(!r.ok) return null; return await r.json(); }
  catch(e){ return null; }
}

function svgGauge(value, max){
  const w = 200, h = 120, cx = w/2, cy = h-12, r = 78;
  const startA = 180, endA = 360;
  const range = endA - startA;
  const fillPct = Math.max(0, Math.min(value/max, 1));
  const fillA = startA + range * fillPct;
  const arc = (a1, a2, rad) => {
    const r1 = a1*Math.PI/180, r2 = a2*Math.PI/180;
    const x1 = cx+Math.cos(r1)*rad, y1 = cy+Math.sin(r1)*rad;
    const x2 = cx+Math.cos(r2)*rad, y2 = cy+Math.sin(r2)*rad;
    const large = Math.abs(a2-a1)>180?1:0;
    return 'M '+x1+' '+y1+' A '+rad+' '+rad+' 0 '+large+' 1 '+x2+' '+y2;
  };
  let color = '#84cc16';
  if(fillPct > 0.75) color = '#ef4444';
  else if(fillPct > 0.55) color = '#fb923c';
  else if(fillPct > 0.35) color = '#fbbf24';
  return '<svg viewBox="0 0 '+w+' '+h+'" width="180" height="108">'
    + '<defs><filter id="glw" x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="3"/></filter></defs>'
    + '<path d="'+arc(startA, endA, r)+'" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="13" stroke-linecap="round"/>'
    + (fillPct > 0 ? '<path d="'+arc(startA, fillA, r)+'" fill="none" stroke="'+color+'" stroke-width="13" stroke-linecap="round" opacity="0.4" filter="url(#glw)"/>' : '')
    + (fillPct > 0 ? '<path d="'+arc(startA, fillA, r)+'" fill="none" stroke="'+color+'" stroke-width="11" stroke-linecap="round"/>' : '')
    + '<text x="'+cx+'" y="'+(cy-12)+'" text-anchor="middle" font-size="36" font-weight="700" fill="#fff" font-family="JetBrains Mono">'+value+'</text>'
    + '<text x="'+cx+'" y="'+(cy+4)+'" text-anchor="middle" font-size="8" fill="#74747e" font-family="JetBrains Mono" letter-spacing="1">/ '+max+'</text>'
    + '</svg>';
}

function svgSparkArea(values){
  if(!values || !values.length) return '<div style="color:#4a4a52;font-family:var(--mono);font-size:.7rem;text-align:center;padding:1rem">no data</div>';
  const w = 320, h = 64, padX = 4, padY = 6;
  const max = Math.max(...values, 1);
  const n = values.length;
  const stepX = n>1 ? (w-2*padX)/(n-1) : 0;
  const pts = values.map((v,i)=>({x: padX+i*stepX, y: h-padY-(v/max)*(h-2*padY)}));
  let line='M '+pts[0].x+' '+pts[0].y, fill='M '+pts[0].x+' '+(h-padY)+' L '+pts[0].x+' '+pts[0].y;
  for(let i=1;i<n;i++){
    const p0=pts[i-1],p1=pts[i];
    const c1x=p0.x+stepX*0.4,c1y=p0.y;
    const c2x=p1.x-stepX*0.4,c2y=p1.y;
    line += ' C '+c1x+' '+c1y+', '+c2x+' '+c2y+', '+p1.x+' '+p1.y;
    fill += ' C '+c1x+' '+c1y+', '+c2x+' '+c2y+', '+p1.x+' '+p1.y;
  }
  fill += ' L '+pts[n-1].x+' '+(h-padY)+' Z';
  return '<svg viewBox="0 0 '+w+' '+h+'" width="100%" preserveAspectRatio="none" style="max-height:64px">'
    + '<defs>'
    + '<linearGradient id="sFill" x1="0" x2="0" y1="0" y2="1"><stop offset="0%" stop-color="#6366F1" stop-opacity="0.45"/><stop offset="100%" stop-color="#6366F1" stop-opacity="0"/></linearGradient>'
    + '<filter id="sGlw" x="-20%" y="-20%" width="140%" height="140%"><feGaussianBlur stdDeviation="2"/></filter>'
    + '</defs>'
    + '<path d="'+fill+'" fill="url(#sFill)"/>'
    + '<path d="'+line+'" fill="none" stroke="#6366F1" stroke-width="2" filter="url(#sGlw)" opacity="0.6"/>'
    + '<path d="'+line+'" fill="none" stroke="#6366F1" stroke-width="1.5" stroke-linecap="round"/>'
    + '</svg>';
}

function svgFileBars(files){
  if(!files || !files.length) return '';
  const max = Math.max(...files.map(f=>(f.additions||0)+(f.deletions||0)), 1);
  const top = [...files].sort((a,b)=>((b.additions||0)+(b.deletions||0))-((a.additions||0)+(a.deletions||0))).slice(0,10);
  return '<div class="file-bar-card"><div class="file-bar-h">CHANGE DISTRIBUTION · TOP '+top.length+' FILES</div>' + top.map(f=>{
    const a = f.additions || 0, d = f.deletions || 0;
    const aPct = (a/max)*100, dPct = (d/max)*100;
    const name = (f.path||'').split('/').pop();
    return '<div class="file-bar-row">'
      + '<span class="file-bar-name" title="'+escapeHtml(f.path||'')+'">'+escapeHtml(name)+'</span>'
      + '<span class="file-bar-trk">'
      +   '<span class="a" style="width:'+aPct+'%"></span>'
      +   '<span class="d" style="width:'+dPct+'%"></span>'
      + '</span>'
      + '<span class="file-bar-stats"><span class="a">+'+a+'</span><span class="d">-'+d+'</span></span>'
      + '</div>';
  }).join('') + '</div>';
}

function diffLineClass(line){
  if(!line) return '';
  if(line.startsWith('@@')) return 'hunk';
  if(line.startsWith('+++') || line.startsWith('---') || line.startsWith('diff ') || line.startsWith('index ') || line.startsWith('new file') || line.startsWith('deleted file') || line.startsWith('similarity')) return 'meta';
  if(line.startsWith('+')) return 'add';
  if(line.startsWith('-')) return 'del';
  return '';
}

function renderDiffFiles(files){
  if(!files || !files.length) return '';
  return '<div class="diff-files">' + files.map((f, idx)=>{
    const startCollapsed = idx > 3 ? ' collapsed' : '';
    const linesHtml = (f.lines||[]).map(l=>'<span class="diff-line '+diffLineClass(l)+'">'+escapeHtml(l||' ')+'</span>').join('');
    const truncBadge = f.truncated ? '<div class="file-truncated">⚠ file truncated at '+(f.lines?f.lines.length:0)+' lines</div>' : '';
    return '<div class="diff-file'+startCollapsed+'">'
      + '<div class="diff-file-head" onclick="this.parentNode.classList.toggle(\'collapsed\')">'
      +   '<span class="chev">▾</span>'
      +   '<span class="diff-file-path" title="'+escapeHtml(f.path)+'">'+escapeHtml(f.path)+'</span>'
      +   '<span class="diff-file-stats"><span class="a">+'+(f.additions||0)+'</span><span class="d">-'+(f.deletions||0)+'</span></span>'
      + '</div>'
      + '<div class="diff-file-body">'+linesHtml+'</div>'
      + truncBadge
      + '</div>';
  }).join('') + '</div>';
}

function renderHero(axis, r){
  const isSilent = axis === 'silent';
  const id = isSilent ? r.sha : r.id;
  const sev = r.severity;
  const score = r.score ?? r.cvss ?? 0;
  const blastTier = r.reach && r.reach.tier;
  const tone = sev ? SEV_TONE_CLASS[sev] : (isSilent ? silentScoreTone(score) : 'acc');
  const heroToneClass = tone === 'crit' ? ' tone-crit' : tone === 'high' ? ' tone-high' : '';

  const badges = [];
  if(sev) badges.push('<span class="badge b-'+SEV_KIND[sev]+'">'+escapeHtml(sev)+'</span>');
  if(blastTier && blastTier !== 'UNKNOWN') badges.push('<span class="badge b-'+BLAST_KIND[blastTier]+'">BLAST '+escapeHtml(blastTier)+'</span>');
  if(r.cve) badges.push('<span class="badge b-cyan">'+escapeHtml(r.cve)+'</span>');
  if(r.cwe) badges.push('<span class="badge b-pink">'+escapeHtml(r.cwe)+'</span>');
  if(r.fp) badges.push('<span class="badge b-vio">'+escapeHtml(r.fp)+'</span>');
  if(r.vuln_type) badges.push('<span class="badge b-pink">'+escapeHtml(r.vuln_type)+'</span>');
  if(r.language) badges.push('<span class="badge b-acc">'+escapeHtml(r.language)+'</span>');
  if(r.pattern) badges.push('<span class="badge b-neutral">'+escapeHtml(r.pattern)+'</span>');
  if(isSilent) badges.push('<span class="badge b-acc">SCORE '+Math.round(score)+'</span>');

  const meta = [];
  if(r.date) meta.push('<span><strong>'+escapeHtml(r.date.slice(0,10))+'</strong></span>');
  if(r.author) meta.push('<span>'+escapeHtml(r.author)+'</span>');
  if(r.package) meta.push('<span>pkg: <strong>'+escapeHtml(r.package)+'</strong></span>');
  if(r.files_changed) meta.push('<span>'+r.files_changed+' files</span>');

  return '<div class="hero'+heroToneClass+'">'
    + '<div class="hero-row1">'+ badges.join('') +'</div>'
    + '<div class="hero-id">'+escapeHtml(isSilent ? id.slice(0,12) : id)+'</div>'
    + '<div class="hero-repo">'+escapeHtml(r.repo||'')+'</div>'
    + (r.msg || r.summary ? '<div class="hero-msg">'+escapeHtml(r.msg || r.summary)+'</div>' : '')
    + (meta.length ? '<div class="hero-meta">'+meta.join('')+'</div>' : '')
    + '</div>';
}

function renderAssessment(axis, r){
  const isSilent = axis === 'silent';
  const score = r.score ?? 0;
  const cvss = r.cvss ?? 0;
  const blastTier = (r.reach && r.reach.tier) || 'UNKNOWN';
  const blastScore = (r.reach && r.reach.score) || 0;

  const card1 = isSilent
    ? (function(){
        const tone = silentScoreTone(score);
        return '<div class="panel green-tint'+(tone==='crit'?' crit-tint':'')+'"><div class="panel-h"><span>DETECTION SCORE</span><span class="nb">'+Math.round(score)+' / 100</span></div>'
          + '<div class="big-stat '+tone+'">'+Math.round(score)+'</div>'
          + '<div class="stat-sub">silent patch confidence</div>'
          + '<div class="stat-desc">Normalized aggregate of fingerprint matches, file signals, and surgical-fix heuristics. Score ≥ 60 indicates high confidence this commit silently patches a vulnerability without public disclosure.</div>'
          + '</div>';
      })()
    : (function(){
        const tone = cvssTone(cvss);
        return '<div class="panel green-tint'+(tone==='crit'?' crit-tint':'')+'"><div class="panel-h"><span>CVSS SEVERITY</span><span class="nb">'+cvss.toFixed(1)+' / 10</span></div>'
          + '<div class="big-stat '+tone+'">'+cvss.toFixed(1)+'</div>'
          + '<div class="stat-sub">'+(r.severity||'UNKNOWN')+'</div>'
          + '<div class="stat-desc">'+escapeHtml((r.root_cause || 'Severity from upstream advisory metadata.').slice(0,260))+'</div>'
          + '</div>';
      })();

  const tierColor = blastTier==='CRITICAL'?'var(--critical)':blastTier==='HIGH'?'var(--high)':blastTier==='MEDIUM'?'var(--moderate)':blastTier==='LOW'?'var(--low)':'var(--dim)';
  const card2 = '<div class="panel violet-tint"><div class="panel-h"><span>BLAST RADIUS</span><span class="nb" style="color:'+tierColor+'">'+blastTier+'</span></div>'
    + '<div class="gauge-wrap">'+ svgGauge(blastScore, 100) +'<div class="gauge-meta"><div class="gauge-tier" style="color:'+tierColor+'">'+blastTier+'</div><div class="gauge-desc">'+escapeHtml(BLAST_DESC[blastTier]||'')+'</div></div></div>'
    + '</div>';

  const provFactors = [];
  if(isSilent){
    provFactors.push(['Source', 'OSDC watchlist scan']);
    provFactors.push(['Status', 'No public advisory']);
    if(r.fp) provFactors.push(['Fingerprint', r.fp]);
    if(r.heuristic_score) provFactors.push(['Heuristic raw', Math.round(r.heuristic_score)]);
    if(r.fp_score) provFactors.push(['Fingerprint score', r.fp_score.toFixed(2)]);
    if(r.top_file_score) provFactors.push(['Top file score', r.top_file_score.toFixed(1)]);
  } else {
    provFactors.push(['Source', 'GitHub Advisory DB']);
    if(r.cve) provFactors.push(['CVE', r.cve]);
    if(r.cwe) provFactors.push(['CWE', r.cwe]);
    if(r.pattern) provFactors.push(['Pattern', r.pattern]);
    if(r.language) provFactors.push(['Language', r.language]);
    if(r.confidence) provFactors.push(['LLM confidence', r.confidence]);
  }
  const card3 = '<div class="panel"><div class="panel-h"><span>PROVENANCE</span></div>'
    + '<ul class="factors">' + provFactors.map(([k,v])=>'<li><span class="k">'+escapeHtml(k)+'</span><span class="v">'+escapeHtml(String(v))+'</span></li>').join('') + '</ul>'
    + '</div>';

  return '<div class="grid-3">'+card1+card2+card3+'</div>';
}

function renderReachAndIntel(axis, r, reachData){
  const isSilent = axis === 'silent';
  const reach = reachData || {};
  const br = reach.blast_radius || {};
  const dl = reach.downloads || {};
  const dep = reach.dependents || {};
  const pkg = reach.pkg_name || r.package || '—';
  const factors = (br.factors || []).map(f=>'<li><span class="k">'+escapeHtml(FACTOR_LABEL[f]||f)+'</span><span class="v">+</span></li>').join('');
  const monthlyHistory = reach.downloads_history || [];
  const sparkValues = monthlyHistory.map(h=>h.downloads||0);

  const reachPanel = '<div class="panel violet-tint">'
    + '<div class="panel-h"><span>REACH ANALYSIS</span><span class="nb" style="color:var(--violet)">'+escapeHtml(pkg)+'</span></div>'
    + '<div class="stat-quad">'
    + '<div class="stat-cell vio"><div class="v">'+fmtNum(dep.direct||0)+'</div><div class="k">direct deps</div></div>'
    + '<div class="stat-cell vio"><div class="v">'+fmtNum(dep.transitive||0)+'</div><div class="k">transitive</div></div>'
    + '<div class="stat-cell acc"><div class="v">'+fmtNum(dl.weekly||0)+'</div><div class="k">dl / week</div></div>'
    + '<div class="stat-cell acc"><div class="v">'+fmtNum(dl.monthly||0)+'</div><div class="k">dl / month</div></div>'
    + '</div>'
    + (sparkValues.length ? '<div class="tl-card"><div class="stat-sub" style="margin-bottom:.4rem">downloads · last '+sparkValues.length+' months</div>'+svgSparkArea(sparkValues)+'</div>' : '')
    + (factors ? '<ul class="factors" style="margin-top:.8rem">'+factors+'</ul>' : '')
    + (Object.keys(reach).length === 0 ? '<div class="stat-desc">Reach data not yet available. Awaiting next enrichment cycle.</div>' : '')
    + '</div>';

  let intel = '';
  if(isSilent){
    const signalsHtml = (r.signals||[]).map(s=>'<span class="sig-chip">'+escapeHtml(s)+'</span>').join('');
    const fpTokens = (r.fp_tokens||[]).slice(0,12).map(t=>'<span class="sig-chip">'+escapeHtml(t)+'</span>').join('');
    intel = '<div class="panel green-tint">'
      + '<div class="panel-h"><span>CODE INTEL</span><span class="nb">'+(r.files_changed||0)+' files</span></div>'
      + '<dl class="kv">'
      +   '<dt>Top file</dt><dd>'+escapeHtml(r.top_file||'—')+'</dd>'
      +   '<dt>File score</dt><dd>'+(r.top_file_score||0).toFixed(1)+'</dd>'
      +   '<dt>Files changed</dt><dd>'+(r.files_changed||0)+'</dd>'
      +   '<dt>Heuristic</dt><dd>'+(r.heuristic_score||0).toFixed(1)+'</dd>'
      + '</dl>'
      + (signalsHtml ? '<div class="stat-sub" style="margin-top:.85rem;margin-bottom:.4rem">DETECTION SIGNALS</div><div class="signals">'+signalsHtml+'</div>' : '')
      + (fpTokens ? '<div class="stat-sub" style="margin-top:.85rem;margin-bottom:.4rem">FINGERPRINT TOKENS</div><div class="signals">'+fpTokens+'</div>' : '')
      + '</div>';
  } else {
    const hasAnalysis = r.root_cause || r.impact || r.fix_summary;
    intel = '<div class="panel green-tint">'
      + '<div class="panel-h"><span>IMPACT &amp; FIX</span><span class="nb">'+(r.confidence||'—')+'</span></div>'
      + (r.root_cause ? '<div class="stat-sub" style="margin-bottom:.3rem">ROOT CAUSE</div><div class="stat-desc" style="margin-top:0">'+escapeHtml(r.root_cause)+'</div>' : '')
      + (r.impact ? '<div class="stat-sub" style="margin-top:.85rem;margin-bottom:.3rem">IMPACT</div><div class="stat-desc" style="margin-top:0">'+escapeHtml(r.impact)+'</div>' : '')
      + (r.fix_summary ? '<div class="stat-sub" style="margin-top:.85rem;margin-bottom:.3rem">FIX SUMMARY</div><div class="stat-desc" style="margin-top:0">'+escapeHtml(r.fix_summary)+'</div>' : '')
      + (!hasAnalysis ? '<div class="stat-desc">No detailed analysis available.</div>' : '')
      + '</div>';
  }

  return '<div class="grid-2">'+reachPanel+intel+'</div>';
}

function renderClassification(axis, r){
  if(axis === 'silent'){
    return '<div class="panel violet-tint"><div class="panel-h"><span>SILENT PATCH CLASSIFICATION</span><span class="nb" style="color:var(--violet)">'+escapeHtml(r.fp||'UNCLASSIFIED')+'</span></div>'
      + '<div class="classify">'
      + '<div class="stat-cell vio"><div class="v">'+escapeHtml(r.fp||'UNCLASSIFIED')+'</div><div class="k">fingerprint</div></div>'
      + '<div class="stat-cell acc"><div class="v">'+escapeHtml(r.top_file ? r.top_file.split('/').slice(-2).join('/') : '—')+'</div><div class="k">primary file</div></div>'
      + '<div class="stat-cell"><div class="v">'+(r.files_changed||0)+'</div><div class="k">files changed</div></div>'
      + '<div class="stat-cell cyan"><div class="v">'+(r.fp_score?r.fp_score.toFixed(2):'—')+'</div><div class="k">fingerprint conf</div></div>'
      + '</div></div>';
  }
  const cells = [];
  if(r.vuln_type) cells.push(['vuln type', r.vuln_type, 'pink']);
  if(r.pattern) cells.push(['osdc pattern', r.pattern, 'vio']);
  if(r.cwe) cells.push(['CWE', r.cwe, 'pink']);
  if(r.cve) cells.push(['CVE', r.cve, 'cyan']);
  if(r.severity) cells.push(['severity', r.severity, '']);
  if(r.cvss) cells.push(['CVSS', r.cvss.toFixed(1), '']);
  if(r.language) cells.push(['language', r.language, 'acc']);
  if(r.package) cells.push(['package', r.package, 'acc']);
  if(r.confidence) cells.push(['LLM confidence', r.confidence, '']);
  if(!cells.length) return '';
  return '<div class="panel violet-tint"><div class="panel-h"><span>VULN CLASSIFICATION</span><span class="nb" style="color:var(--pink)">'+escapeHtml(r.vuln_type||r.pattern||'UNKNOWN')+'</span></div>'
    + '<div class="classify">'
    + cells.map(([k,v,cls])=>{
        const isLong = String(v).length > 18;
        return '<div class="stat-cell '+cls+(isLong?' long':'')+'"><div class="v">'+escapeHtml(String(v))+'</div><div class="k">'+escapeHtml(k)+'</div></div>';
      }).join('')
    + '</div></div>';
}

function relCardClass(score){return score>=60?'s-crit':score>=30?'s-high':score>=15?'s-mod':'s-low';}

function renderRelated(axis, r, allRecords){
  if(!allRecords || allRecords.length < 2) return '';
  const isSilent = axis === 'silent';
  const myId = isSilent ? r.sha : r.id;
  const sections = [];

  const sameRepo = allRecords.filter(x => x.repo === r.repo && (isSilent ? x.sha : x.id) !== myId).slice(0, 5);
  if(sameRepo.length){
    sections.push({title: 'SAME REPO · ' + r.repo, items: sameRepo});
  }

  if(isSilent && r.author){
    const sameAuthor = allRecords.filter(x => x.author === r.author && x.sha !== myId && x.repo !== r.repo).slice(0, 5);
    if(sameAuthor.length){
      sections.push({title: 'SAME AUTHOR · ' + r.author, items: sameAuthor});
    }
  } else if(!isSilent && r.pattern){
    const samePattern = allRecords.filter(x => x.pattern === r.pattern && x.id !== myId && x.repo !== r.repo).slice(0, 5);
    if(samePattern.length){
      sections.push({title: 'SAME PATTERN · ' + r.pattern, items: samePattern});
    }
  }

  if(!sections.length) return '';
  const baseURL = (axis === 'silent' ? 'silent.html' : axis === 'threats' ? 'threats.html' : 'index.html').replace('.html', '');

  return sections.map(sec => {
    const items = sec.items.map(x => {
      const sId = isSilent ? x.sha : x.id;
      const sScore = x.score ?? x.cvss ?? 0;
      const sCls = isSilent ? relCardClass(sScore) : ('s-'+(SEV_KIND[x.severity]||'mod'));
      const url = 'detail.html?axis='+encodeURIComponent(axis)+'&id='+encodeURIComponent(sId);
      const sevPart = x.severity ? '<span style="color:var(--'+(SEV_KIND[x.severity]==='crit'?'critical':SEV_KIND[x.severity]==='high'?'high':SEV_KIND[x.severity]==='mod'?'moderate':'low')+');font-weight:600">'+x.severity+'</span>' : '';
      const scorePart = isSilent ? '<span>score '+Math.round(sScore)+'</span>' : (x.cvss?'<span>CVSS '+x.cvss.toFixed(1)+'</span>':'');
      const dateP = x.date ? '<span>'+x.date.slice(0,10)+'</span>' : '';
      const patternP = x.pattern && !isSilent ? '<span>'+x.pattern+'</span>' : '';
      const fpP = x.fp && isSilent ? '<span>'+x.fp+'</span>' : '';
      return '<a class="rel-card '+sCls+'" href="'+url+'">'
        + '<div class="rel-row"><span class="rel-id">'+escapeHtml(isSilent ? sId.slice(0,12) : sId)+'</span>'+sevPart+'</div>'
        + '<div class="rel-msg">'+escapeHtml(x.msg||x.summary||'')+'</div>'
        + '<div class="rel-meta">'+dateP+scorePart+patternP+fpP+'</div>'
        + '</a>';
    }).join('');
    return '<div class="panel cyan-tint"><div class="panel-h"><span>RELATED INTEL · '+escapeHtml(sec.title)+'</span><span class="nb" style="color:var(--cyan)">'+sec.items.length+'</span></div>'
      + '<div class="related">'+items+'</div>'
      + '</div>';
  }).join('');
}

function renderDiffPanel(axis, r, diffData){
  let body = '';
  if(diffData && diffData.parsed){
    const p = diffData.parsed;
    const summary = '<div class="diff-summary">'
      + '<span class="files-n">'+(p.file_count||0)+' files changed</span>'
      + '<span class="add">+'+(p.additions||0)+'</span>'
      + '<span class="del">-'+(p.deletions||0)+'</span>'
      + (p.truncated ? '<span class="truncated">diff truncated at 30KB</span>' : '')
      + '</div>';
    body = summary + svgFileBars(p.files) + '<div style="margin-top:.8rem">' + renderDiffFiles(p.files) + '</div>';
  } else {
    body = '<div class="diff-loader">Full diff capture pending — enrichment will surface it on next pipeline run (~30 min after commit detection).</div>';
  }
  return '<div class="panel"><div class="panel-h"><span>UNIFIED DIFF</span><span class="nb">commit '+(r.sha||r.id||'').slice(0,12)+'</span></div>'+body+'</div>';
}

function renderExternalRefs(axis, r){
  const refs = [];
  const isSilent = axis === 'silent';
  const sha = isSilent ? r.sha : ((r.url||'').split('/commit/')[1]||'').split(/[?#]/)[0];

  if(!isSilent && r.id && r.id.startsWith('GHSA-')){
    refs.push({k:'GHSA',ic:'GH',v:r.id,url:'https://github.com/advisories/'+r.id});
  }
  if(r.cve){
    refs.push({k:'NVD · CVE',ic:'NVD',v:r.cve,url:'https://nvd.nist.gov/vuln/detail/'+r.cve});
    refs.push({k:'MITRE · CVE',ic:'MIT',v:r.cve,url:'https://cve.mitre.org/cgi-bin/cvename.cgi?name='+r.cve});
  }
  if(r.cwe){
    const cweNum = (r.cwe.match(/\d+/) || [])[0];
    if(cweNum) refs.push({k:'MITRE · CWE',ic:'CWE',v:r.cwe,url:'https://cwe.mitre.org/data/definitions/'+cweNum+'.html'});
  }
  if(r.url || r.repo){
    const commitUrl = r.url || (r.repo && sha ? 'https://github.com/'+r.repo+'/commit/'+sha : null);
    if(commitUrl) refs.push({k:'Source commit',ic:'⌥',v:sha?sha.slice(0,12):'github',url:commitUrl});
  }
  if(r.repo){
    refs.push({k:'Repository',ic:'⌘',v:r.repo,url:'https://github.com/'+r.repo});
    if(isSilent && r.author){
      refs.push({k:'Author commits',ic:'@',v:r.author,url:'https://github.com/'+r.repo+'/commits?author='+encodeURIComponent(r.author)});
    }
  }
  if(r.package && r.language){
    const reg = PKG_REGISTRY[r.language];
    if(reg) refs.push({k:reg[0],ic:'PKG',v:r.package,url:reg[1](r.package)});
  }

  if(!refs.length) return '';
  return '<div class="panel cyan-tint"><div class="panel-h"><span>EXTERNAL REFERENCES</span><span class="nb" style="color:var(--cyan)">'+refs.length+'</span></div>'
    + '<div class="refs-grid">'
    + refs.map(ref => '<a class="ref-link" href="'+escapeHtml(ref.url)+'" target="_blank" rel="noopener noreferrer">'
      + '<span class="ref-icon">'+escapeHtml(ref.ic)+'</span>'
      + '<span class="ref-meta"><span class="k">'+escapeHtml(ref.k)+'</span><span class="v">'+escapeHtml(ref.v)+'</span></span>'
      + '<span class="arr">→</span>'
      + '</a>').join('')
    + '</div></div>';
}

async function main(){
  const axis = getParam('axis') || 'advisories';
  const id = getParam('id');
  if(!id){
    document.getElementById('app').innerHTML = '<div class="err">missing id parameter</div>';
    return;
  }

  document.getElementById('backLink').href = (axis === 'silent' ? 'silent.html' : axis === 'threats' ? 'threats.html' : 'index.html');

  const data = await fetchJSON('data/' + axis + '.json');
  if(!data){
    document.getElementById('app').innerHTML = '<div class="err">failed to load '+axis+'.json</div>';
    return;
  }
  const allRecords = data.records || [];
  const rec = allRecords.find(r => axis === 'silent' ? r.sha === id : r.id === id);
  if(!rec){
    document.getElementById('app').innerHTML = '<div class="err">record not found: '+escapeHtml(id)+'</div>';
    return;
  }

  document.title = 'OSDC · ' + (axis === 'silent' ? rec.sha.slice(0,12) : rec.id);

  const sha = axis === 'silent' ? rec.sha : ((rec.url||'').split('/commit/')[1]||'').split(/[?#]/)[0];
  const reachId = axis === 'silent' ? rec.sha : rec.id;
  const reachData = await fetchJSON('data/enrichments/reach/' + reachId + '.json');
  const diffData = sha ? await fetchJSON('data/enrichments/diff/' + sha + '.json') : null;

  let html = renderHero(axis, rec);
  html += renderAssessment(axis, rec);
  html += renderReachAndIntel(axis, rec, reachData);
  html += renderClassification(axis, rec);
  html += renderDiffPanel(axis, rec, diffData);
  html += renderRelated(axis, rec, allRecords);
  html += renderExternalRefs(axis, rec);

  document.getElementById('app').innerHTML = html;
}

main();
})();
</script>
</body>
</html>
