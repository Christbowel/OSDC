<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5">
<title>OSDC - Intel Briefing</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
--bg-deep:#08080a;--bg:#0e0e10;--bg-elev:#16161a;
--panel:rgba(255,255,255,.025);--panel-2:rgba(255,255,255,.045);--panel-hover:rgba(255,255,255,.075);
--text:#ffffff;--muted:#c5c5cf;--dim:#74747e;--dimmer:#4a4a52;
--accent:#CCFF00;--accent-soft:rgba(204,255,0,.18);--accent-glow:rgba(204,255,0,.4);
--violet:#6366F1;--violet-soft:rgba(99,102,241,.18);--violet-glow:rgba(99,102,241,.4);
--cyan:#06b6d4;--cyan-soft:rgba(6,182,212,.16);--cyan-glow:rgba(6,182,212,.35);
--pink:#ec4899;--pink-soft:rgba(236,72,153,.14);
--critical:#ef4444;--critical-glow:rgba(239,68,68,.4);
--high:#fb923c;--high-glow:rgba(251,146,60,.36);
--moderate:#fbbf24;--moderate-glow:rgba(251,191,36,.32);
--low:#84cc16;--low-glow:rgba(132,204,22,.32);
--diff-add:rgba(132,204,22,.10);
--diff-del:rgba(239,68,68,.10);
--border:rgba(255,255,255,.08);--border-strong:rgba(255,255,255,.16);
--mono:'JetBrains Mono','SF Mono',ui-monospace,monospace;
--sans:'Inter','SF Pro Display',-apple-system,system-ui,sans-serif;
}
html,body{height:100%}
body{
font-family:var(--sans);color:var(--text);-webkit-font-smoothing:antialiased;line-height:1.55;overflow-x:hidden;
background:
  radial-gradient(ellipse 60% 50% at 85% 0%, rgba(99,102,241,.10), transparent 55%),
  radial-gradient(ellipse 50% 40% at 15% 100%, rgba(204,255,0,.04), transparent 60%),
  var(--bg);
min-height:100vh;
}
a{color:var(--accent);text-decoration:none}a:hover{color:var(--text)}
::-webkit-scrollbar{width:8px;height:8px}
::-webkit-scrollbar-track{background:var(--bg-deep)}
::-webkit-scrollbar-thumb{background:var(--border-strong);border-radius:4px}
::-webkit-scrollbar-thumb:hover{background:var(--dim)}

nav{background:rgba(10,10,12,.7);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:50;backdrop-filter:blur(24px) saturate(140%);-webkit-backdrop-filter:blur(24px) saturate(140%)}
.nav-inner{max-width:1400px;margin:0 auto;padding:0 1.25rem;display:flex;align-items:center;gap:.5rem;height:56px;overflow-x:auto;scrollbar-width:none}
.nav-inner::-webkit-scrollbar{display:none}
.nav-brand{font-family:var(--mono);font-weight:700;font-size:.85rem;color:var(--accent);padding-right:1.1rem;border-right:1px solid var(--border);white-space:nowrap;text-shadow:0 0 12px var(--accent-glow)}
.nav-link{font-family:var(--mono);font-size:.72rem;color:var(--muted);padding:.55rem .9rem;border-radius:7px;white-space:nowrap;transition:background .15s,color .15s;letter-spacing:.02em}
.nav-link:hover{color:var(--text);background:var(--panel)}
.nav-spacer{flex:1;min-width:.5rem}

.wrap{max-width:1400px;margin:0 auto;padding:1.25rem}
.back{font-family:var(--mono);font-size:.72rem;color:var(--muted);margin-bottom:1rem;display:inline-flex;align-items:center;gap:.4rem;padding:.4rem .75rem;border:1px solid var(--border);border-radius:8px;background:var(--panel);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px)}
.back:hover{color:var(--accent);border-color:var(--border-strong)}

.hero{background:var(--panel);border:1px solid var(--border);border-radius:14px;padding:1.4rem 1.5rem;margin-bottom:1rem;position:relative;overflow:hidden;backdrop-filter:blur(22px) saturate(140%);-webkit-backdrop-filter:blur(22px) saturate(140%)}
.hero::before{content:'';position:absolute;top:-40%;right:-20%;width:80%;height:160%;background:radial-gradient(circle,var(--accent-soft) 0%,transparent 50%);pointer-events:none;opacity:.45}
.hero.tone-crit::before{background:radial-gradient(circle,rgba(239,68,68,.16) 0%,transparent 50%);opacity:.6}
.hero.tone-high::before{background:radial-gradient(circle,rgba(251,146,60,.14) 0%,transparent 50%)}
.hero>*{position:relative}
.hero-row1{display:flex;gap:.55rem;flex-wrap:wrap;align-items:center;margin-bottom:.7rem}
.hero-id{font-family:var(--mono);font-size:1.05rem;font-weight:700;color:var(--accent);letter-spacing:-.01em;text-shadow:0 0 16px var(--accent-glow)}
.hero-repo{font-family:var(--mono);font-size:.78rem;color:var(--muted);margin-top:.25rem;word-break:break-all}
.hero-msg{font-family:var(--mono);font-size:.88rem;color:var(--text);margin-top:.65rem;line-height:1.55}
.hero-meta{display:flex;gap:1.2rem;flex-wrap:wrap;font-family:var(--mono);font-size:.7rem;color:var(--dim);margin-top:.7rem}
.hero-meta strong{color:var(--muted);font-weight:600}

.badge{font-family:var(--mono);font-size:.62rem;font-weight:600;padding:3px 9px;border-radius:11px;white-space:nowrap;letter-spacing:.04em;line-height:1.25}
.b-crit{color:var(--critical);background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.36)}
.b-high{color:var(--high);background:rgba(251,146,60,.1);border:1px solid rgba(251,146,60,.32)}
.b-mod{color:var(--moderate);background:rgba(251,191,36,.08);border:1px solid rgba(251,191,36,.28)}
.b-low{color:var(--low);background:rgba(132,204,22,.1);border:1px solid rgba(132,204,22,.28)}
.b-acc{color:var(--accent);background:var(--accent-soft);border:1px solid rgba(204,255,0,.3)}
.b-vio{color:var(--violet);background:var(--violet-soft);border:1px solid rgba(99,102,241,.32)}
.b-cyan{color:var(--cyan);background:var(--cyan-soft);border:1px solid rgba(6,182,212,.3)}
.b-pink{color:var(--pink);background:var(--pink-soft);border:1px solid rgba(236,72,153,.3)}
.b-neutral{color:var(--muted);background:rgba(255,255,255,.04);border:1px solid var(--border)}
.b-blast-crit{color:var(--critical);background:rgba(239,68,68,.18);border:1px solid rgba(239,68,68,.5);font-weight:800;letter-spacing:.05em;text-shadow:0 0 8px var(--critical-glow)}
.b-blast-high{color:var(--high);background:rgba(251,146,60,.14);border:1px solid rgba(251,146,60,.42);font-weight:800;letter-spacing:.05em}
.b-blast-med{color:var(--moderate);background:rgba(251,191,36,.12);border:1px solid rgba(251,191,36,.35);font-weight:800;letter-spacing:.05em}
.b-blast-low{color:var(--low);background:rgba(132,204,22,.1);border:1px solid rgba(132,204,22,.3);font-weight:800;letter-spacing:.05em}

.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem;margin-bottom:1rem}
@media(max-width:780px){.grid-3{grid-template-columns:1fr}}

.grid-2{display:grid;grid-template-columns:1.05fr 1fr;gap:.75rem;margin-bottom:1rem}
@media(max-width:980px){.grid-2{grid-template-columns:1fr}}

.panel{background:var(--panel);border:1px solid var(--border);border-radius:12px;padding:1.1rem 1.25rem;position:relative;overflow:hidden;backdrop-filter:blur(20px) saturate(140%);-webkit-backdrop-filter:blur(20px) saturate(140%);margin-bottom:1rem}
.panel.violet-tint::before{content:'';position:absolute;top:-50%;right:-30%;width:120%;height:120%;background:radial-gradient(circle,var(--violet-soft) 0%,transparent 50%);pointer-events:none;opacity:.45}
.panel.green-tint::before{content:'';position:absolute;top:-50%;right:-30%;width:120%;height:120%;background:radial-gradient(circle,var(--accent-soft) 0%,transparent 50%);pointer-events:none;opacity:.4}
.panel.cyan-tint::before{content:'';position:absolute;top:-50%;right:-30%;width:120%;height:120%;background:radial-gradient(circle,var(--cyan-soft) 0%,transparent 50%);pointer-events:none;opacity:.4}
.panel.crit-tint::before{content:'';position:absolute;top:-50%;right:-30%;width:120%;height:120%;background:radial-gradient(circle,rgba(239,68,68,.16) 0%,transparent 50%);pointer-events:none;opacity:.5}
.panel>*{position:relative}
.panel-h{font-family:var(--mono);font-size:.6rem;text-transform:uppercase;letter-spacing:.14em;color:var(--dim);font-weight:600;margin-bottom:.75rem;display:flex;justify-content:space-between;align-items:center}
.panel-h .nb{color:var(--accent);font-weight:700}
.panel.cyan-tint .panel-h .nb{color:var(--cyan)}

.big-stat{font-family:var(--mono);font-size:2.6rem;font-weight:700;letter-spacing:-.02em;line-height:1;margin:.3rem 0}
.big-stat.crit{color:var(--critical);text-shadow:0 0 24px var(--critical-glow)}
.big-stat.high{color:var(--high);text-shadow:0 0 24px var(--high-glow)}
.big-stat.mod{color:var(--moderate);text-shadow:0 0 24px var(--moderate-glow)}
.big-stat.low{color:var(--low);text-shadow:0 0 24px var(--low-glow)}
.big-stat.acc{color:var(--accent);text-shadow:0 0 24px var(--accent-glow)}
.big-stat.violet{color:var(--violet);text-shadow:0 0 24px var(--violet-glow)}
.stat-sub{font-family:var(--mono);font-size:.62rem;color:var(--dim);letter-spacing:.08em;text-transform:uppercase;font-weight:600}
.stat-desc{font-family:var(--sans);font-size:.78rem;color:var(--muted);margin-top:.55rem;line-height:1.55}

.stat-quad{display:grid;grid-template-columns:1fr 1fr;gap:.6rem;margin-top:.5rem}
.stat-cell{padding:.55rem .7rem;background:var(--panel-2);border:1px solid var(--border);border-radius:8px}
.stat-cell .v{font-family:var(--mono);font-size:1.15rem;font-weight:700;color:var(--text)}
.stat-cell.acc .v{color:var(--accent)}
.stat-cell.vio .v{color:var(--violet)}
.stat-cell.cyan .v{color:var(--cyan)}
.stat-cell .k{font-family:var(--mono);font-size:.58rem;color:var(--dim);letter-spacing:.1em;text-transform:uppercase;margin-top:.1rem;font-weight:600}

.gauge-wrap{display:flex;align-items:center;gap:1rem}
.gauge-wrap svg{flex-shrink:0}
.gauge-meta{flex:1;min-width:0}
.gauge-tier{font-family:var(--mono);font-size:1.1rem;font-weight:700;letter-spacing:.02em}
.gauge-desc{font-family:var(--sans);font-size:.76rem;color:var(--muted);margin-top:.35rem;line-height:1.5}

.factors{list-style:none;margin-top:.7rem;display:flex;flex-direction:column;gap:.3rem}
.factors li{font-family:var(--mono);font-size:.7rem;color:var(--muted);padding:.32rem .55rem;background:var(--panel-2);border:1px solid var(--border);border-radius:6px;display:flex;justify-content:space-between;align-items:center;gap:.5rem}
.factors li .k{color:var(--dim);font-size:.62rem;letter-spacing:.08em;text-transform:uppercase;font-weight:600}
.factors li .v{color:var(--accent);font-weight:600;text-align:right;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

.signals{display:flex;gap:.3rem;flex-wrap:wrap;margin-top:.6rem}
.sig-chip{font-family:var(--mono);font-size:.62rem;padding:3px 9px;border-radius:11px;background:var(--violet-soft);border:1px solid rgba(99,102,241,.32);color:var(--violet);letter-spacing:.04em;font-weight:600}

.kv{display:grid;grid-template-columns:auto 1fr;gap:.4rem 1rem;font-family:var(--mono);font-size:.72rem;margin-top:.5rem}
.kv dt{color:var(--dim);font-weight:600;letter-spacing:.04em}
.kv dd{color:var(--muted);word-break:break-all}

.classify{display:grid;grid-template-columns:1fr 1fr;gap:.6rem;margin-top:.5rem}
@media(max-width:580px){.classify{grid-template-columns:1fr}}
.classify .stat-cell{padding:.7rem .85rem}
.classify .stat-cell .v{font-size:.92rem;line-height:1.3;word-break:break-word}
.classify .stat-cell.long .v{font-size:.78rem;font-family:var(--mono);font-weight:600}

.related{display:flex;flex-direction:column;gap:.4rem;margin-top:.55rem}
.rel-card{display:block;padding:.55rem .8rem;background:var(--panel-2);border:1px solid var(--border);border-left:3px solid var(--cyan);border-radius:8px;text-decoration:none;color:inherit;transition:all .15s}
.rel-card:hover{background:var(--panel-hover);border-left-color:var(--accent);transform:translateY(-1px)}
.rel-card.s-crit{border-left-color:var(--critical)}
.rel-card.s-high{border-left-color:var(--high)}
.rel-card.s-mod{border-left-color:var(--moderate)}
.rel-card.s-low{border-left-color:var(--low)}
.rel-row{display:flex;gap:.5rem;align-items:center;flex-wrap:wrap}
.rel-id{font-family:var(--mono);font-size:.72rem;color:var(--accent);font-weight:600}
.rel-meta{font-family:var(--mono);font-size:.62rem;color:var(--dim);margin-top:.2rem;display:flex;gap:.7rem;flex-wrap:wrap}
.rel-msg{font-family:var(--mono);font-size:.7rem;color:var(--muted);margin-top:.25rem;line-height:1.5;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden;word-break:break-word}

.refs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:.55rem;margin-top:.55rem}
.ref-link{display:flex;align-items:center;gap:.6rem;padding:.65rem .8rem;background:var(--panel-2);border:1px solid var(--border);border-left:3px solid var(--cyan);border-radius:8px;text-decoration:none;color:inherit;transition:all .15s;font-family:var(--mono)}
.ref-link:hover{background:var(--panel-hover);border-color:var(--cyan);transform:translateY(-1px)}
.ref-icon{width:26px;height:26px;border-radius:6px;background:var(--cyan-soft);color:var(--cyan);display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:700;flex-shrink:0;letter-spacing:.02em}
.ref-meta{min-width:0;flex:1}
.ref-meta .k{font-size:.58rem;color:var(--dim);letter-spacing:.1em;text-transform:uppercase;font-weight:600;line-height:1}
.ref-meta .v{font-size:.74rem;color:var(--text);font-weight:500;margin-top:.18rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;line-height:1.2}
.ref-link .arr{color:var(--dim);font-size:.85rem;flex-shrink:0}

.diff-summary{display:flex;align-items:center;gap:.8rem;font-family:var(--mono);font-size:.72rem;color:var(--muted);margin-bottom:.6rem;flex-wrap:wrap}
.diff-summary .add{color:var(--low);font-weight:700}
.diff-summary .del{color:var(--critical);font-weight:700}
.diff-summary .files-n{color:var(--accent);font-weight:700}
.diff-summary .truncated{color:var(--moderate);font-weight:600;font-size:.66rem;letter-spacing:.04em;padding:2px 8px;background:rgba(251,191,36,.1);border:1px solid rgba(251,191,36,.32);border-radius:10px}
.diff-loader{padding:1.5rem 1rem;text-align:center;color:var(--dim);font-family:var(--mono);font-size:.72rem;background:var(--panel-2);border:1px solid var(--border);border-radius:8px}
.diff-files{display:flex;flex-direction:column;gap:.55rem}
.diff-file{background:var(--bg-deep);border:1px solid var(--border);border-radius:8px;overflow:hidden}
.diff-file-head{padding:.6rem .85rem;background:var(--panel-2);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:.6rem;flex-wrap:wrap;cursor:pointer;user-select:none;transition:background .15s}
.diff-file-head:hover{background:var(--panel-hover)}
.diff-file-head .chev{font-family:var(--mono);color:var(--dim);font-size:.7rem;width:10px;transition:transform .15s}
.diff-file.collapsed .chev{transform:rotate(-90deg)}
.diff-file.collapsed .diff-file-body{display:none}
.diff-file-path{font-family:var(--mono);font-size:.74rem;color:var(--text);flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-weight:500}
.diff-file-stats{display:flex;gap:.5rem;font-family:var(--mono);font-size:.66rem;font-weight:600;flex-shrink:0}
.diff-file-stats .a{color:var(--low)}
.diff-file-stats .d{color:var(--critical)}
.diff-file-body{font-family:var(--mono);font-size:.7rem;line-height:1.55;overflow-x:auto;background:var(--bg-deep);max-height:520px;overflow-y:auto}
.diff-line{padding:1px .85rem;white-space:pre;min-height:1.2em;display:block;color:var(--muted);border-left:2px solid transparent}
.diff-line.add{background:var(--diff-add);border-left-color:rgba(132,204,22,.5);color:#d9f99d}
.diff-line.del{background:var(--diff-del);border-left-color:rgba(239,68,68,.5);color:#fca5a5}
.diff-line.hunk{background:rgba(99,102,241,.08);color:var(--violet);font-weight:600;border-left-color:rgba(99,102,241,.4)}
.diff-line.meta{color:var(--dim);font-size:.66rem}
.file-truncated{padding:.55rem .85rem;background:rgba(251,191,36,.06);color:var(--moderate);font-family:var(--mono);font-size:.66rem;border-top:1px solid var(--border)}

.file-bar-card{margin-top:.8rem;background:var(--panel-2);border:1px solid var(--border);border-radius:8px;padding:.7rem .9rem}
.file-bar-h{font-family:var(--mono);font-size:.58rem;color:var(--dim);letter-spacing:.1em;text-transform:uppercase;margin-bottom:.55rem;font-weight:600}
.file-bar-row{display:flex;align-items:center;gap:.6rem;margin-bottom:.32rem}
.file-bar-row:last-child{margin-bottom:0}
.file-bar-name{font-family:var(--mono);font-size:.65rem;color:var(--muted);width:35%;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.file-bar-trk{flex:1;display:flex;height:8px;border-radius:4px;overflow:hidden;background:var(--border)}
.file-bar-trk .a{background:linear-gradient(90deg,#84cc16,#CCFF00)}
.file-bar-trk .d{background:linear-gradient(90deg,#fca5a5,#ef4444)}
.file-bar-stats{font-family:var(--mono);font-size:.62rem;font-weight:600;flex-shrink:0;display:flex;gap:.4rem}
.file-bar-stats .a{color:var(--low)}
.file-bar-stats .d{color:var(--critical)}

.tl-card{background:var(--panel-2);border:1px solid var(--border);border-radius:8px;padding:.7rem .9rem;margin-top:.6rem}

footer{text-align:center;padding:2rem 1rem;color:var(--dim);font-family:var(--mono);font-size:.66rem;border-top:1px solid var(--border);margin-top:2rem}
footer a{color:var(--accent)}

.loader-wrap{min-height:60vh;display:flex;align-items:center;justify-content:center;color:var(--accent);font-family:var(--mono);font-size:.85rem}
.loader-wrap::after{content:'';display:inline-block;width:1ch;animation:dots 1.2s steps(4) infinite}
@keyframes dots{0%{content:''}25%{content:'.'}50%{content:'..'}75%{content:'...'}}

.err{padding:3rem 1.5rem;text-align:center;color:var(--critical);font-family:var(--mono);font-size:.85rem;background:var(--panel);border:1px solid rgba(239,68,68,.25);border-radius:12px}
</style>
